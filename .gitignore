# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Validation output (regenerated; evidence records kept selectively)
ontology/reports/*.json
ontology/reports/*.txt
# throwaway ROBOT reason output (inline comments are NOT valid in .gitignore -- keep on own lines)
ontology/reports/_reasoned_*.ttl
# throwaway corpus-merge reason output
ontology/reports/_corpus_reasoned.ttl
!ontology/reports/.gitkeep

# Vendored dependency closure is large; pin + fetch via script, do not commit
vendor/cco/*.ttl
vendor/cco/*.owl
!vendor/cco/README.md

# ROBOT jar (Gate D reasoner, ~82MB); fetch via README, do not commit
tools/robot.jar

# Intermediate per-section data bundles (regeneratable via scripts/stage_section.py)
build/

# Generated ontology docs site (sources are ontology-site.yml + qa/queries/ +
# docs/patterns/; everything below is produced by the webhost generator at build time).
/site/
/mkdocs.yml
/docs/index.md
/docs/qa.md
/docs/ontologies/
/docs/artifacts/
webhost-tool/

# Secrets
.env
*.key
