@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .

####################################################################
# APQC PCF -> BFO 2020 / CCO  REFERENCE TEMPLATE  (v0.2.0)
# Slice 1.1.1 "Analyze the external business environment" (PCF 10017)
#
# v0.2.0 changelog (CCO-conformance pass; every CCO IRI below was
# verified against CommonCoreOntologiesMerged v2.0, 2024-11-06):
#   * Reuse CCO terms instead of local stand-ins:
#       is about            -> cco:ont00001808
#       ICE / Descriptive / Directive ICE -> ont00000958 / 853 / 965
#       Agent / Organization-> cco:ont00001017 / ont00001180
#       has capability      -> cco:ont00001954  (subPropertyOf bearer of)
#       Agent Capability    -> cco:ont00001379
#       has process part    -> cco:ont00001777  (subPropertyOf has occurrent part)
#   * Re-anchor processes under real CCO Act classes:
#       Act of Information Processing  cco:ont00000366  (analysis/identification)
#       Act of Appraisal               cco:ont00000636  (assessment)
#       Act of Planning                cco:ont00000511  (measures / strategy)
#   * Definitions rewritten to strict genus-differentia ("b is a c that d's"),
#     parent named; rdfs:comment + skos:example added to all processes & stubs.
#
# DELIBERATE NON-REUSE (verified): CCO cco:ont00001261 "Act of Identifying"
# is NOT used. Its definition is "An Act of Representative Communication
# performed by asserting who or what a thing is" -- a *communication* act.
# APQC "Identify ..." means *discerning* a concern, which is information
# processing, so ex:ActOfIdentification subclasses cco:ont00000366 instead.
#
# Retained design decisions (unchanged, still correct):
#   (1) APQC dotted hierarchy = process partonomy, not subsumption.
#   (2) The is-a hierarchy is engineered separately from APQC position.
#   (3) Informational inputs/outputs are ICEs (GDCs), attached via
#       has input / has output -- never as roles.
#   (4) Roles inhere only in independent continuants (agents, subjects).
####################################################################

<http://example.org/apqc> a owl:Ontology ;
    dct:title "APQC PCF to BFO/CCO Reference Template: Slice 1.1.1" ;
    dct:source "APQC Process Classification Framework (Cross-Industry)" ;
    owl:versionInfo "0.2.0" ;
    rdfs:comment "Production-oriented module. Imports CCO (which imports BFO 2020). Validate offline by loading CommonCoreOntologiesMerged.ttl alongside this file." .
    # owl:imports <https://www.commoncoreontologies.org/2024-11-06/CommonCoreOntologiesMerged> .

####################################################################
# 0. ANNOTATION PROPERTIES (provenance / traceability)
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

####################################################################
# 1. DOMAIN ACT LAYER  (engineered is-a; thin extensions only where
#    CCO lacks a fitting class)
####################################################################

ex:ActOfAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Analysis" ;
    skos:definition "An Act of Information Processing in which an Agent examines one or more input Information Content Entities and produces an Information Content Entity that represents an understanding of their subject matter." ;
    rdfs:comment "Local extension. CCO 2.0 has no generic analysis class; analysis is information processing (input ICEs manipulated into an output ICE), so it is anchored under cco:ont00000366." .

ex:ActOfIdentification a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Identification (discernment sense)" ;
    skos:definition "An Act of Information Processing in which an Agent discerns and enumerates entities of a given kind and produces an Information Content Entity that registers them." ;
    rdfs:comment "Local extension. NOT cco:ont00001261 'Act of Identifying', which is an Act of Representative Communication (asserting who/what a thing is). APQC 'Identify ...' denotes discernment of concerns, i.e. information processing." .

####################################################################
# 2. REALIZABLES + AGENTS  (decision (4): realizables on independent
#    continuants only; capabilities via CCO has capability)
####################################################################

ex:CompetitiveIntelligenceAnalystRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;   # role
    rdfs:label "Competitive Intelligence Analyst Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with analyzing competitors on behalf of an Organization." .

ex:CompetitorRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Competitor Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of competing with a focal organization in a market." ;
    rdfs:comment "Borne by an independent continuant (the rival Organization), never by the analysis ICE that is about it." .

ex:ManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of exercising managerial authority within an Organization." .

ex:CompetitiveAnalysisCapability a owl:Class ;
    rdfs:subClassOf cco:ont00001379 ,   # Agent Capability
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000054 ;   # realized in
          owl:someValuesFrom ex:AnalyzeCompetitors ] ;
    rdfs:label "Competitive Analysis Capability" ;
    skos:definition "An Agent Capability that is realized in Acts of Analyzing Competitors." ;
    rdfs:comment "Use cco:ont00000568 (Organization Capability) instead where the bearer is specifically an Organization." .

ex:CompetitiveIntelligenceAnalyst a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ;
          owl:onProperty cco:ont00001954 ;   # has capability
          owl:someValuesFrom ex:CompetitiveAnalysisCapability ] ,
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;   # bearer of
          owl:someValuesFrom ex:CompetitiveIntelligenceAnalystRole ] ;
    rdfs:label "Competitive Intelligence Analyst" ;
    skos:definition "An Agent that has a competitive analysis capability and bears a competitive-intelligence analyst role." ;
    rdfs:comment "Narrower than BFO material entity: cco:Agent excludes tools, animals, and arbitrary material objects from being analysts." .

ex:Competitor a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:CompetitorRole ] ;
    rdfs:label "Competitor" ;
    skos:definition "An Organization that bears a competitor role in relation to some focal organization or market." ;
    rdfs:comment "Modeled as Organization per APQC 'competing firms'. Use cco:Agent for individual (non-organizational) competitors." .

ex:ManagementPersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:ManagerRole ] ;
    rdfs:label "Management Personnel" ;
    skos:definition "An Agent that bears a manager role." .

####################################################################
# 3. INPUT INFORMATION CONTENT ENTITIES
#    (genus = Descriptive ICE: each describes a portion of reality)
#    NOTE: production should add per-class skos:example + rdfs:comment;
#    omitted here on the bulk data classes for brevity.
####################################################################

ex:CompetitorData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Competitor Data" ;
    skos:definition "A Descriptive Information Content Entity that describes competitors and their products or services." .

ex:MarketData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Data" ;
    skos:definition "A Descriptive Information Content Entity that describes features of a market." .

ex:MacroeconomicData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Macroeconomic Data" ;
    skos:definition "A Descriptive Information Content Entity that describes macroeconomic indicators such as interest rates, taxation, commodity prices, and unemployment." .

ex:RegulatoryData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Data" ;
    skos:definition "A Descriptive Information Content Entity that describes public-policy and regulatory measures issued by sovereign or multinational authorities." .

ex:EcologicalData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Ecological Data" ;
    skos:definition "A Descriptive Information Content Entity that describes ecological factors and shifts relevant to an organization." .

ex:SocioculturalData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sociocultural Data" ;
    skos:definition "A Descriptive Information Content Entity that describes societal composition, distribution, and value systems." .

ex:TechnologyData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Technology Data" ;
    skos:definition "A Descriptive Information Content Entity that describes deployed, emerging, and disruptive technologies." .

ex:DemographicData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Demographic Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the size, distribution, and composition of populations." .

ex:ResearchPublication a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Research Publication" ;
    skos:definition "A Descriptive Information Content Entity published as a report, brief, or article and used as analytic input." .

####################################################################
# 4. OUTPUT INFORMATION CONTENT ENTITIES
#    Descriptive ICE (ont00000853) for representations/judgements;
#    Directive ICE (ont00000965) for prescriptions/decisions.
####################################################################

ex:ExternalEnvironmentAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "External Environment Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a big-picture understanding of an organization's external environment." ;
    skos:example "A strategy team's annual environmental scan report." .

ex:CompetitorAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ;
          owl:onProperty cco:ont00001808 ;   # is about
          owl:someValuesFrom ex:Competitor ] ;
    rdfs:label "Competitor Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes one or more competitors with respect to their strengths and weaknesses relative to a focal organization." ;
    rdfs:comment "Descriptive (not Directive) because it represents competitors rather than prescribing a course of action." ;
    skos:example "A report comparing two competitors' pricing, product capabilities, and market position." .

ex:CompetitiveForcesAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Competitive Forces Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the competitive forces in a marketplace." .

ex:CompetitiveBenchmark a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Competitive Benchmark" ;
    skos:definition "A Descriptive Information Content Entity that describes a juxtaposition of processes and performance metrics against competitors." .

ex:SubstitutionBusinessCase a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Substitution Business Case" ;
    skos:definition "A Descriptive Information Content Entity that describes an argument for or against a course of action in light of substitute products or services." .

ex:GoNoGoDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Go/No-Go Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes whether to proceed or not proceed with a course of action." ;
    rdfs:comment "Directive (not Descriptive) because a decision prescribes rather than describes." .

ex:MacroeconomicTrendAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Macroeconomic Trend Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes medium- to long-term macroeconomic shifts relevant to an organization." .

ex:RegulatoryConcernRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Concern Register" ;
    skos:definition "A Descriptive Information Content Entity that describes identified public-policy and regulatory concerns." .

ex:EcologicalConcernRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Ecological Concern Register" ;
    skos:definition "A Descriptive Information Content Entity that describes identified ecological concerns." .

ex:SocioculturalShiftAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sociocultural Shift Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes shifts in societal makeup and cultural composition." .

ex:TechnologyAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Technology Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of current, emerging, and disruptive technologies." .

ex:DemographicAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Demographic Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the size, distribution, and composition of relevant populations." .

ex:IPThreatMeasureSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "IP Threat Measure Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes measures and procedures for identifying intellectual-property threats." ;
    skos:example "A documented procedure listing IP-threat indicators and the steps to screen for them." .

####################################################################
# 5. PARENT PROCESS  --  1.1.1  (PCF 10017)
#    Partonomy via cco:has process part (ont00001777).
####################################################################

ex:AnalyzeExternalBusinessEnvironment a owl:Class ;
    ex:pcfID "10017" ;
    ex:hierarchyID "1.1.1" ;
    ex:apqcSourceText "Assessing all forces, entities, and systems that are external to an organization but can affect its operation. Analyze far-reaching currents in the macroeconomic situation, assess the competition, evaluate technological changes, and identify societal as well as ecological issues of concern. Create a big-picture understanding of externalities, with sufficient depth across individual aspects." ;
    rdfs:label "Analyze the external business environment" ;
    skos:definition "An Act of Analysis that examines the external forces, entities, and systems bearing on an organization and produces an external-environment assessment." ;
    rdfs:comment "Models APQC process 1.1.1 as an occurrent. Its APQC children are process parts, not subclasses." ;
    skos:example "An organization's yearly strategic environmental scan culminating in an external-environment assessment." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExternalEnvironmentAssessment ] ,
        # --- APQC dotted children = PROCESS PARTS (cco:has process part) ---
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:AnalyzeCompetitors ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:AssessMarketplaceCompetitiveForces ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:EvaluateSubstituteProducts ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:DetermineMacroeconomicTrends ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:IdentifyRegulatoryConcerns ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:IdentifyEcologicalConcerns ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:DistinguishSocioculturalShifts ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:AssessTechnologyDevelopments ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:AnalyzeDemographics ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:EstablishIPThreatMeasures ] .

####################################################################
# 6. CHILD PROCESSES  --  1.1.1.1 ... 1.1.1.10
#    Anchored to the appropriate CCO Act class per their genus.
####################################################################

# --- 1.1.1.1 (PCF 19945) : Analysis -- FULL SHOWCASE
ex:AnalyzeCompetitors a owl:Class ;
    ex:pcfID "19945" ; ex:hierarchyID "1.1.1.1" ;
    ex:apqcSourceText "Identifying your competitors, their service and/or product. Evaluating competitors strategies to determine their strengths and weaknesses relative to those of your own product or service." ;
    rdfs:label "Analyze competitors" ;
    skos:definition "An Act of Analysis that has as input competitor data and has as output a competitor analysis about one or more competitors." ;
    rdfs:comment "Represents APQC 1.1.1.1 as an occurrent, not as the analysis artifact (that is ex:CompetitorAnalysis) nor an organizational function." ;
    skos:example "A competitive-intelligence team reviews market reports and produces a competitor analysis for strategic planning." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CompetitorData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetitorAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:CompetitiveIntelligenceAnalyst ] .

# --- 1.1.1.2 (PCF 10021) : Assessment -> cco:Act of Appraisal; multi-output
ex:AssessMarketplaceCompetitiveForces a owl:Class ;
    ex:pcfID "10021" ; ex:hierarchyID "1.1.1.2" ;
    ex:apqcSourceText "Assessing the competitive forces in the marketplace that could potentially affect the organization. Analyze various aspects of business competition including competing firms. Aggregate competitive intelligence, create benchmarks to juxtapose processes and performance metrics, and inject crucial information about the competition into management models to synthesize insights." ;
    rdfs:label "Assess marketplace competitive forces" ;
    skos:definition "An Act of Appraisal that has as input competitor data and market data and has as output a competitive-forces assessment and competitive benchmarks." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal) because the act evaluates and judges competitive forces." ;
    skos:example "An analyst benchmarks rivals and issues an assessment of the competitive forces in the sector." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CompetitorData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetitiveForcesAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetitiveBenchmark ] .

# --- 1.1.1.3 (PCF 21421) : Assessment culminating in a decision (dual output)
ex:EvaluateSubstituteProducts a owl:Class ;
    ex:pcfID "21421" ; ex:hierarchyID "1.1.1.3" ;
    ex:apqcSourceText "Examining if there are other existing products or services in the marketplace, and building the business case to make a go/no go decision based upon substitutions." ;
    rdfs:label "Evaluate substitute products and services" ;
    skos:definition "An Act of Appraisal that has as input market data and has as output a substitution business case and a go/no-go decision." ;
    rdfs:comment "Output includes both a Descriptive ICE (the business case) and a Directive ICE (the decision)." ;
    skos:example "A product team appraises a substitute on the market and recommends a no-go decision." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SubstitutionBusinessCase ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GoNoGoDecision ] .

# --- 1.1.1.4 (PCF 10022) : Analysis
ex:DetermineMacroeconomicTrends a owl:Class ;
    ex:pcfID "10022" ; ex:hierarchyID "1.1.1.4" ;
    ex:apqcSourceText "Determining large-scale macroeconomic shifts and trends, with medium to long-term relevance for the organization. Vet the immediate and the larger economic ecosystem to identify broad-based movements that affect the organization." ;
    rdfs:label "Determine macroeconomic trends" ;
    skos:definition "An Act of Analysis that has as input macroeconomic data and has as output a macroeconomic trend analysis." ;
    skos:example "An economist reviews indicators and reports the trends likely to affect the firm over five years." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MacroeconomicData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MacroeconomicTrendAnalysis ] .

# --- 1.1.1.5 (PCF 10023) : Identification (discernment sense)
ex:IdentifyRegulatoryConcerns a owl:Class ;
    ex:pcfID "10023" ; ex:hierarchyID "1.1.1.5" ;
    ex:apqcSourceText "Identifying areas of concern pertaining to public policy and regulation, established by sovereign or multinational authorities. Examine various regions and geopolitical formations to identify those political and regulatory issues that can potentially affect the organization." ;
    rdfs:label "Identify regulatory concerns" ;
    skos:definition "An Act of Identification that has as input regulatory data and has as output a regulatory concern register." ;
    skos:example "A compliance team screens jurisdictions and registers the regulatory changes that bear on the firm." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryConcernRegister ] .

# --- 1.1.1.6 (PCF 10027) : Identification (two inputs)
ex:IdentifyEcologicalConcerns a owl:Class ;
    ex:pcfID "10027" ; ex:hierarchyID "1.1.1.6" ;
    ex:apqcSourceText "Identifying changes in ecological ecosystems that can be directly or indirectly detrimental to the organization. Analyze ecological factors within the immediate ecosystem for near to middle-term impact. Gather analyses from research publications. Speak to subject matter experts." ;
    rdfs:label "Identify ecological concerns" ;
    skos:definition "An Act of Identification that has as input ecological data and research publications and has as output an ecological concern register." ;
    skos:example "An ESG analyst registers ecological risks drawn from scientific publications and expert input." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EcologicalData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ResearchPublication ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EcologicalConcernRegister ] .

# --- 1.1.1.7 (PCF 10026) : Identification ("distinguish")
ex:DistinguishSocioculturalShifts a owl:Class ;
    ex:pcfID "10026" ; ex:hierarchyID "1.1.1.7" ;
    ex:apqcSourceText "Distinguishing changes in societal makeup, as well as the cultural composite. Isolate shifts in the societal composition and distribution, as well as the value systems and attributes that bind the organization together." ;
    rdfs:label "Distinguish sociocultural shifts" ;
    skos:definition "An Act of Identification that has as input sociocultural data and has as output a sociocultural shift analysis." ;
    skos:example "A market researcher distinguishes generational value shifts relevant to the brand." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SocioculturalData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SocioculturalShiftAnalysis ] .

# --- 1.1.1.8 (PCF 10024) : Assessment + PARTICIPANT SHOWCASE (named agent)
ex:AssessTechnologyDevelopments a owl:Class ;
    ex:pcfID "10024" ; ex:hierarchyID "1.1.1.8" ;
    ex:apqcSourceText "Assessing developments in technologies presently being used by the business, new technologies that have a potential for the business, and any disruptive innovations. Arrange for mid- to senior-level management personnel who explore contingent uses to assess new and disruptive technologies." ;
    rdfs:label "Assess technology developments" ;
    skos:definition "An Act of Appraisal that has as input technology data, has as output a technology assessment, and has management personnel as participant." ;
    skos:example "Senior managers appraise an emerging technology and issue a technology assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TechnologyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TechnologyAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ManagementPersonnel ] .

# --- 1.1.1.9 (PCF 10025) : Analysis
ex:AnalyzeDemographics a owl:Class ;
    ex:pcfID "10025" ; ex:hierarchyID "1.1.1.9" ;
    ex:apqcSourceText "Analyzing statistical data relating to the size, distribution, and composition of relevant populations, as well as their characteristics. Perform quantitative analysis over raw data-sets gathered from well-founded sources such as government census or large, private databases." ;
    rdfs:label "Analyze demographics" ;
    skos:definition "An Act of Analysis that has as input demographic data and has as output a demographic analysis." ;
    skos:example "A team analyzes census data and produces a demographic profile of a target market." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DemographicData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DemographicAnalysis ] .

# --- 1.1.1.10 (PCF 16790) : Establishing measures -> cco:Act of Planning; Directive ICE output
ex:EstablishIPThreatMeasures a owl:Class ;
    ex:pcfID "16790" ; ex:hierarchyID "1.1.1.10" ;
    ex:apqcSourceText "Establishing measures and procedures for identifying various intellectual property threats and concerns." ;
    rdfs:label "Establish IP threat measures" ;
    skos:definition "An Act of Planning that has as output an IP threat measure specification prescribing procedures for identifying intellectual-property threats." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): it makes a plan/procedure (a Directive ICE) to achieve an objective." ;
    skos:example "Legal counsel establishes a procedure for screening incoming filings for IP-infringement risk." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IPThreatMeasureSpecification ] .

####################################################################
# 7. UPWARD SCAFFOLDING  --  attachment to parents (now with definitions)
####################################################################

ex:DefineBusinessConcept a owl:Class ;
    ex:pcfID "17040" ; ex:hierarchyID "1.1" ;
    rdfs:label "Define a business concept and long-term vision" ;
    skos:definition "An Act of Planning that creates a conceptual framework of an organization's business activity and strategic vision with long-term applicability." ;
    rdfs:comment "STUB. Recurse the parent->child cco:has process part pattern for its other children (1.1.2 - 1.1.5)." ;
    skos:example "An executive team defines the firm's ten-year strategic vision." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:AnalyzeExternalBusinessEnvironment ] .

ex:DevelopVisionAndStrategy a owl:Class ;
    ex:pcfID "10002" ; ex:hierarchyID "1" ;
    rdfs:label "Develop Vision and Strategy" ;
    skos:definition "An Act of Planning that establishes a direction and vision for an organization, comprising the definition of its business concept and the development of its business strategy." ;
    rdfs:comment "STUB + OPEN DECISION: an APQC Category may have no single instance (it is a curatorial aggregate). Either model it as a process whose instances have all group-level processes as process parts (done here), or demote it to a grouping and begin real process classes at the Process-Group level. Choose once; it sets the pattern for all 13 categories." ;
    skos:example "An organization's end-to-end strategic-planning cycle for a fiscal year." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:DefineBusinessConcept ] .

####################################################################
# 8. FLOW / PRECEDENCE  (decision (7))
#    The ten children of 1.1.1 are PARALLEL FACETS of one scan; no
#    precedence is asserted among them. Assert precedence only where the
#    source text licenses it (cross-references / "feeds into"). Template:
#
# ex:AnalyzeExternalBusinessEnvironment rdfs:subClassOf
#     [ a owl:Restriction ; owl:onProperty obo:BFO_0000063 ;   # precedes
#       owl:someValuesFrom ex:DefineBusinessConcept ] .
