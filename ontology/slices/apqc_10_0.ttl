@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC PCF -> BFO 2020 / CCO 2.0  REALITY-LAYER MODULE
# Section 10.0 "Acquire, Construct, and Manage Assets"
#
# Assembled from the four process-group transforms (10.1, 10.2, 10.3,
# 10.4) plus the shared section-10.0 supporting vocabulary. House style
# mirrors the GOLD reference ontology/slices/apqc_1_1_1.ttl. Every
# cco:ont... IRI was verified (label + definition + parent) against
# vendor/cco/CommonCoreOntologiesMerged.ttl (CCO v2.0, 2024-11-06).
#
# RECONCILIATION NOTES (duplicate IRIs across the four group drafts
# collapsed to one coherent definition each):
#   * ex:ActOfMonitoring -- the four drafts anchored it variously under
#     cco:ont00000037 (Act of Observation) and cco:ont00000366 (Act of
#     Information Processing). RECONCILED to cco:ont00000366: monitoring
#     receives repeated observations and yields a DESCRIPTIVE status ICE
#     (GOLDEN PRINCIPLE), and the dominant usage across 10.2/10.3/10.4
#     uses 366. (cco:ont00000037 rejected: a single sensory acquisition,
#     not sustained criterion-referenced information processing.)
#   * ex:ActOfDisposition -- drafts anchored it under cco:ont00000908
#     (Act of Material Artifact Processing) and cco:ont00000228 (Planned
#     Act). RECONCILED to cco:ont00000228: 10.4 applies the genus to
#     ownership transfer (sale/trade) and waste-stream removal, which do
#     not always physically process a material artifact, so the broader
#     Planned Act is the only coherent genus. (908 rejected as too narrow
#     for sale/abandonment; 950 Maintenance and 970 Modification rejected
#     because disposition removes from service rather than preserving or
#     altering qualities.)
#   * ex:DispositionNeedRegister, ex:ReprocessingRecord,
#     ex:RecoveredMaterial -- minted once (10.4); duplicate copies merged.
#   * ex:MarketData reused from the shared section-10.0 vocabulary
#     (single definition here).
#
# Two-layer (ADR-001): reality layer only; no skos:broader / skos:Concept.
####################################################################

<http://example.org/apqc/slice/10.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 10.0: Acquire, Construct, and Manage Assets" ;
    dct:source "APQC Process Classification Framework (Cross-Industry)" ;
    owl:versionInfo "0.3.0" ;
    rdfs:comment "Reality-layer BFO 2020 / CCO 2.0 module for APQC section 10.0. CCO pin: v2.0 (2024-11-06). Modeling decisions per ADR-001 (two-layer model; R5 bounded-occurrent test; GOLDEN PRINCIPLE genus<->output agreement). Self-contained: the shared act genera it uses are inlined from the apqc-ext.ttl registry, so it validates standalone against the pinned CCO/BFO closure with no extension merge." .

####################################################################
# ACT GENERA -- SELF-CONTAINED (canonical defs mirrored from
# apqc-ext.ttl, the D9 shared registry). Inlined so this module
# validates standalone against CCO without merging the extension.
####################################################################

ex:ActOfAcquisition a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Acquisition" ;
    skos:definition "A Planned Act in which an Agent obtains from some authority or supplier an entity (such as an authorization, license, or resource) that the Agent did not previously hold." ;
    rdfs:comment "Local extension (D9). Rejected cco:ont00000950 'Act of Maintenance' (modifying Material Artifacts) and cco:ont00000402 'Act of Communication' (mere ICE transfer). Securing/obtaining a held entity anchors at the generic Planned Act. Expected to recur in procurement/asset-acquisition categories (4.0, 10.0)." .

ex:ActOfAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Analysis" ;
    skos:definition "An Act of Information Processing in which an Agent examines one or more input Information Content Entities and produces an Information Content Entity that represents an understanding of their subject matter." ;
    rdfs:comment "Local extension (D9). CCO 2.0 has no generic analysis class; analysis is information processing, so it is anchored under cco:ont00000366." .

ex:ActOfDisposition a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Disposition" ;
    skos:definition "A Planned Act in which an Agent removes an asset or portion of material from active service, ownership, or possession at its end-of-life by retiring, selling, dismantling, recycling, abandoning, or otherwise applying a terminal disposition to it or its parts in accordance with applicable requirements." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic disposal/disposition Act. Anchored at the generic cco:ont00000228 (Planned Act) because disposition spans physical destruction/recycling AND ownership transfer (sale/trade) AND waste-stream removal -- not all of which physically process a material artifact. Rejected cco:ont00000908 (Act of Material Artifact Processing: too narrow -- excludes sale/abandonment), cco:ont00000950 (Act of Maintenance: preserves/restores Qualities, the opposite of retiring an asset), and cco:ont00000970 (Act of Artifact Modification: changes an artifact's qualities, not its service/ownership status). Recurs across asset end-of-life: decommission, sale/trade, recycle, abandonment, hazardous-material/waste disposition (10.0)." .

ex:ActOfFormulation a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Formulation" ;
    skos:definition "An Act of Planning in which an Agent composes and articulates a Directive Information Content Entity - such as a mission, strategy, objective, design, roadmap, or business model - that prescribes an organization's intended course of action." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000511 (Act of Planning) because formulating a strategy/mission/design is making a plan to achieve an objective; its output is a Directive ICE. Recurs across develop/define/compose-a-directive processes corpus-wide." .

ex:ActOfIdentification a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Identification (discernment sense)" ;
    skos:definition "An Act of Information Processing in which an Agent discerns and enumerates entities of a given kind and produces an Information Content Entity that registers them." ;
    rdfs:comment "Local extension (D9). NOT cco:ont00001261 'Act of Identifying' (a communication act). APQC 'Identify ...' denotes discernment, i.e. information processing." .

ex:ActOfMonitoring a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Monitoring" ;
    skos:definition "An Act of Information Processing in which an Agent repeatedly or continuously observes the state, progress, or performance of some process, system, or quantity over time and produces a Descriptive Information Content Entity that represents its tracked status against expected conditions, targets, or requirements." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic monitoring/tracking class. Anchored under cco:ont00000366 (Act of Information Processing) because monitoring ingests repeated observations (including electronic records, not only senses) and yields a descriptive status/deviation ICE -- the GOLDEN PRINCIPLE (descriptive output => information-processing genus) holds. Rejected cco:ont00000037 (Act of Observation: a single sense-based acquisition, too narrow -- monitoring also processes ICEs and is sustained); cco:ont00000636 (Act of Appraisal: renders a single bounded value/quality judgement rather than tracking status over time); and cco:ont00000345 (Act of Measuring: a single quantification against a standard at one time -- at most a method sub-step of the monitoring cycle; a node that is purely one quantification, e.g. Calculate performance measures, anchors to cco:ont00000345 directly, not here). Distinct from ex:ActOfAnalysis (one-shot examination of a fixed input set) by its continuous, longitudinal character. A standing 'Manage/Monitor X' function with no natural end is an Organization Capability (cco:ont00000568) realized in such acts, not itself a process. Recurs corpus-wide (slices 3.0/4.0/5.0/6.0/8.0/9.0/10.0/11.0/12.0/13.0). Reconciled from 10 divergent slice restatements to one definition." .

ex:ActOfNegotiation a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Negotiation" ;
    skos:definition "A Planned Act in which two or more Agents confer and bargain over terms and conditions, exchanging proposals and concessions, in order to reach and record a mutually binding Directive Information Content Entity such as an agreement or contract." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000228 (Planned Act): negotiation is two or more agents conferring and bargaining over terms to reach a mutually binding directive (an agreement or contract). Rejected cco:ont00001327 (Social Act) as too generic; Act of Contract Formation (cco:ont00000684) models only the consummating promise, narrower than the bargaining process." .

ex:ActOfSelection a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Selection" ;
    skos:definition "An Act of Information Processing in which an Agent chooses one or more options from a set of candidates and produces a Directive Information Content Entity that prescribes the chosen option(s)." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000366 (Act of Information Processing): receives candidate-option ICEs and yields a decision ICE. Distinct from Act of Appraisal (judges without committing) and Act of Planning. NOTE: ratifying a single already-settled option is NOT selection (no candidate set) -- anchor such acts at cco:ont00000228 (Planned Act)." .

####################################################################
# 0. PROVENANCE ANNOTATION PROPERTIES
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "Catalog->reality bridge. Links an APQC catalog node (ex:PCF_<pcfID>) to the reality-layer class (process, capability) that it designates." .

####################################################################
# 1. PROPOSE-EXT: promote to apqc-ext.ttl after review
#    New recurring act genera needed corpus-wide. Minted locally here
#    and flagged for human promotion (D9). Declared ONCE.
####################################################################

####################################################################
# 2. SHARED SUPPORTING VOCABULARY (section 10.0)
#    ICEs / material entities / agents / roles / capabilities reused by
#    every 10.x group. Every cco:ont... IRI verified against the vendored
#    CommonCoreOntologiesMerged.ttl. No process classes in this section.
#
#    Verified reuse anchors:
#      Descriptive ICE   cco:ont00000853   ("Descriptive Information Content Entity")
#      Directive ICE     cco:ont00000965   ("Prescriptive Information Content Entity")
#      is about          cco:ont00001808
#      Agent             cco:ont00001017
#      Organization      cco:ont00001180
#      Agent Capability  cco:ont00001379
#      Organization Cap. cco:ont00000568
#      has capability    cco:ont00001954
#      Facility          cco:ont00000192
#      Material Artifact cco:ont00000995
#      Portion of Waste Material cco:ont00000980
#      role obo:BFO_0000023 ; bearer of obo:BFO_0000196 ;
#      realized in obo:BFO_0000054 ; material entity obo:BFO_0000040 ;
#      has participant obo:BFO_0000057
####################################################################

# --- 2a. DESCRIPTIVE ICEs (cco:ont00000853) ---

ex:BusinessStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Business Strategy" ;
    skos:definition "A Descriptive Information Content Entity that describes an organization's overall direction, goals, and competitive positioning, used as a reference against which asset requirements are aligned." ;
    rdfs:comment "Shared input across 10.0 (e.g. confirm property requirements align with business strategy). Modeled as Descriptive (a standing reference document) rather than Directive; the prescriptive strategy artifacts produced within 10.0 are typed separately (e.g. ex:PropertyStrategy, ex:ConstructionStrategy)." .

ex:ExternalEnvironmentAppraisal a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "External Environment Appraisal" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the external circumstances, objects, events, and aspects surrounding an organization that affect its asset decisions, including opportunities and risks." .

ex:MarketData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Data" ;
    skos:definition "A Descriptive Information Content Entity that describes features of a market, such as property prices, construction costs, and supply conditions." ;
    rdfs:comment "Shared input for build/buy/lease and property-selection appraisals across 10.1 and 10.2." .

ex:BudgetAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Budget Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the feasibility of a budget prepared for construction or acquisition." .

ex:Budget a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Budget" ;
    skos:definition "A Descriptive Information Content Entity that describes the planned allocation of funds for a project or program." ;
    rdfs:comment "Input to budget-feasibility and capital-program work. Modeled Descriptive (a financial statement of planned figures); the prescriptive commitment of funds is captured by ex:CapitalInvestmentPlan." .

ex:CapitalProgramReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Capital Program Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the status, progress, and variances of a capital program against its plan." ;
    rdfs:comment "Output of monitoring acts (proposed ex:ActOfMonitoring)." .

ex:WorkPerformanceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Work Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the observed timeliness, regulatory compliance, and quality of construction or maintenance work." ;
    rdfs:comment "Shared monitoring output across 10.2 and 10.3." .

ex:QualityControlReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Quality Control Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the results of verifying that construction or maintenance work was performed correctly, including any errors found and rework required." .

ex:WorkAndAssetRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductiveAsset ] ;
    rdfs:label "Work and Asset Record" ;
    skos:definition "A Descriptive Information Content Entity, about an asset, that records the construction or maintenance work performed on it, the assets serviced, and any issues that arose." ;
    rdfs:comment "Shared record across 10.2.4.3 (create) and 10.3.2.4 (update). Descriptive: a record of past events." .

ex:MaintenanceRequirementsForecast a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductiveAsset ] ;
    rdfs:label "Maintenance Requirements Forecast" ;
    skos:definition "A Descriptive Information Content Entity, about an asset, that describes a projection of that asset's future maintenance requirements based on its present working condition." ;
    rdfs:comment "Descriptive: it represents projected requirements (an analysis/prediction), not a prescription." .

ex:MaintenancePerformanceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Maintenance Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the organization's measured success in meeting maintenance performance targets and contractual obligations." .

ex:SafetyComplianceRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Safety Compliance Record" ;
    skos:definition "A Descriptive Information Content Entity that records that safety, security, and access controls at a work site conform to applicable laws, regulations, and organizational guidelines." ;
    rdfs:comment "Shared across 10.2.4.4 (sites) and 10.3.2.5 (maintenance work safety)." .

ex:UsefulLifeAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductiveAsset ] ;
    rdfs:label "Useful Life Assessment" ;
    skos:definition "A Descriptive Information Content Entity, about an asset, that describes the asset's status against its planned useful life using criteria such as age, maintenance history, and capacity." .

ex:CostBenefitAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductiveAsset ] ;
    rdfs:label "Cost-Benefit Analysis" ;
    skos:definition "A Descriptive Information Content Entity, about an asset, that describes a comparison of the asset's total lifecycle cost against repair, refurbishment, replacement, and alternative-solution options to inform retention or end-of-life decisions." .

ex:ReplacementNeedAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductiveAsset ] ;
    rdfs:label "Replacement Need Assessment" ;
    skos:definition "A Descriptive Information Content Entity, about an asset, that describes a judgement of whether the asset needs to be renewed or replaced." ;
    rdfs:comment "Minted (Gate-F) as the descriptive output of 10.2.3.5 (ex:P19234) once its lead act is correctly read as a determination/appraisal ('Determining the need to replace existing assets'), not a build. Descriptive (a judgement), satisfying the GOLDEN PRINCIPLE for an Act of Appraisal." ;
    skos:example "An engineer's finding that a worn machine has reached the point where replacement is warranted." .

ex:PartTrackingRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:AssetPart ] ;
    rdfs:label "Part Tracking Record" ;
    skos:definition "A Descriptive Information Content Entity, about the parts of end-of-life assets, that records each part's source, rationale for disposition, and destination as an audit trail." .

ex:GovernmentReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Government Report" ;
    skos:definition "A Descriptive Information Content Entity prepared for and distributed to a government authority that describes regulated aspects of an organization's asset and material activities." .

ex:MaterialSafetyDataSheet a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:HazardousMaterial ] ;
    rdfs:label "Material Safety Data Sheet" ;
    skos:definition "A Descriptive Information Content Entity, about a hazardous material, that records the safety properties and required handling and disposal information for that material." ;
    rdfs:comment "Descriptive: an MSDS records material properties; the handling requirements it cites are described, not authored, by it." .

ex:ComplianceAuditReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Compliance Audit Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the findings of an audit of hazardous-material handling, disposal, and reporting practices against regulatory requirements." .

ex:DispositionRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Disposition and Disposal Record" ;
    skos:definition "A Descriptive Information Content Entity that records the disposition, disposal, and reprocessing activities performed on hazardous materials and waste." .

ex:SiteStatusReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Site Status Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the status of an abandoned or remediated site for the duration required by regulators." .

ex:RegulatoryRequirementsBriefing a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Requirements Briefing" ;
    skos:definition "A Descriptive Information Content Entity that gives an account, to the personnel responsible for compliance, of the hazardous-material regulatory requirements they must follow." ;
    rdfs:comment "Minted (Gate-F) as the DESCRIPTIVE product of the communication act 10.4.11.2 (ex:P12181), which relays externally-authored regulatory requirements. Descriptive (an account/statement given by a reporting act), matching the Act-of-Reporting genus per the GOLDEN PRINCIPLE; the Directive ex:RegulatoryRequirementsStatement is the communicated content (has input), not a product of this act." ;
    skos:example "A briefing note summarizing updated transport rules for corrosives for the disposal team." .

ex:AssetHandoverDocumentation a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductiveAsset ] ;
    rdfs:label "Asset Handover Documentation" ;
    skos:definition "A Descriptive Information Content Entity, about an asset, that documents the asset's history and current state to enable an orderly handover to a new operator or landowner." .

ex:DispositionNeedRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Disposition Need Register" ;
    skos:definition "A Descriptive Information Content Entity that records identified hazardous materials or waste recognized as requiring disposition, together with the rationale for that need." ;
    skos:example "A flagged list of expired solvents and contaminated rags awaiting a disposal determination." .

ex:ReprocessingRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Reprocessing and Disposal Activity Record" ;
    skos:definition "A Descriptive Information Content Entity that documents the disposition, disposal, and reprocessing activities performed on hazardous materials or waste." ;
    skos:example "A logged record of a batch of solvent sent for reprocessing, with quantities, handler, and destination." .

ex:PropertyAlignmentAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Property Alignment Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the degree to which an organization's property requirements are consistent with its business strategy." ;
    rdfs:comment "Minted because the section-10.0 shared vocabulary has no output ICE for the 'confirm alignment' appraisal (10.1.1.1). Descriptive (not Directive) because it represents a judgement of consistency rather than prescribing an action." ;
    skos:example "A one-page sign-off noting that the requested space matches the firm's expansion plan." .

# --- 2b. DIRECTIVE ICEs (cco:ont00000965) ---

ex:PropertyRequirementsSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Property Requirements Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the property, facility, and workspace requirements an organization must satisfy." ;
    rdfs:comment "Directive: it states required conditions that candidate properties/facilities must meet, not a description of a portion of reality." .

ex:BuildBuyLeaseDecision a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:RealProperty ] ;
    rdfs:label "Build/Buy/Lease Decision" ;
    skos:definition "A Directive Information Content Entity, about a property, that prescribes whether the organization will build, buy, or lease that property." ;
    rdfs:comment "Directive: a decision that authorizes/selects a future course of action (acquisition mode). Distinct from a mere decision record." .

ex:FacilityDesign a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Facility ] ;
    rdfs:label "Facility Design" ;
    skos:definition "A Directive Information Content Entity, about a facility, that prescribes the configuration, layout, and specifications of that facility to be built or modified." ;
    rdfs:comment "Directive (a blueprint/specification prescribing how the facility shall be realized), per CCO's Directive-ICE elucidation citing blueprints." .

ex:AssetDesign a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductiveAsset ] ;
    rdfs:label "Asset Design" ;
    skos:definition "A Directive Information Content Entity, about a productive asset, that prescribes the specifications of that asset and the construction codes it must satisfy." .

ex:FacilityTermsAgreement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Facility Terms Agreement" ;
    skos:definition "A Directive Information Content Entity that prescribes the negotiated terms and conditions under which a facility is to be occupied or used." ;
    rdfs:comment "Directive: a contract/agreement prescribes the obligations of the parties." .

ex:CapitalInvestmentPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Capital Investment Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes what funds will be invested in the construction or acquisition of productive assets in pursuit of established business objectives." ;
    rdfs:comment "Directive (a plan that prescribes intended investment acts). Output of Act of Planning / Formulation." .

ex:ConstructionFinancing a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Construction Financing Arrangement" ;
    skos:definition "A Directive Information Content Entity, such as a loan agreement, that prescribes the terms under which funds are provided to construct necessary assets." ;
    rdfs:comment "Output of an acquisition act (securing financing). Directive because a financing agreement prescribes obligations." .

ex:ConstructionStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Construction Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes the approach for performing asset construction so that timelines, regulations, resources, and budget are met." ;
    rdfs:comment "Directive (a strategy prescribing intended course of action); output of Act of Formulation." .

ex:PropertyStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Property Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes a long-term vision and approach for managing an organization's purchased and retained properties." ;
    rdfs:comment "Directive; output of Act of Formulation (develop property strategy and long-term vision)." .

ex:ConstructionPermit a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Construction Permit" ;
    skos:definition "A Directive Information Content Entity, issued by a jurisdiction, that authorizes and prescribes conditions for performing construction work on an asset." ;
    rdfs:comment "Directive: a permit authorizes future action under stated conditions. Obtained via an acquisition act (ex:ActOfAcquisition)." .

ex:ConstructionResourcePlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Construction Resource Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes which resources will be acquired for construction, and when, where, how, and for how long they will be used." .

ex:ConstructionSchedule a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Construction Schedule" ;
    skos:definition "A Directive Information Content Entity that prescribes a timetable for executing the construction of an asset." ;
    rdfs:comment "Directive (a schedule prescribes when intended acts occur)." .

ex:MaintenanceSchedule a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Maintenance Schedule" ;
    skos:definition "A Directive Information Content Entity that prescribes a timetable for executing the maintenance of an asset." .

ex:MaintenanceStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Maintenance Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes goals and agendas for realizing an organization's asset-maintenance policies." .

ex:MaintenancePolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Maintenance Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the procedures and policies governing how asset maintenance is to be carried out." ;
    rdfs:comment "Directive (a policy prescribes required/permitted action)." .

ex:WorkPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Work Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the procedures by which productive assets are to be maintained." .

ex:WorkTaskList a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Work Task List" ;
    skos:definition "A Directive Information Content Entity that prescribes the prioritized set of tasks required to complete asset-maintenance work." ;
    rdfs:comment "Directive: a prioritized task list prescribes the acts to be performed and their ordering." .

ex:ResourcePlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Resource Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the resources to be allocated to a body of work in light of analyzed workload needs." .

ex:MaintenancePerformanceTarget a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Maintenance Performance Target" ;
    skos:definition "A Directive Information Content Entity that prescribes the predictive indicators and target levels to be achieved in performing maintenance." ;
    rdfs:comment "Directive: a target prescribes an intended state to be achieved (cf. CCO Objective)." .

ex:AssetExitStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Asset Exit Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's approach for managing the end-of-life exit of its assets." .

ex:DispositionDecision a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductiveAsset ] ;
    rdfs:label "Asset Disposition Decision" ;
    skos:definition "A Directive Information Content Entity, about an asset or part, that prescribes the disposition to be applied to it at end-of-life, such as retention, resale, reuse, recycling, or disposal." ;
    rdfs:comment "Directive: a decision that selects and authorizes a future disposition. Shared across 10.4 (take-back centers, dismantling, waste disposition)." .

ex:RegulatoryRequirementsStatement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Regulatory Requirements Statement" ;
    skos:definition "A Directive Information Content Entity that prescribes the regulatory requirements applicable to hazardous-material handling, disposal, and reporting." ;
    rdfs:comment "Directive: it conveys externally-authored prescriptions that the organization must satisfy and communicate." .

ex:PropertySelectionDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Property Selection Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes which property, among the reviewed options, an organization will acquire or occupy." ;
    rdfs:comment "Minted because the section-10.0 shared vocabulary has no output ICE for the 'select property' decision (10.1.2.3). Directive (not Descriptive) because a selection prescribes the chosen option rather than describing it." ;
    skos:example "A documented decision committing the firm to lease Building C." .

####################################################################
# 3. MATERIAL ENTITIES (operations section: material I/O is legal)
#    Genus = Material Artifact (cco:ont00000995) or Facility
#    (cco:ont00000192) or BFO material entity (obo:BFO_0000040) where
#    artifact-hood is not assured.
####################################################################

ex:RealProperty a owl:Class ; rdfs:subClassOf obo:BFO_0000040 ;
    rdfs:label "Real Property" ;
    skos:definition "A Material Entity, comprising land together with any buildings or fixtures on it, that an organization may build, buy, lease, retain, or dispose of." ;
    rdfs:comment "Anchored at BFO material entity rather than Material Artifact because raw land is not an artifact. Subject of property-selection and build/buy/lease decisions." .

ex:Facility a owl:Class ; rdfs:subClassOf cco:ont00000192 ;
    rdfs:label "Facility (asset)" ;
    skos:definition "A Facility that an organization plans, designs, constructs, modifies, operates, maintains, or disposes of as part of managing its assets." ;
    rdfs:comment "Specialization of CCO Facility (ont00000192, 'a building or campus dedicated to some specific purpose') scoped to the managed-asset role in section 10.0." .

ex:Workspace a owl:Class ; rdfs:subClassOf cco:ont00000192 ;
    rdfs:label "Workspace" ;
    skos:definition "A Facility, together with its supporting assets such as furniture and equipment, provided to occupants to perform work." ;
    rdfs:comment "Subject of acquire/change-fit-form-function activities in 10.1.3." .

ex:ProductiveAsset a owl:Class ; rdfs:subClassOf cco:ont00000995 ;
    rdfs:label "Productive Asset" ;
    skos:definition "A Material Artifact, such as a machine, tool, or factory, that an organization constructs, acquires, operates, maintains, and ultimately disposes of in the course of production." ;
    rdfs:comment "Central material subject of section 10.0. Anchored at CCO Material Artifact (designed to realize a Function)." .

ex:ConstructionResource a owl:Class ; rdfs:subClassOf obo:BFO_0000040 ;
    rdfs:label "Construction Resource" ;
    skos:definition "A Material Entity, such as materials, equipment, or labor input, that is acquired and consumed or employed in performing construction work." ;
    rdfs:comment "Anchored at BFO material entity because resources range over materials and equipment (artifacts) as well as raw materials (non-artifacts)." .

ex:MaintenanceResource a owl:Class ; rdfs:subClassOf obo:BFO_0000040 ;
    rdfs:label "Maintenance Resource" ;
    skos:definition "A Material Entity, such as a spare part, consumable, tool, or material, that is gathered and consumed or employed in performing asset-maintenance work." ;
    rdfs:comment "Minted (Gate-F) for 10.3.2.2 (ex:P19247) 'Gathering resources needed to complete all maintenance work'. Distinct from ex:AssetPart, whose definition is a part resulting from DISMANTLING an end-of-life asset (a 10.4 disposition concept) -- semantically wrong for spare parts/materials gathered to PERFORM maintenance. Anchored at BFO material entity because maintenance resources span artifacts (spares, tools) and non-artifact materials (consumables)." .

ex:AssetPart a owl:Class ; rdfs:subClassOf obo:BFO_0000040 ;
    rdfs:label "Asset Part" ;
    skos:definition "A Material Entity that results from dismantling an end-of-life asset and that may follow a disposition such as resale, reuse, recycling, or disposal." .

ex:HazardousMaterial a owl:Class ; rdfs:subClassOf obo:BFO_0000040 ;
    rdfs:label "Hazardous Material" ;
    skos:definition "A Material Entity that poses a health, safety, or environmental hazard and whose handling, shipment, and disposal are subject to legal and regulatory control." .

ex:WasteMaterial a owl:Class ; rdfs:subClassOf cco:ont00000980 ;
    rdfs:label "Waste Material" ;
    skos:definition "A Portion of Waste Material that arises from asset end-of-life activities and is subject to disposition, disposal, or reprocessing under regulatory requirements." ;
    rdfs:comment "Reuses CCO Portion of Waste Material (ont00000980), verified: 'serves no further use ... such that the Agent wants to dispose of it.'" .

ex:RecoveredMaterial a owl:Class ; rdfs:subClassOf obo:BFO_0000040 ;
    rdfs:label "Recovered Material" ;
    skos:definition "A Material Entity recovered from end-of-life asset parts for reuse or recycling into new material stock." ;
    rdfs:comment "Minted locally (10.4). Distinct from ex:WasteMaterial: recovered material re-enters a value stream rather than being discarded." .

####################################################################
# 4. AGENTS / ORGANIZATIONS, ROLES, CAPABILITIES
#    Realizables borne by independent continuants only (D4).
#    Roles obo:BFO_0000023 ; capabilities cco:ont00001379 (Agent) /
#    cco:ont00000568 (Organization) ; realized in obo:BFO_0000054.
####################################################################

# --- 4a. ROLES (obo:BFO_0000023) ---

ex:FacilityManagerRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Facility Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with planning, providing, and operating an organization's facilities and workspaces." .

ex:AssetManagerRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Asset Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with overseeing the construction, maintenance, and end-of-life of an organization's productive assets." .

ex:MaintenanceTechnicianRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Maintenance Technician Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with performing preventative, routine, corrective, and unplanned maintenance on assets." .

ex:ConstructionContractorRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Construction Contractor Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being engaged to perform or oversee construction work on an organization's assets." .

ex:RegulatoryAuthorityRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Regulatory Authority Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of issuing permits, codes, or requirements and overseeing compliance for construction, maintenance, or hazardous-material activities." ;
    rdfs:comment "Borne by the authority Organization, never by the permit or requirements ICE it issues." .

# --- 4b. CAPABILITIES (Organization: cco:ont00000568) ---

ex:FacilityManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Facility Management Capability" ;
    skos:definition "An Organization Capability that is realized in acts of planning, providing, operating, and maintaining facilities and workspaces." ;
    rdfs:comment "Organization Capability (cco:ont00000568) because 'Manage facilities operations' (10.1.4) is a standing organizational function (R5). Realized in the operational location-change acts via obo:BFO_0000054 (see R6 axioms in the 10.1 process block)." .

ex:AssetConstructionCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Asset Construction Capability" ;
    skos:definition "An Organization Capability that is realized in acts of designing, planning, scheduling, and performing the construction of assets." .

ex:AssetMaintenanceCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Asset Maintenance Capability" ;
    skos:definition "An Organization Capability that is realized in acts of planning, managing, and performing asset maintenance." ;
    rdfs:comment "Models the 10.3 process-group standing function (R5/R6). Realized in 10.3.1/.2/.3 (see R6 axioms in the 10.3 process block); 10.3 mints no ex:P19238 process." .

ex:AssetDispositionCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Asset Disposition Capability" ;
    skos:definition "An Organization Capability that is realized in acts of managing the end-of-life disposition of assets, including decommissioning, dismantling, recycling, and abandonment." ;
    rdfs:comment "Models the 10.4.4 'Manage take-back centers' standing function (R5/R6): a never-ending capacity, not a bounded process. Catalog bridge ex:PCF_12717 -> this capability." .

# --- 4c. AGENTS / ORGANIZATIONS (cco:ont00001017 / cco:ont00001180) ---

ex:FacilityManagementPersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:FacilityManagerRole ] ;
    rdfs:label "Facility Management Personnel" ;
    skos:definition "An Agent that bears a facility manager role." .

ex:RelocatedPersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ;
    rdfs:label "Relocated Personnel" ;
    skos:definition "An Agent that is a staff member or employee of an organization moved from one location to another in the course of a relocation act." ;
    rdfs:comment "Minted (Gate-F) for 10.1.4.1 'Relocate people': the relocated population is the Object whose location is changed, which is distinct from ex:FacilityManagementPersonnel (the facilities staff who PERFORM the move). CCO Act of Location Change (ont00000065) moves an Object, so the moved employees -- not the facility managers -- are the definitional participant standing in for that Object." .

ex:MaintenancePersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:MaintenanceTechnicianRole ] ;
    rdfs:label "Maintenance Personnel" ;
    skos:definition "An Agent that bears a maintenance technician role." .

ex:ConstructionContractor a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ConstructionContractorRole ] ;
    rdfs:label "Construction Contractor" ;
    skos:definition "An Agent that bears a construction contractor role." ;
    rdfs:comment "Modeled as Agent (rather than Organization) so it covers both individual and organizational contractors; slice modules may narrow to Organization where the text requires." .

ex:RegulatoryAuthority a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:RegulatoryAuthorityRole ] ;
    rdfs:label "Regulatory Authority" ;
    skos:definition "An Organization that bears a regulatory authority role in relation to construction, maintenance, or hazardous-material activities." .

####################################################################
# 5. PROCESS CLASSES
# ================================================================
# GROUP 10.1  "Plan and acquire assets"  (PCF 10937)
# ================================================================
####################################################################

####################################################################
# 5.1  PROCESS-GROUP UMBRELLA  --  10.1  (PCF 10937)
####################################################################

ex:P10937 a owl:Class ;
    ex:pcfID "10937" ;
    ex:hierarchyID "10.1" ;
    ex:apqcSourceText "Planning, acquiring, and managing facilities, workspaces, and supporting assets. Acquire, configure, and manage facilities and workspaces, to include supporting equipment and materials." ;
    rdfs:label "Plan and acquire assets" ;
    skos:definition "A Planned Act in which an Agent plans for, acquires, and configures the facilities, workspaces, and supporting assets required by an organization." ;
    rdfs:comment "Models APQC process group 10.1 as a curatorial aggregate occurrent. Its dotted children that are reality-layer processes are process parts (cco:ont00001777), not subclasses. 10.1.4 'Manage facilities operations' is a standing function (Organization Capability), so it is not a process part; the underlying location-change acts are reachable as parts of the operational facet instead." ;
    skos:example "An organization's end-to-end cycle of strategizing, acquiring, and fitting out a new office building." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10941 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10943 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10944 ] .

####################################################################
# 5.2  PROCESS  --  10.1.1  (PCF 10941)  Formulation -> Directive output
####################################################################

ex:P10941 a owl:Class ;
    ex:pcfID "10941" ;
    ex:hierarchyID "10.1.1" ;
    ex:apqcSourceText "Strategizing a long-term vision for managing properties. Prepare strategies and a long-term vision for managing purchased/retained properties." ;
    rdfs:label "Develop property strategy and long term vision" ;
    skos:definition "An Act of Formulation that composes a property strategy and long-term vision prescribing how an organization will manage its purchased or retained properties." ;
    rdfs:comment "Genus ex:ActOfFormulation (Act of Planning) per the GOLDEN PRINCIPLE: 'Develop ... strategy/vision' yields a Directive ICE (Property Strategy)." ;
    skos:example "A real-estate committee drafts a ten-year property strategy for the firm's owned portfolio." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PropertyStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10955 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10956 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10957 ] .

# --- 10.1.1.1 (PCF 10955) : Appraisal -> Descriptive output
ex:P10955 a owl:Class ;
    ex:pcfID "10955" ;
    ex:hierarchyID "10.1.1.1" ;
    ex:apqcSourceText "Creating alignment between the requirement of properties and the overall business strategy. This process requires the organization to align the requirement of properties in accordance with its business strategies of the organization." ;
    rdfs:label "Confirm alignment of property requirements with business strategy" ;
    skos:definition "An Act of Appraisal that has as input a property requirements specification and a business strategy and has as output a property alignment assessment judging their consistency." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): 'Confirm alignment' judges/evaluates consistency, yielding a Descriptive ICE (GOLDEN PRINCIPLE: appraisal -> descriptive)." ;
    skos:example "A portfolio analyst confirms that the requested floor space aligns with the firm's growth strategy." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PropertyRequirementsSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PropertyAlignmentAssessment ] .

# --- 10.1.1.2 (PCF 10956) : Appraisal -> Descriptive output
ex:P10956 a owl:Class ;
    ex:pcfID "10956" ;
    ex:hierarchyID "10.1.1.2" ;
    ex:apqcSourceText "Evaluating the impact of the external environment. Evaluate the circumstances, objects, events, and aspects surrounding an organization that affects its actions and selections and that recognizes its opportunities and risks." ;
    rdfs:label "Appraise the external environment" ;
    skos:definition "An Act of Appraisal that evaluates the forces, circumstances, and events surrounding an organization and has as output an external environment appraisal of its opportunities and risks." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal); output is a Descriptive ICE (ex:ExternalEnvironmentAppraisal) per the GOLDEN PRINCIPLE." ;
    skos:example "A facilities team appraises regional economic and regulatory conditions before committing to a site." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExternalEnvironmentAppraisal ] .

# --- 10.1.1.3 (PCF 10957) : Selection -> Directive output
ex:P10957 a owl:Class ;
    ex:pcfID "10957" ;
    ex:hierarchyID "10.1.1.3" ;
    ex:apqcSourceText "Deciding whether to buy or build properties. Study the market forces about property prices and cost of construction in order to take decisions based on the market research." ;
    rdfs:label "Determine build, buy, or lease decision" ;
    skos:definition "An Act of Selection that has as input market data and chooses among building, buying, or leasing, producing a build/buy/lease decision." ;
    rdfs:comment "Anchored to ex:ActOfSelection (Act of Information Processing): a candidate set (build/buy/lease) is reduced to a chosen option, yielding a Directive ICE (GOLDEN PRINCIPLE: selection -> directive)." ;
    skos:example "After studying construction costs and lease rates, management decides to lease rather than build." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BuildBuyLeaseDecision ] .

####################################################################
# 5.3  PROCESS  --  10.1.2  (PCF 10943)  Formulation umbrella
####################################################################

ex:P10943 a owl:Class ;
    ex:pcfID "10943" ;
    ex:hierarchyID "10.1.2" ;
    ex:apqcSourceText "Recognizing the needs of facility users in order to construct a project proposal that meets those needs." ;
    rdfs:label "Plan facility" ;
    skos:definition "An Act of Formulation that recognizes the needs of facility users and composes a facility project proposal that prescribes how those needs will be met." ;
    rdfs:comment "Genus ex:ActOfFormulation (Act of Planning): producing a project proposal/plan is a Directive ICE. Hosts its activities as process parts." ;
    skos:example "A project team turns user requirements into a costed facility proposal for sign-off." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10958 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10959 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10960 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10961 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10962 ] .

# --- 10.1.2.1 (PCF 10958) : Formulation -> Directive output
ex:P10958 a owl:Class ;
    ex:pcfID "10958" ;
    ex:hierarchyID "10.1.2.1" ;
    ex:apqcSourceText "Preparing and analyzing different designs for a facility in order to finalize which design will be the most suitable option." ;
    rdfs:label "Design facility" ;
    skos:definition "An Act of Formulation that prepares and evaluates candidate facility designs and has as output a finalized facility design." ;
    rdfs:comment "Genus ex:ActOfFormulation (Act of Planning); a facility design is a Directive ICE (a blueprint/specification) per the GOLDEN PRINCIPLE." ;
    skos:example "Architects develop and down-select to a final layout for a new warehouse." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FacilityDesign ] .

# --- 10.1.2.2 (PCF 10959) : Analysis -> Descriptive output
ex:P10959 a owl:Class ;
    ex:pcfID "10959" ;
    ex:hierarchyID "10.1.2.2" ;
    ex:apqcSourceText "Evaluating the feasibility of budgets prepared for the construction of facilities." ;
    rdfs:label "Analyze budget" ;
    skos:definition "An Act of Analysis that has as input a budget and has as output a budget analysis evaluating the feasibility of the funds prepared for facility construction." ;
    rdfs:comment "Genus ex:ActOfAnalysis (Act of Information Processing); output is a Descriptive ICE (ex:BudgetAnalysis) per the GOLDEN PRINCIPLE." ;
    skos:example "A finance analyst tests whether the proposed construction budget covers the design's costs." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:Budget ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BudgetAnalysis ] .

# --- 10.1.2.3 (PCF 10960) : Selection -> Directive output
ex:P10960 a owl:Class ;
    ex:pcfID "10960" ;
    ex:hierarchyID "10.1.2.3" ;
    ex:apqcSourceText "Assessing and choosing the appropriate property. Analyze the property requirements. Review the available property options. Finalize the most suitable option." ;
    rdfs:label "Select property" ;
    skos:definition "An Act of Selection that has as input a property requirements specification, reviews available property options, and produces a directive selection of the most suitable property." ;
    rdfs:comment "Genus ex:ActOfSelection (Act of Information Processing): a candidate set of properties is reduced to a chosen one, yielding a Directive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "A site-selection team reviews three buildings against requirements and commits to one." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PropertyRequirementsSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PropertySelectionDecision ] .

# --- 10.1.2.4 (PCF 10961) : Negotiation -> Directive output
ex:P10961 a owl:Class ;
    ex:pcfID "10961" ;
    ex:hierarchyID "10.1.2.4" ;
    ex:apqcSourceText "Discussing the terms and conditions of facilities to be occupied according to the business requirements and availability of budgets." ;
    rdfs:label "Negotiate terms for facility" ;
    skos:definition "An Act of Negotiation that discusses the terms and conditions for occupying a facility and produces a facility terms agreement reconciling business requirements and budget." ;
    rdfs:comment "Genus ex:ActOfNegotiation (PROPOSE-EXT, Planned Act): an interactive deliberation between parties yielding a binding Directive ICE (ex:FacilityTermsAgreement). Rejected cco:ont00000511 (Act of Planning) -- the act is an inter-agent bargaining rather than making a plan to achieve an objective." ;
    skos:example "Facilities and a landlord negotiate lease length, rent, and fit-out responsibilities into an agreement." ;
    rdfs:subClassOf ex:ActOfNegotiation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FacilityTermsAgreement ] .

# --- 10.1.2.5 (PCF 10962) : Construction + (de-conflated) renovation -> Material output (operations)
#     SUPPORTING PROCESS for the de-conflated 'manage renovations' sense.
#     Carries NO pcfID (supporting class); it is the modification sub-act of P10962.
ex:ManageBuildingRenovation a owl:Class ;
    rdfs:subClassOf cco:ont00000970 ,   # Act of Artifact Modification
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000970)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Facility ] ;
    rdfs:label "Manage building renovation" ;
    skos:definition "An Act of Artifact Modification that renovates an existing building on site, changing its qualities or functions according to requirements and demands." ;
    rdfs:comment "Minted (Gate-F, Phase-1 de-conflation) for the 'Manage renovations according to requirements and demands' half of PCF 10962, which fuses two act kinds (build NEW + renovate EXISTING). Anchored to cco:ont00000970 (Act of Artifact Modification) because renovating an existing building changes the qualities/functions of an existing Material Artifact, mirroring 10.2.3.4 (ex:P19233), which rejects cco:ont00000051 (Act of Construction, builds NEW) for the same modify-existing sense. Attached as a process part of ex:P10962 so the modification sense is not mis-genused under Construction nor silently dropped." .

# --- 10.1.2.5 (PCF 10962) : Construction/modification -> Material output (operations)
ex:P10962 a owl:Class ;
    ex:pcfID "10962" ;
    ex:hierarchyID "10.1.2.5" ;
    ex:apqcSourceText "Constructing the buildings. Manage renovations according to requirements and demands." ;
    rdfs:label "Manage construction or modification to building" ;
    skos:definition "An Act of Construction that builds a building on site as prescribed by a facility design or contract and has as output a facility, and that has the management of building renovations as a process part." ;
    rdfs:comment "R5: although the APQC name says 'Manage', the Element Description ('Constructing the buildings. Manage renovations') denotes bounded constructive/modifying acts, so it is a process, not a standing function. De-conflated (Gate-F, Phase 1): the 'construct buildings' sense keeps the primary class at cco:ont00000051 (Act of Construction); the 'manage renovations' sense is the modify-existing-artifact genus cco:ont00000970 (Act of Artifact Modification), modeled as the supporting process ex:ManageBuildingRenovation and attached here as a process part rather than collapsed into Construction. Operations layer (10.0) permits the material output ex:Facility. has-input ex:FacilityDesign is typical, recorded here rather than as a definitional restriction." ;
    skos:example "A general contractor erects the warehouse shell per the approved design and manages later renovations to it." ;
    rdfs:subClassOf cco:ont00000051 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000051, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Facility ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ConstructionContractor ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:ManageBuildingRenovation ] .

####################################################################
# 5.4  PROCESS  --  10.1.3  (PCF 10944)  Acquisition umbrella (operations)
####################################################################

ex:P10944 a owl:Class ;
    ex:pcfID "10944" ;
    ex:hierarchyID "10.1.3" ;
    ex:apqcSourceText "Managing the provision of the workspace and its assets. Arrange an office space with all assets (tables, chairs, computers, admin staff, etc.) according to requirements." ;
    rdfs:label "Provide workspace and facilities" ;
    skos:definition "An Act of Acquisition that obtains and arranges a workspace together with its supporting assets according to organizational requirements." ;
    rdfs:comment "R5: a bounded provisioning act, modeled as ex:ActOfAcquisition (Planned Act) rather than a standing function, because it has an identifiable begin/end (the workspace is provisioned). Hosts its activities as process parts." ;
    skos:example "A facilities team stands up a new floor of desks, chairs, and computers ready for occupancy." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10963 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10964 ] .

# --- 10.1.3.1 (PCF 10963) : Acquisition -> Material output (operations)
ex:P10963 a owl:Class ;
    ex:pcfID "10963" ;
    ex:hierarchyID "10.1.3.1" ;
    ex:apqcSourceText "Attaining the office space with all assets (tables, chairs, computers, admin staff, etc.) according to requirements." ;
    rdfs:label "Acquire workspace and facilities" ;
    skos:definition "An Act of Acquisition that obtains an office workspace together with its supporting assets according to organizational requirements." ;
    rdfs:comment "Genus ex:ActOfAcquisition (Planned Act). Operations layer permits the material output ex:Workspace." ;
    skos:example "Procurement secures a leased floor and furnishes it with the required equipment." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Workspace ] .

# --- 10.1.3.2 (PCF 10964) : Material Artifact Processing -> Material I/O (operations)
ex:P10964 a owl:Class ;
    ex:pcfID "10964" ;
    ex:hierarchyID "10.1.3.2" ;
    ex:apqcSourceText "Modifying the formation of the workspace and its assets. Make necessary changes in an office space with all assets (tables, chairs, computers, admin staff, interior designing, etc.) according to requirements." ;
    rdfs:label "Change fit/form/function of workspace and facilities" ;
    skos:definition "An Act of Artifact Modification that modifies the fit, form, or function of a workspace and its assets according to changed organizational requirements." ;
    rdfs:comment "Re-anchored (Gate-F) from the over-general cco:ont00000908 (Act of Material Artifact Processing) to its nearest correct child cco:ont00000970 (Act of Artifact Modification): the source ('Modifying the formation of the workspace and its assets ... Make necessary changes ... according to requirements') is precisely 'an existing Material Artifact is acted upon in a manner that changes ... its Qualities, Dispositions, or Functions' (ont00000970). This matches the sibling-pattern 10.2.3.4 'Augment existing assets' (ex:P19233), which anchors the same modify-existing-artifact act at ont00000970. ont00000908 retained as the (over-general) parent reached transitively. Rejected cco:ont00000950 (Act of Maintenance), which only preserves/restores existing qualities rather than altering fit/form/function. Operations layer permits the material input/output ex:Workspace." ;
    skos:example "A facilities crew reconfigures an open-plan floor into team pods with new partitions." ;
    rdfs:subClassOf cco:ont00000970 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000970, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Workspace ] .

####################################################################
# 5.5  CAPABILITY  --  10.1.4  (PCF 10949)  Standing function (R5 -> R6)
#    'Manage facilities operations' has no natural end => Organization
#    Capability (reuse ex:FacilityManagementCapability), realized in the
#    operational location-change acts. NOT a process; no has-process-part.
####################################################################

# --- 10.1.4.1 (PCF 10965) : Location Change (operations)
ex:P10965 a owl:Class ;
    ex:pcfID "10965" ;
    ex:hierarchyID "10.1.4.1" ;
    ex:apqcSourceText "Shifting staff or employees from one place to another place according to changes in business requirements." ;
    rdfs:label "Relocate people" ;
    skos:definition "An Act of Location Change that moves the relocated staff or employees of an organization from one location to another, performed by facility-management personnel, in response to changed business requirements." ;
    rdfs:comment "Anchored to cco:ont00000065 (Act of Location Change): the location of an Object is changed by an Agent. Realizes the standing ex:FacilityManagementCapability (10.1.4). Corrected (Gate-F): the moved Object is the relocated population (ex:RelocatedPersonnel), NOT ex:FacilityManagementPersonnel. The earlier model wrongly asserted that the facility managers (who PERFORM the move) were the relocated party; ex:FacilityManagementPersonnel is retained as a SEPARATE participant restriction representing the performers, not as the moved party." ;
    skos:example "An HR/facilities team moves a department to a different building floor." ;
    rdfs:subClassOf cco:ont00000065 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RelocatedPersonnel ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FacilityManagementPersonnel ] .

# --- 10.1.4.2 (PCF 10966) : Location Change -> Material I/O (operations)
ex:P10966 a owl:Class ;
    ex:pcfID "10966" ;
    ex:hierarchyID "10.1.4.2" ;
    ex:apqcSourceText "Relocating the tools and raw materials. Shift raw or finished material and machines of company from one place to another place according to changes in business requirements." ;
    rdfs:label "Relocate material and tools" ;
    skos:definition "An Act of Location Change that moves an organization's materials, tools, and machines from one location to another in response to changed business requirements." ;
    rdfs:comment "Anchored to cco:ont00000065 (Act of Location Change). Realizes the standing ex:FacilityManagementCapability (10.1.4). Operations layer permits the material participant ex:ProductiveAsset (machines/tools relocated)." ;
    skos:example "A logistics crew relocates machine tools and stock to a newly acquired warehouse." ;
    rdfs:subClassOf cco:ont00000065 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] .

# --- R6 REALIZATION: 10.1.4 standing capability realized in operational acts ---
ex:FacilityManagementCapability rdfs:subClassOf
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10965 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10966 ] .

####################################################################
# ================================================================
# GROUP 10.2  "Design and construct assets"  (PCF 21575)
# ================================================================
####################################################################

####################################################################
# 5.6  PARENT PROGRAM PROCESS  --  10.2  (PCF 21575)
####################################################################

ex:P21575 a owl:Class ;
    ex:pcfID "21575" ;
    ex:hierarchyID "10.2" ;
    ex:apqcSourceText "Designing and constructing assets such as machines, tools, factories, etc. Manage steps to acquire assets including managing capital, as well as planning, scheduling, and overseeing acquisition/construction." ;
    rdfs:label "Design and construct assets" ;
    skos:definition "A Planned Act in which an Organization designs, plans, finances, schedules, and physically constructs productive assets, decomposing into managing the capital program, designing and planning the construction, scheduling and performing the construction work, and managing the construction effort." ;
    rdfs:comment "Models APQC process group 10.2 as a bounded undertaking (one asset build program), not a standing function. Anchored at cco:ont00000228 (Planned Act) because it is a composite program spanning planning and material work rather than a single act of one genus. Its APQC children are process parts, not subclasses." ;
    skos:example "A manufacturer's program to design, finance, and build a new production plant, ending when the plant is commissioned." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19209 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20139 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19229 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19224 ] .

####################################################################
# 5.7  PROCESS  --  10.2.1  Manage capital program for assets (PCF 19209)
####################################################################

ex:P19209 a owl:Class ;
    ex:pcfID "19209" ;
    ex:hierarchyID "10.2.1" ;
    ex:apqcSourceText "Producing and maintaining a planning schedule and a financial plan to purchase or manufacture productive assets. Determine the investment plan, monitor capital, and secure the necessary financing in order to realize completion of the program." ;
    rdfs:label "Manage capital program for assets" ;
    skos:definition "A Planned Act in which an Organization produces and maintains the financial plan for acquiring or constructing productive assets, decomposing into defining the capital investment plan, monitoring the capital program, and securing construction financing." ;
    rdfs:comment "Bounded program-management act (one capital program has a definite begin/end), not a standing capability; anchored at cco:ont00000228 (Planned Act) as a composite of formulation, monitoring, and acquisition acts." ;
    skos:example "A facilities team prepares the investment plan and arranges loans for a new warehouse build." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CapitalInvestmentPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19210 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19211 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19212 ] .

# --- 10.2.1.1 (PCF 19210) : Formulation -> Directive ICE
ex:P19210 a owl:Class ;
    ex:pcfID "19210" ;
    ex:hierarchyID "10.2.1.1" ;
    ex:apqcSourceText "Establishing what funds will be invested in the construction of productive assets for the advancement of established business objectives." ;
    rdfs:label "Define capital investment plan" ;
    skos:definition "An Act of Formulation that has as output a capital investment plan prescribing the funds to be invested in the construction of productive assets." ;
    rdfs:comment "GOLDEN PRINCIPLE: formulation/planning -> Directive ICE (CapitalInvestmentPlan). Uses shared genus ex:ActOfFormulation (cco:ont00000511)." ;
    skos:example "Finance defines a USD 40M capital plan for a new plant." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CapitalInvestmentPlan ] .

# --- 10.2.1.2 (PCF 19211) : Monitoring -> Descriptive ICE
ex:P19211 a owl:Class ;
    ex:pcfID "19211" ;
    ex:hierarchyID "10.2.1.2" ;
    ex:apqcSourceText "Monitoring plans on capital projects. Capital projects can be purchasing buildings, lands, etc." ;
    rdfs:label "Monitor capital program" ;
    skos:definition "An Act of Monitoring that has as input a capital investment plan and has as output a capital program report describing the tracked status of the capital projects." ;
    rdfs:comment "GOLDEN PRINCIPLE: monitoring -> Descriptive ICE (CapitalProgramReport). Uses ex:ActOfMonitoring (PROPOSE-EXT)." ;
    skos:example "A program office tracks spend against the capital plan and issues a quarterly status report." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CapitalInvestmentPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CapitalProgramReport ] .

# --- 10.2.1.3 (PCF 19212) : Acquisition -> Directive financing arrangement
ex:P19212 a owl:Class ;
    ex:pcfID "19212" ;
    ex:hierarchyID "10.2.1.3" ;
    ex:apqcSourceText "Acquiring the loans needed to construct necessary assets." ;
    rdfs:label "Secure construction financing" ;
    skos:definition "An Act of Acquisition that has as output a construction financing arrangement obtained to fund the construction of assets." ;
    rdfs:comment "Uses shared genus ex:ActOfAcquisition (cco:ont00000228 Planned Act): the org obtains financing it did not previously hold. Output is a Directive ICE (the financing arrangement)." ;
    skos:example "Treasury secures a construction loan facility for the build program." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConstructionFinancing ] .

####################################################################
# 5.8  PROCESS  --  10.2.2  Design and plan asset construction (PCF 20139)
####################################################################

ex:P20139 a owl:Class ;
    ex:pcfID "20139" ;
    ex:hierarchyID "10.2.2" ;
    ex:apqcSourceText "Outlining the steps and strategies needed to construct assets. Verify that all regulations are adhered to and that all permissions have been granted. Organize and plan for resources to complete construction." ;
    rdfs:label "Design and plan asset construction" ;
    skos:definition "A Planned Act in which an Organization formulates the strategy, designs, permits, and resource plans needed to construct assets, decomposing into developing the construction strategy, managing construction performance, obtaining permissions, designing the assets, and planning construction resources." ;
    rdfs:comment "Bounded design-and-plan phase preceding physical construction; anchored at cco:ont00000228 (Planned Act) as a composite of formulation, acquisition, and monitoring acts. Children are process parts." ;
    skos:example "An engineering team produces the plant design, secures permits, and a resource plan before breaking ground." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19220 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11276 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19221 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19222 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19223 ] .

# --- 10.2.2.1 (PCF 19220) : Formulation -> Directive ICE
ex:P19220 a owl:Class ;
    ex:pcfID "19220" ;
    ex:hierarchyID "10.2.2.1" ;
    ex:apqcSourceText "Developing a strategy to perform asset construction. Assure that timelines, regulations, and resources are on task and on budget." ;
    rdfs:label "Develop construction strategy" ;
    skos:definition "An Act of Formulation that has as output a construction strategy prescribing how asset construction is to be performed within timeline, regulatory, and budget constraints." ;
    rdfs:comment "GOLDEN PRINCIPLE: formulation -> Directive ICE (ConstructionStrategy). Uses ex:ActOfFormulation." ;
    skos:example "A project lead drafts the construction strategy and delivery approach for a new facility." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConstructionStrategy ] .

# --- 10.2.2.2 (PCF 11276) : Monitoring -> Descriptive ICE
ex:P11276 a owl:Class ;
    ex:pcfID "11276" ;
    ex:hierarchyID "10.2.2.2" ;
    ex:apqcSourceText "Managing the construction process to ensure that activates are on task, on budget, and are being performed with safety and quality in mind." ;
    rdfs:label "Perform construction performance management" ;
    skos:definition "An Act of Monitoring that has as output a work performance report describing whether construction activities are on task, on budget, and performed with safety and quality." ;
    rdfs:comment "GOLDEN PRINCIPLE: monitoring/oversight -> Descriptive ICE (WorkPerformanceReport). Despite the 'Managing' wording it is bounded to one construction effort, so it is a process (ex:ActOfMonitoring), not a standing capability." ;
    skos:example "A construction manager reviews daily progress against plan and reports performance to the program office." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkPerformanceReport ] .

# --- 10.2.2.3 (PCF 19221) : Acquisition -> Directive permit
ex:P19221 a owl:Class ;
    ex:pcfID "19221" ;
    ex:hierarchyID "10.2.2.3" ;
    ex:apqcSourceText "Gathering the required permits for construction from the proper jurisdiction. This may include inspections during and after construction to verify that the new asset meets all national, regional, and local codes." ;
    rdfs:label "Obtain construction permissions" ;
    skos:definition "An Act of Acquisition that has as output a construction permit obtained from the proper jurisdiction authorizing construction of the asset." ;
    rdfs:comment "Uses ex:ActOfAcquisition (cco:ont00000228): the org obtains a permit it did not previously hold from a Regulatory Authority. Output is a Directive ICE (ConstructionPermit). Inspections referenced in the text are typical, not definitional -> not restricted." ;
    skos:example "A developer obtains building permits from the municipal authority before construction begins." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConstructionPermit ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryAuthority ] .

# --- 10.2.2.4 (PCF 19222) : Formulation (designing) -> Directive ICE
ex:P19222 a owl:Class ;
    ex:pcfID "19222" ;
    ex:hierarchyID "10.2.2.4" ;
    ex:apqcSourceText "Designing assets to meet organizational needs as well as ensuring that the asset adheres to all national, regional, and local construction codes." ;
    rdfs:label "Design assets" ;
    skos:definition "An Act of Formulation that has as output an asset design prescribing an asset that meets organizational needs and adheres to applicable construction codes." ;
    rdfs:comment "GOLDEN PRINCIPLE: designing is formulation -> Directive ICE (AssetDesign). Uses ex:ActOfFormulation. Regulatory requirements are a typical input -> noted, not restricted." ;
    skos:example "Engineers produce the design and drawings for a new production machine." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AssetDesign ] .

# --- 10.2.2.5 (PCF 19223) : Formulation (planning) -> Directive ICE
ex:P19223 a owl:Class ;
    ex:pcfID "19223" ;
    ex:hierarchyID "10.2.2.5" ;
    ex:apqcSourceText "Determining what resources will need to be acquired in order to carry out construction. Plan when, where, and how resources will be used. Determine the length of time resources will be utilized." ;
    rdfs:label "Plan construction resources" ;
    skos:definition "An Act of Formulation that has as output a construction resource plan prescribing what resources will be acquired and when, where, and how long they will be used for construction." ;
    rdfs:comment "GOLDEN PRINCIPLE: planning -> Directive ICE (ConstructionResourcePlan). Uses ex:ActOfFormulation." ;
    skos:example "A planner schedules crews, equipment, and materials for the build." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConstructionResourcePlan ] .

####################################################################
# 5.9  PROCESS  --  10.2.3  Schedule and perform construction work (PCF 19229)
####################################################################

ex:P19229 a owl:Class ;
    ex:pcfID "19229" ;
    ex:hierarchyID "10.2.3" ;
    ex:apqcSourceText "Arranging a timetable for which to perform construction work. Schedule resources to contract assets for new or replacement assets. Reschedule or redesign assets if needed." ;
    rdfs:label "Schedule and perform construction work" ;
    skos:definition "A Planned Act in which an Organization schedules and physically carries out construction work, decomposing into scheduling the work, obtaining resources, constructing new assets, augmenting existing assets, and renewing or replacing assets." ;
    rdfs:comment "Bounded schedule-and-build phase; anchored at cco:ont00000228 (Planned Act) as a composite of a scheduling act and material construction/modification acts. Children are process parts." ;
    skos:example "A contractor schedules and executes the erection of a new factory building." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19230 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19231 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19232 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19233 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19234 ] .

# --- 10.2.3.1 (PCF 19230) : Formulation (scheduling) -> Directive ICE
ex:P19230 a owl:Class ;
    ex:pcfID "19230" ;
    ex:hierarchyID "10.2.3.1" ;
    ex:apqcSourceText "Defining a timetable for which to execute the construction of the asset." ;
    rdfs:label "Schedule construction work" ;
    skos:definition "An Act of Formulation that has as output a construction schedule prescribing the timetable for executing the construction of the asset." ;
    rdfs:comment "GOLDEN PRINCIPLE: scheduling is formulation -> Directive ICE (ConstructionSchedule). Uses ex:ActOfFormulation." ;
    skos:example "A planner sets the construction milestone schedule for the project." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConstructionSchedule ] .

# --- 10.2.3.2 (PCF 19231) : Acquisition -> MATERIAL output (operations)
ex:P19231 a owl:Class ;
    ex:pcfID "19231" ;
    ex:hierarchyID "10.2.3.2" ;
    ex:apqcSourceText "Gathering resources needed to complete all construction work. Verify that all resources have the proper training and skills to perform the work." ;
    rdfs:label "Obtain resources" ;
    skos:definition "An Act of Acquisition that has as output construction resources gathered to complete the construction work." ;
    rdfs:comment "Operations category -> MATERIAL output is legal (ex:ConstructionResource is a Material Entity). Uses ex:ActOfAcquisition: the org obtains resources it did not previously hold." ;
    skos:example "A site manager procures steel, formwork, and a crane for the build." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ConstructionResource ] .

# --- 10.2.3.3 (PCF 19232) : Act of Construction (CCO) -> MATERIAL output
ex:P19232 a owl:Class ;
    ex:pcfID "19232" ;
    ex:hierarchyID "10.2.3.3" ;
    ex:apqcSourceText "Building new assets necessary for the organization. Be aware of any construction codes and permits that need to be addressed." ;
    rdfs:label "Construct new assets" ;
    skos:definition "An Act of Construction that has as input construction resources and has as output a newly built productive asset required by the organization." ;
    rdfs:comment "Anchored at cco:ont00000051 (Act of Construction): 'Material Artifacts are built on site as prescribed by some contract' -- exactly building a new asset. Operations category -> MATERIAL input/output (ConstructionResource in, ProductiveAsset out). A construction permit is referenced but typical, not definitional." ;
    skos:example "A crew erects a new assembly line building on site." ;
    rdfs:subClassOf cco:ont00000051 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000051, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ConstructionResource ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] .

# --- 10.2.3.4 (PCF 19233) : Act of Artifact Modification (CCO) -> MATERIAL I/O
ex:P19233 a owl:Class ;
    ex:pcfID "19233" ;
    ex:hierarchyID "10.2.3.4" ;
    ex:apqcSourceText "Modifying existing assets to align with the changing needs of the organization. Be aware of any construction codes and permits that need to be addressed." ;
    rdfs:label "Augment existing assets" ;
    skos:definition "An Act of Artifact Modification that has as input an existing productive asset and has as output that asset modified to align with the changing needs of the organization." ;
    rdfs:comment "Anchored at cco:ont00000970 (Act of Artifact Modification): an existing Material Artifact is acted upon to change its qualities/functions -- exactly augmenting an existing asset. Rejected cco:ont00000051 (Act of Construction), which builds a NEW artifact. Operations category -> MATERIAL input and output." ;
    skos:example "An engineering team retrofits an existing plant with new automation." ;
    rdfs:subClassOf cco:ont00000970 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000970, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] .

# --- 10.2.3.5 (PCF 19234) : Act of Appraisal (determine replacement need) -> Descriptive output
ex:P19234 a owl:Class ;
    ex:pcfID "19234" ;
    ex:hierarchyID "10.2.3.5" ;
    ex:apqcSourceText "Determining the need to replace existing assets. Be aware of any construction codes and permits that need to be addressed." ;
    rdfs:label "Renew/Replace assets" ;
    skos:definition "An Act of Appraisal that judges whether an existing asset needs to be renewed or replaced and has as output a replacement need assessment." ;
    rdfs:comment "Re-anchored (Gate-F) from cco:ont00000051 (Act of Construction) to cco:ont00000636 (Act of Appraisal). The lead gerund 'Determining the need to replace existing assets' is a determination/appraisal yielding a DESCRIPTIVE judgement (ex:ReplacementNeedAssessment), not a build; this is the false-friend on the label 'Replace' -- the row classifies the DECISION to replace, not the act of constructing the replacement. Consistent with the determination siblings 10.1.1.3 (ex:P10957) and 10.1.2.3 (ex:P10960). Rejected cco:ont00000051 (Act of Construction): the Element Description never states a build, a replacement ProductiveAsset output, nor a UsefulLifeAssessment input (the latter is borrowed from the 10.4 vocabulary). DESIGN NOTE / CQ target: the unsupported has-output some ex:ProductiveAsset and has-input some ex:UsefulLifeAssessment were dropped (Phase-3 definitional-necessity test: neither is licensed by the Element Description). If the physical replacement build is later in scope, it should be a SEPARATE supporting Act-of-Construction class, not collapsed into this determination row." ;
    skos:example "After reviewing a machine's condition, an engineer determines it needs replacing and records that finding." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ReplacementNeedAssessment ] .

####################################################################
# 5.10  PROCESS  --  10.2.4  Manage asset construction (PCF 19224)
#    NOTE: child 10.2.4.4 (PCF 19228) is a standing function ->
#    Organization Capability (R6), NOT a process part of this node.
####################################################################

ex:P19224 a owl:Class ;
    ex:pcfID "19224" ;
    ex:hierarchyID "10.2.4" ;
    ex:apqcSourceText "Overseeing the performance and quality of work. Assure that records are maintained throughout the construction process. Adhere to all safety, security, and access regulations set forth by the organization and all government standards." ;
    rdfs:label "Manage asset construction" ;
    skos:definition "A Planned Act in which an Organization oversees the performance and quality of construction work and maintains records throughout the construction process, decomposing into monitoring work performance, undertaking quality control, and creating work and asset records." ;
    rdfs:comment "Re-anchored (Gate-F) from the narrow ex:ActOfMonitoring to the composite cco:ont00000228 (Planned Act), matching its three sibling group-parents 10.2.1/10.2.2/10.2.3 (ex:P19209, ex:P20139, ex:P19229), which are all anchored at Planned Act because they aggregate acts of mixed genera. This node's three modeled children span heterogeneous genera -- monitoring (ex:P19225), Act of Appraisal/QC (ex:P19226), and Act of Information Processing/record creation (ex:P19227) -- so typing the whole aggregate as a single Act of Monitoring mis-types it (a monitoring act does not have a quality-control appraisal as a proper part). The oversight emphasis is kept in the definition; the monitoring/appraisal/record children carry their own genera as process parts. Its safety/security/access child (PCF 19228) is a standing function modeled as ex:P19228 Organization Capability (R6) and is therefore NOT attached here as a has-process-part; it is realized in the org's safety acts." ;
    skos:example "A project office oversees a building project's quality and keeps its construction records." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19225 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19226 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19227 ] .

# --- 10.2.4.1 (PCF 19225) : Monitoring -> Descriptive ICE
ex:P19225 a owl:Class ;
    ex:pcfID "19225" ;
    ex:hierarchyID "10.2.4.1" ;
    ex:apqcSourceText "Monitoring construction to insure that all regulatory laws are being adhered to, that all work is being performed in a timely manner, and that quality assurance is met at all steps of the construction process." ;
    rdfs:label "Monitor work performance" ;
    skos:definition "An Act of Monitoring that has as output a work performance report describing regulatory adherence, timeliness, and quality assurance across the construction process." ;
    rdfs:comment "GOLDEN PRINCIPLE: monitoring -> Descriptive ICE (WorkPerformanceReport). Uses ex:ActOfMonitoring (PROPOSE-EXT)." ;
    skos:example "An inspector tracks regulatory compliance and progress and logs a performance report." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkPerformanceReport ] .

# --- 10.2.4.2 (PCF 19226) : Appraisal -> Descriptive ICE
ex:P19226 a owl:Class ;
    ex:pcfID "19226" ;
    ex:hierarchyID "10.2.4.2" ;
    ex:apqcSourceText "Implementing a checks and balances system to verify that the construction was performed correctly. Rework when errors are found." ;
    rdfs:label "Undertake construction quality control" ;
    skos:definition "An Act of Appraisal that has as output a quality control report judging whether the construction was performed correctly and identifying defects to be reworked." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): it evaluates/judges the correctness and quality of the construction. GOLDEN PRINCIPLE: appraisal -> Descriptive ICE (QualityControlReport)." ;
    skos:example "A QA team inspects completed work and issues a quality control report flagging defects for rework." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityControlReport ] .

# --- 10.2.4.3 (PCF 19227) : Information Processing -> Descriptive record
ex:P19227 a owl:Class ;
    ex:pcfID "19227" ;
    ex:hierarchyID "10.2.4.3" ;
    ex:apqcSourceText "Implementing records to include all construction work that has been performed. Include all new or modified construction, and any construction or regulatory issues that might have occurred." ;
    rdfs:label "Create work and asset records" ;
    skos:definition "An Act of Information Processing that has as output a work and asset record describing all construction work performed, including new or modified construction and any construction or regulatory issues." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): compiling/registering records is manipulating input information into an output record. GOLDEN PRINCIPLE: information-processing -> Descriptive ICE (WorkAndAssetRecord)." ;
    skos:example "A clerk compiles the as-built record documenting all work and issues on the project." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkAndAssetRecord ] .

# --- 10.2.4.4 (PCF 19228) : STANDING FUNCTION -> Organization Capability (R6)
ex:P19228 a owl:Class ;
    ex:pcfID "19228" ;
    ex:hierarchyID "10.2.4.4" ;
    ex:apqcSourceText "Ensuring that safety, security, and access is maintained. Provide a workplace that meets and exceeds all local, state, and federal guidelines. Provide security and access to the building site as set forth by safety and organizational guidelines." ;
    rdfs:label "Manage safety, security, and access to sites" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to continuously maintain the safety, security, and access of construction and operational sites in conformance with safety and regulatory guidelines." ;
    rdfs:comment "R5/R6: standing function with no natural end ('Ensuring that ... is maintained') -> Organization Capability (cco:ont00000568), not a bounded process. Therefore NOT a has-process-part of parent ex:P19224. Realized in ongoing acts that maintain site safety/security/access (producing safety compliance records)." ;
    skos:example "A firm's ongoing site-safety and access-control program covering all its construction sites." ;
    rdfs:subClassOf cco:ont00000568 .

####################################################################
# ================================================================
# GROUP 10.3  "Maintain assets"  (PCF 19238)
# 10.3 (PG 19238) is a standing function -> reuse shared
# ex:AssetMaintenanceCapability (Organization Capability), realized in
# 10.3.1/.2/.3 (R6). NOT minted as a process.
# ================================================================
####################################################################

# --- R6 REALIZATION: 10.3 standing capability realized in its sub-processes ---
ex:AssetMaintenanceCapability rdfs:subClassOf
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19239 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19245 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19253 ] .

####################################################################
# 5.11  PROCESS GROUP 10.3.1  --  Plan asset maintenance  (PCF 19239)
####################################################################

ex:P19239 a owl:Class ;
    ex:pcfID "19239" ;
    ex:hierarchyID "10.3.1" ;
    ex:apqcSourceText "Ensuring that necessary resources are available and tasks are prioritized accordingly through planning. Provide strategies and policies that identify tasks that need to be completed, and the resources necessary to fulfill those tasks." ;
    rdfs:label "Plan asset maintenance" ;
    skos:definition "An Act of Planning that determines the maintenance strategies, policies, tasks, and resources required to preserve an organization's productive assets and produces the corresponding maintenance plans." ;
    rdfs:comment "Models APQC 10.3.1 as a bounded occurrent. Its APQC activities are process parts (cco:ont00001777), not subclasses." ;
    skos:example "A facilities team's annual maintenance-planning cycle producing the year's strategy, policies, task list, and resource plan." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19240 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10967 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19241 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10968 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19242 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19243 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19244 ] .

# --- 10.3.1.1 (PCF 19240) : Formulation -> Directive output
ex:P19240 a owl:Class ;
    ex:pcfID "19240" ; ex:hierarchyID "10.3.1.1" ;
    ex:apqcSourceText "Creating goals and agendas to better realize the success of the maintenance policies that have been put into place." ;
    rdfs:label "Develop maintenance strategies" ;
    skos:definition "An Act of Formulation that composes the goals and agendas guiding asset maintenance and has as output a maintenance strategy." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (Act of Planning): its definitional output is a Directive ICE (Maintenance Strategy), per the GOLDEN PRINCIPLE." ;
    skos:example "A maintenance manager drafts the multi-year strategy aligning upkeep goals with asset-criticality." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaintenanceStrategy ] .

# --- 10.3.1.2 (PCF 10967) : Analysis -> Descriptive output
ex:P10967 a owl:Class ;
    ex:pcfID "10967" ; ex:hierarchyID "10.3.1.2" ;
    ex:apqcSourceText "Evaluating assets in order to project future requirements for maintenance. Evaluate the present working condition of assets. Determine the future maintenance requirements of assets." ;
    rdfs:label "Analyze assets and predict maintenance requirements" ;
    skos:definition "An Act of Analysis that examines the present condition of productive assets and has as output a maintenance requirements forecast projecting their future maintenance needs." ;
    rdfs:comment "Anchored under ex:ActOfAnalysis (Act of Information Processing): its definitional output is a Descriptive ICE (Maintenance Requirements Forecast), per the GOLDEN PRINCIPLE." ;
    skos:example "An asset analyst reviews equipment condition data and forecasts the parts and servicing needed next year." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaintenanceRequirementsForecast ] .

# --- 10.3.1.3 (PCF 19241) : Formulation -> Directive output
ex:P19241 a owl:Class ;
    ex:pcfID "19241" ; ex:hierarchyID "10.3.1.3" ;
    ex:apqcSourceText "Communicating policies in regards to asset maintenance. Provide a clear set of procedures and policies that outline what will be involved in the maintenance process." ;
    rdfs:label "Specify maintenance policies" ;
    skos:definition "An Act of Formulation that articulates the procedures and rules governing asset maintenance and has as output a maintenance policy." ;
    rdfs:comment "Anchored under ex:ActOfFormulation: its definitional output is a Directive ICE (Maintenance Policy). De-conflation note (Gate-F, false-friend caution): the source LEADS with 'Communicating policies in regards to asset maintenance' then 'Provide a clear set of procedures and policies'. Phase-1 reads 'Communicating' here as articulating/issuing the AUTHORED policy, not as policy dissemination; the definitional act is authoring the Directive ICE (ex:MaintenancePolicy), so the genus is Formulation (Act of Planning) and the GOLDEN PRINCIPLE holds (directive output -> planning genus). Rejected the Act of Communication reading (cco:ont00001261 / the cco:ont00000402 Act of Communication family): were this row genuine dissemination of an ALREADY-AUTHORED policy it would duplicate the authoring at 10.3.1.1 (strategy) / 10.3.1.7 (work plans); on a dissemination re-reading it should re-anchor to an Act of Communication with ex:MaintenancePolicy as has input, not has output." ;
    skos:example "A facilities office issues the documented maintenance policy and procedure manual." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaintenancePolicy ] .

# --- 10.3.1.4 (PCF 10968) : Planning -> Directive output
ex:P10968 a owl:Class ;
    ex:pcfID "10968" ; ex:hierarchyID "10.3.1.4" ;
    ex:apqcSourceText "Devising a methodology and procedure for assimilating the works of planned maintenance into the schedule scheme for the processing of finished products that utilizes the same machinery." ;
    rdfs:label "Integrate preventive maintenance into operations schedule" ;
    skos:definition "An Act of Planning that assimilates planned preventive maintenance into the production operations timetable and has as output a maintenance schedule." ;
    rdfs:comment "Anchored under cco:ont00000511 (Act of Planning): its definitional output is a Directive ICE (Maintenance Schedule) coordinating maintenance with production." ;
    skos:example "A planner slots preventive servicing into windows when the shared line is idle." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaintenanceSchedule ] .

# --- 10.3.1.5 (PCF 19242) : Formulation -> Directive (prioritized task list)
ex:P19242 a owl:Class ;
    ex:pcfID "19242" ; ex:hierarchyID "10.3.1.5" ;
    ex:apqcSourceText "Identifying the steps needed for asset maintenance. List out the those tasks that are involved in completing this process. Prioritize the tasks that are created." ;
    rdfs:label "Identify work management tasks & priorities" ;
    skos:definition "An Act of Formulation that enumerates and prioritizes the tasks required for asset maintenance and has as output a work task list." ;
    rdfs:comment "Although phrased 'Identify ...', the definitional output is a prescriptive prioritized task list (Directive ICE), so by the GOLDEN PRINCIPLE the genus is Formulation (Act of Planning), not Identification." ;
    skos:example "A supervisor compiles and ranks the work-order tasks for the upcoming maintenance window." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkTaskList ] .

# --- 10.3.1.6 (PCF 19243) : Planning -> Directive output
ex:P19243 a owl:Class ;
    ex:pcfID "19243" ; ex:hierarchyID "10.3.1.6" ;
    ex:apqcSourceText "Analyzing workload needs in relation to asset maintenance and plan resources around those needs." ;
    rdfs:label "Conduct resource planning" ;
    skos:definition "An Act of Planning that determines the resources required to meet asset-maintenance workload and has as output a resource plan." ;
    rdfs:comment "Anchored under cco:ont00000511 (Act of Planning): its definitional output is a Directive ICE (Resource Plan)." ;
    skos:example "A planner allocates technicians, parts, and budget to the forecasted maintenance workload." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResourcePlan ] .

# --- 10.3.1.7 (PCF 19244) : Formulation -> Directive output
ex:P19244 a owl:Class ;
    ex:pcfID "19244" ; ex:hierarchyID "10.3.1.7" ;
    ex:apqcSourceText "Creating procedures on how to maintain productive assets." ;
    rdfs:label "Create work plans" ;
    skos:definition "An Act of Formulation that composes the procedures for maintaining productive assets and has as output a work plan." ;
    rdfs:comment "Anchored under ex:ActOfFormulation: its definitional output is a Directive ICE (Work Plan)." ;
    skos:example "A planner writes the step-by-step work plan for servicing a pump assembly." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkPlan ] .

####################################################################
# 5.12  PROCESS GROUP 10.3.2  --  Manage asset maintenance  (PCF 19245)
####################################################################

ex:P19245 a owl:Class ;
    ex:pcfID "19245" ;
    ex:hierarchyID "10.3.2" ;
    ex:apqcSourceText "Ensuring that asset maintenance is conducted in a timely manner and successfully. Schedule work with the required resources with an eye on quality control and safety. Verify that contracted maintenance meets performance targets." ;
    rdfs:label "Manage asset maintenance" ;
    skos:definition "A Planned Act that coordinates the scheduling, resourcing, quality control, safety, and performance verification of asset-maintenance work to ensure it is completed successfully." ;
    rdfs:comment "Re-anchored (Gate-F, GOLDEN PRINCIPLE at the umbrella) from cco:ont00000511 (Act of Planning) to cco:ont00000228 (Planned Act), the honest umbrella genus for a heterogeneous coordination cycle. This node asserts NO has-output restriction, and several of its process parts are descriptive/appraisal acts (ex:P19248 Appraisal, ex:P19249 Info Processing, ex:P19250 Monitoring, ex:P19252 Monitoring) whose outputs are Descriptive ICEs, so typing the whole 'manage/coordinate execution' cycle as an Act of Planning ('making a Plan to achieve an Objective') over-commits the genus (the analysis-misfiled-under-Planning failure mode). Modeled as a bounded coordination occurrent (an execution-management cycle with begin/end), not a never-ending function: it hosts the 10.3.2 activities as process parts (cco:ont00001777), and the formulation/appraisal/monitoring children carry their own genera. The earlier has-output justification is withdrawn, since the class asserts no output. Consistent with the bounded-oversight umbrellas modeled elsewhere in 10.0." ;
    skos:example "A maintenance coordinator runs the cycle of scheduling crews, controlling quality, and confirming targets are met for a quarter's work." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19246 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19247 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19248 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19249 ] ,
        # 10.3.2.5 (ex:P19250) is a standing Organization Capability (R5/R6), NOT a process part -- see its block.
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19251 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19252 ] .

# --- 10.3.2.1 (PCF 19246) : Planning -> Directive output
ex:P19246 a owl:Class ;
    ex:pcfID "19246" ; ex:hierarchyID "10.3.2.1" ;
    ex:apqcSourceText "Defining a timetable for which to execute the maintenance of the asset." ;
    rdfs:label "Schedule maintenance work" ;
    skos:definition "An Act of Planning that defines the timetable for executing asset maintenance and has as output a maintenance schedule." ;
    rdfs:comment "Anchored under cco:ont00000511 (Act of Planning): its definitional output is a Directive ICE (Maintenance Schedule)." ;
    skos:example "A coordinator sets dates and crews for each scheduled servicing in the work queue." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaintenanceSchedule ] .

# --- 10.3.2.2 (PCF 19247) : Acquisition -> material output (operations)
ex:P19247 a owl:Class ;
    ex:pcfID "19247" ; ex:hierarchyID "10.3.2.2" ;
    ex:apqcSourceText "Gathering resources needed to complete all maintenance work. Verify that all resources have the proper training and skills to perform the work." ;
    rdfs:label "Obtain required resources" ;
    skos:definition "An Act of Acquisition that obtains the spare parts, consumables, and material resources needed to complete maintenance work, which participate in the act as the gathered maintenance resources." ;
    rdfs:comment "Reuses ex:ActOfAcquisition (Planned Act). Operations category: the obtained resources are material entities, attached as a material participant via obo:BFO_0000057 (has participant) -- the same pattern as the operations sibling 10.2.3.2 (ex:P19231 'Obtain resources'). Corrected (Gate-F, critical): the previous axiom's filler ex:AssetPart is defined as a part resulting from DISMANTLING an end-of-life asset (a 10.4 disposition concept), which is the wrong universal for resources gathered to PERFORM maintenance; replaced with the maintenance-resource material entity ex:MaintenanceResource. (Material fillers are modeled as has-participant rather than has-output here because in this domain a has-output filler must be an Information Content Entity.)" ;
    skos:example "A storekeeper draws spare parts and consumables for the week's work orders." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:MaintenanceResource ] .

# --- 10.3.2.3 (PCF 19248) : Appraisal -> Descriptive output
ex:P19248 a owl:Class ;
    ex:pcfID "19248" ; ex:hierarchyID "10.3.2.3" ;
    ex:apqcSourceText "Implementing a checks and balances system to verify that the maintenance was performed correctly. Rework when errors are found." ;
    rdfs:label "Undertake quality control" ;
    skos:definition "An Act of Appraisal that verifies whether maintenance work was performed correctly and has as output a quality control report." ;
    rdfs:comment "Anchored under cco:ont00000636 (Act of Appraisal): it judges the quality/condition of completed work, yielding a Descriptive ICE (Quality Control Report)." ;
    skos:example "An inspector checks a completed repair against spec and records pass/fail with required rework." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityControlReport ] .

# --- 10.3.2.4 (PCF 19249) : Information Processing -> Descriptive output
ex:P19249 a owl:Class ;
    ex:pcfID "19249" ; ex:hierarchyID "10.3.2.4" ;
    ex:apqcSourceText "Modifying existing maintenance records to include all new work that has been performed, what assets were serviced, and any issues that might have arisen." ;
    rdfs:label "Update work and asset records" ;
    skos:definition "An Act of Information Processing that revises maintenance records to register the work performed, the assets serviced, and any issues, and has as output an updated work and asset record." ;
    rdfs:comment "Anchored directly under cco:ont00000366 (Act of Information Processing): existing record ICEs are received and modified into an updated Descriptive ICE (Work and Asset Record)." ;
    skos:example "A technician closes a work order and updates the asset's service history." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkAndAssetRecord ] .

# --- 10.3.2.5 (PCF 19250) : STANDING FUNCTION -> Organization Capability (R5/R6)
ex:P19250 a owl:Class ;
    ex:pcfID "19250" ; ex:hierarchyID "10.3.2.5" ;
    ex:apqcSourceText "Assuring that all safety laws and regulations are being implemented and followed. Align practices with regulatory bureaus such as OSHA , EHS, and ISO." ;
    rdfs:label "Manage maintenance work safety" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to continuously assure that maintenance work practices implement and follow applicable safety laws and regulations and align with regulatory bureaus such as OSHA, EHS, and ISO." ;
    rdfs:comment "Re-modeled (Gate-F, R5 reconciliation) from a bounded ex:ActOfMonitoring process to a standing Organization Capability (cco:ont00000568), mirroring its parallel 10.2 sibling PCF 19228 (ex:P19228), which was modeled as a standing function for the same kind of safety/security/access assurance. The source ('Assuring that all safety laws and regulations are being implemented and followed') describes an ongoing, never-ending assurance function with no natural end, so by R5 it is a capability, not a bounded process. Realized in the org's safety-assurance acts (which produce ex:SafetyComplianceRecord). Therefore NOT a has-process-part of parent ex:P19245; the parallel rows 10.2.4.4 and 10.3.2.5 are now anchored consistently." ;
    skos:example "A firm's ongoing maintenance-safety assurance program aligning practices with OSHA, EHS, and ISO." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:MaintenanceSafetyAssuranceAct ] .

# SUPPORTING ACT for the 10.3.2.5 standing capability's R6 realization.
# Carries NO pcfID (supporting class). It attaches its descriptive output via
# rdfs:comment rather than a has-output restriction so it is not (mis)targeted
# by the Process provenance shape (which requires a pcfID); the genuine PCF
# process anchor for this row is the capability ex:P19250.
ex:MaintenanceSafetyAssuranceAct a owl:Class ;
    rdfs:subClassOf ex:ActOfMonitoring ;   # Act of Information Processing
    rdfs:label "Maintenance Safety Assurance Act" ;
    skos:definition "An Act of Monitoring that observes maintenance work practices against applicable safety laws and regulations and produces a safety compliance record." ;
    rdfs:comment "Minted (Gate-F) as the bounded act in which the standing ex:P19250 (Manage maintenance work safety) capability is realized (R6). The recurring assurance function is the capability; each individual observe-and-record occurrence is one of these acts, producing ex:SafetyComplianceRecord. GOLDEN PRINCIPLE: monitoring -> Descriptive ICE (Safety Compliance Record). (Output recorded here rather than as a has-output restriction so this supporting act is not flagged as a PCF process requiring a pcfID; the PCF anchor for 10.3.2.5 is the capability ex:P19250.)" .

# --- 10.3.2.6 (PCF 19251) : Formulation -> Directive output
ex:P19251 a owl:Class ;
    ex:pcfID "19251" ; ex:hierarchyID "10.3.2.6" ;
    ex:apqcSourceText "Outlining what should be achieved through predictive indicators with regard to performing maintenance. This could include the length of time it takes to perform routine maintenance or how often unplanned maintenance feasibly occur." ;
    rdfs:label "Define maintenance performance targets" ;
    skos:definition "An Act of Formulation that establishes the predictive performance indicators to be achieved in maintenance and has as output a maintenance performance target." ;
    rdfs:comment "Anchored under ex:ActOfFormulation: its definitional output is a Directive ICE (Maintenance Performance Target)." ;
    skos:example "A manager sets the target mean-time-to-repair and acceptable unplanned-failure rate." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaintenancePerformanceTarget ] .

# --- 10.3.2.7 (PCF 19252) : Monitoring -> Descriptive output
ex:P19252 a owl:Class ;
    ex:pcfID "19252" ; ex:hierarchyID "10.3.2.7" ;
    ex:apqcSourceText "Following set performance targets, monitor and gage the success of the organization in meeting those targets." ;
    rdfs:label "Monitor maintenance performance against targets/contracts" ;
    skos:definition "An Act of Monitoring that gauges maintenance performance against established targets and contracts and has as output a maintenance performance report." ;
    rdfs:comment "Anchored under ex:ActOfMonitoring (PROPOSE-EXT): it receives the performance-target ICE and observed results, yielding a Descriptive ICE (Maintenance Performance Report). The target is a definitional input." ;
    skos:example "A reliability engineer compares actual downtime against targets and reports variance to management." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MaintenancePerformanceTarget ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaintenancePerformanceReport ] .

####################################################################
# 5.13  PROCESS GROUP 10.3.3  --  Perform asset maintenance  (PCF 19253)
#    Physical work anchored at cco:ont00000950 Act of Maintenance.
####################################################################

ex:P19253 a owl:Class ;
    ex:pcfID "19253" ;
    ex:hierarchyID "10.3.3" ;
    ex:apqcSourceText "Engaging in all aspects of asset maintenance. Ensure that all assets are functioning properly and to all specified codes and regulations where applicable. Maintenance includes all preventative, routine, and corrective activates." ;
    rdfs:label "Perform asset maintenance" ;
    skos:definition "An Act of Maintenance in which an organization acts upon its productive assets to preserve or restore their designed functions, comprising preventive, routine, and corrective work." ;
    rdfs:comment "Anchored at cco:ont00000950 (Act of Maintenance), verified: 'An Act of Artifact Modification in which a Material Artifact is modified in order to preserve or restore one or more of its designed Qualities or Functions.' Its APQC activities are process parts (cco:ont00001777)." ;
    skos:example "A maintenance crew works through the preventive, routine, and corrective tasks on the plant's equipment." ;
    rdfs:subClassOf cco:ont00000950 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000950, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10947 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19254 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19255 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19256 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19257 ] .

# --- 10.3.3.1 (PCF 10947) : Act of Maintenance, material input
ex:P10947 a owl:Class ;
    ex:pcfID "10947" ; ex:hierarchyID "10.3.3.1" ;
    ex:apqcSourceText "Performing prophylactic maintenance in an effort to avoid corrective or unplanned repairs." ;
    rdfs:label "Perform preventative asset maintenance" ;
    skos:definition "An Act of Maintenance that acts upon a productive asset prophylactically to preserve its designed functions and avert future corrective or unplanned repairs." ;
    rdfs:comment "Anchored at cco:ont00000950 (Act of Maintenance). Operations category: the serviced productive asset is a material entity, attached as a definitional has-input filler (D4)." ;
    skos:example "A technician lubricates and calibrates a machine on its scheduled preventive interval." ;
    rdfs:subClassOf cco:ont00000950 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000950, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] .

# --- 10.3.3.2 (PCF 19254) : Act of Maintenance, material input
ex:P19254 a owl:Class ;
    ex:pcfID "19254" ; ex:hierarchyID "10.3.3.2" ;
    ex:apqcSourceText "Carrying out required maintenance to continue upkeep of equipment or assets." ;
    rdfs:label "Perform routine asset maintenance" ;
    skos:definition "An Act of Maintenance that carries out the recurring upkeep required to keep a productive asset in working condition." ;
    rdfs:comment "Anchored at cco:ont00000950 (Act of Maintenance); the maintained productive asset is a definitional material has-input filler." ;
    skos:example "A crew performs the routine filter changes and inspections on the HVAC system." ;
    rdfs:subClassOf cco:ont00000950 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000950, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] .

# --- 10.3.3.3 (PCF 19255) : Act of Maintenance (corrective/repair), material input
ex:P19255 a owl:Class ;
    ex:pcfID "19255" ; ex:hierarchyID "10.3.3.3" ;
    ex:apqcSourceText "Repairing or correcting faults that occur with an asset. This could be a break or other repairable damage." ;
    rdfs:label "Perform corrective asset maintenance and repairs" ;
    skos:definition "An Act of Maintenance that repairs or corrects a fault in a productive asset to restore its designed functions." ;
    rdfs:comment "Anchored at cco:ont00000950 (Act of Maintenance), whose definition explicitly covers restoring designed functions; the faulted asset is a definitional material has-input filler." ;
    skos:example "A technician replaces a failed bearing to return a pump to service." ;
    rdfs:subClassOf cco:ont00000950 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000950, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] .

# --- 10.3.3.4 (PCF 19256) : Identification (discernment) -> non-definitional I/O
ex:P19256 a owl:Class ;
    ex:pcfID "19256" ; ex:hierarchyID "10.3.3.4" ;
    ex:apqcSourceText "Realizing potential or current problems with assets that would require unplanned maintenance. Unplanned maintenance is a repair or change that needs to be made that is not preventative or routine." ;
    rdfs:label "Identify unplanned maintenance requirements" ;
    skos:definition "An Act of Identification that discerns current or potential asset problems requiring unplanned maintenance and registers the resulting requirements." ;
    rdfs:comment "Anchored under ex:ActOfIdentification (discernment sense, an Act of Information Processing). The output requirement register is typical but not present for every instance (a scan may find no new problems), so it is recorded here rather than as an owl:someValuesFrom restriction (Phase-3 necessity)." ;
    skos:example "An operator notices abnormal vibration and flags an unplanned-repair requirement." ;
    rdfs:subClassOf ex:ActOfIdentification .

# --- 10.3.3.5 (PCF 19257) : Act of Maintenance (unplanned/repair), material input
ex:P19257 a owl:Class ;
    ex:pcfID "19257" ; ex:hierarchyID "10.3.3.5" ;
    ex:apqcSourceText "Performing repairs that occur outside of normal routine or preventative maintenance." ;
    rdfs:label "Perform unplanned maintenance and repairs" ;
    skos:definition "An Act of Maintenance that performs repairs on a productive asset outside the routine or preventive maintenance schedule to restore its designed functions." ;
    rdfs:comment "Anchored at cco:ont00000950 (Act of Maintenance); the repaired asset is a definitional material has-input filler." ;
    skos:example "A crew is dispatched to fix an unexpected conveyor failure on the line." ;
    rdfs:subClassOf cco:ont00000950 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000950, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] .

####################################################################
# ================================================================
# GROUP 10.4  "Manage asset end-of-life"  (PCF 21576)
# ================================================================
####################################################################

####################################################################
# 5.14  PROCESS GROUP PARENT  --  10.4  (PCF 21576)
####################################################################

ex:P21576 a owl:Class ;
    ex:pcfID "21576" ;
    ex:hierarchyID "10.4" ;
    ex:apqcSourceText "Managing the disposition of assets at their end-of-life. End-of-life for an asset may be due to obsolescence, replacement, excess capacity, or disrepair among other potential factors. Steps may include decommissioning, disassembly, recycling, etc. Tracking and reporting may also be appropriate for some or all asset types due to law, regulation, or social/environmental responsibility." ;
    rdfs:label "Manage asset end-of-life" ;
    skos:definition "An Act of Disposition that retires and disposes of an organization's assets once they reach end-of-life, comprising the development of an exit strategy and the decommissioning, sale, dismantling, recycling, abandonment, and waste management of those assets." ;
    rdfs:comment "Models APQC process group 10.4 as a bounded occurrent. Its APQC children are process parts (cco:ont00001777), not subclasses. The standing function of operating take-back centers (10.4.4) is modeled as a capability (ex:AssetDispositionCapability), not a process part." ;
    skos:example "A utility's program to retire and dispose of an obsolete substation, from exit strategy through demolition, recycling, and regulatory reporting." ;
    rdfs:subClassOf ex:ActOfDisposition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10952 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19258 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10953 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21579 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21580 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21581 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12721 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12722 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21582 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21583 ] .

####################################################################
# 5.15  10.4.1 Develop exit strategy (PCF 10952) + activities
####################################################################

ex:P10952 a owl:Class ;
    ex:pcfID "10952" ;
    ex:hierarchyID "10.4.1" ;
    ex:apqcSourceText "Creating a strategy for managing asset exits." ;
    rdfs:label "Develop exit strategy" ;
    skos:definition "An Act of Formulation that examines the condition and economics of assets and produces an asset exit strategy prescribing how and when assets are to be exited." ;
    rdfs:comment "Directive output (ex:AssetExitStrategy) -> Act of Formulation (GOLDEN PRINCIPLE). Children are monitoring and analysis acts that feed the strategy." ;
    skos:example "An asset team drafts the multi-year retirement and replacement strategy for an ageing equipment fleet." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AssetExitStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18592 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21577 ] .

ex:P18592 a owl:Class ;
    ex:pcfID "18592" ;
    ex:hierarchyID "10.4.1.1" ;
    ex:apqcSourceText "Monitoring assets against their planned useful life. Each asset may have specific criteria that indicate their usability. This may include time-based, maintenance history, capacity planning, etc." ;
    rdfs:label "Monitor useful life of assets" ;
    skos:definition "An Act of Monitoring that observes assets against their planned useful-life criteria and produces a useful-life assessment of their remaining usability." ;
    rdfs:comment "GOLDEN PRINCIPLE: monitoring -> Descriptive ICE (UsefulLifeAssessment). Uses ex:ActOfMonitoring (PROPOSE-EXT)." ;
    skos:example "A reliability engineer tracks a pump against its rated service hours and reports it is approaching end-of-life." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:UsefulLifeAssessment ] .

ex:P21577 a owl:Class ;
    ex:pcfID "21577" ;
    ex:hierarchyID "10.4.1.2" ;
    ex:apqcSourceText "Cost/benefit analysis of assets to determine retention or end-of-life. Evaluating asset total lifecycle cost against other factors such as repair/refurbishment, replacement, and alternate solutions." ;
    rdfs:label "Perform cost vs. benefit analysis for replacement" ;
    skos:definition "An Act of Analysis that examines an asset's total lifecycle cost against repair, replacement, and alternative options and produces a cost-benefit analysis informing retention or end-of-life." ;
    rdfs:comment "GOLDEN PRINCIPLE: analysis -> Descriptive ICE (CostBenefitAnalysis). Uses ex:ActOfAnalysis." ;
    skos:example "An analyst compares the cost of refurbishing a turbine against replacing it and documents the trade-off." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CostBenefitAnalysis ] .

####################################################################
# 5.16  10.4.2 Decommission productive assets (PCF 19258)
####################################################################

ex:P19258 a owl:Class ;
    ex:pcfID "19258" ;
    ex:hierarchyID "10.4.2" ;
    ex:apqcSourceText "Retiring assets that are no longer viable to the business. Decommission assets that are no longer in working order, are out of date, or whose maintenance exceeds the cost of replacement." ;
    rdfs:label "Decommission productive assets" ;
    skos:definition "An Act of Disposition that retires a productive asset from active service because it is no longer in working order, is obsolete, or is uneconomic to maintain." ;
    rdfs:comment "Operations category: the asset is a definitional material input (cco:ont00001921 some ex:ProductiveAsset)." ;
    skos:example "A plant decommissions a worn-out compressor, isolating and de-energizing it ahead of removal." ;
    rdfs:subClassOf ex:ActOfDisposition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] .

####################################################################
# 5.17  10.4.3 Perform sale or trade (PCF 10953)
####################################################################

ex:P10953 a owl:Class ;
    ex:pcfID "10953" ;
    ex:hierarchyID "10.4.3" ;
    ex:apqcSourceText "Performing the sale of assets. Achieve and complete the sale process. Deliver the end product to the customers." ;
    rdfs:label "Perform sale or trade" ;
    skos:definition "An Act of Disposition that transfers ownership of an end-of-life asset to a buyer through sale or trade and produces a disposition record of the transaction." ;
    rdfs:comment "Asset is a definitional material input; ex:DispositionRecord captures the transaction. CCO 2.0 has no Act of Selling; disposition by ownership transfer anchors at ex:ActOfDisposition." ;
    skos:example "A fleet manager sells a retired delivery van to a dealer and records the sale." ;
    rdfs:subClassOf ex:ActOfDisposition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DispositionRecord ] .

####################################################################
# 5.18  10.4.5 Dismantle assets (PCF 21579)
####################################################################

ex:P21579 a owl:Class ;
    ex:pcfID "21579" ;
    ex:hierarchyID "10.4.5" ;
    ex:apqcSourceText "Dismantling an asset into manageable parts. The parts may follow different dispositions, such as resale, reuse, recycle, etc." ;
    rdfs:label "Dismantle assets" ;
    skos:definition "An Act of Artifact Modification that disassembles an end-of-life asset into manageable parts that may follow different downstream dispositions." ;
    rdfs:comment "Anchored to cco:ont00000970 (Act of Artifact Modification): the asset's structure is physically altered by removing parts, without yet disposing of them. Asset is a definitional material input; parts are the material output." ;
    skos:example "A technician disassembles a decommissioned generator into its motor, frame, and copper windings." ;
    rdfs:subClassOf cco:ont00000970 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000970, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductiveAsset ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:AssetPart ] .

####################################################################
# 5.19  10.4.6 Track parts (PCF 21580)
####################################################################

ex:P21580 a owl:Class ;
    ex:pcfID "21580" ;
    ex:hierarchyID "10.4.6" ;
    ex:apqcSourceText "Tracking the disposition of all parts from end-of-life assets. Tracking should provide an audit trail to include source, rational for disposition, and destination." ;
    rdfs:label "Track parts" ;
    skos:definition "An Act of Monitoring that follows the disposition of parts from end-of-life assets and produces a part tracking record providing an audit trail of source, rationale, and destination." ;
    rdfs:comment "GOLDEN PRINCIPLE: monitoring/tracking -> Descriptive ICE (PartTrackingRecord). Uses ex:ActOfMonitoring (PROPOSE-EXT)." ;
    skos:example "A disposition coordinator logs each salvaged part's origin asset, chosen disposition, and final destination." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PartTrackingRecord ] .

####################################################################
# 5.20  10.4.7 Recycle parts (PCF 21581)
####################################################################

ex:P21581 a owl:Class ;
    ex:pcfID "21581" ;
    ex:hierarchyID "10.4.7" ;
    ex:apqcSourceText "Recycling parts in accordance with legal, regulatory, and social/environmental responsibilities." ;
    rdfs:label "Recycle parts" ;
    skos:definition "An Act of Disposition that processes parts from end-of-life assets into recovered material in accordance with legal, regulatory, and social/environmental responsibilities." ;
    rdfs:comment "Parts are a definitional material input; recovered material is the output. Operations category permits material I/O." ;
    skos:example "Copper windings stripped from a dismantled motor are sent to a smelter and returned as recovered copper stock." ;
    rdfs:subClassOf ex:ActOfDisposition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:AssetPart ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RecoveredMaterial ] .

####################################################################
# 5.21  10.4.8 Ship hazardous material (PCF 12721)
####################################################################

ex:P12721 a owl:Class ;
    ex:pcfID "12721" ;
    ex:hierarchyID "10.4.8" ;
    ex:apqcSourceText "Planning, conducting, and tracking shipment of hazardous materials." ;
    rdfs:label "Ship hazardous material" ;
    skos:definition "An Act of Cargo Transportation that moves a portion of hazardous material from one location to another under controlled, tracked conditions." ;
    rdfs:comment "Anchored to cco:ont00000595 (Act of Cargo Transportation): the payload (hazardous material) changes location. Hazardous material is a definitional material input/payload." ;
    skos:example "A licensed carrier transports drums of spent solvent from a plant to a treatment facility with manifest tracking." ;
    rdfs:subClassOf cco:ont00000595 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000595, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HazardousMaterial ] .

####################################################################
# 5.22  10.4.9 Provide government reporting (PCF 12722)
####################################################################

ex:P12722 a owl:Class ;
    ex:pcfID "12722" ;
    ex:hierarchyID "10.4.9" ;
    ex:apqcSourceText "Preparing and distributing government reports." ;
    rdfs:label "Provide government reporting" ;
    skos:definition "An Act of Reporting that prepares and distributes a government report accounting for asset end-of-life and waste activities to a regulatory authority." ;
    rdfs:comment "Anchored to cco:ont00000151 (Act of Reporting, an Act of Representative Communication). Descriptive output (ex:GovernmentReport). Regulatory authority is the recipient participant." ;
    skos:example "An environmental compliance officer files the annual hazardous-waste generation report with the regulator." ;
    rdfs:subClassOf cco:ont00000151 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000151, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GovernmentReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryAuthority ] .

####################################################################
# 5.23  10.4.10 Perform abandonment (PCF 21582) + activities
####################################################################

ex:P21582 a owl:Class ;
    ex:pcfID "21582" ;
    ex:hierarchyID "10.4.10" ;
    ex:apqcSourceText "Planning and performing abandonment activities. Whether facilities  or equipment, ensure assets to be abandoned are safe, secure, and meet all legal, regulatory, and social/environmental responsibilities." ;
    rdfs:label "Perform abandonment" ;
    skos:definition "An Act of Disposition that abandons a facility or equipment by demolishing and securing it, restoring its site, monitoring the site as required, and handing it over, ensuring the abandoned asset is safe, secure, and compliant." ;
    rdfs:comment "Parent of four sub-activities (process parts). Anchored at ex:ActOfDisposition because abandonment removes an asset from service and ownership responsibility." ;
    skos:example "An operator abandons a depleted well site: plugging, demolishing surface equipment, remediating soil, and handing the land back." ;
    rdfs:subClassOf ex:ActOfDisposition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P13131 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P13132 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19465 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P13133 ] .

ex:P13131 a owl:Class ;
    ex:pcfID "13131" ;
    ex:hierarchyID "10.4.10.1" ;
    ex:apqcSourceText "Demolishing and securing asset and resulting parts/debris." ;
    rdfs:label "Demolish and secure" ;
    skos:definition "An Act of Artifact Modification that demolishes an asset and secures the resulting parts and debris." ;
    rdfs:comment "Anchored to cco:ont00000970 (Act of Artifact Modification): the asset's physical structure is destructively altered. Asset is a definitional material input; debris/parts the material output." ;
    skos:example "A demolition crew razes a disused warehouse and fences off the rubble." ;
    rdfs:subClassOf cco:ont00000970 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000970, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Facility ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:AssetPart ] .

ex:P13132 a owl:Class ;
    ex:pcfID "13132" ;
    ex:hierarchyID "10.4.10.2" ;
    ex:apqcSourceText "Performing remediation or restoration activities." ;
    rdfs:label "Restore site" ;
    skos:definition "An Act of Disposition that performs remediation or restoration activities on a site to make it environmentally safe and compliant as part of an asset's end-of-life." ;
    rdfs:comment "Re-anchored (Gate-F, false-friend) from cco:ont00000950 (Act of Maintenance) to ex:ActOfDisposition. CCO Act of Maintenance is 'An Act of Artifact Modification in which a MATERIAL ARTIFACT is modified in order to preserve or restore one or more of its DESIGNED Qualities or Functions', but the only definitional participant here is ex:RealProperty, which the slice anchors at obo:BFO_0000040 (a material entity, NOT a Material Artifact) precisely because raw/contaminated land is not a designed artifact and has no designed Qualities. Remediation restores ENVIRONMENTAL qualities of land, not designed artifact qualities, so the Maintenance genus (and its artifact-hood presupposition) is violated by its own input. Anchored under ex:ActOfDisposition, consistent with its abandonment-parent ex:P21582, whose endpoint is making the site safe/compliant. The ex:RealProperty filler is kept as obo:BFO_0000057 (has participant), not the artifact-presupposing maintenance has-input frame." ;
    skos:example "A remediation contractor removes contaminated soil and re-grades a former tank farm." ;
    rdfs:subClassOf ex:ActOfDisposition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RealProperty ] .

ex:P19465 a owl:Class ;
    ex:pcfID "19465" ;
    ex:hierarchyID "10.4.10.3" ;
    ex:apqcSourceText "Managing and reporting site status. Align efforts to all legal, regulatory and social/environmental responsibilities." ;
    rdfs:label "Monitor site for duration of time required by regulators" ;
    skos:definition "An Act of Monitoring that observes an abandoned site for the duration required by regulators and produces a site status report documenting its condition." ;
    rdfs:comment "GOLDEN PRINCIPLE: monitoring -> Descriptive ICE (SiteStatusReport). Uses ex:ActOfMonitoring (PROPOSE-EXT)." ;
    skos:example "For thirty years after closure, a landfill operator monitors groundwater and reports site status to the regulator." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SiteStatusReport ] .

ex:P13133 a owl:Class ;
    ex:pcfID "13133" ;
    ex:hierarchyID "10.4.10.4" ;
    ex:apqcSourceText "Supporting handover to new operator or landowner. Include proper documentation on asset history and current state to enable orderly transition." ;
    rdfs:label "Prepare handover to new operator or landowner" ;
    skos:definition "An Act of Information Processing that compiles asset history and current-state information into handover documentation enabling an orderly transition to a new operator or landowner." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): existing records are compiled into a descriptive handover package. Descriptive output -> matches genus (GOLDEN PRINCIPLE)." ;
    skos:example "A site team assembles as-built drawings, inspection history, and a condition report for the incoming landowner." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AssetHandoverDocumentation ] .

####################################################################
# 5.24  10.4.11 Perform waste and hazardous goods management (PCF 21583)
#       + eight activities
####################################################################

ex:P21583 a owl:Class ;
    ex:pcfID "21583" ;
    ex:hierarchyID "10.4.11" ;
    ex:apqcSourceText "Planning and performing waste and hazardous goods management. In compliance with all legal, regulatory, and social/environmental requirements, plan, document, and conduct hazardous material handling, disposal, and reporting." ;
    rdfs:label "Perform waste and hazardous goods management" ;
    skos:definition "An Act of Disposition that plans, documents, and conducts the compliant handling, disposal, and reporting of waste and hazardous materials." ;
    rdfs:comment "Parent of eight sub-activities (process parts). Anchored at ex:ActOfDisposition because its endpoint is the compliant removal/disposal of hazardous materials and waste." ;
    skos:example "A facility's hazardous-waste program: characterizing, manifesting, shipping, and reporting each waste stream to disposal." ;
    rdfs:subClassOf ex:ActOfDisposition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HazardousMaterial ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12180 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12181 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12182 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12183 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12184 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12185 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12186 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12187 ] .

ex:P12180 a owl:Class ;
    ex:pcfID "12180" ;
    ex:hierarchyID "10.4.11.1" ;
    ex:apqcSourceText "Preparing material safety sheets. Capture material safety records to properly apply handling and disposal requirements." ;
    rdfs:label "Maintain material safety data sheets" ;
    skos:definition "An Act of Information Processing that captures material safety information and produces a material safety data sheet used to apply handling and disposal requirements." ;
    rdfs:comment "Verb 'Maintain' denotes preparing/capturing records (a bounded act), not a standing function. Descriptive output (ex:MaterialSafetyDataSheet)." ;
    skos:example "An EHS specialist compiles the safety data sheet for a newly stocked solvent." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaterialSafetyDataSheet ] .

ex:P12181 a owl:Class ;
    ex:pcfID "12181" ;
    ex:hierarchyID "10.4.11.2" ;
    ex:apqcSourceText "Understanding and communicating hazardous material regulatory requirements." ;
    rdfs:label "Maintain awareness of and communicate regulatory requirements" ;
    skos:definition "An Act of Reporting that conveys hazardous-material regulatory requirements to the personnel responsible for compliance and produces a regulatory requirements briefing accounting for them." ;
    rdfs:comment "Anchored to cco:ont00000151 (Act of Reporting, an Act of Representative Communication whose proper product is a DESCRIPTIVE account). Corrected (Gate-F, GOLDEN PRINCIPLE): the externally-authored Directive ex:RegulatoryRequirementsStatement is the COMMUNICATED CONTENT (has input via cco:ont00001921), not a product of this act -- a reporting/communication act does not AUTHOR a directive, it RELAYS it. The produced output is the descriptive ex:RegulatoryRequirementsBriefing (has output), so the descriptive genus now agrees with the descriptive output. (If on review this row is genuine authoring of the requirements, it would instead re-anchor to a directive-producing planning genus.)" ;
    skos:example "A compliance lead briefs the disposal team on updated transport rules for corrosives." ;
    rdfs:subClassOf cco:ont00000151 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000151, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryRequirementsStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryRequirementsBriefing ] .

ex:P12182 a owl:Class ;
    ex:pcfID "12182" ;
    ex:hierarchyID "10.4.11.3" ;
    ex:apqcSourceText "Planning, overseeing, and tracking hazardous material handling and disposal." ;
    rdfs:label "Maintain hazardous material handling and disposal" ;
    skos:definition "An Act of Disposition that plans, oversees, and tracks the handling and disposal of hazardous material." ;
    rdfs:comment "Verb 'Maintain' here denotes conducting handling/disposal, a bounded disposition performance. Hazardous material is the definitional material input." ;
    skos:example "A waste coordinator schedules, supervises, and logs the neutralization and disposal of a spent-acid batch." ;
    rdfs:subClassOf ex:ActOfDisposition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HazardousMaterial ] .

ex:P12183 a owl:Class ;
    ex:pcfID "12183" ;
    ex:hierarchyID "10.4.11.4" ;
    ex:apqcSourceText "Planning, supporting, and documenting hazardous material audits." ;
    rdfs:label "Manage compliance audits" ;
    skos:definition "An Act of Appraisal that examines hazardous-material handling against regulatory requirements and produces a compliance audit report." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): an audit evaluates and judges compliance. Descriptive output (ex:ComplianceAuditReport)." ;
    skos:example "An auditor reviews manifests and storage practices and issues a hazardous-waste compliance audit report." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ComplianceAuditReport ] .

ex:P12184 a owl:Class ;
    ex:pcfID "12184" ;
    ex:hierarchyID "10.4.11.5" ;
    ex:apqcSourceText "Identifying and establishing approaches to dispose of hazardous materials/waste." ;
    rdfs:label "Recognize need to disposition hazardous materials/waste" ;
    skos:definition "An Act of Identification that discerns hazardous materials or waste requiring disposition and registers the recognized disposition need." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment sense). The 'approaches to dispose' established here are typical follow-on detail, captured downstream at 10.4.11.6; the definitional output is the descriptive recognition (ex:DispositionNeedRegister)." ;
    skos:example "An operator flags a quantity of expired reagent as requiring disposal." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DispositionNeedRegister ] .

ex:P12185 a owl:Class ;
    ex:pcfID "12185" ;
    ex:hierarchyID "10.4.11.6" ;
    ex:apqcSourceText "Evaluating hazardous materials and waste for appropriate disposition. Apply requirements and initiate disposition activities." ;
    rdfs:label "Determine disposition and associated processing" ;
    skos:definition "An Act of Selection that evaluates hazardous materials and waste against requirements and chooses an appropriate disposition, producing an asset disposition decision that initiates disposition activities." ;
    rdfs:comment "Anchored to ex:ActOfSelection: a disposition approach is chosen from candidate options, yielding a Directive ICE (ex:DispositionDecision) -> directive output (GOLDEN PRINCIPLE)." ;
    skos:example "A specialist determines that a contaminated batch must be incinerated rather than landfilled and issues the disposition decision." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HazardousMaterial ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DispositionDecision ] .

ex:P12186 a owl:Class ;
    ex:pcfID "12186" ;
    ex:hierarchyID "10.4.11.7" ;
    ex:apqcSourceText "Performing disposition, disposal, and reprocessing activities." ;
    rdfs:label "Manage disposition, disposal, reprocessing activities" ;
    skos:definition "An Act of Disposition that performs the disposition, disposal, and reprocessing of hazardous materials and waste." ;
    rdfs:comment "Verb 'Manage' here denotes performing the activities, a bounded disposition. Hazardous material is the definitional material input." ;
    skos:example "A licensed handler incinerates a hazardous batch and reprocesses recoverable solvent." ;
    rdfs:subClassOf ex:ActOfDisposition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HazardousMaterial ] .

ex:P12187 a owl:Class ;
    ex:pcfID "12187" ;
    ex:hierarchyID "10.4.11.8" ;
    ex:apqcSourceText "Documenting and reporting disposition, disposal, and reprocessing activities." ;
    rdfs:label "Manage documentation and reporting" ;
    skos:definition "An Act of Reporting that documents and reports the disposition, disposal, and reprocessing activities performed on hazardous materials and waste, producing a disposition and disposal record." ;
    rdfs:comment "Anchored to cco:ont00000151 (Act of Reporting). Descriptive outputs (ex:DispositionRecord, ex:ReprocessingRecord)." ;
    skos:example "A coordinator files the disposal manifests and reprocessing logs for the quarter's hazardous-waste shipments." ;
    rdfs:subClassOf cco:ont00000151 ,
        cco:ont00000228 ,   # Planned Act (explicit anchor; entailed via cco:ont00000151, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DispositionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ReprocessingRecord ] .

# --- 10.4.4 Manage take-back centers (PCF 12717) -- R6 CAPABILITY ---
# Standing function (no natural end) -> Organization Capability, realized
# in the disposition acts. Reuses shared ex:AssetDispositionCapability
# (defined in section 4 above). Catalog bridge: ex:PCF_12717 ->
# ex:AssetDispositionCapability (section 6 below). Not minted as a process.

