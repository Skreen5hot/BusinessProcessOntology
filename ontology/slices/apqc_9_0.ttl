@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC reality-layer slice 9.0 "Manage Financial Resources"
####################################################################

<http://example.org/apqc/slice/9.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 9.0: Manage Financial Resources" ;
    dct:source "APQC Process Classification Framework (Cross-Industry)" ;
    owl:versionInfo "0.3.0" ;
    rdfs:comment "Reality-layer module for APQC section 9.0. CCO pin v2.0 (2024-11-06); modeled per ADR-001 (two-layer model, R5 bounded-occurrent test). Self-contained: the shared act genera it uses are inlined from the apqc-ext.ttl registry, so it validates standalone against the pinned CCO/BFO closure with no extension merge." .

####################################################################
# ACT GENERA -- SELF-CONTAINED (canonical defs mirrored from
# apqc-ext.ttl, the D9 shared registry). Inlined so this module
# validates standalone against CCO without merging the extension.
####################################################################

ex:ActOfAccounting a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Accounting" ;
    skos:definition "An Act of Information Processing in which an Agent records, classifies, posts, or reconciles financial transactions and produces or updates a Descriptive Information Content Entity (such as a ledger, journal, or account record) that registers the organization's financial state." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic bookkeeping/record-keeping class; recording and reconciling transactions manipulates input ICEs into an updated record ICE, so it anchors under cco:ont00000366 (Act of Information Processing), per the GOLDEN PRINCIPLE. Rejected cco:ont00000950 'Act of Maintenance' (modifies Material Artifacts, not records). Distinct from ex:ActOfFinancialTransaction (which moves the money itself). Recurs in accounting categories (9.0; likely 8.0)." .

ex:ActOfAcquisition a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Acquisition" ;
    skos:definition "A Planned Act in which an Agent obtains from some authority or supplier an entity (such as an authorization, license, or resource) that the Agent did not previously hold." ;
    rdfs:comment "Local extension (D9). Rejected cco:ont00000950 'Act of Maintenance' (modifying Material Artifacts) and cco:ont00000402 'Act of Communication' (mere ICE transfer). Securing/obtaining a held entity anchors at the generic Planned Act. Expected to recur in procurement/asset-acquisition categories (4.0, 10.0)." .

ex:ActOfAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Analysis" ;
    skos:definition "An Act of Information Processing in which an Agent examines one or more input Information Content Entities and produces an Information Content Entity that represents an understanding of their subject matter." ;
    rdfs:comment "Local extension (D9). CCO 2.0 has no generic analysis class; analysis is information processing, so it is anchored under cco:ont00000366." .

ex:ActOfCardAdministration a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Card Administration" ;
    skos:definition "A Planned Act in which an Agent issues, handles, processes a request for, or deactivates a payment card on behalf of an Organization, thereby establishing or altering the card's status without itself transferring money or a Financial Instrument." ;
    rdfs:comment "PROPOSE-EXT (D9). Minted for the corporate-credit-card lifecycle family (issue/handle, process requests, deactivate). REJECTED ex:ActOfFinancialTransaction: card issuance/handling/blocking transfers no money and settles no obligation, so it falls outside that genus's differentia ('transfers money or a Financial Instrument in settlement') -- anchoring it there was a false friend driven by the surface theme 'credit card'. Anchored at the generic cco:ont00000228 (Planned Act) because the act operates on the card artifact (a material participant) rather than manipulating only ICEs (cco:ont00000366) or obtaining a not-previously-held entity (ex:ActOfAcquisition, which covers ordering a card). Recurs in 9.0." .

ex:ActOfFinancialTransaction a owl:Class ;
    rdfs:subClassOf cco:ont00000836 ,   # Act of Financial Instrument Use
        cco:ont00000228 ;               # Planned Act (co-asserted: 836 is outside the S2 standalone-SHACL process-anchor allowlist {366,636,511,228}; 836 -> 566 -> 228 in the CCO closure)
    rdfs:label "Act of Financial Transaction" ;
    skos:definition "A Planned Act in which an Agent transfers or uses money or a Financial Instrument to or from another Agent in settlement of an obligation, an investment, or an exchange." ;
    rdfs:comment "PROPOSE-EXT (D9). Re-anchored from the bare cco:ont00000228 to cco:ont00000836 (Act of Financial Instrument Use): every subclass here uses/transfers a Financial Instrument (money and cash are Financial Instruments in CCO -- cf. Portion of Cash cco:ont00000475 subClassOf 537), and CCO models settlements, loans, purchases, deposits, withdrawals and exchanges uniformly under 836, so the earlier claim that this genus is 'broader than financial-instrument use' was incorrect (investments and exchanges still USE financial instruments). Rejected cco:ont00001334 'Act of Purchasing' and cco:ont00000389 'Act of Buying' (both acquire a good/service -- too narrow for payments/remittances/trades/deposits) and cco:ont00000366 'Act of Information Processing' (a payment moves a material/financial-instrument filler, not only an ICE). cco:ont00000228 co-asserted because 836 falls outside the S2 standalone-SHACL allowlist. Recurs in payment/treasury/trade categories (9.0)." .

ex:ActOfRemuneration a owl:Class ;
    rdfs:subClassOf cco:ont00000449 ,   # Act of Remuneration (Employer compensates Employee)
        cco:ont00000228 ;               # Planned Act (co-asserted: 449 -> 1334 -> 836 -> 566 -> 228; 449 is outside the S2 allowlist {366,636,511,228})
    rdfs:label "Act of Remuneration" ;
    skos:definition "An Act of Remuneration in which an Employer disburses a Financial Instrument (salary, wages, bonus, or other compensation) to an Employee for services performed." ;
    rdfs:comment "PROPOSE-EXT (D9). Inlines the verified CCO leaf cco:ont00000449 (Act of Remuneration, subClassOf cco:ont00001334 Act of Purchasing subClassOf cco:ont00000836) for payroll rows whose APQC text is salary/compensation disbursement to employees -- a closer genus than ex:ActOfFinancialTransaction. NOT used for payroll-TAX remittance to a government authority (the recipient is not the compensated employee; those keep ex:ActOfFinancialTransaction). cco:ont00000228 co-asserted because 449 is outside the standalone-SHACL S2 process-anchor allowlist." .

ex:ActOfFormulation a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Formulation" ;
    skos:definition "An Act of Planning in which an Agent composes and articulates a Directive Information Content Entity - such as a mission, strategy, objective, design, roadmap, or business model - that prescribes an organization's intended course of action." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000511 (Act of Planning) because formulating a strategy/mission/design is making a plan to achieve an objective; its output is a Directive ICE. Recurs across develop/define/compose-a-directive processes corpus-wide." .

ex:ActOfIdentification a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Identification (discernment sense)" ;
    skos:definition "An Act of Information Processing in which an Agent discerns and enumerates entities of a given kind and produces an Information Content Entity that registers them." ;
    rdfs:comment "Local extension (D9). NOT cco:ont00001261 'Act of Identifying' (a communication act). APQC 'Identify ...' denotes discernment, i.e. information processing." .

ex:ActOfMonitoring a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Monitoring" ;
    skos:definition "An Act of Information Processing in which an Agent repeatedly or continuously observes the state, progress, or performance of some process, system, or quantity over time and produces a Descriptive Information Content Entity that represents its tracked status against expected conditions, targets, or requirements." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic monitoring/tracking class. Anchored under cco:ont00000366 (Act of Information Processing) because monitoring ingests repeated observations (including electronic records, not only senses) and yields a descriptive status/deviation ICE -- the GOLDEN PRINCIPLE (descriptive output => information-processing genus) holds. Rejected cco:ont00000037 (Act of Observation: a single sense-based acquisition, too narrow -- monitoring also processes ICEs and is sustained); cco:ont00000636 (Act of Appraisal: renders a single bounded value/quality judgement rather than tracking status over time); and cco:ont00000345 (Act of Measuring: a single quantification against a standard at one time -- at most a method sub-step of the monitoring cycle; a node that is purely one quantification, e.g. Calculate performance measures, anchors to cco:ont00000345 directly, not here). Distinct from ex:ActOfAnalysis (one-shot examination of a fixed input set) by its continuous, longitudinal character. A standing 'Manage/Monitor X' function with no natural end is an Organization Capability (cco:ont00000568) realized in such acts, not itself a process. Recurs corpus-wide (slices 3.0/4.0/5.0/6.0/8.0/9.0/10.0/11.0/12.0/13.0). Reconciled from 10 divergent slice restatements to one definition." .

ex:ActOfOrganizationalEstablishment a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Organizational Establishment" ;
    skos:definition "A Planned Act in which an Agent constitutes and seats an Organization or organizational body (such as a board, committee, or unit), bringing the body into existence and conferring its mandate." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no Act-of-Establishment/Organization class (verified: no 'Act of Establish/Organiz/Constitut/Found' label in the closure). REJECTED ex:ActOfFormulation (Act of Planning): formulating composes a Directive ICE, but establishing a committee primarily constitutes an independent continuant (the body) rather than authoring a directive; the responsibility-assignment directive is a downstream byproduct of seating the body, not the act's primary product. Anchored at the generic cco:ont00000228 (Planned Act). Recurs in 9.0." .

ex:ActOfReporting a owl:Class ;
    rdfs:subClassOf cco:ont00000379 ,   # Act of Representative Communication
        cco:ont00000228 ;               # Planned Act (explicit allowlist anchor; ont00000379 -> ont00000402 -> ont00000228 in the CCO closure, asserted locally so the standalone SHACL S2 Act-anchor chain resolves)
    rdfs:label "Act of Reporting" ;
    skos:definition "An Act of Representative Communication in which an Agent transfers to one or more recipients a Descriptive Information Content Entity (such as a report, statement, scorecard, or filing) that asserts, as true, a representation of an organization's condition or results." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no broad reporting class spanning compilation and assertion. Anchored under cco:ont00000379 (Act of Representative Communication), with cco:ont00000228 (Planned Act) co-anchored so standalone SHACL resolves the act chain: reporting transfers to recipients a descriptive account (report, statement, scorecard, filing) asserting an organization's condition or results. Pure submission of an already-prepared report may use the verified leaf cco:ont00000151 directly." .

ex:ActOfSelection a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Selection" ;
    skos:definition "An Act of Information Processing in which an Agent chooses one or more options from a set of candidates and produces a Directive Information Content Entity that prescribes the chosen option(s)." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000366 (Act of Information Processing): receives candidate-option ICEs and yields a decision ICE. Distinct from Act of Appraisal (judges without committing) and Act of Planning. NOTE: ratifying a single already-settled option is NOT selection (no candidate set) -- anchor such acts at cco:ont00000228 (Planned Act)." .

####################################################################
# 0. ANNOTATION PROPERTIES (provenance / traceability)
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "Catalog-to-reality bridge: links an APQC catalog node (ex:PCF_<pcfID>) to the reality-layer class (process or capability) it designates." .

####################################################################
# 1. DOMAIN ACT-GENUS LAYER
#    Canonical shared genera used by this slice are inlined from the
#    apqc-ext.ttl registry so the module validates standalone against
#    the pinned CCO/BFO closure -- no apqc-ext.ttl import is required.
#    Inlined genera: ex:ActOfAnalysis, ex:ActOfIdentification,
#    ex:ActOfFormulation, ex:ActOfSelection, ex:ActOfAcquisition --
#    these recur across section 9.0 and are emitted ONCE (the group
#    modules' standalone re-declarations are reconciled to these single
#    canonical definitions). Section-specific genera remain marked
#    PROPOSE-EXT where they should be reviewed for promotion. Every cco:
#    anchor verified against CommonCoreOntologiesMerged v2.0
#    (2024-11-06): definition + parent read, not just label.
####################################################################

####################################################################
# 1b. CCO SUPERCLASS BRIDGES (for standalone Gate-C SHACL only)
# Gate C validates this module STANDALONE without merging the CCO
# closure, so subclass-chain shapes (S2/S5, process-part, ICE-kind)
# cannot see CCO's own rdfs:subClassOf axioms for the directly-reused
# CCO act/ICE classes below. These three bridge triples re-state the
# verified CCO axioms IN-MODULE so the chains resolve offline. Each is
# a faithful copy of the pinned CCO v2.0 (2024-11-06) hierarchy and is
# redundant once the CCO closure is merged. (Same need that motivated
# the explicit cco:ont00000228 anchor on ex:P10877.)
####################################################################

cco:ont00000371 rdfs:subClassOf cco:ont00000228 .   # Act of Prediction -> Planned Act
cco:ont00000402 rdfs:subClassOf cco:ont00000228 .   # Act of Communication -> Planned Act
cco:ont00000626 rdfs:subClassOf cco:ont00000853 .   # Predictive ICE -> Descriptive ICE

####################################################################
# 2. SHARED SUPPORTING VOCABULARY (reality layer)
# Single source of supporting classes reused by every 9.x group module
# so the groups never re-mint or collide. NO process classes here.
# Every cco:ont... IRI below verified against CommonCoreOntologiesMerged
# v2.0 (2024-11-06): label + definition + parent read, not label alone.
# Operations note: 9.0 is an operations category, so MATERIAL I/O
# (bfo:material entity fillers) is legal (CONTEXT.md).
####################################################################

####################################################################
# 2a. REALIZABLES -- ROLES  (obo:BFO_0000023; borne by Agents/Orgs only)
####################################################################

ex:FinanceFunctionRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Finance Function Role" ;
    skos:definition "A Role that is borne by an Agent or organizational unit in virtue of being tasked with carrying out the financial management activities of an Organization." ;
    rdfs:comment "Shared across 9.0. Borne by the independent continuant (the finance unit or officer), never by an ICE." .

ex:AccountantRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Accountant Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with recording, classifying, and reporting an Organization's financial transactions." .

ex:TreasurerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Treasurer Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with managing an Organization's cash, liquidity, debt, investments, and financial risk." .

ex:AuditorRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Auditor Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of independently examining and attesting to an organization's records, controls, or compliance." ;
    rdfs:comment "Covers both internal and external auditors; the bearer (a Person or Organization) carries the role." .

ex:RegulatorRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Regulator Role" ;
    skos:definition "A Role that is borne by an authority in virtue of having legal power to issue and enforce financial, tax, or trade rules binding on an Organization." .

ex:CustomerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Customer Role" ;
    skos:definition "A Role that is borne by an Agent or Organization in virtue of acquiring, consuming, contracting for, or being a target acquirer of the goods or services of a focal organization." .

ex:SupplierRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Supplier Role" ;
    skos:definition "A Role that is borne by an Agent or Organization in virtue of furnishing goods, materials, resources, or services to a procuring organization, typically for consideration." ;
    rdfs:comment "Used for accounts-payable counterparties (vendors) in 9.6." .

ex:EmployeeRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Employee Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being engaged or employed by an organization to perform assigned activities in exchange for compensation." ;
    rdfs:comment "Used for payroll and expense-reimbursement subjects in 9.5 and 9.6." .

ex:DebtorRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Debtor Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of owing an outstanding amount to an Organization under a credit or payment obligation." ;
    rdfs:comment "Used for delinquent/default account holders in 9.2." .

ex:SubsidiaryRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Subsidiary Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of being a separate legal entity controlled by a parent Organization." ;
    rdfs:comment "Used in consolidation, in-house banking, and international-funds processes (9.3, 9.7, 9.10)." .

ex:BankingPartnerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Banking Partner Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of providing banking, financial-intermediary, or custodial services to a focal Organization." ;
    rdfs:comment "Used for banks and financial intermediaries in treasury and international-funds processes (9.7, 9.10)." .

####################################################################
# 2b. REALIZABLES -- CAPABILITIES  (cco:ont00001379 Agent Capability;
#     cco:ont00000568 Organization Capability where bearer is an Org)
####################################################################

ex:FinancialManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Financial Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to plan, account for, control, and report on its financial resources." ;
    rdfs:comment "Process-layer 'Manage ...' standing functions (R5 capabilities) realize-in the section's acts; group modules attach realized-in restrictions to this or its specializations." .

ex:AccountingCapability a owl:Class ;
    rdfs:subClassOf cco:ont00001379 ;   # Agent Capability
    rdfs:label "Accounting Capability" ;
    skos:definition "An Agent Capability that inheres in an Agent in virtue of its capacity to record, classify, reconcile, and report financial transactions." .

ex:TreasuryManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Treasury Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to manage cash, liquidity, debt, investments, and financial risk." .

ex:TaxManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Tax Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to estimate, plan, file, and pay its tax liabilities." .

ex:InternalControlCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Internal Control Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to establish, operate, monitor, and report on internal controls over financial reporting and operations." .

####################################################################
# 2c. AGENTS & ORGANIZATIONS
#     (cco:ont00001017 Agent / cco:ont00001180 Organization)
####################################################################

ex:FinanceFunction a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;   # bearer of
          owl:someValuesFrom ex:FinanceFunctionRole ] ;
    rdfs:label "Finance Function" ;
    skos:definition "An Organization that bears a finance-function role within a larger organization in virtue of being tasked with carrying out its financial management activities." ;
    rdfs:comment "Models the finance department/function as an organizational unit (an Organization), NOT a realizable function/capability despite the 'Function' label. Mirrors the slice-7 ex:HumanResourcesFunction precedent: cco:ont00001180 (Organization) is a Group of Agents / Object Aggregate, not an Agent (cco:ont00001017). Bearer of the finance-function role and the agent/participant of section 9.0 acts." .

ex:Accountant a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ;
          owl:onProperty cco:ont00001954 ;   # has capability
          owl:someValuesFrom ex:AccountingCapability ] ,
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:AccountantRole ] ;
    rdfs:label "Accountant" ;
    skos:definition "An Agent that has an accounting capability and bears an accountant role." .

ex:Treasurer a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:TreasurerRole ] ;
    rdfs:label "Treasurer" ;
    skos:definition "An Agent that bears a treasurer role and manages an Organization's cash, liquidity, debt, investments, and financial risk." .

ex:Auditor a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:AuditorRole ] ;
    rdfs:label "Auditor" ;
    skos:definition "An Agent that bears an auditor role and independently examines an Organization's financial records or controls." .

ex:RegulatoryAuthority a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:RegulatorRole ] ;
    rdfs:label "Regulatory Authority" ;
    skos:definition "An Organization that bears a regulator role and issues or enforces financial, tax, or trade rules binding on other organizations." ;
    rdfs:comment "Covers tax authorities, securities exchanges, and customs agencies referenced in 9.3, 9.8, 9.9, 9.11." .

ex:Customer a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:CustomerRole ] ;
    rdfs:label "Customer" ;
    skos:definition "An Agent that bears a customer role in relation to a focal Organization." .

ex:Supplier a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Agent
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:SupplierRole ] ;
    rdfs:label "Supplier" ;
    skos:definition "An Agent that bears a supplier role and provides goods or services to a focal Organization for payment." ;
    rdfs:comment "Vendor counterparty for accounts payable (9.6)." .

ex:Employee a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:EmployeeRole ] ;
    rdfs:label "Employee" ;
    skos:definition "An Agent that bears an employee role in relation to an employing Organization." ;
    rdfs:comment "Subject of payroll (9.5) and expense reimbursement (9.6)." .

ex:Subsidiary a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:SubsidiaryRole ] ;
    rdfs:label "Subsidiary" ;
    skos:definition "An Organization that bears a subsidiary role, being a separate legal entity controlled by a parent Organization." .

ex:BankingPartner a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:BankingPartnerRole ] ;
    rdfs:label "Banking Partner" ;
    skos:definition "An Organization that bears a banking partner role and provides banking, financial-intermediary, or custodial services to a focal Organization." .

ex:GovernanceBody a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ;   # Organization
    rdfs:label "Governance Body" ;
    skos:definition "An Organization constituted within or over a focal Organization to direct, oversee, or assure its activities, such as a board of directors or an audit committee." ;
    rdfs:comment "Participant minted for ex:P10914 (the board of directors and audit committee that the establishment act constitutes). Modeled as an Organization (independent continuant) that bears the governance mandate, never as an ICE." .

####################################################################
# 2d. MATERIAL ENTITIES  (bfo:material entity, obo:BFO_0000040)
#     Legal in operations categories. Money/payments/instruments are
#     material I/O; informational I/O stays as ICEs in section 2e/2f.
####################################################################

ex:PaymentInstrument a owl:Class ;
    rdfs:subClassOf cco:ont00000537 ,   # Financial Instrument (a legally-sanctioned tradeable Material Artifact)
        obo:BFO_0000040 ;               # material entity (co-asserted so material ancestry is visible to the standalone Gate-C SHACL run)
    rdfs:label "Payment Instrument" ;
    skos:definition "A Financial Instrument consisting of a quantity of money (cash or funds) transferred from one Agent to another in settlement of an obligation or exchange." ;
    rdfs:comment "Material input/participant of Acts of Financial Transaction (payments, salary disbursements, deposits, remittances) in 9.2, 9.5, 9.6, 9.7, 9.10, 9.11. Renamed from ex:PaymentInstrument, whose label misread as the payment EVENT; this class is the transferred MONEY (a material filler), never the act. Anchored to cco:ont00000537 to match CCO's treatment of money as a Financial Instrument (cf. Portion of Cash cco:ont00000475 subClassOf 537)." .

ex:FinancialInstrument a owl:Class ;
    rdfs:subClassOf cco:ont00000537 ,   # Financial Instrument (a Material Artifact)
        obo:BFO_0000040 ;               # material entity (made explicit so the material-entity
                                        # ancestry is visible to the standalone Gate-C SHACL run;
                                        # cco:ont00000537 is a CCO subclass of BFO material entity)
    rdfs:label "Traded Financial Instrument" ;
    skos:definition "A Financial Instrument such as a bond, currency holding, derivative, or marketable security that is held, traded, or hedged in treasury operations." ;
    rdfs:comment "Specializes the verified CCO class cco:ont00000537 (a legally-sanctioned tradeable Material Artifact) for the treasury and trade instruments in 9.7, 9.10, 9.11." .

ex:CorporateCreditCard a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ,   # Material Artifact (a Material Entity designed to realize a Function); subClassOf obo:BFO_0000040 in CCO
        obo:BFO_0000040 ;               # material entity (co-asserted so material ancestry is visible to the standalone Gate-C SHACL run)
    rdfs:label "Corporate Credit Card" ;
    skos:definition "A Material Artifact issued to an Organization or its personnel that is designed to realize the function of authorizing the charging of business expenses to a corporate credit account." ;
    rdfs:comment "Material object handled in 9.6.3 (manage corporate credit cards): ordered, issued, deactivated. Anchored to cco:ont00000995 (Material Artifact), NOT cco:ont00000537 (Financial Instrument): a credit card is an access/authorization device, not a tradeable asset, so 537's 'designed to be a tradeable asset' differentia is unsatisfied (a finance-theme false friend). Genuinely tradeable instruments are modeled separately under 537 via ex:FinancialInstrument." .

####################################################################
# 2e. DESCRIPTIVE INFORMATION CONTENT ENTITIES  (cco:ont00000853)
#     Outputs of Analysis/Appraisal/Accounting/Reporting/Monitoring;
#     inputs that describe a portion of reality. 'is about'
#     (cco:ont00001808) added where the ICE describes a named subject.
####################################################################

# --- Inputs (data) ---
ex:FinancialData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Financial Data" ;
    skos:definition "A Descriptive Information Content Entity that describes an Organization's financial transactions, balances, or results." .

ex:CostData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Cost Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the costs incurred in producing products, delivering services, or performing activities." .

ex:TransactionRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Transaction Record" ;
    skos:definition "A Descriptive Information Content Entity that registers an individual financial transaction together with its amount, date, and parties." .

ex:GeneralLedger a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "General Ledger" ;
    skos:definition "A Descriptive Information Content Entity that records, by account, the complete set of an Organization's financial transactions for an accounting period." .

ex:TrialBalance a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Trial Balance" ;
    skos:definition "A Descriptive Information Content Entity that lists the debit and credit balances of all ledger accounts to verify that total debits equal total credits." ;
    rdfs:comment "Minted for ex:P10826 ('Prepare trial balance'). A trial balance is a distinct derived statement, not the general ledger from which it is computed; modeling its output as ex:GeneralLedger asserted a falsehood about the definitional artifact." .

ex:ChartOfAccounts a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Chart of Accounts" ;
    skos:definition "A Descriptive Information Content Entity that enumerates and classifies the accounts used in an Organization's general ledger." .

ex:CustomerMasterFile a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Master File" ;
    skos:definition "A Descriptive Information Content Entity that records the identifying details and purchase history of an Organization's customers." .

ex:FixedAssetRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Fixed-Asset Register" ;
    skos:definition "A Descriptive Information Content Entity that records each of an Organization's fixed assets together with its cost, useful life, depreciation, and resale value." .

ex:CreditScoringHistory a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Credit Scoring History" ;
    skos:definition "A Descriptive Information Content Entity that describes the past credit scores and payment behavior of a customer or applicant." .

ex:AccountStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Account Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes the balance and activity of a particular financial account over a period." .

ex:TaxData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Tax Data" ;
    skos:definition "A Descriptive Information Content Entity that describes income, deductions, and liabilities relevant to an Organization's taxation." .

ex:MarketRateData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Rate Data" ;
    skos:definition "A Descriptive Information Content Entity that describes prevailing interest rates, foreign-exchange rates, or other market prices." ;
    rdfs:comment "Input to treasury, hedging, and international-funds processes (9.7, 9.10)." .

ex:RiskExposureData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Risk Exposure Data" ;
    skos:definition "A Descriptive Information Content Entity that describes an Organization's current counterparty or customer exposures, positions, and the limits applicable to them." ;
    rdfs:comment "Definitional input to exposure-determination analyses (9.7.5). Used by ex:P19584; parallels ex:MarketRateData (the input to the rate-exposure analyses ex:P19576 / ex:P19580) so all three exposure-determination rows carry a definitional input." .

# --- Analytical / appraisal outputs ---
ex:VarianceAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Variance Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the differences between budgeted or forecasted figures and actual financial results." .

ex:CostAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Cost Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the composition, drivers, and behavior of an Organization's costs." .

ex:ProfitabilityAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Profitability Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the revenues, costs, and resulting profit attributable to a customer, product, unit, or project." .

ex:PerformanceMeasure a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Measure" ;
    skos:definition "A Descriptive Information Content Entity that describes a quantified measure of financial or operational performance." ;
    rdfs:comment "Modeled as Descriptive ICE when it records/reports a quantified performance value; a KPI specification prescribing what to measure, how, and against what target should be modeled separately as a Directive ICE (cco:ont00000965)." .

ex:CreditAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ;
          owl:onProperty cco:ont00001808 ;   # is about
          owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Credit Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of a customer's or applicant's creditworthiness." .

ex:RiskAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Financial Risk Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes an organization's exposure to interest-rate, foreign-exchange, credit, or market risk." .

ex:FinancialJustification a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Financial Justification" ;
    skos:definition "A Descriptive Information Content Entity that describes the projected costs and benefits supporting or opposing a capital project or investment." ;
    rdfs:comment "Business case substantiating project approval in 9.4." .

# --- Accounting / reporting outputs ---
ex:FinancialStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Financial Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes an Organization's financial position and results, comprising balance sheet, income statement, cash-flow statement, and statement of equity." .

ex:ConsolidatedFinancialStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Consolidated Financial Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes the combined financial position and results of a parent Organization and its subsidiaries." .

ex:FinancialReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Financial Report" ;
    skos:definition "A Descriptive Information Content Entity that presents financial data compiled for a management, shareholder, or regulatory audience." ;
    rdfs:comment "General report genus for AR/AP, profitability, treasury, and shareholder reports across 9.0." .

ex:RegulatoryFiling a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Filing" ;
    skos:definition "A Descriptive Information Content Entity submitted to a regulatory authority that reports required financial, tax, or compliance information." .

ex:TaxReturn a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Tax Return" ;
    skos:definition "A Descriptive Information Content Entity that reports an Organization's or individual's taxable income, deductions, and tax owed to a tax authority." .

ex:Invoice a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ;
          owl:onProperty cco:ont00001808 ;   # is about
          owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Invoice" ;
    skos:definition "A Descriptive Information Content Entity that describes a commercial transaction between a seller and a customer, itemizing quantities, prices, dates, and tax." ;
    rdfs:comment "Descriptive: it records the particulars of a transaction rather than prescribing a course of action; the obligation to pay is borne separately." .

ex:ComplianceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Internal Controls Compliance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the state of an Organization's compliance with its internal-control policies and procedures." .

ex:ControlEffectivenessAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Control Effectiveness Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of how effectively an Organization's internal controls mitigate risk." .

ex:TradeDocumentation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Trade Documentation" ;
    skos:definition "A Descriptive Information Content Entity that records the description, quantity, transport, indemnity, and inspection details of an international-trade transaction." ;
    rdfs:comment "Output of 9.11 document-trade processes." .

ex:ProductClassification a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Product Trade Classification" ;
    skos:definition "A Descriptive Information Content Entity that assigns products or services to trade categories according to national and international standards." .

####################################################################
# 2f. DIRECTIVE INFORMATION CONTENT ENTITIES  (cco:ont00000965)
#     Outputs of Planning/Formulation/Selection -- plans, policies,
#     procedures, budgets, strategies, decisions, authorizations.
####################################################################

ex:FinancialPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Financial Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the rules governing a financial process such as budgeting, accounting, credit, or reimbursement." ;
    rdfs:comment "General policy genus for the many 'Establish ... policies' nodes across 9.0." .

ex:FinancialProcedure a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Financial Procedure" ;
    skos:definition "A Directive Information Content Entity that prescribes the ordered steps for carrying out a financial process." .

ex:Budget a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Budget" ;
    skos:definition "A Directive Information Content Entity that prescribes the planned allocation of funds to activities over a defined period." ;
    rdfs:comment "Directive: a budget prescribes intended fund allocation, constraining subsequent spending." .

ex:FinancialForecast a owl:Class ; rdfs:subClassOf cco:ont00000626 ;
    rdfs:label "Financial Forecast" ;
    skos:definition "A Predictive Information Content Entity that describes projected future income, expenses, or cash flows of an Organization." ;
    rdfs:comment "Predictive (a specialization of Descriptive, cco:ont00000853): a forecast describes an uncertain expected future state rather than prescribing an allocation; contrast ex:Budget. Re-anchored from cco:ont00000853 to cco:ont00000626 (Predictive Information Content Entity) so the output kind matches the predictive nature of ex:P10773 (Act of Prediction). Still a Descriptive ICE for GOLDEN-PRINCIPLE purposes (cco:ont00000626 subClassOf cco:ont00000853)." .

ex:FinancialPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Financial Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the financial goals and the actions intended to achieve them over a planning horizon." .

ex:TaxStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Tax Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes how an Organization will manage and minimize its tax liabilities." .

ex:HedgingStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Hedging Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes the positions an Organization will take to offset exposure to financial risk." .

ex:InvestmentPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Investment Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the principles governing an Organization's investment decisions." .

ex:CreditPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Credit Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the credit standards, terms, and collection rules an Organization applies to its customers." .

ex:CreditScoreRequirementSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Credit Score Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the minimum credit scores an applicant must meet for credit to be extended." ;
    rdfs:comment "Directive (not Descriptive): a requirement prescribes a threshold the applicant must satisfy, rather than describing a projected future state. Minted for ex:P14188 ('Planning credit score requirements based on established credit policies'); contrast ex:FinancialForecast, which is a predictive description of income/cash flows and does not denote a credit-score requirement." .

ex:InternalControlPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Internal Control Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the controls, roles, and responsibilities an Organization adopts to assure reliable financial reporting and operations." .

ex:ServiceLevelAgreement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Service-Level Agreement" ;
    skos:definition "A Directive Information Content Entity, agreed between parties, that prescribes the scope, quality, and responsibilities of a service." .

ex:PaymentApproval a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Payment Approval Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes that a particular payment, reimbursement, or credit change is authorized to proceed." ;
    rdfs:comment "Directive: an approval authorizes (prescribes) an action; covers approve-payments, approve-reimbursements, approve credit-limit changes." .

ex:ProjectApprovalDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Project Approval Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes whether a capital project or fixed-asset acquisition is authorized to proceed." ;
    rdfs:comment "Go/no-go decision in capital planning (9.4)." .

ex:ProjectContinuationDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Project Continuation Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes whether to proceed with a capital project on the basis of the returns it has generated." ;
    rdfs:comment "Directive go/no-go decision in capital project accounting (9.4.2). Minted for ex:P10851 ('Decide whether to proceed based on the revenues generated'), mirroring ex:ProjectApprovalDecision." .

ex:LetterOfCredit a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Letter of Credit" ;
    skos:definition "A Directive Information Content Entity issued by a bank that prescribes payment to a seller upon satisfaction of specified delivery conditions." ;
    rdfs:comment "Directive: it commits a bank to pay under stated conditions (9.11)." ;
    rdfs:comment "FALSE-FRIEND note: this class models the CONTENT of a letter of credit (the bank's prescriptive payment commitment), hence Directive ICE -- it is the 9.11 process output (has output cco:ont00001986). It does NOT model the document/artifact that bears this content, nor the trade-finance sense in which a letter of credit is a negotiable instrument; that artifact, if needed, is a separate Material Artifact (cco:ont00000995). Do not re-anchor this ICE class to cco:ont00000537." .

####################################################################
# 2g. EXTRA SUPPORTING CLASSES (minted in group modules; reconciled
#     here to one canonical definition each). All carry NO PCF ids.
####################################################################

# -- group 9.1 supporting ICEs --
ex:CostDriverSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Cost-Driver Specification" ;
    skos:definition "A Descriptive Information Content Entity that registers the factors identified as driving the cost of an activity." ;
    rdfs:comment "Minted: shared vocab has ex:CostData (raw cost facts) and ex:CostAnalysis (a cost study) but no class for the enumerated set of identified cost drivers. Descriptive because it registers what the drivers are." ;
    skos:example "A list naming machine-hours, setups, and order lines as the drivers of warehousing cost." .

ex:CostDriverMeasurement a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Cost-Driver Measurement" ;
    skos:definition "A Descriptive Information Content Entity that records the measured magnitudes of identified cost drivers." ;
    rdfs:comment "Minted: distinct from ex:CostDriverSpecification (which names the drivers) - this records their quantified values. Descriptive measurement record." ;
    skos:example "A table giving 12,400 machine-hours and 830 setups for the period." .

ex:CriticalActivityDetermination a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Critical-Activity Determination" ;
    skos:definition "A Descriptive Information Content Entity that records which finance activities are indispensable and where costs cannot be reduced." ;
    rdfs:comment "Minted: no shared-vocab class registers the essential/non-cuttable activities. Descriptive register of a determination." ;
    skos:example "A register marking payroll and statutory reporting as indispensable." .

ex:AssetDeploymentPlan a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Asset Deployment Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes how asset resources are allocated across processes for optimal utilization." ;
    rdfs:comment "Minted: shared vocab has ex:FinancialPlan/ex:Budget but no class specific to asset-resource allocation. Directive because it prescribes a deployment." ;
    skos:example "A plan reassigning two machines from line A to line B for the next quarter." .

ex:LifeCycleCostAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Life-Cycle Cost Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the revenue and cost incurred at each stage of a product or process life cycle." ;
    rdfs:comment "Minted: narrower than ex:CostAnalysis, which is not stage/life-cycle structured. Descriptive." ;
    skos:example "A cradle-to-grave cost breakdown for a product across design, production, and disposal." .

ex:NewProductEvaluation a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "New-Product Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the demand and projected profitability of a new product in a market." ;
    rdfs:comment "Minted: distinct from ex:ProfitabilityAnalysis (general profit study) - this is the appraisal of a prospective product's viability. Descriptive judgement." ;
    skos:example "A go-to-market assessment of a proposed product line for a target segment." .

ex:ProductMixDecision a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Product-Mix Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes the chosen combination of products and customer segments offered to the market." ;
    rdfs:comment "Minted: a decision/selection record (Directive ICE), distinct from descriptive analyses. Output of an Act of Selection (ex:P10785)." ;
    skos:example "A decision to offer products X and Y to segment A and product Z to segment B." .

# -- group 9.2 supporting --
ex:AccountApprovalDecision a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive (Prescriptive) ICE
    rdfs:label "Account Approval Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes whether to approve or decline the opening of a new customer credit account." ;
    rdfs:comment "Minted locally: Directive (not Descriptive) because a decision prescribes rather than describes. Distinct from the shared ex:CreditAssessment (the Descriptive judgement underlying it) and from ex:PaymentApproval (a per-payment approval)." ;
    skos:example "A recorded decision to approve a new customer's credit account at a $10,000 limit." .

ex:DefaultAccountManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ;
          owl:onProperty obo:BFO_0000054 ;   # realized in
          owl:someValuesFrom ex:P14007 ] ;
    rdfs:label "Default Account Management Capability" ;
    skos:definition "An Organization Capability that is realized in the recovery and collection acts by which an organization handles customer accounts that have not met their agreed repayment obligations." ;
    rdfs:comment "Models APQC 9.2.4.7 'Manage default accounts' (PCF 14008). R5: a standing function with no natural end, so modeled as an Organization Capability (cco:ont00000568) per R6 rather than a process. Bears no ex:pcfID (supporting class); realized in ex:P14007 (Perform recovery workout) as a bounded act of that management." .

# -- group 9.3 supporting --
ex:ApprovalLimitSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Approval Limit Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the monetary thresholds and conditions under which financial approvals may be granted." ;
    rdfs:comment "Minted locally: more specific than ex:FinancialPolicy/ex:FinancialProcedure (numeric approval thresholds). Directive per GOLDEN PRINCIPLE (it prescribes, not describes)." ;
    skos:example "A schedule stating that purchases over USD 50,000 require CFO sign-off." .

ex:FinancialPolicyManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10816 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20604 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10817 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10818 ] ;
    rdfs:label "Financial Policy Management Capability" ;
    skos:definition "An Organization Capability that is realized in the acts of establishing, publishing, and enforcing an organization's accounting policies and procedures." ;
    rdfs:comment "R5/R6: APQC 9.3.1 'Manage financial policies and procedures' is a standing function (no natural end), so modeled as a capability realized in its bounded child acts. No ex:pcfID (capability, not a PCF process)." ;
    skos:example "A finance department's ongoing capacity to keep accounting policy current and enforced." .

# -- group 9.4 supporting --
ex:FixedAssetProjectAccountingCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10751 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10752 ] ;
    rdfs:label "Fixed-Asset Project Accounting Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to plan, approve, and account for large capital (fixed-asset) projects over their multi-year lifecycle." ;
    rdfs:comment "Reality-layer node for APQC process group 9.4 (PCF 10731). Modeled as a standing function (R5/R6), not a bounded process: 'Manage ... project accounting' over many years has no natural end. Realized in its bounded child acts P10751 and P10752. Carries no ex:pcfID per the IRI scheme (capabilities are supporting classes)." ;
    skos:example "A corporation's standing ability to run capital-project accounting across its portfolio of multi-year investments." .

ex:ProjectAccountCode a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive Information Content Entity
    rdfs:label "Project Account Code" ;
    skos:definition "A Descriptive Information Content Entity that is a reference code identifying a capital project within a system of accounts so that its transactions can be classified and aggregated." ;
    rdfs:comment "Local mint. Rejected ex:ChartOfAccounts (the master account structure) as too broad for a single per-project classification code. Descriptive (it identifies/classifies, it does not prescribe)." ;
    skos:example "Cost-collection code 'CP-2026-014' assigned to a new turbine-replacement project." .

# -- group 9.5 supporting ICEs --
ex:TimeRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Employee Time Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the working days, hours, billing hours, and leave of an employee over a reporting period." ;
    skos:example "A weekly timesheet capturing each employee's hours and billable time." .

ex:LeaveRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Leave Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the paid and unpaid leave allowed to and taken by employees." ;
    skos:example "A monthly report of vacation, sick, and unpaid leave balances per employee." .

ex:EmployeeUtilizationReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Employee Utilization Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the productive (billable) hours of employees relative to their available hours." ;
    skos:example "A utilization dashboard showing each consultant's billable-hour ratio." .

ex:EarningsInformation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Employee Earnings Information" ;
    skos:definition "A Descriptive Information Content Entity that describes the structure and components of an employee's salary or wages held in a central repository." ;
    skos:example "The salary-structure record (base, allowances, bonus components) for one employee." .

ex:PayrollDeductionRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Payroll Deduction Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the deductions applied to an employee's salary on the basis of expenses, investments, and tax rules." ;
    skos:example "A record of an employee's statutory and voluntary deductions for the year." .

ex:PeriodEndAdjustmentRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Payroll Period-End Adjustment Record" ;
    skos:definition "A Descriptive Information Content Entity that describes corrections to salary deductions reconciled at the close of a tax period." ;
    skos:example "A year-end recalculation adjusting an employee's tax-deduction shortfall or surplus." .

ex:PayrollInquiryResponse a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Payroll Inquiry Response" ;
    skos:definition "A Descriptive Information Content Entity that describes the answer given to an employee's salary-related query." ;
    skos:example "A help-desk reply explaining a deduction that reduced an employee's net pay." .

ex:EmployeeTaxStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Employee Annual Tax Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes the tax withheld from an employee's salary over a year, issued to the employee for reference or refund." ;
    skos:example "A year-end wage-and-tax statement provided to each employee." .

# -- group 9.6 supporting ICEs --
ex:VendorMasterFile a owl:Class ; rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Supplier ] ;
    rdfs:label "Vendor Master File" ;
    skos:definition "A Descriptive Information Content Entity that records the account particulars of an organization's suppliers, against which accounts-payable entries are matched." ;
    rdfs:comment "Minted locally for 9.6: no shared-vocab ICE covers the supplier/vendor account register used in AP verification (shared ex:CustomerMasterFile is the customer-side analogue). Is about a Supplier (cco:ont00001808)." .

ex:PaymentMatchResult a owl:Class ; rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Payment Match Result" ;
    skos:definition "A Descriptive Information Content Entity that records whether an accounts-payable pay-file entry matches the corresponding vendor master and purchase-order record." ;
    rdfs:comment "Minted locally for 9.6.1.1: descriptive judgement of AP three-way matching. Descriptive, not Directive, because it represents a match state rather than prescribing action." .

ex:AuditJudgement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Invoice Audit Judgement" ;
    skos:definition "A Descriptive Information Content Entity that records the findings of an audit of invoices and key accounts-payable data." ;
    rdfs:comment "Minted locally for 9.6.1.3: descriptive output of the invoice/AP-data audit." .

ex:ExceptionResolutionRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Payable Exception Resolution Record" ;
    skos:definition "A Descriptive Information Content Entity that records the investigation and disposition of an atypical or inconsistent accounts-payable situation." ;
    rdfs:comment "Minted locally for 9.6.1.7: descriptive output of researching/resolving payable exceptions." .

# -- group 9.7 supporting ICEs --
ex:TreasuryGovernanceCharter a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Treasury Governance Charter" ;
    skos:definition "A Directive Information Content Entity that prescribes the scope of treasury operations and designates the authoritative body governing investment decisions." ;
    rdfs:comment "Local mint for 9.7.1.1; no fitting class in the shared section vocabulary. Directive because it prescribes scope and authority rather than describing them." .

ex:SystemSecurityRequirement a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "System Security Requirement" ;
    skos:definition "A Directive Information Content Entity that prescribes requirements for controlling access, information reliability, accountability, and availability within an organization's treasury systems." ;
    rdfs:comment "Local mint for 9.7.1.8. Directive because requirements prescribe what a system must satisfy." .

ex:CashPosition a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Cash Position" ;
    skos:definition "A Descriptive Information Content Entity that describes the reconciled balance of an organization's available cash funds at a point in time." ;
    rdfs:comment "Local mint for 9.7.2.1; reconciliation input/output not covered by the shared vocabulary." .

ex:BankFeeAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Bank Fee Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes a study and negotiated determination of the fees a bank charges for its services." ;
    rdfs:comment "Local mint for 9.7.2.8. Descriptive: it represents a judgement of fee levels rather than prescribing them." .

ex:HedgeRequirementSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Hedge Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the hedging requirements for a class of market exposures in accordance with an organization's risk policy." ;
    rdfs:comment "Local mint for 9.7.5.2.3 and 9.7.5.3.3. Directive because it prescribes which hedges must be put in place." .

ex:ExposureLimitResolution a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Exposure Limit Resolution" ;
    skos:definition "A Directive Information Content Entity that prescribes the settlement of a customer exposure-limit violation." ;
    rdfs:comment "Local mint for 9.7.5.4.2. Directive because a resolution prescribes the corrective course of action." .

ex:HedgeSelectionDecision a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Hedge Selection Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes which hedging option is to be executed after evaluation of available options." ;
    rdfs:comment "Local mint for 9.7.5.5.4. Directive because a selection decision commits to a chosen option." .

# -- group 9.8 supporting ICEs --
ex:CodeOfEthics a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive (Prescriptive) ICE
    rdfs:label "Code of Ethics" ;
    skos:definition "A Directive Information Content Entity that prescribes the standards of ethical conduct expected of an organization's personnel." ;
    rdfs:comment "Minted for 9.8. Directive (cco:ont00000965), not Descriptive, because a code prescribes conduct rather than describing it." ;
    skos:example "A published corporate code of conduct circulated to all employees." .

ex:ControlResponsibilityAssignment a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive (Prescriptive) ICE
    rdfs:label "Control Responsibility Assignment" ;
    skos:definition "A Directive Information Content Entity that prescribes the roles, responsibilities, and accountabilities of agents for the effectiveness of an organization's internal controls and financial reporting." ;
    rdfs:comment "Minted for 9.8. Directive because it prescribes who is accountable for what. Output of both 'establish board/audit committee' and 'assign roles and responsibility for internal controls'." ;
    skos:example "A RACI matrix assigning internal-control duties to the audit committee and process owners." .

ex:ProcessControlObjective a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive (Prescriptive) ICE
    rdfs:label "Process Control Objective" ;
    skos:definition "A Directive Information Content Entity that prescribes what a business process is intended to accomplish and the control objectives governing it." ;
    rdfs:comment "Minted for 9.8.1.4. Directive (prescribes intended accomplishment). Paired with a descriptive ex:RiskAssessment describing the risks attached to the process." ;
    skos:example "A documented objective that all disbursements above a threshold require dual authorization." .

ex:RiskToleranceSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive (Prescriptive) ICE
    rdfs:label "Risk Tolerance Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the maximum acceptable risk, in quantitative terms, for an entity or organizational unit across strategic, operational, financial, and compliance risk subcategories." ;
    rdfs:comment "Minted for 9.8.1.5. Directive because it prescribes binding limits, not a description of current risk (that is ex:RiskAssessment)." ;
    skos:example "A board-approved statement capping aggregate operational loss exposure at 2% of revenue." .

ex:CorrectiveActionRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Corrective Action Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the corrective measures taken to rectify deficiencies in an organization's internal controls." ;
    rdfs:comment "Minted for 9.8.2.2. Descriptive: it records what remediation was performed. The remediation act itself is a Planned Act, not an information-processing act." ;
    skos:example "A remediation log noting that a missing approval control was reinstated for the procurement workflow." .

# -- group 9.9 supporting ICE --
ex:TaxInquiryResponse a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive Information Content Entity
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;   # is about
          owl:someValuesFrom ex:TaxData ] ;
    rdfs:label "Tax Inquiry Response" ;
    skos:definition "A Descriptive Information Content Entity that describes the organization's answer to a tax query raised by a regulatory or government authority, drawing on historical taxation records." ;
    rdfs:comment "Minted because no shared section-9.0 ICE denotes a response to an external tax inquiry; ex:TaxReturn (a filing) and ex:ComplianceReport (internal controls) do not fit. Descriptive (it represents/answers, not prescribes). Reuses verified cco:ont00000853 and cco:ont00001808 (is about)." ;
    skos:example "A written reply to a revenue authority's audit question, citing the relevant prior-year filings." .

# -- group 9.10 supporting capability --
ex:InternationalFundsManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10767 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10768 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10769 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10770 ] ;
    rdfs:label "International Funds Management Capability" ;
    skos:definition "An Organization Capability that is realized in acts of monitoring international rates and currency exposure, managing cross-border fund transfers, hedging currency, and reporting foreign-exchange results so as to manage and consolidate funds across an enterprise's operating units." ;
    rdfs:comment "Models APQC process group 9.10 (PCF 10737), a standing 'Manage...' function. Per R5/R6 it is an Organization Capability (cco:ont00000568) realized in its four child acts, NOT a process: it has no identifiable single beginning and end." ;
    skos:example "An enterprise treasury team's ongoing program for consolidating subsidiary cash and managing cross-border currency risk." .

# -- group 9.11 supporting ICEs & capabilities --
ex:SanctionedPartyList a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Sanctioned Party List" ;
    skos:definition "A Descriptive Information Content Entity that describes the parties approved or prohibited for engaging in international trade, together with their granted legal rights and credentials." ;
    rdfs:comment "Minted for group 9.11. Input to sanctioned-party screening. Descriptive (it represents who may trade), not Directive." ;
    skos:example "A consolidated denied-/approved-parties screening list maintained for export controls." .

ex:SanctionedPartyScreeningResult a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Sanctioned Party Screening Result" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of whether the parties to a prospective transaction are clear to engage in international trade, based on evaluation of the approved-party list and their credentials." ;
    rdfs:comment "Minted for group 9.11. Output of 9.11.1. Descriptive (it records a clearance judgement) per the GOLDEN PRINCIPLE for an Appraisal act." ;
    skos:example "A trade-compliance clearance record flagging a counterparty as cleared or blocked." .

ex:DutyCalculation a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Duty Calculation" ;
    skos:definition "A Descriptive Information Content Entity that describes the excise duty computed as payable on a given international-trade transaction." ;
    rdfs:comment "Minted for group 9.11. Output of 9.11.5. Descriptive: it represents a computed amount owed, it does not prescribe an action." ;
    skos:example "A line-item computation of customs duty owed on an imported shipment." .

ex:CurrencyConversionRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Currency Conversion Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the conversion of a monetary amount from one currency to another at an identified exchange rate." ;
    rdfs:comment "Minted for group 9.11. Output of 9.11.4. Descriptive record of a performed conversion." ;
    skos:example "A record converting 100,000 yen to US dollars at the day's spot rate." .

ex:CustomsInformation a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Customs Information" ;
    skos:definition "A Descriptive Information Content Entity that describes the trade particulars mandated by law to be disclosed to the customs authority that controls and collects duties on the international exchange of products and services." ;
    rdfs:comment "Minted for group 9.11. The ICE transferred to customs in 9.11.6 (an Act of Communication)." ;
    skos:example "An electronic customs declaration submitted with a shipment." .

ex:TradePreferenceDocumentation a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Trade Preference Documentation" ;
    skos:definition "A Descriptive Information Content Entity that describes a shipment's eligibility for trade under preference, by which products may be imported or exported at a lower or nil rate of customs duty or levy." ;
    rdfs:comment "Minted for group 9.11. Output of 9.11.8. Descriptive (it evidences eligibility); the preferential-rate entitlement it records derives from external trade agreements, not from this artifact prescribing conduct." ;
    skos:example "A certificate of origin claiming preferential tariff treatment under a free-trade agreement." .

ex:ImportExportControlCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P17059 ] ;
    rdfs:label "Import-Export Control Capability" ;
    skos:definition "An Organization Capability that is realized in the ongoing oversight and direction of the flow of trade into and out of an organization so as to secure financial gains." ;
    rdfs:comment "Models APQC 9.11.2 'Control exports and imports' (PCF 14091). R5: 'overseeing and directing the flow of trade' is a standing control function with no natural end -- a capability, not a bounded process. Realized in the global-trade-servicing acts (R6)." ;
    skos:example "A trade-compliance department's standing capacity to govern what the firm imports and exports." .

ex:RestitutionManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P17059 ] ;
    rdfs:label "Restitution Management Capability" ;
    skos:definition "An Organization Capability that is realized in the ongoing administration and oversight of an organization's restitution obligations, including maintaining compliance with applicable legal frameworks and discharging any fines or non-financial measures imposed by authorities." ;
    rdfs:comment "Models APQC 9.11.9 'Handle restitution' (PCF 14097). R5: 'Administering and overseeing all restitution activities... Manage compliance' is a standing managerial function with no natural end -- a capability, not a bounded process. Realized in the underlying restitution/compliance acts (R6)." ;
    skos:example "A legal function's standing capacity to manage court-ordered restitution and regulatory penalties." .

####################################################################
# 3. PROCESS CLASSES
####################################################################

# ================== group 9.1 ==================
# Perform planning and management accounting

ex:P10728 a owl:Class ;
    ex:pcfID "10728" ;
    ex:hierarchyID "9.1" ;
    ex:apqcSourceText "Determining different stages of the planning process and accounting. Classify, determine, analyze, interpret, and communicate information to make up-to-date business decisions for better management and control functions." ;
    rdfs:label "Perform planning and management accounting (capability)" ;
    skos:definition "An Organization Capability that inheres in a finance function in virtue of its capacity to plan, budget, account for, and evaluate financial performance, realized in acts of management accounting." ;
    rdfs:comment "R5 = capability (R6). The APQC process group denotes a standing finance function with no identifiable single beginning and end, so it is an Organization Capability (cco:ont00000568), not a process. Its four child Processes are the acts in which it is realized." ;
    skos:example "A corporation's standing management-accounting function exercised continuously across fiscal periods." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10738 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10739 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10740 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10741 ] .

ex:P10738 a owl:Class ;
    ex:pcfID "10738" ;
    ex:hierarchyID "9.1.1" ;
    ex:apqcSourceText "Allocating funds to meet future and current financial goals. Led by the chief financial officer, have the finance function plan, budget, and forecast in order to determine and describe long and short-term financial goals." ;
    rdfs:label "Perform planning/budgeting/forecasting" ;
    skos:definition "An Act of Formulation in which a finance function plans, budgets, and forecasts to set an organization's short- and long-term financial goals, producing a financial plan and budget." ;
    rdfs:comment "Composite process; APQC children are process parts (cco:ont00001777), not subclasses. Genus is ex:ActOfFormulation because the dominant output is a directive budget/plan." ;
    skos:example "A finance team's annual budgeting and forecasting cycle led by the CFO." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:Budget ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10771 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10772 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20135 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10773 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20136 ] .

ex:P10771 a owl:Class ;
    ex:pcfID "10771" ;
    ex:hierarchyID "9.1.1.1" ;
    ex:apqcSourceText "Formulating financial budgetary guidelines and strategies. Develop a framework for rules and regulations regarding budgets. Create a step-by-step process to achieve financial goals." ;
    rdfs:label "Develop and maintain budget policies and procedures" ;
    skos:definition "An Act of Formulation that composes budgetary guidelines and produces a financial policy and a financial procedure governing how budgets are set." ;
    rdfs:comment "Directive output (GOLDEN PRINCIPLE): formulating rules/procedures yields Directive ICEs (cco:ont00000965), so the act genus is ex:ActOfFormulation." ;
    skos:example "A controller drafts the corporate budgeting policy and the step-by-step budgeting procedure." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] .

ex:P10772 a owl:Class ;
    ex:pcfID "10772" ;
    ex:hierarchyID "9.1.1.2" ;
    ex:apqcSourceText "Creating reports on a quarterly or annual basis for fund allocation. Create a financial statement that estimates revenues and expenses over a specific period of time. (Leverage budget methods such as cost-based and zero-based budgeting techniques, in light of the periodic targets outlined during Develop and maintain budget policies and procedures [10771].)" ;
    rdfs:label "Prepare periodic budgets and plans" ;
    skos:definition "An Act of Formulation that allocates funds over a period and produces a budget prescribing estimated revenues and expenses." ;
    rdfs:comment "Directive output (GOLDEN PRINCIPLE): a budget prescribes intended allocation (cco:ont00000965). Method references (cost-based/zero-based budgeting) and the budget policies from 10771 are typical, not definitional, so not promoted to restrictions." ;
    skos:example "The annual departmental budget estimating next year's revenues and expenses." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:Budget ] .

ex:P20135 a owl:Class ;
    ex:pcfID "20135" ;
    ex:hierarchyID "9.1.1.3" ;
    ex:apqcSourceText "Putting budgeting plans into practical use keeping within designated forecasting parameters." ;
    rdfs:label "Operationalize and implement plans to achieve budget" ;
    skos:definition "A Planned Act that puts an approved budget into practical use, executing financial activity within designated forecasting parameters." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): this is execution/implementation, not the production of an informational artifact. The Budget is a definitional directive input; it has no definitional informational output." ;
    skos:example "Releasing budgeted funds and steering spending to stay within the approved plan." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:Budget ] .

ex:P10773 a owl:Class ;
    ex:pcfID "10773" ;
    ex:hierarchyID "9.1.1.4" ;
    ex:apqcSourceText "Creating estimates of the projected income and expenses required over a predetermined time frame. Develop the projections of profit and loss statements, balance sheets, and the cash flow forecast." ;
    rdfs:label "Prepare periodic financial forecasts" ;
    skos:definition "An Act of Prediction that examines financial data and generates a financial forecast projecting income and expenses over a predetermined time frame." ;
    rdfs:comment "Re-anchored from ex:ActOfAnalysis to cco:ont00000371 (Act of Prediction). The source text is purely predictive ('Creating estimates of the projected income and expenses ... Develop the projections of profit and loss statements, balance sheets, and the cash flow forecast') and CCO ships a dedicated verified class for exactly this: cco:ont00000371 (Act of Prediction) = 'A Planned Act that involves the generation of a Predictive Information Content entity that is intended to describe an uncertain possible future event, value, entity, or attribute', whose own examples include predicting a stock's future value. REJECTED candidate ex:ActOfAnalysis (under Act of Information Processing): it is correct but under-committal and obscures the predictive nature; reuse-before-mint (D5) prefers the fitting verified CCO class over a broader local genus. Output ex:FinancialForecast retyped under cco:ont00000626 (Predictive ICE, still a Descriptive ICE), so the GOLDEN PRINCIPLE holds under either genus and this is a pure act-genus specificity fix. P&L, balance-sheet, and cash-flow projections are facets of the one forecast." ;
    skos:example "A quarterly cash-flow and P&L forecast for the next four quarters." ;
    rdfs:subClassOf cco:ont00000371 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialForecast ] .

ex:P20136 a owl:Class ;
    ex:pcfID "20136" ;
    ex:hierarchyID "9.1.1.5" ;
    ex:apqcSourceText "Conducting a quantitative analysis between what was forecasted and budgeted and actual financial behavior." ;
    rdfs:label "Perform variance analysis against forecasts and budgets" ;
    skos:definition "An Act of Analysis that compares actual financial behavior against the budget and the financial forecast and produces a variance analysis." ;
    rdfs:comment "Descriptive output (GOLDEN PRINCIPLE): a variance analysis represents the gap between plan and actuals (cco:ont00000853). Budget and forecast are definitional inputs." ;
    skos:example "A monthly budget-versus-actual variance report." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:Budget ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:VarianceAnalysis ] .

ex:P10739 a owl:Class ;
    ex:pcfID "10739" ;
    ex:hierarchyID "9.1.2" ;
    ex:apqcSourceText "Defining costs to be incurred and methods for optimum utilization. Determine the costs of products, processes, projects, etc. to compile in the financial statements, as well as to assist management in making decisions regarding planning and control. Control costs by managing and reducing business expenses." ;
    rdfs:label "Perform cost accounting and control" ;
    skos:definition "An Act of Accounting that determines the costs of products, processes, and projects and compiles them into financial records to support cost control." ;
    rdfs:comment "Composite process; APQC children are process parts. Genus ex:ActOfAccounting because the dominant output is descriptive accounting records (cost determination compiled into statements)." ;
    skos:example "A cost-accounting close that compiles product costs into the period's financial statements." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10774 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14057 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10775 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10776 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10777 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11175 ] .

ex:P10774 a owl:Class ;
    ex:pcfID "10774" ;
    ex:hierarchyID "9.1.2.1" ;
    ex:apqcSourceText "Conducting accounting for assets, and finding reasons for changes (depreciation, obsolescence, deterioration, change in customer taste, increased demand, decreased market supply, etc.)." ;
    rdfs:label "Perform inventory accounting" ;
    skos:definition "An Act of Accounting that records inventory and asset values and accounts for the causes of their change, producing a financial statement of those assets." ;
    rdfs:comment "Descriptive output: accounting records/statements (cco:ont00000853). The fixed-asset register is the definitional input that is updated; the financial statement is the definitional output." ;
    skos:example "Recording depreciation and obsolescence write-downs against the fixed-asset register." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FixedAssetRegister ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialStatement ] .

ex:P14057 a owl:Class ;
    ex:pcfID "14057" ;
    ex:hierarchyID "9.1.2.2" ;
    ex:apqcSourceText "Determining the revenue, profits, and losses incurred by each unit within the organization that produces profit." ;
    rdfs:label "Perform profit center accounting" ;
    skos:definition "An Act of Accounting that determines the revenue, profit, and loss of each profit-producing unit and produces a profitability analysis of those units." ;
    rdfs:comment "Descriptive output (cco:ont00000853): a per-unit profitability statement. Genus ex:ActOfAccounting." ;
    skos:example "Computing each business unit's monthly profit and loss." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProfitabilityAnalysis ] .

ex:P10775 a owl:Class ;
    ex:pcfID "10775" ;
    ex:hierarchyID "9.1.2.3" ;
    ex:apqcSourceText "Studying expenses directly associated with product. Analyze the cost of sales, which is the cost of manufacturing products." ;
    rdfs:label "Perform cost of sales analysis" ;
    skos:definition "An Act of Analysis that examines the expenses directly associated with products and produces a cost analysis of the cost of sales." ;
    rdfs:comment "Descriptive output (cco:ont00000853). Genus ex:ActOfAnalysis: examining cost data to produce an understanding." ;
    skos:example "Breaking down manufacturing cost of goods sold by component." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CostAnalysis ] .

ex:P10776 a owl:Class ;
    ex:pcfID "10776" ;
    ex:hierarchyID "9.1.2.4" ;
    ex:apqcSourceText "Studying and finding out the relevant cost center for a product by studying every resource used in its making." ;
    rdfs:label "Perform product costing" ;
    skos:definition "An Act of Analysis that examines every resource consumed in making a product and produces a cost analysis attributing the product's cost to the relevant cost center." ;
    rdfs:comment "Descriptive output (cco:ont00000853). Genus ex:ActOfAnalysis: derives a cost figure from resource-usage data." ;
    skos:example "Allocating direct material, labor, and overhead to compute a unit product cost." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CostAnalysis ] .

ex:P10777 a owl:Class ;
    ex:pcfID "10777" ;
    ex:hierarchyID "9.1.2.5" ;
    ex:apqcSourceText "Discovering the changes between forecasted and actual costing. Analyze actual and planned behavior by reviewing the amount of a variance on a trend line in order to maintain control over a business." ;
    rdfs:label "Perform variance analysis" ;
    skos:definition "An Act of Analysis that compares planned and actual costing and produces a variance analysis of the differences." ;
    rdfs:comment "Descriptive output (cco:ont00000853). Genus ex:ActOfAnalysis. Distinct from 20136 (variance against forecasts/budgets at the planning level); this one operates on cost data." ;
    skos:example "Plotting actual-vs-standard cost variances on a trend line." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:VarianceAnalysis ] .

ex:P11175 a owl:Class ;
    ex:pcfID "11175" ;
    ex:hierarchyID "9.1.2.6" ;
    ex:apqcSourceText "Making a report about revenues generated by the organization or business unit concerned. This process requires the organization to create a report which shows how business is generating profits. Profits are the part which is left after paying all expenses directly related to the generation of the revenue, such as producing a product, and other expenses related to conducting business activities." ;
    rdfs:label "Report on profitability" ;
    skos:definition "An Act of Reporting that takes a profitability analysis and produces a financial report communicating how the organization or unit generates profit." ;
    rdfs:comment "Descriptive output (cco:ont00000853). Genus ex:ActOfReporting: the act communicates an existing analysis as a report. The profitability analysis is the definitional input; the financial report is the definitional output." ;
    skos:example "Issuing the quarterly profitability report to management." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProfitabilityAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] .

ex:P10740 a owl:Class ;
    ex:pcfID "10740" ;
    ex:hierarchyID "9.1.3" ;
    ex:apqcSourceText "Deciding which expenses can be avoided to reduce some costs and increase revenues. Plan and control the organization's budget to forecast future expenditures." ;
    rdfs:label "Perform cost management" ;
    skos:definition "A Planned Act in which an organization identifies and measures cost drivers and reallocates resources to reduce avoidable expenses and control costs." ;
    rdfs:comment "Composite process anchored at cco:ont00000228 (Planned Act) because its parts are heterogeneous (descriptive cost-driver analysis plus directive resource allocation), so no single descriptive/directive act genus fits the whole." ;
    skos:example "A cost-reduction initiative that profiles cost drivers and reallocates assets." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10778 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10779 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10780 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10781 ] .

ex:P10778 a owl:Class ;
    ex:pcfID "10778" ;
    ex:hierarchyID "9.1.3.1" ;
    ex:apqcSourceText "Defining cost drivers for a particular activity." ;
    rdfs:label "Determine key cost drivers" ;
    skos:definition "An Act of Identification that discerns the factors driving the cost of an activity and produces a cost-driver specification registering them." ;
    rdfs:comment "Descriptive output (cco:ont00000853): a register of identified drivers. Genus ex:ActOfIdentification (discernment sense), reused from apqc-ext." ;
    skos:example "Identifying machine-hours and order-count as the drivers of a warehousing activity's cost." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CostDriverSpecification ] .

ex:P10779 a owl:Class ;
    ex:pcfID "10779" ;
    ex:hierarchyID "9.1.3.2" ;
    ex:apqcSourceText "Calculating cost drivers." ;
    rdfs:label "Measure cost drivers" ;
    skos:definition "An Act of Measuring that calculates the magnitude of identified cost drivers and produces a cost-driver measurement." ;
    rdfs:comment "Anchored at cco:ont00000345 (Act of Measuring) because the act literally quantifies driver magnitudes against a standard. Descriptive measurement output (cco:ont00000853). The cost-driver specification from 10778 is the definitional input. Explicit rdfs:subClassOf cco:ont00000228 (Planned Act) added so the act-anchor chain is visible to the standalone SHACL run (ont00000345 is a CCO subclass of ont00000228, but the closure is not merged for Gate C)." ;
    skos:example "Counting the machine-hours consumed per product line." ;
    rdfs:subClassOf cco:ont00000345 ,
        cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostDriverSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CostDriverMeasurement ] .

ex:P10780 a owl:Class ;
    ex:pcfID "10780" ;
    ex:hierarchyID "9.1.3.3" ;
    ex:apqcSourceText "Determine the activities that hinder the progress of finance activities. This requires the organization to determine those business activities carried out by the financial function of the organization and which are indispensable. This undertaking helps the organization triangulate those activities which are essential and where costs cannot be slashed." ;
    rdfs:label "Determine critical activities" ;
    skos:definition "An Act of Identification that discerns which finance activities are indispensable and produces a critical-activity determination." ;
    rdfs:comment "Descriptive output (cco:ont00000853): a register marking which activities are essential. Genus ex:ActOfIdentification." ;
    skos:example "Flagging payroll and regulatory reporting as indispensable, non-cuttable finance activities." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CriticalActivityDetermination ] .

ex:P10781 a owl:Class ;
    ex:pcfID "10781" ;
    ex:hierarchyID "9.1.3.4" ;
    ex:apqcSourceText "Distributing or allocating asset resources in different processes for optimal utilization." ;
    rdfs:label "Manage asset resource deployment and utilization" ;
    skos:definition "An Act of Formulation that allocates asset resources across processes and produces an asset-deployment plan prescribing their optimal utilization." ;
    rdfs:comment "Directive output (GOLDEN PRINCIPLE): an allocation plan prescribes how resources are deployed (cco:ont00000965), so the genus is ex:ActOfFormulation. Modeled as a bounded allocation exercise (a single deployment decision), not the standing 'manage' sense." ;
    skos:example "Reassigning capital equipment between plants to improve utilization." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AssetDeploymentPlan ] .

ex:P10741 a owl:Class ;
    ex:pcfID "10741" ;
    ex:hierarchyID "9.1.4" ;
    ex:apqcSourceText "Checking and achieving predetermined financial targets and timelines. Assess and manage the profitability, feasibility, and consistency of a business or project. Study the revenues generated." ;
    rdfs:label "Evaluate and manage financial performance" ;
    skos:definition "A Planned Act in which an organization appraises and manages the profitability and feasibility of its products, customers, and projects against predetermined financial targets." ;
    rdfs:comment "Composite process anchored at cco:ont00000228 (Planned Act) because its parts mix appraisal (assess profitability, evaluate new products) with planning/selection (optimize mix), so no single act genus fits the whole." ;
    skos:example "A profitability and product-mix review cycle assessing performance against targets." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10782 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10783 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10784 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10785 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10786 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10787 ] .

ex:P10782 a owl:Class ;
    ex:pcfID "10782" ;
    ex:hierarchyID "9.1.4.1" ;
    ex:apqcSourceText "Studying product demand and targeted customer preferences. Study customers' demands or preferences after deducting the cost of delivering the final product." ;
    rdfs:label "Assess customer and product profitability" ;
    skos:definition "An Act of Appraisal that judges the profitability of customers and products after deducting delivery cost and produces a profitability analysis." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): the act evaluates/judges profitability. Descriptive output (cco:ont00000853)." ;
    skos:example "Ranking customer segments by net margin after cost-to-serve." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerMasterFile ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProfitabilityAnalysis ] .

ex:P10783 a owl:Class ;
    ex:pcfID "10783" ;
    ex:hierarchyID "9.1.4.2" ;
    ex:apqcSourceText "Checking demand about a specific product by a customer segment. Conduct a detailed study--or research a customer behavior or preference for a product--in order to determine its production and profitability in a specific market." ;
    rdfs:label "Evaluate new products" ;
    skos:definition "An Act of Appraisal that judges the demand and projected profitability of a new product in a market and produces a new-product evaluation." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal). Descriptive output (cco:ont00000853): a judgement of the product's viability." ;
    skos:example "Assessing whether a proposed product line is worth producing for a target segment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:NewProductEvaluation ] .

ex:P10784 a owl:Class ;
    ex:pcfID "10784" ;
    ex:hierarchyID "9.1.4.3" ;
    ex:apqcSourceText "Determining the cost of delivering an end product at different stages of production. Study the total life cycle of a product/process to determine how much revenue and production cost will be incurred at every stage in order to make strategic decisions." ;
    rdfs:label "Perform life cycle costing" ;
    skos:definition "An Act of Analysis that examines a product's full life cycle and produces a life-cycle cost analysis of the revenue and cost incurred at each stage." ;
    rdfs:comment "Descriptive output (cco:ont00000853). Genus ex:ActOfAnalysis: derives stage-by-stage cost understanding from cost data." ;
    skos:example "Computing total cost of ownership across a product's design, production, and disposal stages." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LifeCycleCostAnalysis ] .

ex:P10785 a owl:Class ;
    ex:pcfID "10785" ;
    ex:hierarchyID "9.1.4.4" ;
    ex:apqcSourceText "Creating the best fit between a product and the end user. Maximize the customer base by providing different products in the market." ;
    rdfs:label "Optimize customer and product mix" ;
    skos:definition "An Act of Selection that chooses the customer and product mix giving the best fit between products and end users and produces a product-mix decision prescribing that mix." ;
    rdfs:comment "Directive output (GOLDEN PRINCIPLE): choosing an optimal mix from candidate combinations yields a decision (cco:ont00000965), so the genus is ex:ActOfSelection, reused from apqc-ext." ;
    skos:example "Selecting which products to offer to which segments to maximize the customer base." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProfitabilityAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductMixDecision ] .

ex:P10786 a owl:Class ;
    ex:pcfID "10786" ;
    ex:hierarchyID "9.1.4.5" ;
    ex:apqcSourceText "Observing the behavior of a new set of customers for different products. Prepare strategies to improve sales and profits." ;
    rdfs:label "Track performance of new-customer and product strategies" ;
    skos:definition "An Act of Monitoring that observes the behavior of new customers toward products and produces a performance measure of those new-customer and product strategies." ;
    rdfs:comment "Descriptive output (cco:ont00000853): tracked performance metrics. Genus ex:ActOfMonitoring. The follow-on 'prepare strategies to improve sales' is a downstream, non-definitional step, so it is noted here rather than promoted to a restriction." ;
    skos:example "Monitoring repeat-purchase rates of customers acquired under a new product strategy." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceMeasure ] .

ex:P10787 a owl:Class ;
    ex:pcfID "10787" ;
    ex:hierarchyID "9.1.4.6" ;
    ex:apqcSourceText "Evaluating performance based on different sets of activities created by management to measure performance." ;
    rdfs:label "Prepare activity-based performance measures" ;
    skos:definition "An Act of Analysis that derives performance metrics from activity data and produces activity-based performance measures." ;
    rdfs:comment "Descriptive output (cco:ont00000853): a performance measure is a representation of measured performance. Genus ex:ActOfAnalysis: computes metrics from activity data." ;
    skos:example "Computing cost-per-transaction and cycle-time metrics for finance activities." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceMeasure ] .

ex:P10788 a owl:Class ;
    ex:pcfID "10788" ;
    ex:hierarchyID "9.1.4.7" ;
    ex:apqcSourceText "Conducting activities to improve cost distribution regularly. Follow or adopt different ways of reducing costs." ;
    rdfs:label "Manage continuous cost improvement (capability)" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to regularly improve cost distribution, realized in recurring acts of cost reduction." ;
    rdfs:comment "R5 = capability (R6). 'Continuous/regularly' denotes a standing function with no identifiable single beginning and end, so it is an Organization Capability (cco:ont00000568), not a bounded process. It is realized in cost-improvement acts and is realized-in-attached to its parent 10741 (the capability is realized in the process, per BFO_0000054 domain=realizable/range=process)." ;
    skos:example "A standing kaizen-style cost-improvement program run every quarter." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10741 ] .

# ================== group 9.2 ==================
# Perform revenue accounting

ex:P10729 a owl:Class ;
    ex:pcfID "10729" ;
    ex:hierarchyID "9.2" ;
    ex:apqcSourceText "Comparing revenue targets to reality. Review all transactions and entries passed in final accounts in a year in order to examine profits." ;
    rdfs:label "Perform revenue accounting" ;
    skos:definition "An Act of Accounting that reviews a period's revenue-related transactions and final-account entries and produces financial data comparing revenue targets to realized results." ;
    rdfs:comment "Models APQC process group 9.2 as a bounded occurrent. Its APQC level-3 children are process parts (cco:ont00001777), not subclasses." ;
    skos:example "A finance team's annual revenue close in which the year's customer transactions are reviewed to examine profits." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10742 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10743 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10744 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10745 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10746 ] .

ex:P10742 a owl:Class ;
    ex:pcfID "10742" ;
    ex:hierarchyID "9.2.1" ;
    ex:apqcSourceText "Evaluating and processing requests for advances. Evaluate credit requests by customers requiring loans to buy products/services." ;
    rdfs:label "Process customer credit" ;
    skos:definition "An Act of Accounting that evaluates and processes customer requests for credit advances and produces a credit assessment of the requesting customer." ;
    rdfs:comment "Anchored to ex:ActOfAccounting as a customer-credit handling act; its APQC children are process parts." ;
    skos:example "A credit department reviews a customer's loan request and decides on a credit line." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CreditAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10789 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10790 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14187 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14188 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10791 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10792 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10793 ] .

ex:P10789 a owl:Class ;
    ex:pcfID "10789" ;
    ex:hierarchyID "9.2.1.1" ;
    ex:apqcSourceText "Creating guidelines for providing advances. Set up credit standards, credit terms, and collection policies." ;
    rdfs:label "Establish credit policies" ;
    skos:definition "An Act of Formulation that composes credit standards, terms, and collection guidelines and produces a credit policy." ;
    rdfs:comment "Genus Act of Formulation (Directive output) per the Golden Principle: a policy is a Directive ICE." ;
    skos:example "A controller sets the firm's credit standards and collection terms for the coming year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CreditPolicy ] .

ex:P10790 a owl:Class ;
    ex:pcfID "10790" ;
    ex:hierarchyID "9.2.1.2" ;
    ex:apqcSourceText "Checking and accepting new requests based on eligibility criteria. Analyze the status of applicants and requirements to be met for a new account." ;
    rdfs:label "Analyze/Approve new account applications" ;
    skos:definition "An Act of Appraisal that evaluates new-account applicants against eligibility criteria and produces a credit assessment and an account approval decision." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges applicant status. Dual output -- a Descriptive credit assessment and a Directive approval decision." ;
    skos:example "A credit analyst checks an applicant's status and approves a new account." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerMasterFile ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CreditAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AccountApprovalDecision ] .

ex:P14187 a owl:Class ;
    ex:pcfID "14187" ;
    ex:hierarchyID "9.2.1.3" ;
    ex:apqcSourceText "Reviewing past credit scores to determine the if a line of credit will be extended to potential customers. This could also include extending additional credit to existing accounts." ;
    rdfs:label "Analyze credit scoring history" ;
    skos:definition "An Act of Analysis that examines a customer's past credit-scoring history and produces a credit assessment indicating whether credit should be extended." ;
    rdfs:comment "Genus Act of Analysis (information processing of input ICEs into a descriptive judgement)." ;
    skos:example "An analyst reviews a customer's credit-score history to decide on extending a line of credit." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CreditScoringHistory ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CreditAssessment ] .

ex:P14188 a owl:Class ;
    ex:pcfID "14188" ;
    ex:hierarchyID "9.2.1.4" ;
    ex:apqcSourceText "Planning credit score requirements based on established credit policies." ;
    rdfs:label "Forecast credit scoring requirement" ;
    skos:definition "An Act of Formulation that determines the credit-score requirements applicants must meet, based on established credit policies, and produces a credit-score requirement specification." ;
    rdfs:comment "Re-anchored from ex:ActOfAnalysis to ex:ActOfFormulation (Act of Planning, cco:ont00000511 family) and output changed from ex:FinancialForecast to the Directive ex:CreditScoreRequirementSpecification. The source text is 'Planning credit score requirements based on established credit policies' -- the act sets/determines the future credit-score REQUIREMENTS (thresholds an applicant must meet), which is prescriptive (a requirement prescribes), not a descriptive projection. The previous model leaned on the label word 'Forecast' to give genus=ActOfAnalysis + output=FinancialForecast, but a credit-score requirement is not an income/cash-flow forecast, so that output ICE did not denote what the process produces. GOLDEN PRINCIPLE: the description verb is 'planning' and the artifact is a requirement spec -> Directive output and a planning/formulation genus. REJECTED reading: that the act merely projects future demand for scoring (which would keep ActOfAnalysis with a Descriptive ICE); the verbatim verb 'Planning' and the prescriptive nature of a 'requirement' refute it." ;
    skos:example "Setting the minimum credit scores required for next year's lending program from the firm's credit policy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CreditPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CreditScoreRequirementSpecification ] .

ex:P10791 a owl:Class ;
    ex:pcfID "10791" ;
    ex:hierarchyID "9.2.1.5" ;
    ex:apqcSourceText "Evaluating existing account holders and their past performance. Regularly review existing accounts to get the required information about the status at present." ;
    rdfs:label "Review existing accounts" ;
    skos:definition "An Act of Appraisal that evaluates existing account holders and their past performance and produces an account statement of their present status." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges account-holder performance/status." ;
    skos:example "A credit team reviews active accounts and reports each holder's current standing." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerMasterFile ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AccountStatement ] .

ex:P10792 a owl:Class ;
    ex:pcfID "10792" ;
    ex:hierarchyID "9.2.1.6" ;
    ex:apqcSourceText "Preparing account payable reports about payments to be made according to accounting rules and principles, and providing the reports to management." ;
    rdfs:label "Produce credit/collection reports" ;
    skos:definition "An Act of Reporting that compiles credit and collection information into a financial report provided to management." ;
    rdfs:comment "Genus Act of Reporting (Descriptive output): the report represents, rather than prescribes." ;
    skos:example "Accounting prepares a monthly collections report for senior management." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] .

ex:P10793 a owl:Class ;
    ex:pcfID "10793" ;
    ex:hierarchyID "9.2.1.7" ;
    ex:apqcSourceText "Closing or restarting accounts according to changes made in credit policies." ;
    rdfs:label "Reinstate or suspend accounts based on credit policies" ;
    skos:definition "An Act of Accounting that closes or restarts customer accounts in accordance with current credit policy and updates the resulting account statement." ;
    rdfs:comment "Operational accounting act on account records; takes the governing credit policy as input." ;
    skos:example "A clerk suspends an account that breaches the revised credit policy." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CreditPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AccountStatement ] .

ex:P10743 a owl:Class ;
    ex:pcfID "10743" ;
    ex:hierarchyID "9.2.2" ;
    ex:apqcSourceText "Preparing detailed reports of customer purchases. Prepare a commercial document between the seller and customer with details about transaction. Detail the quantity purchased, price of products/services, date, parties involved, unique invoice number, and tax information." ;
    rdfs:label "Invoice customer" ;
    skos:definition "An Act of Accounting that prepares a commercial invoice documenting a customer's purchase transaction and produces an invoice about that customer." ;
    rdfs:comment "Output ex:Invoice is a Descriptive ICE that is about the Customer (per shared vocabulary)." ;
    skos:example "Billing issues a tax invoice for a customer's order." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:Invoice ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10794 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10795 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10796 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10797 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10798 ] .

ex:P10794 a owl:Class ;
    ex:pcfID "10794" ;
    ex:hierarchyID "9.2.2.1" ;
    ex:apqcSourceText "Creating and updating a record of customers and the products being purchased by them in a database. This process element requires the organization to maintain a database of customers and their purchases. Such a master-file can be used to ensure customer touch point, enhance customer satisfaction, explore cross selling opportunities, and identify future trends. This database will include several particulars about the personal details of the organization's customers and a tracking of the products being sold." ;
    rdfs:label "Maintain customer/product master files" ;
    skos:definition "An Act of Accounting that creates and updates records of customers and the products they purchase and produces a customer master file." ;
    rdfs:comment "Record-maintenance accounting act; output is the Descriptive customer master file." ;
    skos:example "A clerk updates the customer master file after a new product is sold." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterFile ] .

ex:P10795 a owl:Class ;
    ex:pcfID "10795" ;
    ex:hierarchyID "9.2.2.2" ;
    ex:apqcSourceText "Preparing detailed reports about products purchased by customers. Record and generate a detail account of transactions made by customers fat a particular time and location. Include all details about products such as price, quantity, and name." ;
    rdfs:label "Generate customer billing data" ;
    skos:definition "An Act of Accounting that records and compiles the details of a customer's purchase transactions and produces customer billing data." ;
    rdfs:comment "Output modeled as ex:FinancialData (Descriptive ICE) covering price/quantity/product detail." ;
    skos:example "The billing system generates the line-item billing data for a customer's monthly statement." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialData ] .

ex:P10796 a owl:Class ;
    ex:pcfID "10796" ;
    ex:hierarchyID "9.2.2.3" ;
    ex:apqcSourceText "Providing information to customers about purchases made by them. Communicate the details of purchases. Provide customers with a copy of details for their reference." ;
    rdfs:label "Transmit billing data to customers" ;
    skos:definition "An Act of Communication that conveys a customer's purchase and billing details to that customer by delivering a copy of an already-prepared invoice." ;
    rdfs:comment "Re-anchored from ex:ActOfReporting to cco:ont00000402 (Act of Communication). Transmit-only per the ex:ActOfReporting carve-out: its rdfs:comment states 'Where a node only transmits an already-prepared report to a party, the group module reuses cco:ont00000402 instead.' The source text is delivery-only ('Providing information to customers ... Communicate the details ... Provide customers with a copy'); no new ICE is produced -- the invoice already exists from ex:P10743/ex:P10795. The invoice is therefore the transmitted ICE (has input), not an output, and the Customer is the recipient participant. cco:ont00000402 (Act of Communication) verified against CCO v2.0 (2024-11-06): 'A Planned Act in which some Information Content Entity is transferred from some Agent to Another.' Same transmit-only test applied to sibling 'provide a copy' nodes." ;
    skos:example "The system emails a customer a copy of their invoice." ;
    rdfs:subClassOf cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:Invoice ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P10797 a owl:Class ;
    ex:pcfID "10797" ;
    ex:hierarchyID "9.2.2.4" ;
    ex:apqcSourceText "Registering transactions and their scheduled payments." ;
    rdfs:label "Post receivable entries" ;
    skos:definition "An Act of Accounting that registers receivable transactions and their scheduled payments and produces a transaction record." ;
    rdfs:comment "Posting/registration accounting act; output is the Descriptive transaction record." ;
    skos:example "Accounting posts the receivable entry for a newly invoiced sale." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10798 a owl:Class ;
    ex:pcfID "10798" ;
    ex:hierarchyID "9.2.2.5" ;
    ex:apqcSourceText "Checking and solving billing queries raised by customers." ;
    rdfs:label "Resolve customer billing inquiries" ;
    skos:definition "An Act of Accounting that checks customer billing queries against the records and produces a corrected or clarified account statement resolving them." ;
    rdfs:comment "Resolution of billing records; the Customer participates as the inquiring party." ;
    skos:example "A billing agent investigates and corrects an over-charge a customer disputed." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AccountStatement ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P10744 a owl:Class ;
    ex:pcfID "10744" ;
    ex:hierarchyID "9.2.3" ;
    ex:apqcSourceText "Processing payments due from customers. This includes all processing of funds received, whether by check or electronically. This does not include the generation of invoices." ;
    rdfs:label "Process accounts receivable (AR)" ;
    skos:definition "An Act of Accounting that processes payments due from customers, whether received by check or electronically, and records the resulting receivable transactions." ;
    rdfs:comment "Excludes invoice generation (that is 9.2.2). Its APQC children are process parts." ;
    skos:example "The AR team applies and books a batch of customer cheque and electronic payments." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10799 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10800 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10801 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10802 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10803 ] .

ex:P10799 a owl:Class ;
    ex:pcfID "10799" ;
    ex:hierarchyID "9.2.3.1" ;
    ex:apqcSourceText "Creating rules and regulations to be followed in case of credit sales to customers. Create rules and procedures to follow at the time of sale (e.g., the allowable number of installments)." ;
    rdfs:label "Establish AR policies" ;
    skos:definition "An Act of Formulation that composes the rules and procedures governing credit sales and produces a financial policy for accounts receivable." ;
    rdfs:comment "Directive output (Financial Policy) -> Act of Formulation per the Golden Principle." ;
    skos:example "Finance sets the allowable installment terms for credit sales." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialPolicy ] .

ex:P10800 a owl:Class ;
    ex:pcfID "10800" ;
    ex:hierarchyID "9.2.3.2" ;
    ex:apqcSourceText "Collecting cash from customers. Deposit it into bank account. Make entries into the books of accounts." ;
    rdfs:label "Receive/Deposit customer payments" ;
    skos:definition "An Act of Financial Transaction that receives monetary payment from a customer, deposits it into a bank account, and books the corresponding entries as a transaction record." ;
    rdfs:comment "Operations category permits material I/O: the input is a Monetary Payment (material entity); the booked entries are a Descriptive transaction record." ;
    skos:example "A cashier deposits a customer's cash payment and records the receipt." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10801 a owl:Class ;
    ex:pcfID "10801" ;
    ex:hierarchyID "9.2.3.3" ;
    ex:apqcSourceText "Checking and moving funds between countries for business activities, typically through authorized remittance agents." ;
    rdfs:label "Apply cash remittances" ;
    skos:definition "An Act of Financial Transaction that checks and moves monetary payments, typically through authorized remittance agents, and records the applied remittance." ;
    rdfs:comment "Material input is a Monetary Payment (the remitted funds); the BankingPartner participates as the authorized remittance agent." ;
    skos:example "Treasury applies an inbound cross-border remittance to the customer's account via an authorized agent." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:BankingPartner ] .

ex:P10802 a owl:Class ;
    ex:pcfID "10802" ;
    ex:hierarchyID "9.2.3.4" ;
    ex:apqcSourceText "Preparing reports that detail balances due or what to collect from customers at a certain point in time." ;
    rdfs:label "Prepare AR reports" ;
    skos:definition "An Act of Reporting that compiles outstanding receivable balances at a point in time into a financial report." ;
    rdfs:comment "Genus Act of Reporting (Descriptive output)." ;
    skos:example "Accounting produces an aged-receivables report at month-end." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] .

ex:P10803 a owl:Class ;
    ex:pcfID "10803" ;
    ex:hierarchyID "9.2.3.5" ;
    ex:apqcSourceText "Preparing the general ledger for account receivables from journals. Place all journal entries related to accounts receivables in the general ledger accounts of a business." ;
    rdfs:label "Post AR activity to the general ledger" ;
    skos:definition "An Act of Accounting that transfers accounts-receivable journal entries into the general ledger accounts." ;
    rdfs:comment "Posting accounting act; output is the General Ledger (Descriptive ICE)." ;
    skos:example "The accountant posts the AR sub-ledger entries to the general ledger." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GeneralLedger ] .

ex:P10745 a owl:Class ;
    ex:pcfID "10745" ;
    ex:hierarchyID "9.2.4" ;
    ex:apqcSourceText "Posting entries to respective accounts, and preparing accounts for receivables. Manage the cash collected by the business from its debtors. Record it in the books of accounts to provide clear information about the availability of the cash." ;
    rdfs:label "Manage and process collections" ;
    skos:definition "An Act of Accounting that posts collection entries to the respective accounts and records cash collected from debtors to evidence available cash." ;
    rdfs:comment "Modeled on the bounded processing core ('posting entries', 'record it in the books'); its APQC children are process parts." ;
    skos:example "The collections team posts a day's debtor receipts to the ledger." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10804 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10805 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10806 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10807 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10808 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14007 ] .

ex:P10804 a owl:Class ;
    ex:pcfID "10804" ;
    ex:hierarchyID "9.2.4.1" ;
    ex:apqcSourceText "Creating a process to follow in case of a failed payment by account holders. Create rules and regulations for the account holder who has failed to make at least the minimum monthly payment by the due date." ;
    rdfs:label "Establish policies for delinquent accounts" ;
    skos:definition "An Act of Formulation that composes the rules to follow when an account holder fails to make required payments and produces a financial policy for delinquent accounts." ;
    rdfs:comment "Directive output (Financial Policy) -> Act of Formulation." ;
    skos:example "Collections defines the dunning policy for accounts past due." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialPolicy ] .

ex:P10805 a owl:Class ;
    ex:pcfID "10805" ;
    ex:hierarchyID "9.2.4.2" ;
    ex:apqcSourceText "Examining balance statements of accountholders who failed to make required payments. Study or review the account details of customers' past payments when preparing negotiations policies." ;
    rdfs:label "Analyze delinquent account balances" ;
    skos:definition "An Act of Analysis that examines the balance statements and past payments of delinquent account holders and produces a credit assessment informing negotiation." ;
    rdfs:comment "Genus Act of Analysis (information processing into a Descriptive judgement); input is the account statement." ;
    skos:example "An analyst studies a defaulter's payment history before settlement talks." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:AccountStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CreditAssessment ] .

ex:P10806 a owl:Class ;
    ex:pcfID "10806" ;
    ex:hierarchyID "9.2.4.3" ;
    ex:apqcSourceText "Determine ways for customers in default to repay debts (e.g., allowing more time or discounts)." ;
    rdfs:label "Correspond/Negotiate with delinquent accounts" ;
    skos:definition "An Act of Formulation that, through correspondence with a defaulting customer, determines and prescribes a repayment arrangement as a financial procedure." ;
    rdfs:comment "Genus Act of Formulation: the definitional output is a prescribed repayment arrangement (Directive ICE). The defaulting Customer participates." ;
    skos:example "A collections officer agrees an extended-time repayment plan with a customer in default." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P10807 a owl:Class ;
    ex:pcfID "10807" ;
    ex:hierarchyID "9.2.4.4" ;
    ex:apqcSourceText "Determining rules for handling accounts. Discuss and plan with internal parties (department heads, managers, and senior management) about rules to follow in coming months." ;
    rdfs:label "Discuss account resolution with internal parties" ;
    skos:definition "An Act of Formulation in which internal parties determine and prescribe the rules for handling accounts and produce a financial procedure." ;
    rdfs:comment "Directive output (Financial Procedure) -> Act of Formulation." ;
    skos:example "Department heads agree the rules for handling overdue accounts next quarter." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] .

ex:P10808 a owl:Class ;
    ex:pcfID "10808" ;
    ex:hierarchyID "9.2.4.5" ;
    ex:apqcSourceText "Maintaining reserves for write-offs and adjustments. Adjust or write off certain expenses and losses." ;
    rdfs:label "Process adjustments/write off balances" ;
    skos:definition "An Act of Accounting that adjusts or writes off uncollectible balances and maintains the related reserves, producing a transaction record." ;
    rdfs:comment "Posting/adjustment accounting act; output is the Descriptive transaction record." ;
    skos:example "Accounting writes off a bad debt and updates the allowance reserve." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P14007 a owl:Class ;
    ex:pcfID "14007" ;
    ex:hierarchyID "9.2.4.6" ;
    ex:apqcSourceText "Renegotiating the terms of a loan agreement in order to recoup money from a default account." ;
    rdfs:label "Perform recovery workout" ;
    skos:definition "An Act of Formulation that renegotiates the terms of a loan agreement with a defaulting debtor and prescribes revised repayment terms as a financial procedure to recoup the debt." ;
    rdfs:comment "Genus Act of Formulation: the definitional output is the revised agreement terms (Directive ICE). The defaulting Customer participates." ;
    skos:example "A workout specialist renegotiates a defaulted loan into a restructured repayment schedule." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P10746 a owl:Class ;
    ex:pcfID "10746" ;
    ex:hierarchyID "9.2.5" ;
    ex:apqcSourceText "Creating and providing funds for necessary adjustments and deductions, including all expenses that were required for the business at certain point in time." ;
    rdfs:label "Manage and process adjustments/deductions" ;
    skos:definition "An Act of Accounting that creates and funds the necessary account adjustments and deductions for a period and records the resulting transactions." ;
    rdfs:comment "Modeled on the bounded processing core; its APQC children are process parts." ;
    skos:example "Accounting books the period's required adjustments and deductions." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10809 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10810 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10811 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10812 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10813 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10814 ] .

ex:P10809 a owl:Class ;
    ex:pcfID "10809" ;
    ex:hierarchyID "9.2.5.1" ;
    ex:apqcSourceText "Creating guidelines to follow in case of adjustments to business processes." ;
    rdfs:label "Establish policies/procedures for adjustments" ;
    skos:definition "An Act of Formulation that composes the guidelines to follow when making account adjustments and produces a financial procedure." ;
    rdfs:comment "Directive output (Financial Procedure) -> Act of Formulation." ;
    skos:example "Finance documents the procedure for posting account adjustments." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] .

ex:P10810 a owl:Class ;
    ex:pcfID "10810" ;
    ex:hierarchyID "9.2.5.2" ;
    ex:apqcSourceText "Checking changes made in accounts during the year. Examine the alterations made in final accounts to rectify errors/omissions." ;
    rdfs:label "Analyze adjustments" ;
    skos:definition "An Act of Analysis that examines the alterations made in the final accounts during the year and produces a variance analysis identifying errors or omissions to rectify." ;
    rdfs:comment "Genus Act of Analysis (information processing into a Descriptive analysis)." ;
    skos:example "An accountant reviews the year's account adjustments to flag posting errors." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:VarianceAnalysis ] .

ex:P10811 a owl:Class ;
    ex:pcfID "10811" ;
    ex:hierarchyID "9.2.5.3" ;
    ex:apqcSourceText "Providing suitable offers to customers. Present different offers (e.g., discounts) available for customers or buyers." ;
    rdfs:label "Correspond/Negotiate with customer" ;
    skos:definition "An Act of Formulation that, through correspondence with a customer, determines and prescribes a suitable offer such as a discount as a financial procedure." ;
    rdfs:comment "Genus Act of Formulation: the definitional output is a prescribed offer (Directive ICE). The Customer participates." ;
    skos:example "An agent offers a customer a settlement discount to clear an adjustment dispute." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P10812 a owl:Class ;
    ex:pcfID "10812" ;
    ex:hierarchyID "9.2.5.4" ;
    ex:apqcSourceText "Discussing and planning with internal parties (department heads, managers, and senior management) about rules to follow in coming months." ;
    rdfs:label "Discuss resolution with internal parties" ;
    skos:definition "An Act of Formulation in which internal parties discuss and prescribe the rules to follow for handling adjustments in the coming months and produce a financial procedure." ;
    rdfs:comment "Directive output (Financial Procedure) -> Act of Formulation." ;
    skos:example "Managers agree the rules for processing customer deductions next quarter." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] .

ex:P10813 a owl:Class ;
    ex:pcfID "10813" ;
    ex:hierarchyID "9.2.5.5" ;
    ex:apqcSourceText "Creating a mechanism for consumer protection in case of a higher price charged. When a supplier sells a product at a higher price to the distributor than the price they have set with the end user, submit a chargeback to the supplier to recover the money lost in the transaction." ;
    rdfs:label "Prepare chargeback invoices" ;
    skos:definition "An Act of Accounting that prepares a chargeback invoice submitted to a supplier to recover an over-charged amount and produces that invoice." ;
    rdfs:comment "Output ex:Invoice (Descriptive ICE) is the chargeback document; the Supplier participates as the chargeback recipient." ;
    skos:example "A distributor issues a supplier chargeback invoice for an over-billed shipment." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:Invoice ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Supplier ] .

ex:P10814 a owl:Class ;
    ex:pcfID "10814" ;
    ex:hierarchyID "9.2.5.6" ;
    ex:apqcSourceText "Recording business transactions as they occur in order to provide a balanced accounts for financial reporting." ;
    rdfs:label "Process related entries" ;
    skos:definition "An Act of Accounting that records related business transactions as they occur to maintain balanced accounts for financial reporting and produces a transaction record." ;
    rdfs:comment "Posting accounting act; output is the Descriptive transaction record." ;
    skos:example "The ledger clerk records the offsetting entries for a processed deduction." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

# ================== group 9.3 ==================
# Perform general accounting and reporting
# 9.3.1 (PCF 10747) is a standing function -> ex:FinancialPolicyManagementCapability (in 2g).

ex:P10730 a owl:Class ;
    ex:pcfID "10730" ;
    ex:hierarchyID "9.3" ;
    ex:apqcSourceText "Making statements about business activities and functions. Prepare financial statements (balance sheet, income statement, statement of cash flows, and statement of stockholders' equity) according to accounting concepts and principles." ;
    rdfs:label "Perform general accounting and reporting" ;
    skos:definition "An Act of Accounting that records an organization's financial transactions and produces financial statements describing its activities in accordance with accounting concepts and principles." ;
    rdfs:comment "Models APQC process group 9.3 as a bounded occurrent (the accounting-and-reporting cycle). Its APQC children are process parts (cco:ont00001777), not subclasses. 9.3.1 is a standing function modeled as a capability, hence absent from the partonomy." ;
    skos:example "A company's fiscal-period close culminating in a published set of financial statements." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10748 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10749 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10750 ] .

ex:P10815 a owl:Class ;
    ex:pcfID "10815" ; ex:hierarchyID "9.3.1.1" ;
    ex:apqcSourceText "Agreeing upon terms and conditions. Negotiate an agreement between two or more parties, the customer and service providers. Specify scope, quality, and responsibilities." ;
    rdfs:label "Negotiate service-level agreements" ;
    skos:definition "An Act of Formulation that negotiates terms among parties and produces a service-level agreement specifying scope, quality, and responsibilities." ;
    rdfs:comment "Genus Act of Formulation (output a Directive ICE) per GOLDEN PRINCIPLE: a negotiated SLA prescribes obligations." ;
    skos:example "A shared-services finance team negotiating an SLA with an internal customer." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceLevelAgreement ] .

ex:P10816 a owl:Class ;
    ex:pcfID "10816" ; ex:hierarchyID "9.3.1.2" ;
    ex:apqcSourceText "Establishing policies and procedures to prepare financial statements, including methods, measurement systems, and procedures for providing disclosures." ;
    rdfs:label "Establish accounting policies" ;
    skos:definition "An Act of Formulation that composes the accounting policies and procedures governing how financial statements and disclosures are prepared." ;
    rdfs:comment "Genus Act of Formulation: output is a Financial Policy (Directive ICE)." ;
    skos:example "A controller adopting a revenue-recognition policy for the organization." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialPolicy ] .

ex:P20604 a owl:Class ;
    ex:pcfID "20604" ; ex:hierarchyID "9.3.1.3" ;
    ex:apqcSourceText "Creating a written copy of agreed-upon procedures for preparing financial statements, and making them available to the public." ;
    rdfs:label "Publish accounting policies" ;
    skos:definition "An Act of Communication that conveys an already-formulated accounting policy to the public." ;
    rdfs:comment "Re-anchored from ex:ActOfReporting to cco:ont00000402 (Act of Communication). Two defects fixed: (1) GOLDEN-PRINCIPLE break -- ex:ActOfReporting compiles a Descriptive ICE, but the asserted output was ex:FinancialPolicy, a Directive ICE (cco:ont00000965); (2) the act merely disseminates an already-formulated policy (input == output == FinancialPolicy), i.e. transfer of an existing ICE between agents, which the ex:ActOfReporting comment routes to cco:ont00000402: 'Where a node only transmits an already-prepared report to a party, the group module reuses cco:ont00000402 instead.' Publishing transmits the same ICE; it does not produce a new descriptive one, so the has output ex:FinancialPolicy restriction is dropped and ex:FinancialPolicy is kept as has input (the transmitted ICE). cco:ont00000402 verified against CCO v2.0 (2024-11-06): 'A Planned Act in which some Information Content Entity is transferred from some Agent to Another.'" ;
    skos:example "Posting the firm's accounting-policy manual on its investor-relations website." ;
    rdfs:subClassOf cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialPolicy ] .

ex:P10817 a owl:Class ;
    ex:pcfID "10817" ; ex:hierarchyID "9.3.1.4" ;
    ex:apqcSourceText "Implementing parameters for accounting. Apply set conditions for any approval process." ;
    rdfs:label "Set and enforce approval limits" ;
    skos:definition "An Act of Formulation that sets the monetary thresholds and conditions governing financial-approval processes and prescribes their enforcement." ;
    rdfs:comment "Genus Act of Formulation: output is an Approval Limit Specification (Directive ICE) per GOLDEN PRINCIPLE." ;
    skos:example "Defining tiered sign-off thresholds for expenditure approvals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ApprovalLimitSpecification ] .

ex:P10818 a owl:Class ;
    ex:pcfID "10818" ; ex:hierarchyID "9.3.1.5" ;
    ex:apqcSourceText "Establishing processes and procedures to exercise financial control and accountability. Record, verify, and report transactions that affect revenues, expenditures, assets, and liabilities." ;
    rdfs:label "Establish common financial systems" ;
    skos:definition "An Act of Formulation that composes the processes and procedures for exercising financial control and accountability over transactions affecting revenues, expenditures, assets, and liabilities." ;
    rdfs:comment "Genus Act of Formulation: output is a Financial Procedure (Directive ICE)." ;
    skos:example "Standing up a common ledger-posting and control procedure across business units." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] .

ex:P10748 a owl:Class ;
    ex:pcfID "10748" ; ex:hierarchyID "9.3.2" ;
    ex:apqcSourceText "Applying basic principles, concepts, and accounting practices in recording and preparing final accounts, and using accounting information in management." ;
    rdfs:label "Perform general accounting" ;
    skos:definition "An Act of Accounting that applies accounting principles and practices to record transactions and prepare an organization's general ledger and final accounts." ;
    rdfs:comment "Parent of 9.3.2.1-9.3.2.9; children attached as process parts (cco:ont00001777)." ;
    skos:example "The monthly general-ledger close performed by a corporate accounting team." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10819 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10820 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10821 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10822 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10823 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10824 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10825 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10826 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10827 ] .

ex:P10819 a owl:Class ;
    ex:pcfID "10819" ; ex:hierarchyID "9.3.2.1" ;
    ex:apqcSourceText "Preparing trial balance account from general ledgers. List all accounts used in the general ledger. Alter accounts according to business requirements." ;
    rdfs:label "Maintain chart of accounts" ;
    skos:definition "An Act of Accounting that lists and updates the set of accounts used in the general ledger to produce a current chart of accounts." ;
    skos:example "Adding a new expense account to the chart of accounts for a new business line." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChartOfAccounts ] .

ex:P10820 a owl:Class ;
    ex:pcfID "10820" ; ex:hierarchyID "9.3.2.2" ;
    ex:apqcSourceText "Making ledger and trial balance accounts from journal entries. This process requires the organization to record every transaction into accounts done by business. It is a base documents for preparing final accounts of company." ;
    rdfs:label "Process journal entries" ;
    skos:definition "An Act of Accounting that records transactions as journal entries and posts them to produce the general ledger." ;
    skos:example "Posting the period's sales and purchase journals to the ledger." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GeneralLedger ] .

ex:P10821 a owl:Class ;
    ex:pcfID "10821" ; ex:hierarchyID "9.3.2.3" ;
    ex:apqcSourceText "Allocating funds across functions. Apportion funds in line with the budgets created. Formalize allocations in centralized internal records." ;
    rdfs:label "Process allocations" ;
    skos:definition "An Act of Accounting that apportions funds across functions in line with the budget and records the allocations in centralized internal records." ;
    rdfs:comment "Budget is a definitional input (the basis for apportionment); allocations are recorded as transaction records." ;
    skos:example "Allocating shared overhead to business units per the approved budget." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:Budget ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10822 a owl:Class ;
    ex:pcfID "10822" ; ex:hierarchyID "9.3.2.4" ;
    ex:apqcSourceText "Updating journal entries to adjust the balance of income and expenses at the end of an accounting period." ;
    rdfs:label "Process period end adjustments" ;
    skos:definition "An Act of Accounting that updates journal entries to adjust income and expense balances at the close of an accounting period, updating the general ledger." ;
    skos:example "Booking accruals and deferrals at month-end close." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GeneralLedger ] .

ex:P10823 a owl:Class ;
    ex:pcfID "10823" ; ex:hierarchyID "9.3.2.5" ;
    ex:apqcSourceText "Checking accounts separately for a parent and subsidiary company. Manage relationship between a parent company and subsidiaries. Document intercompany transactions in separate financial statements." ;
    rdfs:label "Post and reconcile intercompany transactions" ;
    skos:definition "An Act of Accounting that posts and reconciles transactions between a parent company and its subsidiaries and documents them in the general ledger." ;
    rdfs:comment "Subsidiaries are typical participants; recorded here as commentary rather than a definitional restriction." ;
    skos:example "Reconciling an intercompany loan between a parent and its subsidiary." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GeneralLedger ] .

ex:P10824 a owl:Class ;
    ex:pcfID "10824" ; ex:hierarchyID "9.3.2.6" ;
    ex:apqcSourceText "Reviewing general ledger accounts for a parent and subsidiaries companies. Validate the integrity of account balances on the company's general ledger of accounts. Review and compare general ledger accounts balances with source documents to ensure that balances match." ;
    rdfs:label "Reconcile general ledger accounts" ;
    skos:definition "An Act of Accounting that compares general-ledger account balances against source documents to validate their integrity and produce a reconciled general ledger." ;
    skos:example "Tying cash-account balances to bank statements during close." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GeneralLedger ] .

ex:P10825 a owl:Class ;
    ex:pcfID "10825" ; ex:hierarchyID "9.3.2.7" ;
    ex:apqcSourceText "Aggregating different processes in the business. Eliminate discontinued processes." ;
    rdfs:label "Perform consolidations and process eliminations" ;
    skos:definition "An Act of Accounting that aggregates accounts across business processes and eliminates discontinued items to produce a consolidated general ledger." ;
    skos:example "Eliminating intercompany balances when consolidating group accounts." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GeneralLedger ] .

ex:P10826 a owl:Class ;
    ex:pcfID "10826" ; ex:hierarchyID "9.3.2.8" ;
    ex:apqcSourceText "Balancing debit and credit balances of trial balance to preparing final accounts. Calculate the total debits and credits in company's accounts. Correspond the sum of all debits with the sum of all credits. Adjust entries as appropriate." ;
    rdfs:label "Prepare trial balance" ;
    skos:definition "An Act of Accounting that totals debit and credit balances to produce a balanced trial balance as the basis for final accounts." ;
    rdfs:comment "Output corrected from ex:GeneralLedger to ex:TrialBalance: 'Prepare trial balance' produces a balanced trial balance (a distinct derived statement), not the general ledger. ex:GeneralLedger is retained as the definitional has input (the trial balance is computed from it)." ;
    skos:example "Producing the adjusted trial balance prior to drafting statements." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TrialBalance ] .

ex:P10827 a owl:Class ;
    ex:pcfID "10827" ; ex:hierarchyID "9.3.2.9" ;
    ex:apqcSourceText "Accounting for changes due to country-level policy changes. Record adjustments made by management in the accounts." ;
    rdfs:label "Prepare and post management adjustments" ;
    skos:definition "An Act of Accounting that records management- and policy-driven adjustments in the accounts, updating the general ledger." ;
    skos:example "Posting a management override to reclassify expenses after a tax-law change." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GeneralLedger ] .

ex:P10749 a owl:Class ;
    ex:pcfID "10749" ; ex:hierarchyID "9.3.3" ;
    ex:apqcSourceText "Accounting for long-term and fixed assets. Record purchased, fixed assets that are not easily convertible into cash. Account for costs, useful life, resale value, depreciation, and amortization." ;
    rdfs:label "Perform fixed-asset accounting" ;
    skos:definition "An Act of Accounting that records and maintains the cost, useful life, depreciation, and disposition of an organization's fixed assets to produce a fixed-asset register." ;
    rdfs:comment "Parent of 9.3.3.1-9.3.3.9; children attached as process parts (cco:ont00001777)." ;
    skos:example "Maintaining the fixed-asset subledger across a fiscal year." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FixedAssetRegister ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10828 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10829 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10830 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10831 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10832 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10833 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10834 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10835 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10836 ] .

ex:P10828 a owl:Class ;
    ex:pcfID "10828" ; ex:hierarchyID "9.3.3.1" ;
    ex:apqcSourceText "Creating rules for fixed assets market valuation. Make rules and regulations for fixed assets regarding depreciation, provisions, resale, usage, etc." ;
    rdfs:label "Establish fixed-asset policies and procedures" ;
    skos:definition "An Act of Formulation that composes the rules and procedures governing fixed-asset valuation, depreciation, provisions, resale, and usage." ;
    rdfs:comment "Genus Act of Formulation: output is a Financial Procedure (Directive ICE) per GOLDEN PRINCIPLE." ;
    skos:example "Setting the straight-line depreciation policy for plant and equipment." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] .

ex:P10829 a owl:Class ;
    ex:pcfID "10829" ; ex:hierarchyID "9.3.3.2" ;
    ex:apqcSourceText "Keeping reports up-to-date regarding fixed assets. Create a fixed assets database detailing price, life cycle, depreciation rate, resale value, installation information, usage information, etc." ;
    rdfs:label "Maintain fixed-asset master data files" ;
    skos:definition "An Act of Accounting that creates and keeps current the fixed-asset master data detailing price, life cycle, depreciation, and usage." ;
    skos:example "Updating an asset's useful-life parameter in the fixed-asset register." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FixedAssetRegister ] .

ex:P10830 a owl:Class ;
    ex:pcfID "10830" ; ex:hierarchyID "9.3.3.3" ;
    ex:apqcSourceText "Keeping a summary of sales and purchases of assets. Record any expenses made for new assets purchased and sales of any old assets during the fiscal year." ;
    rdfs:label "Process and record fixed-asset additions and retires" ;
    skos:definition "An Act of Accounting that records additions and retirements of fixed assets during the fiscal year in the fixed-asset register." ;
    skos:example "Capitalizing a newly purchased machine and writing off a retired one." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FixedAssetRegister ] .

ex:P10831 a owl:Class ;
    ex:pcfID "10831" ; ex:hierarchyID "9.3.3.4" ;
    ex:apqcSourceText "Keeping a summary of expenses for installing and modifying assets. Record any expenses made for new assets purchased, any expenses incurred on improvements, the valuation of assets to reach current market price, and any transfer assets from one location to another during the fiscal year." ;
    rdfs:label "Process and record fixed-asset adjustments, enhancements, revaluations, and transfers" ;
    skos:definition "An Act of Accounting that records fixed-asset adjustments, enhancements, revaluations, and inter-location transfers in the fixed-asset register." ;
    skos:example "Revaluing a building to current market price and recording the uplift." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FixedAssetRegister ] .

ex:P10832 a owl:Class ;
    ex:pcfID "10832" ; ex:hierarchyID "9.3.3.5" ;
    ex:apqcSourceText "Maintaining a record of expenses necessitated for repairs and the preservation of assets. Administer and oversee the maintenance and repair of any fixed assets. Record all related transactions." ;
    rdfs:label "Process and record fixed-asset maintenance and repair expenses" ;
    skos:definition "An Act of Accounting that records the maintenance and repair expenses incurred to preserve fixed assets in the fixed-asset register." ;
    skos:example "Expensing a routine servicing cost against a vehicle asset." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FixedAssetRegister ] .

ex:P10833 a owl:Class ;
    ex:pcfID "10833" ; ex:hierarchyID "9.3.3.6" ;
    ex:apqcSourceText "Carrying out accounting for depreciation over fixed assets. Compute the sums necessitated. Maintain a record of the cost value of fixed assets over their useful life in the book of accounts." ;
    rdfs:label "Calculate and record depreciation expense" ;
    skos:definition "An Act of Accounting that computes periodic depreciation on fixed assets and records the resulting expense and carrying value in the fixed-asset register." ;
    skos:example "Booking monthly straight-line depreciation for the asset base." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FixedAssetRegister ] .

ex:P10834 a owl:Class ;
    ex:pcfID "10834" ; ex:hierarchyID "9.3.3.7" ;
    ex:apqcSourceText "Balancing the ledger account balance for fixed assets. Correct errors in the books of fixed assets. Provide correct information in relevant accounts." ;
    rdfs:label "Reconcile fixed-asset ledger" ;
    skos:definition "An Act of Accounting that balances and corrects the fixed-asset ledger so that its account balances are accurate." ;
    skos:example "Reconciling the fixed-asset subledger to the general ledger control account." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FixedAssetRegister ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FixedAssetRegister ] .

ex:P10835 a owl:Class ;
    ex:pcfID "10835" ; ex:hierarchyID "9.3.3.8" ;
    ex:apqcSourceText "Checking and updating the record of all raw materials and fixed assets. Track all fixes asset. Maintain a record of all inventory items." ;
    rdfs:label "Track fixed-assets including physical inventory" ;
    skos:definition "An Act of Monitoring that checks fixed assets against physical inventory over time and updates the fixed-asset register to reflect their current state." ;
    rdfs:comment "Genus Act of Monitoring (not Accounting): the act observes assets over time and reconciles them to a physical count, maintaining a representational record." ;
    skos:example "An annual physical-inventory count reconciled to the asset register." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FixedAssetRegister ] .

ex:P10836 a owl:Class ;
    ex:pcfID "10836" ; ex:hierarchyID "9.3.3.9" ;
    ex:apqcSourceText "Showing market value and related expenses on fixed assets data for taxation. Provide complete information recorded in the books of fixed assets about purchase price, depreciation, installation charges, resale market value etc. for tax and regulatory purposes." ;
    rdfs:label "Provide fixed-asset data to support tax, statutory, and regulatory reporting" ;
    skos:definition "An Act of Reporting that compiles fixed-asset data from the register and conveys it to support tax, statutory, and regulatory reporting." ;
    rdfs:comment "Genus Act of Reporting: the act disseminates fixed-asset information; the Fixed-Asset Register is the definitional input and the conveyed Financial Report the output." ;
    skos:example "Supplying depreciation schedules to the tax team for a return." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FixedAssetRegister ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] .

ex:P10750 a owl:Class ;
    ex:pcfID "10750" ; ex:hierarchyID "9.3.4" ;
    ex:apqcSourceText "Reporting on the organization's financial status to stakeholders. Include balance sheets, income statements, cash flow statements, and statements of shareholders' equity." ;
    rdfs:label "Perform financial reporting" ;
    skos:definition "An Act of Reporting that compiles an organization's financial statements and conveys its financial status to stakeholders." ;
    rdfs:comment "Parent of 9.3.4.1-9.3.4.8; children attached as process parts (cco:ont00001777)." ;
    skos:example "Issuing the quarterly financial-reporting package to investors." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10837 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10838 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10839 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10840 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10841 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10842 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10843 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14074 ] .

ex:P10837 a owl:Class ;
    ex:pcfID "10837" ; ex:hierarchyID "9.3.4.1" ;
    ex:apqcSourceText "Making reports of subsidiaries units to show profits generated from them. Prepare financial statements (balance sheets, income statements, cash flow statements and statements of shareholders' equity) for a single unit of a business." ;
    rdfs:label "Prepare business unit financial statements" ;
    skos:definition "An Act of Reporting that prepares the financial statements of a single business unit from its general-ledger balances." ;
    skos:example "Producing a division's standalone income statement and balance sheet." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialStatement ] .

ex:P10838 a owl:Class ;
    ex:pcfID "10838" ; ex:hierarchyID "9.3.4.2" ;
    ex:apqcSourceText "Making final accounts for all units of company together. Prepare combined financial statements of a parent company and its subsidiaries (i.e., separate legal entities controlled by a parent company) showing assets, liabilities, equity, income, expenses, and cash flows." ;
    rdfs:label "Prepare consolidated financial statements" ;
    skos:definition "An Act of Reporting that combines the accounts of a parent company and its subsidiaries to produce consolidated financial statements." ;
    skos:example "Preparing group consolidated statements at year-end." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConsolidatedFinancialStatement ] .

ex:P10839 a owl:Class ;
    ex:pcfID "10839" ; ex:hierarchyID "9.3.4.3" ;
    ex:apqcSourceText "Making reports for units/subsidiaries to help management in decision making. Prepare financial statements (balance sheets, income statements, cash flow statements, and statements of shareholders' equity) for a single unit of a business. Break down profits and losses by function/unit, clients, products, and region." ;
    rdfs:label "Perform business unit reporting/review management reports" ;
    skos:definition "An Act of Reporting that prepares and reviews business-unit management reports breaking down results by function, client, product, and region." ;
    skos:example "Issuing a divisional profitability pack for the monthly management review." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] .

ex:P10840 a owl:Class ;
    ex:pcfID "10840" ; ex:hierarchyID "9.3.4.4" ;
    ex:apqcSourceText "Making reports for all units to help higher management in decision making. Prepare combined financial statements of a parent company and its all subsidiaries (separate legal entities controlled by a parent company) showing assets, liabilities, equity, income, expenses and cash flows, and also going through periodic reports which shows the actual and estimated costs and their variances." ;
    rdfs:label "Perform consolidated reporting/review of cost management reports" ;
    skos:definition "An Act of Reporting that prepares consolidated management reports combining all units' results and reviewing actual-versus-estimated cost variances." ;
    rdfs:comment "Variance analysis is a typical reviewed input; recorded as commentary rather than a definitional restriction." ;
    skos:example "Reviewing group cost variances alongside the consolidated results." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConsolidatedFinancialStatement ] .

ex:P10841 a owl:Class ;
    ex:pcfID "10841" ; ex:hierarchyID "9.3.4.5" ;
    ex:apqcSourceText "Preparing a draft of financial statements for the board to review before they are sent to the auditor." ;
    rdfs:label "Prepare statements for board review" ;
    skos:definition "An Act of Reporting that prepares a draft of the financial statements for board review prior to audit." ;
    skos:example "Circulating draft annual statements to the audit committee." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialStatement ] .

ex:P10842 a owl:Class ;
    ex:pcfID "10842" ; ex:hierarchyID "9.3.4.6" ;
    ex:apqcSourceText "Making and presenting financial reports to stakeholders. Create annual and quarterly financial statements for reporting purposes. Prepare shareholder reports with details of the profit-and-loss account, balance sheet, and past year's business activities." ;
    rdfs:label "Produce quarterly/annual filings and shareholder reports" ;
    skos:definition "An Act of Reporting that produces quarterly and annual financial filings and shareholder reports and presents them to stakeholders." ;
    skos:example "Publishing the annual report and 10-K filing." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] .

ex:P10843 a owl:Class ;
    ex:pcfID "10843" ; ex:hierarchyID "9.3.4.7" ;
    ex:apqcSourceText "Reporting raw or summary data for final accounts following rules and regulations." ;
    rdfs:label "Produce regulatory reports" ;
    skos:definition "An Act of Reporting that compiles final-account data in accordance with rules and regulations to produce a regulatory filing." ;
    skos:example "Filing statutory accounts with the securities regulator." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryFiling ] .

ex:P14074 a owl:Class ;
    ex:pcfID "14074" ; ex:hierarchyID "9.3.4.8" ;
    ex:apqcSourceText "Carrying out activities associated with legal and management consolidation. Legal consolidation can include currency conversion, balance carry forward, and consolidation of journal entries. Management consolidation can include reporting on financials on a reporting cycle basis to gauge the performance of the organization." ;
    rdfs:label "Perform legal and management consolidation" ;
    skos:definition "An Act of Accounting that performs legal and management consolidation - currency conversion, balance carry-forward, and journal-entry consolidation - to produce consolidated financial statements." ;
    rdfs:comment "Genus Act of Accounting (not Reporting): the act combines and converts ledger data rather than merely conveying it; its output feeds the reporting acts of 9.3.4." ;
    skos:example "Consolidating foreign-subsidiary ledgers into the group reporting currency." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConsolidatedFinancialStatement ] .

# ================== group 9.4 ==================
# Manage fixed-asset project accounting
# 9.4 (PCF 10731) is a standing function -> ex:FixedAssetProjectAccountingCapability (in 2g).

ex:P10751 a owl:Class ;
    ex:pcfID "10751" ;
    ex:hierarchyID "9.4.1" ;
    ex:apqcSourceText "Preparing a project finance report to solicit approvals in capital projects. Prepare budgets for projects that require heavy investments. Report on project finances to solicit approvals from management." ;
    rdfs:label "Perform capital planning and project approval" ;
    skos:definition "An Act of Reporting that compiles a project finance report on a capital project in order to solicit management approvals, and that has as process parts the development of capital-investment policies, expenditure plans and budgets, project review and approval, and financial justification." ;
    rdfs:comment "Models APQC process 9.4.1 as a bounded occurrent. Its APQC dotted children are process parts (cco:ont00001777), not subclasses. Budget input/output handled by its child P10845; only the report output is asserted as definitional here." ;
    skos:example "A finance team assembles a capital-project finance report and budget package and submits it to the investment committee for approval." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10844 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10845 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10846 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10847 ] .

ex:P10844 a owl:Class ;
    ex:pcfID "10844" ;
    ex:hierarchyID "9.4.1.1" ;
    ex:apqcSourceText "Creating procedures and policies to follow for investing in capital projects. Create rules and regulations regarding large investment plans, which require in-depth forecasting for expenditure and revenue." ;
    rdfs:label "Develop capital investment policies and procedures" ;
    skos:definition "An Act of Formulation that composes the financial policies and procedures governing investment in capital projects." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (inlined) because creating policies/procedures composes Directive ICEs (Golden Principle: Formulation -> Directive)." ;
    skos:example "Treasury drafts the corporate capital-investment policy and the accompanying approval procedure." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] .

ex:P10845 a owl:Class ;
    ex:pcfID "10845" ;
    ex:hierarchyID "9.4.1.2" ;
    ex:apqcSourceText "Creating budgets, and soliciting approvals for capital projects. Prepare budgets for projects that require heavy investments. Secure approvals from management." ;
    rdfs:label "Develop and approve capital expenditure plans and budgets" ;
    skos:definition "An Act of Formulation that prepares a capital-expenditure plan and budget for a heavy-investment project and secures management approval of it." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: developing a budget composes a Directive ICE. The 'approve' facet ratifies the same budget and does not introduce a separate candidate set, so no separate selection act is modeled." ;
    skos:example "A project manager builds a multi-year capital-expenditure budget and obtains sign-off from the board." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:Budget ] .

ex:P10846 a owl:Class ;
    ex:pcfID "10846" ;
    ex:hierarchyID "9.4.1.3" ;
    ex:apqcSourceText "Evaluating and supporting capital investments in projects and fixed assets. Confirm details of capital projects. Secure approvals from managements for large investments." ;
    rdfs:label "Review and approve capital projects and fixed-asset acquisitions" ;
    skos:definition "An Act of Selection that reviews proposed capital projects and fixed-asset acquisitions and authorizes which are to proceed, producing a project approval decision." ;
    rdfs:comment "Re-anchored from cco:ont00000636 (Act of Appraisal) to ex:ActOfSelection to satisfy the GOLDEN PRINCIPLE: the sole asserted output is ex:ProjectApprovalDecision, a Directive ICE (cco:ont00000965), whereas an Act of Appraisal characteristically yields a DESCRIPTIVE judgement ('judges without committing', per apqc-ext). The act fuses a review/evaluate facet with an authorize/approve facet; the definitional product is the authorization (a go/no-go choice among the proposed investments), which is exactly what ex:ActOfSelection was minted for ('chooses ... and produces a Directive Information Content Entity that prescribes the chosen option(s)'). REJECTED candidate cco:ont00000636 (Act of Appraisal): retained for the evaluative facet only would force a Descriptive output and split the act; here the directive approval is definitional, so Selection is the correct genus. Aligned with sibling ex:P10851 (also a go/no-go decision -> ex:ActOfSelection)." ;
    skos:example "An investment committee reviews a capital project's details and approves the acquisition of the related fixed assets." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectApprovalDecision ] .

ex:P10847 a owl:Class ;
    ex:pcfID "10847" ;
    ex:hierarchyID "9.4.1.4" ;
    ex:apqcSourceText "Reviewing all project business cases in order to substantiate projected financial gains. Validate any project's business case. Juxtapose the benefits derived from moving a project forward against the associated costs." ;
    rdfs:label "Conduct financial justification for project approval" ;
    skos:definition "An Act of Appraisal that juxtaposes the projected benefits of a capital project against its costs and produces a financial justification substantiating the project's expected financial gains." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it evaluates a business case's value. Output ex:FinancialJustification is a Descriptive ICE (it represents an argument, it does not prescribe). Cost data is a typical input, recorded as comment not restriction (Phase-3)." ;
    skos:example "An analyst validates a project's business case and documents a cost-benefit justification recommending approval." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialJustification ] .

ex:P10752 a owl:Class ;
    ex:pcfID "10752" ;
    ex:hierarchyID "9.4.2" ;
    ex:apqcSourceText "Accounting for large-scale and large-cost investments. Manage and account for ongoing activities related to capital projects, including setting up new projects, recording project transactions, monitoring and tracking spending, closing and capitalizing projects, and measuring the financial returns on completed projects." ;
    rdfs:label "Perform capital project accounting" ;
    skos:definition "An Act of Accounting that records and maintains the financial Information Content Entities of capital projects across their lifecycle, and that has as process parts project account-code creation, transaction recording, spending monitoring, project capitalization, and return measurement." ;
    rdfs:comment "Models APQC process 9.4.2 as a bounded occurrent. Its APQC dotted children are process parts (cco:ont00001777), not subclasses." ;
    skos:example "An accounting team sets up a new capital project, books its transactions, tracks spend against budget, capitalizes it on completion, and measures its return." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10848 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10849 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10850 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10851 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10852 ] .

ex:P10848 a owl:Class ;
    ex:pcfID "10848" ;
    ex:hierarchyID "9.4.2.1" ;
    ex:apqcSourceText "Giving reference codes for every project." ;
    rdfs:label "Create project account codes" ;
    skos:definition "An Act of Accounting that assigns a reference account code to each capital project so that its transactions can be classified and tracked." ;
    rdfs:comment "Anchored to ex:ActOfAccounting (creating classification codes within a system of accounts). Output ex:ProjectAccountCode is a Descriptive ICE; ex:ChartOfAccounts (the master structure) was rejected as too broad for a single per-project code." ;
    skos:example "The ledger administrator opens a new project and issues it a unique cost-collection account code." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectAccountCode ] .

ex:P10849 a owl:Class ;
    ex:pcfID "10849" ;
    ex:hierarchyID "9.4.2.2" ;
    ex:apqcSourceText "Noting every transaction during a project in a common financial database. Document all transactions associated with any project. Maintain a centralized repository of all such financial data." ;
    rdfs:label "Record project-related transactions" ;
    skos:definition "An Act of Accounting that documents every financial transaction associated with a capital project into a centralized repository, producing the project's transaction records." ;
    rdfs:comment "Anchored to ex:ActOfAccounting. Output ex:TransactionRecord is a Descriptive ICE." ;
    skos:example "A clerk posts each invoice and payment for a construction project to the shared project ledger." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10850 a owl:Class ;
    ex:pcfID "10850" ;
    ex:hierarchyID "9.4.2.3" ;
    ex:apqcSourceText "Evaluating project progress and funds invested. Observe and track significant funds invested on any long-term project. Compare to budget." ;
    rdfs:label "Monitor and track capital projects and budget spending" ;
    skos:definition "An Act of Monitoring that observes the funds invested in a capital project, compares actual spending against its budget, and produces a variance analysis." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring. The Budget is definitional (the comparison reference), so it is asserted as an input restriction; cost data is a typical input recorded in comment only (Phase-3)." ;
    skos:example "A controller tracks a project's cumulative spend against its approved budget and reports the variance each month." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:Budget ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:VarianceAnalysis ] .

ex:P10851 a owl:Class ;
    ex:pcfID "10851" ;
    ex:hierarchyID "9.4.2.4" ;
    ex:apqcSourceText "Checking for returns generated from projects for decision making. Evaluate capital projects that require heavy investments. Decide whether to proceed based on the revenues generated." ;
    rdfs:label "Close/capitalize projects" ;
    skos:definition "An Act of Selection that evaluates the returns generated by a capital project and decides whether to proceed with it, producing a project continuation decision." ;
    rdfs:comment "Re-anchored from ex:ActOfAccounting to ex:ActOfSelection (D2 / Phase-1 fix). The verbatim apqcSourceText is an APPRAISAL-and-DECISION act: 'Checking for returns generated from projects for decision making. Evaluate capital projects ... Decide whether to proceed based on the revenues generated.' It never mentions closing or capitalizing onto the fixed-asset register; the previous 'close/capitalize' genus and ex:FixedAssetRegister output were supplied from the LABEL, discarding the row's evaluate+decide meaning. Per D2 the genus must come from the de-conflated description, which describes evaluation of returns plus a go/no-go decision -- the same act kind as its 9.4.2 siblings ex:P10846 (review+approve) and ex:P10852 (measure returns). GOLDEN PRINCIPLE + sibling consistency: the definitional product is a Directive go/no-go decision (ex:ProjectContinuationDecision), so the genus is ex:ActOfSelection (chooses among proceed/not-proceed, produces a Directive ICE), aligned with ex:P10846. REJECTED candidates: ex:ActOfAccounting (label-driven, asserts a bookkeeping capitalization the description does not describe) and cco:ont00000636 (Act of Appraisal) (would pair an Appraisal genus with a Directive decision output, breaking genus-output agreement -- see ex:P10846). ex:ProfitabilityAnalysis (returns data) is the Descriptive input baseline. If a genuine bookkeeping 'capitalize onto fixed-asset register' facet is intended, it should be split into a separate Act of Accounting child rather than overwriting this PCF row's evaluative meaning." ;
    skos:example "On reviewing a project's realized returns, the committee decides to continue (or halt) the investment." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProfitabilityAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectContinuationDecision ] .

ex:P10852 a owl:Class ;
    ex:pcfID "10852" ;
    ex:hierarchyID "9.4.2.5" ;
    ex:apqcSourceText "Comparing a finished project's profitability with forecasted returns. Scrutinize revenues generated by completed projects that required heavy investments. Determine profitability." ;
    rdfs:label "Measure financial returns on completed capital projects" ;
    skos:definition "An Act of Appraisal that compares a completed capital project's actual returns against its forecasted returns and produces a profitability analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it measures/judges the project's return. The financial forecast is definitional (the comparison baseline), asserted as an input restriction; output ex:ProfitabilityAnalysis is a Descriptive ICE." ;
    skos:example "A finance analyst measures a finished plant project's realized IRR against the forecast and reports its profitability." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProfitabilityAnalysis ] .

# ================== group 9.5 ==================
# Process payroll
# 9.5.3.2 'Manage tax plan' (PCF 14076) modeled as realization of the
# reused ex:TaxManagementCapability (see realized-in axiom below); no ex:P14076.

ex:TaxManagementCapability rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;   # realized in
      owl:someValuesFrom ex:P10866 ] .

ex:P10732 a owl:Class ;
    ex:pcfID "10732" ;
    ex:hierarchyID "9.5" ;
    ex:apqcSourceText "Handling reporting time, managing pay, and processing taxes from salaries. Pay employees. Withhold taxes. Confirm the correct funds are paid to the correct government agency." ;
    rdfs:label "Process payroll" ;
    skos:definition "An Act of Financial Transaction that disburses pay to an organization's employees by reporting their time, managing their pay, and processing their payroll taxes, producing monetary payments to employees and to tax authorities." ;
    rdfs:comment "Models APQC group 9.5 as a bounded payroll-run occurrent. Its three APQC children are process parts, not subclasses. The disbursed monetary payment is a MATERIAL participant (obo:BFO_0000057, not has output: cco:ont00001986 has output is reserved for ICE outputs); time records and tax filings are produced by its parts." ;
    skos:example "A company's biweekly payroll cycle that pays employees and remits withheld taxes." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10753 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10754 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10755 ] .

ex:P10753 a owl:Class ;
    ex:pcfID "10753" ;
    ex:hierarchyID "9.5.1" ;
    ex:apqcSourceText "Recording the reporting time of employees on-site. Track working days, salary calculations, holidays taken, number of hours spend in the office, billing hours, etc." ;
    rdfs:label "Report time" ;
    skos:definition "An Act of Information Processing that records the working time of employees and produces an employee time record." ;
    rdfs:comment "Bounded information-processing act; its five APQC activities are process parts." ;
    skos:example "Capturing every employee's daily hours, billable time, and leave into a time record." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TimeRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10853 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10854 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10855 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10856 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10857 ] .

ex:P10853 a owl:Class ;
    ex:pcfID "10853" ;
    ex:hierarchyID "9.5.1.1" ;
    ex:apqcSourceText "Developing policies and procedures for the HR function to calculate compensation." ;
    rdfs:label "Establish policies and procedures" ;
    skos:definition "An Act of Formulation that composes a financial procedure prescribing how compensation is to be calculated." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (output is a Directive ICE) per the GOLDEN PRINCIPLE: developing policies/procedures produces a prescription, not a description." ;
    skos:example "HR drafts the standard operating procedure for computing employee compensation." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] .

ex:P10854 a owl:Class ;
    ex:pcfID "10854" ;
    ex:hierarchyID "9.5.1.2" ;
    ex:apqcSourceText "Tracking billing hours of each employee on daily basis." ;
    rdfs:label "Collect and record employee time worked" ;
    skos:definition "An Act of Information Processing that collects the daily hours worked by each employee and produces an employee time record." ;
    skos:example "Recording every employee's clock-in and billable hours each day." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TimeRecord ] .

ex:P10855 a owl:Class ;
    ex:pcfID "10855" ;
    ex:hierarchyID "9.5.1.3" ;
    ex:apqcSourceText "Tracking leaves allowed and taken by employees." ;
    rdfs:label "Analyze and report paid and unpaid leave" ;
    skos:definition "An Act of Analysis that has as input employee time records and produces a leave report describing the paid and unpaid leave allowed to and taken by employees." ;
    skos:example "Producing a monthly leave-balance report from recorded time data." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TimeRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LeaveRecord ] .

ex:P10856 a owl:Class ;
    ex:pcfID "10856" ;
    ex:hierarchyID "9.5.1.4" ;
    ex:apqcSourceText "Observing the number of hours worked by an employees on daily basis. Track the number of hours worked by an employee, as well as the number of hours worked beyond normal working hour's according to company standards." ;
    rdfs:label "Monitor regular, overtime, and other hours" ;
    skos:definition "An Act of Monitoring that tracks the regular, overtime, and other hours worked by employees and produces an employee time record registering them." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring: ongoing daily observation of hours against company standards, output is a descriptive record." ;
    skos:example "Daily tracking of overtime hours against the standard work week." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TimeRecord ] .

ex:P10857 a owl:Class ;
    ex:pcfID "10857" ;
    ex:hierarchyID "9.5.1.5" ;
    ex:apqcSourceText "Monitoring the number of productive hours for employees." ;
    rdfs:label "Analyze and report employee utilization" ;
    skos:definition "An Act of Analysis that has as input employee time records and produces an employee utilization report describing employees' productive hours." ;
    skos:example "Computing and reporting each employee's billable-utilization ratio." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TimeRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeUtilizationReport ] .

ex:P10754 a owl:Class ;
    ex:pcfID "10754" ;
    ex:hierarchyID "9.5.2" ;
    ex:apqcSourceText "Managing the total payments made in employees payroll, including bonuses and compensation." ;
    rdfs:label "Manage pay" ;
    skos:definition "An Act of Financial Transaction that computes and disburses the total pay owed to employees, including bonuses and compensation, producing monetary payments to employees." ;
    rdfs:comment "Despite the 'Manage' label this denotes the bounded pay-disbursement run; its eight APQC activities are process parts. The disbursed monetary payment is a MATERIAL participant (obo:BFO_0000057), not has output." ;
    skos:example "Running a pay cycle that calculates and pays each employee's net salary and bonuses." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10858 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10859 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10860 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10861 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10862 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10863 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10864 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10865 ] .

ex:P10858 a owl:Class ;
    ex:pcfID "10858" ;
    ex:hierarchyID "9.5.2.1" ;
    ex:apqcSourceText "Tracking the number of hours worked for the payroll system. Register the number of hours worked by an employee into the payroll system for the purpose of calculating salaries or wages." ;
    rdfs:label "Enter employee time worked into payroll system" ;
    skos:definition "An Act of Information Processing that has as input an employee time record and registers the hours worked into the payroll system as a transaction record for salary calculation." ;
    skos:example "Importing approved timesheet hours into the payroll engine before a pay run." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TimeRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10859 a owl:Class ;
    ex:pcfID "10859" ;
    ex:hierarchyID "9.5.2.2" ;
    ex:apqcSourceText "Tracking and oversee salary breakups of employees. This process requires the organization to manage and update information pertaining to the structure of every employee's salary. This would involve the updating any changes to the salary structures of the employees, in a central repository which can be accessed by pertinent departments." ;
    rdfs:label "Maintain and administer employee earnings information" ;
    skos:definition "An Act of Accounting that maintains and updates the employee earnings information held in a central repository, producing an updated employee-earnings record." ;
    rdfs:comment "Re-anchored from ex:ActOfMonitoring to ex:ActOfAccounting (false-friend fix). The source text ('manage and update information pertaining to the structure of every employee's salary ... updating any changes ... in a central repository') describes record creation/maintenance, not observation. ex:ActOfMonitoring is defined as observing an ongoing process/position over time AGAINST EXPECTED PARAMETERS; maintaining a salary-structure repository involves no comparison against expected parameters and is not status observation -- it is records upkeep, which ex:ActOfAccounting's scope ('produces or UPDATES a Descriptive ICE ... maintain ledgers/master files') covers. The Descriptive output (ex:EarningsInformation) and R5 hold; only the act genus changes. Anchored identically to its 'Maintain and administer' twin ex:P10860." ;
    skos:example "Updating an employee's salary-structure record after a raise." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EarningsInformation ] .

ex:P10860 a owl:Class ;
    ex:pcfID "10860" ;
    ex:hierarchyID "9.5.2.3" ;
    ex:apqcSourceText "Processing salary deductions for tax purposes. Keep and manage the details of every employee's salary deductions based on their expenses and investments during the year." ;
    rdfs:label "Maintain and administer applicable deductions" ;
    skos:definition "An Act of Accounting that keeps current the details of each employee's salary deductions and produces a payroll deduction record." ;
    rdfs:comment "Re-anchored from ex:ActOfMonitoring to ex:ActOfAccounting (same false-friend fix as its twin ex:P10859). The source verb is literally 'Processing'/'Keep and manage' ('Processing salary deductions for tax purposes. Keep and manage the details of every employee's salary deductions ...'), i.e. maintaining deduction records, not observing a position against expected parameters (the ex:ActOfMonitoring differentia). Records upkeep falls under ex:ActOfAccounting ('produces or UPDATES a Descriptive ICE ... maintain ledgers/master files'). Output ex:PayrollDeductionRecord (Descriptive) and R5 are unchanged. Anchored identically to ex:P10859 so the 'Maintain and administer' pair is consistent." ;
    skos:example "Recording an employee's updated investment declarations to adjust deductions." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PayrollDeductionRecord ] .

ex:P10861 a owl:Class ;
    ex:pcfID "10861" ;
    ex:hierarchyID "9.5.2.4" ;
    ex:apqcSourceText "Tracking changes in the salary structure of employees for tax deductions." ;
    rdfs:label "Monitor changes in tax status of employees" ;
    skos:definition "An Act of Monitoring that tracks changes in employees' tax status and produces updated tax data for payroll deduction." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring: ongoing tracking of tax-status changes; output is descriptive tax data." ;
    skos:example "Detecting an employee's change of tax bracket and flagging it for the next pay run." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxData ] .

ex:P10862 a owl:Class ;
    ex:pcfID "10862" ;
    ex:hierarchyID "9.5.2.5" ;
    ex:apqcSourceText "Processing and distributing salaries to all employees. Execute the payroll management function through the dispensation of employee salaries. Leverage a centralized database of all payroll expenses." ;
    rdfs:label "Process and distribute payments" ;
    skos:definition "An Act of Remuneration that disburses salaries to employees, producing a monetary payment to each employee in compensation for services performed." ;
    rdfs:comment "Re-anchored from ex:ActOfFinancialTransaction to ex:ActOfRemuneration (the verified CCO leaf cco:ont00000449): an unambiguous employer->employee salary disbursement -- the exact differentia of Remuneration. The disbursed payment is a MATERIAL participant (obo:BFO_0000057), not has output." ;
    skos:example "Paying every employee's net salary by direct deposit on payday." ;
    rdfs:subClassOf ex:ActOfRemuneration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10863 a owl:Class ;
    ex:pcfID "10863" ;
    ex:hierarchyID "9.5.2.6" ;
    ex:apqcSourceText "Handling incorrect/omitted salary payments." ;
    rdfs:label "Process and distribute manual checks" ;
    skos:definition "An Act of Financial Transaction that issues a manual payment to correct an incorrect or omitted salary payment, producing a monetary payment to the affected employee." ;
    rdfs:comment "The monetary payment is a MATERIAL participant (obo:BFO_0000057), not has output; the off-cycle manual check corrects a prior payroll error. Substantively an Act of Remuneration (cco:ont00000449) but kept under ex:ActOfFinancialTransaction: as an error-correction disbursement its differentia is rectifying an omission, one step removed from the canonical compensation-for-services run (cf. ex:P10862, which moves to ex:ActOfRemuneration)." ;
    skos:example "Cutting a manual check for an employee whose overtime was missed in the main run." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] .

ex:P10864 a owl:Class ;
    ex:pcfID "10864" ;
    ex:hierarchyID "9.5.2.7" ;
    ex:apqcSourceText "Adjusting salary deductions for tax purposes at the end of the year." ;
    rdfs:label "Process period-end adjustments" ;
    skos:definition "An Act of Accounting that reconciles and adjusts employees' salary deductions at the close of a tax period and produces a payroll period-end adjustment record." ;
    rdfs:comment "Anchored to ex:ActOfAccounting: reconciling/adjusting financial records; output is a descriptive ICE." ;
    skos:example "Recomputing year-end tax deductions and posting the correcting adjustments." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PayrollDeductionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PeriodEndAdjustmentRecord ] .

ex:P10865 a owl:Class ;
    ex:pcfID "10865" ;
    ex:hierarchyID "9.5.2.8" ;
    ex:apqcSourceText "Addressing salary-related queries raised by employees." ;
    rdfs:label "Respond to employee payroll inquiries" ;
    skos:definition "An Act of Information Processing that addresses an employee's salary-related query and produces a payroll inquiry response." ;
    skos:example "Answering an employee's question about why a deduction changed this month." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PayrollInquiryResponse ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10755 a owl:Class ;
    ex:pcfID "10755" ;
    ex:hierarchyID "9.5.3" ;
    ex:apqcSourceText "Deducting and paying taxes from employees' salaries." ;
    rdfs:label "Manage and process payroll taxes" ;
    skos:definition "An Act of Financial Transaction that deducts payroll taxes from employees' salaries and remits them to the appropriate tax authority, producing a monetary payment of tax." ;
    rdfs:comment "Bounded payroll-tax process; its modeled APQC children are process parts. 9.5.3.2 'Manage tax plan' is excluded as a process (standing oversight = capability, R6). The tax remittance is a MATERIAL participant Monetary Payment (obo:BFO_0000057), not has output." ;
    skos:example "Withholding income tax from salaries and paying it to the revenue authority." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14075 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10866 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10867 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10868 ] .

ex:P14075 a owl:Class ;
    ex:pcfID "14075" ;
    ex:hierarchyID "9.5.3.1" ;
    ex:apqcSourceText "Devising a method to minimize payroll tax liability by means of allowances, deductions, exclusions or exemptions." ;
    rdfs:label "Develop tax plan" ;
    skos:definition "An Act of Formulation that devises a tax strategy prescribing how to minimize payroll-tax liability through allowances, deductions, exclusions, or exemptions." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (output is a Directive ICE) per the GOLDEN PRINCIPLE: devising a method/plan produces a prescription." ;
    skos:example "Designing a withholding strategy that lawfully reduces the firm's payroll-tax burden." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxStrategy ] .

ex:P10866 a owl:Class ;
    ex:pcfID "10866" ;
    ex:hierarchyID "9.5.3.3" ;
    ex:apqcSourceText "Paying tax according to appropriate deductions made from salaries. Calculate and pay the tax liabilities according to the salaries and tax regulations of employees with the help of certified chartered accountants." ;
    rdfs:label "Calculate and pay applicable payroll taxes" ;
    skos:definition "An Act of Financial Transaction that calculates the payroll-tax liability owed on employees' salaries and pays it to the tax authority, producing a monetary payment of tax." ;
    rdfs:comment "The remitted Monetary Payment is a MATERIAL participant (obo:BFO_0000057), not has output; calculation per tax regulations is a sub-step. Certified accountants typically participate (rdfs:comment, not definitional)." ;
    skos:example "Computing and remitting withheld income tax for the period to the revenue authority." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TaxData ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] .

ex:P10867 a owl:Class ;
    ex:pcfID "10867" ;
    ex:hierarchyID "9.5.3.4" ;
    ex:apqcSourceText "Providing tax deductions statements created by certified chartered accountants to every employee for their reference or refunds." ;
    rdfs:label "Produce and distribute employee annual tax statements" ;
    skos:definition "An Act of Reporting that compiles and issues an employee annual tax statement describing the tax withheld from each employee's salary." ;
    rdfs:comment "Anchored to ex:ActOfReporting: compiling and issuing a statement; output is a descriptive ICE delivered to employees." ;
    skos:example "Issuing each employee a year-end statement of wages and taxes withheld." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeTaxStatement ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10868 a owl:Class ;
    ex:pcfID "10868" ;
    ex:hierarchyID "9.5.3.5" ;
    ex:apqcSourceText "Filling taxes, and highlighting different sources of income and expenditures made." ;
    rdfs:label "File regulatory payroll tax forms" ;
    skos:definition "An Act of Reporting that compiles and submits the required payroll-tax forms to a regulatory authority, producing a regulatory filing." ;
    rdfs:comment "Anchored to ex:ActOfReporting: compiling and issuing a filing to an authority; output is a descriptive ICE (regulatory filing)." ;
    skos:example "Submitting the quarterly payroll-tax return to the revenue authority." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryFiling ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryAuthority ] .

# ================== group 9.6 ==================
# Process accounts payable and expense reimbursements

ex:P10733 a owl:Class ;
    ex:pcfID "10733" ; ex:hierarchyID "9.6" ;
    ex:apqcSourceText "Handling bills and reimbursements to be made. Make payments for goods or services taken or used on behalf of the organization." ;
    rdfs:label "Process accounts payable and expense reimbursements" ;
    skos:definition "An Act of Financial Transaction that handles bills and reimbursements owed by an organization and disburses payment for goods or services taken or used on its behalf." ;
    rdfs:comment "Models APQC process group 9.6 as a bounded occurrent (the organization's payables-and-reimbursement payment cycle); its APQC children are process parts, not subclasses." ;
    skos:example "A finance team's monthly run that settles supplier invoices, employee reimbursements, and corporate-card balances." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10756 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10757 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20929 ] .

ex:P10756 a owl:Class ;
    ex:pcfID "10756" ; ex:hierarchyID "9.6.1" ;
    ex:apqcSourceText "Processing payments of operating expenses and other supplier charges. This includes the development of policies and procedures around processing of accounts payable and all operations. This process is often supported by key technology enablers." ;
    rdfs:label "Process accounts payable (AP)" ;
    skos:definition "An Act of Financial Transaction that processes payment of operating expenses and other supplier charges through an organization's accounts-payable operations." ;
    rdfs:comment "APQC 9.6.1 as an occurrent; its activities are process parts. Policy/procedure development is a typical adjunct, noted not as a definitional restriction here." ;
    skos:example "An AP department settling a batch of approved supplier invoices." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10869 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10870 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10871 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10872 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10873 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10874 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10875 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10876 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10877 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10878 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10879 ] .

ex:P10869 a owl:Class ;
    ex:pcfID "10869" ; ex:hierarchyID "9.6.1.1" ;
    ex:apqcSourceText "Matching records of bills to be paid with accounts. Check accounts payable entries with vendor's account for every payment made." ;
    rdfs:label "Verify AP pay file with purchase order vendor master file" ;
    skos:definition "An Act of Appraisal that checks accounts-payable pay-file entries against the vendor master file and produces a payment match result." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges an entry against a reference record, yielding a descriptive match judgement (GOLDEN PRINCIPLE)." ;
    skos:example "An AP clerk three-way-matching an invoice to the PO and vendor master before release." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:VendorMasterFile ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PaymentMatchResult ] .

ex:P10870 a owl:Class ;
    ex:pcfID "10870" ; ex:hierarchyID "9.6.1.2" ;
    ex:apqcSourceText "Tracking all online transactions." ;
    rdfs:label "Maintain/Manage electronic commerce" ;
    skos:definition "An Act of Monitoring that tracks an organization's online accounts-payable transactions and produces a record of their status." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (cco:ont00000366): the source ('Tracking all online transactions') is longitudinal observation of a transaction stream, not a one-shot analysis. The status output is descriptive (TransactionRecord)." ;
    skos:example "An e-commerce settlement console tracking the day's online supplier payments." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10871 a owl:Class ;
    ex:pcfID "10871" ; ex:hierarchyID "9.6.1.3" ;
    ex:apqcSourceText "Monitoring and evaluating bills registered in accounts books. Check all invoices. Maintain records." ;
    rdfs:label "Audit invoices and key data in AP system" ;
    skos:definition "An Act of Appraisal that evaluates invoices and key data registered in the accounts-payable system and produces an invoice audit judgement." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): auditing/evaluating registered bills judges them against records and yields a descriptive finding. Invoice is a typical input (commented, not definitional)." ;
    skos:example "An AP auditor reviewing posted invoices for accuracy and policy compliance." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:Invoice ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AuditJudgement ] .

ex:P10872 a owl:Class ;
    ex:pcfID "10872" ; ex:hierarchyID "9.6.1.4" ;
    ex:apqcSourceText "Processing payments for products/services." ;
    rdfs:label "Approve payments" ;
    skos:definition "A Planned Act that authorizes a settled payment for products or services and produces a payment approval decision." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act) -- the §6-documented TOP intentional-act anchor -- because the act is an AUTHORIZATION/RATIFICATION of a single already-settled payment, for which CCO 2.0 has no dedicated act kind. REJECTED candidates (D5/§6 step 3): (1) cco:ont00000636 'Act of Appraisal' -- an Appraisal characteristically yields a DESCRIPTIVE judgement ('judges without committing'), but the definitional product here is the Directive ex:PaymentApproval (an authorization that prescribes release), so re-anchoring to Appraisal would break the GOLDEN-PRINCIPLE genus-output agreement; the act commits rather than merely judges. (2) ex:ActOfSelection -- there is no candidate set; approval ratifies one already-settled payment, and the apqc-ext ActOfSelection note explicitly routes 'ratifying a single already-settled option' to cco:ont00000228. The bare Planned Act is therefore the nearest correct class whose genus does not contradict the Directive output. Anchored identically to its 9.6 approval siblings ex:P10882 and ex:P20934 (sibling consistency)." ;
    skos:example "A controller approving a vetted supplier payment for release." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PaymentApproval ] .

ex:P10873 a owl:Class ;
    ex:pcfID "10873" ; ex:hierarchyID "9.6.1.5" ;
    ex:apqcSourceText "Handling transactions for accruals and reversals. Record transactions in the books of accounts on an accrual basis (irrespective of the actual cash flow) and reversals basis (cancel out the adjusting entries) for balancing accounts." ;
    rdfs:label "Process financial accruals and reversals" ;
    skos:definition "An Act of Accounting that records accrual and reversal entries in the books of accounts and produces the corresponding transaction records." ;
    rdfs:comment "Anchored to ex:ActOfAccounting (cco:ont00000366): bookkeeping entries are recorded into a descriptive ledger artifact." ;
    skos:example "Month-end posting of accrued expenses and the reversal of the prior period's adjusting entries." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10874 a owl:Class ;
    ex:pcfID "10874" ; ex:hierarchyID "9.6.1.6" ;
    ex:apqcSourceText "Filing the amount of taxes that a company owes as of the balance sheet date. Prepare tax returns, including the income tax filing for an individual or business entity from earnings." ;
    rdfs:label "Process payables taxes" ;
    skos:definition "An Act of Reporting that prepares and files the payables taxes owed by an organization and produces a tax return." ;
    rdfs:comment "Anchored to ex:ActOfReporting (cco:ont00000366): tax data is compiled into a return (Descriptive ICE) for submission." ;
    skos:example "Preparing and filing withholding/income tax returns tied to payables as of the balance-sheet date." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxReturn ] .

ex:P10875 a owl:Class ;
    ex:pcfID "10875" ; ex:hierarchyID "9.6.1.7" ;
    ex:apqcSourceText "Resolving any atypical or inconsistent situation concerning payments to be made by the organization. Address any exceptional case of accounts payable on an ad hoc basis, by seeking counsel or carrying out any necessary research." ;
    rdfs:label "Research/Resolve payable exceptions" ;
    skos:definition "An Act of Information Processing that investigates an atypical or inconsistent accounts-payable situation and produces a payable exception resolution record." ;
    rdfs:comment "Anchored directly to cco:ont00000366 (Act of Information Processing): ad hoc research/resolution of a payable anomaly producing a descriptive disposition record." ;
    skos:example "An AP analyst researching a duplicate-payment exception and recording its resolution." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExceptionResolutionRecord ] .

ex:P10876 a owl:Class ;
    ex:pcfID "10876" ; ex:hierarchyID "9.6.1.8" ;
    ex:apqcSourceText "Making payments for products/services on due dates (payment cycle) decided by parties involved." ;
    rdfs:label "Process payments" ;
    skos:definition "An Act of Financial Transaction that disburses monetary payment for products or services on the due dates of an agreed payment cycle." ;
    rdfs:comment "Anchored to ex:ActOfFinancialTransaction (cco:ont00000228). The disbursed monetary payment is a MATERIAL participant (obo:BFO_0000057), not has output (operations material-I/O rule). The supplier is a definitional participant (it receives the payment)." ;
    skos:example "Releasing a scheduled ACH run to suppliers on invoice due dates." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Supplier ] .

ex:P10877 a owl:Class ;
    ex:pcfID "10877" ; ex:hierarchyID "9.6.1.9" ;
    ex:apqcSourceText "Clarifying or address queries relating to the particulars of AP such as date, discounts, amount, and installments. Coordinate with concerned parties about the fulfillment of bills payable." ;
    rdfs:label "Respond to AP inquiries" ;
    skos:definition "An Act of Communication that clarifies queries about accounts-payable particulars and transfers the clarifying information to the inquiring party." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication, a Planned Act in which an ICE is transferred from one Agent to another). The transferred clarification is descriptive; the supplier is the definitional recipient/participant. Explicit rdfs:subClassOf cco:ont00000228 (Planned Act) added so the act-anchor chain is visible to the standalone SHACL run (ont00000402 is a CCO subclass of ont00000228, but the closure is not merged for Gate C). VERIFICATION (D6/§6): cco:ont00000402 verified against the pinned CCO v2.0 (2024-11-06) closure -- rdfs:label 'Act of Communication'@en, skos:definition 'A Planned Act in which some Information Content Entity is transferred from some Agent to Another', rdfs:subClassOf cco:ont00000228 (Planned Act). This is the correct verified communication class and is NOT the §6 false-friend reject cco:ont00001261 'Act of Identifying' (an Act of Representative Communication for discernment); ont00000402 genuinely denotes agent-to-agent ICE transfer, the act kind required for an inquiry response. It should be added to the §6 verified-core-terms table as the canonical Act-of-Communication anchor used corpus-wide (transmit-only nodes)." ;
    skos:example "AP staff answering a supplier's query about a payment date and discount taken." ;
    rdfs:subClassOf cco:ont00000402 ,
        cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Supplier ] .

ex:P10878 a owl:Class ;
    ex:pcfID "10878" ; ex:hierarchyID "9.6.1.10" ;
    ex:apqcSourceText "Keeping bills of every transaction for future reference." ;
    rdfs:label "Retain records" ;
    skos:definition "An Act of Information Processing that preserves the bills and transaction records of every accounts-payable transaction for future reference." ;
    rdfs:comment "Re-anchored from ex:ActOfAccounting to cco:ont00000366 (Act of Information Processing) directly, and the I/O direction corrected. Two defects fixed: (1) Genus stretch -- ex:ActOfAccounting is defined as recording, classifying, posting, or reconciling transactions; retaining/archiving bills 'for future reference' is records retention/storage, none of those verbs, so it is generic records-management information processing. (2) Wrong I/O direction -- 'has output some ex:TransactionRecord' was a semantic inversion: retention does not PRODUCE a transaction record; the record already exists and is being preserved, so it is an input/object, not an output generated at the end (contra cco:ont00001986's 'output present at end because the process made it'). The retained record is therefore modeled as has input." ;
    skos:example "Archiving paid invoices and remittance advices to the records repository." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10879 a owl:Class ;
    ex:pcfID "10879" ; ex:hierarchyID "9.6.1.11" ;
    ex:apqcSourceText "Rectifying for alterations occurred in accounts while recording." ;
    rdfs:label "Adjust accounting records" ;
    skos:definition "An Act of Accounting that rectifies alterations that occurred while recording in the accounts and produces corrected transaction records." ;
    rdfs:comment "Anchored to ex:ActOfAccounting (cco:ont00000366): correcting bookkeeping entries updates a descriptive record." ;
    skos:example "Posting correcting journal entries for a mis-keyed invoice amount." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10757 a owl:Class ;
    ex:pcfID "10757" ; ex:hierarchyID "9.6.2" ;
    ex:apqcSourceText "Processing reimbursements to employees for the expenses incurred during the course of business. Approve and process advancements and reimbursements for employee expenses on the organization's behalf. Capture and report relevant tax data and manage personal accounts." ;
    rdfs:label "Process expense reimbursements" ;
    skos:definition "An Act of Financial Transaction that processes reimbursements and advances to employees for expenses incurred during the course of business on the organization's behalf." ;
    rdfs:comment "APQC 9.6.2 as an occurrent; its activities are process parts. The employee is a definitional participant (the reimbursed party)." ;
    skos:example "Settling an employee's approved travel-expense claim." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10880 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10881 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10882 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10883 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10884 ] .

ex:P10880 a owl:Class ;
    ex:pcfID "10880" ; ex:hierarchyID "9.6.2.1" ;
    ex:apqcSourceText "Explaining policies and procedures related to reimbursements requests by employees. Set policies regarding reimbursement process and amount limits etc. Inform employees." ;
    rdfs:label "Establish and communicate expense reimbursement policies and approval limits" ;
    skos:definition "An Act of Formulation that sets the policies and approval limits governing employee expense reimbursements and produces a financial policy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (inlined; cco:ont00000511): setting reimbursement policy and limits composes a Directive ICE (GOLDEN PRINCIPLE). Communicating it to employees is a typical downstream adjunct, not a separate definitional output." ;
    skos:example "Finance issuing an updated travel-and-expense policy with per-diem caps." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialPolicy ] .

ex:P10881 a owl:Class ;
    ex:pcfID "10881" ; ex:hierarchyID "9.6.2.2" ;
    ex:apqcSourceText "Collecting and reporting all pertinent information regarding the taxes paid by the organization's employees." ;
    rdfs:label "Capture and report relevant tax data" ;
    skos:definition "An Act of Reporting that collects and reports the tax information pertinent to taxes paid by an organization's employees and produces tax data." ;
    rdfs:comment "Anchored to ex:ActOfReporting (cco:ont00000366): pertinent information is compiled into a descriptive tax-data report." ;
    skos:example "Compiling employee per-diem and reimbursement amounts for payroll-tax reporting." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxData ] .

ex:P10882 a owl:Class ;
    ex:pcfID "10882" ; ex:hierarchyID "9.6.2.3" ;
    ex:apqcSourceText "Permitting expense reimbursement requests from employees." ;
    rdfs:label "Approve reimbursements and advances" ;
    skos:definition "A Planned Act that authorizes an employee's expense-reimbursement or advance request and produces a payment approval decision." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act) -- the §6 TOP intentional-act anchor -- as an AUTHORIZATION/RATIFICATION of a single already-settled request (no candidate set), for which CCO 2.0 has no dedicated act kind. REJECTED candidates (D5/§6 step 3), uniform with sibling ex:P10872: (1) cco:ont00000636 'Act of Appraisal' -- would pair an Appraisal genus (Descriptive judgement, 'judges without committing') with the Directive ex:PaymentApproval output, breaking GOLDEN-PRINCIPLE agreement; the act commits/authorizes rather than merely judging. (2) ex:ActOfSelection -- no candidate set; the apqc-ext ActOfSelection note routes 'ratifying a single already-settled option' to cco:ont00000228. The employee is the definitional participant whose request is approved. Anchored identically to ex:P10872 and ex:P20934 (sibling consistency)." ;
    skos:example "A manager approving an employee's travel-advance request." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PaymentApproval ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10883 a owl:Class ;
    ex:pcfID "10883" ; ex:hierarchyID "9.6.2.4" ;
    ex:apqcSourceText "Paying for expense reimbursement requests from employees. (Follow Approve reimbursements and advances [10882] according to policies and conditions.)" ;
    rdfs:label "Process reimbursements and advances" ;
    skos:definition "An Act of Financial Transaction that disburses monetary payment to employees in settlement of approved expense-reimbursement and advance requests." ;
    rdfs:comment "Anchored to ex:ActOfFinancialTransaction (cco:ont00000228). The disbursed monetary payment is a MATERIAL participant; the employee is the definitional recipient. The source cross-reference licenses bfo:precedes from 10882 (see precedence block)." ;
    skos:example "Paying an employee's approved expense claim by direct deposit." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PaymentApproval ] .

ex:P10884 a owl:Class ;
    ex:pcfID "10884" ; ex:hierarchyID "9.6.2.5" ;
    ex:apqcSourceText "Maintaining accounts of individuals who are connected with business." ;
    rdfs:label "Manage personnel accounts" ;
    skos:definition "An Act of Accounting that maintains the financial accounts of individuals connected with the business and produces updated account statements." ;
    rdfs:comment "R5: despite the 'Manage' label the source ('Maintaining accounts') denotes discrete record-maintenance acts over personnel-account records, a bounded occurrent, not a no-end standing function. Anchored to ex:ActOfAccounting (cco:ont00000366)." ;
    skos:example "Updating an employee's advance/reimbursement balance after a settlement." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AccountStatement ] .

ex:P20929 a owl:Class ;
    ex:pcfID "20929" ; ex:hierarchyID "9.6.3" ;
    ex:apqcSourceText "Handling and authoring credit cards to business entities or for corporate purchases." ;
    rdfs:label "Manage corporate credit cards" ;
    skos:definition "An Act of Card Administration that handles and authorizes the issuance of corporate credit cards to business entities and for corporate purchases, and that has as process parts the card-lifecycle activities of policy-setting, request handling, ordering, account maintenance, limit changes, and deactivation." ;
    rdfs:comment "Re-anchored from ex:ActOfFinancialTransaction to ex:ActOfCardAdministration. (1) Genus fix: 'handling and authoring (issuing) credit cards' is card issuance/administration, not a transfer of money/Financial-Instrument in settlement, so ex:ActOfFinancialTransaction's differentia is not satisfied (false friend on the theme 'credit card'); the new ex:ActOfCardAdministration (a Planned Act) covers the issue/handle/deactivate family. (2) R5 discriminator (made explicit and applied identically to ex:P10734): open-ended stewardship with no natural terminus -> Organization Capability (cco:ont00000568), as for ex:P10734 'Manage treasury operations' (ongoing optimization of cash/liquidity/risk, realized-in its acts); a bounded card-lifecycle exercise over a concrete card-set with a definite completion -> a process, as here (issue a set of cards, run their lifecycle, deactivate). The source verbs 'Handling and authoring' name discrete bounded acts with material card participants, so 9.6.3 is a process whose activities are process parts -- distinct from the no-end stewardship that makes ex:P10734 a capability. The corporate credit card is a definitional material participant." ;
    skos:example "A finance team issuing and administering corporate purchasing cards." ;
    rdfs:subClassOf ex:ActOfCardAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:CorporateCreditCard ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20930 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20931 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20932 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20933 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20934 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20935 ] .

ex:P20930 a owl:Class ;
    ex:pcfID "20930" ; ex:hierarchyID "9.6.3.1" ;
    ex:apqcSourceText "Developing procedures for using company credit cards. Set or approve credit limits." ;
    rdfs:label "Establish corporate credit card policies and approval limits" ;
    skos:definition "An Act of Formulation that develops the procedures and credit limits governing corporate credit-card use and produces a financial policy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (cco:ont00000511): composing card-use procedures and limits yields a Directive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "Issuing a corporate-card policy that sets default spend limits by role." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialPolicy ] .

ex:P20931 a owl:Class ;
    ex:pcfID "20931" ; ex:hierarchyID "9.6.3.2" ;
    ex:apqcSourceText "Handling applications credit card applications for business expenses." ;
    rdfs:label "Process corporate credit card requests" ;
    skos:definition "An Act of Card Administration that handles applications for corporate credit cards for business expenses within the card-issuance lifecycle." ;
    rdfs:comment "Re-anchored from ex:ActOfFinancialTransaction to ex:ActOfCardAdministration. Handling card applications transfers no money and settles no obligation, so it falls outside ex:ActOfFinancialTransaction's differentia; 'family coherence' is not a valid reason to file an act under a genus whose differentia it fails (same false-friend as ex:P20929/ex:P20935). ex:ActOfCardAdministration (a Planned Act) is the correct shared genus. The corporate-card request remains a typical input ICE (commented, not a definitional restriction); the card requested is the material participant in the lifecycle." ;
    skos:example "Intake and routing of an employee's corporate-card application." ;
    rdfs:subClassOf ex:ActOfCardAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:CorporateCreditCard ] .

ex:P20932 a owl:Class ;
    ex:pcfID "20932" ; ex:hierarchyID "9.6.3.3" ;
    ex:apqcSourceText "Obtaining credit cards for business-related expenses." ;
    rdfs:label "Order corporate credit cards" ;
    skos:definition "An Act of Acquisition that obtains corporate credit cards, not previously held, for business-related expenses." ;
    rdfs:comment "Anchored to ex:ActOfAcquisition (inlined; cco:ont00000228 Planned Act): obtaining a card from an issuer that the organization did not previously hold. The card obtained is a MATERIAL participant (obo:BFO_0000057), not has output." ;
    skos:example "Ordering newly approved corporate purchasing cards from the issuing bank." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:CorporateCreditCard ] .

ex:P20933 a owl:Class ;
    ex:pcfID "20933" ; ex:hierarchyID "9.6.3.4" ;
    ex:apqcSourceText "Handling credit card accounts of business customers." ;
    rdfs:label "Manage corporate credit card accounts" ;
    skos:definition "An Act of Accounting that maintains the corporate credit-card accounts of business customers and produces updated account statements." ;
    rdfs:comment "R5: the source ('Handling credit card accounts') denotes discrete account-record maintenance, a bounded occurrent, not a no-end function. Anchored to ex:ActOfAccounting (cco:ont00000366)." ;
    skos:example "Reconciling and updating a corporate-card account at month-end." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AccountStatement ] .

ex:P20934 a owl:Class ;
    ex:pcfID "20934" ; ex:hierarchyID "9.6.3.5" ;
    ex:apqcSourceText "Authorizing changes to the available credit advances." ;
    rdfs:label "Approve/Change credit limits" ;
    skos:definition "A Planned Act that authorizes a change to the available credit advances on a corporate credit card and produces an approval decision." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act) -- the §6 TOP intentional-act anchor -- as an AUTHORIZATION/RATIFICATION of a settled limit change (no candidate set), for which CCO 2.0 has no dedicated act kind. REJECTED candidates (D5/§6 step 3), uniform with the 9.6 approval siblings ex:P10872 and ex:P10882: (1) cco:ont00000636 'Act of Appraisal' -- would pair an Appraisal genus (Descriptive judgement) with the Directive ex:PaymentApproval output, breaking GOLDEN-PRINCIPLE agreement. (2) ex:ActOfSelection -- no candidate set; ratifying a single settled change routes to cco:ont00000228 per the apqc-ext ActOfSelection note. Output is the Directive ex:PaymentApproval (reused for the authorization decision)." ;
    skos:example "Approving an increase to a department card's monthly credit limit." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PaymentApproval ] .

ex:P20935 a owl:Class ;
    ex:pcfID "20935" ; ex:hierarchyID "9.6.3.6" ;
    ex:apqcSourceText "Blocking an existing credit card to disable all future transactions." ;
    rdfs:label "Cancel/Deactivate credit card" ;
    skos:definition "An Act of Card Administration that blocks an existing corporate credit card so as to disable all of its future transactions." ;
    rdfs:comment "Re-anchored from ex:ActOfFinancialTransaction to ex:ActOfCardAdministration (critical fix). ex:ActOfFinancialTransaction is 'A Planned Act in which an Agent transfers money or a Financial Instrument ... in settlement ...'; blocking a card to disable future transactions transfers no money and settles nothing -- it is the OPPOSITE of a financial transaction, a false friend driven by the theme 'credit card' rather than the verb 'block/deactivate'. The genus definition does not subsume this act. REJECTED candidate ex:ActOfFinancialTransaction (reason: no money/instrument transfer). Modeled as a card-lifecycle administrative act (ex:ActOfCardAdministration, a Planned Act over the card artifact), with the corporate credit card as the definitional material participant." ;
    skos:example "Deactivating a lost corporate card to prevent further charges." ;
    rdfs:subClassOf ex:ActOfCardAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:CorporateCreditCard ] .

# --- 9.6 precedence (Phase 6): 10882 approval precedes 10883 payment ---
ex:P10882 rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000063 ; owl:someValuesFrom ex:P10883 ] .   # precedes

# ================== group 9.7 ==================
# Manage treasury operations. Standing "Manage X" nodes -> Organization
# Capability (cco:ont00000568) realized in their modeled act children.

ex:P10734 a owl:Class ;
    ex:pcfID "10734" ;
    ex:hierarchyID "9.7" ;
    ex:apqcSourceText "Managing business's investments in trading in bonds, currencies, financial derivatives, etc. Manage the financial assets and holdings of the organization. Optimize the organization's liquidity. Invest excess cash. Reduce financial risks." ;
    rdfs:label "Manage treasury operations" ;
    skos:definition "An Organization Capability that is realized in acts of managing an organization's investments, financial assets, liquidity, and financial risk." ;
    rdfs:comment "R5: standing treasury function with no natural end -> Organization Capability (R6), not a process. Sub-functions and their underlying acts realize it." ;
    skos:example "A corporate treasury department's ongoing stewardship of the firm's cash, debt, investments, and hedging." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10885 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10893 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P14079 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12974 ] .

ex:P10758 a owl:Class ;
    ex:pcfID "10758" ;
    ex:hierarchyID "9.7.1" ;
    ex:apqcSourceText "Managing rules and regulations for investments in trading in bonds, currencies, financial derivatives, etc. Establish policies and procedures for investments made. Optimize liquidity in treasury operations." ;
    rdfs:label "Manage treasury policies and procedures" ;
    skos:definition "An Organization Capability that is realized in acts of establishing, developing, monitoring, auditing, and revising the policies and procedures governing treasury operations." ;
    rdfs:comment "R5: standing governance function -> Organization Capability (R6). Its discrete establish/develop/monitor/audit/revise children are processes that realize it." ;
    skos:example "A treasury policy office continuously maintaining the firm's investment rulebook." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10885 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10886 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10887 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10888 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10889 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10890 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10891 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10892 ] .

ex:P10885 a owl:Class ;
    ex:pcfID "10885" ; ex:hierarchyID "9.7.1.1" ;
    ex:apqcSourceText "Selecting opportunities and the authoritative body for investments in trading in bonds, currencies, financial derivatives, etc." ;
    rdfs:label "Establish scope and governance of treasury operations" ;
    skos:definition "An Act of Formulation that has as output a treasury governance charter prescribing the scope of treasury operations and its authoritative governing body." ;
    rdfs:comment "Genus ex:ActOfFormulation (Directive output) per GOLDEN PRINCIPLE: establishing scope and authority composes a prescriptive directive." ;
    skos:example "A board committee sets the mandate and approval authority for the treasury desk." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TreasuryGovernanceCharter ] .

ex:P10886 a owl:Class ;
    ex:pcfID "10886" ; ex:hierarchyID "9.7.1.2" ;
    ex:apqcSourceText "Creating and providing investment regulations for the organization. Establish policies and procedures for investments to optimize liquidity in treasury operations. Create a written copy of it." ;
    rdfs:label "Establish and publish treasury policies" ;
    skos:definition "An Act of Formulation that has as output a financial policy that prescribes the organization's investment regulations." ;
    rdfs:comment "Genus ex:ActOfFormulation (Directive output). Reuses shared ex:FinancialPolicy (treasury investment policy)." ;
    skos:example "Treasury issues and circulates the written corporate investment policy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialPolicy ] .

ex:P10887 a owl:Class ;
    ex:pcfID "10887" ; ex:hierarchyID "9.7.1.3" ;
    ex:apqcSourceText "Making processes for investing. Create steps for investments in bonds, currencies, and financial derivatives in order to optimize company's liquidity, invest excess cash, and reduce its financial risks." ;
    rdfs:label "Develop treasury procedures" ;
    skos:definition "An Act of Formulation that has as output a financial procedure prescribing the steps for executing investments." ;
    rdfs:comment "Genus ex:ActOfFormulation (Directive output). Reuses shared ex:FinancialProcedure." ;
    skos:example "Treasury drafts the step-by-step procedure for placing a bond trade." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] .

ex:P10888 a owl:Class ;
    ex:pcfID "10888" ; ex:hierarchyID "9.7.1.4" ;
    ex:apqcSourceText "Checking treasury processes in order to optimize company's liquidity, invest excess cash, and reduce its financial risks." ;
    rdfs:label "Monitor treasury procedures" ;
    skos:definition "An Act of Monitoring that has as input a financial procedure and has as output a control-effectiveness assessment of treasury processes." ;
    rdfs:comment "Genus ex:ActOfMonitoring (Descriptive output) per GOLDEN PRINCIPLE: ongoing checking yields a judgement. Reuses shared ex:FinancialProcedure and ex:ControlEffectivenessAssessment." ;
    skos:example "A treasury controller periodically reviews adherence to investment procedures." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialProcedure ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ControlEffectivenessAssessment ] .

ex:P10889 a owl:Class ;
    ex:pcfID "10889" ; ex:hierarchyID "9.7.1.5" ;
    ex:apqcSourceText "Auditing the treasury function." ;
    rdfs:label "Audit treasury procedures" ;
    skos:definition "An Act of Appraisal that examines the treasury function and has as output a control-effectiveness assessment." ;
    rdfs:comment "Genus cco:ont00000636 (Act of Appraisal): auditing evaluates and judges, producing a Descriptive ICE. Reuses shared ex:ControlEffectivenessAssessment." ;
    skos:example "Internal audit reviews treasury controls and issues an assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ControlEffectivenessAssessment ] .

ex:P10890 a owl:Class ;
    ex:pcfID "10890" ; ex:hierarchyID "9.7.1.6" ;
    ex:apqcSourceText "Reassessing all treasury procedures based on audit findings." ;
    rdfs:label "Revise treasury procedures" ;
    skos:definition "An Act of Formulation that has as input a control-effectiveness assessment and has as output a revised financial procedure." ;
    rdfs:comment "Genus ex:ActOfFormulation (Directive output): revising reformulates a prescriptive procedure. Reuses shared ex:ControlEffectivenessAssessment and ex:FinancialProcedure." ;
    skos:example "Treasury updates its trading procedures in response to audit findings." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ControlEffectivenessAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] .

ex:P10891 a owl:Class ;
    ex:pcfID "10891" ; ex:hierarchyID "9.7.1.7" ;
    ex:apqcSourceText "Creating and managing the internal control systems for investments in bonds, currencies, and financial derivatives to verify procedures." ;
    rdfs:label "Develop and confirm internal controls for treasury" ;
    skos:definition "An Act of Formulation that has as output an internal-control policy governing treasury investment activity." ;
    rdfs:comment "Genus ex:ActOfFormulation (Directive output). Reuses shared ex:InternalControlPolicy." ;
    skos:example "Treasury defines the segregation-of-duties controls over derivative trades." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InternalControlPolicy ] .

ex:P10892 a owl:Class ;
    ex:pcfID "10892" ; ex:hierarchyID "9.7.1.8" ;
    ex:apqcSourceText "Describing the need of system security requirements for controlling access, reliability of information, accountability, and availability of information in the organization." ;
    rdfs:label "Define system security requirements" ;
    skos:definition "An Act of Formulation that has as output a system security requirement prescribing controls over access, reliability, accountability, and availability of treasury information." ;
    rdfs:comment "Genus ex:ActOfFormulation (Directive output). Output ex:SystemSecurityRequirement minted locally." ;
    skos:example "Treasury IT specifies the access-control and audit-trail requirements for the dealing system." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SystemSecurityRequirement ] .

ex:P10759 a owl:Class ;
    ex:pcfID "10759" ;
    ex:hierarchyID "9.7.2" ;
    ex:apqcSourceText "Taking care of all cash-related activities in the business. Manage and reconcile cash positions. Manage cash equivalents. Process and oversee electronic fund transfers. Develop cash flow forecasts. Manage cash flows. Produce cash management accounting transactions and reports. Manage and oversee banking relationships. Analyze, negotiate, resolve, and confirm bank fees." ;
    rdfs:label "Manage cash" ;
    skos:definition "An Organization Capability that is realized in acts of reconciling cash positions, transferring funds, forecasting cash flow, and accounting for and reporting on cash activity." ;
    rdfs:comment "R5: standing cash-management function -> Organization Capability (R6). Discrete reconcile/transfer/forecast/report children are processes that realize it; standing sub-functions (cash equivalents, cash flows, banking relationships) are themselves capabilities." ;
    skos:example "A cash-management team's ongoing oversight of corporate liquidity." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10893 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10895 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10896 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10898 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10900 ] .

ex:P10893 a owl:Class ;
    ex:pcfID "10893" ; ex:hierarchyID "9.7.2.1" ;
    ex:apqcSourceText "Correcting cash differences in the books of accounts. Make optimum utilization of funds available in the business. Check for differences to rectify." ;
    rdfs:label "Manage and reconcile cash positions" ;
    skos:definition "An Act of Accounting that has as input a general ledger and has as output a reconciled cash position." ;
    rdfs:comment "Genus ex:ActOfAccounting (info-processing; Descriptive output). Reuses shared ex:GeneralLedger; output ex:CashPosition minted locally." ;
    skos:example "Treasury reconciles bank statements against the ledger and corrects discrepancies." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CashPosition ] .

ex:P10894 a owl:Class ;
    ex:pcfID "10894" ;
    ex:hierarchyID "9.7.2.2" ;
    ex:apqcSourceText "Taking care of all cash-related activities in the business. Utilize short-term assets that can be easily convertible into cash, such as marketable securities, commercial paper and short-term government bonds, and treasury bills." ;
    rdfs:label "Manage cash equivalents" ;
    skos:definition "An Organization Capability that is realized in acts of holding and utilizing short-term assets readily convertible into cash." ;
    rdfs:comment "R5: standing function of maintaining cash-equivalent holdings, no natural end -> Organization Capability (R6)." ;
    skos:example "Treasury parks surplus cash in treasury bills and commercial paper." ;
    rdfs:subClassOf cco:ont00000568 .

ex:P10895 a owl:Class ;
    ex:pcfID "10895" ; ex:hierarchyID "9.7.2.3" ;
    ex:apqcSourceText "Supervising all online transactions." ;
    rdfs:label "Process and oversee electronic fund transfers (EFTs)" ;
    skos:definition "An Act of Financial Transaction in which monetary payments are transferred electronically between accounts." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Operations category: the material filler ex:PaymentInstrument is the transferred MATERIAL participant (obo:BFO_0000057), not has output (has output is reserved for ICE outputs)." ;
    skos:example "Treasury executes a wire transfer to settle a supplier invoice." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] .

ex:P10896 a owl:Class ;
    ex:pcfID "10896" ; ex:hierarchyID "9.7.2.4" ;
    ex:apqcSourceText "Preparing forecasts for the cash generated or used by the organization." ;
    rdfs:label "Develop cash flow forecasts" ;
    skos:definition "An Act of Prediction that examines financial data and generates a financial forecast of cash to be generated or used by the organization." ;
    rdfs:comment "Re-anchored from ex:ActOfReporting to cco:ont00000371 (Act of Prediction) to reconcile a cross-group inconsistency: the SAME output type (ex:FinancialForecast) is produced by ex:P10773 'Prepare periodic financial forecasts', and both are forecasts, i.e. predictive projections rather than mere compilation/reporting of existing results. ex:P10773 was re-anchored to cco:ont00000371 (Act of Prediction, output a Predictive ICE); this row is aligned to that precedent so the same artifact is not anchored under two different genera across groups (Gate-F reconciliation). REJECTED candidate ex:ActOfReporting: reporting compiles existing results, whereas producing a forecast generates a Predictive ICE about an uncertain future state. Reuses shared ex:FinancialData (input) and ex:FinancialForecast (output, now a Predictive ICE)." ;
    skos:example "Treasury builds a 13-week rolling cash-flow forecast." ;
    rdfs:subClassOf cco:ont00000371 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialForecast ] .

ex:P10897 a owl:Class ;
    ex:pcfID "10897" ;
    ex:hierarchyID "9.7.2.5" ;
    ex:apqcSourceText "Delaying the outflow of funds as long as possible, but encourage the inflow of as fast as possible." ;
    rdfs:label "Manage cash flows" ;
    skos:definition "An Organization Capability that is realized in acts of optimizing the timing of cash inflows and outflows." ;
    rdfs:comment "R5: standing optimization function with no natural end -> Organization Capability (R6)." ;
    skos:example "Treasury accelerates receivables collection while extending payables." ;
    rdfs:subClassOf cco:ont00000568 .

ex:P10898 a owl:Class ;
    ex:pcfID "10898" ; ex:hierarchyID "9.7.2.6" ;
    ex:apqcSourceText "Presenting reports on all cash-related activities. Collect and manage short-term investing activities. Prepare reports of all transactions done." ;
    rdfs:label "Produce cash management accounting transactions and reports" ;
    skos:definition "An Act of Reporting that has as input transaction records and has as output a financial report on cash-management activity." ;
    rdfs:comment "Genus ex:ActOfReporting (Descriptive output). Reuses shared ex:TransactionRecord and ex:FinancialReport." ;
    skos:example "Treasury issues the monthly cash-management activity report." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] .

ex:P10899 a owl:Class ;
    ex:pcfID "10899" ;
    ex:hierarchyID "9.7.2.7" ;
    ex:apqcSourceText "Maintaining and directing the course of relationships with banking partners." ;
    rdfs:label "Manage and oversee banking relationships" ;
    skos:definition "An Organization Capability that is realized in acts of maintaining and directing relationships with banking partners." ;
    rdfs:comment "R5: standing relationship-maintenance function with no natural end -> Organization Capability (R6)." ;
    skos:example "Treasury holds quarterly reviews with its relationship banks." ;
    rdfs:subClassOf cco:ont00000568 .

ex:P10900 a owl:Class ;
    ex:pcfID "10900" ; ex:hierarchyID "9.7.2.8" ;
    ex:apqcSourceText "Studying and finalizing bank fees for services provided by banks. Negotiate and finalize nominal fees that bank charges for various services, such as requesting a deposit slip or counter check or certifying papers." ;
    rdfs:label "Analyze, negotiate, resolve, and confirm bank fees" ;
    skos:definition "An Act of Analysis that has as input financial data and has as output a bank fee analysis determining the fees charged by a banking partner." ;
    rdfs:comment "Genus ex:ActOfAnalysis (Descriptive output) per GOLDEN PRINCIPLE: the dominant act is studying and determining fees. Reuses shared ex:FinancialData; output ex:BankFeeAnalysis minted locally." ;
    skos:example "Treasury benchmarks and negotiates a bank's transaction-fee schedule." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BankFeeAnalysis ] .

ex:P10760 a owl:Class ;
    ex:pcfID "10760" ;
    ex:hierarchyID "9.7.3" ;
    ex:apqcSourceText "Managing financial services provided by an in-house bank structure in the corporation that is operating like a commercial bank." ;
    rdfs:label "Manage in-house bank accounts" ;
    skos:definition "An Organization Capability that is realized in acts of operating an internal banking structure providing financial services to the corporation and its subsidiaries." ;
    rdfs:comment "R5: standing in-house-bank function -> Organization Capability (R6). Discrete borrowing/payment/interest/statement children are processes that realize it." ;
    skos:example "A corporate in-house bank settling intercompany balances for the group." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10902 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10903 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10904 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10905 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10906 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10907 ] .

ex:P10901 a owl:Class ;
    ex:pcfID "10901" ;
    ex:hierarchyID "9.7.3.1" ;
    ex:apqcSourceText "Maintaining subsidiaries' company accounts opened with bank inside the corporation. Manage different financial services provided by in-house bank structure for parent companies' subsidiaries or branches." ;
    rdfs:label "Manage in-house bank accounts for subsidiaries" ;
    skos:definition "An Organization Capability that is realized in acts of maintaining and servicing subsidiary accounts held within the corporation's in-house bank." ;
    rdfs:comment "R5: standing account-maintenance function for subsidiaries, no natural end -> Organization Capability (R6)." ;
    skos:example "The in-house bank maintains a current account for each operating subsidiary." ;
    rdfs:subClassOf cco:ont00000568 .

ex:P10902 a owl:Class ;
    ex:pcfID "10902" ; ex:hierarchyID "9.7.3.2" ;
    ex:apqcSourceText "Arranging loans for subsidiaries from in-house banks." ;
    rdfs:label "Manage and facilitate inter-company borrowing transactions" ;
    skos:definition "An Act of Loaning in which the in-house bank (Creditor) extends a loan to a subsidiary (Debtor) to receive repayments of greater financial value." ;
    rdfs:comment "Re-anchored from ex:ActOfFinancialTransaction to the verified CCO leaf cco:ont00000884 (Act of Loaning): the in-house bank gives a Financial Instrument to the subsidiary as Debtor to receive repayments -- exactly 884's differentia, closer than the generic transaction genus. cco:ont00000228 (Planned Act) co-asserted because 884 is outside the standalone-SHACL S2 allowlist (884 -> 836 -> 566 -> 228). The loaned funds are a MATERIAL participant (obo:BFO_0000057)." ;
    skos:example "The in-house bank books an intercompany loan to a foreign subsidiary." ;
    rdfs:subClassOf cco:ont00000884 ,
        cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Subsidiary ] .

ex:P10903 a owl:Class ;
    ex:pcfID "10903" ; ex:hierarchyID "9.7.3.3" ;
    ex:apqcSourceText "Handling payments made for subsidiaries by parent company." ;
    rdfs:label "Manage centralized outgoing payments on behalf of subsidiaries" ;
    skos:definition "An Act of Financial Transaction in which the parent disburses monetary payments outward on behalf of its subsidiaries." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Material filler ex:PaymentInstrument is the definitional MATERIAL participant (obo:BFO_0000057, the payment disbursed), not has output." ;
    skos:example "The parent pays a subsidiary's vendor through the central payments factory." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Subsidiary ] .

ex:P10904 a owl:Class ;
    ex:pcfID "10904" ; ex:hierarchyID "9.7.3.4" ;
    ex:apqcSourceText "Handling payments received by parent company for subsidiaries." ;
    rdfs:label "Manage central incoming payments on behalf of subsidiaries" ;
    skos:definition "An Act of Financial Transaction in which the parent collects monetary payments inward on behalf of its subsidiaries." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Material filler ex:PaymentInstrument is definitional (the payment collected)." ;
    skos:example "The parent receives a customer remittance owed to a subsidiary." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Subsidiary ] .

ex:P10905 a owl:Class ;
    ex:pcfID "10905" ; ex:hierarchyID "9.7.3.5" ;
    ex:apqcSourceText "Taking care of all business outflows and recording as whole. Manage making all payments for the organization and its units or subsidiaries. Track in books of accounts of parent company." ;
    rdfs:label "Manage internal payments and netting transactions" ;
    skos:definition "An Act of Financial Transaction in which internal payments across organizational units are settled on a netted basis and recorded." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Recording produces a transaction record (Descriptive ICE), the definitional has output; the netted monetary payment is the MATERIAL participant (obo:BFO_0000057)." ;
    skos:example "The in-house bank nets intercompany balances and posts the residual settlement." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10906 a owl:Class ;
    ex:pcfID "10906" ; ex:hierarchyID "9.7.3.6" ;
    ex:apqcSourceText "Computing all expenses paid to and receivables collected over the organization's banking activity. Calculate all charges and receivables, towards interest, fees, and any other payments over its own bank accounts. Record transactions in the books of accounts." ;
    rdfs:label "Calculate interest and fees for in-house bank accounts" ;
    skos:definition "An Act of Accounting that has as input a general ledger and has as output transaction records of computed interest and fees on in-house bank accounts." ;
    rdfs:comment "Genus ex:ActOfAccounting (info-processing; Descriptive output). Reuses shared ex:GeneralLedger and ex:TransactionRecord." ;
    skos:example "The in-house bank computes and posts monthly interest on subsidiary balances." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GeneralLedger ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10907 a owl:Class ;
    ex:pcfID "10907" ; ex:hierarchyID "9.7.3.7" ;
    ex:apqcSourceText "Facilitating account statements for all in-house banking activity." ;
    rdfs:label "Provide account statements for in-house bank accounts" ;
    skos:definition "An Act of Communication that delivers an already-prepared account statement for in-house banking activity to the account holder." ;
    rdfs:comment "Re-anchored from ex:ActOfReporting to cco:ont00000402 (Act of Communication). The source ('Facilitating account statements for all in-house banking activity') and the verb 'Provide/facilitate' read as delivering/transmitting an already-produced statement, not compiling it; the compilation is the sibling ex:P10906 'Calculate interest and fees for in-house bank accounts' (which records the transactions and from which the statement is drawn). The ex:ActOfReporting carve-out routes transmit-only nodes to cco:ont00000402: 'Where a node only transmits an already-prepared report to a party, the group module reuses cco:ont00000402 instead.' Keeping ex:ActOfReporting would double-count the production step. The account statement is therefore the transmitted ICE (has input), and the subsidiary account holder is the recipient participant. cco:ont00000402 verified against CCO v2.0 (2024-11-06)." ;
    skos:example "The in-house bank issues each subsidiary its monthly account statement." ;
    rdfs:subClassOf cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:AccountStatement ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Subsidiary ] .

ex:P10761 a owl:Class ;
    ex:pcfID "10761" ;
    ex:hierarchyID "9.7.4" ;
    ex:apqcSourceText "Taking care of the organization's financial position. Manage its loans or debts from different sources and investments. Leverage the most profitable options to balance the financial position in the market." ;
    rdfs:label "Manage debt and investment" ;
    skos:definition "An Organization Capability that is realized in acts of establishing investment policy and processing the organization's debt and investment transactions." ;
    rdfs:comment "R5: standing portfolio-management function -> Organization Capability (R6). Discrete establish/process/produce children are processes that realize it." ;
    skos:example "A treasury investment desk balancing the firm's debt and investment book." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P14079 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10911 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10912 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10913 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P14210 ] .

ex:P14079 a owl:Class ;
    ex:pcfID "14079" ; ex:hierarchyID "9.7.4.1" ;
    ex:apqcSourceText "Developing and instituting principles that the organization ill use in making investments." ;
    rdfs:label "Establish investment policy" ;
    skos:definition "An Act of Formulation that has as output an investment policy prescribing the principles the organization will follow in making investments." ;
    rdfs:comment "Genus ex:ActOfFormulation (Directive output). Reuses shared ex:InvestmentPolicy." ;
    skos:example "The investment committee adopts a policy capping single-issuer exposure." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InvestmentPolicy ] .

ex:P10908 a owl:Class ;
    ex:pcfID "10908" ;
    ex:hierarchyID "9.7.4.2" ;
    ex:apqcSourceText "Maintaining smooth relations with financial investment banks that help availing loans and services." ;
    rdfs:label "Manage financial intermediary relationships" ;
    skos:definition "An Organization Capability that is realized in acts of maintaining relationships with financial intermediaries that provide loans and services." ;
    rdfs:comment "R5: standing relationship-maintenance function -> Organization Capability (R6)." ;
    skos:example "Treasury maintains its panel of investment-banking counterparties." ;
    rdfs:subClassOf cco:ont00000568 .

ex:P10909 a owl:Class ;
    ex:pcfID "10909" ;
    ex:hierarchyID "9.7.4.3" ;
    ex:apqcSourceText "Managing and maintaining enough liquidity in form of cash and cash equivalents in the business to meet urgent and timely requirements" ;
    rdfs:label "Manage liquidity" ;
    skos:definition "An Organization Capability that is realized in acts of maintaining sufficient cash and cash equivalents to meet the organization's obligations." ;
    rdfs:comment "R5: standing liquidity-maintenance function with no natural end -> Organization Capability (R6)." ;
    skos:example "Treasury keeps a liquidity buffer sized to a stressed cash-outflow scenario." ;
    rdfs:subClassOf cco:ont00000568 .

ex:P10910 a owl:Class ;
    ex:pcfID "10910" ;
    ex:hierarchyID "9.7.4.4" ;
    ex:apqcSourceText "Managing the exposure incurred by the issuer for providing credit to the borrower." ;
    rdfs:label "Manage issuer exposure" ;
    skos:definition "An Organization Capability that is realized in acts of controlling the credit exposure incurred toward issuers and borrowers." ;
    rdfs:comment "R5: standing exposure-control function -> Organization Capability (R6)." ;
    skos:example "Treasury monitors and caps exposure to each bond issuer in the portfolio." ;
    rdfs:subClassOf cco:ont00000568 .

ex:P10911 a owl:Class ;
    ex:pcfID "10911" ; ex:hierarchyID "9.7.4.5" ;
    ex:apqcSourceText "Tracking loans taken and money invested in different options. Arrange and supervise loans from banks and individuals and investments in different available and profitable options." ;
    rdfs:label "Process and oversee debt and investment transactions" ;
    skos:definition "An Act of Financial Transaction in which loans are taken or investments are placed and the resulting positions are recorded." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Recording yields a transaction record (Descriptive ICE), included as a definitional output." ;
    skos:example "Treasury draws a term loan and books the proceeds and schedule." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10912 a owl:Class ;
    ex:pcfID "10912" ; ex:hierarchyID "9.7.4.6" ;
    ex:apqcSourceText "Arranging and supervising foreign exchange rate changes to avoid loss on foreign-currency transactions." ;
    rdfs:label "Process and oversee foreign currency transactions" ;
    skos:definition "An Act of Financial Transaction in which foreign-currency positions are exchanged and the resulting transactions are recorded." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Recording yields a transaction record (Descriptive ICE)." ;
    skos:example "Treasury converts EUR proceeds to USD and records the settled trade." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10913 a owl:Class ;
    ex:pcfID "10913" ; ex:hierarchyID "9.7.4.7" ;
    ex:apqcSourceText "Creating transactions report of loans and investments. Prepare and maintain records of loans and investment transactions." ;
    rdfs:label "Produce debt and investment accounting transaction reports" ;
    skos:definition "An Act of Reporting that has as input transaction records and has as output a financial report on debt and investment activity." ;
    rdfs:comment "Genus ex:ActOfReporting (Descriptive output). Reuses shared ex:TransactionRecord and ex:FinancialReport." ;
    skos:example "Treasury issues the quarterly debt-and-investment portfolio report." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] .

ex:P14210 a owl:Class ;
    ex:pcfID "14210" ; ex:hierarchyID "9.7.4.8" ;
    ex:apqcSourceText "Supervising the interest paid or received by the organization. Arrange and supervise interest rate swap transactions to manage exposure to fluctuations in interest rates. Or attain a marginally lower rate of interest than could be gained through a swap." ;
    rdfs:label "Process and oversee interest rate transactions" ;
    skos:definition "An Act of Financial Transaction in which interest-rate swap or related transactions are arranged and recorded to manage interest-rate exposure." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Recording yields a transaction record (Descriptive ICE)." ;
    skos:example "Treasury enters a pay-fixed interest-rate swap and books the trade." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P11208 a owl:Class ;
    ex:pcfID "11208" ;
    ex:hierarchyID "9.7.5" ;
    ex:apqcSourceText "Performing transactions that limit investment risk with the help of derivatives, such as options and futures contracts. Manage interest rates, foreign exchange, and exposure risks. Develop and execute hedging transactions. Evaluate and refine hedging positions. Produce hedge accounting transactions and reports. Monitor credit." ;
    rdfs:label "Monitor and execute risk and hedging transactions" ;
    skos:definition "An Organization Capability that is realized in acts of developing hedging strategy, managing market and exposure risks, executing hedges, and accounting for hedging activity." ;
    rdfs:comment "R5: standing risk-and-hedging function -> Organization Capability (R6). Discrete strategy/report children are processes; market/exposure sub-functions are themselves capabilities." ;
    skos:example "A market-risk desk running the firm's hedging programme." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12974 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11214 ] .

ex:P12974 a owl:Class ;
    ex:pcfID "12974" ; ex:hierarchyID "9.7.5.1" ;
    ex:apqcSourceText "Taking an investment position to offset exposure to certain risks. This may include purchasing opposite of the organization's position in the marketplace, using derivatives transactions, or futures contracts." ;
    rdfs:label "Develop risk management/hedging strategy" ;
    skos:definition "An Act of Formulation that has as output a hedging strategy prescribing positions taken to offset exposure to financial risks." ;
    rdfs:comment "Genus ex:ActOfFormulation (Directive output). Reuses shared ex:HedgingStrategy." ;
    skos:example "The risk committee adopts a strategy to hedge 80 percent of forecast FX exposure." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HedgingStrategy ] .

ex:P11209 a owl:Class ;
    ex:pcfID "11209" ;
    ex:hierarchyID "9.7.5.2" ;
    ex:apqcSourceText "Handling risks arising from changes in the interest rate." ;
    rdfs:label "Manage interest rate risk" ;
    skos:definition "An Organization Capability that is realized in acts of collecting interest-rate market data, determining interest-rate exposure and hedge requirements, and executing interest-rate trades." ;
    rdfs:comment "R5: standing interest-rate-risk function -> Organization Capability (R6). Its four tasks are processes that realize it." ;
    skos:example "The rates desk managing the firm's interest-rate risk position." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19575 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19576 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19577 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19578 ] .

ex:P19575 a owl:Class ;
    ex:pcfID "19575" ; ex:hierarchyID "9.7.5.2.1" ;
    ex:apqcSourceText "Collecting and storing data that pertains to interest rate markets." ;
    rdfs:label "Manage interest rate market data" ;
    skos:definition "An Act of Monitoring that collects and stores interest-rate market data and has as output a market rate data record." ;
    rdfs:comment "Genus ex:ActOfMonitoring (info-processing; Descriptive output): ongoing collection/storage of market data. Reuses shared ex:MarketRateData." ;
    skos:example "The rates desk feeds live swap curves into its data store." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketRateData ] .

ex:P19576 a owl:Class ;
    ex:pcfID "19576" ; ex:hierarchyID "9.7.5.2.2" ;
    ex:apqcSourceText "Identifying potential interest rate risks for all markets." ;
    rdfs:label "Determine interest rate exposure for all markets" ;
    skos:definition "An Act of Analysis that has as input market rate data and has as output a financial risk assessment of interest-rate exposure across markets." ;
    rdfs:comment "Genus ex:ActOfAnalysis (Descriptive output). Reuses shared ex:MarketRateData and ex:RiskAssessment." ;
    skos:example "The desk computes the portfolio's DV01 by market." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketRateData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RiskAssessment ] .

ex:P19577 a owl:Class ;
    ex:pcfID "19577" ; ex:hierarchyID "9.7.5.2.3" ;
    ex:apqcSourceText "Deciding the requirements on interest rate investments that are made by trading in futures or options market, on the basis of the accepted risk policy." ;
    rdfs:label "Determine interest rate hedge requirements in accordance with risk policy" ;
    skos:definition "An Act of Selection that has as input a financial risk assessment and a financial policy and has as output a hedge requirement specification for interest-rate exposure." ;
    rdfs:comment "Genus ex:ActOfSelection (Directive output) per GOLDEN PRINCIPLE: deciding requirements commits to prescribed hedges. Reuses shared ex:RiskAssessment and ex:FinancialPolicy (risk policy); output ex:HedgeRequirementSpecification minted locally." ;
    skos:example "The desk sets the required futures hedge given the accepted risk policy." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RiskAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HedgeRequirementSpecification ] .

ex:P19578 a owl:Class ;
    ex:pcfID "19578" ; ex:hierarchyID "9.7.5.2.4" ;
    ex:apqcSourceText "Performing trading on interest rates." ;
    rdfs:label "Execute interest rate trades" ;
    skos:definition "An Act of Financial Transaction in which interest-rate instruments are traded to implement a hedge." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Recording yields a transaction record (Descriptive ICE)." ;
    skos:example "The desk executes an interest-rate futures order." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P11210 a owl:Class ;
    ex:pcfID "11210" ;
    ex:hierarchyID "9.7.5.3" ;
    ex:apqcSourceText "Taking care of foreign-exchange risks." ;
    rdfs:label "Manage foreign exchange risk" ;
    skos:definition "An Organization Capability that is realized in acts of managing FX market data, determining FX exposure and hedge requirements, executing FX trades, and managing balance-sheet FX risk." ;
    rdfs:comment "R5: standing FX-risk function -> Organization Capability (R6). Its five tasks are processes that realize it." ;
    skos:example "The FX desk managing the group's currency risk." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19579 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19580 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19581 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19582 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19583 ] .

ex:P19579 a owl:Class ;
    ex:pcfID "19579" ; ex:hierarchyID "9.7.5.3.1" ;
    ex:apqcSourceText "Handling and processing information about changes in foreign exchange rates." ;
    rdfs:label "Manage foreign exchange market data" ;
    skos:definition "An Act of Monitoring that handles and processes foreign-exchange rate data and has as output a market rate data record." ;
    rdfs:comment "Genus ex:ActOfMonitoring (Descriptive output). Reuses shared ex:MarketRateData." ;
    skos:example "The FX desk ingests live spot and forward rates." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketRateData ] .

ex:P19580 a owl:Class ;
    ex:pcfID "19580" ; ex:hierarchyID "9.7.5.3.2" ;
    ex:apqcSourceText "Establishing potential foreign exchange risks for all currencies." ;
    rdfs:label "Determine foreign exchange exposure for all currencies" ;
    skos:definition "An Act of Analysis that has as input market rate data and has as output a financial risk assessment of foreign-exchange exposure across currencies." ;
    rdfs:comment "Genus ex:ActOfAnalysis (Descriptive output). Reuses shared ex:MarketRateData and ex:RiskAssessment." ;
    skos:example "The desk reports net open position by currency." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketRateData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RiskAssessment ] .

ex:P19581 a owl:Class ;
    ex:pcfID "19581" ; ex:hierarchyID "9.7.5.3.3" ;
    ex:apqcSourceText "Deciding the requirements on investments in foreign exchange made by trading in futures or options market, on the basis of current risk policy." ;
    rdfs:label "Determine foreign exchange hedge requirements in accordance with risk policy" ;
    skos:definition "An Act of Selection that has as input a financial risk assessment and a financial policy and has as output a hedge requirement specification for foreign-exchange exposure." ;
    rdfs:comment "Genus ex:ActOfSelection (Directive output). Reuses shared ex:RiskAssessment and ex:FinancialPolicy; output ex:HedgeRequirementSpecification reused (minted locally)." ;
    skos:example "The desk sets required forward cover given the FX risk policy." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RiskAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HedgeRequirementSpecification ] .

ex:P19582 a owl:Class ;
    ex:pcfID "19582" ; ex:hierarchyID "9.7.5.3.4" ;
    ex:apqcSourceText "Executing all aspects for foreign exchange trade within foreign exchange market. This includes buying, selling, and exchanging currencies at the current or expressed price point." ;
    rdfs:label "Execute foreign exchange trades" ;
    skos:definition "An Act of Financial Transaction in which currencies are bought, sold, or exchanged in the foreign-exchange market." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Recording yields a transaction record (Descriptive ICE)." ;
    skos:example "The desk executes a spot EUR/USD trade." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P19583 a owl:Class ;
    ex:pcfID "19583" ; ex:hierarchyID "9.7.5.3.5" ;
    ex:apqcSourceText "Overseeing the foreign exchange balance sheet with an eye towards potential risk. Risks include changes in conversion rates between the time the transaction occurred and when it is completed, or when transactions are made in a denomination other than that of the organization's base currency." ;
    rdfs:label "Manage foreign exchange balance sheet risk" ;
    skos:definition "An Act of Monitoring that oversees the foreign-exchange balance sheet and has as output a financial risk assessment of translation and settlement risk." ;
    rdfs:comment "Genus ex:ActOfMonitoring (Descriptive output): continuous oversight producing a risk judgement. Reuses shared ex:RiskAssessment." ;
    skos:example "The desk tracks translation risk on non-base-currency balances." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RiskAssessment ] .

ex:P11211 a owl:Class ;
    ex:pcfID "11211" ;
    ex:hierarchyID "9.7.5.4" ;
    ex:apqcSourceText "Taking care of exposure risks. Maintain financial investments in particular investments or a portfolios that could be risky for the organization." ;
    rdfs:label "Manage exposure risk" ;
    skos:definition "An Organization Capability that is realized in acts of determining customer exposures, resolving limit violations, managing collateral, and reviewing customer credit." ;
    rdfs:comment "R5: standing exposure-risk function -> Organization Capability (R6). Its four tasks are processes that realize it." ;
    skos:example "The credit-risk team managing counterparty exposure limits." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19584 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19585 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19586 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19587 ] .

ex:P19584 a owl:Class ;
    ex:pcfID "19584" ; ex:hierarchyID "9.7.5.4.1" ;
    ex:apqcSourceText "Establishing ongoing risks that the customers face, and the exceptions to exceeded limits." ;
    rdfs:label "Determine current customer exposures and limit exceptions" ;
    skos:definition "An Act of Analysis that has as input risk exposure data and has as output a financial risk assessment describing current customer exposures and exceptions to exposure limits." ;
    rdfs:comment "Genus ex:ActOfAnalysis (Descriptive output). Reuses shared ex:RiskAssessment. Phase-3 consistency fix: a definitional has input (ex:RiskExposureData) was added to match the input pattern of its structurally parallel exposure-determination peers ex:P19576 and ex:P19580 (both has input ex:MarketRateData). An exposure-determination analysis cannot occur without exposure/position data as input, so the input is definitional for all three; this row previously lacked it, making it look less constrained than its twins." ;
    skos:example "The team flags counterparties breaching their exposure limit." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RiskExposureData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RiskAssessment ] .

ex:P19585 a owl:Class ;
    ex:pcfID "19585" ; ex:hierarchyID "9.7.5.4.2" ;
    ex:apqcSourceText "Settling cases that involve violations of customer exposure limit." ;
    rdfs:label "Resolve customer exposure limit violations" ;
    skos:definition "An Act of Selection that has as input a financial risk assessment and has as output an exposure limit resolution prescribing the settlement of a limit violation." ;
    rdfs:comment "Genus ex:ActOfSelection (Directive output) per GOLDEN PRINCIPLE: resolving a case commits to a prescribed remedy. Reuses shared ex:RiskAssessment; output ex:ExposureLimitResolution minted locally." ;
    skos:example "The team requires additional margin to cure a limit breach." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RiskAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExposureLimitResolution ] .

ex:P19586 a owl:Class ;
    ex:pcfID "19586" ; ex:hierarchyID "9.7.5.4.3" ;
    ex:apqcSourceText "Handling customer securities to recover loans that are not paid back." ;
    rdfs:label "Manage customer collateral" ;
    skos:definition "An Act of Financial Transaction in which customer securities held as collateral are realized to recover unpaid loans, with the customer bearing a debtor role." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Reuses shared ex:Customer as participant and ex:FinancialInstrument as the collateral material entity (definitional)." ;
    skos:example "The bank liquidates pledged shares to cover a defaulted margin loan." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialInstrument ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P19587 a owl:Class ;
    ex:pcfID "19587" ; ex:hierarchyID "9.7.5.4.4" ;
    ex:apqcSourceText "Conducting reviews to assess customer credit on a yearly basis. Introduce changes or make recommendations, if needed." ;
    rdfs:label "Perform annual customer credit reviews" ;
    skos:definition "An Act of Appraisal that has as input a credit scoring history and has as output a credit assessment about a customer." ;
    rdfs:comment "Genus cco:ont00000636 (Act of Appraisal; Descriptive output) per GOLDEN PRINCIPLE: a credit review judges creditworthiness. Reuses shared ex:CreditScoringHistory, ex:CreditAssessment, and ex:Customer." ;
    skos:example "Credit risk re-rates a corporate customer at its annual review." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CreditScoringHistory ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CreditAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P20137 a owl:Class ;
    ex:pcfID "20137" ;
    ex:hierarchyID "9.7.5.5" ;
    ex:apqcSourceText "Implementing hedging strategy in attempt to alleviate risk. This will include all options, depravities, and futures contracts agreed upon in Develop risk management/hedging strategy [12974]." ;
    rdfs:label "Execute hedging transactions" ;
    skos:definition "An Organization Capability that is realized in acts of measuring positions, establishing and unwinding hedges, refining hedging positions, and monitoring credit to implement a hedging strategy." ;
    rdfs:comment "R5: heading aggregating discrete hedge-execution tasks -> modeled as Organization Capability (R6) realized in those task processes. Implements the hedging strategy produced by ex:P12974." ;
    skos:example "The desk puts on the futures and options called for by the hedging strategy." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19588 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19589 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19590 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11213 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11215 ] .

ex:P19588 a owl:Class ;
    ex:pcfID "19588" ; ex:hierarchyID "9.7.5.5.1" ;
    ex:apqcSourceText "Evaluating investments made in some market to offset the risks of investing in a contrary or opposing market." ;
    rdfs:label "Measure physical positions" ;
    skos:definition "An Act of Appraisal that has as output a financial risk assessment of the physical positions held to offset opposing-market risk." ;
    rdfs:comment "Genus cco:ont00000636 (Act of Appraisal; Descriptive output): measuring/evaluating positions yields a judgement. Reuses shared ex:RiskAssessment." ;
    skos:example "The desk marks the offsetting commodity position to market." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RiskAssessment ] .

ex:P19589 a owl:Class ;
    ex:pcfID "19589" ; ex:hierarchyID "9.7.5.5.2" ;
    ex:apqcSourceText "Determining which hedge options to execute." ;
    rdfs:label "Establish hedges" ;
    skos:definition "An Act of Selection that determines which hedge options to execute and produces a hedge selection decision prescribing the chosen option(s)." ;
    rdfs:comment "Re-anchored from ex:ActOfFinancialTransaction to ex:ActOfSelection (critical fix). The verbatim source is 'Determining which hedge options to execute' -- i.e. CHOOSING among candidate hedges, a decision/selection act with a directive outcome, not the later execution. GOLDEN PRINCIPLE: the act's product is a directive (a chosen hedge to put on), so genus is ex:ActOfSelection and the output is the Directive ex:HedgeSelectionDecision, NOT a Descriptive TransactionRecord. This aligns the row with its near-identical direct sibling ex:P11213 'Evaluate and refine hedging positions' ('Examining options in the market for hedging investments. Select an option.'), already modeled as ex:ActOfSelection -> ex:HedgeSelectionDecision; the two parallel rows now share one genus. The actual transacting/execution of the chosen hedge is covered by the trade-execution rows (ex:P19582), not by this decision row. REJECTED candidate ex:ActOfFinancialTransaction: it conflated the decision with the later execution and gave a Descriptive output for a directive product." ;
    skos:example "The desk decides which put-option hedge to put on against an equity holding." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HedgeSelectionDecision ] .

ex:P19590 a owl:Class ;
    ex:pcfID "19590" ; ex:hierarchyID "9.7.5.5.3" ;
    ex:apqcSourceText "Closing out a position or cashing in derivatives early." ;
    rdfs:label "Unwind hedges" ;
    skos:definition "An Act of Financial Transaction in which an open hedging position is closed out or derivatives are settled early." ;
    rdfs:comment "Genus ex:ActOfFinancialTransaction (Planned Act). Recording yields a transaction record (Descriptive ICE)." ;
    skos:example "The desk closes a futures hedge ahead of expiry." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P11213 a owl:Class ;
    ex:pcfID "11213" ; ex:hierarchyID "9.7.5.5.4" ;
    ex:apqcSourceText "Examining options in the market for hedging investments. Select an option." ;
    rdfs:label "Evaluate and refine hedging positions" ;
    skos:definition "An Act of Selection that examines available hedging options and has as output a hedge selection decision prescribing the chosen option." ;
    rdfs:comment "Genus ex:ActOfSelection (Directive output) per GOLDEN PRINCIPLE: the act culminates in selecting an option. Output ex:HedgeSelectionDecision minted locally." ;
    skos:example "The desk compares collar structures and selects one to refine the hedge." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HedgeSelectionDecision ] .

ex:P11215 a owl:Class ;
    ex:pcfID "11215" ; ex:hierarchyID "9.7.5.5.5" ;
    ex:apqcSourceText "Revising credit reports periodically for accurateness and changes that could be suggestive of duplicitous activity." ;
    rdfs:label "Monitor credit" ;
    skos:definition "An Act of Monitoring that has as input a credit scoring history and has as output a credit assessment flagging inaccuracies or signs of fraudulent activity." ;
    rdfs:comment "Genus ex:ActOfMonitoring (Descriptive output): periodic review of credit reports yields a judgement. Reuses shared ex:CreditScoringHistory and ex:CreditAssessment." ;
    skos:example "The team rescreens counterparty credit files each quarter." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CreditScoringHistory ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CreditAssessment ] .

ex:P11214 a owl:Class ;
    ex:pcfID "11214" ; ex:hierarchyID "9.7.5.6" ;
    ex:apqcSourceText "Preparing and documenting accounts and records of all hedging investment transactions to reduce risks due to change in markets." ;
    rdfs:label "Produce hedge accounting transactions and reports" ;
    skos:definition "An Act of Reporting that has as input transaction records and has as output a financial report documenting hedging investment activity." ;
    rdfs:comment "Genus ex:ActOfReporting (Descriptive output). Reuses shared ex:TransactionRecord and ex:FinancialReport." ;
    skos:example "Treasury issues the hedge-accounting effectiveness report." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] .

ex:P16958 a owl:Class ;
    ex:pcfID "16958" ;
    ex:hierarchyID "9.7.6" ;
    ex:apqcSourceText "Handling cases that involve financial fraud. Resolve disputes." ;
    rdfs:label "Manage financial fraud/dispute cases" ;
    skos:definition "An Organization Capability that is realized in acts of handling financial-fraud cases and resolving disputes." ;
    rdfs:comment "R5: standing case-handling function with no decomposed children and no natural end -> Organization Capability (R6)." ;
    skos:example "A treasury controls team investigating and resolving suspected payment fraud." ;
    rdfs:subClassOf cco:ont00000568 .

# ================== group 9.8 ==================
# Manage internal controls. 9.8 (PCF 10735) is a standing function ->
# reused ex:InternalControlCapability (realized-in axioms below).

ex:InternalControlCapability rdfs:subClassOf
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10762 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21574 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10764 ] .

ex:P10762 a owl:Class ;
    ex:pcfID "10762" ;
    ex:hierarchyID "9.8.1" ;
    ex:apqcSourceText "Forming rules and regulations to ensure the achievement of effectiveness, proficiency of operations, and reliability of financial reporting." ;
    rdfs:label "Establish internal controls, policies, and procedures" ;
    skos:definition "An Act of Formulation that composes internal-control policies and procedures prescribing the rules that ensure operational effectiveness and reliable financial reporting." ;
    rdfs:comment "Models APQC 9.8.1 as an occurrent. Its APQC children are process parts, not subclasses. Directive outputs (policy + procedure) confirm the Formulation genus (GOLDEN PRINCIPLE)." ;
    skos:example "A controllership team drafts and ratifies the company's internal-control policy and supporting procedures." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InternalControlPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialProcedure ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10914 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10915 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10916 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11250 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11251 ] .

ex:P10914 a owl:Class ;
    ex:pcfID "10914" ;
    ex:hierarchyID "9.8.1.1" ;
    ex:apqcSourceText "Establishing board of directors and auditing committee in order to assign roles and responsibilities for internal controls." ;
    rdfs:label "Establish board of directors and audit committee" ;
    skos:definition "An Act of Organizational Establishment that constitutes and seats a board of directors and audit committee to assign roles and responsibilities for internal controls." ;
    rdfs:comment "Re-anchored from ex:ActOfFormulation to ex:ActOfOrganizationalEstablishment (false-friend fix: 'establish a committee' is not 'formulate a directive'). The lead verb 'Establishing a board / audit committee' primarily denotes CONSTITUTING/SEATING a governance body (an organizational establishment act on independent continuants), not composing-and-articulating a directive ICE. The control-responsibility assignment (ex:ControlResponsibilityAssignment, Directive) is a downstream byproduct of seating the body, not the definitional output of every instance, so it is recorded here per the Phase-3 existential-necessity rule rather than promoted to a has output restriction (which would over-commit and reverse-engineer an output to justify a planning genus). REJECTED candidate ex:ActOfFormulation (Act of Planning): would treat the responsibility directive as the definitional product. The constituted governance body (ex:GovernanceBody, covering the board and audit committee) is the definitional participant. TYPICAL/secondary output (commented, not restricted): ex:ControlResponsibilityAssignment." ;
    skos:example "Shareholders seat an audit committee and document its internal-control oversight mandate." ;
    rdfs:subClassOf ex:ActOfOrganizationalEstablishment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:GovernanceBody ] .

ex:P10915 a owl:Class ;
    ex:pcfID "10915" ;
    ex:hierarchyID "9.8.1.2" ;
    ex:apqcSourceText "Outlining and communicating a code of ethics act responsibly." ;
    rdfs:label "Define and communicate code of ethics" ;
    skos:definition "An Act of Formulation that composes a code of ethics prescribing the standards of responsible conduct for an organization's personnel." ;
    rdfs:comment "Formulation (Directive output ex:CodeOfEthics). The communication step is a typical downstream act, not definitional, so it is noted here rather than restricted." ;
    skos:example "A compliance office drafts the corporate code of ethics and distributes it to staff." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CodeOfEthics ] .

ex:P10916 a owl:Class ;
    ex:pcfID "10916" ;
    ex:hierarchyID "9.8.1.3" ;
    ex:apqcSourceText "Defining roles, responsibilities, and accountabilities for effectiveness and proficiency of operations and reliability of financial reporting." ;
    rdfs:label "Assign roles and responsibility for internal controls" ;
    skos:definition "An Act of Formulation that prescribes the roles, responsibilities, and accountabilities of agents for internal-control effectiveness and reliable financial reporting." ;
    rdfs:comment "Formulation (Directive output ex:ControlResponsibilityAssignment): assigning accountabilities prescribes a control arrangement." ;
    skos:example "A controller documents which positions own each key financial control." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ControlResponsibilityAssignment ] .

ex:P11250 a owl:Class ;
    ex:pcfID "11250" ;
    ex:hierarchyID "9.8.1.4" ;
    ex:apqcSourceText "Outlining the objectives and risks associated with a process. Delineate process goals. Determine the risks attached to it. Determine what the process is meant to accomplish, potential issues, a timeline of potential risks, the scope and potential impact of risks, etc." ;
    rdfs:label "Define business process objectives and risks" ;
    skos:definition "An Act of Formulation that prescribes the control objectives of a business process and produces a risk assessment describing the risks attached to that process." ;
    rdfs:comment "Formulation: the primary output is a Directive process-control objective (GOLDEN PRINCIPLE); the descriptive ex:RiskAssessment is a co-output capturing the determined risks." ;
    skos:example "A process owner documents the objectives of the payroll process and the risks that threaten them." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessControlObjective ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RiskAssessment ] .

ex:P11251 a owl:Class ;
    ex:pcfID "11251" ;
    ex:hierarchyID "9.8.1.5" ;
    ex:apqcSourceText "Outlining the risk tolerance levels of individual units, as well as the organization as a whole. Determine the specific maximum risk to take in quantitative terms for each relevant risk subcategory, including strategic, operational, financial, and compliance risks." ;
    rdfs:label "Define entity/unit risk tolerances" ;
    skos:definition "An Act of Formulation that prescribes the maximum acceptable risk, in quantitative terms, for organizational units and the organization as a whole across risk subcategories." ;
    rdfs:comment "Formulation (Directive output ex:RiskToleranceSpecification): tolerances are binding limits, distinct from a descriptive ex:RiskAssessment of current exposure." ;
    skos:example "A risk committee sets a maximum tolerable compliance-risk threshold for each business unit." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RiskToleranceSpecification ] .

ex:P21574 a owl:Class ;
    ex:pcfID "21574" ;
    ex:hierarchyID "9.8.2" ;
    ex:apqcSourceText "Performing planning, management, operations, and monitoring of internal control mechanism policies and procedures in order to manage internal controls." ;
    rdfs:label "Operate controls and monitor compliance with internal controls policies and procedures" ;
    skos:definition "A Planned Act that operates an organization's internal-control mechanisms and monitors compliance with control policies and procedures, having as process parts the monitoring of control effectiveness and the remediation of control deficiencies." ;
    rdfs:comment "Re-anchored from ex:ActOfMonitoring to cco:ont00000228 (Planned Act) as a composite OPERATE-and-monitor process. The source enumerates 'Performing planning, management, OPERATIONS, and monitoring of internal control mechanism' and the label leads with 'OPERATE controls': operating/running controls is a performative Planned Act, not an information-processing/observation act, so anchoring the whole as ex:ActOfMonitoring captured only the 'monitor' facet and silently dropped the dominant 'operate' facet. This is now consistent with the module's own treatment of the sibling child ex:P10919 ('Remediate'), which was pulled OUT of ex:ActOfMonitoring to cco:ont00000228 because executing a measure is not information-processing. The monitoring facet is carried by the has-process-part ex:P10918 (an ex:ActOfMonitoring that produces ex:ControlEffectivenessAssessment); the ex:ControlEffectivenessAssessment output is therefore NOT asserted as a definitional output of the whole composite (it is produced by the monitoring part, not by the operate-and-monitor process as a whole). Input ex:InternalControlPolicy is the control standard operated and monitored; definitional, so restricted. REJECTED candidate ex:ActOfMonitoring (would scope the whole to pure observation, dropping the operate facet)." ;
    skos:example "An internal-controls team runs the control suite each period and assesses whether procedures were followed." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InternalControlPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10918 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10919 ] .

ex:P10918 a owl:Class ;
    ex:pcfID "10918" ;
    ex:hierarchyID "9.8.2.1" ;
    ex:apqcSourceText "Overseeing the activities for internal controls. Observe the effectiveness of policies, procedures, techniques, and mechanisms actions taken to minimize risk." ;
    rdfs:label "Monitor control effectiveness" ;
    skos:definition "An Act of Monitoring that observes the operation of internal-control policies, procedures, and mechanisms and produces a control-effectiveness assessment of their adequacy in minimizing risk." ;
    rdfs:comment "Monitoring -> Descriptive output ex:ControlEffectivenessAssessment (GOLDEN PRINCIPLE)." ;
    skos:example "An auditor reviews whether reconciliation controls operated as designed and reports their effectiveness." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InternalControlPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ControlEffectivenessAssessment ] .

ex:P10919 a owl:Class ;
    ex:pcfID "10919" ;
    ex:hierarchyID "9.8.2.2" ;
    ex:apqcSourceText "Taking corrective measures for policies, procedures, techniques, and mechanisms actions taken to minimize risk. (Conduct in accordance with Monitor control effectiveness [10918] in order to determine and rectify the control deficiencies.)" ;
    rdfs:label "Remediate control deficiencies" ;
    skos:definition "A Planned Act that takes corrective measures against deficiencies in internal-control policies, procedures, and mechanisms identified by control-effectiveness monitoring." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): remediation executes corrective measures rather than processing information (rejected ex:ActOfMonitoring) or formulating a directive. Input ex:ControlEffectivenessAssessment carries the identified deficiencies; output ex:CorrectiveActionRecord documents the remediation." ;
    skos:example "After a monitoring finding, the team reinstates a missing dual-approval control and logs the fix." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ControlEffectivenessAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CorrectiveActionRecord ] .

ex:P10764 a owl:Class ;
    ex:pcfID "10764" ;
    ex:hierarchyID "9.8.3" ;
    ex:apqcSourceText "Reporting on internal controls compliance to the appropriate authority, including IT regulations and pertinent data." ;
    rdfs:label "Report on internal controls compliance" ;
    skos:definition "An Act of Reporting that communicates an internal-controls compliance report concerning regulatory adherence and pertinent data to the appropriate authority." ;
    rdfs:comment "Reporting -> Descriptive output ex:ComplianceReport (GOLDEN PRINCIPLE). Recipients vary by child process." ;
    skos:example "A compliance officer issues the annual internal-controls compliance report to the relevant stakeholders." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ComplianceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10923 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10924 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10925 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10926 ] .

ex:P10923 a owl:Class ;
    ex:pcfID "10923" ;
    ex:hierarchyID "9.8.3.1" ;
    ex:apqcSourceText "Reporting to external auditors. This process requires the organization to report to external auditors about the regulations for any critical data that the organization is holding." ;
    rdfs:label "Report to external auditors" ;
    skos:definition "An Act of Communication that transmits an already-prepared internal-controls compliance report to external auditors regarding the regulations governing critical data held by the organization." ;
    rdfs:comment "Re-anchored from ex:ActOfReporting to cco:ont00000402 (Act of Communication). The source ('Reporting to external auditors ...') is pure transmission of an already-prepared compliance report whose PRODUCTION is the parent ex:P10764 (9.8.3); the ex:ActOfReporting definition is the production/compilation step and its comment routes transmit-only nodes to cco:ont00000402. The previous has output ex:ComplianceReport over-asserted that each instance independently compiles its OWN report, when all four 9.8.3.x children distribute the single report produced by 9.8.3; ex:ComplianceReport is therefore consumed/transmitted (has input), not produced. Recipient ex:Auditor is the definitional recipient participant. cco:ont00000402 verified against CCO v2.0 (2024-11-06). REJECTED candidate ex:ActOfReporting (§6 false-friend caution: communication-sense vs production-sense)." ;
    skos:example "Management furnishes the external audit firm with its internal-controls compliance report." ;
    rdfs:subClassOf cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ComplianceReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Auditor ] .

ex:P10924 a owl:Class ;
    ex:pcfID "10924" ;
    ex:hierarchyID "9.8.3.2" ;
    ex:apqcSourceText "Reporting to regulators, shareholders, debt holders, securities exchanges, etc. about IT regulations and pertinent data." ;
    rdfs:label "Report to regulators, share-/debt-holders, securities exchanges, etc." ;
    skos:definition "An Act of Communication that transmits an already-prepared internal-controls compliance report to regulators, shareholders, debt holders, and securities exchanges, producing in the process a regulatory filing of the pertinent data." ;
    rdfs:comment "Re-anchored from ex:ActOfReporting to cco:ont00000402 (Act of Communication), consistent with its 9.8.3.x transmit-only siblings ex:P10923/ex:P10925/ex:P10926. The compliance report is produced by the parent ex:P10764 (9.8.3) and merely transmitted here, so ex:ComplianceReport is has input, not has output. EXCEPTION retained per the Gate-F note: ex:RegulatoryFiling IS genuinely compiled/produced in the act of filing with the regulator, so it is kept as a has output. Recipient ex:RegulatoryAuthority is the definitional recipient participant. cco:ont00000402 verified against CCO v2.0 (2024-11-06). REJECTED candidate ex:ActOfReporting for the compliance-report transmission (§6 false-friend caution)." ;
    skos:example "A listed company files its internal-controls compliance attestation with the securities regulator and notifies bondholders." ;
    rdfs:subClassOf cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ComplianceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryFiling ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryAuthority ] .

ex:P10925 a owl:Class ;
    ex:pcfID "10925" ;
    ex:hierarchyID "9.8.3.3" ;
    ex:apqcSourceText "Reporting to suppliers, customers, and partners that are doing business with the company about IT regulations and pertinent data." ;
    rdfs:label "Report to third parties" ;
    skos:definition "An Act of Communication that transmits an already-prepared internal-controls compliance report to suppliers, customers, and business partners regarding IT regulations and pertinent data." ;
    rdfs:comment "Re-anchored from ex:ActOfReporting to cco:ont00000402 (Act of Communication), consistent with its 9.8.3.x transmit-only siblings. The compliance report is produced by the parent ex:P10764 (9.8.3) and only distributed here, so ex:ComplianceReport is has input, not has output. Recipients ex:Supplier and ex:Customer are the definitional recipient participants. cco:ont00000402 verified against CCO v2.0 (2024-11-06). REJECTED candidate ex:ActOfReporting (§6 false-friend caution)." ;
    skos:example "A vendor-management team shares the firm's data-controls compliance summary with key suppliers." ;
    rdfs:subClassOf cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ComplianceReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Supplier ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P10926 a owl:Class ;
    ex:pcfID "10926" ;
    ex:hierarchyID "9.8.3.4" ;
    ex:apqcSourceText "Reporting to internal management (all employees, directors, and management) about IT regulations and pertinent data." ;
    rdfs:label "Report to internal management" ;
    skos:definition "An Act of Communication that transmits an already-prepared internal-controls compliance report to an organization's employees, directors, and management regarding IT regulations and pertinent data." ;
    rdfs:comment "Re-anchored from ex:ActOfReporting to cco:ont00000402 (Act of Communication), consistent with its 9.8.3.x transmit-only siblings. The compliance report is produced by the parent ex:P10764 (9.8.3) and only distributed here, so ex:ComplianceReport is has input, not has output. Recipient ex:Employee (covering staff, directors, and management as internal personnel) is the definitional recipient participant. cco:ont00000402 verified against CCO v2.0 (2024-11-06). REJECTED candidate ex:ActOfReporting (§6 false-friend caution)." ;
    skos:example "Leadership circulates an internal memo summarizing the company's controls-compliance status to all staff." ;
    rdfs:subClassOf cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ComplianceReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

# ================== group 9.9 ==================
# Manage taxes. 9.9 (PCF 10736) is a standing function -> reused
# ex:TaxManagementCapability (bridged in section 4).

ex:P10765 a owl:Class ;
    ex:pcfID "10765" ; ex:hierarchyID "9.9.1" ;
    ex:apqcSourceText "Setting targets for periodic tax liabilities. Assess the tax impact of various activities such as the acquisition or disposal of fixed assets or a deliberate change in number of employee." ;
    rdfs:label "Develop tax strategy and plan" ;
    skos:definition "An Act of Formulation that sets targets for the organization's periodic tax liabilities and produces a tax strategy prescribing how those liabilities are to be planned and met." ;
    rdfs:comment "R5=process. Genus ex:ActOfFormulation (planning -> directive output) per GOLDEN PRINCIPLE. Assessment of tax impact of activities is a typical sub-step, recorded here rather than as a restriction (Phase-3 necessity)." ;
    skos:example "A tax department sets next year's effective-tax-rate target and documents the plan to achieve it." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10927 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10928 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10929 ] .

ex:P10927 a owl:Class ;
    ex:pcfID "10927" ; ex:hierarchyID "9.9.1.1" ;
    ex:apqcSourceText "Developing a tax strategy for foreign, national, state, local administration. Set up tax strategies for foreign trade in imports and exports and at national, state, and local level." ;
    rdfs:label "Develop foreign, national, state, and local tax strategy" ;
    skos:definition "An Act of Formulation that composes a tax strategy governing the organization's tax position across foreign, national, state, and local jurisdictions." ;
    rdfs:comment "R5=process. Directive output (Tax Strategy) -> ex:ActOfFormulation." ;
    skos:example "A multinational drafts a transfer-pricing and import/export tax strategy spanning its operating jurisdictions." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxStrategy ] .

ex:P10928 a owl:Class ;
    ex:pcfID "10928" ; ex:hierarchyID "9.9.1.2" ;
    ex:apqcSourceText "Combining and enhancing a rational analysis of a financial condition or plan from a tax perspective in order to align financial goals through efficient tax planning." ;
    rdfs:label "Consolidate and optimize total tax plan" ;
    skos:definition "An Act of Formulation that combines and optimizes the organization's component tax plans into a single total tax plan aligning financial goals through efficient tax planning." ;
    rdfs:comment "R5=process. Although it draws on prior analysis of financial condition (a typical input, left as comment per Phase-3), its product is a consolidated directive plan, so genus is ex:ActOfFormulation." ;
    skos:example "A finance team merges per-jurisdiction tax strategies into one optimized group tax plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxStrategy ] .

ex:P10929 a owl:Class ;
    ex:pcfID "10929" ; ex:hierarchyID "9.9.1.3" ;
    ex:apqcSourceText "Maintaining a master file about the rational analysis of a financial condition or plan from a tax perspective in order to align financial goals through efficient tax planning." ;
    rdfs:label "Maintain tax master data" ;
    skos:definition "An Act of Accounting that maintains and updates the tax master data file recording the reference data underpinning the organization's tax planning." ;
    rdfs:comment "R5=process. Descriptive output (Tax Data master file). Re-anchored from the bare cco:ont00000366 to ex:ActOfAccounting (which is itself subClassOf cco:ont00000366): the earlier 'No shared maintain genus fits' claim was false. ex:ActOfAccounting is defined as an act that 'produces or UPDATES a Descriptive ICE ... such as a ledger, journal, or account record', and its PROPOSE-EXT scope explicitly lists 'maintain ledgers/master files' -- 'Maintaining a master file' is exactly that pattern. Anchoring this master-file-maintenance act to the bare parent while its descriptive-output siblings ex:P10933 and ex:P10934 (also output ex:TaxData) use ex:ActOfAccounting was an avoidable inconsistency. Descriptive output agrees with the info-processing genus (GOLDEN PRINCIPLE)." ;
    skos:example "A tax analyst updates jurisdiction codes and rates in the tax master file each quarter." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxData ] .

ex:P10766 a owl:Class ;
    ex:pcfID "10766" ; ex:hierarchyID "9.9.2" ;
    ex:apqcSourceText "Processing the taxes of the organization in line with the regional taxation structure, including corporate, property, excise, and service taxes." ;
    rdfs:label "Process taxes" ;
    skos:definition "A Planned Act that carries out the organization's tax obligations in line with the regional taxation structure -- encompassing corporate, property, excise, and service taxes -- and that has as process parts the planning, filing, accounting, monitoring, and payment of those taxes." ;
    rdfs:comment "Re-anchored from ex:ActOfFinancialTransaction to the neutral cco:ont00000228 (Planned Act), and the has output ex:TaxReturn existential DROPPED. Two coupled defects fixed: (1) GENUS/OUTPUT disagreement -- ex:ActOfFinancialTransaction is a money-transfer act, yet the sole asserted output was ex:TaxReturn, a Descriptive reporting product (the 'pay' genus and the 'file' output describe two different acts). (2) The node is a standing file-and-pay umbrella: the source ('Processing the taxes ... corporate, property, excise, service taxes') and example ('runs the quarterly cycle that files and pays all taxes') span both filing and payment, and NONE of its seven children is itself an ex:ActOfFinancialTransaction (10930 Formulation, 10931/10932/10936 Reporting, 10933/10934 Accounting, 10935 Monitoring) -- so the transaction genus was not exemplified by any part. No single definitional output spans both filing and payment, so the umbrella carries none; ex:TaxReturn (filing) and Monetary Payment (payment) are produced by the respective children. REJECTED candidate ex:ActOfFinancialTransaction (over-commits to the 'pay' facet)." ;
    skos:example "A finance shared-service center runs the quarterly cycle that files and pays all corporate and indirect taxes." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10930 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10931 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10932 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10933 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10934 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10935 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10936 ] .

ex:P10930 a owl:Class ;
    ex:pcfID "10930" ; ex:hierarchyID "9.9.2.1" ;
    ex:apqcSourceText "Creating and implementing strategies for taxes to be paid or collected by the business." ;
    rdfs:label "Perform tax planning/strategy" ;
    skos:definition "An Act of Formulation that creates strategies for the taxes to be paid or collected by the organization and prescribes their implementation." ;
    rdfs:comment "R5=process. Directive output (Tax Strategy) -> ex:ActOfFormulation. The implementation aspect is carried out by the sibling transaction/accounting processes; here the definitional product is the strategy." ;
    skos:example "A tax team designs a strategy for collecting and remitting indirect taxes on sales." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxStrategy ] .

ex:P10931 a owl:Class ;
    ex:pcfID "10931" ; ex:hierarchyID "9.9.2.2" ;
    ex:apqcSourceText "Preparing and submitting tax reports for every employee to the tax department in order to show the tax paid and deducted from their salaries in the year." ;
    rdfs:label "Prepare tax returns" ;
    skos:definition "An Act of Reporting that prepares and submits a tax return reporting the tax paid by and deducted on behalf of the organization and its employees to the relevant tax authority." ;
    rdfs:comment "R5=process. Descriptive output (Tax Return) -> ex:ActOfReporting. Employees are subjects of the per-employee filings (typical participant, left as comment); Tax Data is a typical input." ;
    skos:example "Payroll files year-end employee tax statements with the tax department." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxReturn ] .

ex:P10932 a owl:Class ;
    ex:pcfID "10932" ; ex:hierarchyID "9.9.2.3" ;
    ex:apqcSourceText "Preparing reports about paid or accrued foreign taxes to an overseas country." ;
    rdfs:label "Prepare foreign taxes" ;
    skos:definition "An Act of Reporting that prepares a tax return reporting the foreign taxes paid or accrued by the organization to an overseas taxing jurisdiction." ;
    rdfs:comment "R5=process. Descriptive output (Tax Return covering foreign tax) -> ex:ActOfReporting." ;
    skos:example "A subsidiary's controller prepares the foreign-tax accrual report for an overseas jurisdiction." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxReturn ] .

ex:P10933 a owl:Class ;
    ex:pcfID "10933" ; ex:hierarchyID "9.9.2.4" ;
    ex:apqcSourceText "Calculating the income that has been realized when the tax on that income has not." ;
    rdfs:label "Calculate deferred taxes" ;
    skos:definition "An Act of Accounting that computes the organization's deferred tax positions arising where income is recognized in a period different from the period in which the related tax is incurred, producing tax data on those positions." ;
    rdfs:comment "R5=process. Descriptive output (Tax Data) -> ex:ActOfAccounting (info-processing genus; agrees with descriptive output). Financial data is a typical input." ;
    skos:example "An accountant computes the deferred tax liability from timing differences between book and tax depreciation." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxData ] .

ex:P10934 a owl:Class ;
    ex:pcfID "10934" ; ex:hierarchyID "9.9.2.5" ;
    ex:apqcSourceText "Managing the organization's financial accounts for the purpose of taxation. Prepare and maintain the tax paid by the organization to the country they have business in." ;
    rdfs:label "Account for taxes" ;
    skos:definition "An Act of Accounting that maintains the organization's financial accounts for tax purposes and records the tax paid in each country in which it operates, producing tax data." ;
    rdfs:comment "R5=process. Descriptive output (Tax Data) -> ex:ActOfAccounting. General ledger / financial data are typical inputs (left as comment per Phase-3)." ;
    skos:example "A controller books and reconciles the tax accounts at period close." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxData ] .

ex:P10935 a owl:Class ;
    ex:pcfID "10935" ; ex:hierarchyID "9.9.2.6" ;
    ex:apqcSourceText "Checking and correcting the tax policies according to the rules and regulations set by the organization." ;
    rdfs:label "Monitor tax compliance" ;
    skos:definition "An Act of Monitoring that checks the organization's tax policies and practices against applicable rules and regulations and produces a compliance report identifying and prompting correction of deviations." ;
    rdfs:comment "R5=process. Descriptive output (Compliance Report) -> ex:ActOfMonitoring. Tax Data / Financial Policy are typical inputs (left as comment per Phase-3)." ;
    skos:example "An internal-controls reviewer audits VAT treatment against the tax code and flags exceptions." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ComplianceReport ] .

ex:P10936 a owl:Class ;
    ex:pcfID "10936" ; ex:hierarchyID "9.9.2.7" ;
    ex:apqcSourceText "Addressing any tax queries by any regulatory or government authorities. Review historical records related to taxation within the organization in order to respond to queries." ;
    rdfs:label "Address tax inquiries" ;
    skos:definition "An Act of Reporting that reviews the organization's historical taxation records and produces a tax inquiry response answering a query raised by a regulatory or government authority." ;
    rdfs:comment "R5=process. Descriptive output (Tax Inquiry Response) -> ex:ActOfReporting. The Regulatory Authority that raised the query is definitional to the act, so it is a participant restriction; reviewed historical records (Tax Data) are a typical input left as comment." ;
    skos:example "A tax manager researches prior filings and replies to an information request from the revenue authority." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TaxInquiryResponse ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryAuthority ] .

# ================== group 9.10 ==================
# Manage international funds/consolidation. 9.10 (PCF 10737) ->
# ex:InternationalFundsManagementCapability (in 2g).

ex:P10767 a owl:Class ;
    ex:pcfID "10767" ;
    ex:hierarchyID "9.10.1" ;
    ex:apqcSourceText "Forecasting and monitoring changes in foreign currency value or interest rates around the world that play an important role in the organization." ;
    rdfs:label "Monitor international rates" ;
    skos:definition "An Act of Monitoring that has as input market rate data and has as output a financial forecast describing anticipated changes in foreign-currency values and interest rates relevant to the organization." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (cco:ont00000366). GOLDEN PRINCIPLE: monitoring/forecasting yields a Descriptive ICE (the forecast), not a directive." ;
    skos:example "A treasury analyst tracks global FX and interest-rate movements and issues a weekly currency-rate forecast." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketRateData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialForecast ] .

ex:P10768 a owl:Class ;
    ex:pcfID "10768" ;
    ex:hierarchyID "9.10.2" ;
    ex:apqcSourceText "Managing any transfer of funds in the course of conducting cross-border trades or investments, including conversion across currencies. Find the most suitable alternative for making payments, while saving taxes and avoiding any unwarranted regulation, with the objective of protecting capital." ;
    rdfs:label "Manage transactions" ;
    skos:definition "An Act of Financial Transaction that transfers funds across borders in the course of trade or investment, converting between currencies, and produces a monetary payment and a record of the transaction." ;
    rdfs:comment "Anchored to ex:ActOfFinancialTransaction (cco:ont00000228). Operations process: the transferred funds are a MATERIAL participant (ex:PaymentInstrument via obo:BFO_0000057, not has output); the audit record is the informational has output (ex:TransactionRecord). Tax-optimization and regulatory-avoidance objectives are typical sub-considerations, recorded here rather than as definitional restrictions." ;
    skos:example "A treasury operation converts EUR to USD and remits an intercompany payment to settle a cross-border purchase." ;
    rdfs:subClassOf ex:ActOfFinancialTransaction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:PaymentInstrument ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TransactionRecord ] .

ex:P10769 a owl:Class ;
    ex:pcfID "10769" ;
    ex:hierarchyID "9.10.3" ;
    ex:apqcSourceText "Assessing exposure to potential financial losses as a result of changes in the value of currencies. Forecast the impact of movements in foreign currency values. Enter into financial transactions designed to offset or limit potential exposure to loss." ;
    rdfs:label "Monitor currency exposure/hedge currency" ;
    skos:definition "An Act of Analysis that examines market rate data and produces a financial risk assessment and a financial forecast describing the organization's exposure to losses from movements in foreign-currency values." ;
    rdfs:comment "Re-anchored from ex:ActOfMonitoring to ex:ActOfAnalysis (false-friend on the label word 'Monitor'). The source verb is 'Assessing exposure to potential financial losses ... Forecast the impact of movements' -- a bounded discernment/judgement producing a risk assessment and forecast, i.e. analysis, not continuous status-observation against expected parameters (the ex:ActOfMonitoring differentia, which fits standing oversight such as ex:P19583). This aligns the exposure-assessment core with the methodology's parallel treatment of identical content in 9.7.5: ex:P19580 'Determine foreign exchange exposure' and ex:P19576 'Determine interest rate exposure', both ex:ActOfAnalysis producing ex:RiskAssessment from ex:MarketRateData (D2 sibling/parallel-row consistency). HEDGING FACET (second defect, intentionally collapsed at 9.10's coarse grain): the label is compound ('...hedge currency') and the source's third sentence ('Enter into financial transactions designed to offset or limit potential exposure to loss') names hedging as a core facet. APQC 9.10 is modeled coarse-grained and does NOT mint separate child rows for it; the hedge decision and execution are first-class acts in the finer-grained 9.7.5 decomposition -- ex:P19581 (ex:ActOfSelection -> Directive ex:HedgeRequirementSpecification, the decision-to-hedge / GOLDEN-PRINCIPLE directive facet) and ex:P19582 (ex:ActOfFinancialTransaction, trade execution). This row is therefore scoped to the assessment/forecast facet and cross-references that decomposition rather than mislabelling hedging as a mere non-definitional 'typical consequence'. REJECTED candidate ex:ActOfMonitoring (continuous-oversight reading; diverges from the 9.7.5 siblings)." ;
    skos:example "A treasurer measures net open EUR exposure and forecasts its loss potential (the offsetting hedge decision/execution being modeled finer-grained at 9.7.5: ex:P19581 / ex:P19582)." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketRateData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RiskAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialForecast ] .

ex:P10770 a owl:Class ;
    ex:pcfID "10770" ;
    ex:hierarchyID "9.10.4" ;
    ex:apqcSourceText "Documenting and reporting accounting entries to formally report financial gains or losses experienced as a result of foreign exchange activity." ;
    rdfs:label "Report results" ;
    skos:definition "An Act of Reporting that has as input transaction records of foreign-exchange accounting entries and has as output a financial report that formally states the gains or losses realized from foreign-exchange activity." ;
    rdfs:comment "Anchored to ex:ActOfReporting (cco:ont00000366). GOLDEN PRINCIPLE: reporting produces a Descriptive ICE (the financial report). The accounting entries reported on are modeled as ex:TransactionRecord inputs." ;
    skos:example "Accounting documents realized FX gains and issues the period's foreign-exchange results report." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TransactionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReport ] .

# ================== group 9.11 ==================
# Perform global trade services. 9.11.2 (PCF 14091) and 9.11.9
# (PCF 14097) are standing functions -> ex:ImportExportControlCapability
# and ex:RestitutionManagementCapability (in 2g); not process parts.

ex:P17059 a owl:Class ;
    ex:pcfID "17059" ;
    ex:hierarchyID "9.11" ;
    ex:apqcSourceText "Making and collecting payments for transactions in products/services, and transporting them to interested markets." ;
    rdfs:label "Perform global trade services" ;
    skos:definition "A Planned Act in which an organization services an international-trade transaction by screening parties, classifying and documenting goods, converting currency, calculating and clearing customs duties, and arranging payment instruments so that products and services can be exchanged across markets." ;
    rdfs:comment "Models APQC process group 9.11 as a bounded occurrent. Anchored at the generic cco:ont00000228 (Planned Act) because the group bundles heterogeneous acts (financial transactions, information processing, communication, formulation) with no single dominant genus. Its APQC dotted children are process parts (cco:ont00001777); the two standing-function children (Control exports/imports; Handle restitution) are modeled as Organization Capabilities and are therefore not process parts." ;
    skos:example "An exporter's end-to-end handling of a cross-border shipment, from sanctions screening through customs clearance and letter-of-credit settlement." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14090 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14092 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19593 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14093 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14094 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14095 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14096 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14098 ] .

ex:P14090 a owl:Class ;
    ex:pcfID "14090" ; ex:hierarchyID "9.11.1" ;
    ex:apqcSourceText "Evaluating the approved list of parties for engaging in international trade in order to ensure the safety of the organization's business transactions. Examine agents that have been granted legal rights to engage in global trade and their credentials." ;
    rdfs:label "Screen sanctioned party list" ;
    skos:definition "An Act of Appraisal that has as input a sanctioned party list and has as output a sanctioned-party screening result judging whether the parties to a prospective transaction are cleared to engage in international trade." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal) because the act evaluates and judges parties against an approved list; its output is a Descriptive ICE (a clearance judgement), satisfying the GOLDEN PRINCIPLE." ;
    skos:example "A compliance officer screens both counterparties of a shipment against the denied-parties list before release." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SanctionedPartyList ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SanctionedPartyScreeningResult ] .

ex:P14092 a owl:Class ;
    ex:pcfID "14092" ; ex:hierarchyID "9.11.3" ;
    ex:apqcSourceText "Systematically categorizing products/services for their suitability to international trade. Create classes and categories for demarcating the types of products suitable for international trade. Study requisite national and international standards and the adherence of the organization's portfolio of offerings to these." ;
    rdfs:label "Classify products" ;
    skos:definition "An Act of Analysis that examines an organization's products and services against national and international trade standards and has as output a product trade classification." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (subClassOf cco:ont00000366) because categorizing offerings against standards processes input information into a classification ICE; the Descriptive output satisfies the GOLDEN PRINCIPLE." ;
    skos:example "A trade analyst assigns HS tariff codes to each item in the product catalogue." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductClassification ] .

ex:P19593 a owl:Class ;
    ex:pcfID "19593" ; ex:hierarchyID "9.11.4" ;
    ex:apqcSourceText "Identifying current exchange rates between two currencies and converting the foreign currency to that of the local monetary unit. I.E., yen to US dollar." ;
    rdfs:label "Perform currency conversion" ;
    skos:definition "An Act of Analysis that examines market rate data to convert a monetary amount from a foreign currency to the local monetary unit, producing a currency conversion record." ;
    rdfs:comment "Re-anchored from ex:ActOfFinancialTransaction to ex:ActOfAnalysis (subClassOf cco:ont00000366) (genus/output mismatch + false-friend fix). The source ('Identifying current exchange rates between two currencies and converting the foreign currency to that of the local monetary unit') and the output ex:CurrencyConversionRecord (a Descriptive ICE) describe a COMPUTATION that identifies rates and produces a record of the equivalent amount -- no money or Financial Instrument is actually transferred between agents, so ex:ActOfFinancialTransaction's differentia ('transfers money or a Financial Instrument ... in settlement') is not satisfied ('conversion' is a false friend for a financial act). GOLDEN PRINCIPLE: a Descriptive-record output pairs with an information-processing genus. Note also that ex:ActOfFinancialTransaction itself rejected cco:ont00000366 on the ground that 'a payment moves a material/financial-instrument filler, not only an ICE' -- this act has only an ICE output, confirming it does not fit the transaction genus. ex:MarketRateData (current exchange rates) is the definitional input; the conversion record is the Descriptive output. REJECTED candidate ex:ActOfFinancialTransaction (reserved for nodes that actually move money/instruments between agents, e.g. 9.5/9.6 disbursement and 9.11 settlement nodes)." ;
    skos:example "Converting an invoice denominated in yen into US dollars at the current spot rate." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketRateData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CurrencyConversionRecord ] .

ex:P14093 a owl:Class ;
    ex:pcfID "14093" ; ex:hierarchyID "9.11.5" ;
    ex:apqcSourceText "Computing the excise duty to be paid during international trade." ;
    rdfs:label "Calculate duty" ;
    skos:definition "An Act of Accounting that computes the excise duty payable on an international-trade transaction and has as output a duty calculation." ;
    rdfs:comment "Anchored to ex:ActOfAccounting (subClassOf cco:ont00000366) because computing duty owed is a financial calculation that processes input information into a numeric Descriptive ICE, satisfying the GOLDEN PRINCIPLE." ;
    skos:example "A customs broker computes the excise duty owed on a consignment before clearance." ;
    rdfs:subClassOf ex:ActOfAccounting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DutyCalculation ] .

ex:P14094 a owl:Class ;
    ex:pcfID "14094" ; ex:hierarchyID "9.11.6" ;
    ex:apqcSourceText "Communicating with the customs department to ensure fluid compliance. Share pertinent information mandated by law with the government agency that controls and collects the duties levied for the international exchange of products/services." ;
    rdfs:label "Communicate with customs" ;
    skos:definition "An Act of Communication in which an organization transfers customs information to the government customs authority in order to ensure compliance with international-trade law." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): an ICE (legally-mandated trade particulars) is transferred from one Agent to another. The Regulatory Authority is the definitional recipient; customs information is the definitional transferred ICE. Explicit rdfs:subClassOf cco:ont00000228 (Planned Act) added so the act-anchor chain is visible to the standalone SHACL run (ont00000402 is a CCO subclass of ont00000228, but the closure is not merged for Gate C)." ;
    skos:example "Filing the mandated electronic declaration with the national customs agency for a shipment." ;
    rdfs:subClassOf cco:ont00000402 ,
        cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomsInformation ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryAuthority ] .

ex:P14095 a owl:Class ;
    ex:pcfID "14095" ; ex:hierarchyID "9.11.7" ;
    ex:apqcSourceText "Documenting and recording the trade processes while making transactions, noting the description, quality, number, transportation medium, indemnity, and inspection." ;
    rdfs:label "Document trade" ;
    skos:definition "An Act of Reporting that records the particulars of a trade transaction -- including description, quality, quantity, transport medium, indemnity, and inspection -- and has as output trade documentation." ;
    rdfs:comment "Anchored to ex:ActOfReporting (subClassOf cco:ont00000366) because documenting/recording a trade gives a detailed account that processes input information into a Descriptive ICE, satisfying the GOLDEN PRINCIPLE." ;
    skos:example "A logistics clerk records the bill of lading, packing list, and inspection certificate for a shipment." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TradeDocumentation ] .

ex:P14096 a owl:Class ;
    ex:pcfID "14096" ; ex:hierarchyID "9.11.8" ;
    ex:apqcSourceText "Preparing global trade under preference, which allows the organization to import/export products at a lower or nil rate of customs duty and/or levy charge." ;
    rdfs:label "Process trade preferences" ;
    skos:definition "An Act of Reporting that prepares the documentation establishing a shipment's eligibility for trade under preference and has as output trade preference documentation." ;
    rdfs:comment "Anchored to ex:ActOfReporting (subClassOf cco:ont00000366): preparing trade-under-preference paperwork records eligibility, processing input information into a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "Preparing a certificate of origin to claim a preferential tariff under a free-trade agreement." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TradePreferenceDocumentation ] .

ex:P14098 a owl:Class ;
    ex:pcfID "14098" ; ex:hierarchyID "9.11.10" ;
    ex:apqcSourceText "Creating a document assuring that a seller will receive payment when certain delivery conditions are met. (If the buyer is unable to make payment on the purchase, a bank covers the outstanding amount.)" ;
    rdfs:label "Prepare letter of credit" ;
    skos:definition "An Act of Formulation that composes a letter of credit prescribing the conditions under which a bank guarantees payment to a seller upon fulfilment of specified delivery conditions." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (inlined, subClassOf cco:ont00000511, Act of Planning) because creating a letter of credit composes a Directive ICE that prescribes a payment guarantee, satisfying the GOLDEN PRINCIPLE." ;
    skos:example "A bank issues a documentary letter of credit guaranteeing payment to an exporter on presentation of shipping documents." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LetterOfCredit ] .

