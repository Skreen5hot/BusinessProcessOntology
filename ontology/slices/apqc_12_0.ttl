@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC PCF -> BFO 2020 / CCO 2.0  REALITY-LAYER MODULE
# Slice 12.0 "Manage External Relationships"
#
# Assembled from the five process-group transforms (12.1 investor
# relationships, 12.2 government and industry relationships, 12.3
# board-of-directors relations, 12.4 legal and ethical issues,
# 12.5 public relations program) over a single shared supporting-
# vocabulary layer.
#
# CCO pin: v2.0 (2024-11-06). Every cco:ont... IRI below was verified
# against vendor/cco/CommonCoreOntologiesMerged.ttl (label +
# definition + parent read, not just the label). Two-layer model and
# the R5 bounded-occurrent test per ADR-001.
#
# RECONCILIATION NOTE: the per-group transforms each emitted a local
# copy of the recurring act genera, occasionally under divergent
# parents. They are reconciled here to ONE coherent definition each,
# matching the section CONTEXT PROPOSE-EXT block (the binding spec):
#   ex:ActOfRelationshipManagement -> cco:ont00000433 (Act of Association)
#   ex:ActOfMonitoring             -> cco:ont00000366 (Act of Info Processing)
#   ex:ActOfNegotiation            -> cco:ont00001327 (Social Act)
#   ex:ActOfPayment                -> cco:ont00000836 (Act of Financial Instrument Use)
#   ex:ActOfReporting              -> cco:ont00000379 (Act of Representative Communication)
####################################################################

<http://example.org/apqc/slice/12.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 12.0: Manage External Relationships" ;
    dct:source "APQC Process Classification Framework (Cross-Industry)" ;
    owl:versionInfo "0.1.0" ;
    rdfs:comment "Reality-layer module for APQC section 12.0. CCO pin v2.0 (2024-11-06). Modeling rules per ADR-001 (two-layer model, R5 bounded-occurrent test, GOLDEN PRINCIPLE). New recurring genera (ex:ActOfRelationshipManagement, ex:ActOfMonitoring, ex:ActOfNegotiation, ex:ActOfPayment, ex:ActOfReporting) are emitted below as PROPOSE-EXT for human promotion. Self-contained: the shared act genera it uses are inlined from the apqc-ext.ttl registry, so it validates standalone against the pinned CCO/BFO closure with no extension merge." .

####################################################################
# ACT GENERA -- SELF-CONTAINED (canonical defs mirrored from
# apqc-ext.ttl, the D9 shared registry). Inlined so this module
# validates standalone against CCO without merging the extension.
####################################################################

ex:ActOfAcquisition a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Acquisition" ;
    skos:definition "A Planned Act in which an Agent obtains from some authority or supplier an entity (such as an authorization, license, or resource) that the Agent did not previously hold." ;
    rdfs:comment "Local extension (D9). Rejected cco:ont00000950 'Act of Maintenance' (modifying Material Artifacts) and cco:ont00000402 'Act of Communication' (mere ICE transfer). Securing/obtaining a held entity anchors at the generic Planned Act. Expected to recur in procurement/asset-acquisition categories (4.0, 10.0)." .

ex:ActOfAdvocacy a owl:Class ;
    rdfs:subClassOf cco:ont00001327 ,   # Social Act
        cco:ont00000228 ;               # Planned Act (explicit allowlist anchor; Social Act ont00001327 ⊑ Planned Act ont00000228 in the CCO closure)
    rdfs:label "Act of Advocacy" ;
    skos:definition "A Social Act in which an Agent promotes, encourages, or supports a cause, position, or change in the societal or political environment through campaigns, programs, or public engagement, on behalf of an organization." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00001327 'Social Act' (verified: 'A Planned Act having an objective that affects, is performed by, or is performed on behalf of, a community or group of Persons'; parent cco:ont00000228) because advocacy/promotion targets a community or society rather than uniting with a single counterpart. Evaluated cco:ont00000079 'Act of Social Movement' (verified: 'A Social Act composed of a series of performances, displays and campaigns directed at implementing, resisting or undoing a change in society') as the nearest sibling: it fits campaign-driven activism but is narrower than the general supporting/promoting intent here (supporting civic programs and connection platforms is not necessarily a movement to undo a societal change), so a dedicated advocacy genus is minted under the shared Social Act parent. Rejected cco:ont00000433 'Act of Association' (a bilateral uniting-with-an-Agent, whereas advocacy influences a societal/political environment rather than uniting into a shared enterprise). Recurs across promote/encourage/support-the-environment nodes (12.0)." .

ex:ActOfFormulation a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Formulation" ;
    skos:definition "An Act of Planning in which an Agent composes and articulates a Directive Information Content Entity - such as a mission, strategy, objective, design, roadmap, or business model - that prescribes an organization's intended course of action." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000511 (Act of Planning) because formulating a strategy/mission/design is making a plan to achieve an objective; its output is a Directive ICE. Recurs across develop/define/compose-a-directive processes corpus-wide." .

ex:ActOfMonitoring a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Monitoring" ;
    skos:definition "An Act of Information Processing in which an Agent repeatedly or continuously observes the state, progress, or performance of some process, system, or quantity over time and produces a Descriptive Information Content Entity that represents its tracked status against expected conditions, targets, or requirements." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic monitoring/tracking class. Anchored under cco:ont00000366 (Act of Information Processing) because monitoring ingests repeated observations (including electronic records, not only senses) and yields a descriptive status/deviation ICE -- the GOLDEN PRINCIPLE (descriptive output => information-processing genus) holds. Rejected cco:ont00000037 (Act of Observation: a single sense-based acquisition, too narrow -- monitoring also processes ICEs and is sustained); cco:ont00000636 (Act of Appraisal: renders a single bounded value/quality judgement rather than tracking status over time); and cco:ont00000345 (Act of Measuring: a single quantification against a standard at one time -- at most a method sub-step of the monitoring cycle; a node that is purely one quantification, e.g. Calculate performance measures, anchors to cco:ont00000345 directly, not here). Distinct from ex:ActOfAnalysis (one-shot examination of a fixed input set) by its continuous, longitudinal character. A standing 'Manage/Monitor X' function with no natural end is an Organization Capability (cco:ont00000568) realized in such acts, not itself a process. Recurs corpus-wide (slices 3.0/4.0/5.0/6.0/8.0/9.0/10.0/11.0/12.0/13.0). Reconciled from 10 divergent slice restatements to one definition." .

ex:ActOfNegotiation a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Negotiation" ;
    skos:definition "A Planned Act in which two or more Agents confer and bargain over terms and conditions, exchanging proposals and concessions, in order to reach and record a mutually binding Directive Information Content Entity such as an agreement or contract." ;
    rdfs:comment "PROPOSE-EXT (D9). ANCHOR CONFLICT RESOLVED: slices 7.0 and 10.0 anchored under cco:ont00000228 (Planned Act); slice 12.0 added cco:ont00001327 as a parent. CHOSEN cco:ont00000228 'Planned Act' (verified: 'An Act in which at least one Agent plays a causative role and which is prescribed by some Prescriptive Information Content Entity held by at least one of the Agents'). FALSE-FRIEND CORRECTION: the consolidation note flagged cco:ont00001327 as 'Act of Social Movement (WRONG)', but verification of the closure shows cco:ont00001327 is actually 'Social Act' (def: 'A Planned Act having an objective that affects, is performed by, or is performed on behalf of, a community or group of Persons'; parent cco:ont00000228) -- 'Act of Social Movement' is the DIFFERENT IRI cco:ont00000079 (⊑ ont00001327). The premise of the rejection was thus mistaken, but cco:ont00001327 'Social Act' is still rejected on its merits: negotiation is bilateral bargaining between specific counterparties toward an agreement, not an act whose objective is directed at a community/group of Persons, so the Social-Act differentia does not fit. The neutral Planned Act (cco:ont00000228) is the nearest correct, non-over-committing anchor; its definitional output is a Directive ICE (the agreement), satisfying the GOLDEN PRINCIPLE. Also rejected cco:ont00000511 (Act of Planning: single-agent composition of a plan, whereas negotiation needs two or more parties jointly authoring the directive); cco:ont00000402 (Act of Communication: a one-directional ICE transfer, not bilateral term-setting toward agreement); cco:ont00001162 (Act of Commissive Communication: commits one speaker only, not a multi-party settlement); and cco:ont00000684 (Act of Contract Formation, ⊑ Act of Promising ⊑ Commissive Communication: this is the consummating promise, narrower than the bargaining process that precedes and produces it). Distinct from ex:ActOfAdministration (which runs an already-established arrangement) because negotiation CREATES a novel directive arrangement. Recurs in procurement, contracting, and engaging/retaining-counsel processes (7.0, 10.0, 12.0)." .

ex:ActOfPayment a owl:Class ;
    rdfs:subClassOf cco:ont00000836 ,   # Act of Financial Instrument Use
        cco:ont00000228 ;               # Planned Act (explicit allowlist anchor; ont00000836 -> Act of Artifact Employment ont00000566 -> ... -> Planned Act in the CCO closure)
    rdfs:label "Act of Payment" ;
    skos:definition "An Act of Financial Instrument Use in which an Agent (the payer) transfers money or a monetary instrument to another Agent (the payee) in settlement of an obligation." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000836 'Act of Financial Instrument Use' (verified: 'An Act of Artifact Employment in which some Agent uses some Financial Instrument'; parent cco:ont00000566 Act of Artifact Employment). Rejected cco:ont00001334 'Act of Purchasing' (acquires a good/service in exchange, whereas payment may settle a pre-existing debt without acquisition) and cco:ont00000389 'Act of Buying' (acquires ownership of a good, narrower still). The transferred money is a material entity moved as a participant; the act's definitional informational output is a Descriptive ICE payment record. Recurs in disbursement/procurement processes (12.0)." .

ex:ActOfRelationshipManagement a owl:Class ;
    rdfs:subClassOf cco:ont00000433 ,   # Act of Association
        cco:ont00000228 ;               # Planned Act (explicit allowlist anchor; ont00000433 -> Social Act ont00001327 -> Planned Act ont00000228 in the CCO closure)
    rdfs:label "Act of Relationship Management" ;
    skos:definition "An Act of Association in which an Agent builds, maintains, extends, or advances an ongoing relationship between an organization and one or more external parties or held assets." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000433 'Act of Association' (verified: 'A Social Act wherein an Agent unites with some other Agent in a Planned Act, enterprise or business'; parent cco:ont00001327 Social Act -> cco:ont00000228) because relationship-building is a sustained social uniting, not mere ICE transfer. Rejected cco:ont00000402 'Act of Communication' (a single ICE-transfer event, too narrow), cco:ont00000511 'Act of Planning' (output is a relationship, not a plan), and cco:ont00000168 'Act of Interpersonal Relationship' (restricted to Persons, whereas the external counterparties here are typically Organizations). Recurs across plan/build/manage-relationship nodes (12.0)." .

ex:ActOfReporting a owl:Class ;
    rdfs:subClassOf cco:ont00000379 ,   # Act of Representative Communication
        cco:ont00000228 ;               # Planned Act (explicit allowlist anchor; ont00000379 -> ont00000402 -> ont00000228 in the CCO closure, asserted locally so the standalone SHACL S2 Act-anchor chain resolves)
    rdfs:label "Act of Reporting" ;
    skos:definition "An Act of Representative Communication in which an Agent transfers to one or more recipients a Descriptive Information Content Entity (such as a report, statement, scorecard, or filing) that asserts, as true, a representation of an organization's condition or results." ;
    rdfs:comment "PROPOSE-EXT (D9). ANCHOR CONFLICT RESOLVED: slices 9.0 and 11.0 anchored under cco:ont00000366 (Act of Information Processing, emphasizing report COMPILATION); slice 12.0 anchored under cco:ont00000379 (Act of Representative Communication, emphasizing the asserted-true TRANSFER). CHOSEN cco:ont00000379 'Act of Representative Communication' (verified: 'An Act of Communication that commits a speaker to the truth of the expressed proposition'; parent cco:ont00000402 Act of Communication -> cco:ont00000228; its scopeNote enumerates 'announcing, disclosing, informing, reporting, stating'). Reporting's differentia is the truth-committing inter-agent assertion of a representation -- the speech act of reporting -- which Representative Communication captures exactly and which CCO already models for its own narrower cco:ont00000151 'Act of Reporting' (ont00000151 ⊑ ont00000379). Anchoring at ont00000379 (rather than reusing the leaf ont00000151, whose definition 'giving a detailed account or statement' is narrower than the corpus's scorecards/filings/disclosures) gives one coherent genus across all reporting verbs while staying inside the verified CCO Representative-Communication branch. Rejected cco:ont00000366 (Act of Information Processing): the 9.0/11.0 'compilation' framing models the internal preparation step, but the recurring APQC act is the OUTWARD assertion to an audience, not mere internal ICE manipulation -- pure compilation with no assertion is better left to ex:ActOfAnalysis/ex:ActOfAccounting. Per the GOLDEN PRINCIPLE the conveyed content is a Descriptive ICE. A node that only forwards an already-prepared report without asserting it (pure transfer/submission) may use cco:ont00000402 or cco:ont00000151 directly. Recurs corpus-wide (9.0, 11.0, 12.0)." .

####################################################################
# 0. PROVENANCE ANNOTATION PROPERTIES
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "Bridges a catalog node (ex:PCF_<pcfID>) to its reality-layer class (ex:P<pcfID> or a supporting capability)." .

####################################################################
# 1. NEW RECURRING ACT GENERA -- PROPOSE-EXT (D9)
#    Promote to apqc-ext.ttl after human review. Each anchored under
#    the nearest correct CCO Act (verify-before-assert).
####################################################################

####################################################################
# APQC Section 12.0 "Manage External Relationships"
# SHARED SUPPORTING VOCABULARY (ICEs, agents/orgs, roles,
# capabilities) reused by ALL process groups (12.1 - 12.5).
# House style copied from ontology/slices/apqc_1_1_1.ttl.
####################################################################

####################################################################
# 2. AGENTS / ORGANIZATIONS  (cco:Agent ont00001017 / Organization
#    ont00001180). Realizables (roles/capabilities) inhere only here.
####################################################################

ex:Lender a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,            # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:LenderRole ] ;
    rdfs:label "Lender" ;
    skos:definition "An Organization that bears a lender role in virtue of extending loans or credit to a borrowing organization." ;
    rdfs:comment "Minted for 12.1.1 (Plan, build, and manage lender relations). Modeled as Organization (banks/lenders); use cco:Agent for an individual lender." .

ex:FinancialAnalyst a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,            # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:FinancialAnalystRole ] ;
    rdfs:label "Financial Analyst" ;
    skos:definition "An Agent that bears a financial-analyst role in virtue of evaluating the securities, performance, and prospects of an organization." ;
    rdfs:comment "Minted for 12.1.2 (Plan, build, and manage analyst relations)." .

ex:Shareholder a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,            # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ShareholderRole ] ;
    rdfs:label "Shareholder" ;
    skos:definition "An Agent that bears a shareholder role in virtue of holding an equity interest in an organization." ;
    rdfs:comment "Minted for 12.1.3 (Communicate with shareholders). Agent (not Organization) because a shareholder may be an individual or an organization." .

ex:GovernmentBody a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,            # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:GovernmentBodyRole ] ;
    rdfs:label "Government Body" ;
    skos:definition "An Organization that bears a government-body role in virtue of exercising public authority at a local, regional, national, or supranational level." ;
    rdfs:comment "Minted for 12.2.1 (Manage government relations). Covers government heads, representatives, and entities at all levels." .

ex:QuasiGovernmentBody a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,            # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:QuasiGovernmentBodyRole ] ;
    rdfs:label "Quasi-Government Body" ;
    skos:definition "An Organization that bears a quasi-government-body role in virtue of operating under government supervision while remaining distinct and self-directed from the government." ;
    rdfs:comment "Minted for 12.2.2. Includes regulatory and auditing agencies." .

ex:TradeOrIndustryGroup a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,            # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:TradeOrIndustryGroupRole ] ;
    rdfs:label "Trade or Industry Group" ;
    skos:definition "An Organization that bears a trade-or-industry-group role in virtue of being established and financed by businesses operating in a specific industry." ;
    rdfs:comment "Minted for 12.2.3." .

ex:BoardOfDirectors a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,            # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:BoardOfDirectorsRole ] ;
    rdfs:label "Board of Directors" ;
    skos:definition "An Organization that bears a board-of-directors role in virtue of representing stockholders and governing a company's major decisions." ;
    rdfs:comment "Minted for 12.3. Modeled as Organization (a Group of Agents with rules), not as a single Agent." .

ex:OutsideCounsel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,            # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:OutsideCounselRole ] ;
    rdfs:label "Outside Counsel" ;
    skos:definition "An Agent that bears an outside-counsel role in virtue of being an external subject-matter expert engaged to provide legal or ethical assistance to an organization." ;
    rdfs:comment "Minted for 12.4.5 (Manage outside counsel). Agent because counsel may be an individual attorney or a law firm." .

ex:RegulatoryAuthority a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,            # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:RegulatoryAuthorityRole ] ;
    rdfs:label "Regulatory Authority" ;
    skos:definition "An Organization that bears a regulatory-authority role in virtue of issuing and enforcing statutes, regulatory directions, or legal principles binding on an organization." ;
    rdfs:comment "Minted for 12.4.4 (Ensure compliance); e.g. the Securities and Exchange Commission." .

ex:MediaOutlet a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,            # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:MediaOutletRole ] ;
    rdfs:label "Media Outlet" ;
    skos:definition "An Organization that bears a media-outlet role in virtue of producing and distributing news or content through channels such as the web, newspapers, or social media." ;
    rdfs:comment "Minted for 12.5.2 / 12.5.5 (media relations, issuing press releases)." .

ex:Journalist a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,            # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:JournalistRole ] ;
    rdfs:label "Journalist" ;
    skos:definition "An Agent that bears a journalist role in virtue of gathering, reporting, and publishing news on behalf of a media outlet." ;
    rdfs:comment "Minted for 12.5.2 (Manage media relations)." .

ex:Community a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,            # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:CommunityRole ] ;
    rdfs:label "Community" ;
    skos:definition "An Organization that bears a community role in virtue of constituting the population of the environment in which an organization operates and from which it draws resources." ;
    rdfs:comment "Minted for 12.5.1 (Manage community relations). Modeled as Organization (a Group of Agents)." .

ex:CompliancePersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,            # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ComplianceOfficerRole ] ;
    rdfs:label "Compliance Personnel" ;
    skos:definition "An Agent that bears a compliance-officer role in virtue of being tasked with validating and maintaining an organization's compliance position." ;
    rdfs:comment "Minted for 12.4.4 (Ensure compliance; coordinate with compliance and risk-management personnel)." .

ex:ExecutivePersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,            # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ExecutiveRole ] ;
    rdfs:label "Executive Personnel" ;
    skos:definition "An Agent that bears an executive role in virtue of holding senior managerial authority responsible for driving and overseeing organizational relationships and activities." ;
    rdfs:comment "Minted for 12.2.1.2 (Appoint responsible executives) and other rows assigning executive-level resources." .

ex:Advisor a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,            # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:AdvisorRole ] ;
    rdfs:label "Advisor" ;
    skos:definition "An Agent that bears an advisor role in virtue of providing advice or counsel, whether internally or as a third party, to support an organization's relationships." ;
    rdfs:comment "Minted for 12.2.1.4 / 12.2.1.5 (receive input from internal/external advisors)." .

ex:Auditor a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,            # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:AuditorRole ] ;
    rdfs:label "Auditor" ;
    skos:definition "An Agent that bears an auditor role in virtue of conducting an examination of an organization's records, controls, or compliance." ;
    rdfs:comment "Minted for 12.2.2.2 (Respond to audit inquiries) and 12.3.2 (Report audit findings). Agent because an auditor may be an individual or an audit firm." .

####################################################################
# 3. ROLES  (obo:BFO_0000023). Borne by the agents/orgs above.
####################################################################

ex:LenderRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Lender Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of extending loans or credit to a focal organization." .

ex:FinancialAnalystRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Financial Analyst Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of evaluating the securities, performance, and prospects of a focal organization." .

ex:ShareholderRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Shareholder Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of holding an equity interest in a focal organization." .

ex:GovernmentBodyRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Government Body Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of exercising public authority over a focal organization at some level of government." .

ex:QuasiGovernmentBodyRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Quasi-Government Body Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of operating under government supervision while remaining distinct and self-directed from the government." .

ex:TradeOrIndustryGroupRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Trade or Industry Group Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of being established and financed by businesses operating in a specific industry." .

ex:BoardOfDirectorsRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Board of Directors Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of representing stockholders and governing a focal company's major decisions." .

ex:OutsideCounselRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Outside Counsel Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being an external expert engaged to provide legal or ethical assistance to a focal organization." .

ex:RegulatoryAuthorityRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Regulatory Authority Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of issuing and enforcing statutes or regulatory directions binding on a focal organization." .

ex:MediaOutletRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Media Outlet Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of producing and distributing news or content to the public." .

ex:JournalistRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Journalist Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of gathering, reporting, and publishing news on behalf of a media outlet." .

ex:CommunityRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Community Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of constituting the population of the environment in which a focal organization operates." .

ex:ComplianceOfficerRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Compliance Officer Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with validating and maintaining a focal organization's compliance position." .

ex:ExecutiveRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Executive Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of holding senior managerial authority within an Organization." .

ex:AdvisorRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Advisor Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of providing advice or counsel to support a focal organization's relationships or decisions." .

ex:AuditorRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Auditor Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of conducting an examination of a focal organization's records, controls, or compliance." .

ex:LobbyistRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Lobbyist Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with influencing public or government policy on behalf of a focal organization." ;
    rdfs:comment "Minted for 12.2.4 (Manage lobby activities)." .

####################################################################
# 4. CAPABILITIES  (Agent Capability cco:ont00001379 /
#    Organization Capability cco:ont00000568). Borne by orgs/agents.
####################################################################

ex:StakeholderRelationshipManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;            # Organization Capability
    rdfs:label "Stakeholder Relationship Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to build and maintain relationships with external stakeholders such as investors, government bodies, and the public." ;
    rdfs:comment "Shared capability for the 'Manage/Build ... relations' standing-function rows (12.1, 12.2.x, 12.3, 12.5.x), realized in the relevant relationship-management acts via obo:BFO_0000054 (realized in)." .

ex:InvestorRelationsCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;            # Organization Capability
    rdfs:label "Investor Relations Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to integrate finance, communication, and securities-law compliance so as to manage two-way communication with the financial community." ;
    rdfs:comment "Supports 12.1 (Build investor relationships) when modeled as a standing function under R5." .

ex:LegalAndComplianceCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;            # Organization Capability
    rdfs:label "Legal and Compliance Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to conduct legal and ethical practices and to validate adherence to applicable laws and regulations." ;
    rdfs:comment "Supports 12.4 / 12.4.4 (Manage legal and ethical issues; Ensure compliance) when modeled as standing functions." .

ex:PublicRelationsCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;            # Organization Capability
    rdfs:label "Public Relations Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to manage its public image and relationships with the community, media, and the public." ;
    rdfs:comment "Supports 12.5 (Manage public relations program) when modeled as a standing function. The catalog node ex:PCF_11014 designates this capability." .

ex:IntellectualPropertyManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;            # Organization Capability
    rdfs:label "Intellectual Property Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to secure, maintain, and protect its intellectual property rights." ;
    rdfs:comment "Supports 12.4.6 (Protect intellectual property) when modeled as a standing function." .

ex:LenderRelationsManagementCapability a owl:Class ;
    rdfs:subClassOf ex:StakeholderRelationshipManagementCapability ;   # => cco:ont00000568 Organization Capability
    rdfs:label "Lender Relations Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to build, maintain, and advance ongoing relationships with bankers and lenders so as to foster a receptive environment for favorable lending terms." ;
    rdfs:comment "Minted for 12.1.1 (P11035), re-judged under R5 as a standing function -> Organization Capability, reconciled with the parallel 'manage relations' rows 12.2.1-3 which are likewise capabilities (Gate-F cross-row consistency). Realized in the bounded lender-relationship-cultivation episodes via obo:BFO_0000054." .

ex:AnalystRelationsManagementCapability a owl:Class ;
    rdfs:subClassOf ex:StakeholderRelationshipManagementCapability ;   # => cco:ont00000568 Organization Capability
    rdfs:label "Analyst Relations Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to create and maintain long-term relationships with financial analysts so as to elicit market intelligence." ;
    rdfs:comment "Minted for 12.1.2 (P11036), re-judged under R5 as a standing function -> Organization Capability ('creating and maintaining LONG-TERM relations' signals the no-natural-end / standing-capacity branch), reconciled with 12.2.1-3 (Gate-F cross-row consistency). Realized in the bounded analyst-relationship-cultivation episodes via obo:BFO_0000054." .

####################################################################
# 5. INPUT INFORMATION CONTENT ENTITIES
#    Descriptive ICE (cco:ont00000853): data/records consumed as input.
####################################################################

ex:RelationshipData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Relationship Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the current state of an organization's relationship with an external party." ;
    rdfs:comment "Input for assessing/monitoring relationships (12.2.1.1, 12.2.1.3, 12.2.3.2)." .

ex:ContactRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Contact Record" ;
    skos:definition "A Descriptive Information Content Entity that describes a partner, prospect, or customer within an organization's network of contacts." ;
    rdfs:comment "Input/output for 12.2.2.3 (Maintain documentation of contacts)." .

ex:AdvisoryInput a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Advisory Input" ;
    skos:definition "A Descriptive Information Content Entity that describes advice or counsel furnished by an internal or external advisor." ;
    rdfs:comment "Input for 12.2.1.4 / 12.2.1.5 (receive input from advisors)." .

ex:AuditInquiry a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Audit Inquiry" ;
    skos:definition "A Descriptive Information Content Entity that describes a question or request raised by an auditor in the course of an audit." ;
    rdfs:comment "Input for 12.2.2.2 (Respond to audit inquiries) and 12.3.2 (Report audit findings)." .

ex:FinancialData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Financial Data" ;
    skos:definition "A Descriptive Information Content Entity that describes an organization's financial position and performance." ;
    rdfs:comment "Input for 12.3.1 (Report financial results)." .

ex:LegalProblemStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Legal Problem Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes a legal or ethical problem an organization faces and the tasks for which assistance may be needed." ;
    rdfs:comment "Input/output for 12.4.5.1 (Assess problem and determine work requirements)." .

ex:LegalWorkProduct a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Legal Work Product" ;
    skos:definition "A Descriptive Information Content Entity that describes a deliverable produced by outside counsel in the course of an engagement." ;
    rdfs:comment "Input for 12.4.5.4 (Receive work product and manage/monitor case). See also ex:WorkProductDeliverable for the deliverable-plus-effort record specifically monitored under 12.4.5.4." .

ex:Invoice a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Invoice" ;
    skos:definition "A Descriptive Information Content Entity that describes fees claimed by a service provider for services rendered." ;
    rdfs:comment "Input for 12.4.5.5 (Process payment for legal services)." .

ex:PaymentRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Payment Record" ;
    skos:definition "A Descriptive Information Content Entity that records a payment made to a service provider in settlement of an obligation, including payer, payee, amount, and the invoice settled." ;
    rdfs:comment "Definitional informational output of 12.4.5.5 (Process payment for legal services). The remittance/payment record is the ICE output of the act; the transferred money itself is the material entity ex:Payment, modeled as a definitional participant rather than as an informational output (per S3 OutputIsICE: process outputs in this domain are ICEs)." .

ex:RegulatoryRequirement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Regulatory Requirement" ;
    skos:definition "A Directive Information Content Entity that prescribes a statute, regulatory direction, or legal principle with which an organization must comply." ;
    rdfs:comment "Directive (not Descriptive): it prescribes obligations. Input for 12.4.4 (Ensure compliance), 12.4.3 (preventive law programs)." .

####################################################################
# 6. OUTPUT INFORMATION CONTENT ENTITIES
#    Descriptive ICE (ont00000853) for reports/assessments/records;
#    Directive ICE (ont00000965) for policies/plans/decisions/contracts.
#    'is about' (cco:ont00001808) added where the ICE describes a subject.
####################################################################

# ---- Descriptive outputs (reports / assessments / records) ----

ex:RelationshipAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:RelationshipData ] ;
    rdfs:label "Relationship Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the state of an organization's relationship with an external party and areas needing growth." ;
    rdfs:comment "Output of 12.2.1.1 (Assess relationships). 'is about' the relationship the assessment characterizes." .

ex:RelationshipStatusReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:RelationshipData ] ;
    rdfs:label "Relationship Status Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the current standing of an organization's relationships as observed through ongoing monitoring." ;
    rdfs:comment "Output of monitoring rows (12.2.1.3 Monitor relationships, 12.2.3.2 Monitor partnership success)." .

ex:FinancialResultsReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Financial Results Report" ;
    skos:definition "A Descriptive Information Content Entity that describes an organization's financial results, including its income statement, balance sheet, and statement of cash flows." ;
    rdfs:comment "Output of 12.3.1 (Report financial results)." .

ex:AuditFindingsReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Audit Findings Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the findings of an audit, including the situation, root cause, and recommendations for resolving a problem." ;
    rdfs:comment "Output of 12.3.2 (Report audit findings)." .

ex:LegalActivityRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Legal Activity Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the legal activities and performance of an organization over time." ;
    rdfs:comment "Output of 12.4.5.6 (Track legal activity/performance)." .

ex:LegalAdvice a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Legal Advice" ;
    skos:definition "A Descriptive Information Content Entity that describes counsel concerning the substance or procedure of a law as it applies to a particular situation." ;
    rdfs:comment "Output of 12.4.8 (Provide legal advice/counseling). Descriptive: it informs rather than itself binding the recipient to act." .

ex:WorkProductDeliverable a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Work Product Deliverable" ;
    skos:definition "A Descriptive Information Content Entity that records a deliverable produced by engaged outside counsel and the effort committed to a matter." ;
    rdfs:comment "Minted for 12.4.5.4: no other shared-vocab ICE captures counsel deliverables together with committed-effort records used to confirm fees. Genus Descriptive ICE because it records what was delivered/performed. Used ONLY as the has-input (received deliverable) of 12.4.5.4; the validated effort/fee record that act produces is the distinct ex:WorkProductValidationRecord." ;
    skos:example "A memorandum and timesheet delivered by outside counsel on a litigation matter." .

ex:WorkProductValidationRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Work Product Validation Record" ;
    skos:definition "A Descriptive Information Content Entity that records the validated work product and verified committed effort of engaged outside counsel, used to confirm the fees due." ;
    rdfs:comment "Minted for 12.4.5.4 (P11059) as the definitional OUTPUT of the monitoring act, distinct from its has-input ex:WorkProductDeliverable (the raw received deliverable). Separating input and output ICEs corrects the Gate-F finding that the same class was asserted as both has-input and has-output (a vacuous distinction / thin-class over-commitment)." ;
    skos:example "A signed-off matter ledger confirming the briefs filed and billable hours verified before fee approval." .

ex:MeetingRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Meeting Record" ;
    skos:definition "A Descriptive Information Content Entity that records what transpired in a meeting, including attendees, topics discussed, and outcomes, for further analysis and use." ;
    rdfs:comment "Minted for 12.2.2.4 (P12878). Distinct from the input-side ex:RelationshipData ('describes the current state of a relationship', consumed as has-input in P12869/P12871/P12880): the recorded artifact a meeting produces is a meeting record (the output of recording), not the relationship-state data consumed elsewhere -- correcting the Gate-F category confusion of reusing an input class as a has-output filler." ;
    skos:example "Minutes of a quarterly liaison meeting with a quasi-governmental body." .

ex:WorkRequirementsSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Work Requirements Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the tasks and action requirements for engaging outside counsel on a legal problem, or for entering into a strategic relationship." ;
    rdfs:comment "Output of 12.4.5.1 (Assess problem and determine work requirements) and 12.2.3.1 (Evaluate the requirements for strategic relationships). Directive: it specifies required actions." .

# ---- Directive outputs (policies / plans / decisions / agreements) ----

ex:EthicsPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Ethics Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's code of ethics communicating its philosophy to employees, partners, and the public." ;
    rdfs:comment "Output of 12.4.1 (Create ethics policies)." .

ex:CorporateGovernancePolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Corporate Governance Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the system of rules, practices, and processes through which a company is directed and controlled." ;
    rdfs:comment "Output of 12.4.2 (Manage corporate governance policies)." .

ex:CompliancePolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Compliance Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the framework, rules, and procedures by which an organization maintains adherence to applicable statutes and regulations." ;
    rdfs:comment "Output of 12.4.4 / 12.4.4.1 (compliance framework and programs)." .

ex:ComplianceProgram a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Compliance Program" ;
    skos:definition "A Directive Information Content Entity that prescribes the internal system and activities for identifying and reducing the risk of breaching applicable laws and regulations." ;
    rdfs:comment "Output of 12.4.4.1 (Plan and initiate compliance program); implemented by 12.4.4.2." .

ex:PreventiveLawProgram a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Preventive Law Program" ;
    skos:definition "A Directive Information Content Entity that prescribes programs and activities encouraging adherence to preventive laws such as environmental, corporate-compliance, and property-transaction law." ;
    rdfs:comment "Output of 12.4.3 (Develop and perform preventive law programs)." .

ex:IntellectualPropertyPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Intellectual Property Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the rules, procedures, and restrictions governing the use and protection of an organization's intellectual property." ;
    rdfs:comment "Output of 12.4.6.2 (Maintain intellectual property rights and restrictions)." .

ex:LicensingTerms a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Licensing Terms" ;
    skos:definition "A Directive Information Content Entity that prescribes the terms and conditions governing the granting of a license to an organization's intellectual property." ;
    rdfs:comment "Output of 12.4.6.3 (Administer licensing terms) and referenced by 12.4.6.4 (Administer options)." .

ex:IntellectualPropertyRight a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Intellectual Property Right" ;
    skos:definition "A Directive Information Content Entity that prescribes the exclusive legal entitlement an organization holds over a patent, copyright, or trademark." ;
    rdfs:comment "Subject/output of 12.4.6.1 (Manage copyrights, patents, and trademarks). Directive: an enforceable entitlement prescribing permitted and prohibited uses." .

ex:Contract a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Contract" ;
    skos:definition "A Directive Information Content Entity that prescribes the mutually agreed terms binding two or more parties to a course of action." ;
    rdfs:comment "Output of 12.4.9 (Negotiate and document agreements/contracts) and the engagement instrument in 12.4.5.2." .

ex:DisputeResolution a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Dispute Resolution" ;
    skos:definition "A Directive Information Content Entity that prescribes the agreed or adjudicated terms settling a dispute or civil lawsuit." ;
    rdfs:comment "Output of 12.4.7 (Resolve disputes and litigations). Directive: a settlement that binds the parties." .

ex:Budget a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Budget" ;
    skos:definition "A Directive Information Content Entity that prescribes, using figures, an organization's expected future financial results for an activity." ;
    rdfs:comment "Input for 12.4.5.3 (Receive strategy/budget). Directive: a financial plan that constrains spending." .

ex:ExecutiveAppointment a owl:Class ; rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Executive Appointment" ;
    skos:definition "A Directive Information Content Entity that prescribes the assignment of an executive-level agent to manage and drive a designated set of relationships." ;
    rdfs:comment "Output of 12.2.1.2 (Appoint responsible executives). Directive: it assigns responsibility." .

# ---- Communication / public-facing ICEs (subjects of communication acts) ----

ex:ShareholderCommunication a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Shareholder Communication" ;
    skos:definition "A Descriptive Information Content Entity that describes information conveyed to shareholders, such as a shareholders' letter, earnings-call statement, or meeting briefing." ;
    rdfs:comment "Subject of 12.1.3 (Communicate with shareholders)." .

ex:PressRelease a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Press Release" ;
    skos:definition "A Descriptive Information Content Entity that describes an official statement issued to the media to announce a newsworthy development of an organization." ;
    rdfs:comment "Output of 12.5.4 (Create press releases) and subject of 12.5.5 (Issue press releases)." .

####################################################################
# 7. MATERIAL ENTITY  (operations-style material I/O, ADR-001/D4)
####################################################################

ex:Payment a owl:Class ; rdfs:subClassOf obo:BFO_0000040 ;   # material entity
    rdfs:label "Payment" ;
    skos:definition "A Material Entity consisting of a quantity of money or a monetary instrument transferred from a payer to a payee in settlement of an obligation." ;
    rdfs:comment "Modeled as a material entity (not an ICE): the transferred funds in 12.4.5.5 (Process payment for legal services). It is the material participant moved by the act (obo:BFO_0000057), while the act's informational has-output is the separate Descriptive ICE ex:PaymentRecord (process outputs in this domain are ICEs, S3)." .

####################################################################
# ================  PROCESS CLASSES + CAPABILITIES  ================
####################################################################

####################################################################
# GROUP 12.1  Build investor relationships
####################################################################

# --- Supporting bounded episode acts (NO pcfID): the relationship-
#     cultivation episodes in which the 12.1.1/12.1.2 standing functions
#     are realized. They are processes (Act of Relationship Management),
#     so they may be realized-in fillers and process-part fillers.
ex:CultivateLenderRelations a owl:Class ;
    rdfs:label "Cultivate Lender Relations" ;
    skos:definition "An Act of Relationship Management that cultivates and sustains an organization's relationship with one or more lenders during a bounded engagement episode, fostering a receptive environment for favorable lending terms, and has a lender as participant." ;
    rdfs:comment "Supporting bounded act (no pcfID) minted for 12.1.1: the discrete episodes (a cultivation act, a banking meeting, a communication) in which ex:LenderRelationsManagementCapability is realized (obo:BFO_0000054). The Lender is a definitional participant; typical relationship/contact data I/O is non-definitional (Phase-3) and omitted." ;
    skos:example "A treasury team's quarterly banker briefing to secure a low-rate credit line." ;
    rdfs:subClassOf ex:ActOfRelationshipManagement ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Lender ] .

ex:CultivateAnalystRelations a owl:Class ;
    rdfs:label "Cultivate Analyst Relations" ;
    skos:definition "An Act of Relationship Management that cultivates and sustains an organization's relationship with one or more financial analysts during a bounded engagement episode in order to elicit market intelligence, and has a financial analyst as participant." ;
    rdfs:comment "Supporting bounded act (no pcfID) minted for 12.1.2: the discrete episodes (analyst meetings, briefings) in which ex:AnalystRelationsManagementCapability is realized (obo:BFO_0000054). The FinancialAnalyst is a definitional participant of these episode acts (not of a capability), per the Gate-F fix." ;
    skos:example "An investor-relations officer's briefing with a sell-side analyst ahead of an earnings release." ;
    rdfs:subClassOf ex:ActOfRelationshipManagement ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FinancialAnalyst ] .

# --- 12.1 (PCF 11010) : standing investor-relations function -> Capability [R6]
ex:P11010 a owl:Class ;
    ex:pcfID "11010" ;
    ex:hierarchyID "12.1" ;
    ex:apqcSourceText "Creating a strategic management responsibility for integrating finance, communication, marketing, and securities law compliance. Allow the most effective two-way communication among the organization, the financial community, and other constituencies. Enlist the investor relations function to provide market intelligence to corporate management." ;
    rdfs:label "Build investor relationships" ;
    skos:definition "An Investor Relations Capability that inheres in an Organization in virtue of its capacity to realize the integrated two-way engagement of the organization with lenders, analysts, and shareholders." ;
    rdfs:comment "Modeled as an Organization Capability (R6), not a process: APQC describes a standing 'strategic management responsibility' / 'investor relations function' with no natural end. Specializes the shared ex:InvestorRelationsCapability. Two of its three APQC children (12.1.1, 12.1.2) are themselves standing functions re-judged as capabilities under R5 (ex:LenderRelationsManagementCapability, ex:AnalystRelationsManagementCapability); a capability is realized only in PROCESSES (BFO_0000054), so this umbrella capability is realized in the bounded episode acts ex:CultivateLenderRelations / ex:CultivateAnalystRelations and in the shareholder-communication process ex:P11037, not in the sub-capabilities." ;
    skos:example "An organization's standing investor-relations office that cultivates lender, analyst, and shareholder relationships across fiscal periods." ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        ex:InvestorRelationsCapability ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:CultivateLenderRelations ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:CultivateAnalystRelations ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11037 ] .

# --- 12.1.1 (PCF 11035) : standing lender-relations function -> Capability [R5/R6]
ex:P11035 a owl:Class ;
    ex:pcfID "11035" ;
    ex:hierarchyID "12.1.1" ;
    ex:apqcSourceText "Building and managing relations with bankers or lenders through strong products/services strategies that bankers would want to invest in. Foster a receptive environment for low rates of interest, easy access to loans, etc." ;
    rdfs:label "Plan, build, and manage lender relations" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to build, maintain, and advance ongoing relationships with bankers and lenders so as to foster a receptive environment for favorable lending terms." ;
    rdfs:comment "RE-ANCHORED (Gate-F, R5 cross-row consistency): previously modeled as a bounded ex:ActOfRelationshipManagement. 'Plan, build, and manage an ongoing relation ... foster a receptive environment' has no natural beginning or end; it is a standing capacity realized in recurring episodes -- exactly the R5 'standing function -> capability' branch already applied to the parallel 'Manage ... relations' rows 12.2.1 (P11038), 12.2.2 (P11039), 12.2.3 (P11040). Leaf-vs-nonleaf is NOT the R5 ground (R5 is per-node bounded-occurrent, independent of whether children were enumerated), so the prior split mistyped parallel rows. Now an Organization Capability (cco:ont00000568) specializing ex:LenderRelationsManagementCapability, realized in the bounded ex:CultivateLenderRelations episodes (obo:BFO_0000054). The Lender participates in those episode acts, not in the capability." ;
    skos:example "An organization's standing treasury function that nurtures banking relationships across fiscal periods to secure low-rate credit lines." ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        ex:LenderRelationsManagementCapability ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:CultivateLenderRelations ] .

# --- 12.1.2 (PCF 11036) : standing analyst-relations function -> Capability [R5/R6]
ex:P11036 a owl:Class ;
    ex:pcfID "11036" ;
    ex:hierarchyID "12.1.2" ;
    ex:apqcSourceText "Creating and maintaining long-term relations with analysts. Involve analysts in strategy and product decisions in order to elicit valuable information." ;
    rdfs:label "Plan, build, and manage analyst relations" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to create and maintain long-term relationships with financial analysts so as to elicit market intelligence." ;
    rdfs:comment "RE-ANCHORED (Gate-F, R5 cross-row consistency): previously modeled as a bounded ex:ActOfRelationshipManagement. 'Creating and maintaining LONG-TERM relations with analysts' is the paradigm of a standing function with no natural end -- 'long-term' actively signals the no-natural-end (standing-capacity) branch of R5 -- the same pattern the module treats as a capability at 12.2.1-3. Reconciled to the same R5 verdict chosen for P11035. Now an Organization Capability (cco:ont00000568) specializing ex:AnalystRelationsManagementCapability, realized in the bounded ex:CultivateAnalystRelations episodes (analyst meetings, briefings) via obo:BFO_0000054. The FinancialAnalyst participates in those episode acts, not in the capability." ;
    skos:example "An organization's standing investor-relations function that maintains relationships with sell-side analysts covering the firm across reporting cycles." ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        ex:AnalystRelationsManagementCapability ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:CultivateAnalystRelations ] .

# --- 12.1.3 (PCF 11037) : Communication (shareholders) -> CCO Act of Communication
ex:P11037 a owl:Class ;
    ex:pcfID "11037" ;
    ex:hierarchyID "12.1.3" ;
    ex:apqcSourceText "Practicing regular, transparent communication with shareholders through annual shareholders' meetings, quarterly earnings calls, shareholders letters, one-on-one emails or calls, etc." ;
    rdfs:label "Communicate with shareholders" ;
    skos:definition "An Act of Communication that transfers information from an organization to its shareholders and produces a shareholder communication." ;
    rdfs:comment "Anchored under cco:ont00000402 (Act of Communication) because the act consists in transferring an Information Content Entity from the organization to its shareholders. The output ShareholderCommunication is a Descriptive ICE and is definitional (every instance produces communicated content), so it is promoted to a restriction; the Shareholder is a definitional participant." ;
    skos:example "A company holds its quarterly earnings call and issues a shareholders' letter." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; Act of Communication -> Planned Act in CCO closure)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ShareholderCommunication ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Shareholder ] .

####################################################################
# GROUP 12.2  Manage government and industry relationships
####################################################################

# --- 12.2.1 (PCF 11038) : standing government-relations function -> Capability
ex:P11038 a owl:Class ;
    ex:pcfID "11038" ;
    ex:hierarchyID "12.2.1" ;
    ex:apqcSourceText "Persuading public and government policy at the local, regional, national, and global level (subject to government regulations)." ;
    rdfs:label "Manage government relations" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to establish, assess, monitor, and advance relationships with government bodies in order to influence public and government policy." ;
    rdfs:comment "R5: standing function ('Manage ...'), no natural end => Organization Capability (cco:ont00000568), not a process. Realized in its APQC child acts (R6)." ;
    skos:example "A corporate government-affairs office's ongoing program of engaging legislators and agencies." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12869 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12870 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12871 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12872 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12873 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12874 ] .

# --- 12.2.2 (PCF 11039) : standing quasi-gov-relations function -> Capability
ex:P11039 a owl:Class ;
    ex:pcfID "11039" ;
    ex:hierarchyID "12.2.2" ;
    ex:apqcSourceText "Managing relations with quasi-governmental organizations, corporations, businesses, or any other agency that is treated by national laws and principles to be under the supervision of the government but also distinct and self-directed from the government." ;
    rdfs:label "Manage relations with quasi-government bodies" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to establish, maintain, and advance relationships with quasi-government bodies." ;
    rdfs:comment "R5: standing function => Organization Capability (cco:ont00000568). Realized in its APQC child acts (R6)." ;
    skos:example "An organization's ongoing engagement with a quasi-governmental regulator." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12875 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12876 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12877 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12878 ] .

# --- 12.2.3 (PCF 11040) : standing trade/industry-relations function -> Capability
ex:P11040 a owl:Class ;
    ex:pcfID "11040" ;
    ex:hierarchyID "12.2.3" ;
    ex:apqcSourceText "Managing relations with organizations established and financed by businesses that operate in a specific industry. Participate in public relations actions such as lobbying and publishing, advertising, education, and political donations." ;
    rdfs:label "Manage relations with trade or industry groups" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to evaluate, establish, monitor, extend, and modify relationships with trade or industry groups." ;
    rdfs:comment "R5: standing function => Organization Capability (cco:ont00000568). Realized in its APQC child acts (R6)." ;
    skos:example "An organization's ongoing membership and lobbying activity within an industry association." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12879 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12880 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P12881 ] .

# --- 12.2.4 (PCF 11041) : standing lobbying function -> Capability (no modeled children)
ex:P11041 a owl:Class ;
    ex:pcfID "11041" ;
    ex:hierarchyID "12.2.4" ;
    ex:apqcSourceText "Managing lobbying activities to affect government policies." ;
    rdfs:label "Manage lobby activities" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to conduct and coordinate lobbying activities aimed at affecting government policies." ;
    rdfs:comment "R5: standing function ('Manage ...'), no natural end and no decomposed APQC children => Organization Capability (cco:ont00000568), not a process." ;
    skos:example "A firm's ongoing lobbying program directed at pending legislation." ;
    rdfs:subClassOf cco:ont00000568 .

# --- 12.2.1.1 (PCF 12869) : Appraisal -> descriptive output
ex:P12869 a owl:Class ;
    ex:pcfID "12869" ;
    ex:hierarchyID "12.2.1.1" ;
    ex:apqcSourceText "Ascertaining how the business entity relates to all levels of government. Identify areas that needs further growth and resources to foster those relationships." ;
    rdfs:label "Assess relationships" ;
    skos:definition "An Act of Appraisal that has as input relationship data and has as output a relationship assessment describing how the organization relates to all levels of government." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it evaluates and judges the state of government relationships. GOLDEN PRINCIPLE: descriptive output (relationship assessment) agrees with the appraisal genus." ;
    skos:example "A government-affairs team rates the strength of the firm's ties to local, regional, and national government." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RelationshipData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RelationshipAssessment ] .

# --- 12.2.1.2 (PCF 12870) : Formulation -> directive output (appointment)
ex:P12870 a owl:Class ;
    ex:pcfID "12870" ;
    ex:hierarchyID "12.2.1.2" ;
    ex:apqcSourceText "Assigning executive level resources to manage, grow, and drive relationships with government bodies." ;
    rdfs:label "Appoint responsible executives" ;
    skos:definition "An Act of Formulation that has as output an executive appointment prescribing the executive-level resource assigned to manage and drive relationships with government bodies, and has executive personnel as participant." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning) because appointing assigns a prescriptive responsibility; its output (executive appointment) is a Directive ICE. GOLDEN PRINCIPLE: directive output agrees with the planning/formulation genus." ;
    skos:example "A CEO assigns a VP of Government Affairs to own the relationship with a regulatory ministry." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExecutiveAppointment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ExecutivePersonnel ] .

# --- 12.2.1.3 (PCF 12871) : Monitoring -> descriptive output
ex:P12871 a owl:Class ;
    ex:pcfID "12871" ;
    ex:hierarchyID "12.2.1.3" ;
    ex:apqcSourceText "Analyzing current relationships with government bodies and entities." ;
    rdfs:label "Monitor relationships" ;
    skos:definition "An Act of Monitoring that has as input relationship data and has as output a relationship status report describing the current state of relationships with government bodies." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (Act of Information Processing): ongoing analysis of current government relationships yielding a descriptive status report. GOLDEN PRINCIPLE: descriptive output agrees with the information-processing genus." ;
    skos:example "A liaison reviews recent interactions and reports the health of each government relationship quarterly." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RelationshipData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RelationshipStatusReport ] .

# --- 12.2.1.4 (PCF 12872) : Communication (input advisory) -- internal
ex:P12872 a owl:Class ;
    ex:pcfID "12872" ;
    ex:hierarchyID "12.2.1.4" ;
    ex:apqcSourceText "Garnering internal advice from an informal group in order to successfully maintain and advance relationships." ;
    rdfs:label "Receive input from internal advisors" ;
    skos:definition "An Act of Communication that has as input advisory input transferred from internal advisors to the organization in order to maintain and advance government relationships, and has an advisor as participant." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): an ICE (advisory input) is transferred from one Agent (the internal advisor) to another. The advisors are internal personnel; modeled as participants via ex:Advisor." ;
    skos:example "A government-affairs lead solicits guidance from an internal advisory committee before a policy push." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; Act of Communication -> Planned Act in CCO closure)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:AdvisoryInput ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Advisor ] .

# --- 12.2.1.5 (PCF 12873) : Communication (input advisory) -- external
ex:P12873 a owl:Class ;
    ex:pcfID "12873" ;
    ex:hierarchyID "12.2.1.5" ;
    ex:apqcSourceText "Garnering third party advice from an informal group in order to successfully maintain and advance relationships." ;
    rdfs:label "Receive input from external advisors" ;
    skos:definition "An Act of Communication that has as input advisory input transferred from third-party advisors to the organization in order to maintain and advance government relationships, and has an advisor as participant." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): advisory input is transferred from an external Agent to the organization. Distinguished from 12.2.1.4 only by the advisor being third-party." ;
    skos:example "A firm retains an external lobbying advisor whose recommendations feed its government-relations plan." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; Act of Communication -> Planned Act in CCO closure)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:AdvisoryInput ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Advisor ] .

# --- 12.2.1.6 (PCF 12874) : Relationship management (liaison with authorities)
ex:P12874 a owl:Class ;
    ex:pcfID "12874" ;
    ex:hierarchyID "12.2.1.6" ;
    ex:apqcSourceText "Meeting with government heads and representatives." ;
    rdfs:label "Liaise with authorities" ;
    skos:definition "An Act of Relationship Management in which representatives of the organization liaise with government heads and representatives in order to advance government relationships, and which has a government body as participant." ;
    rdfs:comment "RE-ANCHORED (Gate-F false-friend): previously cco:ont00000144 'Act of Meeting', whose verified CCO definition is 'An Act of Association wherein two or more PERSONS assemble for some common purpose' -- Persons-restricted. The asserted participant ex:GovernmentBody is an Organization (subClassOf cco:ont00001180), not a Person, so Act of Meeting does not genuinely fit; it is the same Persons defect this module already rejects for cco:ont00000168 'Act of Interpersonal Relationship' (a sibling of Act of Meeting under Act of Association carrying the same Persons restriction). The CCO Persons restriction is a skos annotation, not an OWL participant axiom, so the class stayed satisfiable at Gate D -- which is exactly why Gate F must catch it. Re-anchored to ex:ActOfRelationshipManagement (=> cco:ont00000433 'Act of Association', whose definition unites an Agent with 'some other Agent', i.e. Organizations are admissible), mirroring the sibling relationship acts in this group (P12875, P12881). No definitional informational output; any minutes are typical, not necessary." ;
    skos:example "A government-affairs director liaises with a ministry's representatives to discuss a pending regulation." ;
    rdfs:subClassOf ex:ActOfRelationshipManagement ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:GovernmentBody ] .

# --- 12.2.2.1 (PCF 12875) : Relationship management
ex:P12875 a owl:Class ;
    ex:pcfID "12875" ;
    ex:hierarchyID "12.2.2.1" ;
    ex:apqcSourceText "Engaging government, regulatory, or industry agencies to establish relationships. Analyze steps and requirements necessary for inclusion, if needed." ;
    rdfs:label "Establish relationships with agencies" ;
    skos:definition "An Act of Relationship Management in which the organization engages government, regulatory, or industry agencies in order to establish a relationship, and which has a regulatory authority as participant." ;
    rdfs:comment "Anchored to ex:ActOfRelationshipManagement (an Act of Association). Any analysis of inclusion requirements is a sub-step, not a definitional informational output, so it is recorded here rather than as a someValuesFrom restriction." ;
    skos:example "A compliance team formally registers with a quasi-governmental regulator to gain recognized standing." ;
    rdfs:subClassOf ex:ActOfRelationshipManagement ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryAuthority ] .

# --- 12.2.2.2 (PCF 12876) : Communication (input audit inquiry) -> participant auditor
ex:P12876 a owl:Class ;
    ex:pcfID "12876" ;
    ex:hierarchyID "12.2.2.2" ;
    ex:apqcSourceText "Cooperating with auditors regarding potential or ongoing inquiries." ;
    rdfs:label "Respond to audit inquiries" ;
    skos:definition "An Act of Communication that has as input an audit inquiry and in which the organization cooperates with auditors regarding potential or ongoing inquiries, having an auditor as participant." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): the organization transfers responsive information in reply to an auditor's inquiry. The audit inquiry is the definitional input ICE." ;
    skos:example "A finance team supplies documentation in response to a regulator's audit inquiry." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; Act of Communication -> Planned Act in CCO closure)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:AuditInquiry ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Auditor ] .

# --- 12.2.2.3 (PCF 12877) : Information processing -> descriptive output (contact record)
ex:P12877 a owl:Class ;
    ex:pcfID "12877" ;
    ex:hierarchyID "12.2.2.3" ;
    ex:apqcSourceText "Keeping a repository of documents that contain information about the network of partners, prospects and customers. Keep records up-to-date with routine reviews and modify as needed." ;
    rdfs:label "Maintain documentation of contacts" ;
    skos:definition "An Act of Information Processing that has as output contact records and that stores and updates documents describing the organization's network of partners, prospects, and customers." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing: input ICEs are received, manipulated, or stored). 'Maintain' here is record-keeping of informational ICEs, NOT cco:ont00000950 'Act of Maintenance' (which modifies Material Artifacts). GOLDEN PRINCIPLE: descriptive output (contact records) agrees with the information-processing genus." ;
    skos:example "A relationship manager keeps a CRM repository of agency contacts current through routine reviews." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ContactRecord ] .

# --- 12.2.2.4 (PCF 12878) : Relationship management -> output meeting record; participant quasi-gov body
ex:P12878 a owl:Class ;
    ex:pcfID "12878" ;
    ex:hierarchyID "12.2.2.4" ;
    ex:apqcSourceText "Ensuring regular interaction between business entity and quasi-government bodies in order to maintain established relationships. Collect and record meeting data for further analysis and use." ;
    rdfs:label "Plan and manage meetings" ;
    skos:definition "An Act of Relationship Management in which the organization interacts regularly with quasi-government bodies to maintain established relationships, has as output a meeting record capturing the meeting data collected, and has a quasi-government body as participant." ;
    rdfs:comment "RE-ANCHORED (Gate-F false-friend, same Persons defect as 12.2.1.6): previously cco:ont00000144 'Act of Meeting' ('two or more PERSONS assemble'), but the asserted participant ex:QuasiGovernmentBody is an Organization, not a Person -- the Persons restriction is violated, contradicting the module's own rejection of the Persons-restricted Act of Interpersonal Relationship. Re-anchored to ex:ActOfRelationshipManagement (=> cco:ont00000433 'Act of Association', Organizations admissible), consistent with the 'plan and manage ... interaction ... to maintain established relationships' reading. OUTPUT corrected (Phase-3 category confusion): the previous has-output filler ex:RelationshipData is a Descriptive INPUT ICE ('describes the current state of a relationship', used as has-input in P12869/P12871/P12880); the artifact this act produces by 'collect and record meeting data' is a meeting record, so the definitional output is the distinct ex:MeetingRecord (recording is definitional per the source, so it is retained as a someValuesFrom restriction rather than demoted)." ;
    skos:example "A liaison holds quarterly meetings with a quasi-governmental body and logs the discussion for later analysis." ;
    rdfs:subClassOf ex:ActOfRelationshipManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MeetingRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:QuasiGovernmentBody ] .

# --- 12.2.3.1 (PCF 12879) : Formulation -> directive output (requirements spec)
ex:P12879 a owl:Class ;
    ex:pcfID "12879" ;
    ex:hierarchyID "12.2.3.1" ;
    ex:apqcSourceText "Determining the requirements to enter in to an agreement with trade or industry agencies. Discover what activities or processes can be conducted to provide the best mutual outcome." ;
    rdfs:label "Evaluate the requirements for strategic relationships" ;
    skos:definition "An Act of Formulation that has as output a work requirements specification prescribing the requirements to enter into an agreement with trade or industry agencies, and which has a trade or industry group as participant." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): the deliverable is a prescriptive specification of the requirements to enter an agreement (a Directive ICE). GOLDEN PRINCIPLE: directive output agrees with the planning/formulation genus, despite the surface verb 'evaluate'." ;
    skos:example "A partnerships team documents the membership and participation requirements needed to join an industry consortium." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkRequirementsSpecification ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:TradeOrIndustryGroup ] .

# --- 12.2.3.2 (PCF 12880) : Monitoring -> descriptive output
ex:P12880 a owl:Class ;
    ex:pcfID "12880" ;
    ex:hierarchyID "12.2.3.2" ;
    ex:apqcSourceText "Analyzing current relationships with trade and industry groups. Ensure that the partnership in successful and make modifications where needed." ;
    rdfs:label "Monitor the success of the partnerships" ;
    skos:definition "An Act of Monitoring that has as input relationship data and has as output a relationship status report describing the current state and success of relationships with trade or industry groups." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (Act of Information Processing): ongoing analysis of partnership success yielding a descriptive status report. GOLDEN PRINCIPLE: descriptive output agrees with the information-processing genus." ;
    skos:example "A partnerships lead reviews engagement metrics and reports whether each industry-group relationship is on track." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RelationshipData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RelationshipStatusReport ] .

# --- 12.2.3.3 (PCF 12881) : Relationship management
ex:P12881 a owl:Class ;
    ex:pcfID "12881" ;
    ex:hierarchyID "12.2.3.3" ;
    ex:apqcSourceText "Providing additional information or inclusion for third party trade or industry entities; or changing existing parameters to modify the current relationship. Communicate and execute changes." ;
    rdfs:label "Extend or change the relationships" ;
    skos:definition "An Act of Relationship Management in which the organization extends or modifies an existing relationship with a trade or industry group by providing additional inclusion or changing its parameters, and which has a trade or industry group as participant." ;
    rdfs:comment "Anchored to ex:ActOfRelationshipManagement (an Act of Association). 'Communicate and execute changes' is a sub-step; no single informational ICE is definitional, so I/O is recorded in this comment rather than as a someValuesFrom restriction." ;
    skos:example "A partnerships team upgrades the firm's membership tier in an industry association and notifies the counterpart." ;
    rdfs:subClassOf ex:ActOfRelationshipManagement ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:TradeOrIndustryGroup ] .

####################################################################
# GROUP 12.3  Manage relations with board of directors
####################################################################

# --- 12.3 (PCF 11012) : standing board-relations function -> Capability [R6]
ex:P11012 a owl:Class ;
    ex:pcfID "11012" ;
    ex:hierarchyID "12.3" ;
    ex:apqcSourceText "Maintaining relations with representatives of the stockholders. Establish corporate management-related policies and to make decisions on major company issues. Implement practices designed to engender communication, trust, and cooperation." ;
    rdfs:label "Manage relations with board of directors" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to sustain communicative and reporting relations with its board of directors and the stockholders the board represents." ;
    rdfs:comment "R5 = capability, not a process: 'manage/maintain relations' denotes a standing function with no natural beginning or end, so it is modeled as an Organization Capability (cco:ont00000568) realized in its underlying acts (R6), not as a bounded occurrent. Subsumed under the shared StakeholderRelationshipManagementCapability. The realized-in restrictions link it to the bounded acts that exercise it." ;
    skos:example "A corporate secretariat's ongoing capacity to deliver financial and audit reporting to the board and shareholders." ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        ex:StakeholderRelationshipManagementCapability ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11042 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11043 ] .

# --- 12.3.1 (PCF 11042) : Reporting -> Act of Representative Communication
ex:P11042 a owl:Class ;
    ex:pcfID "11042" ;
    ex:hierarchyID "12.3.1" ;
    ex:apqcSourceText "Reporting financial results to management, and releasing results to the public. Report financial statements, including the income statement, balance sheet, and statement of cash flows." ;
    rdfs:label "Report financial results" ;
    skos:definition "An Act of Reporting that has as input financial data and has as output a financial results report asserting an organization's financial statements to management and the public." ;
    rdfs:comment "GOLDEN PRINCIPLE: a representative-communication (reporting) act asserting facts, so the definitional output ex:FinancialResultsReport is a Descriptive ICE (cco:ont00000853). Financial data is a definitional input (one cannot report results without it). The Board of Directors / management are modeled as recipients of the communicated report; release to the public is a typical further recipient noted in the source text." ;
    skos:example "A controller's office issues the quarterly income statement, balance sheet, and statement of cash flows to the board and to the public." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialResultsReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001922 ; owl:someValuesFrom ex:BoardOfDirectors ] .

# --- 12.3.2 (PCF 11043) : Reporting -> Act of Representative Communication
ex:P11043 a owl:Class ;
    ex:pcfID "11043" ;
    ex:hierarchyID "12.3.2" ;
    ex:apqcSourceText "Reporting audit findings to management. Practice an internal audit with criteria for confirming a problem, a description of the situation, and the root cause of the problem. Make recommendations that resolve the issue." ;
    rdfs:label "Report audit findings" ;
    skos:definition "An Act of Reporting that has as input an audit inquiry and has as output an audit findings report asserting confirmed problems, their situation and root cause, and recommendations to management." ;
    rdfs:comment "GOLDEN PRINCIPLE: a representative-communication (reporting) act, so the definitional output ex:AuditFindingsReport is a Descriptive ICE (cco:ont00000853). The internal-audit inquiry that surfaces the findings is the definitional input. The conducting of the internal audit itself is a separate appraisal act outside this reporting node; here only the reporting (transfer of asserted findings to the board/management) is modeled. The Board of Directors / management are the recipients." ;
    skos:example "Internal audit issues a findings report to the audit committee of the board, stating the confirmed control gap, its root cause, and remediation recommendations." ;
    rdfs:subClassOf ex:ActOfReporting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:AuditInquiry ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AuditFindingsReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001922 ; owl:someValuesFrom ex:BoardOfDirectors ] .

####################################################################
# GROUP 12.4  Manage legal and ethical issues
####################################################################

# --- 12.4 (PCF 11013) : standing umbrella function -> Organization Capability
ex:P11013 a owl:Class ;
    ex:pcfID "11013" ; ex:hierarchyID "12.4" ;
    ex:apqcSourceText "Managing legal practices to abide by the law, as well as ethical practices." ;
    rdfs:label "Manage legal and ethical issues" ;
    skos:definition "An Organization Capability that an Organization realizes in the acts by which it manages its legal and ethical practices so as to abide by the law." ;
    rdfs:comment "R5/R6: 'Manage legal and ethical issues' is a standing function with no natural end, so it is an Organization Capability (cco:ont00000568), not a process. Realized in the modeled child acts. Narrower, pcf-bearing refinement of the shared ex:LegalAndComplianceCapability. NOTE: 12.4.4 (P11047 Ensure compliance) is itself re-judged as a sub-capability under R5 (Gate-F), and a capability is realized only in processes, so this umbrella capability is realized in P11047's bounded acts ex:P11053 / ex:P11054 rather than in the P11047 sub-capability." ;
    rdfs:subClassOf cco:ont00000568 , ex:LegalAndComplianceCapability ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11044 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11046 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11053 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11054 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11050 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11051 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11052 ] .

# --- 12.4.1 (PCF 11044) : Formulation -> Directive ICE (EthicsPolicy)
ex:P11044 a owl:Class ;
    ex:pcfID "11044" ; ex:hierarchyID "12.4.1" ;
    ex:apqcSourceText "Creating a code of ethics that communicate the organization's philosophy to employees, vendors, customers, clients, and the public." ;
    rdfs:label "Create ethics policies" ;
    skos:definition "An Act of Formulation that composes a code of ethics and has as output an ethics policy expressing the organization's philosophy." ;
    rdfs:comment "GOLDEN PRINCIPLE: output EthicsPolicy is a Directive ICE, so the act genus is Formulation (Act of Planning), not Information Processing." ;
    skos:example "A compliance team drafts and publishes the company code of ethics." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EthicsPolicy ] .

# --- 12.4.2 (PCF 11045) : standing governance administration -> Organization Capability
ex:P11045 a owl:Class ;
    ex:pcfID "11045" ; ex:hierarchyID "12.4.2" ;
    ex:apqcSourceText "Administering the system of rules, practices, and processes through which a company is directed and controlled. Balance stakeholder interests including shareholders, management, customers, suppliers, financiers, government, and the community. Outline a strategy for achieving organizational goals, from action plans and internal controls to performance measurement and corporate disclosure." ;
    rdfs:label "Manage corporate governance policies" ;
    skos:definition "An Organization Capability that an Organization realizes in administering the system of rules, practices, and processes through which it is directed and controlled while balancing stakeholder interests." ;
    rdfs:comment "R5/R6: administering the standing governance 'system' has no natural end, so it is an Organization Capability (cco:ont00000568). The corporate governance policy it maintains is the shared ex:CorporateGovernancePolicy (a Directive ICE) produced by the underlying formulation acts." ;
    rdfs:subClassOf cco:ont00000568 , ex:LegalAndComplianceCapability .

# --- 12.4.3 (PCF 11046) : Formulation -> Directive ICE (PreventiveLawProgram)
ex:P11046 a owl:Class ;
    ex:pcfID "11046" ; ex:hierarchyID "12.4.3" ;
    ex:apqcSourceText "Creating and applying programs and activities. Encourage the adherence preventive laws, such as environmental law, sex discrimination, computer law, estate planning, corporate compliance, business planning, and property transactions." ;
    rdfs:label "Develop and perform preventive law programs" ;
    skos:definition "An Act of Formulation that creates programs and activities encouraging adherence to preventive laws and has as output a preventive law program." ;
    rdfs:comment "Output PreventiveLawProgram is a Directive ICE (a program prescribing activities), so the genus is Formulation. 'Perform' is realization of the program; the definitional move is its creation." ;
    skos:example "Legal counsel rolls out an environmental-law and corporate-compliance preventive program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PreventiveLawProgram ] .

# --- 12.4.4 (PCF 11047) : standing compliance-oversight function -> Organization Capability [R5/R6]
ex:P11047 a owl:Class ;
    ex:pcfID "11047" ; ex:hierarchyID "12.4.4" ;
    ex:apqcSourceText "Ensuring the organization's compliance position. Validate compliance with different statutes, regulatory directions, and legal principles (using Establish compliance framework and policies [17468]). Coordinate with compliance and risk management personnel." ;
    rdfs:label "Ensure compliance" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to ensure and oversee its compliance position by designing compliance programs and validating adherence to statutes, regulatory directions, and legal principles." ;
    rdfs:comment "RE-ANCHORED (Gate-F, R5 / genus-vs-parts tension): previously a single bounded Act of Appraisal. (a) 'Ensuring the organization's compliance position' / 'coordinate with personnel' reads as a standing oversight function with no natural end -- like its modeled-as-Capability siblings P11045/P11048/P11049. (b) It was given cco:has process part to a FORMULATION act (P11053 design a compliance program) and an EXECUTION act (P11054), neither of which is an occurrent part of judging compliance -- an appraisal does not have 'design a program' as a part. Re-modeled as an Organization Capability (cco:ont00000568) specializing ex:LegalAndComplianceCapability, realized (obo:BFO_0000054) in its bounded child acts P11053 and P11054, which are thereby re-parented as realizations of the capability rather than process parts of an appraisal. The bounded validation judgement against ex:RegulatoryRequirement, performed with ex:CompliancePersonnel, is itself one of the acts that realize this capability." ;
    skos:example "A standing compliance office that designs anti-trust programs and continually validates the firm's standing against SEC and consumer-protection statutes." ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        ex:LegalAndComplianceCapability ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11053 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11054 ] .

# --- 12.4.4.1 (PCF 11053) : Formulation -> Directive ICE (ComplianceProgram)
ex:P11053 a owl:Class ;
    ex:pcfID "11053" ; ex:hierarchyID "12.4.4.1" ;
    ex:apqcSourceText "Employing an internal system or process to identify and reduce the risk of breaching the Competition and Consumer Act 2010. Remedy any breach. Create a culture of compliance. Design compliance programs." ;
    rdfs:label "Plan and initiate compliance program" ;
    skos:definition "An Act of Formulation that designs an internal system to identify and reduce the risk of statutory breach and has as output a compliance program." ;
    rdfs:comment "Output ComplianceProgram is a Directive ICE, so the genus is Formulation (Act of Planning)." ;
    skos:example "A compliance lead designs and launches an anti-trust compliance program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ComplianceProgram ] .

# --- 12.4.4.2 (PCF 11054) : Planned Act executing the program
ex:P11054 a owl:Class ;
    ex:pcfID "11054" ; ex:hierarchyID "12.4.4.2" ;
    ex:apqcSourceText "Implementing the established compliance program in order to meet the government laws and regulations. Create a compliance team that scrutinizes the rules set out by government bodies such as the Securities and Exchange Commission." ;
    rdfs:label "Execute compliance program" ;
    skos:definition "A Planned Act that implements an established compliance program to meet government laws and regulations, prescribed by that compliance program." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): execution is prescribed by the ComplianceProgram (Directive ICE), modeled as a held prescription via cco:ont00001921 (has input). It produces no new definitional ICE of its own." ;
    skos:example "A compliance team carries out the scheduled controls and audits defined by the program." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ComplianceProgram ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:CompliancePersonnel ] .

# --- 12.4.5 (PCF 11048) : standing counsel-management function -> Organization Capability
ex:P11048 a owl:Class ;
    ex:pcfID "11048" ; ex:hierarchyID "12.4.5" ;
    ex:apqcSourceText "Managing professionals, sought externally for assistance over legal and ethical concerns. Administer and oversee assistance from subject matter experts and professionals for sourcing expert opinion and counseling over legal and ethical matters." ;
    rdfs:label "Manage outside counsel" ;
    skos:definition "An Organization Capability that an Organization realizes in the acts by which it engages, oversees, pays, and monitors externally sourced professionals for legal and ethical assistance." ;
    rdfs:comment "R5/R6: a standing 'administer and oversee' function with no natural end, so an Organization Capability (cco:ont00000568). Realized in its six bounded child acts (12.4.5.1-12.4.5.6)." ;
    rdfs:subClassOf cco:ont00000568 , ex:LegalAndComplianceCapability ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11056 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11057 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11058 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11059 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11060 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11061 ] .

# --- Supporting formulation act (NO pcfID): the planning facet split out of
#     P11056 so the appraisal genus no longer carries a Directive output.
ex:DetermineLegalWorkRequirements a owl:Class ;
    rdfs:label "Determine legal work requirements" ;
    skos:definition "An Act of Formulation that determines and specifies the tasks and action requirements for engaging outside counsel on a legal problem and has as output a work requirements specification (ex:WorkRequirementsSpecification, a Directive ICE)." ;
    rdfs:comment "Supporting act (no pcfID, so it carries NO targeted has-output someValuesFrom restriction -- the IRI scheme reserves pcfIDs for catalog-backed process classes and the process shape requires a pcfID on any class bearing an I/O restriction). Minted to de-conflate the compound row 12.4.5.1 (Phase-1): producing a Directive WorkRequirementsSpecification is a planning/decision facet whose genus is ex:ActOfFormulation (Act of Planning), in agreement with its Directive output (GOLDEN PRINCIPLE). Its output ex:WorkRequirementsSpecification is recorded here and in the definition rather than as a restriction. It is a cco:has process part of the appraisal P11056, which keeps only its Descriptive output." ;
    skos:example "In-house counsel breaks down a dispute into the tasks to hand to outside counsel and documents the action requirements." ;
    rdfs:subClassOf ex:ActOfFormulation .

# --- 12.4.5.1 (PCF 11056) : Appraisal -> Descriptive judgement (Directive facet split out)
ex:P11056 a owl:Class ;
    ex:pcfID "11056" ; ex:hierarchyID "12.4.5.1" ;
    ex:apqcSourceText "Examining the problems and deciding the action requirements for engaging outside counsel. This process element calls upon the organization to internally analyze the issues for which assistance from external counsel is needed. Additionally, the organization needs to break-down the issue, identifying the tasks and exercises where outside counsel can help." ;
    rdfs:label "Assess problem and determine work requirements" ;
    skos:definition "An Act of Appraisal that examines the legal issues for which external counsel is needed and has as output a legal problem statement, and which has as process part the determination of the legal work requirements." ;
    rdfs:comment "SPLIT (Gate-F GOLDEN-PRINCIPLE / Phase-1): previously a single Act of Appraisal carrying TWO definitional existential outputs of opposite kind -- ex:LegalProblemStatement (Descriptive, the judgement, agreeing with Appraisal) and ex:WorkRequirementsSpecification (Directive, the determined action requirements). A Directive specification is a planning/decision facet, so the appraisal genus disagreed with one of its own mandatory outputs. The compound row is de-conflated: P11056 retains only its Descriptive output (LegalProblemStatement), and the Directive-producing facet is the supporting ex:ActOfFormulation class ex:DetermineLegalWorkRequirements, linked via cco:has process part (cco:ont00001777)." ;
    skos:example "In-house counsel scopes a dispute (the appraisal) and, as a part, specifies the tasks to hand to outside counsel." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LegalProblemStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:DetermineLegalWorkRequirements ] .

# --- 12.4.5.2 (PCF 11057) : Acquisition (obtain counsel services)
ex:P11057 a owl:Class ;
    ex:pcfID "11057" ; ex:hierarchyID "12.4.5.2" ;
    ex:apqcSourceText "Recruiting the assistance of outside counsel for any legal and/or ethical concerns. Engage and/or retain any external counsel sought from subject matter experts and professionals." ;
    rdfs:label "Engage/Retain outside counsel if necessary" ;
    skos:definition "An Act of Acquisition that obtains the assistance of outside counsel for legal or ethical concerns, taking a work requirements specification as input." ;
    rdfs:comment "Reuses shared genus ex:ActOfAcquisition: the organization obtains counsel services it did not previously hold. WorkRequirementsSpecification from 12.4.5.1 is a definitional input; OutsideCounsel is a definitional participant." ;
    skos:example "The legal department retains an external IP firm to handle a patent suit." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkRequirementsSpecification ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:OutsideCounsel ] .

# --- 12.4.5.3 (PCF 11058) : Information Processing (receive a budget)
ex:P11058 a owl:Class ;
    ex:pcfID "11058" ; ex:hierarchyID "12.4.5.3" ;
    ex:apqcSourceText "Making a financial plan. This strategy sets out, using figures, an organization's expected future results. Enlist the finance function to support work generated by other business functions in order to build and secure their support for the budget." ;
    rdfs:label "Receive strategy/budget" ;
    skos:definition "An Act of Information Processing that receives a budget, a financial plan setting out expected future results in figures, for the engaged legal work." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): an input ICE (the Budget, a Directive ICE) is received. Budget is the definitional input." ;
    skos:example "The legal team receives the finance-approved budget for an outside-counsel engagement." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:Budget ] .

# --- 12.4.5.4 (PCF 11059) : Monitoring -> Descriptive ICE (work-product record)
ex:P11059 a owl:Class ;
    ex:pcfID "11059" ; ex:hierarchyID "12.4.5.4" ;
    ex:apqcSourceText "Receiving deliverables from outside counsel, and monitoring the efforts committed by them. Track the progress of, collect, and validate the required work product from the subject matter experts and professionals engaged as external counsel. Verify the amount of effort dedicated by these counsels to the issue at hand, in order to confirm their fees." ;
    rdfs:label "Receive work product and manage/monitor case and work performed" ;
    skos:definition "An Act of Monitoring that receives the work product of engaged outside counsel, tracks and validates the committed effort, and has as output a work product validation record used to confirm fees." ;
    rdfs:comment "I/O CORRECTED (Gate-F, Phase-3): previously the identical class ex:WorkProductDeliverable was asserted as BOTH has-input and has-output, making the input/output distinction vacuous and over-committing (thin-class risk). The received raw deliverable (input) and the validated tracking/effort record the act produces (output) are different ICEs. Now has-input the received deliverable ex:LegalWorkProduct and has-output the distinct ex:WorkProductValidationRecord (the validated effort/fee-confirmation record). Reuses PROPOSE-EXT genus ex:ActOfMonitoring; OutsideCounsel is a definitional participant." ;
    skos:example "In-house counsel logs and verifies a law firm's filed briefs and billed hours before approving fees." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:LegalWorkProduct ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkProductValidationRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:OutsideCounsel ] .

# --- 12.4.5.5 (PCF 11060) : Payment (material output) ; informational input = Invoice
ex:P11060 a owl:Class ;
    ex:pcfID "11060" ; ex:hierarchyID "12.4.5.5" ;
    ex:apqcSourceText "Making payments to legal advisers for their services. Payments include addressing issues or suits by customers, suppliers, competitors, bankers, government agencies, etc." ;
    rdfs:label "Process payment for legal services" ;
    skos:definition "An Act of Payment that transfers consideration to a legal adviser for services rendered, taking an invoice as input, transferring a payment as a material participant, and having a payment record as its informational output." ;
    rdfs:comment "Reuses PROPOSE-EXT genus ex:ActOfPayment. Definitional informational output is the Descriptive ICE ex:PaymentRecord (the remittance/payment record); the transferred money ex:Payment is the material entity moved by the act and is modeled as a definitional participant (obo:BFO_0000057), not as a has-output filler, because process outputs in this domain are ICEs (S3 OutputIsICE). Invoice is the informational (Descriptive ICE) input; Advisor is a definitional participant." ;
    skos:example "Accounts payable settles an outside-counsel invoice for litigation services and logs the remittance." ;
    rdfs:subClassOf ex:ActOfPayment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:Invoice ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PaymentRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Payment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Advisor ] .

# --- 12.4.5.6 (PCF 11061) : Monitoring -> Descriptive ICE (LegalActivityRecord)
ex:P11061 a owl:Class ;
    ex:pcfID "11061" ; ex:hierarchyID "12.4.5.6" ;
    ex:apqcSourceText "Keeping track of the legal activities and performance of the organization." ;
    rdfs:label "Track legal activity/performance" ;
    skos:definition "An Act of Monitoring that tracks the legal activities and performance of the organization and has as output a legal activity record." ;
    rdfs:comment "Reuses PROPOSE-EXT genus ex:ActOfMonitoring; its descriptive output LegalActivityRecord records ongoing legal activity, satisfying the GOLDEN PRINCIPLE." ;
    skos:example "The legal operations team maintains a register of active matters and outcomes." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LegalActivityRecord ] .

# --- 12.4.6 (PCF 11049) : standing IP-protection function -> Organization Capability
ex:P11049 a owl:Class ;
    ex:pcfID "11049" ; ex:hierarchyID "12.4.6" ;
    ex:apqcSourceText "Safeguarding the intellectual property of the organization. This process requires the organization to protect a wide variety of intellectual property created by it. It involves creating and managing non-disclosure agreements (NDAs), following up on current developments in the areas where the organization holds patents, tracking the use of the organization's copyrighted material, creating and upholding licensing terms, and administering policies for safeguarding intellectual property." ;
    rdfs:label "Protect intellectual property" ;
    skos:definition "An Organization Capability that an Organization realizes in the acts by which it safeguards, registers, licenses, and polices its intellectual property." ;
    rdfs:comment "R5/R6: an ongoing 'safeguarding/administering policies' function with no natural end, so an Organization Capability (cco:ont00000568). Realized in its four bounded child acts (12.4.6.1-12.4.6.4). Narrower, pcf-bearing refinement of the shared ex:IntellectualPropertyManagementCapability." ;
    rdfs:subClassOf cco:ont00000568 , ex:IntellectualPropertyManagementCapability ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11062 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11063 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11064 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11065 ] .

# --- 12.4.6.1 (PCF 11062) : Relationship Management of the IP portfolio
ex:P11062 a owl:Class ;
    ex:pcfID "11062" ; ex:hierarchyID "12.4.6.1" ;
    ex:apqcSourceText "Managing the patents and copyrights already held or sought by the organization. Administer and oversee applying for, securing, and maintaining intellectual property rights in the form of patents and copyrights. Submit applications for such rights. Handle associated legal issues. Draft and communicate proper attributions. Collect royalties. Monitor any misuse of the intellectual property rights." ;
    rdfs:label "Manage copyrights, patents, and trademarks" ;
    skos:definition "An Act of Acquisition that applies for, secures, and maintains the organization's patents, copyrights, and trademarks and has as output the resulting intellectual property right." ;
    rdfs:comment "RE-ANCHORED (Gate-F false-friend): previously ex:ActOfRelationshipManagement (=> cco:ont00000433 'Act of Association' = 'an Agent unites with some other Agent in a Planned Act, enterprise or business'). The source describes administering an IP ASSET portfolio -- applying for, securing, maintaining rights; submitting applications; collecting royalties; monitoring misuse -- with no uniting-with-an-external-Agent to ground an Act of Association; the dominant definitional move is obtaining/securing the IntellectualPropertyRight, i.e. acquisition, not social uniting. 'Manage' -> RelationshipManagement was a surface-word false friend (D2/§6). Re-anchored to the shared genus ex:ActOfAcquisition (a Planned Act in which an Agent obtains an entity it did not previously hold), keeping the IntellectualPropertyRight (Directive ICE) as definitional output. Royalty collection and misuse monitoring remain typical, non-definitional sub-steps (this comment, not restrictions). Evaluated minting a dedicated ex:ActOfPortfolioAdministration (=> cco:ont00000228) but the acquisition core is captured by the existing shared genus, so no new genus is minted (reuse-before-mint, D5)." ;
    skos:example "The IP office files and renews patents and pursues infringers of company trademarks." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IntellectualPropertyRight ] .

# --- 12.4.6.2 (PCF 11063) : Formulation -> Directive ICE (IntellectualPropertyPolicy)
ex:P11063 a owl:Class ;
    ex:pcfID "11063" ; ex:hierarchyID "12.4.6.2" ;
    ex:apqcSourceText "Managing the upkeep of intellectual property rights by creating and managing a framework of rules, policies, procedures, and restrictions. Outline a clear policy for any possible scenario of their use by any external agent." ;
    rdfs:label "Maintain intellectual property rights and restrictions" ;
    skos:definition "An Act of Formulation that creates a framework of rules, procedures, and restrictions governing the use of the organization's intellectual property and has as output an intellectual property policy." ;
    rdfs:comment "Output IntellectualPropertyPolicy is a Directive ICE, so the genus is Formulation (Act of Planning), not relationship management; the definitional move is composing the policy framework." ;
    skos:example "Legal drafts the company policy governing third-party use of its patents." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IntellectualPropertyPolicy ] .

# --- 12.4.6.3 (PCF 11064) : Formulation -> Directive ICE (LicensingTerms)
ex:P11064 a owl:Class ;
    ex:pcfID "11064" ; ex:hierarchyID "12.4.6.3" ;
    ex:apqcSourceText "Administering and overseeing the terms and policies associated with licensing the organization's intellectual property. Create and manage the policies and terms governing the possible granting of a license to any external agent. Demarcate a clear framework that governs the licensing of any patents or copyrights held by the organization." ;
    rdfs:label "Administer licensing terms" ;
    skos:definition "An Act of Formulation that creates the policies and terms governing the licensing of the organization's intellectual property and has as output licensing terms." ;
    rdfs:comment "Output LicensingTerms is a Directive ICE, so the genus is Formulation; the definitional move is composing the licensing framework rather than ongoing oversight." ;
    skos:example "Legal demarcates the standard royalty and field-of-use terms for licensing company patents." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LicensingTerms ] .

# --- 12.4.6.4 (PCF 11065) : Relationship Management of licensing options
ex:P11065 a owl:Class ;
    ex:pcfID "11065" ; ex:hierarchyID "12.4.6.4" ;
    ex:apqcSourceText "Managing options regarding licensing agreements. Follow favorable terms and conditions." ;
    rdfs:label "Administer options" ;
    skos:definition "A Planned Act that administers and exercises the options available under the organization's licensing agreements so as to follow favorable terms and conditions, taking the governing licensing terms as input." ;
    rdfs:comment "RE-ANCHORED (Gate-F false-friend, same pattern as P11062): previously ex:ActOfRelationshipManagement (=> cco:ont00000433 'Act of Association'). There is no uniting-with-an-external-Agent here -- exercising/overseeing contractual options is decision/management over a Directive ICE (the governing ex:LicensingTerms), not a social uniting; 'administer/manage' -> Act of Association was a surface-word false friend. Re-anchored to cco:ont00000228 (Planned Act), keeping P11065 in the same corrected Planned-Act genus family as the reconciled P11062 (ex:ActOfAcquisition => Planned Act) rather than both defaulting to Act of Association. Considered ex:ActOfSelection (Information Processing) but rejected it: the source 'follow favorable terms' is overseeing/exercising an already-granted option, and the apqc-ext caveat notes that ratifying a single already-settled option is NOT Selection (no candidate set), so the generic Planned Act is the correct anchor. LicensingTerms is the definitional input governing the options." ;
    skos:example "The IP office exercises a renewal option on a favorable inbound licensing agreement." ;
    rdfs:subClassOf cco:ont00000228 ,   # Planned Act
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:LicensingTerms ] .

# --- 12.4.7 (PCF 11050) : Formulation -> Directive ICE (DisputeResolution)
ex:P11050 a owl:Class ;
    ex:pcfID "11050" ; ex:hierarchyID "12.4.7" ;
    ex:apqcSourceText "Resolving disputes or civil lawsuits internally or externally." ;
    rdfs:label "Resolve disputes and litigations" ;
    skos:definition "An Act of Negotiation that settles a dispute or civil lawsuit between adverse parties, internally or externally, and has as output a dispute resolution." ;
    rdfs:comment "RE-ANCHORED (Gate-F sibling consistency): previously ex:ActOfFormulation (=> cco:ont00000511 'Act of Planning' = making a plan to achieve an objective), but a dispute resolution is reached through negotiation or adjudication BETWEEN adverse parties -- a Social Act, not a solo planning act (the slice's own skos:example says the team 'negotiates a settlement'). The parallel binding-settlement sibling P11052 'Negotiate and document agreements' correctly uses ex:ActOfNegotiation (a Social Act), so P11050 is anchored consistently. Output DisputeResolution (Directive ICE) is retained: ex:ActOfNegotiation is defined as producing a Directive ICE such as a contract/settlement that prescribes the agreed terms, so the GOLDEN PRINCIPLE holds (negotiation's bargained output is directive). OutsideCounsel is a typical, non-definitional participant (external resolution only)." ;
    skos:example "The legal team negotiates a settlement that ends a supplier lawsuit." ;
    rdfs:subClassOf ex:ActOfNegotiation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DisputeResolution ] .

# --- 12.4.8 (PCF 11051) : Act of Communication -> Descriptive ICE (LegalAdvice)
ex:P11051 a owl:Class ;
    ex:pcfID "11051" ; ex:hierarchyID "12.4.8" ;
    ex:apqcSourceText "Providing legal advice concerning the substance or procedure of a law in relation to a particular situation." ;
    rdfs:label "Provide legal advice/counseling" ;
    skos:definition "An Act of Communication that conveys legal advice concerning the substance or procedure of a law in relation to a particular situation and has that legal advice as output." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): providing advice transfers an ICE from adviser to recipient. Output LegalAdvice is a Descriptive ICE (it represents/explains the legal position rather than prescribing a binding action), satisfying the GOLDEN PRINCIPLE for an information/advisory act. Advisor is a definitional participant." ;
    skos:example "Counsel advises management on the disclosure obligations triggered by an acquisition." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; Act of Communication -> Planned Act in CCO closure)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LegalAdvice ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Advisor ] .

# --- 12.4.9 (PCF 11052) : Negotiation -> Directive ICE (Contract)
ex:P11052 a owl:Class ;
    ex:pcfID "11052" ; ex:hierarchyID "12.4.9" ;
    ex:apqcSourceText "Negotiating terms to reach a final draft of a contract that is acceptable to all parties." ;
    rdfs:label "Negotiate and document agreements/contracts" ;
    skos:definition "An Act of Negotiation that exchanges offers among parties to reach a final draft of a contract acceptable to all of them and has that contract as output." ;
    rdfs:comment "Reuses PROPOSE-EXT genus ex:ActOfNegotiation (a Social Act). Output Contract is a Directive ICE, consistent with a negotiated, binding agreement." ;
    skos:example "Counsel negotiates and finalizes a master services agreement with a vendor." ;
    rdfs:subClassOf ex:ActOfNegotiation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:Contract ] .

####################################################################
# GROUP 12.5  Manage public relations program
####################################################################

# --- 12.5 (PCF 11014) : standing public-relations function -> Capability [R6]
#     Modeled by reusing the shared ex:PublicRelationsCapability and
#     asserting its realization in the modeled child acts. The catalog
#     node ex:PCF_11014 designates ex:PublicRelationsCapability.
ex:PublicRelationsCapability rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11066 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11067 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11068 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11069 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11070 ] .

# --- 12.5.1 (PCF 11066) : Relationship management (community)
ex:P11066 a owl:Class ;
    ex:pcfID "11066" ;
    ex:hierarchyID "12.5.1" ;
    ex:apqcSourceText "Developing and administering community relations. Establish business connections with the people constituting the environment the organization operates in and draws resources from in order to foster mutual understanding, trust, and support. Create programs that promote the organization's image in a positive and community-oriented way." ;
    rdfs:label "Manage community relations" ;
    skos:definition "An Act of Relationship Management in which an Agent develops and administers connections with the community in which an organization operates in order to foster mutual understanding, trust, and support, and has the community as participant." ;
    rdfs:comment "R5: bounded, repeatable relationship-management engagement (a realization of the public-relations capability), not the standing function itself. Typical output: an ex:RelationshipStatusReport; left in comment (not a someValuesFrom restriction) because not every instance produces one (Phase-3 necessity)." ;
    skos:example "A community-affairs team runs a neighbourhood sponsorship program and meets with local leaders to build goodwill." ;
    rdfs:subClassOf ex:ActOfRelationshipManagement ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Community ] .

# --- 12.5.2 (PCF 11067) : Relationship management (media / journalists)
ex:P11067 a owl:Class ;
    ex:pcfID "11067" ;
    ex:hierarchyID "12.5.2" ;
    ex:apqcSourceText "Developing and managing relations with media. Develop connections with journalists to solicit critical, third-party endorsements for a product, issue, service, or organization." ;
    rdfs:label "Manage media relations" ;
    skos:definition "An Act of Relationship Management in which an Agent develops and manages connections with media outlets and journalists in order to solicit third-party endorsements for a product, issue, service, or organization, and has a journalist as participant." ;
    rdfs:comment "R5: bounded, repeatable relationship-management engagement with the press. Participant ex:Journalist is definitional (relations are developed with journalists); ex:MediaOutlet is the typical organizational counterparty and is noted here rather than asserted as a restriction." ;
    skos:example "A PR officer pitches a feature story to a journalist and cultivates an ongoing media contact list." ;
    rdfs:subClassOf ex:ActOfRelationshipManagement ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Journalist ] .

# --- 12.5.3 (PCF 11068) : Advocacy / civic engagement
ex:P11068 a owl:Class ;
    ex:pcfID "11068" ;
    ex:hierarchyID "12.5.3" ;
    ex:apqcSourceText "Promoting political security and stability in the regions where the organization conducts business. Encourage political stability in the regions where the organization operates. Support civic programs, citizen engagement, connection platforms, etc." ;
    rdfs:label "Promote political stability" ;
    skos:definition "An Act of Advocacy in which an Agent promotes and encourages political security and stability in the regions where an organization operates -- supporting civic programs, citizen engagement, and connection platforms -- and has a government body as participant." ;
    rdfs:comment "RE-ANCHORED (Gate-F false-friend): previously ex:ActOfRelationshipManagement (=> cco:ont00000433 'Act of Association' = 'an Agent unites with some other Agent in a Planned Act, enterprise or business'). The de-conflated lead verbs are 'Promote / Encourage political security and stability' and 'Support civic programs, citizen engagement, connection platforms' -- the dominant intent is advocacy / influencing the societal-political environment, not bilateral uniting into a shared enterprise. The prior comment ('unites the org with civic/government parties') re-read an advocacy verb as an association verb -- exactly the false friend the methodology warns against (verify the differentia, not the surface). Re-anchored to the new shared-extension genus ex:ActOfAdvocacy (=> cco:ont00001327 Social Act). Evaluated cco:ont00000079 'Act of Social Movement' (verified: 'A Social Act composed of a series of performances, displays and campaigns directed at implementing, resisting or undoing a change in society') as the nearer Social-Act sibling: it fits campaign-driven activism but is narrower than the general supporting/promoting intent here (supporting civic programs and citizen-engagement platforms is not necessarily a movement to implement/resist/undo a societal change), so the dedicated ex:ActOfAdvocacy genus was preferred over both ont00000079 and Act of Association. (NB: the review note's 'cco:ont00000478' is NOT Act of Social Movement -- ont00000478 is 'Cuboidal', a shape; the correct Social-Movement IRI is ont00000079, verified in the closure.) ex:Community is also a typical participant (noted, not asserted)." ;
    skos:example "A corporate-affairs unit funds a local civic-engagement platform and partners with a municipal authority to support regional stability." ;
    rdfs:subClassOf ex:ActOfAdvocacy ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:GovernmentBody ] .

# --- 12.5.4 (PCF 11069) : Information processing -> compose a Descriptive ICE
ex:P11069 a owl:Class ;
    ex:pcfID "11069" ;
    ex:hierarchyID "12.5.4" ;
    ex:apqcSourceText "Developing press releases to communicate developments and generate interest in the organization." ;
    rdfs:label "Create press releases" ;
    skos:definition "An Act of Information Processing in which an Agent composes a press release that describes organizational developments in order to generate interest in the organization, and has that press release as output." ;
    rdfs:comment "R5: bounded, repeatable authoring act. Anchored directly under cco:ont00000366 (Act of Information Processing) per the GOLDEN PRINCIPLE: its definitional output ex:PressRelease is a Descriptive ICE (a representation of developments), not a directive. Output is definitional (every instance yields a press release) so it is asserted as a restriction." ;
    skos:example "A communications writer drafts a press release announcing a new product launch." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PressRelease ] .

# --- 12.5.5 (PCF 11070) : Mass media communication -> issue/disseminate
ex:P11070 a owl:Class ;
    ex:pcfID "11070" ;
    ex:hierarchyID "12.5.5" ;
    ex:apqcSourceText "Issuing press releases to carefully selected media in distribution channels such as the web, newspapers, and social media." ;
    rdfs:label "Issue press releases" ;
    skos:definition "An Act of Mass Media Communication in which an Agent disseminates a press release to selected media in distribution channels such as the web, newspapers, and social media, and has a media outlet as participant." ;
    rdfs:comment "R5: bounded, repeatable dissemination act. Anchored under cco:ont00000588 (Act of Mass Media Communication, verified: 'intended to reach a large audience using a medium such as the internet, television, radio, newspaper, and magazine'). Input ex:PressRelease and participant ex:MediaOutlet are both definitional (issuing necessarily transfers an existing press release to media)." ;
    skos:example "A PR team distributes a finalized press release to wire services, newspapers, and the corporate social-media channels." ;
    rdfs:subClassOf cco:ont00000588 ,   # Act of Mass Media Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; Act of Mass Media Communication -> Act of Communication -> Planned Act in CCO closure)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PressRelease ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:MediaOutlet ] .

