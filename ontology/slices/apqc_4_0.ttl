@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC PCF -> BFO 2020 / CCO 2.0  REALITY-LAYER MODULE
# Section 4.0 "Manage Supply Chain for Physical Products" (PCF 10004*)
#
# Assembled, reconciled single module covering process groups
# 4.1 - 4.4 plus the section-wide shared supporting vocabulary and the
# catalog->reality bridges. House style + prefixes mirror the GOLD
# reference ontology/slices/apqc_1_1_1.ttl.
#
# CCO pin: v2.0 (2024-11-06). Every cco:ont... IRI below was verified
# against vendor/cco/CommonCoreOntologiesMerged.ttl (definition read,
# not just label). Verified anchors:
#   Act of Planning                 cco:ont00000511
#   Planned Act                     cco:ont00000228
#   Act of Information Processing    cco:ont00000366
#   Act of Appraisal                 cco:ont00000636
#   Act of Measuring                 cco:ont00000345
#   Act of Maintenance               cco:ont00000950
#   Act of Material Artifact Processing  cco:ont00000908
#   Act of Location Change           cco:ont00000065
#   Act of Cargo Transportation      cco:ont00000595
#   Act of Contract Formation        cco:ont00000684
#   Descriptive ICE                  cco:ont00000853
#   Prescriptive (Directive) ICE     cco:ont00000965
#   Agent                            cco:ont00001017
#   Organization                     cco:ont00001180
#   Organization Capability          cco:ont00000568
#   Agent Capability                 cco:ont00001379
#   Material Artifact                cco:ont00000995
#   Facility                         cco:ont00000192   (NB: ont00000130 is
#       "Power Transformer", NOT Facility -- corrected during assembly)
#   Vehicle                          cco:ont00000713
#   Portion of Material              cco:ont00000457
#   is about                         cco:ont00001808
#   has input / has output           cco:ont00001921 / cco:ont00001986
#   has process part                 cco:ont00001777
#   has capability                   cco:ont00001954
#   role / bearer of / realized in / has participant
#       obo:BFO_0000023 / obo:BFO_0000196 / obo:BFO_0000054 / obo:BFO_0000057
####################################################################

<http://example.org/apqc/slice/4.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 4.0: Manage Supply Chain for Physical Products" ;
    dct:source "APQC Process Classification Framework (Cross-Industry)" ;
    owl:versionInfo "0.3.0" ;
    rdfs:comment "Reality-layer module for APQC section 4.0 (groups 4.1-4.4) plus the section-wide shared supporting vocabulary. CCO pin v2.0 (2024-11-06); modeling decisions follow ADR-001 (reality layer only; the SKOS catalog lives in apqc-catalog.ttl). Self-contained: the shared act genera it uses are inlined from the apqc-ext.ttl registry, so it validates standalone against the pinned CCO/BFO closure with no extension merge." .

####################################################################
# ACT GENERA -- SELF-CONTAINED (canonical defs mirrored from
# apqc-ext.ttl, the D9 shared registry). Inlined so this module
# validates standalone against CCO without merging the extension.
####################################################################

ex:ActOfAcquisition a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Acquisition" ;
    skos:definition "A Planned Act in which an Agent obtains from some authority or supplier an entity (such as an authorization, license, or resource) that the Agent did not previously hold." ;
    rdfs:comment "Local extension (D9). Rejected cco:ont00000950 'Act of Maintenance' (modifying Material Artifacts) and cco:ont00000402 'Act of Communication' (mere ICE transfer). Securing/obtaining a held entity anchors at the generic Planned Act. Expected to recur in procurement/asset-acquisition categories (4.0, 10.0)." .

ex:ActOfAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Analysis" ;
    skos:definition "An Act of Information Processing in which an Agent examines one or more input Information Content Entities and produces an Information Content Entity that represents an understanding of their subject matter." ;
    rdfs:comment "Local extension (D9). CCO 2.0 has no generic analysis class; analysis is information processing, so it is anchored under cco:ont00000366." .

ex:ActOfForecasting a owl:Class ;
    rdfs:subClassOf cco:ont00000371 ,   # Act of Prediction
        cco:ont00000228 ;               # Planned Act (explicit; Act of Prediction subClassOf Planned Act in CCO, asserted so standalone SHACL S2 resolves)
    rdfs:label "Act of Forecasting" ;
    skos:definition "An Act of Prediction in which an Agent extrapolates from historical and current Information Content Entities to produce a Predictive Information Content Entity that estimates a future quantity such as demand, volume, revenue, or value." ;
    rdfs:comment "Inlined canonical shared genus (apqc-ext.ttl registry). Anchored under cco:ont00000371 (Act of Prediction; parent cco:ont00000228), whose definitional output is a Predictive ICE (cco:ont00000626 subClassOf cco:ont00000853) -- exactly the genus of a demand/sales/volume forecast. Recurs in 3.0/5.0/6.0/8.0/10.0/4.0." .

ex:ActOfFormulation a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Formulation" ;
    skos:definition "An Act of Planning in which an Agent composes and articulates a Directive Information Content Entity - such as a mission, strategy, objective, design, roadmap, or business model - that prescribes an organization's intended course of action." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000511 (Act of Planning) because formulating a strategy/mission/design is making a plan to achieve an objective; its output is a Directive ICE. Recurs across develop/define/compose-a-directive processes corpus-wide." .

ex:ActOfIdentification a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Identification (discernment sense)" ;
    skos:definition "An Act of Information Processing in which an Agent discerns and enumerates entities of a given kind and produces an Information Content Entity that registers them." ;
    rdfs:comment "Local extension (D9). NOT cco:ont00001261 'Act of Identifying' (a communication act). APQC 'Identify ...' denotes discernment, i.e. information processing." .

ex:ActOfMonitoring a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Monitoring" ;
    skos:definition "An Act of Information Processing in which an Agent repeatedly or continuously observes the state, progress, or performance of some process, system, or quantity over time and produces a Descriptive Information Content Entity that represents its tracked status against expected conditions, targets, or requirements." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic monitoring/tracking class. Anchored under cco:ont00000366 (Act of Information Processing) because monitoring ingests repeated observations (including electronic records, not only senses) and yields a descriptive status/deviation ICE -- the GOLDEN PRINCIPLE (descriptive output => information-processing genus) holds. Rejected cco:ont00000037 (Act of Observation: a single sense-based acquisition, too narrow -- monitoring also processes ICEs and is sustained); cco:ont00000636 (Act of Appraisal: renders a single bounded value/quality judgement rather than tracking status over time); and cco:ont00000345 (Act of Measuring: a single quantification against a standard at one time -- at most a method sub-step of the monitoring cycle; a node that is purely one quantification, e.g. Calculate performance measures, anchors to cco:ont00000345 directly, not here). Distinct from ex:ActOfAnalysis (one-shot examination of a fixed input set) by its continuous, longitudinal character. A standing 'Manage/Monitor X' function with no natural end is an Organization Capability (cco:ont00000568) realized in such acts, not itself a process. Recurs corpus-wide (slices 3.0/4.0/5.0/6.0/8.0/9.0/10.0/11.0/12.0/13.0). Reconciled from 10 divergent slice restatements to one definition." .

ex:ActOfProcessControl a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Process Control" ;
    skos:definition "A Planned Act in which an Agent, or an automation system acting for an Agent, regulates a running production process or plant by closing the loop between observation and actuation -- adjusting setpoints, parameters, and equipment so as to keep the process within target or optimize its performance." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000228 (Planned Act): closed-loop control ACTS ON the plant (it changes setpoints and equipment state), so its product is a change in the controlled material participants, not a Descriptive ICE. Rejected ex:ActOfMonitoring (cco:ont00000366, Act of Information Processing): monitoring is the OBSERVE half only and over-commits to a descriptive output, whereas advanced process control / real-time optimization also ACTUATE. The controlled equipment is attached via obo:BFO_0000057 (has participant). Recurs across automate/control-plant and industrial-control activities (4.0)." .

ex:ActOfProduction a owl:Class ;
    rdfs:subClassOf cco:ont00000908 ,   # Act of Material Artifact Processing
        cco:ont00000228 ;               # Planned Act (explicit; entailed via ont00000908, asserted so SHACL S2/S5 resolve standalone)
    rdfs:label "Act of Production" ;
    skos:definition "An Act of Material Artifact Processing in which an Agent transforms raw materials and components into finished Material Artifacts according to a production specification or schedule." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000908 (Act of Material Artifact Processing, verified: 'A Planned Act of performing a series of physical operations on a material artifact in order to change or preserve the artifact'; parent cco:ont00000228), the common parent of Act of Manufacturing (cco:ont00001359) and Act of Artifact Assembly. Generalizes produce/assemble-product where APQC covers both mass manufacturing and assembly; cco:ont00001359 (mass production for sale) alone is too narrow and Assembly alone excludes non-assembly production, so the shared genus sits at their common parent. The material product is attached via obo:BFO_0000057 (has participant), NOT has output -- a deliberate CORPUS-LOCAL CONVENTION (not a missing output): cco:has output is used only for informational (ICE) outputs in these reality slices, so material products produced or moved by operations attach via bfo:has participant. CCO itself permits a material has-output; adopting that pattern corpus-wide is an open policy option (see methodology section 10). Recurs in physical-production categories (4.0, 6.0)." .

ex:ActOfScheduling a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Scheduling" ;
    skos:definition "An Act of Planning in which an Agent fixes the timing, sequencing, and resource allocation of future activities and produces a schedule (a Directive Information Content Entity) that prescribes when, in what order, and by whom those activities are to be performed." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000511 (Act of Planning, verified: 'A Planned Act that involves making a Plan to achieve some specified Objective'): a schedule is a plan whose differentia is the temporal/resource ordering of activities; its output is a Directive ICE, satisfying the GOLDEN PRINCIPLE. Distinct from ex:ActOfFormulation (mission/strategy/design) by its specifically temporal/resource-allocation product. Recurs across operations and project categories (4.0, 6.0, 8.0)." .

ex:ActOfSelection a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Selection" ;
    skos:definition "An Act of Information Processing in which an Agent chooses one or more options from a set of candidates and produces a Directive Information Content Entity that prescribes the chosen option(s)." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000366 (Act of Information Processing): receives candidate-option ICEs and yields a decision ICE. Distinct from Act of Appraisal (judges without committing) and Act of Planning. NOTE: ratifying a single already-settled option is NOT selection (no candidate set) -- anchor such acts at cco:ont00000228 (Planned Act)." .

ex:ActOfTransportation a owl:Class ;
    rdfs:subClassOf cco:ont00000065 ,   # Act of Location Change
        cco:ont00000228 ;               # Planned Act (explicit; entailed via ont00000065, asserted so SHACL S2/S5 resolve standalone)
    rdfs:label "Act of Transportation" ;
    skos:definition "An Act of Location Change in which an Agent moves materials or finished products from one supply-chain location to another, such as from a source to a warehouse, distribution center, or customer." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000065 (Act of Location Change, verified: 'An Act of Motion in which the location of some Object is changed by some Agent'; parent cco:ont00000357 Act of Motion -> ... -> Planned Act), the parent of cco:ont00000595 'Act of Cargo Transportation'. Generalizes inbound/outbound movement, picking-packing-shipping, and warehouse transfers; cco:ont00000595 is a close fit but is scoped to a Payload being conveyed, whereas ex:ActOfTransportation also covers internal warehouse transfers and deployment. Recurs across physical-logistics categories (4.0, 6.0, 9.0)." .

####################################################################
# 0. ANNOTATION PROPERTIES (provenance + catalog->reality bridge)
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "ADR-001 R4 bridge: catalog node (ex:PCF_<id>, defined in apqc-catalog.ttl) -> reality-layer process universal or capability. Populated during reality-layer modeling, NOT by the catalog generator." .

####################################################################
# 1. ACT-GENUS LAYER  (section-specific genera; canonical shared genera
#    are inlined above from the apqc-ext.ttl registry). Each appears ONCE
#    here; the group modules below reference them. Inlined shared genera:
#    ex:ActOfAnalysis, ex:ActOfIdentification,
#    ex:ActOfFormulation, ex:ActOfSelection, ex:ActOfAcquisition.
#    Reused-as-is from CCO: cco:ont00000366 (Act of Information
#    Processing), cco:ont00000636 (Act of Appraisal), cco:ont00000511
#    (Act of Planning), cco:ont00000228 (Planned Act), cco:ont00000345
#    (Act of Measuring), cco:ont00000950 (Act of Maintenance),
#    cco:ont00000684 (Act of Contract Formation).
####################################################################

####################################################################
# 2. SHARED SUPPORTING VOCABULARY -- APQC Section 4.0
# "Manage Supply Chain for Physical Products"
#
# Minted ONCE here for reuse by all four group modules (4.1-4.4) so
# the section shares one consistent set of ICEs, material entities,
# agents/orgs, roles, and capabilities -- no collisions, no re-mints.
# Process classes (ex:P<pcfID> / readable group names) reference these.
#
# Every cco:ont... IRI below was verified against
# CommonCoreOntologiesMerged v2.0 (2024-11-06): definition + parent
# read, not just label.
#   Descriptive ICE   cco:ont00000853
#   Directive ICE     cco:ont00000965
#   Agent             cco:ont00001017
#   Organization      cco:ont00001180
#   Agent Capability  cco:ont00001379
#   Org Capability    cco:ont00000568
#   is about          cco:ont00001808
#   has capability    cco:ont00001954
#   role              obo:BFO_0000023
#   bearer of         obo:BFO_0000196
#   realized in       obo:BFO_0000054
#   Material Artifact cco:ont00000995
#   Vehicle           cco:ont00000713
#   Portion of Material cco:ont00000457
#   Facility          cco:ont00000192   (corrected from ont00000130)
####################################################################

####################################################################
# A. DIRECTIVE INFORMATION CONTENT ENTITIES  (cco:ont00000965)
####################################################################

# --- 4.1 strategy / policy / plan directives ---
ex:ProductionAndMaterialsStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Production and Materials Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's intended approach to production processes and the management of materials, including production and supply constraints." ;
    rdfs:comment "Shared 4.0 supporting class. Directive: a strategy prescribes a course of action (GOLDEN PRINCIPLE). Output of an Act of Formulation." .

ex:ManufacturingGoalSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Manufacturing Goal Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes quantifiable strategic objectives for one or more manufacturing segments." .

ex:LaborAndMaterialsPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Labor and Materials Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes internal rules and regulations governing employees and materials." .

ex:OutsourcingPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Outsourcing Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes rules and regulations governing the contracting out of business processes to other parties." .

ex:CapitalExpensePolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Capital Expense Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes rules and regulations governing expenditure on acquiring or upgrading manufacturing capital." .

ex:ProductionProcessSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Production Process Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the scheme for processing inventory into finished products or services, including the materials, machinery, and skills to be used." .

ex:StandardOperatingProcedure a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Standard Operating Procedure" ;
    skos:definition "A Directive Information Content Entity that prescribes step-by-step methods to be followed routinely for the performance of designated operations." .

ex:ProductionWorkplaceLayoutPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Production Workplace Layout Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the floor plan and infrastructure of a processing facility for delivering finished products or services." .

ex:ProductionBalanceAndControlScheme a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Production Balance and Control Scheme" ;
    skos:definition "A Directive Information Content Entity that prescribes an equilibrium production volume and a control scheme for systematically planning, coordinating, and directing manufacturing activities." .

ex:MaterialsPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Materials Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the advance provision of raw materials and spares required to meet market demand." ;
    rdfs:comment "Genus for both the unconstrained and the constrained materials plan; group modules may specialize as needed." .

ex:UnconstrainedMaterialsPlan a owl:Class ; rdfs:subClassOf ex:MaterialsPlan ;
    rdfs:label "Unconstrained Materials Plan" ;
    skos:definition "A Materials Plan that prescribes raw-material and inventory provision to meet market demand without yet accounting for supply-chain constraints." .

ex:ConstrainedMaterialsPlan a owl:Class ; rdfs:subClassOf ex:MaterialsPlan ;
    rdfs:label "Constrained Materials Plan" ;
    skos:definition "A Materials Plan that prescribes raw-material and inventory provision bounded by the actual supply-chain scenario." .

ex:ProductionNetworkModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Production Network Model" ;
    skos:definition "A Directive Information Content Entity that represents the logical production system, providing the framework of sequential flow and capacity relationships among raw materials, parts, resources, and finished products to enable simulation and optimization." ;
    rdfs:comment "Modeled as Directive when the model functions as a prescriptive blueprint for how the production network is to be configured or operated. A descriptive network representation (a model OF the current network for simulation/analysis) would instead be a Descriptive ICE; that reading is out of scope here. Reused for the plant model (4.3.1.1)." .

ex:MasterProductionSchedule a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Master Production Schedule" ;
    skos:definition "A Directive Information Content Entity that prescribes the planned quantity, timing, and staffing of internal production and inventory activities over a planning horizon." .

ex:DistributionRequirementsPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Distribution Requirements Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the finished-goods requirements, consolidation, replenishment, dispatch, and load arrangements for distributing products from source to destination." .

ex:DispatchPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Dispatch Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the timing, duration, routes, and logistics of delivering inventory from a source to a destination." .

ex:LoadPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Load Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes how loads are to be delivered to a given destination or partner." .

ex:ReplenishmentPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Replenishment Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the collaborative replenishment of inventory, including provision for faulty production." .

ex:DistributionPlanningConstraintSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Distribution Planning Constraint Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the constraints governing distribution planning, covering distribution-center layout, inventory, transportation, and storage management." .

ex:DistributionPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Distribution Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes guidelines for the distribution network, sourcing relationships, and dynamic product deployment across distribution centers." .

ex:QualityStandard a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality Standard" ;
    skos:definition "A Directive Information Content Entity that prescribes qualitative and quantitative quality targets for products or services." .

ex:QualityTestingProcedure a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality Testing Procedure" ;
    skos:definition "A Directive Information Content Entity that prescribes the standard steps and routine instructions for testing the quality of products or services." .

ex:KeyPerformanceIndicatorSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Key Performance Indicator Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the key performance measures by which the performance of a logistics or production strategy is to be evaluated." .

# --- 4.2 procurement directives ---
ex:ProcurementPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Procurement Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes what materials and services to buy, when, and from what sources, together with the supplier-selection approach and timeline." .

ex:PurchasingRequirementSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Purchasing Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the exact materials and services required for procurement, avoiding duplication or overlap." .

ex:MaterialsManagementContingencyPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Materials Management Contingency Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes how to react to issues arising during execution of the inventory plan, such as a vendor failing to deliver on time." .

ex:RequestForQuotation a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Request for Quotation" ;
    skos:definition "A Directive Information Content Entity that solicits suppliers to submit price quotes for specified products or services." .

ex:PurchaseRequisition a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Purchase Requisition" ;
    skos:definition "A Directive Information Content Entity that requests authorization to procure specified products or services to satisfy an internal need." .

ex:PurchaseOrder a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Purchase Order" ;
    skos:definition "A Directive Information Content Entity that directs a specified supplier to provide stated materials or services in stated quantities at agreed terms." .

ex:SupplierContract a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Supplier Contract" ;
    skos:definition "A Directive Information Content Entity that prescribes the mutually binding obligations between an organization and a supplier, including promised delivery, dates, and duration." .

ex:SupplierSelectionDecision a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Supplier ] ;
    rdfs:label "Supplier Selection Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes which supplier or suppliers are chosen, on the basis of material quality, delivery schedules, and cost." ;
    rdfs:comment "Directive because it selects and commits to a supplier for future action (Phase 3: a decision that authorizes/selects is a Directive ICE). Output of an Act of Selection." .

# --- 4.3 production / scheduling directives ---
ex:ProductionSchedule a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Production Schedule" ;
    skos:definition "A Directive Information Content Entity that prescribes the timing and sequencing of production activities for final products." ;
    rdfs:comment "Genus for the line-level plan and the detailed schedule; group modules may specialize." .

ex:ProductionOrder a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Production Order" ;
    skos:definition "A Directive Information Content Entity that prescribes which material to produce, where, by which operations, and on which date." .

ex:MaintenanceSchedule a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Maintenance Schedule" ;
    skos:definition "A Directive Information Content Entity that prescribes the timing of planned and unplanned maintenance of production equipment." .

ex:LotNumberingSystemSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Lot Numbering System Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the scheme for assigning lot identification numbers to quantities of manufactured material." .

ex:LotUsageSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductionLot ] ;
    rdfs:label "Lot Usage Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes where, how, and when a production lot is to be used." ;
    rdfs:comment "Minted (D5) as the forward-production output of Determine lot use [10377]. Distinct from ex:DispositionDecision, which is scoped to reverse logistics (it prescribes the disposition of a RETURNED PRODUCT and is about ex:ReturnedProduct); reusing it here would mis-relate the act to returns. Directive because it prescribes the allocation/consumption of a production lot." ;
    skos:example "A plan earmarking a specific lot for a customer order and setting its consumption window." .

# --- 4.4 logistics directives ---
ex:LogisticsStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Logistics Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's approach to managing logistics, including network design, outsourcing, and transportation cost and schedule optimization." .

ex:DeliveryServicePolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Delivery Service Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the rules, terms, and conditions governing how, when, and in what way services are delivered to customers." .

ex:ReverseLogisticsStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Reverse Logistics Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes the handling, information processing, and disposition of products and packaging returned by a buyer to a seller or intermediary." .

ex:LogisticsRequirementSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Logistics Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the logistics requirements derived from customer service requirements for managing flow between origin and consumption." .

ex:LogisticsNetworkDesign a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Logistics Network Design" ;
    skos:definition "A Directive Information Content Entity that prescribes the network of entities through which materials and information flow in logistical activities." .

ex:InboundMaterialReceiptPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Inbound Material Receipt Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the receipt of inbound materials procured from supply sources and delivered to a distribution center or warehouse." .

ex:OutboundTransportationPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Outbound Transportation Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the dispatch, transportation, and delivery of outbound products to their destinations." .

ex:CustomerCompensationOffer a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Customer Compensation Offer" ;
    skos:definition "A Directive Information Content Entity that proposes additional incentives or compensation to a customer in the event of a defective delivery or specification discrepancy, in order to retain the order and avoid a permanent return." ;
    rdfs:comment "Minted (D5) as the conveyed deliverable of Perform salvage activities [10366], whose Element Description is about presenting customer incentives, not physical reconditioning. Directive because an offer proposes terms/action to the customer. Distinct from ex:DispositionDecision (reverse-logistics disposition of a returned artifact)." ;
    skos:example "A retention offer of a partial refund and free reshipment made to keep a customer from returning a discrepant order." .

ex:DispositionDecision a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ReturnedProduct ] ;
    rdfs:label "Disposition Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes whether a returned product is to be salvaged, repaired, refurbished, or returned to inventory." ;
    rdfs:comment "Directive because it authorizes a course of action on the returned product (Phase 3). Output of an Act of Selection over disposition options." .

####################################################################
# B. DESCRIPTIVE INFORMATION CONTENT ENTITIES  (cco:ont00000853)
####################################################################

# --- demand / forecasting ---
ex:DemandForecast a owl:Class ;
    rdfs:subClassOf cco:ont00000626 ,   # Predictive Information Content Entity
        cco:ont00000853 ;               # Descriptive ICE (allowlisted ICE anchor; co-asserted because 626 is outside the S3/S4 allowlist)
    rdfs:label "Demand Forecast" ;
    skos:definition "A Predictive Information Content Entity that estimates the anticipated future demand for an organization's products or services." ;
    rdfs:comment "Predictive (cco:ont00000626, a specialization of Descriptive cco:ont00000853): a forecast estimates an uncertain future demand state rather than prescribing action. Re-anchored from plain cco:ont00000853 to match the corpus forecast pattern (slice 5's identical ex:DemandForecast is 626+853); cco:ont00000853 co-asserted because 626 is outside the S3/S4 ICE allowlist. Genus for baseline and consensus forecasts." .

ex:BaselineDemandForecast a owl:Class ; rdfs:subClassOf ex:DemandForecast ;
    rdfs:label "Baseline Demand Forecast" ;
    skos:definition "A Demand Forecast that describes the bedrock anticipated level of market demand, estimated from historical data and market analysis." .

ex:ConsensusDemandForecast a owl:Class ; rdfs:subClassOf ex:DemandForecast ;
    rdfs:label "Consensus Demand Forecast" ;
    skos:definition "A Demand Forecast that describes an agreed level of anticipated demand reconciled between baseline forecasts and customer-collaboration estimates." .

ex:AvailableToPromiseQuantity a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Available-to-Promise Quantity" ;
    skos:definition "A Descriptive Information Content Entity that describes the volume of products or services that may be committed for delivery to fulfill sales." .

ex:DemandForecastAccuracyReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:DemandForecast ] ;
    rdfs:label "Demand Forecast Accuracy Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the measured accuracy and reliability of an organization's demand forecasts." .

ex:ForecastingMethodologyAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:DemandForecast ] ;
    rdfs:label "Forecasting Methodology Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the fitness of an organization's demand-forecasting methodology in light of current market realities." ;
    rdfs:comment "Minted (D5) for the appraisal output of Evaluate and revise demand forecasting approach [10240]. Distinct from ex:DemandForecastAccuracyReport, which describes the accuracy of the forecasts themselves (output of Measure demand forecast accuracy [10241]) rather than the fitness of the forecasting METHOD. Descriptive because it represents a judgement of the methodology rather than prescribing a revised method." ;
    skos:example "A planning lead's note that the current ARIMA model under-reacts to promotional spikes and should be reviewed." .

# --- materials / capacity / supplier data ---
ex:MaterialSpecification a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Material Specification" ;
    skos:definition "A Descriptive Information Content Entity that describes the attributes and characteristics of an inventory item, such as density, volume, and size." ;
    rdfs:comment "Despite the 'Specification' label, this class is DESCRIPTIVE: it records observed material attributes (density, volume, size), not a prescriptive requirement. A prescriptive material requirement should be modeled separately as a Directive ICE (e.g. a Material Requirement Specification). Label-driven false-friend guard (D6)." .

ex:CapacityAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Capacity Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the manufacturing and processing capacities of an organization or supplier." .

ex:SupplierCapacityProfile a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Supplier ] ;
    rdfs:label "Supplier Capacity Profile" ;
    skos:definition "A Descriptive Information Content Entity that describes the average, peak, and baseline supply capacities of vendors and suppliers." .

ex:SpendProfileAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Spend Profile Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes an organization's procurement spend, classified and analyzed to reduce cost and monitor compliance." .

ex:SupplierQuote a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Supplier ] ;
    rdfs:label "Supplier Quote" ;
    skos:definition "A Descriptive Information Content Entity in which a supplier states its proposed price and terms for specified products or services." .

ex:SupplierPerformanceReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Supplier ] ;
    rdfs:label "Supplier Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the delivery timing and product quality achieved by suppliers." .

ex:PurchaseOrderReconciliationReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:PurchaseOrder ] ;
    rdfs:label "Purchase Order Reconciliation Report" ;
    skos:definition "A Descriptive Information Content Entity that describes whether the items and quantities of a purchase order were delivered as expected against goods receipts." .

# --- production / quality records ---
ex:ProductionNetworkSimulationResult a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Production Network Simulation Result" ;
    skos:definition "A Descriptive Information Content Entity that describes the outcomes of simulating and optimizing a production network model under given resources, volumes, and processes." .

ex:ProductionPerformanceAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Production Performance Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the effectiveness and efficiency of a production process, including production metrics." .

ex:ProductionStateReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Production State Report" ;
    skos:definition "A Descriptive Information Content Entity that reports the current state of a running production process and any deviations of its parameters from expected setpoints." ;
    rdfs:comment "Minted (D5) as the monitoring-specific descriptive output of Monitor and optimize production process [19566], distinct from ex:ProductionPerformanceAssessment (an appraisal judgement, output of Assess production performance [10314]). Descriptive state/deviation report, agreeing with the Act of Monitoring genus (GOLDEN PRINCIPLE)." ;
    skos:example "A control-room dashboard snapshot showing live process variables and flagged deviations during a shift." .

ex:MaintenanceIssueReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Maintenance Issue Report" ;
    skos:definition "A Descriptive Information Content Entity that describes deviations or issues in the maintenance schedule or in production performance." .

ex:QualityTestResult a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:FinishedProduct ] ;
    rdfs:label "Quality Test Result" ;
    skos:definition "A Descriptive Information Content Entity that describes the documented outcomes of a quality test conducted on manufactured products." .

ex:NonconformanceTrendAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Nonconformance Trend Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes trends in the occurrence of process or product nonconformances over time." .

ex:RootCauseAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Root Cause Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the identified origin of a problem and the reasoning establishing what happened, why, and how to reduce recurrence." .

ex:ProductionRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Production Record" ;
    skos:definition "A Descriptive Information Content Entity that documents the constituent parts, labor, and equipment involved in the manufacturing of a product, enabling lot traceability." .

# --- logistics / inventory / performance records ---
ex:InventoryRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Inventory Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the quantity, location, and availability of inventory items at warehouses and distribution centers." .

ex:DistributionMasterData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Distribution Master Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the systematic master data of finished products and inventory used for distribution planning." .

ex:InventoryAccuracyReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Inventory Accuracy Report" ;
    skos:definition "A Descriptive Information Content Entity that describes discrepancies between the recorded inventory and the physical state of the inventory." .

ex:DeliveryPerformanceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Delivery Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the efficiency, cost-effectiveness, and schedule adherence of an inbound or outbound delivery system." .

ex:CarrierPerformanceReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Carrier ] ;
    rdfs:label "Carrier Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the delivery performance of carriers conveying products from warehouses to retailers or consumers." .

ex:ThirdPartyLogisticsPerformanceReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ThirdPartyLogisticsProvider ] ;
    rdfs:label "Third-Party Logistics Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the storage and shipping performance of third-party logistics providers." .

ex:CapacityUtilizationReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Capacity Utilization Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the extent to which an organization uses its installed productive capacity." .

ex:SupplyCostEstimate a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Supply Cost Estimate" ;
    skos:definition "A Descriptive Information Content Entity that describes the estimated overall cost of supplying products to market, including distribution and logistics costs." .

ex:CarrierInvoice a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Carrier ] ;
    rdfs:label "Carrier Invoice" ;
    skos:definition "A Descriptive Information Content Entity that records the financial, regulatory, and administrative account of a carrier's freight transaction." .

ex:ReturnedPartQualityAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ReturnedProduct ] ;
    rdfs:label "Returned Part Quality Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes whether a returned part meets acceptable quality standards, supporting a disposition decision." .

# --- locally-minted supporting ICEs (no shared-vocab term fits) ---

ex:ConsolidationQuantity a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Consolidation Quantity" ;
    skos:definition "A Descriptive Information Content Entity that states the aggregate volume of finished products consolidated at a source location for delivery on a given date." ;
    rdfs:comment "Minted because no shared-vocab Descriptive ICE captures a source-consolidation volume; it is the output of Calculate consolidation at source [10255]. Descriptive (states a computed quantity), so its producing act is an Act of Analysis." .

ex:DestinationRequirementQuantity a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Destination Requirement Quantity" ;
    skos:definition "A Descriptive Information Content Entity that states the specific computed figure correctly representing the distribution requirements at a destination." ;
    rdfs:comment "Minted (D5) as the descriptive figure output of Calculate requirements at destination [10254], mirroring ex:ConsolidationQuantity for the parallel sibling Calculate consolidation at source [10255]. Descriptive (states a computed figure), so its producing act is an Act of Analysis -- not a Directive requirements spec." .

ex:OutsourcingNeedsStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Outsourcing Needs Statement" ;
    skos:definition "A Descriptive Information Content Entity that states which portion of an organization's logistics activities is needed to be transferred to outside suppliers, prepared for conveyance to management or the appropriate authority." ;
    rdfs:comment "Minted (D5) as the conveyed deliverable of Communicate outsourcing needs [10345]. Descriptive because it states/reports identified outsourcing needs rather than prescribing a course of action. Distinct from ex:OutsourcingPolicy (a Directive policy artifact), which APQC does not say this act produces." ;
    skos:example "A memo to management stating the warehousing scope recommended for outsourcing and the assistance required." .

ex:InventoryNeedsAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Inventory Needs Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the problems and issues discerned in managing inventory together with the exact quantity of inventory needed in the near future." ;
    rdfs:comment "Minted (D5) as the descriptive output of Establish inventory management constraints [10268], whose source centres on discerning inventory problems and quantifying needs. Descriptive because it represents identified problems and a computed need rather than prescribing constraints." ;
    skos:example "A note listing phantom-stock and shelf-life problems in the warehouse plus the near-term reorder quantity." .

ex:StorageRequirementAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Storage Requirement Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes an evaluation of the constraints, needs, parameters, and conditions for the physical storage and retrieval of components or products in a storage facility." ;
    rdfs:comment "Minted (D5) as the descriptive output of Determine product storage facility requirements [19555], whose source leads with 'Evaluate constraints, needs, parameters, and conditions'. Descriptive because it represents an appraisal of storage requirements rather than prescribing a storage plan. Distinct from ex:LogisticsRequirementSpecification (a Directive spec)." ;
    skos:example "An assessment of the racking, temperature, and throughput needs evaluated for a candidate storage facility." .

ex:ValidatedRequirementAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Validated Requirement Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the confirmation, obtained by interacting with the concerned party at a destination, that the stated finished-goods inventory requirements at that destination are correct and free of miscommunication." ;
    rdfs:comment "Minted (D5) as the descriptive output of Determine finished goods inventory requirements at destination [10253], whose source is purely a validation/communication-confirmation act. Descriptive because it represents a confirmation of existing requirements rather than composing a new prescriptive plan. Distinct from ex:LogisticsRequirementSpecification (the Directive requirements artifact that this act confirms, not authors)." ;
    skos:example "A planner's confirmation note that the regional DC manager has agreed the stated stocking requirement is correct." .

ex:NeedsSupplyAlignmentAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Needs-Supply Alignment Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the degree of fit between an organization's purchasing requirements and the capacity of its suppliers." ;
    rdfs:comment "Minted: no shared-vocab descriptive ICE captures a requirements-versus-capacity reconciliation. Descriptive because it represents fit rather than prescribing action." ;
    skos:example "A report noting that forecast demand for a part exceeds the qualified suppliers' combined monthly capacity." .

ex:SourcingOpportunityAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sourcing Opportunity Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes discerned opportunities to improve sourcing efficiency, value, or coverage." ;
    rdfs:comment "Minted: shared vocab has no opportunity-register ICE. Descriptive because it represents identified opportunities, not a chosen course of action." ;
    skos:example "A register of consolidation and dual-sourcing opportunities found across the supply base." .

ex:SupplierValidationAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Supplier Validation Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of whether a supply source meets the requirements to be an approved supplier." ;
    rdfs:comment "Minted: distinct from ex:SupplierPerformanceReport (ongoing performance) and ex:SupplierCertification (the resulting authorization). Descriptive because it represents a validation judgement." ;
    skos:example "An audit finding that a vendor's quality system conforms to the required standard." .

ex:ContractReviewAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Contract Review Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the findings of a periodic review of a supplier contract for currency and compliance." ;
    rdfs:comment "Minted: no shared-vocab ICE for contract-administration findings. Descriptive because it represents review findings, not new terms." ;
    skos:example "A quarterly note flagging that a contract's pricing schedule has lapsed and needs renewal." .

ex:ProcurementImpactAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Procurement Impact Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the effect of procurement decisions on inventory levels and production flexibility." ;
    rdfs:comment "Minted: no shared-vocab ICE for this cross-process impact study. Descriptive because it represents an analytical finding." ;
    skos:example "An analysis showing how minimum-order-quantity terms drive excess raw-material inventory." .

ex:CarrierInvoiceAuditResult a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Carrier Invoice Audit Result" ;
    skos:definition "A Descriptive Information Content Entity that reports the reconciliation of carrier invoices and freight account documents against shipment and contract records, recording verified charges and discrepancies." ;
    rdfs:comment "Minted locally (D5): no shared-vocab ICE covers a carrier-freight invoice audit. Descriptive (not Directive) because it reports a reconciliation judgement rather than prescribing action. Rejected ex:PurchaseOrderReconciliationReport (procurement PO scope)." ;
    skos:example "An audit summary listing matched freight charges and flagged carrier overbilling for a billing period." .

ex:ReviewedRequisition a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Reviewed Requisition" ;
    skos:definition "A Directive Information Content Entity consisting of a purchase requisition that has been received, checked against procurement policy, and marked ready for authorization." ;
    rdfs:comment "Minted (D5) as the distinct output of Process/Review requisitions [10292], replacing the degenerate input-class=output-class restriction. Directive because it is a requisition (a request that authorizes/initiates procurement) bearing an added review status, not a mere description. Distinct from ex:PurchaseRequisition (the un-reviewed request) and ex:RequisitionApprovalDecision (the later authorization)." ;
    skos:example "An incoming requisition validated against policy and queued for a budget owner's approval." .

ex:RequisitionApprovalDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Requisition Approval Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes that a purchase requisition is authorized to proceed to procurement." ;
    rdfs:comment "Minted: distinct from ex:PurchaseRequisition (the request) and ex:PurchaseOrder (the order). Directive because an approval authorizes rather than describes." ;
    skos:example "A signed approval record releasing a requisition for purchase-order creation." .

ex:SupplierCertification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Supplier Certification" ;
    skos:definition "A Directive Information Content Entity that confers and prescribes the status of an entity as an official approved supplier." ;
    rdfs:comment "Minted: shared vocab has no supplier-certification artifact. Directive because it grants and governs an authorized status rather than describing one." ;
    skos:example "A certificate designating a vendor as an approved supplier for a given material category." .

####################################################################
# C. MATERIAL ENTITIES  (operations I/O is legal here; bfo:material
#    entity fillers permitted). Anchored under cco:Material Artifact
#    (ont00000995) or a more specific CCO class.
#    NB: Facility is cco:ont00000192 (verified); ont00000130 is
#    "Power Transformer" and was rejected during assembly.
####################################################################

ex:RawMaterial a owl:Class ; rdfs:subClassOf cco:ont00000457 , obo:BFO_0000040 ;   # Portion of Material (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Raw Material" ;
    skos:definition "A Portion of Material that is provided as input to an act of production and incorporated into, or consumed during, the manufacture of a finished product." ;
    rdfs:comment "Anchored under cco:ont00000457 (Portion of Material), whose CCO definition is a portion produced to be used as the input for another Act of Material Artifact Processing -- an exact fit for raw materials." .

ex:InventoryItem a owl:Class ; rdfs:subClassOf cco:ont00000995 , obo:BFO_0000040 ;   # Material Artifact (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Inventory Item" ;
    skos:definition "A Material Artifact held in stock by an organization, such as a raw material, spare, or finished product awaiting use or sale." .

ex:FinishedProduct a owl:Class ; rdfs:subClassOf cco:ont00000995 , obo:BFO_0000040 ;   # Material Artifact (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Finished Product" ;
    skos:definition "A Material Artifact that has completed production and is ready to be tested, stored, distributed, or delivered to a customer." .

ex:ProductionLot a owl:Class ; rdfs:subClassOf cco:ont00000995 , obo:BFO_0000040 ;   # Material Artifact (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Production Lot" ;
    skos:definition "A Material Artifact consisting of a particular production unit of an assembly that is planned and manufactured together and tracked under a single lot number." .

ex:ReturnedProduct a owl:Class ; rdfs:subClassOf cco:ont00000995 , obo:BFO_0000040 ;   # Material Artifact (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Returned Product" ;
    skos:definition "A Material Artifact that has been returned by a buyer to the seller or an intermediary, pending inspection, salvage, repair, or restocking." .

ex:ProductSample a owl:Class ; rdfs:subClassOf cco:ont00000995 , obo:BFO_0000040 ;   # Material Artifact (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Product Sample" ;
    skos:definition "A Material Artifact consisting of a set of elements drawn from a product lot in order to infer the quality of the lot." .

ex:ProductionEquipment a owl:Class ; rdfs:subClassOf cco:ont00000995 , obo:BFO_0000040 ;   # Material Artifact (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Production Equipment" ;
    skos:definition "A Material Artifact, such as machinery, used in a production process and subject to planned or unplanned maintenance." .

ex:Warehouse a owl:Class ; rdfs:subClassOf cco:ont00000192 , obo:BFO_0000040 ;   # Facility (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Warehouse" ;
    skos:definition "A Facility designed for the storage, handling, and movement of inventory and finished goods." .

ex:DistributionCenter a owl:Class ; rdfs:subClassOf cco:ont00000192 , obo:BFO_0000040 ;   # Facility (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Distribution Center" ;
    skos:definition "A Facility designed for receiving, storing, and dispatching products to downstream destinations in a distribution network." .

ex:ProductionFacility a owl:Class ; rdfs:subClassOf cco:ont00000192 , obo:BFO_0000040 ;   # Facility (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Production Facility" ;
    skos:definition "A Facility designed for processing inventory into finished products or services." .

ex:TransportationVehicle a owl:Class ; rdfs:subClassOf cco:ont00000713 , obo:BFO_0000040 ;   # Vehicle (BFO material entity asserted so S4 resolves standalone)
    rdfs:label "Transportation Vehicle" ;
    skos:definition "A Vehicle used to convey inbound or outbound products between supply-chain locations." .

####################################################################
# D. AGENTS AND ORGANIZATIONS  (cco:Agent / cco:Organization)
####################################################################

ex:Supplier a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:SupplierRole ] ;
    rdfs:label "Supplier" ;
    skos:definition "An Organization that bears a supplier role in relation to a procuring organization, providing materials or services." ;
    rdfs:comment "Modeled as Organization per APQC 'vendors/suppliers'. Use cco:Agent for an individual supplier where needed." .

ex:ContractManufacturer a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:SupplierRole ] ;
    rdfs:label "Contract Manufacturer" ;
    skos:definition "An Organization that bears a supplier role and manufactures products under contract on behalf of a procuring organization." .

ex:Customer a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:CustomerRole ] ;
    rdfs:label "Customer" ;
    skos:definition "An Agent that bears a customer role in relation to an organization, being a recipient of its products or services." .

ex:Carrier a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:CarrierRole ] ;
    rdfs:label "Carrier" ;
    skos:definition "An Organization that bears a carrier role, conveying products between supply-chain locations on behalf of another organization." .

ex:ThirdPartyLogisticsProvider a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:LogisticsServiceProviderRole ] ;
    rdfs:label "Third-Party Logistics Provider" ;
    skos:definition "An Organization that bears a logistics service provider role, performing outsourced storage, shipping, or transportation activities on behalf of another organization." .

ex:ManagementPersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ManagerRole ] ;
    rdfs:label "Management Personnel" ;
    skos:definition "An Agent that bears a manager role and exercises managerial authority within an organization." ;
    rdfs:comment "Mirrors the reference slice's ex:ManagementPersonnel; minted here so all 4.0 groups share one class (e.g. senior management as participant in demand-consensus and technology decisions)." .

ex:SupplyChainOrganization a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty cco:ont00001954 ; owl:someValuesFrom ex:SupplyChainManagementCapability ] ;
    rdfs:label "Supply Chain Organization" ;
    skos:definition "An Organization that has a supply-chain management capability realized in supply-chain planning, procurement, production, and logistics acts." ;
    rdfs:comment "The focal agent for section 4.0 standing functions (R5 capability bearers). Group modules attach Organization Capabilities to this class." .

####################################################################
# E. ROLES  (obo:BFO_0000023)
####################################################################

ex:SupplierRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Supplier Role" ;
    skos:definition "A Role that is borne by an Agent or Organization in virtue of furnishing goods, materials, resources, or services to a procuring organization, typically for consideration." .

ex:CustomerRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Customer Role" ;
    skos:definition "A Role that is borne by an Agent or Organization in virtue of acquiring, consuming, contracting for, or being a target acquirer of the goods or services of a focal organization." .

ex:CarrierRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Carrier Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of conveying products between supply-chain locations on behalf of another organization." .

ex:LogisticsServiceProviderRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Logistics Service Provider Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of performing outsourced logistics, storage, or shipping activities for another organization." .

ex:ManagerRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of exercising managerial authority within an organization." .

####################################################################
# F. CAPABILITIES  (Organization Capability cco:ont00000568)
####################################################################

ex:SupplyChainManagementCapability a owl:Class ; rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Supply Chain Management Capability" ;
    skos:definition "An Organization Capability that is realized in the planning, procurement, production, and logistics acts by which an organization manages its supply chain for physical products." ;
    rdfs:comment "Top section-4.0 capability. The four group-level capabilities below specialize it; group modules may add 'realized in' restrictions to specific process classes (R6)." .

ex:SupplyChainPlanningCapability a owl:Class ; rdfs:subClassOf ex:SupplyChainManagementCapability ;
    rdfs:label "Supply Chain Planning Capability" ;
    skos:definition "A Supply Chain Management Capability that is realized in acts of planning and aligning production, materials, demand, and distribution resources." .

ex:ProcurementCapability a owl:Class ; rdfs:subClassOf ex:SupplyChainManagementCapability ;
    rdfs:label "Procurement Capability" ;
    skos:definition "A Supply Chain Management Capability that is realized in acts of sourcing, selecting suppliers, ordering, and managing the supply of materials and services." .

ex:ProductionCapability a owl:Class ; rdfs:subClassOf ex:SupplyChainManagementCapability ;
    rdfs:label "Production Capability" ;
    skos:definition "A Supply Chain Management Capability that is realized in acts of scheduling, producing, assembling, and quality-testing physical products." .

ex:LogisticsManagementCapability a owl:Class ;
    rdfs:subClassOf ex:SupplyChainManagementCapability ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10338 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20936 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10340 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10341 ] ;
    rdfs:label "Logistics Management Capability" ;
    skos:definition "A Supply Chain Management Capability that is realized in acts of governing logistics, managing inbound material flow, operating warehousing, and operating outbound transportation." ;
    rdfs:comment "R5/R6: APQC group 4.4 'Manage logistics and warehousing' (PCF 10219) is a standing oversight function with no natural end, so it is modeled as this Organization Capability rather than a process. It is realized in the four bounded sub-processes 4.4.1-4.4.4. Reconciled: the realization axioms (originally added to ex:LogisticsManagementCapability in the 4.4 group module) are folded into this single shared declaration." .

ex:RawMaterialInventoryManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10304 ] ;
    rdfs:label "Raw Material Inventory Management Capability" ;
    skos:definition "An Organization Capability that inheres in a supply-chain organization in virtue of its capacity to administer the stock and total cost of raw materials supporting production." ;
    rdfs:comment "Minted for APQC 4.3.2.1 'Manage raw material inventory', a standing administrative function (R5/R6) rather than a bounded process. Realized in ex:P10304 (Produce/Assemble product), the production acts that consume the managed inventory. Not in the shared vocabulary (ex:ProductionCapability is broader); proposed as a section-4.0 capability addition." .

ex:FleetManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10341 ] ;
    rdfs:label "Fleet Management Capability" ;
    skos:definition "An Organization Capability that inheres in a supply-chain organization in virtue of its capacity to administer the transportation vehicles used for delivering end products, covering vehicle financing, maintenance, telematics, driver, speed, fuel, and health-and-safety management." ;
    rdfs:comment "Gate-F R5 fix for APQC 4.4.4.3 'Manage transportation fleet' [10362]: the source is a textbook STANDING administrative function with no natural end ('Taking care of a range of functions... Manage vehicle financing, maintenance, telematics, driver management, speed management, fuel management, and health and safety management'), so it is modeled as an Organization Capability rather than a bounded Planned Act -- mirroring how group 10219 is handled as ex:LogisticsManagementCapability. Realized in ex:P10341, the bounded outbound-transport operations (including fleet maintenance and telematics-monitoring acts) that exercise the fleet. The catalog node ex:PCF_10362 designates this capability per the ADR-001 R4 bridge." .

####################################################################
# 3. PROCESS CLASSES
# ===== GROUP 4.1  Plan for and align supply chain resources (PCF 10215)
# Partonomy via cco:ont00001777 (has process part); never rdfs:subClassOf
# between processes. Act genera follow the GOLDEN PRINCIPLE.
####################################################################

####################################################################
# 4.1.1 branch -- Develop production and materials strategies
####################################################################

ex:P10221 a owl:Class ;
    ex:pcfID "10221" ; ex:hierarchyID "4.1.1" ;
    ex:apqcSourceText "Creating strategies for production processes, as well as the process of managing materials. Define production and supply constraints. Design a blueprint of the workplace. Establish rules and regulations regarding the employees, outsourcing of services, and the expenditure to be incurred on the manufacturing capital." ;
    rdfs:label "Develop production and materials strategies" ;
    skos:definition "An Act of Formulation that composes the strategies, policies, and constraints governing an organization's production processes and materials management, producing a production and materials strategy." ;
    rdfs:comment "Models APQC 4.1.1 as an occurrent. Its APQC children are process parts, not subclasses." ;
    skos:example "An operations team drafts the plant's production strategy together with its labor, outsourcing, and capital-expense policies." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionAndMaterialsStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10229 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10230 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10231 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10232 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10233 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10234 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14193 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19551 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14194 ] .

ex:P10229 a owl:Class ;
    ex:pcfID "10229" ; ex:hierarchyID "4.1.1.1" ;
    ex:apqcSourceText "Creating quantifiable strategic objectives for each manufacturing segment in conjunction with sales projections." ;
    rdfs:label "Define manufacturing goals" ;
    skos:definition "An Act of Formulation that has as output a manufacturing goal specification setting quantifiable strategic objectives for each manufacturing segment." ;
    skos:example "Planners set per-line output targets aligned with the annual sales projection." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ManufacturingGoalSpecification ] .

ex:P10230 a owl:Class ;
    ex:pcfID "10230" ; ex:hierarchyID "4.1.1.2" ;
    ex:apqcSourceText "Setting up internal rules and regulations regarding the employees and the materials." ;
    rdfs:label "Define labor and materials policies" ;
    skos:definition "An Act of Formulation that has as output a labor and materials policy prescribing internal rules governing employees and materials." ;
    skos:example "HR and operations jointly issue the plant's labor and materials handling policy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LaborAndMaterialsPolicy ] .

ex:P10231 a owl:Class ;
    ex:pcfID "10231" ; ex:hierarchyID "4.1.1.3" ;
    ex:apqcSourceText "Creating rules and regulations regarding contracting out of a business process to another party in order to reduce costs." ;
    rdfs:label "Define outsourcing policies" ;
    skos:definition "An Act of Formulation that has as output an outsourcing policy prescribing rules for contracting business processes to external parties." ;
    skos:example "Management publishes the criteria under which production steps may be outsourced." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OutsourcingPolicy ] .

ex:P10232 a owl:Class ;
    ex:pcfID "10232" ; ex:hierarchyID "4.1.1.4" ;
    ex:apqcSourceText "Designing rules and regulations pertaining to the expenditure incurred in acquiring or upgrading the existing stock of manufacturing capital." ;
    rdfs:label "Define capital expense policies" ;
    skos:definition "An Act of Formulation that has as output a capital expense policy prescribing rules for spending on acquiring or upgrading manufacturing capital." ;
    skos:example "Finance issues the capex approval thresholds for new production equipment." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CapitalExpensePolicy ] .

ex:P10233 a owl:Class ;
    ex:pcfID "10233" ; ex:hierarchyID "4.1.1.5" ;
    ex:apqcSourceText "Outlining the manufacturing and processing capacities of the organization. Delineate the capabilities required for optimizing output with available resources. Analyze capabilities possessed by the organization concerning the raw materials required and the process necessitated for producing finished products." ;
    rdfs:label "Define capacities" ;
    skos:definition "An Act of Analysis that examines the organization's manufacturing and processing capabilities and has as output a capacity assessment." ;
    rdfs:comment "Anchored to Act of Analysis (not Formulation) because the lead activity examines existing capabilities and produces a Descriptive capacity assessment rather than a prescription." ;
    skos:example "Engineers analyze line throughput and report the plant's effective production capacity." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CapacityAssessment ] .

ex:P10234 a owl:Class ;
    ex:pcfID "10234" ; ex:hierarchyID "4.1.1.6" ;
    ex:apqcSourceText "Defining limitations in the ability of the organization's supply chain to deliver a new stock, and creating a network of production stakeholders. Frame and manage relationships within the flow of manufacturing and processing operations. Identify probable supply issues." ;
    rdfs:label "Define production network and supply constraints" ;
    skos:definition "An Act of Formulation that has as output a production network model representing the network of production stakeholders and its supply constraints." ;
    skos:example "Supply-chain planners map the production stakeholder network and document its binding supply constraints." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionNetworkModel ] .

ex:P14193 a owl:Class ;
    ex:pcfID "14193" ; ex:hierarchyID "4.1.1.7" ;
    ex:apqcSourceText "Outlining the scheme of processing inventory into finished products/services. This includes the use of raw materials, machinery, skill sets, and knowledge to create new offerings." ;
    rdfs:label "Define production process" ;
    skos:definition "An Act of Formulation that has as output a production process specification describing the scheme for processing inventory into finished products." ;
    skos:example "Process engineers document the routing that converts raw material into the finished good." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionProcessSpecification ] .

ex:P19551 a owl:Class ;
    ex:pcfID "19551" ; ex:hierarchyID "4.1.1.8" ;
    ex:apqcSourceText "Establishing or prescribing methods to be followed routinely for the performance of designated operations or in designated situations. This may include step-by-step instructions to help workers carry out complex routine operations. The goal is to improve efficiency, quality, and uniformity of performance, while reducing miscommunication, failure, or rework." ;
    rdfs:label "Define standard operating procedures" ;
    skos:definition "An Act of Formulation that has as output a standard operating procedure prescribing methods to be followed routinely for designated operations." ;
    skos:example "An SOP is written giving step-by-step instructions for a complex changeover." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StandardOperatingProcedure ] .

ex:P14194 a owl:Class ;
    ex:pcfID "14194" ; ex:hierarchyID "4.1.1.9" ;
    ex:apqcSourceText "Determining the floor plans for the processing facility that is meant for delivering finished products/services. Identify the totality of infrastructure needed for using this space in the manufacturing process, including machinery, factory floors, offices, and furniture." ;
    rdfs:label "Define production workplace layout and infrastructure" ;
    skos:definition "An Act of Formulation that has as output a production workplace layout plan specifying the floor plan and infrastructure of a processing facility." ;
    skos:example "Industrial engineers lay out the new line's floor plan and equipment placement." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionWorkplaceLayoutPlan ] .

####################################################################
# 4.1.2 branch -- Manage demand for products
####################################################################

ex:P10222 a owl:Class ;
    ex:pcfID "10222" ; ex:hierarchyID "4.1.2" ;
    ex:apqcSourceText "Forecasting demand for products using secondary research and customer feedback. Refine these forecasts. Inspect the approach used in creating forecasts, and determine its accuracy." ;
    rdfs:label "Manage demand for products" ;
    skos:definition "An Act of Analysis that forecasts and refines demand for an organization's products and has as output a consensus demand forecast." ;
    rdfs:comment "Modeled as a bounded forecasting process (Act of Analysis), not an Organization Capability: the APQC description is a delimited forecast-refine-inspect cycle producing a Descriptive forecast. Its APQC children are process parts." ;
    skos:example "The demand-planning team runs its monthly forecasting cycle and signs off a consensus forecast." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConsensusDemandForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10235 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10236 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10237 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10238 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10239 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10240 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10241 ] .

ex:P10235 a owl:Class ;
    ex:pcfID "10235" ; ex:hierarchyID "4.1.2.1" ;
    ex:apqcSourceText "Identify the bedrock levels of market demand anticipated for the organization's products/services. Estimate future demand for product and services using historical data, analysis of the market environment and any externalities, etc. to create ex ante approximations." ;
    rdfs:label "Develop baseline demand forecasts" ;
    skos:definition "An Act of Analysis that has as output a baseline demand forecast estimating anticipated market demand from historical and market data." ;
    skos:example "An analyst builds a statistical baseline forecast from three years of shipment history." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BaselineDemandForecast ] .

ex:P10236 a owl:Class ;
    ex:pcfID "10236" ; ex:hierarchyID "4.1.2.2" ;
    ex:apqcSourceText "Working closely with the organization's customers to understand their drives and behavior, with the objective of estimating future demand. Reach out to customers through various means to understand their behavior patterns, usage elasticity, and degree of variability--and ultimately determine demand for each offering." ;
    rdfs:label "Collaborate demand with customers" ;
    skos:definition "An Act of Forecasting that works with customers to understand their behavior and, with that input, estimates future demand, producing a demand forecast." ;
    rdfs:comment "Re-anchored from ex:ActOfAnalysis to ex:ActOfForecasting: the act's definitional output is a Predictive ICE (ex:DemandForecast) and the source's objective is 'estimating future demand'. Customer collaboration is the method; the product is a forecast, matching the corpus pattern (slice 5's demand-forecast acts P20043/P20045 use ex:ActOfForecasting). Customer is a definitional participant (the act is constituted by working with customers)." ;
    skos:example "Planners run joint demand-review sessions with key accounts to refine the forecast." ;
    rdfs:subClassOf ex:ActOfForecasting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DemandForecast ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P10237 a owl:Class ;
    ex:pcfID "10237" ; ex:hierarchyID "4.1.2.3" ;
    ex:apqcSourceText "Arriving at a consensus over the forecasted levels of demand for products/services. Consensus is achieved by juxtaposing decisions developed in the baseline forecast with those reached at by collaborating with customers. Enlist senior-level decision makers of the sales and marketing functions." ;
    rdfs:label "Develop demand consensus forecast" ;
    skos:definition "An Act of Analysis that has as input a baseline demand forecast and has as output a consensus demand forecast reconciling baseline and customer-collaboration estimates." ;
    rdfs:comment "Management personnel participate as definitional senior decision makers." ;
    skos:example "Sales, marketing, and operations leaders sign off one consensus number in the S&OP meeting." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BaselineDemandForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConsensusDemandForecast ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ManagementPersonnel ] .

ex:P10238 a owl:Class ;
    ex:pcfID "10238" ; ex:hierarchyID "4.1.2.4" ;
    ex:apqcSourceText "Identify the volume of products/services that may be committed for delivery to fulfill sales. Figure out the amount of stock available. Forecast its volumes." ;
    rdfs:label "Determine available to promise" ;
    skos:definition "An Act of Analysis that has as output an available-to-promise quantity stating the volume of product that may be committed for delivery." ;
    skos:example "Planning computes the ATP quantity available against open sales orders for the week." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AvailableToPromiseQuantity ] .

ex:P10239 a owl:Class ;
    ex:pcfID "10239" ; ex:hierarchyID "4.1.2.5" ;
    ex:apqcSourceText "Picking out any activity that deviates from the forecast, and adjusting it. Closely track and study the levels of demand as they emerge. Refine the consensus forecast as needed." ;
    rdfs:label "Monitor activity against demand forecast and revise forecast" ;
    skos:definition "An Act of Monitoring that has as input a consensus demand forecast, tracks emerging demand against it, and has as output a revised consensus demand forecast." ;
    skos:example "Demand planners watch actual orders versus forecast and adjust the number mid-cycle." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ConsensusDemandForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConsensusDemandForecast ] .

ex:P10240 a owl:Class ;
    ex:pcfID "10240" ; ex:hierarchyID "4.1.2.6" ;
    ex:apqcSourceText "Examining the methodology used to estimate future demand. Refine it in light of current market realities and demand." ;
    rdfs:label "Evaluate and revise demand forecasting approach" ;
    skos:definition "An Act of Appraisal that examines the demand-forecasting methodology and produces a forecasting methodology assessment judging its fitness for current market realities." ;
    rdfs:comment "Anchored to Act of Appraisal because the lead activity evaluates/judges the forecasting METHODOLOGY. Gate-F fix: removed the erroneous [has output some ex:DemandForecastAccuracyReport] restriction -- an accuracy report appraises the forecasts and is the output of the sibling Measure demand forecast accuracy [10241], not of this act, which appraises the method. The definitional output is now ex:ForecastingMethodologyAssessment (Descriptive ICE), agreeing with the Appraisal genus (GOLDEN PRINCIPLE). The refined approach is noted in the source but not asserted as a definitional output (Phase-3 necessity)." ;
    skos:example "A planning lead reviews whether the current forecasting model still fits a volatile market." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ForecastingMethodologyAssessment ] .

ex:P10241 a owl:Class ;
    ex:pcfID "10241" ; ex:hierarchyID "4.1.2.7" ;
    ex:apqcSourceText "Calculating and inspecting the accuracy of demand forecasts. Use metrics to check the reliability of the forecasts created." ;
    rdfs:label "Measure demand forecast accuracy" ;
    skos:definition "An Act of Appraisal that has as input a consensus demand forecast and has as output a demand forecast accuracy report judging the reliability of the forecasts." ;
    skos:example "The team computes MAPE for last quarter's forecasts and reports the accuracy." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ConsensusDemandForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DemandForecastAccuracyReport ] .

####################################################################
# 4.1.3 branch -- Create materials plan
####################################################################

ex:P10223 a owl:Class ;
    ex:pcfID "10223" ; ex:hierarchyID "4.1.3" ;
    ex:apqcSourceText "Developing a scheme that allows for advance planning for the availability of raw materials and spares. Start with an unconstrained plan, and refine based on supply chain realities by identifying critical materials required for production, checking material specifications, and collaborating with all vendors over the supply." ;
    rdfs:label "Create materials plan" ;
    skos:definition "An Act of Formulation that produces a materials plan for the advance availability of raw materials and spares, refined from an unconstrained to a constrained plan." ;
    rdfs:comment "Models APQC 4.1.3 as an occurrent; its APQC children are process parts." ;
    skos:example "Materials planning produces and then constrains the quarter's raw-material supply plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaterialsPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10242 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10243 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10244 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10245 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10246 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14196 ] .

ex:P10242 a owl:Class ;
    ex:pcfID "10242" ; ex:hierarchyID "4.1.3.1" ;
    ex:apqcSourceText "Developing a plan for raw materials and other inventory items in order to meet market demand. Ensure the availability of all inventory items such as raw materials and spares. Create a blueprint in line with Define labor and materials policies [10230]." ;
    rdfs:label "Create unconstrained plan" ;
    skos:definition "An Act of Formulation that has as output an unconstrained materials plan ensuring the availability of raw materials and spares to meet market demand." ;
    rdfs:comment "Source cross-references Define labor and materials policies [10230]; that policy is a typical, not definitional, input." ;
    skos:example "Planning drafts the ideal materials plan ignoring supplier limits as a first pass." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:UnconstrainedMaterialsPlan ] .

ex:P10243 a owl:Class ;
    ex:pcfID "10243" ; ex:hierarchyID "4.1.3.2" ;
    ex:apqcSourceText "Collaborating with vendors and contractual manufacturers with the objective of ensuring a continual supply of raw materials and spares. Leverage long-term connections/relationships with various suppliers, and cultivate new ones. Track the activities of all vendors. Receive regular updates to prepare for any fluctuations in supply." ;
    rdfs:label "Collaborate with supplier and contract manufacturers" ;
    skos:definition "An Act of Information Processing in which an organization coordinates with suppliers and contract manufacturers to secure a continual supply of raw materials and spares." ;
    rdfs:comment "Anchored to Act of Information Processing (receiving and acting on supply updates). Supplier and Contract Manufacturer are definitional participants; no single ICE output is definitional, so none is asserted as a restriction." ;
    skos:example "Procurement holds standing supply reviews with strategic vendors and tracks their output." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Supplier ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ContractManufacturer ] .

ex:P10244 a owl:Class ;
    ex:pcfID "10244" ; ex:hierarchyID "4.1.3.3" ;
    ex:apqcSourceText "Identifying principal materials needed for the manufacturing process and the levels of supply that may be ensured for them. Determine the essential and crucial inventory items required for the smooth functioning of all manufacturing processes. Estimate the average, peak, and baseline capacities of various vendors and suppliers. Establish the capability of individual suppliers from the market and the vendors." ;
    rdfs:label "Identify critical materials and supplier capacity" ;
    skos:definition "An Act of Identification that discerns the critical materials required for production and has as output a supplier capacity profile estimating vendor supply levels." ;
    skos:example "Sourcing flags the single-source materials and profiles each supplier's peak capacity." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierCapacityProfile ] .

ex:P10245 a owl:Class ;
    ex:pcfID "10245" ; ex:hierarchyID "4.1.3.4" ;
    ex:apqcSourceText "Observing and surveying all inventory items in order to check for the veracity of their specifications. Monitor various attributes and characteristics for respective inventory items such as density, volume, and size, as well as contextualized specifications particular to the respective materials." ;
    rdfs:label "Monitor material specifications" ;
    skos:definition "An Act of Monitoring that has as input material specifications and surveys inventory items to verify their conformance to those specifications." ;
    skos:example "QA tracks incoming lots against the material spec for density and dimensional tolerance." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MaterialSpecification ] .

ex:P10246 a owl:Class ;
    ex:pcfID "10246" ; ex:hierarchyID "4.1.3.5" ;
    ex:apqcSourceText "Generating a bounded plan that takes stock of the actual supply chain scenario. Take stock of all information collected while creating an inventory supply plan." ;
    rdfs:label "Generate constrained plan" ;
    skos:definition "An Act of Formulation that has as input an unconstrained materials plan and a supplier capacity profile and has as output a constrained materials plan reflecting actual supply realities." ;
    skos:example "Planning re-runs MRP against real supplier capacity to produce the executable materials plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:UnconstrainedMaterialsPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SupplierCapacityProfile ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConstrainedMaterialsPlan ] .

ex:P14196 a owl:Class ;
    ex:pcfID "14196" ; ex:hierarchyID "4.1.3.6" ;
    ex:apqcSourceText "Defining an equitable volume for the production of products/services that adheres to an equilibrium value, and creating a scheme of control for processing items. Create schematics for systematically planning, coordinating, and directing the manufacturing activities in line with the production balance determined." ;
    rdfs:label "Define production balance and control" ;
    skos:definition "An Act of Formulation that has as output a production balance and control scheme prescribing an equilibrium production volume and the control of processing items." ;
    skos:example "Operations sets the level-loaded production volume and the kanban control rules to maintain it." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionBalanceAndControlScheme ] .

####################################################################
# 4.1.4 branch -- Create and manage master production schedule
####################################################################

ex:P10224 a owl:Class ;
    ex:pcfID "10224" ; ex:hierarchyID "4.1.4" ;
    ex:apqcSourceText "Taking care of the master production plan. The master production includes creation and implementation of the site-level production plan, as well as management of the inventory that is currently in the production process." ;
    rdfs:label "Create and manage master production schedule" ;
    skos:definition "An Act of Scheduling that creates and maintains the site-level master production schedule and has as output a master production schedule." ;
    rdfs:comment "Modeled as a bounded scheduling process (Act of Scheduling), not an Organization Capability: the description centers on creating and re-setting a concrete schedule. Its APQC children are process parts." ;
    skos:example "Production control builds and weekly-updates the site master production schedule." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MasterProductionSchedule ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20023 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20024 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17041 ] .

ex:P20023 a owl:Class ;
    ex:pcfID "20023" ; ex:hierarchyID "4.1.4.1" ;
    ex:apqcSourceText "Create representative logical system that provides the framework to attain strategic objectives based on resources, product volumes, and processes. Provides the general sequential flow and capacity requirement relationships among raw materials, parts, resources, finished products, and product families." ;
    rdfs:label "Model production network to enable simulation and optimization" ;
    skos:definition "An Act of Formulation that has as output a production network model providing the sequential-flow and capacity-requirement framework among materials, resources, and finished products." ;
    rdfs:comment "A production network simulation result is a typical downstream output of running the model and is not asserted as definitional here." ;
    skos:example "Planners build a network model linking plants, lines, and product families for scenario simulation." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionNetworkModel ] .

ex:P20024 a owl:Class ;
    ex:pcfID "20024" ; ex:hierarchyID "4.1.4.2" ;
    ex:apqcSourceText "Creating the plan for internal activities such as production, inventory, and staffing. Include forecasted quantity of items to produce based on inputs from sales planning, demand planning/forecasting, and supply chain partners." ;
    rdfs:label "Create master production schedule" ;
    skos:definition "An Act of Scheduling that has as input a consensus demand forecast and has as output a master production schedule for production, inventory, and staffing." ;
    skos:example "The MPS run converts the demand forecast into a weekly build schedule." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ConsensusDemandForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MasterProductionSchedule ] .

ex:P17041 a owl:Class ;
    ex:pcfID "17041" ; ex:hierarchyID "4.1.4.3" ;
    ex:apqcSourceText "Supervising and overseeing the plan for internal activities such as production, inventory, and staffing. Set the quantity of items to produce each week of a short-range planning horizon." ;
    rdfs:label "Maintain master production schedule" ;
    skos:definition "An Act of Scheduling that has as input an existing master production schedule and re-sets the weekly production quantities over the short-range planning horizon." ;
    skos:example "The scheduler re-firms next week's build quantities every Monday." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MasterProductionSchedule ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MasterProductionSchedule ] .

####################################################################
# 4.1.5 branch -- Plan distribution requirements
####################################################################

ex:P17042 a owl:Class ;
    ex:pcfID "17042" ; ex:hierarchyID "4.1.5" ;
    ex:apqcSourceText "Maintaining master data of finished products and inventory. Identify the requirements of finished products at the destination, as well as partner requirements. Calculate the consolidation at source. Manage replenishment planning. Create and administer a dispatch plan. Calculate load plans for destinations and partners. Manage the cost of supplying these products. Ensure effective utilization of capacity." ;
    rdfs:label "Plan distribution requirements" ;
    skos:definition "An Act of Planning that determines finished-product and partner distribution requirements and has as output a distribution requirements plan." ;
    rdfs:comment "Models APQC 4.1.5 as an occurrent; its APQC children are process parts." ;
    skos:example "Distribution planning produces the period's DRP covering replenishment, dispatch, and load plans." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DistributionRequirementsPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10252 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10253 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19555 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10254 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10255 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10256 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10258 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10259 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10260 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10261 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10262 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10263 ] .

ex:P10252 a owl:Class ;
    ex:pcfID "10252" ; ex:hierarchyID "4.1.5.1" ;
    ex:apqcSourceText "Maintaining and preserving the master data plan for distribution requirements. Create a systematic collection of facts and figures regarding the distribution of the inventories. Maintain policies, processes, and tools covering the distribution function." ;
    rdfs:label "Maintain master data" ;
    skos:definition "An Act of Information Processing that performs a bounded, repeatable update of distribution master data describing the organization's distribution of inventory." ;
    rdfs:comment "Gate-F R5 fix: the R5 judgement is now explicit and uniform. Although the source is phrased as a standing curatorial function ('MAINTAINING and PRESERVING the master data... MAINTAIN policies, processes, and tools'), this class is modeled as a bounded occurrent because it reduces to a discrete, repeatable master-data update task with an identifiable begin and end that can be a proper part of Plan distribution requirements [17042] -- exactly the reduction the slice applies to the other 'Maintain' rows P17041 (Maintain master production schedule) and P10262 (Manage cost of supply). The genuinely standing distribution-data-curation FUNCTION (no natural end) is the responsibility of ex:LogisticsManagementCapability / ex:SupplyChainManagementCapability, not of this bounded act. Rejected demotion to a standalone ex:DistributionMasterDataManagementCapability so as to preserve the 4.1.5 partonomy (this act is a process part of P17042); the standing aspect is already carried by the section capabilities." ;
    skos:example "Master-data stewards run the periodic update keeping distribution-center and lane reference data current." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DistributionMasterData ] .

ex:P10253 a owl:Class ;
    ex:pcfID "10253" ; ex:hierarchyID "4.1.5.2" ;
    ex:apqcSourceText "Interact with the concerned person at the destination to validate the requirements and to avoid any miscommunication of information." ;
    rdfs:label "Determine finished goods inventory requirements at destination" ;
    skos:definition "An Act of Analysis that interacts with the concerned party at a destination to validate the finished-goods inventory requirements and produces a validated requirement assessment confirming them." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfFormulation (Act of Planning -> Directive) to ex:ActOfAnalysis (Act of Information Processing -> Descriptive). The source ('Interact with the concerned person at the destination to validate the requirements and to avoid any miscommunication') is a validation/communication-confirmation act, not the composition of a new prescriptive plan; nothing in it authors a directive. Rejected ex:ActOfFormulation: the Planning genus + Directive output disagree with the act's descriptive/confirmatory character (GOLDEN PRINCIPLE). The Directive ex:LogisticsRequirementSpecification (the requirement that is confirmed, not authored, here) is demoted to a non-definitional reference; the definitional output is the Descriptive ex:ValidatedRequirementAssessment." ;
    skos:example "A planner confirms the regional DC's stocking requirement with its manager." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ValidatedRequirementAssessment ] .

ex:P19555 a owl:Class ;
    ex:pcfID "19555" ; ex:hierarchyID "4.1.5.3" ;
    ex:apqcSourceText "Evaluate constraints, needs, parameters, and conditions for physical storage and retrieval of components or products for future use or shipment in a storage facility within a certain timeframe." ;
    rdfs:label "Determine product storage facility requirements" ;
    skos:definition "An Act of Appraisal that evaluates the constraints, needs, parameters, and conditions for physical storage and retrieval in a storage facility and produces a storage requirement assessment." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfFormulation (Act of Planning -> Directive) to cco:ont00000636 (Act of Appraisal -> Descriptive). The lead verb 'Evaluate constraints, needs, parameters, and conditions' denotes appraisal producing a descriptive assessment, not the composition of a prescriptive plan. Rejected ex:ActOfFormulation: evaluating constraints/conditions is not authoring a directive, so the Planning genus + Directive output disagree with the verb (GOLDEN PRINCIPLE). Output changed from the Directive ex:LogisticsRequirementSpecification to the Descriptive ex:StorageRequirementAssessment." ;
    skos:example "Warehousing defines the racking, temperature, and throughput requirements for the new DC." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StorageRequirementAssessment ] .

ex:P10254 a owl:Class ;
    ex:pcfID "10254" ; ex:hierarchyID "4.1.5.4" ;
    ex:apqcSourceText "Interact with the concerned authority at the destination to reach a specific figure that correctly represents requirements." ;
    rdfs:label "Calculate requirements at destination" ;
    skos:definition "An Act of Analysis that computes and has as output a destination requirement quantity giving the specific figure that correctly represents the requirements at a destination." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfFormulation (Act of Planning -> Directive) to ex:ActOfAnalysis (Act of Information Processing -> Descriptive). The lead verb 'Calculate' and the product 'a figure that correctly represents requirements' is a computed/descriptive quantity, not a prescriptive plan. Rejected ex:ActOfFormulation: it would force a Directive output, contradicting the GOLDEN PRINCIPLE and breaking parallel-row consistency with its sibling Calculate consolidation at source [10255], which is correctly an Act of Analysis with a Descriptive ex:ConsolidationQuantity. Output changed from the Directive ex:LogisticsRequirementSpecification to the Descriptive ex:DestinationRequirementQuantity, mirroring P10255." ;
    skos:example "The team agrees the exact replenishment quantity for the destination DC." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DestinationRequirementQuantity ] .

ex:P10255 a owl:Class ;
    ex:pcfID "10255" ; ex:hierarchyID "4.1.5.5" ;
    ex:apqcSourceText "Determining the aggregate volume of products/services consolidated at the source. Calculate the number of finished products that are ready to be delivered to the customers, particularly at one date." ;
    rdfs:label "Calculate consolidation at source" ;
    skos:definition "An Act of Analysis that computes and has as output a consolidation quantity giving the aggregate volume of finished products consolidated at the source for a given date." ;
    skos:example "Shipping totals the units ready to consolidate at the plant for Friday's outbound." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ConsolidationQuantity ] .

ex:P10256 a owl:Class ;
    ex:pcfID "10256" ; ex:hierarchyID "4.1.5.6" ;
    ex:apqcSourceText "Administering the plan for collaborative replenishment of goods. Replenish inventory by creating a plan in case of faulty production." ;
    rdfs:label "Manage collaborative replenishment planning" ;
    skos:definition "An Act of Formulation that has as output a replenishment plan for the collaborative replenishment of inventory." ;
    rdfs:comment "Anchored to Act of Formulation (creating/administering a plan), not an Organization Capability; the lead activity yields a Directive replenishment plan." ;
    skos:example "Planners and the supplier agree a VMI replenishment plan for the DC." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ReplenishmentPlan ] .

ex:P10258 a owl:Class ;
    ex:pcfID "10258" ; ex:hierarchyID "4.1.5.7" ;
    ex:apqcSourceText "Estimating the timing and duration of the delivery of the inventory from the source to the destination. Plan the logistic details of all the distribution routes and activities." ;
    rdfs:label "Calculate and optimize destination dispatch plan" ;
    skos:definition "An Act of Formulation that has as output a dispatch plan specifying the timing, duration, and routing of inventory delivery from source to destination." ;
    skos:example "Transport planning builds the optimized dispatch plan for the week's outbound loads." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DispatchPlan ] .

ex:P10259 a owl:Class ;
    ex:pcfID "10259" ; ex:hierarchyID "4.1.5.8" ;
    ex:apqcSourceText "Accomplishing the dispatch plan. Strictly follow the schedule, and adjust for deviations. Coordinate with the concerned authorities at various destinations." ;
    rdfs:label "Manage dispatch plan attainment" ;
    skos:definition "An Act of Monitoring that has as input a dispatch plan, tracks adherence to it, and adjusts for deviations from the schedule." ;
    skos:example "Logistics control watches dispatch execution and reschedules a delayed load." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DispatchPlan ] .

ex:P10260 a owl:Class ;
    ex:pcfID "10260" ; ex:hierarchyID "4.1.5.9" ;
    ex:apqcSourceText "Evaluating the plans for delivering loads to destinations. Create a systematic plan that specifies the load plans for every single destination." ;
    rdfs:label "Calculate and optimize destination load plans" ;
    skos:definition "An Act of Formulation that has as output a load plan specifying how loads are built and delivered to each destination." ;
    skos:example "Planning produces the per-destination load plan maximizing trailer fill." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LoadPlan ] .

ex:P10261 a owl:Class ;
    ex:pcfID "10261" ; ex:hierarchyID "4.1.5.10" ;
    ex:apqcSourceText "Administering the load plan for partners. Manage the delivery, and dispatch from the source to the partners." ;
    rdfs:label "Manage partner load plan" ;
    skos:definition "An Act of Monitoring that has as input a load plan and oversees its attainment for partner deliveries and dispatch from the source." ;
    skos:example "The team tracks partner load execution and resolves a missed partner pickup." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:LoadPlan ] .

ex:P10262 a owl:Class ;
    ex:pcfID "10262" ; ex:hierarchyID "4.1.5.11" ;
    ex:apqcSourceText "Managing all expenses to provide products/services in the market. Estimate the overall cost of supplying of products/inventory, including the cost distributing it through various partners and channels. Consider the cost of all the logistical processes that occur from the moment a product is ready to be dispatched to the time it reaches the destination." ;
    rdfs:label "Manage cost of supply" ;
    skos:definition "An Act of Appraisal that estimates and has as output a supply cost estimate of the overall cost of supplying products through distribution channels." ;
    rdfs:comment "Anchored to Act of Appraisal (estimating value/cost); output is a Descriptive supply cost estimate." ;
    skos:example "Finance estimates the all-in cost to land product at each region's DC." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplyCostEstimate ] .

ex:P10263 a owl:Class ;
    ex:pcfID "10263" ; ex:hierarchyID "4.1.5.12" ;
    ex:apqcSourceText "Determining the capacity utilization of the organization's production process. Realize the extent to which an enterprise uses its installed productive capacity (i.e., the relationship between output and the potential output if capacity was fully used)." ;
    rdfs:label "Manage capacity utilization" ;
    skos:definition "An Act of Appraisal that determines and has as output a capacity utilization report on the extent to which installed productive capacity is used." ;
    skos:example "Operations reports lines at 78 percent of installed capacity for the quarter." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CapacityUtilizationReport ] .

####################################################################
# 4.1.6 branch -- Establish distribution planning constraints
####################################################################

ex:P10226 a owl:Class ;
    ex:pcfID "10226" ; ex:hierarchyID "4.1.6" ;
    ex:apqcSourceText "Instituting the constraints for planning of distribution process. Create a plan that specifies every element in the distribution process from the blueprint of the distribution centers to how and when the inventory would reach the distribution centers." ;
    rdfs:label "Establish distribution planning constraints" ;
    skos:definition "An Act of Formulation that has as output a distribution planning constraint specification instituting the constraints governing the distribution process." ;
    rdfs:comment "Models APQC 4.1.6 as an occurrent; its APQC children are process parts." ;
    skos:example "Network planning fixes the layout, inventory, transport, and storage constraints for the next design cycle." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DistributionPlanningConstraintSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10267 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10268 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10269 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19558 ] .

ex:P10267 a owl:Class ;
    ex:pcfID "10267" ; ex:hierarchyID "4.1.6.1" ;
    ex:apqcSourceText "Instituting the constraints for creating a layout for distribution center. Consider factors such as the number of customers, demand forecasting, product groups, condition of product conservation, warehousing, and transportation management." ;
    rdfs:label "Establish distribution center layout constraints" ;
    skos:definition "An Act of Formulation that has as output a distribution planning constraint specification governing distribution-center layout." ;
    skos:example "Planners set the layout constraints for the DC given product mix and demand." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DistributionPlanningConstraintSpecification ] .

ex:P10268 a owl:Class ;
    ex:pcfID "10268" ; ex:hierarchyID "4.1.6.2" ;
    ex:apqcSourceText "Determining any problems that might be faced while managing inventory. Identify problems and possible issues in managing the warehousing of the raw materials, spares, and other items of inventory. Take stock of inventory needs, and determine the exact quantity of the inventory needed in the near future." ;
    rdfs:label "Establish inventory management constraints" ;
    skos:definition "An Act of Analysis that discerns the problems and issues in managing inventory and quantifies inventory needs, producing an inventory needs assessment." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfFormulation (Act of Planning -> Directive) to ex:ActOfAnalysis (Act of Information Processing -> Descriptive). Unlike its siblings P10267/P10269/P19558 (which 'institute'/'identify constraints' and genuinely formulate a Directive constraint specification), this row's dominant content is problem-identification and needs-quantification ('Determining any problems... Identify problems and possible issues... Take stock of inventory needs, and determine the exact quantity needed'), which is descriptive analysis. Rejected ex:ActOfFormulation: it would force a Directive output mismatched to the discern/quantify verbs (GOLDEN PRINCIPLE). Output changed from the Directive ex:DistributionPlanningConstraintSpecification to the Descriptive ex:InventoryNeedsAssessment." ;
    skos:example "The team documents storage and stock-level constraints for the warehouse." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InventoryNeedsAssessment ] .

ex:P10269 a owl:Class ;
    ex:pcfID "10269" ; ex:hierarchyID "4.1.6.3" ;
    ex:apqcSourceText "Identifying any potential constraints while deciding on the dispatch and delivery plan from the source to the various distribution centers. Decide how the inventory will be transported , which and how many transportation means to use, what route to take, etc." ;
    rdfs:label "Establish transportation management constraints" ;
    skos:definition "An Act of Formulation that has as output a distribution planning constraint specification governing transportation management." ;
    skos:example "Logistics fixes mode, fleet-size, and routing constraints for source-to-DC transport." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DistributionPlanningConstraintSpecification ] .

ex:P19558 a owl:Class ;
    ex:pcfID "19558" ; ex:hierarchyID "4.1.6.4" ;
    ex:apqcSourceText "Determining potential constraints for physical storage and retrieval of components or products in a storage facility within a certain timeframe. Consider factors such as the building shape, height, capacity, door locations, lift equipment, automation, etc." ;
    rdfs:label "Establish storage management constraints" ;
    skos:definition "An Act of Formulation that has as output a distribution planning constraint specification governing physical storage and retrieval in a storage facility." ;
    skos:example "Warehousing sets the height, door, and automation constraints for the storage facility." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DistributionPlanningConstraintSpecification ] .

####################################################################
# 4.1.7 branch -- Review distribution planning policies
####################################################################

ex:P10227 a owl:Class ;
    ex:pcfID "10227" ; ex:hierarchyID "4.1.7" ;
    ex:apqcSourceText "Revisiting and refurbishing the policies for planning the distribution process. Asses the distribution strategies, including how the products are to be made available and sent to different distributors. Set guidelines regarding relationships between the sources and the distribution centers." ;
    rdfs:label "Review distribution planning policies" ;
    skos:definition "An Act of Appraisal that has as input a distribution policy and reassesses the organization's distribution strategies and sourcing guidelines." ;
    rdfs:comment "Anchored to Act of Appraisal (the lead verb 'Review/Assess' is a judgement). Its APQC children are process parts; revised policy is produced by child 4.1.7.3." ;
    skos:example "The logistics council reviews and updates the distribution policy at year end." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DistributionPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10264 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10265 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10266 ] .

ex:P10264 a owl:Class ;
    ex:pcfID "10264" ; ex:hierarchyID "4.1.7.1" ;
    ex:apqcSourceText "Evaluating the system that defines how the products/inventory would reach from the source (i.e., manufacturer) to the destination (i.e., retailer/distributer)." ;
    rdfs:label "Review distribution network" ;
    skos:definition "An Act of Appraisal that has as input a logistics network design and evaluates how products reach destinations from the source." ;
    rdfs:comment "A network-review assessment is the typical output but is not asserted as definitional; the input logistics network design is what the act necessarily evaluates." ;
    skos:example "Network analysts evaluate whether the current DC footprint still serves demand efficiently." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:LogisticsNetworkDesign ] .

ex:P10265 a owl:Class ;
    ex:pcfID "10265" ; ex:hierarchyID "4.1.7.2" ;
    ex:apqcSourceText "Establishing relationships with transportation/distribution sources in order to ensure an effective distribution network and strategy. Screen and evaluate various sources available to pick out the best among them." ;
    rdfs:label "Establish sourcing relationships" ;
    skos:definition "An Act of Selection that screens candidate transportation and distribution sources and has as output a supplier selection decision identifying the chosen source." ;
    rdfs:comment "Anchored to Act of Selection: a best option is chosen from a candidate set, yielding a Directive decision. Carrier is a definitional participant." ;
    skos:example "Logistics screens carriers and selects the preferred regional partner." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierSelectionDecision ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Carrier ] .

ex:P10266 a owl:Class ;
    ex:pcfID "10266" ; ex:hierarchyID "4.1.7.3" ;
    ex:apqcSourceText "Creating strategic guidelines on the availability of the products at all the distribution centers. Create a dynamic network to ensure availability at all times, even in cases of defaults." ;
    rdfs:label "Establish dynamic deployment policies" ;
    skos:definition "An Act of Formulation that has as output a distribution policy of strategic guidelines ensuring product availability across all distribution centers." ;
    skos:example "Planning sets the dynamic deployment rules that rebalance stock across DCs on stockout risk." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DistributionPolicy ] .

####################################################################
# 4.1.8 branch -- Develop quality standards and procedures
####################################################################

ex:P10368 a owl:Class ;
    ex:pcfID "10368" ; ex:hierarchyID "4.1.8" ;
    ex:apqcSourceText "Developing standards and procedures for maintaining the quality of products/services. Establish desired quality targets. Create standardized procedures for the quality. Ensure quality specifications are effectively communicated." ;
    rdfs:label "Develop quality standards and procedures" ;
    skos:definition "An Act of Formulation that composes the quality targets and testing procedures for products and has as output a quality standard and a quality testing procedure." ;
    rdfs:comment "Models APQC 4.1.8 as an occurrent; its APQC children are process parts." ;
    skos:example "The quality team sets target tolerances and writes the matching test procedures." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityStandard ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestingProcedure ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10371 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10372 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10373 ] .

ex:P10371 a owl:Class ;
    ex:pcfID "10371" ; ex:hierarchyID "4.1.8.1" ;
    ex:apqcSourceText "Defining specific qualitative and quantitative target figures." ;
    rdfs:label "Establish quality targets" ;
    skos:definition "An Act of Formulation that has as output a quality standard defining specific qualitative and quantitative quality target figures." ;
    skos:example "QA fixes the defect-rate and dimensional targets for the product family." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityStandard ] .

ex:P10372 a owl:Class ;
    ex:pcfID "10372" ; ex:hierarchyID "4.1.8.2" ;
    ex:apqcSourceText "Creating standard procedures for testing the quality of products/services. Describe the steps of key processes to help ensure consistent and quality output. Define the routine instructions for performing the quality testing activity." ;
    rdfs:label "Develop standard testing procedures" ;
    skos:definition "An Act of Formulation that has as output a quality testing procedure prescribing the routine steps for testing product quality." ;
    skos:example "QA writes the inspection procedure for incoming and finished-goods testing." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestingProcedure ] .

ex:P10373 a owl:Class ;
    ex:pcfID "10373" ; ex:hierarchyID "4.1.8.3" ;
    ex:apqcSourceText "Communicating the desired quality specifications to the manufacturing units, as well as the distribution centers, to avoid any misunderstanding or misinterpretation." ;
    rdfs:label "Communicate quality specifications" ;
    skos:definition "An Act of Communication that has as input a quality standard and transfers the desired quality specifications to manufacturing units and distribution centers." ;
    rdfs:comment "Re-anchored (Gate-F) to cco:ont00000402 (Act of Communication, co-anchored to cco:ont00000228 Planned Act): the act TRANSFERS an existing Directive ICE (the quality standard) to manufacturing units and distribution centers; it does not formulate the standard. Aligns with the communication anchoring of P10345 and P10366." ;
    skos:example "QA circulates the approved quality spec sheet to all plants and DCs." ;
    rdfs:subClassOf cco:ont00000402 ,
        cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityStandard ] .

####################################################################
# PROCESS GROUP PARENT -- 4.1 (PCF 10215)
####################################################################

ex:P10215 a owl:Class ;
    ex:pcfID "10215" ; ex:hierarchyID "4.1" ;
    ex:apqcSourceText "Creating strategies for production and materials. Handle the demand for the products of the organization. Develop plans for handling materials. Develop and administer the schedule for master production. Plan for distribution requirements and its constraints by reviewing and assessing distribution policies and performance and by establishing quality standards and procedures." ;
    rdfs:label "Plan for and align supply chain resources" ;
    skos:definition "An Act of Planning that aligns an organization's supply chain resources by formulating production, materials, demand, scheduling, distribution, and quality plans." ;
    rdfs:comment "Models APQC process group 4.1 as an occurrent whose APQC children are process parts (cco:ont00001777), mirroring the GOLD treatment of group-level nodes. Not given existential has-process-part to it from Category 4.0 (R3)." ;
    skos:example "An organization's annual supply-chain planning cycle aligning production, materials, and distribution resources." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10221 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10222 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10223 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10224 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17042 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10226 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10227 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10368 ] .

####################################################################
# ===== GROUP 4.2  Procure materials and services (PCF 10216)
# Reuses shared act genera (ex:ActOfAnalysis, ex:ActOfIdentification,
# ex:ActOfFormulation, ex:ActOfSelection, ex:ActOfAcquisition) and the
# section-4.0 shared vocab. Partonomy via cco:ont00001777.
####################################################################

ex:P10216 a owl:Class ;
    ex:pcfID "10216" ; ex:hierarchyID "4.2" ;
    ex:apqcSourceText "Creating a plan for procuring materials and services. Develop strategies for sourcing materials and services. Choose the most appropriate suppliers, and develop contracts with them. Order the materials and services as per the requirements. Manage relationships with suppliers." ;
    rdfs:label "Procure materials and services" ;
    skos:definition "An Act of Acquisition that obtains the materials and services an organization requires by planning sourcing, selecting suppliers, ordering, and managing supplier relationships." ;
    rdfs:comment "Models APQC process group 4.2 as a bounded procurement cycle. Its APQC children are process parts, not subclasses. No definitional single output; the cycle's deliverables are carried by its parts." ;
    skos:example "A manufacturer's quarterly procurement cycle from sourcing strategy through supplier management." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10277 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10278 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10279 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10280 ] .

####################################################################
# 4.2.1  Provide sourcing governance and perform category management
####################################################################

ex:P10277 a owl:Class ;
    ex:pcfID "10277" ; ex:hierarchyID "4.2.1" ;
    ex:apqcSourceText "Creating strategies for procuring materials and services from various sources, and for managing and evaluating categories. Establish a procurement process that describes the approach for obtaining products and purchasing activities. Evaluate the sources. Create sourcing relationships in order to continuously improve. Re-evaluate purchasing activities." ;
    rdfs:label "Provide sourcing governance and perform category management" ;
    skos:definition "An Act of Formulation that composes the sourcing strategies and procurement process governing how an organization obtains materials and services across categories." ;
    rdfs:comment "Genus Act of Formulation (cco:ont00000511 Act of Planning): its principal deliverable is a prescriptive procurement process/sourcing strategy (a Directive ICE), per the Golden Principle." ;
    skos:example "A procurement office defines category strategies and a documented sourcing process for the coming year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10281 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10282 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10283 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10284 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10285 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10286 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10287 ] .

ex:P10281 a owl:Class ;
    ex:pcfID "10281" ; ex:hierarchyID "4.2.1.1" ;
    ex:apqcSourceText "Creating a plan for procuring materials and services. Plan what to buy, when, and from what sources. Include project requirements, the procurement team, the justification for the procurement, a timeline of events, and an explanation of the supplier selection process. Outline specific actions to start and complete purchases in order to adhere to best practices." ;
    rdfs:label "Develop procurement plan" ;
    skos:definition "An Act of Formulation that composes a Procurement Plan prescribing what to buy, when, and from which sources." ;
    skos:example "A procurement lead drafts a sourcing plan with timeline, team, and supplier-selection approach for a build program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcurementPlan ] .

ex:P10282 a owl:Class ;
    ex:pcfID "10282" ; ex:hierarchyID "4.2.1.2" ;
    ex:apqcSourceText "Defining the purchasing requirements for materials and services. Specify the exact inventory required for the production process. Create a specific quotation for all the sources in order to avoid any duplication or overlap." ;
    rdfs:label "Clarify purchasing requirements" ;
    skos:definition "An Act of Formulation that specifies the exact materials and services to be purchased, producing a Purchasing Requirement Specification." ;
    rdfs:comment "Output is a Directive ICE (a requirement specification), so the act is anchored under Act of Formulation per the Golden Principle." ;
    skos:example "A buyer defines exact part numbers and quantities required by a production line into a purchasing requirement spec." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PurchasingRequirementSpecification ] .

ex:P10283 a owl:Class ;
    ex:pcfID "10283" ; ex:hierarchyID "4.2.1.3" ;
    ex:apqcSourceText "Developing a strategy to deal with issues projected to arise during implementation of the inventory plan. Identify how to react to issues that arise and require changes to the inventory plan, such as a vendor failing to deliver materials on time. Collaborate with production and suppliers to prepare solutions to projected problems." ;
    rdfs:label "Establish materials management contingency plans" ;
    skos:definition "An Act of Formulation that composes a Materials Management Contingency Plan prescribing responses to projected materials-supply disruptions." ;
    skos:example "A team prepares fallback sourcing and buffer-stock procedures for the case of a key vendor's late delivery." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaterialsManagementContingencyPlan ] .

ex:P10284 a owl:Class ;
    ex:pcfID "10284" ; ex:hierarchyID "4.2.1.4" ;
    ex:apqcSourceText "Synchronizing the requirements of materials and services and the capacity of suppliers for providing these materials and services. Revamp the procurement needs of the company in consideration of the capabilities of the suppliers." ;
    rdfs:label "Match needs to supply capabilities" ;
    skos:definition "An Act of Analysis that examines purchasing requirements against supplier capacity and produces a needs-supply alignment assessment." ;
    rdfs:comment "Genus Act of Analysis: it manipulates requirement and capacity ICEs into a descriptive judgement of fit; revised needs follow from that judgement." ;
    skos:example "A planner reconciles a bill of requirements with supplier capacity profiles and reports where demand exceeds capacity." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PurchasingRequirementSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SupplierCapacityProfile ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:NeedsSupplyAlignmentAssessment ] .

ex:P10285 a owl:Class ;
    ex:pcfID "10285" ; ex:hierarchyID "4.2.1.5" ;
    ex:apqcSourceText "Evaluating the spend profile of the organization. Collect, cleanse, classify, and analyze the procurement data with the purpose of reducing procurement costs, improving efficiency, and monitoring compliance." ;
    rdfs:label "Analyze organization's spend profile" ;
    skos:definition "An Act of Analysis that examines collected procurement data and produces a Spend Profile Analysis." ;
    skos:example "A category manager classifies a year of purchase data and reports spend concentration by supplier and category." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SpendProfileAnalysis ] .

ex:P10286 a owl:Class ;
    ex:pcfID "10286" ; ex:hierarchyID "4.2.1.6" ;
    ex:apqcSourceText "Seeking the most efficient sourcing and procurement opportunities." ;
    rdfs:label "Seek opportunities to improve efficiency and value" ;
    skos:definition "An Act of Identification that discerns sourcing and procurement opportunities for improved efficiency and value, producing a sourcing-opportunity assessment." ;
    rdfs:comment "Genus Act of Identification (discernment): the act registers discerned opportunities as a Descriptive ICE." ;
    skos:example "A sourcing analyst scans the supply base and registers consolidation and renegotiation opportunities." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SourcingOpportunityAssessment ] .

ex:P10287 a owl:Class ;
    ex:pcfID "10287" ; ex:hierarchyID "4.2.1.7" ;
    ex:apqcSourceText "Collaborating with the suppliers of materials and services in order to determine new opportunities for sourcing." ;
    rdfs:label "Collaborate with suppliers to identify sourcing opportunities" ;
    skos:definition "An Act of Identification that, in collaboration with suppliers, discerns new sourcing opportunities and produces a sourcing-opportunity assessment." ;
    rdfs:comment "Suppliers are definitional participants (the collaboration is constitutive of the act); modeled via has participant on ex:Supplier (shared vocab Organization)." ;
    skos:example "Buyers and key suppliers jointly identify a new co-sourcing arrangement for a component." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SourcingOpportunityAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Supplier ] .

####################################################################
# 4.2.2  Select suppliers and develop/maintain contracts
####################################################################

ex:P10278 a owl:Class ;
    ex:pcfID "10278" ; ex:hierarchyID "4.2.2" ;
    ex:apqcSourceText "Evaluating supplier options to select the most effective and efficient suppliers. Validate selected suppliers. Establish and manage supplier contracts." ;
    rdfs:label "Select suppliers and develop/maintain contracts" ;
    skos:definition "An Act of Selection that chooses suppliers from evaluated options and establishes the contracts that bind them, producing a Supplier Selection Decision." ;
    rdfs:comment "Dominant deliverable is a Supplier Selection Decision (Directive); genus Act of Selection. Contract formation and management are process parts." ;
    skos:example "A sourcing committee selects two qualified suppliers and puts framework contracts in place." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierSelectionDecision ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10288 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10289 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10290 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10291 ] .

ex:P10288 a owl:Class ;
    ex:pcfID "10288" ; ex:hierarchyID "4.2.2.1" ;
    ex:apqcSourceText "Evaluating the pros and cons of various suppliers. Choose the most appropriate and cost-effective suppliers on the basis of their material quality, delivery schedules, and costs." ;
    rdfs:label "Select suppliers" ;
    skos:definition "An Act of Selection that chooses one or more suppliers from candidate supplier quotes and produces a Supplier Selection Decision." ;
    skos:example "A buyer compares three vendor quotes and decides which supplier wins the award." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SupplierQuote ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierSelectionDecision ] .

ex:P10289 a owl:Class ;
    ex:pcfID "10289" ; ex:hierarchyID "4.2.2.2" ;
    ex:apqcSourceText "Validating the supply sources, and provide certification as an official supplier." ;
    rdfs:label "Certify and validate suppliers" ;
    skos:definition "An Act of Appraisal that validates a supply source and produces a supplier validation assessment judging its fitness to be an approved supplier." ;
    rdfs:comment "Genus Act of Appraisal (cco:ont00000636): the principal act judges the supplier's fitness, yielding a Descriptive validation assessment that agrees with the genus (GOLDEN PRINCIPLE). Gate-F fix: demoted the second output [has output some ex:SupplierCertification] from an existential restriction to this non-definitional note. Issuing a certification is an authorization act, not an appraisal, and is only a CONDITIONAL downstream artifact: an instance can validate a source, find it non-conforming, and produce NO certification, so SupplierCertification is not necessary for every instance of the type (Phase-3 necessity). Where the certification issuance is tracked, model it as a separate authorization act (an Act of Acquisition over the Directive ex:SupplierCertification) rather than as a definitional output of this appraisal." ;
    skos:example "A quality team audits a vendor's facility, judges it compliant, and grants official-supplier status." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierValidationAssessment ] .

ex:P10290 a owl:Class ;
    ex:pcfID "10290" ; ex:hierarchyID "4.2.2.3" ;
    ex:apqcSourceText "Legally binding suppliers with the company. Negotiate contracts individually with all the suppliers that include the promised material delivery, the delivery dates and duration, etc." ;
    rdfs:label "Negotiate and establish contracts" ;
    skos:definition "An Act of Contract Formation that, through negotiation with a supplier, establishes a legally binding Supplier Contract governing material delivery terms." ;
    rdfs:comment "Reuses CCO cco:ont00000684 (Act of Contract Formation) -- 'An Act of Promising ... entered into voluntarily by two or more agents ... intends to create one or more legal obligations' -- which fits exactly. Supplier is a definitional participant." ;
    skos:example "Procurement and a supplier negotiate and sign a one-year supply agreement with fixed delivery windows." ;
    rdfs:subClassOf cco:ont00000684 ,   # Act of Contract Formation
        cco:ont00000228 ,               # Planned Act (explicit; entailed via ont00000684, asserted so S2 resolves standalone)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierContract ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Supplier ] .

ex:P10291 a owl:Class ;
    ex:pcfID "10291" ; ex:hierarchyID "4.2.2.4" ;
    ex:apqcSourceText "Keeping contracts up-to-date with routine evaluation. Maintain order and discipline with the contracts in order to avoid any loss of information and mishaps." ;
    rdfs:label "Manage contracts" ;
    skos:definition "An Act of Appraisal that periodically evaluates a Supplier Contract for currency and compliance and produces a contract review assessment." ;
    rdfs:comment "R5: although phrased 'Manage', the source reduces this to routine periodic evaluation -- a bounded, repeatable review act -- so it is modeled as a process (genus Act of Appraisal), preserving the partonomy of 4.2.2, rather than as an unbounded Organization Capability." ;
    skos:example "A contract administrator reviews active supplier contracts each quarter and flags terms needing update." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SupplierContract ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ContractReviewAssessment ] .

####################################################################
# 4.2.3  Order materials and services
####################################################################

ex:P10279 a owl:Class ;
    ex:pcfID "10279" ; ex:hierarchyID "4.2.3" ;
    ex:apqcSourceText "Creating and approving requisitions and distributing purchase orders accordingly. Hasten the procurement process to satisfy internal needs." ;
    rdfs:label "Order materials and services" ;
    skos:definition "An Act of Acquisition that obtains required materials and services by creating and approving requisitions and issuing purchase orders to suppliers." ;
    rdfs:comment "Genus Act of Acquisition (Planned Act). Distinct from cco:ont00001334 Act of Purchasing, which requires actual use of a financial instrument; ordering here culminates in issued purchase orders, modeled by its parts." ;
    skos:example "A buyer raises requisitions, gets approval, and dispatches purchase orders to win the needed parts." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10292 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10293 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10294 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10295 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10296 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10297 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10298 ] .

ex:P10292 a owl:Class ;
    ex:pcfID "10292" ; ex:hierarchyID "4.2.3.1" ;
    ex:apqcSourceText "Handling operations related to processing/reviewing the requisitions. Establish and maintain procedures for the initiation, authorization, and processing of purchase requirements to procure products/services." ;
    rdfs:label "Process/Review requisitions" ;
    skos:definition "An Act of Information Processing that receives and reviews purchase requisitions and produces a reviewed requisition ready for authorization." ;
    rdfs:comment "Genus cco:ont00000366 (Act of Information Processing): requisition ICEs are received, checked, and routed. Gate-F fix: dropped the degenerate [has output some ex:PurchaseRequisition] restriction (input class = output class is semantically empty and trivially satisfied by any review); the distinct produced artifact is ex:ReviewedRequisition. R5: the source's 'Establish and maintain procedures for the initiation, authorization, and processing of purchase requirements' describes a standing SOP that is NOT modeled as a bounded occurrent here; that procedure-maintenance reduces to the standing ex:ProcurementCapability, while this class is scoped to the bounded per-requisition review (Phase-1 method-phrase criterion)." ;
    skos:example "A procurement clerk validates incoming requisitions against policy before routing them for approval." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PurchaseRequisition ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ReviewedRequisition ] .

ex:P10293 a owl:Class ;
    ex:pcfID "10293" ; ex:hierarchyID "4.2.3.2" ;
    ex:apqcSourceText "Approving requisitions for materials and services. Examine distributor-specific requests, and validate them individually." ;
    rdfs:label "Approve requisitions" ;
    skos:definition "A Planned Act that ratifies a purchase requisition and produces a Requisition Approval Decision authorizing procurement to proceed." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act), not Act of Selection: approval ratifies a single already-settled requisition with no candidate set (per the apqc-ext Act of Selection note). Output is a Directive ICE." ;
    skos:example "A budget owner signs off on a requisition, authorizing the purchase." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PurchaseRequisition ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RequisitionApprovalDecision ] .

ex:P10294 a owl:Class ;
    ex:pcfID "10294" ; ex:hierarchyID "4.2.3.3" ;
    ex:apqcSourceText "Requesting quotes from suppliers. Use a request for quotation (RFQ) to invite suppliers into a bidding process for specific products/services." ;
    rdfs:label "Solicit supplier quotes" ;
    skos:definition "An Act of Formulation that composes and issues a Request for Quotation inviting suppliers to bid on specified products or services." ;
    rdfs:comment "Output is a Directive ICE (the RFQ prescribes what bidders must respond to), so the act is anchored under Act of Formulation per the Golden Principle." ;
    skos:example "A buyer issues an RFQ to five vendors for a custom fastener and opens a bidding window." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RequestForQuotation ] .

ex:P10295 a owl:Class ;
    ex:pcfID "10295" ; ex:hierarchyID "4.2.3.4" ;
    ex:apqcSourceText "Creating and placing the orders for purchasing materials and services from suppliers. Analyze vendor quotes. Choose the most cost-effective vendors. Create vendor-specific orders. Distribute them in order to initiate the purchasing process." ;
    rdfs:label "Create/Distribute purchase orders" ;
    skos:definition "An Act of Formulation that, from analyzed supplier quotes, composes and distributes vendor-specific Purchase Orders." ;
    rdfs:comment "Principal deliverable is a Purchase Order (Directive ICE); genus Act of Formulation. Vendor quotes are a definitional input." ;
    skos:example "A buyer turns the winning quotes into purchase orders and sends them to the chosen vendors." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SupplierQuote ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PurchaseOrder ] .

ex:P10296 a owl:Class ;
    ex:pcfID "10296" ; ex:hierarchyID "4.2.3.5" ;
    ex:apqcSourceText "Accelerating the purchase orders in order to fulfill the internal needs (for raw materials) depicted through inquiries." ;
    rdfs:label "Expedite orders and satisfy inquiries" ;
    skos:definition "A Planned Act that accelerates outstanding purchase orders to satisfy urgent internal needs for raw materials expressed through inquiries." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): expediting coordinates faster fulfillment rather than producing a definitional informational artifact. Inputs (inquiries) and the affected purchase orders are typical, not necessary, so they are noted here rather than as restrictions." ;
    skos:example "A buyer chases a supplier to advance a delivery date so a production line is not starved of raw material." ;
    rdfs:subClassOf cco:ont00000228 .

ex:P10297 a owl:Class ;
    ex:pcfID "10297" ; ex:hierarchyID "4.2.3.6" ;
    ex:apqcSourceText "Verify that purchase orders are filled as expected: verify that items and quantities are delivered as expected, based on purchase order details and goods receipts." ;
    rdfs:label "Reconcile purchase orders" ;
    skos:definition "An Act of Analysis that compares purchase orders against goods receipts and produces a Purchase Order Reconciliation Report." ;
    rdfs:comment "Genus Act of Analysis: it manipulates the purchase-order and inventory-record ICEs into a descriptive reconciliation report. The delivered materials are operational context; the definitional output is informational." ;
    skos:example "Accounts payable matches received quantities against PO lines and reports the discrepancies." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PurchaseOrder ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InventoryRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PurchaseOrderReconciliationReport ] .

ex:P10298 a owl:Class ;
    ex:pcfID "10298" ; ex:hierarchyID "4.2.3.7" ;
    ex:apqcSourceText "Identifying and resolving any exceptions. Address the internal needs/inquiries for materials that cannot be procured immediately. Research inquiries that require the need of exceptional materials." ;
    rdfs:label "Research/Resolve order exceptions" ;
    skos:definition "An Act of Selection that researches order exceptions and chooses a resolution, producing a Disposition Decision for the exceptional material need." ;
    rdfs:comment "Genus Act of Selection: among candidate resolution paths for an exception, one is chosen and recorded as a Disposition Decision (a Directive ICE). Reuses ex:DispositionDecision (shared vocab)." ;
    skos:example "A buyer researches a hard-to-source material and decides to substitute an approved alternate." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DispositionDecision ] .

####################################################################
# 4.2.4  Manage suppliers
####################################################################

ex:P10280 a owl:Class ;
    ex:pcfID "10280" ; ex:hierarchyID "4.2.4" ;
    ex:apqcSourceText "Collecting and analyzing new information in order to track and rate suppliers through a supplier information management system." ;
    rdfs:label "Manage suppliers" ;
    skos:definition "An Act of Analysis that collects and analyzes supplier information to track and rate suppliers, producing a Supplier Performance Report." ;
    rdfs:comment "R5: although phrased 'Manage', the source reduces this to a bounded, repeatable collect-and-analyze rating cycle, so it is modeled as a process (genus Act of Analysis) with its monitoring/analysis acts as parts, rather than as an unbounded Organization Capability." ;
    skos:example "Procurement runs its periodic supplier scorecard cycle, rating vendors on delivery and quality." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierPerformanceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10299 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10300 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10301 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10302 ] .

ex:P10299 a owl:Class ;
    ex:pcfID "10299" ; ex:hierarchyID "4.2.4.1" ;
    ex:apqcSourceText "Examining procurement and vendor performance. Report delivery timing and the quality of the materials procured through different vendors." ;
    rdfs:label "Monitor/Manage supplier information" ;
    skos:definition "An Act of Monitoring that tracks procurement and vendor performance over time and produces a Supplier Performance Report." ;
    rdfs:comment "Genus ex:ActOfMonitoring (section-4.0 ext proposal): ongoing observation of performance yielding a Descriptive performance report." ;
    skos:example "A supplier-management team logs each vendor's on-time delivery and defect rate into a performance report." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierPerformanceReport ] .

ex:P10300 a owl:Class ;
    ex:pcfID "10300" ; ex:hierarchyID "4.2.4.2" ;
    ex:apqcSourceText "Assisting the production and inventory processes through the information and reports created. Use the information and metrics of the procurement and vendor performance to enhance or improve the production process." ;
    rdfs:label "Prepare/Analyze procurement and supplier performance" ;
    skos:definition "An Act of Analysis that examines procurement and supplier performance metrics and produces a Supplier Performance Report supporting production improvement." ;
    skos:example "An analyst aggregates vendor metrics into a performance report used to tune production planning." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierPerformanceReport ] .

ex:P10301 a owl:Class ;
    ex:pcfID "10301" ; ex:hierarchyID "4.2.4.3" ;
    ex:apqcSourceText "Support inventory and production processes by analyzing impact of procurement decisions and collaborating to constantly improve. (For example, perhaps minimum order requirements could be negotiated to be lower, to reduce excessive inventory and make production more flexible.)" ;
    rdfs:label "Support inventory and production processes" ;
    skos:definition "An Act of Analysis that examines the impact of procurement decisions on inventory and production and produces a procurement-impact analysis." ;
    rdfs:comment "R5: 'Support' reduces here to a bounded analytical contribution (analyzing procurement-decision impact), modeled as a process rather than an unbounded capability." ;
    skos:example "An analyst shows how a high minimum-order quantity inflates inventory and recommends renegotiation." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcurementImpactAnalysis ] .

ex:P10302 a owl:Class ;
    ex:pcfID "10302" ; ex:hierarchyID "4.2.4.4" ;
    ex:apqcSourceText "Track the performance of the suppliers on product quality. Use this information to further improve sourcing and supplier performance." ;
    rdfs:label "Monitor quality of product delivered" ;
    skos:definition "An Act of Monitoring that tracks the quality of products delivered by suppliers and produces a Supplier Performance Report on product quality." ;
    rdfs:comment "Genus ex:ActOfMonitoring (section-4.0 ext proposal): ongoing observation of delivered-product quality yielding a Descriptive report." ;
    skos:example "An inbound-quality team records defect rates per supplier shipment into a supplier quality report." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierPerformanceReport ] .

####################################################################
# ===== GROUP 4.3  Produce/Assemble/Test product (PCF 10217)
# Reuses ex:ActOfProduction, ex:ActOfScheduling, ex:ActOfMonitoring
# (section genera above) and ex:ActOfFormulation, ex:ActOfAnalysis
# (inlined). Quality testing anchors at cco:ont00000345 (Act of
# Measuring); calibration at cco:ont00000950 (Act of Maintenance).
####################################################################

ex:P10217 a owl:Class ;
    ex:pcfID "10217" ; ex:hierarchyID "4.3" ;
    ex:apqcSourceText "Processing and delivering the finished goods manufactured by the organization. Schedule the production of products. Execute the product production activities. Perform tests to oversee and ensure quality of production. Maintain records of the production process. Track lots." ;
    rdfs:label "Produce/Assemble/Test product" ;
    skos:definition "An Act of Production that schedules, executes, tests, and records the manufacture of an organization's physical products, yielding tested finished products and production records." ;
    rdfs:comment "Models APQC process group 4.3 as a bounded production-and-test cycle (occurrent). Its APQC children are process parts (cco:ont00001777), never subclasses." ;
    skos:example "A plant's end-to-end run for a production order: scheduling, manufacturing, quality testing, and lot record-keeping." ;
    rdfs:subClassOf ex:ActOfProduction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FinishedProduct ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10303 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10304 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10369 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10370 ] .

####################################################################
# 4.3.1 Schedule production  (PCF 10303) + children
####################################################################

ex:P10303 a owl:Class ;
    ex:pcfID "10303" ; ex:hierarchyID "4.3.1" ;
    ex:apqcSourceText "Scheduling the production of final products. Generate a detailed schedule plan. Create and release production orders and lots. Schedule the planned and unplanned maintenance orders." ;
    rdfs:label "Schedule production" ;
    skos:definition "An Act of Scheduling that allocates production activities, orders, and maintenance to times and resources and produces a production schedule." ;
    rdfs:comment "Models APQC 4.3.1 as an occurrent; APQC children are process parts." ;
    skos:example "A planner builds and releases the week's production and maintenance schedule." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionSchedule ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19563 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10306 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10307 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10308 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10315 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10316 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10309 ] .

ex:P19563 a owl:Class ;
    ex:pcfID "19563" ; ex:hierarchyID "4.3.1.1" ;
    ex:apqcSourceText "Creating a representation of plant facilities to optimize material flow, resource utilization, and logistics for all levels of plant planning from global production facilities, through local plants, to specific lines and enabling the comparison of production alternatives." ;
    rdfs:label "Model and simulate plant" ;
    skos:definition "An Act of Formulation that produces a production network model of plant facilities enabling optimization and comparison of production alternatives." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (Act of Planning): its definitional output is the directive Production Network Model. The descriptive Production Network Simulation Result is a typical secondary output, asserted via has output but not part of the genus-differentia." ;
    skos:example "An industrial engineer simulates line layouts to compare throughput across production alternatives." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionNetworkModel ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionNetworkSimulationResult ] .

ex:P10306 a owl:Class ;
    ex:pcfID "10306" ; ex:hierarchyID "4.3.1.2" ;
    ex:apqcSourceText "Initiating the line-level plan for production. Break down the production schedule into specific lines, specifying the various objectives the production schedule." ;
    rdfs:label "Generate line level plan" ;
    skos:definition "An Act of Scheduling that breaks down the production schedule into line-level objectives and produces a line-level production schedule." ;
    rdfs:comment "Output reuses ex:ProductionSchedule (a line-scoped production schedule)." ;
    skos:example "A scheduler decomposes the master plan into per-line objectives." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductionSchedule ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionSchedule ] .

ex:P10307 a owl:Class ;
    ex:pcfID "10307" ; ex:hierarchyID "4.3.1.3" ;
    ex:apqcSourceText "Broadening the line-level plan. Specify all the individual production processes, along with the timing and the duration to come up with a working schedule that tracks the whole process and any deviations that might occur." ;
    rdfs:label "Generate detailed schedule" ;
    skos:definition "An Act of Scheduling that elaborates the line-level plan into a working production schedule specifying the timing and duration of all individual production processes." ;
    skos:example "A planner produces the minute-by-minute working schedule for each line." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductionSchedule ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionSchedule ] .

ex:P10308 a owl:Class ;
    ex:pcfID "10308" ; ex:hierarchyID "4.3.1.4" ;
    ex:apqcSourceText "Creating a schedule to commence production of orders received, and creating lots to consolidate the processing. Plan when the production orders are to be initiated by commencing the operations for processing products/services. Specify which materials to produce, where to produce them, which operations will facilitate this, and on which date production is to start. Define the size of production lots, demarcating the durations of batch production." ;
    rdfs:label "Schedule production orders and create lots" ;
    skos:definition "An Act of Scheduling that plans the initiation of received production orders and defines production lots, producing a production order and a production lot." ;
    rdfs:comment "Operations category: the production lot is a material participant (obo:has participant) of the act, alongside the directive production order as has output. Material products attach via has participant, not has output (has output is reserved for ICEs per the methodology and S3)." ;
    skos:example "A scheduler sets order start dates and demarcates batch lot sizes." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionOrder ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductionLot ] .

ex:P10315 a owl:Class ;
    ex:pcfID "10315" ; ex:hierarchyID "4.3.1.5" ;
    ex:apqcSourceText "Scheduling planned maintenance of the production equipment." ;
    rdfs:label "Plan for preventive maintenance" ;
    skos:definition "An Act of Scheduling that allocates planned maintenance of production equipment to specific times and produces a maintenance schedule." ;
    skos:example "A maintenance planner books quarterly preventive servicing for each machine." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaintenanceSchedule ] .

ex:P10316 a owl:Class ;
    ex:pcfID "10316" ; ex:hierarchyID "4.3.1.6" ;
    ex:apqcSourceText "Scheduling requested maintenance in order to address breakdowns where repairs or corrective remedies are needed immediately. Create a scheme for undertaking unplanned maintenance work on equipment/machinery that has come to be in urgent need for it. Express turnaround to redress using specialized personnel." ;
    rdfs:label "Request unplanned maintenance" ;
    skos:definition "An Act of Scheduling that creates a scheme for urgent unplanned maintenance of broken-down equipment and produces a maintenance schedule." ;
    skos:example "A line supervisor raises an emergency maintenance order for a stalled machine." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaintenanceSchedule ] .

ex:P10309 a owl:Class ;
    ex:pcfID "10309" ; ex:hierarchyID "4.3.1.7" ;
    ex:apqcSourceText "Initiating the delivery of production orders, and creating lots. Communicate the order that specifies which material to produce, where to produce it, which operations to require, and on which date production takes place. Define how to settle the order costs. Create production lots, which is a particular production unit of an assembly that is planned and manufactured." ;
    rdfs:label "Release production orders and create lots" ;
    skos:definition "A Planned Act that issues an already-formulated production order to the floor and creates the corresponding production lot." ;
    rdfs:comment "Anchored under cco:ont00000228 (Planned Act), not ex:ActOfScheduling: releasing/communicating an existing order issues a held directive rather than formulating a new schedule. The production order is a held directive input; the production lot is a material participant (obo:has participant, since has output is reserved for ICEs)." ;
    skos:example "A controller releases the day's production orders and opens their lots." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductionOrder ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductionLot ] .

####################################################################
# 4.3.2 Produce/Assemble product  (PCF 10304) + children
####################################################################

ex:P10304 a owl:Class ;
    ex:pcfID "10304" ; ex:hierarchyID "4.3.2" ;
    ex:apqcSourceText "Manufacturing the product. Convert the raw materials to develop consumer-ready products. Manage the raw materials to implement the detailed production schedule. Reproduce defectives to establish and remediate cause. Ensure production optimization and benchmark performance." ;
    rdfs:label "Produce/Assemble product" ;
    skos:definition "An Act of Production that converts raw materials into consumer-ready finished products as prescribed by the detailed production schedule." ;
    rdfs:comment "Models APQC 4.3.2 as an occurrent; APQC children are process parts. The standing 'manage raw material inventory' child (4.3.2.1) is modeled as a capability (ex:RawMaterialInventoryManagementCapability), not a process part." ;
    skos:example "A line converts raw stock into finished units for the day's orders." ;
    rdfs:subClassOf ex:ActOfProduction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RawMaterial ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FinishedProduct ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10311 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10319 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10313 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19566 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10314 ] .

ex:P10311 a owl:Class ;
    ex:pcfID "10311" ; ex:hierarchyID "4.3.2.2" ;
    ex:apqcSourceText "Creating and implementing the detailed line production schedule on the ground level." ;
    rdfs:label "Execute detailed line schedule" ;
    skos:definition "An Act of Production that implements the detailed line production schedule on the floor, converting raw materials into finished product." ;
    rdfs:comment "The detailed production schedule is a held directive input prescribing the run; raw material is the material input (has input) and finished product is a material participant (obo:has participant, since has output is reserved for ICEs)." ;
    skos:example "Operators run the line per the released schedule, producing finished units." ;
    rdfs:subClassOf ex:ActOfProduction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductionSchedule ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RawMaterial ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FinishedProduct ] .

ex:P10319 a owl:Class ;
    ex:pcfID "10319" ; ex:hierarchyID "4.3.2.3" ;
    ex:apqcSourceText "Recording and reporting any deviations or issues in the maintenance schedule, in the performance to the production management team, and for unplanned maintenance." ;
    rdfs:label "Report maintenance issues" ;
    skos:definition "An Act of Monitoring that records deviations and issues in scheduled maintenance and produces a maintenance issue report for the production management team." ;
    skos:example "A technician logs an out-of-tolerance reading and reports it to production management." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaintenanceIssueReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ManagementPersonnel ] .

ex:P10313 a owl:Class ;
    ex:pcfID "10313" ; ex:hierarchyID "4.3.2.4" ;
    ex:apqcSourceText "Reproducing the items produced defectively. Assess the produced items by conducting quality and standardization tests in order to diagnose any discrepancies. Reproduce defective items." ;
    rdfs:label "Rerun defective items" ;
    skos:definition "An Act of Production that reproduces items found defective, taking the defective production lot as input and producing conforming finished product." ;
    rdfs:comment "A quality test result is a typical input that triggers the rerun; asserted as has input where definitional." ;
    skos:example "A line re-manufactures a batch that failed inspection." ;
    rdfs:subClassOf ex:ActOfProduction ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductionLot ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityTestResult ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FinishedProduct ] .

ex:P19566 a owl:Class ;
    ex:pcfID "19566" ; ex:hierarchyID "4.3.2.5" ;
    ex:apqcSourceText "Integrating different resources in the production process: material, personnel, equipment, robotics, etc. Includes automating and controlling the plant, performing advanced process control and real-time optimization. This activity also includes managing plant alarms and alerts." ;
    rdfs:label "Monitor and optimize production process" ;
    skos:definition "An Act of Monitoring that integrates production resources and oversees the running production process, producing a production state report on its current state and deviations." ;
    rdfs:comment "Models APQC 4.3.2.5 as an occurrent; its four APQC tasks are process parts (the control tasks P19567/19568/19569 are Acts of Process Control; P19570 is monitoring). Gate-F sibling/output fix: dropped [has output some ex:ProductionPerformanceAssessment] -- that ICE is the appraisal output of the sibling Assess production performance [10314] (an Act of Appraisal), and attaching the same descriptive ICE to two divergent genera (Monitoring here vs Appraisal there) was inconsistent. The performance assessment is not the definitional product of this monitoring/control aggregate; its monitoring-specific descriptive output is now ex:ProductionStateReport (a production state/deviation report), so the two siblings no longer share an output across divergent genera." ;
    skos:example "A control room runs APC and RTO loops and handles alarms during a production shift." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionStateReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19567 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19568 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19569 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19570 ] .

ex:P19567 a owl:Class ;
    ex:pcfID "19567" ; ex:hierarchyID "4.3.2.5.1" ;
    ex:apqcSourceText "Creating and applying technology to monitor and control the production and delivery of products and services. Automation involves a broad range of technologies." ;
    rdfs:label "Automate and control plant" ;
    skos:definition "An Act of Process Control that applies automation technology to monitor and control plant production and delivery by regulating the controlled production equipment." ;
    rdfs:comment "Gate-F false-friend fix: re-anchored from ex:ActOfMonitoring to ex:ActOfProcessControl. The source ('Creating and applying technology to monitor and CONTROL the production and delivery of products') and the obo:has participant some ex:ProductionEquipment restriction make this a closed-loop CONTROL act that actuates the plant (changes setpoints), not a pure observe-and-report act. Rejected ex:ActOfMonitoring: it captures only the observe half and over-commits the act to a descriptive output; control also actuates. No descriptive-ICE output is asserted (the product is a change in the controlled equipment). R5 holds (bounded)." ;
    skos:example "A SCADA system regulates valve and conveyor setpoints automatically." ;
    rdfs:subClassOf ex:ActOfProcessControl ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductionEquipment ] .

ex:P19568 a owl:Class ;
    ex:pcfID "19568" ; ex:hierarchyID "4.3.2.5.2" ;
    ex:apqcSourceText "Including a broad range of techniques and technologies implemented within industrial process control systems that are routinely reviewed, audited, and improved, advanced process controls typically address particular performance or economic improvement opportunities. An advanced set of process control measures can be used to reduce variation and identify primary improvement options. Results of analysis are fed back into process design for incorporation into production." ;
    rdfs:label "Perform advanced process control" ;
    skos:definition "An Act of Process Control that applies advanced process-control techniques to reduce process variation and identify improvement options for incorporation into production." ;
    rdfs:comment "Gate-F sibling-consistency fix: re-anchored from ex:ActOfMonitoring to ex:ActOfProcessControl, matching its parallel siblings P19567 (automate/control plant) and P19569 (real-time optimization). APC is a control technique that adjusts the running process to reduce variation, i.e. it actuates rather than merely observing." ;
    skos:example "An APC layer trims a distillation column to reduce energy variation." ;
    rdfs:subClassOf ex:ActOfProcessControl .

ex:P19569 a owl:Class ;
    ex:pcfID "19569" ; ex:hierarchyID "4.3.2.5.3" ;
    ex:apqcSourceText "Helping organizations increase performance and efficiency, real-time optimization is a category of closed-loop process control that aims at optimizing process performance in real time for systems. It is normally built upon model-based optimization systems and is usually large scale. Real-time optimization automatically detects errors, and can modify and eliminate both random and non-random errors, as well as analyze and monitor all systems involved." ;
    rdfs:label "Perform real-time optimization" ;
    skos:definition "An Act of Process Control that runs closed-loop, model-based real-time optimization of process performance, detecting and eliminating errors and modifying the running process across the controlled systems." ;
    rdfs:comment "Gate-F false-friend fix (same class as P19567): re-anchored from ex:ActOfMonitoring to ex:ActOfProcessControl. The source describes 'a category of closed-loop process control that aims at OPTIMIZING process performance in real time... automatically detects errors, and can MODIFY AND ELIMINATE both random and non-random errors' -- an optimizing/control act that ALTERS the running process, not an observe-and-report act. The definition's 'analyze and monitor all systems' is secondary to the optimizing function. Rejected ex:ActOfMonitoring: it observes; RTO actuates. P19567/19568/19569 are treated as a parallel control triple." ;
    skos:example "An RTO solver continuously re-optimizes reactor conditions against a plant model." ;
    rdfs:subClassOf ex:ActOfProcessControl .

ex:P19570 a owl:Class ;
    ex:pcfID "19570" ; ex:hierarchyID "4.3.2.5.4" ;
    ex:apqcSourceText "Applying human factors and instrumentation engineering and systems thinking to manage the design of an alarm or alert system to increase its usability. Typical challenges include having too many alarms in a plant, poorly designed alarms/alerts, improperly set alarm/alert points, unclear alarm/alert messages, etc. Poor alarm management is one of the leading causes of unplanned downtime." ;
    rdfs:label "Manage plant alarms and alerts" ;
    skos:definition "An Act of Monitoring that handles and tunes plant alarms and alerts to surface abnormal process conditions reliably." ;
    rdfs:comment "Modeled as a bounded monitoring task (handling/configuring alarms during operation), not an organization-wide standing function." ;
    skos:example "An operator rationalizes nuisance alarms and resets alert thresholds for a unit." ;
    rdfs:subClassOf ex:ActOfMonitoring .

ex:P10314 a owl:Class ;
    ex:pcfID "10314" ; ex:hierarchyID "4.3.2.6" ;
    ex:apqcSourceText "Analyzing and benchmarking the production process to judge its effectiveness and efficiency. Create production metrics to numerically calculate the performance of the production process." ;
    rdfs:label "Assess production performance" ;
    skos:definition "An Act of Appraisal that benchmarks and judges the effectiveness and efficiency of the production process and produces a production performance assessment." ;
    rdfs:comment "Anchored under cco:ont00000636 (Act of Appraisal): it evaluates and judges, yielding a Descriptive ICE." ;
    skos:example "An operations analyst benchmarks line OEE and issues a performance assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionPerformanceAssessment ] .

####################################################################
# 4.3.3 Perform quality testing  (PCF 10369) + children
####################################################################

ex:P10369 a owl:Class ;
    ex:pcfID "10369" ; ex:hierarchyID "4.3.3" ;
    ex:apqcSourceText "Executing tests to evaluate the quality of the products manufactured. Calibrate the test equipment. Conduct the actual tests. Record the results and outcomes of the quality test conducted." ;
    rdfs:label "Perform quality testing" ;
    skos:definition "An Act of Measuring that evaluates the quality of manufactured products against a quality standard and produces a quality test result." ;
    rdfs:comment "Anchored under cco:ont00000345 (Act of Measuring): testing determines product quality relative to a standard. APQC children are process parts." ;
    skos:example "A QA lab calibrates gauges, runs tests on sampled units, and records results." ;
    rdfs:subClassOf cco:ont00000345 ,   # Act of Measuring
        cco:ont00000228 ,               # Planned Act (explicit; entailed via ont00000345, asserted so S2 resolves standalone)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestResult ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10318 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10374 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20956 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10375 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12045 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12046 ] .

ex:P10318 a owl:Class ;
    ex:pcfID "10318" ; ex:hierarchyID "4.3.3.1" ;
    ex:apqcSourceText "Regulating the equipment used for performing quality tests. Assess correspondence between the quality testing equipment and the desired quality standards. Ensure the calibration standard is more accurate than the instrument being tested." ;
    rdfs:label "Calibrate test equipment" ;
    skos:definition "An Act of Maintenance that regulates quality-test equipment to a calibration standard so as to preserve its measurement accuracy." ;
    rdfs:comment "Anchored under cco:ont00000950 (Act of Maintenance): calibration modifies a material artifact to restore/preserve a designed quality (measurement accuracy). The test equipment is the participant; the quality standard is the directive against which it is regulated." ;
    skos:example "A metrologist calibrates a torque wrench against a reference standard before testing." ;
    rdfs:subClassOf cco:ont00000950 ,   # Act of Maintenance
        cco:ont00000228 ,               # Planned Act (explicit; entailed via ont00000950, asserted so S2 resolves standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductionEquipment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityStandard ] .

ex:P10374 a owl:Class ;
    ex:pcfID "10374" ; ex:hierarchyID "4.3.3.2" ;
    ex:apqcSourceText "Performing testing using calibrated equipment and in consent with the standard testing procedure, including testing time." ;
    rdfs:label "Perform testing using the standard testing procedure" ;
    skos:definition "An Act of Measuring that tests sampled product with calibrated equipment per the standard testing procedure and produces a quality test result." ;
    rdfs:comment "The quality testing procedure is a held directive input prescribing the test; the product sample is the material input tested." ;
    skos:example "A technician runs the prescribed tensile test on a sample and records the reading." ;
    rdfs:subClassOf cco:ont00000345 ,   # Act of Measuring
        cco:ont00000228 ,               # Planned Act (explicit; entailed via ont00000345, asserted so S2 resolves standalone)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityTestingProcedure ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductSample ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestResult ] .

ex:P20956 a owl:Class ;
    ex:pcfID "20956" ; ex:hierarchyID "4.3.3.3" ;
    ex:apqcSourceText "Selecting a set of elements from a product lot to draw conclusions or make inferences about the quality of the product lot from which the sample is drawn. Sampling is frequently used because gathering data on every product produced by a company is often impossible, impractical, or too costly to collect." ;
    rdfs:label "Manage quality samples" ;
    skos:definition "A Planned Act that draws a set of elements from a production lot to obtain a product sample representative of the lot's quality." ;
    rdfs:comment "Anchored under cco:ont00000228 (Planned Act): drawing physical samples takes a material lot as input and yields a material product sample, so it is not ex:ActOfSelection (whose output is a Directive ICE). The production lot is the material input (has input); the product sample is a material participant (obo:has participant, since has output is reserved for ICEs)." ;
    skos:example "An inspector pulls ten units from a batch for testing." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductionLot ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductSample ] .

ex:P10375 a owl:Class ;
    ex:pcfID "10375" ; ex:hierarchyID "4.3.3.4" ;
    ex:apqcSourceText "Documenting the results and outcomes of the quality tests. Track the performance of the production process. Record/Document it to evaluate the qualitative efficiency of the production process. Use electronic devices and software in order to ensure effectiveness in recording the results and outcomes of the test." ;
    rdfs:label "Record test results" ;
    skos:definition "An Act of Information Processing that documents the outcomes of quality tests into a quality test result record." ;
    rdfs:comment "Anchored under cco:ont00000366 (Act of Information Processing): recording manipulates and stores test outcomes as a Descriptive ICE." ;
    skos:example "A LIMS captures each gauge reading into the test record." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestResult ] .

ex:P12045 a owl:Class ;
    ex:pcfID "12045" ; ex:hierarchyID "4.3.3.5" ;
    ex:apqcSourceText "Managing and monitoring the occurrences of problems with a process or product. It is important that nonconformance occurrences are tracked in a standardized way so the data can easily be reviewed to assess the impact of the problem. Ongoing analysis of trends in nonconformance gives an organization the ability to make process changes to reduce the incidence and cost of nonconformances." ;
    rdfs:label "Track and analyze non-conformance trends" ;
    skos:definition "An Act of Analysis that examines tracked nonconformance occurrences over time and produces a nonconformance trend analysis." ;
    skos:example "A quality engineer charts defect rates by cause to find a rising trend." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityTestResult ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:NonconformanceTrendAnalysis ] .

ex:P12046 a owl:Class ;
    ex:pcfID "12046" ; ex:hierarchyID "4.3.3.6" ;
    ex:apqcSourceText "Using a technique that helps people answer the question of why a problem occurred in the first place. It seeks to identify the origin of a problem using a specific set of steps, with associated tools, to find the primary cause of the problem to determine what happened, why, and how to reduce the likelihood that it will happen again." ;
    rdfs:label "Perform root cause analysis" ;
    skos:definition "An Act of Analysis that traces a quality problem to its primary cause and produces a root cause analysis." ;
    rdfs:comment "A nonconformance trend analysis is a typical input that triggers root-cause work; asserted as has input where definitional." ;
    skos:example "A team runs a 5-Whys investigation and documents the root cause of a defect." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:NonconformanceTrendAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RootCauseAnalysis ] .

####################################################################
# 4.3.4 Maintain production records & lot traceability (PCF 10370) + children
####################################################################

ex:P10370 a owl:Class ;
    ex:pcfID "10370" ; ex:hierarchyID "4.3.4" ;
    ex:apqcSourceText "Perpetuating the production records by systematically documenting and using it to ensure the effective management of lots. Determine the lot numbering system and its use. (The lot number enables tracking of the constituent parts, as well as labor and equipment records involved in the manufacturing of a product. It enables manufacturers and to perform quality control checks, calculate expiration dates, and issue corrections of their production output.)" ;
    rdfs:label "Maintain production records and manage lot traceability" ;
    skos:definition "An Act of Information Processing that systematically documents production into production records and establishes lot identification enabling traceability." ;
    rdfs:comment "Anchored under cco:ont00000366 (Act of Information Processing): the modelable content is repeatable record-keeping producing a Descriptive ICE (production record). Its lot-definition children are process parts." ;
    skos:example "A plant logs each run into the batch record and assigns traceable lot numbers." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10376 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10377 ] .

ex:P10376 a owl:Class ;
    ex:pcfID "10376" ; ex:hierarchyID "4.3.4.1" ;
    ex:apqcSourceText "Allotting an identification number to a particular quantity or lot of material manufactured. Assign lot numbers on the basis of specific production units, material similarity, etc. Place lot numbers on the outside of packaging." ;
    rdfs:label "Determine lot numbering system" ;
    skos:definition "An Act of Formulation that composes a lot numbering system specification prescribing how identification numbers are assigned to production lots." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (Act of Planning): determining a numbering scheme yields a Directive ICE (the lot numbering system specification)." ;
    skos:example "Operations defines a YYMMDD-line-sequence lot-numbering convention." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LotNumberingSystemSpecification ] .

ex:P10377 a owl:Class ;
    ex:pcfID "10377" ; ex:hierarchyID "4.3.4.2" ;
    ex:apqcSourceText "Identifying the use of production lots. Define where, how, and when to use a specific production lot." ;
    rdfs:label "Determine lot use" ;
    skos:definition "An Act of Formulation that defines where, how, and when a production lot is to be used and produces a lot usage specification for the lot." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (Act of Planning): defining lot usage yields a Directive ICE, so the GOLDEN PRINCIPLE holds. Gate-F fix: replaced the wrongly-reused ex:DispositionDecision output with the dedicated ex:LotUsageSpecification. ex:DispositionDecision is defined for reverse logistics (it prescribes the salvage/repair/refurbish/restock disposition of a RETURNED PRODUCT and is about ex:ReturnedProduct); this act concerns forward production-lot allocation, so reusing it was a semantic mismatch that would mis-relate the act to ex:ReturnedProduct via the output's aboutness." ;
    skos:example "Planning earmarks a specific lot for a customer order and sets its consumption window." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LotUsageSpecification ] .

####################################################################
# ===== GROUP 4.4  Manage logistics and warehousing
# The standing group-level function (PCF 10219) is the Organization
# Capability ex:LogisticsManagementCapability (section F), realized in
# the four bounded sub-processes below. Reuses ex:ActOfFormulation,
# ex:ActOfSelection (inlined), ex:ActOfTransportation,
# ex:ActOfMonitoring (section genera), and CCO Acts directly:
# cco:ont00000636 (Appraisal), cco:ont00000950 (Maintenance),
# cco:ont00000366 (Info Processing), cco:ont00000228 (Planned Act).
####################################################################

####################################################################
# 4.4.1 Provide logistics governance
####################################################################

ex:P10338 a owl:Class ;
    ex:pcfID "10338" ; ex:hierarchyID "4.4.1" ;
    ex:apqcSourceText "Outlining the strategy for managing logistics. Translate customer requirements logistic requirements. Create an efficient logistic network and outsourcing portions of logistics activities. Design a logistics strategy that optimizes transportation costs and schedule. Define key performance indicators." ;
    rdfs:label "Provide logistics governance" ;
    skos:definition "An Act of Formulation that composes the directive specifications governing an organization's logistics function - its logistics requirements, network design, outsourcing policy, delivery service policy, logistics strategy, performance measures, and reverse-logistics strategy." ;
    rdfs:comment "Planning/Formulation -> DIRECTIVE outputs (GOLDEN PRINCIPLE). Its APQC children are process parts, not subclasses." ;
    skos:example "A logistics function's annual governance cycle producing an updated logistics strategy and KPI set." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10343 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10344 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10345 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10346 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10347 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10348 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16905 ] .

ex:P10343 a owl:Class ;
    ex:pcfID "10343" ; ex:hierarchyID "4.4.1.1" ;
    ex:apqcSourceText "Determining the requirements for managing the flow of things between the point of origin and the point of consumption by assessing the service requirements of the customers." ;
    rdfs:label "Translate customer service requirements into logistics requirements" ;
    skos:definition "An Act of Formulation that derives from customer service requirements and composes a logistics requirement specification for managing the flow of goods between origin and consumption." ;
    skos:example "A logistics planner converts a customer's service-level expectations into documented inbound/outbound logistics requirements." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LogisticsRequirementSpecification ] .

ex:P10344 a owl:Class ;
    ex:pcfID "10344" ; ex:hierarchyID "4.4.1.2" ;
    ex:apqcSourceText "Developing a network for logistical activities. Create a network of entities through which materials and information flow, encompassing all related activities associated with the flow of transformation of products." ;
    rdfs:label "Design logistics network" ;
    skos:definition "An Act of Formulation that composes a logistics network design specifying the entities through which materials and information flow." ;
    skos:example "A supply-chain team designs a hub-and-spoke distribution-center network for a product line." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LogisticsNetworkDesign ] .

ex:P10345 a owl:Class ;
    ex:pcfID "10345" ; ex:hierarchyID "4.4.1.3" ;
    ex:apqcSourceText "Conveying outsourcing needs within the organization, with the objective of sourcing the assistance required. Define the portion of logistical activities that can be transferred to outside suppliers. Assess third-party agencies to carefully select the most appropriate agencies for outsourcing. Convey these needs to management or the appropriate authority." ;
    rdfs:label "Communicate outsourcing needs" ;
    skos:definition "An Act of Communication in which an Agent determines which logistics activities to transfer to outside suppliers and conveys the resulting outsourcing needs statement to management or the appropriate authority." ;
    rdfs:comment "Gate-F false-friend fix: re-anchored from ex:ActOfFormulation (Act of Planning) to cco:ont00000402 (Act of Communication). The source's lead verb is 'Conveying / Convey these needs to management or the appropriate authority' with the objective 'sourcing the assistance required' -- fundamentally a communication act, not the authoring of a directive policy. Rejected ex:ActOfFormulation: classifying a communication act under Planning is a mis-anchor; the description does not say a policy is produced. The definitional output is the conveyed Descriptive ex:OutsourcingNeedsStatement; ex:OutsourcingPolicy is dropped as the definitional output (APQC does not track a policy artifact here). The assess-and-select-agencies facet is a non-definitional sub-step. cco:ont00000402 verified: 'A Planned Act in which some Information Content Entity is transferred from some Agent to Another.'" ;
    skos:example "A logistics manager conveys the warehousing scope to outsource to executives for action." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,               # Planned Act (explicit; entailed via ont00000402, asserted so S2 resolves standalone)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OutsourcingNeedsStatement ] .

ex:P10346 a owl:Class ;
    ex:pcfID "10346" ; ex:hierarchyID "4.4.1.4" ;
    ex:apqcSourceText "Establishing rules and regulations, as well as the terms and conditions regarding the delivery of service by the company. Develop a delivery plan that specifies what, how, when, and in which way to deliver services to the customer." ;
    rdfs:label "Develop and maintain delivery service policy" ;
    skos:definition "An Act of Formulation that composes a delivery service policy prescribing the terms and conditions for delivering services to customers." ;
    skos:example "A logistics team issues a delivery-service policy defining delivery windows, modes, and customer notification terms." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DeliveryServicePolicy ] .

ex:P10347 a owl:Class ;
    ex:pcfID "10347" ; ex:hierarchyID "4.4.1.5" ;
    ex:apqcSourceText "Optimizing the schedule and costs of transportation services. Design a logistics strategy by strategically creating delivery routes and systems, which optimizes the overall transportation schedules and costs. Evaluate different transportation sources in order to select the most appropriate and cost-effective sources." ;
    rdfs:label "Optimize transportation schedules and costs" ;
    skos:definition "An Act of Formulation that composes a logistics strategy of delivery routes and systems optimizing transportation schedules and costs and selecting cost-effective transportation sources." ;
    rdfs:comment "Evaluate-and-select-sources facet is folded into the strategy formulation; the definitional output is the directive logistics strategy." ;
    skos:example "A planner designs optimized delivery routes and selects carriers that minimize total transportation cost." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LogisticsStrategy ] .

ex:P10348 a owl:Class ;
    ex:pcfID "10348" ; ex:hierarchyID "4.4.1.6" ;
    ex:apqcSourceText "Establishing measures for evaluating the performance of the logistics strategy of the organization. Establish key performance indicators, including the logistics performance index, delivery in full, and delivery on time." ;
    rdfs:label "Define key performance measures" ;
    skos:definition "An Act of Formulation that composes a key performance indicator specification for evaluating the organization's logistics strategy." ;
    skos:example "A logistics team defines delivery-in-full and on-time KPIs and their measurement formulas." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KeyPerformanceIndicatorSpecification ] .

ex:P16905 a owl:Class ;
    ex:pcfID "16905" ; ex:hierarchyID "4.4.1.7" ;
    ex:apqcSourceText "Establish a strategy that includes rules and regulations for the physical handling, information processing, and disposition of product and packaging returned by the buyer to the seller or an intermediary. Include return approval, transportation coordination, advance communication, product tracking, receipt, disposition of the return, and processing warranty claims in the strategy." ;
    rdfs:label "Define reverse logistics strategy" ;
    skos:definition "An Act of Formulation that composes a reverse logistics strategy prescribing the handling, processing, and disposition of returned product and packaging." ;
    skos:example "A supply-chain team establishes a returns strategy covering approval, transport, tracking, disposition, and warranty handling." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ReverseLogisticsStrategy ] .

####################################################################
# 4.4.2 Plan and manage inbound material flow
####################################################################

ex:P20936 a owl:Class ;
    ex:pcfID "20936" ; ex:hierarchyID "4.4.2" ;
    ex:apqcSourceText "Creating and executing a strategy for all the internal activities related to the flow/transfer of inbound materials. This process includes planning inbound material receipts, managing inbound material flow, monitoring inbound delivery performance, managing the flow of returned products, controlling the quality of returned parts, and salvaging or repairing returned products." ;
    rdfs:label "Plan and manage inbound material flow" ;
    skos:definition "A Planned Act that plans and carries out the internal activities for the flow and transfer of inbound materials, including receipt planning, material handling, delivery monitoring, and returns disposition." ;
    rdfs:comment "Heterogeneous operational aggregate (planning + material handling + monitoring + returns) anchored at the generic cco:ont00000228 (Planned Act). Its APQC children are process parts. The standing oversight aspect is realized by ex:LogisticsManagementCapability." ;
    skos:example "An inbound-logistics team's per-shipment cycle from receipt plan through put-away and returns disposition." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10349 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10350 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10351 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10352 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20109 ] .

ex:P10349 a owl:Class ;
    ex:pcfID "10349" ; ex:hierarchyID "4.4.2.1" ;
    ex:apqcSourceText "Managing the receipts of inbound materials. Create a plan accounting for the materials procured from the source of supply and the materials delivered to the distribution center or the warehouse." ;
    rdfs:label "Plan inbound material receipts" ;
    skos:definition "An Act of Formulation that composes an inbound material receipt plan accounting for materials procured from supply and delivered to the distribution center or warehouse." ;
    skos:example "A receiving planner schedules expected inbound deliveries and dock assignments for the coming week." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InboundMaterialReceiptPlan ] .

ex:P10350 a owl:Class ;
    ex:pcfID "10350" ; ex:hierarchyID "4.4.2.2" ;
    ex:apqcSourceText "Managing all the internal activities related to the flow/transfer of materials. Manage materials being delivered to distribution center or warehouse. Gauge the time taken for delivery and if the delivery process is on time." ;
    rdfs:label "Manage inbound material flow" ;
    skos:definition "A Planned Act that coordinates all the internal activities related to the flow and transfer of inbound materials to the distribution center or warehouse, including handling the materials and gauging whether delivery is on time." ;
    rdfs:comment "Gate-F genus-too-narrow fix: re-anchored from ex:ActOfTransportation (Act of Location Change) to the generic cco:ont00000228 (Planned Act). The description is a coordination-plus-monitoring MANAGEMENT activity over all internal flow activities ('Managing all the internal activities related to the flow/transfer of materials'), not a single location change; reducing it to one Act of Location Change under-captured it. The monitoring facet -- 'Gauge the time taken for delivery and if the delivery process is on time' -- is now made explicit in the definition as a constituent monitoring task (it yields a descriptive delivery-timeliness judgement) rather than being silently dropped as a typical sub-step. R5: the standing 'Managing all... activities' oversight aspect is realized by ex:LogisticsManagementCapability; this class is the bounded per-cycle coordination act. Inbound inventory items participate via has participant (operations material I/O)." ;
    skos:example "A warehouse team routes arriving materials from the receiving dock to put-away locations and checks delivery timeliness." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:InventoryItem ] .

ex:P10351 a owl:Class ;
    ex:pcfID "10351" ; ex:hierarchyID "4.4.2.3" ;
    ex:apqcSourceText "Overseeing the performance of an inbound delivery system. Check the present delivery system's efficiency, cost effectiveness, and adherence to a delivery schedule." ;
    rdfs:label "Monitor inbound delivery performance" ;
    skos:definition "An Act of Monitoring that tracks the efficiency, cost-effectiveness, and schedule adherence of the inbound delivery system and produces a delivery performance report." ;
    skos:example "A logistics analyst reviews inbound on-time and cost metrics and issues a monthly delivery performance report." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DeliveryPerformanceReport ] .

ex:P10352 a owl:Class ;
    ex:pcfID "10352" ; ex:hierarchyID "4.4.2.4" ;
    ex:apqcSourceText "Tracking and taking care of the products that have been internally returned either because of their deficiency or in cases of incorrect delivery." ;
    rdfs:label "Manage flow of returned products" ;
    skos:definition "An Act of Transportation that moves and handles internally returned products through their reverse-logistics flow." ;
    rdfs:comment "Operations material I/O (section 4.0): returned products participate via has participant. Returns arising from deficiency or incorrect delivery." ;
    skos:example "A returns team routes deficient returned units from receiving to the disposition staging area." ;
    rdfs:subClassOf ex:ActOfTransportation ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ReturnedProduct ] .

ex:P20109 a owl:Class ;
    ex:pcfID "20109" ; ex:hierarchyID "4.4.2.5" ;
    ex:apqcSourceText "Determining if a returned product can be salvaged or repaired. Salvage or repair is dependent upon the product, the condition of the product, or the availability of a like item." ;
    rdfs:label "Manage disposition of returned products" ;
    skos:definition "An Act of Selection that chooses the disposition - salvage, repair, or restock - for a returned product and produces a disposition decision." ;
    rdfs:comment "Selection -> DIRECTIVE output (GOLDEN PRINCIPLE): the disposition decision prescribes the chosen handling. Its APQC tasks are process parts." ;
    skos:example "A disposition analyst decides a returned unit will be repaired rather than salvaged based on its condition." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DispositionDecision ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12708 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10366 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21604 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21605 ] .

ex:P12708 a owl:Class ;
    ex:pcfID "12708" ; ex:hierarchyID "4.4.2.5.1" ;
    ex:apqcSourceText "Implement a checks and balances system to verify that returned parts meet acceptable quality standards to determine appropriate disposition activity." ;
    rdfs:label "Determine quality of controlled part" ;
    skos:definition "An Act of Appraisal that has as input returned products and a quality standard and produces a returned-part quality assessment used to determine the appropriate disposition." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): it judges whether returned parts meet quality standards. Returned product is a material input (has participant); the quality standard is a directive input." ;
    skos:example "An inspector grades returned parts against the quality standard before disposition." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ReturnedProduct ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityStandard ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ReturnedPartQualityAssessment ] .

ex:P10366 a owl:Class ;
    ex:pcfID "10366" ; ex:hierarchyID "4.4.2.5.2" ;
    ex:apqcSourceText "Executing activities for reinstating the returned products. Present the customer with additional incentives of compensation in case of any defective products delivery or any discrepancy in the product specifications in order to save the order from being permanently returned." ;
    rdfs:label "Perform salvage activities" ;
    skos:definition "An Act of Communication in which an Agent presents a customer with additional incentives or compensation for a defective delivery or specification discrepancy, conveying a customer compensation offer in order to save the order from being permanently returned." ;
    rdfs:comment "Gate-F label/text-divergence fix (D2): re-anchored from cco:ont00000950 (Act of Maintenance) to cco:ont00000402 (Act of Communication). The genus had been read from the LABEL ('salvage') rather than the de-conflated Element Description, which is about CUSTOMER INCENTIVES: 'Present the customer with additional incentives of compensation in case of any defective products delivery or any discrepancy... in order to save the order from being permanently returned.' That is a commercial communication/retention act, not physical maintenance of a Material Artifact. Rejected cco:ont00000950: nothing in the description restores an artifact's designed qualities; 'save the order' is a transactional outcome (R5 strain). CURATOR NOTE: if APQC genuinely intends physical salvage reconditioning, the source text is mismatched to the label and must be reconciled before reinstating cco:ont00000950. The has-participant ex:ReturnedProduct (definitional only under physical handling) is removed accordingly; the definitional output is the conveyed ex:CustomerCompensationOffer." ;
    skos:example "A service rep offers a discrepant-order customer a discount and free reshipment to retain the sale." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,               # Planned Act (explicit; entailed via ont00000402, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerCompensationOffer ] .

ex:P21604 a owl:Class ;
    ex:pcfID "21604" ; ex:hierarchyID "4.4.2.5.3" ;
    ex:apqcSourceText "Administering the reinstatement of the returned product in order to return them back to customers. Repair or remanufacture the defective or ineffective products returned by the customer. Process the delivery of the repaired or remanufactured products back to the customer." ;
    rdfs:label "Manage repair/refurbishment" ;
    skos:definition "An Act of Maintenance in which defective or ineffective returned products are repaired or remanufactured to restore their designed qualities for return to customers." ;
    rdfs:comment "Anchored at cco:ont00000950 (Act of Maintenance): the returned Material Artifact is modified to restore its functions. Returned product participates via has participant; redelivery to the customer is a non-definitional downstream sub-step." ;
    skos:example "A refurbishment center remanufactures returned units and routes them back to customers." ;
    rdfs:subClassOf cco:ont00000950 ,   # Act of Maintenance
        cco:ont00000228 ,               # Planned Act (explicit; entailed via ont00000950, asserted so S2/S5 resolve standalone)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ReturnedProduct ] .

ex:P21605 a owl:Class ;
    ex:pcfID "21605" ; ex:hierarchyID "4.4.2.5.4" ;
    ex:apqcSourceText "Moving a returned product back to inventory or stock. Whether a product is sufficient as returned, repaired, or refurbished, moving that product back to inventory for resale or returning to customer is the fnal step in Manage disposition of returned products." ;
    rdfs:label "Return to finished goods inventory" ;
    skos:definition "An Act of Transportation that moves a returned, repaired, or refurbished product back into finished-goods inventory for resale." ;
    rdfs:comment "Operations material I/O (section 4.0): the inventory item participates via has participant. Final step of disposition." ;
    skos:example "A warehouse operator restocks a refurbished unit into sellable inventory." ;
    rdfs:subClassOf ex:ActOfTransportation ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:InventoryItem ] .

####################################################################
# 4.4.3 Operate warehousing
####################################################################

ex:P10340 a owl:Class ;
    ex:pcfID "10340" ; ex:hierarchyID "4.4.3" ;
    ex:apqcSourceText "Tracking the inventory deployment. Accept and store products. Ship the products. Measure the accuracy of the inventory. Assess the performance of the outsourced logistics activities." ;
    rdfs:label "Operate warehousing" ;
    skos:definition "A Planned Act that carries out warehousing operations - inventory tracking, receipt and storage, picking and shipping, and accuracy and performance measurement - for an organization's goods." ;
    rdfs:comment "Heterogeneous operational aggregate anchored at the generic cco:ont00000228 (Planned Act). Its APQC children are process parts. The standing operate-warehousing function is realized by ex:LogisticsManagementCapability." ;
    skos:example "A distribution center's daily warehousing cycle from inbound put-away through outbound pick-pack-ship." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10353 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10354 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10355 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10356 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10357 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10358 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10359 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20957 ] .

ex:P10353 a owl:Class ;
    ex:pcfID "10353" ; ex:hierarchyID "4.4.3.1" ;
    ex:apqcSourceText "Tracking the logistical act of delivering or releasing an inventory item or entity to targeted end users. Track how much inventory has been deployed at all the distribution centers, individually." ;
    rdfs:label "Manage and track inventory deployment" ;
    skos:definition "An Act of Monitoring that tracks how much inventory has been deployed and released to end users at each distribution center and produces an inventory record." ;
    skos:example "An inventory controller monitors per-DC deployment levels in the warehouse management system." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InventoryRecord ] .

ex:P10354 a owl:Class ;
    ex:pcfID "10354" ; ex:hierarchyID "4.4.3.2" ;
    ex:apqcSourceText "Coordinating the incoming inbound materials/products. Accept the delivery of these materials and the subsequent storage. Track them at the warehouse/distribution center." ;
    rdfs:label "Receive, inspect, and store inbound deliveries" ;
    skos:definition "An Act of Transportation that accepts inbound materials and moves them into storage within the warehouse or distribution center." ;
    rdfs:comment "Operations material I/O (section 4.0): inbound inventory items and the warehouse participate via has participant. Inspection is a non-definitional sub-step." ;
    skos:example "Dock staff receive a delivery, verify it, and put the goods away into warehouse storage." ;
    rdfs:subClassOf ex:ActOfTransportation ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:InventoryItem ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Warehouse ] .

ex:P10355 a owl:Class ;
    ex:pcfID "10355" ; ex:hierarchyID "4.4.3.3" ;
    ex:apqcSourceText "Keeping track of the availability of different materials/products at the warehouse and distribution centers." ;
    rdfs:label "Track product availability" ;
    skos:definition "An Act of Monitoring that tracks the availability of materials and products across warehouses and distribution centers and produces an inventory record." ;
    skos:example "A planner checks current on-hand availability of SKUs across all distribution centers." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InventoryRecord ] .

ex:P10356 a owl:Class ;
    ex:pcfID "10356" ; ex:hierarchyID "4.4.3.4" ;
    ex:apqcSourceText "Packing and shipping the product to deliver to the customer. Take care of the internal and external packaging of the products in order to ensure safe transportation of the products from the warehouse to delivery locations. Notify the ERP system and/or Accounts Receivable Dept." ;
    rdfs:label "Pick, pack, and ship product for delivery" ;
    skos:definition "An Act of Transportation that picks, packs, and moves finished product out of the warehouse for delivery to the customer." ;
    rdfs:comment "Operations material I/O (section 4.0): finished product participates via has participant. ERP/AR notification is a non-definitional sub-step." ;
    skos:example "A warehouse operator picks and packs an order and ships it from the dock to the customer." ;
    rdfs:subClassOf ex:ActOfTransportation ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FinishedProduct ] .

ex:P10357 a owl:Class ;
    ex:pcfID "10357" ; ex:hierarchyID "4.4.3.5" ;
    ex:apqcSourceText "Monitoring any discrepancies between electronic records that represent the inventory and the physical state of the inventory. Look for discrepancies such as phantom inventory, which includes products that an inventory accounting system considers to be available at the storage location but are not actually available." ;
    rdfs:label "Track inventory accuracy" ;
    skos:definition "An Act of Monitoring that tracks discrepancies between inventory records and the physical state of inventory and produces an inventory accuracy report." ;
    skos:example "A cycle-count team reconciles system records against physical counts and reports phantom inventory." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InventoryAccuracyReport ] .

ex:P10358 a owl:Class ;
    ex:pcfID "10358" ; ex:hierarchyID "4.4.3.6" ;
    ex:apqcSourceText "Keeping a track on the storage and shipping performance of third-party agencies. Monitor logistics storage and shipping performance for third-party agencies. Use measures such as a logistics scoreboard, activity-based costing, economic value analysis, and balanced scorecards." ;
    rdfs:label "Track third-party logistics storage and shipping performance" ;
    skos:definition "An Act of Monitoring that tracks the storage and shipping performance of third-party logistics agencies and produces a third-party logistics performance report." ;
    skos:example "A logistics manager scores a 3PL's storage and shipping metrics on a balanced scorecard." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ThirdPartyLogisticsPerformanceReport ] .

ex:P10359 a owl:Class ;
    ex:pcfID "10359" ; ex:hierarchyID "4.4.3.7" ;
    ex:apqcSourceText "Administering the movement of the finished products that are processed by the organization through its warehouses. Track goods through the use of systems such as barcodes in order to monitor the volumes available, quantity of out-flowing goods, remaining shelf life of the product, etc.--ultimately, to best manage the warehouse capacity." ;
    rdfs:label "Manage physical finished goods inventory" ;
    skos:definition "An Act of Monitoring that tracks finished goods through the warehouses -- volumes available, out-flowing quantities, and remaining shelf life -- to best manage warehouse capacity, producing an inventory record." ;
    rdfs:comment "Gate-F genus-mismatch + parallel-row fix: re-anchored from ex:ActOfTransportation to ex:ActOfMonitoring (Act of Information Processing). The defining content is administrative TRACKING/MONITORING to manage capacity ('Track goods through the use of systems such as barcodes in order to monitor the volumes available, quantity of out-flowing goods, remaining shelf life... to best manage the warehouse capacity'), not a location change. This aligns it with its sibling tracking acts 10353/10355/10357/10358, all correctly ex:ActOfMonitoring; anchoring it as Transportation was a parallel-row inconsistency. The has-participant ex:FinishedProduct/ex:Warehouse are demoted (the physical-movement administration is a non-definitional sub-step, not the genus); the definitional output is the Descriptive ex:InventoryRecord, agreeing with the monitoring genus (GOLDEN PRINCIPLE)." ;
    skos:example "A warehouse supervisor monitors barcode-tracked volumes and shelf life to manage capacity." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InventoryRecord ] .

ex:P20957 a owl:Class ;
    ex:pcfID "20957" ; ex:hierarchyID "4.4.3.8" ;
    ex:apqcSourceText "Shipping items from one warehouse to another in a multi-warehouse environment. A warehouse transfer is typically handled electronically in a system designed to replicate the physical processes involved with transferring items from one warehouse to another." ;
    rdfs:label "Manage warehouse transfers" ;
    skos:definition "An Act of Transportation that ships inventory items from one warehouse to another in a multi-warehouse environment." ;
    rdfs:comment "Operations material I/O (section 4.0): the transferred inventory items participate via has participant." ;
    skos:example "A planner triggers a stock transfer of items from a regional warehouse to a depleted one." ;
    rdfs:subClassOf ex:ActOfTransportation ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:InventoryItem ] .

####################################################################
# 4.4.4 Operate outbound transportation
####################################################################

ex:P10341 a owl:Class ;
    ex:pcfID "10341" ; ex:hierarchyID "4.4.4" ;
    ex:apqcSourceText "Creating a plan that specifies the schedule and system for transportation and delivery of the outbound products, as well as tracking the performance of the carrier delivery system. Conduct vehicle management and processing of all carrier-related documents." ;
    rdfs:label "Operate outbound transportation" ;
    skos:definition "A Planned Act that carries out outbound transportation operations - planning and executing transport and delivery of outbound products, tracking carrier performance, and auditing carrier documents." ;
    rdfs:comment "Heterogeneous operational aggregate anchored at the generic cco:ont00000228 (Planned Act). Its APQC children are process parts. Gate-F: 4.4.4.3 'Manage transportation fleet' [10362] is NOT a process part here -- it is a standing function demoted to ex:FleetManagementCapability (R5), which is in turn realized in this bounded outbound-transport cycle." ;
    skos:example "A transportation team's cycle from outbound dispatch planning through carrier-invoice audit." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10360 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10361 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10363 ] .

ex:P10360 a owl:Class ;
    ex:pcfID "10360" ; ex:hierarchyID "4.4.4.1" ;
    ex:apqcSourceText "Organizing the transportation and delivery of outbound products. Plan and organize the transportation, shipping, and delivery of the end products. Create a plan that specifies dispatch and delivery of the product to its destination, as well the transportation." ;
    rdfs:label "Plan, transport, and deliver outbound product" ;
    skos:definition "An Act of Transportation that moves and delivers outbound finished products to their destination." ;
    rdfs:comment "Gate-F genus/output-contradiction fix: removed the [has output some ex:OutboundTransportationPlan] restriction. A location-change act does not, by its genus, author a Directive plan as its definitional output (the GOLDEN PRINCIPLE entails that a directive output requires a planning genus); authoring the plan is a planning act, while this compound 'Plan, transport, AND deliver' row is dominantly the physical move. The OutboundTransportationPlan is now a non-definitional annotation: the dispatch/delivery plan is a typical method-step input prepared for the move, not a definitional product of the location change, leaving a clean Transportation genus. (Where the planning facet is tracked separately, model it as a sibling ex:ActOfScheduling producing ex:OutboundTransportationPlan.) Finished product participates via has participant (operations material I/O)." ;
    skos:example "A dispatcher plans routes and ships finished goods to their delivery destinations." ;
    rdfs:subClassOf ex:ActOfTransportation ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FinishedProduct ] .

ex:P10361 a owl:Class ;
    ex:pcfID "10361" ; ex:hierarchyID "4.4.4.2" ;
    ex:apqcSourceText "Monitoring delivery performance when carrying products from the warehouse/distribution centers to the retailers or end consumers. Create a performance metrics based on the key performance indicators." ;
    rdfs:label "Track carrier delivery performance" ;
    skos:definition "An Act of Monitoring that tracks carrier delivery performance from warehouses to retailers or consumers and produces a carrier performance report." ;
    skos:example "A logistics analyst tracks carrier on-time delivery against KPIs and issues a carrier performance report." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CarrierPerformanceReport ] .

# 4.4.4.3 'Manage transportation fleet' [10362] is NOT modeled as a process.
# Gate-F R5: it is a standing administrative function (no natural end), demoted
# to the Organization Capability ex:FleetManagementCapability (section F),
# realized in the bounded outbound-transport acts. ex:PCF_10362 designates that
# capability in the catalog->reality bridge below.

ex:P10363 a owl:Class ;
    ex:pcfID "10363" ; ex:hierarchyID "4.4.4.4" ;
    ex:apqcSourceText "Organizing and inspecting all account statements and any other documentation for the carriers used in delivery. Create, manage, and inspect all documents related to the financial, regulatory, and administrative accounts of all the carriers/freights. Generate receipts for all freight transactions." ;
    rdfs:label "Process and audit carrier invoices and documents" ;
    skos:definition "An Act of Information Processing that organizes and inspects carrier invoices and account documents and produces a carrier invoice audit result." ;
    rdfs:comment "Information-Processing -> DESCRIPTIVE output (GOLDEN PRINCIPLE). Carrier invoice is an informational input (Descriptive ICE); receipt generation is a non-definitional sub-step." ;
    skos:example "An accounts team reconciles carrier invoices against shipment records and flags billing discrepancies." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CarrierInvoice ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CarrierInvoiceAuditResult ] .

####################################################################
# 4. CATALOG -> REALITY BRIDGES (ADR-001 R4)
# Each catalog node ex:PCF_<id> (defined in apqc-catalog.ttl)
# designates the reality-layer process universal / capability here.
# PCF_10219 (group 4.4) designates the Organization Capability.
####################################################################

ex:PCF_10215 ex:designatesProcessType ex:P10215 .
