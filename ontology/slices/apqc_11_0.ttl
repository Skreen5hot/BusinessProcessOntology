ex:PCF_16442 ex:designatesProcessType ex:P16442 .
ex:PCF_16443 ex:designatesProcessType ex:P16443 .
ex:PCF_16444 ex:designatesProcessType ex:P16444 .
ex:PCF_16445 ex:designatesProcessType ex:P16445 .
ex:PCF_16446 ex:designatesProcessType ex:P16446 .
ex:PCF_16447 ex:designatesProcessType ex:P16447 .
ex:PCF_16448 ex:designatesProcessType ex:P16448 .
ex:PCF_16449 ex:designatesProcessType ex:P16449 .
