@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC reality-layer slice 6.0 "Manage Customer Service"
# BFO 2020 / CCO 2.0 module (ex:P<pcfID> process classes; partonomy
# via cco:ont00001777 has process part; no rdfs:subClassOf between
# processes). Composed from group modules 6.1, 6.2, 6.3, 6.4, 6.5 over
# ONE shared supporting vocabulary, with duplicate IRIs reconciled to a
# single coherent definition.
#
# by the validator; the live example.org import is commented out so it
# does not break ROBOT). Per ADR-001.
#
#   ex:ActOfAnalysis, ex:ActOfIdentification, ex:ActOfFormulation,
#   ex:ActOfSelection, ex:ActOfAcquisition.
# New recurring genera proposed for promotion are marked # PROPOSE-EXT
# and minted ONCE here:
#   ex:ActOfScheduling      (already proposed in 4.0; cco:ont00000511)
#   ex:ActOfMonitoring      (already proposed in 3.0/4.0/5.0; cco:ont00000366)
#   ex:ActOfResolution      (NEW this section; reconciled to cco:ont00000228)
#   ex:ActOfServiceProvision (already proposed in 5.0; cco:ont00000228)
#   ex:ActOfForecasting     (already proposed in 3.0; cco:ont00000371)
#
# RECONCILIATION NOTE (ex:ActOfResolution): the group inputs supplied
# two incompatible anchors -- cco:ont00000366 (Act of Information
# Processing, for the single leaf "resolve" acts 6.2.2.3 / 6.2.3.3) and
# cco:ont00000228 (Planned Act, for the end-to-end case-resolution
# processes 6.3.2 / 6.3.3 / 6.4.6). Reconciled to ONE definition under
# the generic cco:ont00000228 (Planned Act): a Planned Act that settles
# a raised case (inquiry, complaint, claim, recovery, or recall matter)
# to a definite disposition. Planned Act is neutral on output kind, so
# the leaf acts' Descriptive resolution records and the composite
# processes' dispositions both remain valid.
#
# Every cco:ont... IRI below was verified against
# CommonCoreOntologiesMerged (definition read, not just label):
#   Planned Act                 cco:ont00000228
#   Act of Information Proc.     cco:ont00000366
#   Act of Appraisal             cco:ont00000636
#   Act of Planning              cco:ont00000511
#   Act of Prediction            cco:ont00000371
#   Act of Communication         cco:ont00000402
#   Act of Representative Comm.  cco:ont00000379
#   Act of Promising             cco:ont00000821
#   Act of Contract Formation    cco:ont00000684
#   Act of Maintenance           cco:ont00000950
#   Descriptive ICE              cco:ont00000853
#   Directive (Prescriptive) ICE cco:ont00000965
#   Agent                        cco:ont00001017
#   Organization                 cco:ont00001180
#   Government Organization      cco:ont00000408
#   Agent Capability             cco:ont00001379
#   Organization Capability      cco:ont00000568
#   Material Artifact            cco:ont00000995
#   has capability               cco:ont00001954
#   is about                     cco:ont00001808
#   has input / has output       cco:ont00001921 / cco:ont00001986
#   has process part             cco:ont00001777
#   has agent                    cco:ont00001833
#   role / bearer of / realized in / has participant / precedes
#       obo:BFO_0000023 / 0000196 / 0000054 / 0000057 / 0000063
####################################################################

<http://example.org/apqc/slice/6.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 6.0: Manage Customer Service" ;
    owl:versionInfo "0.3.0" ;
    rdfs:comment "Reality-layer BFO 2020 / CCO 2.0 module for APQC section 6.0 'Manage Customer Service'. CCO pin v2.0 (2024-11-06); modeled per ADR-001 (two-layer model, R5 bounded-occurrent test, GOLDEN PRINCIPLE genus<->output agreement). Self-contained: the shared act genera it uses are inlined from the apqc-ext.ttl registry, so it validates standalone against the pinned CCO/BFO closure with no extension merge." .

####################################################################
# ACT GENERA -- SELF-CONTAINED (canonical defs mirrored from
# apqc-ext.ttl, the D9 shared registry). Inlined so this module
# validates standalone against CCO without merging the extension.
####################################################################

ex:ActOfAcquisition a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Acquisition" ;
    skos:definition "A Planned Act in which an Agent obtains from some authority or supplier an entity (such as an authorization, license, or resource) that the Agent did not previously hold." ;
    rdfs:comment "Local extension (D9). Rejected cco:ont00000950 'Act of Maintenance' (modifying Material Artifacts) and cco:ont00000402 'Act of Communication' (mere ICE transfer). Securing/obtaining a held entity anchors at the generic Planned Act. Expected to recur in procurement/asset-acquisition categories (4.0, 10.0)." .

ex:ActOfAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Analysis" ;
    skos:definition "An Act of Information Processing in which an Agent examines one or more input Information Content Entities and produces an Information Content Entity that represents an understanding of their subject matter." ;
    rdfs:comment "Local extension (D9). CCO 2.0 has no generic analysis class; analysis is information processing, so it is anchored under cco:ont00000366." .

ex:ActOfForecasting a owl:Class ;
    rdfs:subClassOf cco:ont00000371 ,   # Act of Prediction
        cco:ont00000228 ;               # Planned Act (explicit; Act of Prediction ⊑ Planned Act in CCO, asserted so the standalone SHACL S2 Act-anchor chain resolves)
    rdfs:label "Act of Forecasting" ;
    skos:definition "An Act of Prediction in which an Agent extrapolates from historical and current Information Content Entities to produce a Predictive Information Content Entity that estimates a future quantity such as demand, volume, revenue, or value." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000371 (Act of Prediction, verified: 'A Planned Act that involves the generation of a Predictive Information Content entity that is intended to describe an uncertain possible future event, value, entity, or attribute'; parent cco:ont00000228), whose definitional output is a Predictive ICE (cco:ont00000626 ⊑ cco:ont00000853 Descriptive ICE) -- exactly the genus of a sales/demand/volume/ROI forecast. A thin specialization (quantitative, history-driven business projection) kept shared so slice agents need not re-derive the anchor. Output is a PREDICTIVE ICE (a Descriptive ICE about an uncertain future), per the GOLDEN PRINCIPLE. Recurs in 3.0 and 6.0." .

ex:ActOfFormulation a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Formulation" ;
    skos:definition "An Act of Planning in which an Agent composes and articulates a Directive Information Content Entity - such as a mission, strategy, objective, design, roadmap, or business model - that prescribes an organization's intended course of action." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000511 (Act of Planning) because formulating a strategy/mission/design is making a plan to achieve an objective; its output is a Directive ICE. Recurs across develop/define/compose-a-directive processes corpus-wide." .

ex:ActOfIdentification a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Identification (discernment sense)" ;
    skos:definition "An Act of Information Processing in which an Agent discerns and enumerates entities of a given kind and produces an Information Content Entity that registers them." ;
    rdfs:comment "Local extension (D9). NOT cco:ont00001261 'Act of Identifying' (a communication act). APQC 'Identify ...' denotes discernment, i.e. information processing." .

ex:ActOfMonitoring a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Monitoring" ;
    skos:definition "An Act of Information Processing in which an Agent repeatedly or continuously observes the state, progress, or performance of some process, system, or quantity over time and produces a Descriptive Information Content Entity that represents its tracked status against expected conditions, targets, or requirements." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic monitoring/tracking class. Anchored under cco:ont00000366 (Act of Information Processing) because monitoring ingests repeated observations (including electronic records, not only senses) and yields a descriptive status/deviation ICE -- the GOLDEN PRINCIPLE (descriptive output => information-processing genus) holds. Rejected cco:ont00000037 (Act of Observation: a single sense-based acquisition, too narrow -- monitoring also processes ICEs and is sustained); cco:ont00000636 (Act of Appraisal: renders a single bounded value/quality judgement rather than tracking status over time); and cco:ont00000345 (Act of Measuring: a single quantification against a standard at one time -- at most a method sub-step of the monitoring cycle; a node that is purely one quantification, e.g. Calculate performance measures, anchors to cco:ont00000345 directly, not here). Distinct from ex:ActOfAnalysis (one-shot examination of a fixed input set) by its continuous, longitudinal character. A standing 'Manage/Monitor X' function with no natural end is an Organization Capability (cco:ont00000568) realized in such acts, not itself a process. Recurs corpus-wide (slices 3.0/4.0/5.0/6.0/8.0/9.0/10.0/11.0/12.0/13.0). Reconciled from 10 divergent slice restatements to one definition." .

ex:ActOfResolution a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Resolution" ;
    skos:definition "A Planned Act in which an Agent settles a raised case -- such as a customer inquiry, complaint, warranty claim, supplier-recovery matter, or product recall -- by determining and recording its disposition, comprising as needed the receipt, investigation, decision, and closure of the case." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic resolution/case-management class. A leaf resolve act settles one complaint and records a Descriptive resolution; an end-to-end case-resolution process composes information-processing/appraisal/planning/communication sub-acts and is individuated by carrying a case from open to closed. Both are Planned Acts that settle a matter, so the coherent genus is the generic cco:ont00000228 (Planned Act), neutral on output kind. Rejected cco:ont00000636 (Act of Appraisal: resolution settles a matter rather than merely judging value) and cco:ont00000402 (Act of Communication: the downstream notify/respond to the customer is a separate communication act). Recurs in service/support case management (6.0)." .

ex:ActOfScheduling a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Scheduling" ;
    skos:definition "An Act of Planning in which an Agent fixes the timing, sequencing, and resource allocation of future activities and produces a schedule (a Directive Information Content Entity) that prescribes when, in what order, and by whom those activities are to be performed." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000511 (Act of Planning, verified: 'A Planned Act that involves making a Plan to achieve some specified Objective'): a schedule is a plan whose differentia is the temporal/resource ordering of activities; its output is a Directive ICE, satisfying the GOLDEN PRINCIPLE. Distinct from ex:ActOfFormulation (mission/strategy/design) by its specifically temporal/resource-allocation product. Recurs across operations and project categories (4.0, 6.0, 8.0)." .

ex:ActOfSelection a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Selection" ;
    skos:definition "An Act of Information Processing in which an Agent chooses one or more options from a set of candidates and produces a Directive Information Content Entity that prescribes the chosen option(s)." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000366 (Act of Information Processing): receives candidate-option ICEs and yields a decision ICE. Distinct from Act of Appraisal (judges without committing) and Act of Planning. NOTE: ratifying a single already-settled option is NOT selection (no candidate set) -- anchor such acts at cco:ont00000228 (Planned Act)." .

ex:ActOfServiceProvision a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Service Provision" ;
    skos:definition "A Planned Act in which an Agent renders a service to a customer by carrying out and completing the tasks that fulfil an agreed service need." ;
    rdfs:comment "PROPOSE-EXT (D9). Operations-category signature genus for 'deliver/render/execute/deploy/operate a service' processes. Anchored at the generic cco:ont00000228 (Planned Act) because service provision need not produce or modify an artifact and need not transfer an ICE. Rejected cco:ont00000908 (Act of Material Artifact Processing: its product is a modified Material Artifact, whereas a service need not modify matter) and cco:ont00000402 (Act of Communication: mere ICE transfer). Recurs in operations/IT-service categories (4.0, 5.0, 6.0, 8.0, 9.0, 10.0)." .

####################################################################
# 0. PROVENANCE ANNOTATION PROPERTIES
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor process-class IRIs (ex:P<pcfID>) to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "Catalog->reality bridge: relates an APQC catalog node (ex:PCF_<pcfID>) to the reality-layer class (process or capability) it designates." .

####################################################################
# 1. NEW SHARED ACT GENERA  (PROPOSE-EXT: promote to apqc-ext.ttl
#    after review). Each minted ONCE here, reconciled across all five
#    group inputs. Reused genera (ex:ActOfAnalysis, ex:ActOfIdentification,
#    ex:ActOfFormulation, ex:ActOfSelection, ex:ActOfAcquisition) live in
#    apqc-ext.ttl and are NOT re-declared.
####################################################################

####################################################################
# 2. SHARED SUPPORTING VOCABULARY
#    Minted ONCE for the whole section so all five group modules
#    (6.1-6.5) reuse one consistent set with no collisions. Contains NO
#    process classes (ex:P<pcfID>). GOLDEN PRINCIPLE applied to ICE
#    outputs. Material I/O is legal here (operations category).
####################################################################

####################################################################
# 2.1 AGENTS / ORGANIZATIONS  (independent continuants; realizables go
#     here, D4)
####################################################################

ex:Customer a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:CustomerRole ] ;
    rdfs:label "Customer" ;
    skos:definition "An Agent that bears a customer role in relation to an organization from which it has obtained or seeks goods or services." ;
    rdfs:comment "Minted because CCO 2.0 has no Customer class. Genus cco:ont00001017 (Agent) so individuals and organizations alike may be customers; the customer-specific aspect is carried by ex:CustomerRole on an independent continuant (D4)." .

ex:CustomerServiceRepresentative a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:CustomerServiceRepresentativeRole ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001954 ; owl:someValuesFrom ex:CustomerServiceCapability ] ;
    rdfs:label "Customer Service Representative" ;
    skos:definition "An Agent that bears a customer-service-representative role and has a customer-service capability, by which it handles customer problems, requests, inquiries, and complaints on behalf of an organization." ;
    rdfs:comment "Minted (no CCO equivalent). The participant named across 6.2.1.4 and the receive/route/resolve/respond activities of 6.2." .

ex:WarrantyTeam a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:WarrantyAdministratorRole ] ;
    rdfs:label "Warranty Team" ;
    skos:definition "An Agent that bears a warranty-administrator role, by which it receives, validates, investigates, and dispositions warranty claims on behalf of an organization." ;
    rdfs:comment "Minted. Named as the actor in 6.3.2 (Process warranty claims) and its tasks. Genus Agent to admit both individual administrators and warranty teams." .

ex:FieldServiceAgent a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:FieldServiceAgentRole ] ;
    rdfs:label "Field Service Agent" ;
    skos:definition "An Agent that bears a field-service-agent role, by which it performs on-site investigation, repair, and evidence collection in support of warranty and service processes." ;
    rdfs:comment "Minted. Named in 6.3.2.3.2 (Schedule field service) and 6.3.4.3 (Provide service to specific customers)." .

ex:Supplier a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:SupplierRole ] ;
    rdfs:label "Supplier" ;
    skos:definition "An Agent that bears a supplier role in relation to an organization to which it furnishes goods, parts, or services and with which it shares warranty obligations." ;
    rdfs:comment "Minted (no CCO Supplier class). Counterparty in 6.1.6.3 (Agree on warranty responsibilities with suppliers) and 6.3.3 (Manage supplier recovery)." .

ex:RegulatoryBody a owl:Class ;
    rdfs:subClassOf cco:ont00000408 ;   # Government Organization
    rdfs:label "Regulatory Body" ;
    skos:definition "A Government Organization that is responsible for the oversight, regulation, or auditing of an industry and to which incidents, risks, and recall reports are submitted." ;
    rdfs:comment "Genus cco:ont00000408 (Government Organization) reused -- its definition (oversight/administration of governmental functions) fits the watchdog/regulatory agencies of 6.2.5 and 6.4. Distinguished by being a recipient of regulatory reports." .

ex:SalesTeam a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:SalesAgentRole ] ;
    rdfs:label "Sales Team" ;
    skos:definition "An Agent that bears a sales-agent role and to which qualified sales leads are delivered for follow-up." ;
    rdfs:comment "Minted. Recipient named in 6.2.2.6 (Deliver opportunity to sales team)." .

ex:ProductManagementTeam a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ProductManagerRole ] ;
    rdfs:label "Product Management Team" ;
    skos:definition "An Agent that bears a product-manager role and to which customer feedback and improvement insights are routed for use in improving offerings." ;
    rdfs:comment "Minted. Recipient named in 6.5.1.3, 6.5.3.5 (Provide feedback/insights to product management / appropriate teams)." .

ex:ManagementPersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ManagerRole ] ;
    rdfs:label "Management Personnel" ;
    skos:definition "An Agent that bears a manager role within an organization." ;
    rdfs:comment "Reuses the supporting pattern from apqc_1_1_1; engaged in 6.5.1.2 (discuss issues with management)." .

####################################################################
# 2.2 ROLES  (borne by Agents/Orgs only -- D4)
####################################################################

ex:CustomerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;   # role
    rdfs:label "Customer Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of having obtained or seeking to obtain goods or services from an organization." .

ex:CustomerServiceRepresentativeRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Customer Service Representative Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with handling customer problems, requests, inquiries, and complaints on behalf of an organization." .

ex:WarrantyAdministratorRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Warranty Administrator Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with receiving, validating, investigating, and dispositioning warranty claims on behalf of an organization." .

ex:FieldServiceAgentRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Field Service Agent Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with on-site investigation, repair, and evidence collection for service and warranty processes." .

ex:SupplierRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Supplier Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of furnishing goods, parts, or services to an organization and sharing warranty obligations with it." .

ex:SalesAgentRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Sales Agent Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with pursuing sales leads and selling an organization's offerings." .

ex:ProductManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Product Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with managing and improving an organization's products or services." .

ex:ManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of exercising managerial authority within an Organization." .

####################################################################
# 2.3 CAPABILITIES  (Agent / Organization Capability; realized-in acts, R6)
####################################################################

ex:CustomerServiceCapability a owl:Class ;
    rdfs:subClassOf cco:ont00001379 ;   # Agent Capability
    rdfs:label "Customer Service Capability" ;
    skos:definition "An Agent Capability that is realized in acts of handling customer problems, requests, inquiries, and complaints." ;
    rdfs:comment "Borne by ex:CustomerServiceRepresentative. Use ex:CustomerServiceManagementCapability (Organization Capability) for the org-level standing function." .

ex:CustomerServiceManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Customer Service Management Capability" ;
    skos:definition "An Organization Capability that is realized in the acts by which an organization plans, delivers, and evaluates customer service." ;
    rdfs:comment "Target for any R5 'Manage ...' node (e.g. the standing function 'Plan and manage customer service work force') that resolves to a capability rather than a process." .

ex:WarrantyManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Warranty Management Capability" ;
    skos:definition "An Organization Capability that is realized in the acts by which an organization defines, processes, and evaluates product warranties and warranty claims." ;
    rdfs:comment "Target for R5 'Manage warranty ...' standing functions (group 6.3 / 6.5.4)." .

ex:RecallManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20110 ] ;   # realized in
    rdfs:label "Recall Management Capability" ;
    skos:definition "An Organization Capability that is realized in the acts by which an organization initiates, communicates, reports on, and terminates product recalls." ;
    rdfs:comment "Target for R5 'Manage product recalls ...' standing functions (group 6.4). Realized in the end-to-end recall-execution process ex:P20110 (R6)." .

####################################################################
# 2.4 MATERIAL ENTITIES  (operations: bfo:material I/O is legal here, D4)
####################################################################

ex:DefectiveProduct a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ,   # Material Artifact
        obo:BFO_0000040 ;   # Material Entity (explicit: Material Artifact is a Material Entity in CCO; stated in-module so the standalone S4 input-kind check resolves)
    rdfs:label "Defective Product" ;
    skos:definition "A Material Artifact that fails to realize one or more of its designed functions or qualities and is therefore subject to repair, return, or recall." ;
    rdfs:comment "Material (not informational) entity. Subject of recalls (6.4) and returns (6.2.4)." .

ex:ReturnedProduct a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;   # Material Artifact
    rdfs:label "Returned Product" ;
    skos:definition "A Material Artifact that a customer has sent back to an organization for refund, replacement, or repair." ;
    rdfs:comment "Material input to 6.2.4 (Process returns); may be scrapped or salvaged per the source." .

ex:DefectivePart a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;   # Material Artifact
    rdfs:label "Defective Part" ;
    skos:definition "A Material Artifact component that has failed and is requested and received for investigation or root-cause analysis of a warranty claim." ;
    rdfs:comment "Material input to 6.3.2.3.3 (Request and receive defective part)." .

####################################################################
# 3. INFORMATION CONTENT ENTITIES  (inputs + outputs)
#    Descriptive ICE (cco:ont00000853) for representations/judgements/
#    records/forecasts; Directive ICE (cco:ont00000965) for plans/specs/
#    procedures/policies/decisions/authorizations. GOLDEN PRINCIPLE: the
#    producing act genus agrees with the descriptive-vs-directive kind.
#    'is about' (cco:ont00001808) added where the ICE has a definite subject.
####################################################################

####################################################################
# 3.1 INPUT ICEs
####################################################################

ex:CustomerInquiry a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Inquiry" ;
    skos:definition "A Descriptive Information Content Entity in which a customer requests information about, or assistance with, an organization's products or services." ;
    rdfs:comment "Covers the requests/inquiries/problems received in 6.2.2. Received over email, phone, online forms, social media, etc." .

ex:CustomerComplaint a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Complaint" ;
    skos:definition "A Descriptive Information Content Entity in which a customer expresses an objection, grievance, or criticism regarding an organization's products or services." ;
    rdfs:comment "Input to 6.2.3 (Manage customer complaints)." .

ex:CustomerFeedback a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Feedback" ;
    skos:definition "A Descriptive Information Content Entity that records a customer's review or evaluation of services delivered, products, advertisements, or service experience." ;
    rdfs:comment "Input to the satisfaction-measurement processes of 6.5 and to 6.3.4.4 (Ensure quality of service)." .

ex:WarrantyClaim a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Warranty Claim" ;
    skos:definition "A Descriptive Information Content Entity submitted by an originator that asserts a product fault and requests remedy under the terms of a warranty." ;
    rdfs:comment "Central informational object processed throughout 6.3.2. Modeled as Descriptive (it asserts a state of affairs / fault), not Directive." .

ex:ServiceRequest a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Service Request" ;
    skos:definition "A Descriptive Information Content Entity that records an individual customer's specific service requirements." ;
    rdfs:comment "Input to 6.3.4.1 (Confirm specific service requirements for individual customer)." .

ex:ReturnRequest a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Return Request" ;
    skos:definition "A Descriptive Information Content Entity that records a customer's request to return a product for refund, replacement, or repair." ;
    rdfs:comment "Minted per Gate-F as the dedicated input to P10364 (6.2.4.1 'Authorize return'). Distinct from ex:ServiceRequest (an individual customer's service requirements, minted for 6.3.4.1): the verbatim source for 10364 is a product-RETURN request, a different informational object. Reusing ex:ServiceRequest there conflated two unrelated ICEs." .

ex:HistoricalContactData a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Historical Contact Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the past volume, frequency, and servicing capacity of customer service contacts." ;
    rdfs:comment "Input to 6.2.1.1 (Forecast volume of customer service contacts)." .

ex:WarrantyPolicy a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:DefectiveProduct ] ;
    rdfs:label "Warranty Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the terms and conditions under which an organization will guarantee, repair, or replace its goods or services." ;
    rdfs:comment "Directive (prescribes obligations). Output of 6.1.6.1 (Determine and document warranty policies); reused as input wherever claims are validated against warranty parameters (6.3.2.2)." .

ex:WarrantyClaimCode a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Warranty Claim Code" ;
    skos:definition "A Directive Information Content Entity that prescribes the rules for processing and routing warranty claims, including coverage lists, fault and trouble codes, and repair-time setups." ;
    rdfs:comment "Output of 6.1.6.2; reused as input to claim definition/validation (6.3.2)." .

####################################################################
# 3.2 DIRECTIVE OUTPUT ICEs  (plans, specs, procedures, policies,
#     decisions, authorizations)
####################################################################

ex:CustomerServiceStrategy a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Customer Service Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's plan for removing customer obstacles and delivering customer service." ;
    rdfs:comment "Output of 6.1 (Develop customer service strategy). Directive -> producing act is a Formulation (apqc-ext)." .

ex:CustomerServiceRequirementSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Customer Service Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the behaviors, skills, and policies required to provide customer service across an enterprise." ;
    rdfs:comment "Output of 6.1.1 (Define customer service requirements across the enterprise). Enterprise-wide scope. Per Gate-F it is NO LONGER the output of the individual-customer act 6.3.4.1 (which now produces the individual-scope ex:IndividualServiceRequirement); it is retained as a constraining Directive input to 6.3.4.1 and 6.3.4.1.3." .

ex:CustomerServiceExperienceSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Customer Service Experience Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes what is expected of customer service resources when engaging the customer." ;
    rdfs:comment "Output of 6.1.2 (Define customer service experience)." .

ex:CustomerServiceChannelStrategy a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Customer Service Channel Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes the procedures and channels for customer service and technical support." ;
    rdfs:comment "Output of 6.1.3 (Define and manage customer service channel strategy)." .

ex:CustomerServicePolicy a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Customer Service Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the rules, regulations, and methods that guide an organization's customer service strategy." ;
    rdfs:comment "Output of 6.1.4 (Define customer service policies and procedures)." .

ex:ServiceLevelAgreement a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Service Level Agreement" ;
    skos:definition "A Directive Information Content Entity that prescribes the negotiated service levels, priorities, and responsibilities agreed for a customer segment." ;
    rdfs:comment "Output of 6.1.5 (Establish target service level for each customer segment)." .

ex:RecallStrategy a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Recall Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes the procedures for handling recalls of defective products." ;
    rdfs:comment "Sole output of 6.1.7 (Develop recall strategy). Per Gate-F it is NOT re-produced by 6.4.1 (Initiate recall), which CONSUMES it as input to launch the operational removal; two process classes must not both assert has output some ex:RecallStrategy." .

ex:WarrantyClaimDefinition a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Warranty Claim Definition" ;
    skos:definition "A Directive Information Content Entity that prescribes the exact terms and conditions under which specific warranties apply to certain goods or services." ;
    rdfs:comment "Minted: verbatim output of PCF 20089 'Define warranty claims'. Directive because it sets governing terms/conditions. Distinct from ex:WarrantyClaim (an input claim) and ex:WarrantyPolicy (customer-facing assurance)." ;
    skos:example "A warranty-terms schedule listing covered defects, time windows, and product lines." .

ex:SupplierWarrantyResponsibilityAgreement a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Supplier Warranty Responsibility Agreement" ;
    skos:definition "A Directive Information Content Entity that prescribes the warranty obligations apportioned between an organization and its suppliers or dealers." ;
    rdfs:comment "Minted: negotiated output of PCF 20090. Directive because it prescribes each party's obligations; the ICE generated by the contract-formation act." ;
    skos:example "A signed supplier addendum specifying which warranty repairs the manufacturer reimburses." .

ex:WarrantyOffering a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Warranty Offering" ;
    skos:definition "A Directive Information Content Entity that specifies the warranties offered to customers for promoted products or services." ;
    rdfs:comment "Minted: the warranty offering communicated to customers in PCF 20091. Directive because it specifies warranty terms extended to customers. Per Gate-F, P20091 is an Act of Communication that conveys this offering (has input), not an act that composes it (has output)." ;
    skos:example "A product page listing a 2-year limited warranty bundled with a promoted appliance." .

ex:WorkforceSchedule a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Workforce Schedule" ;
    skos:definition "A Directive Information Content Entity that prescribes the deployment of the customer service work force across operations and time." ;
    rdfs:comment "Output of 6.2.1.2 (Schedule customer service work force) and 6.3.2.3.2 (Schedule field service). Directive -> producing act is Scheduling (proposed genus)." .

ex:ResourcingPlan a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Resourcing Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the sourcing and deployment of the resources required to fulfill customer service requirements." ;
    rdfs:comment "Output of 6.3.4.2.1 (Create resourcing plan and schedule)." .

ex:ServiceOrderFulfillmentSchedule a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Service Order Fulfillment Schedule" ;
    skos:definition "A Directive Information Content Entity that prescribes the timing and duration of the services required to fulfill service orders." ;
    rdfs:comment "Output of 6.3.4.2.2 and the daily schedule of 6.3.4.3.1." .

ex:ServiceOrder a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Service Order" ;
    skos:definition "A Directive Information Content Entity that prescribes a short-term agreement between a service provider and a customer for a one-time service and its resource-related billing." ;
    rdfs:comment "Output of 6.3.4.1.3 (Generate service order). Directive -> producing act is Formulation." .

ex:CorrectiveActionRecommendation a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Corrective Action Recommendation" ;
    skos:definition "A Directive Information Content Entity that prescribes the corrective action to take in response to a diagnosed warranty issue." ;
    rdfs:comment "Output of 6.3.2.3.4 (Investigate issue / root cause analysis), consumed by claim disposition (6.3.2.5-6) and supplier recovery (6.3.3.1)." .

ex:ClaimDisposition a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:WarrantyClaim ] ;
    rdfs:label "Claim Disposition" ;
    skos:definition "A Directive Information Content Entity that prescribes the approval or rejection of a warranty claim." ;
    rdfs:comment "Directive (a decision -> prescribes). Output of 6.3.2.6 (Approve or reject warranty claim); reused by notify (6.3.2.7) and authorize payment (6.3.2.8)." .

ex:ReturnAuthorization a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ReturnedProduct ] ;
    rdfs:label "Return Authorization" ;
    skos:definition "A Directive Information Content Entity that prescribes approval for a customer to return a product for refund, replacement, or repair." ;
    rdfs:comment "Output of 6.2.4.1 (Authorize return); reused in 6.3.3.2." .

ex:PaymentAuthorization a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Payment Authorization" ;
    skos:definition "A Directive Information Content Entity that prescribes that a payment be made to a claimant." ;
    rdfs:comment "Output of 6.3.2.8 (Authorize payment)." .

ex:ClaimPreAuthorization a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Claim Pre-Authorization" ;
    skos:definition "A Directive Information Content Entity that grants preliminary authorization of a warranty claim prior to its formal submittal." ;
    rdfs:comment "Output of 6.3.2.5. Directive: permits/prescribes that the claim may proceed; distinct from ex:PaymentAuthorization (authorizes disbursement) and ex:ClaimDisposition (final decision)." .

####################################################################
# 3.3 DESCRIPTIVE OUTPUT ICEs  (forecasts, analyses, assessments,
#     reports, records, registers)
####################################################################

ex:SupplierRecoveryClaim a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Supplier Recovery Claim" ;
    skos:definition "A Descriptive Information Content Entity that asserts an organization's right to recover from a supplier the costs of a settled warranty claim." ;
    rdfs:comment "Output of 6.3.3.1 (Create supplier recovery claims). Descriptive: it asserts a cost-recovery basis rather than prescribing action." .

ex:IndividualServiceRequirement a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Individual Service Requirement" ;
    skos:definition "A Descriptive Information Content Entity that records the validated, individual-customer-specific service requirements confirmed for one customer." ;
    rdfs:comment "Minted per Gate-F as the individual-scope output of P10320 (6.3.4.1 'Confirm specific service requirements for individual customer'). Descriptive because the confirming act validates and records a customer's stated requirements (an appraisal/information-processing judgement), not an enterprise directive. Distinct from the enterprise-wide ex:CustomerServiceRequirementSpecification (Directive, output of 6.1.1), which prescribes behaviors/skills/policies across the enterprise -- reusing that as the output of an individual-customer confirmation act was a category error." .

ex:CustomerProfile a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Customer Profile" ;
    skos:definition "A Descriptive Information Content Entity that describes an individual customer's service requirements and personal information." ;
    rdfs:comment "Output of 6.3.4.1.2 (Create customer profile); about a Customer." .

ex:ContactVolumeForecast a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Contact Volume Forecast" ;
    skos:definition "A Descriptive Information Content Entity that describes the projected volume of customer service contacts and the work force required to service them." ;
    rdfs:comment "Output of 6.2.1.1. Descriptive/predictive: it represents a projection, not a prescription." .

ex:WorkforceUtilizationReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Workforce Utilization Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the utilization, performance, and quality of the deployed customer service work force." ;
    rdfs:comment "Output of 6.2.1.3 (Track work force utilization)." .

ex:InteractionQualityAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Interaction Quality Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the quality of interactions between customers and customer service representatives." ;
    rdfs:comment "Output of 6.2.1.4." .

ex:InquiryAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:CustomerInquiry ] ;
    rdfs:label "Inquiry Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the content and appropriate handling of customer problems, requests, and inquiries." ;
    rdfs:comment "Output of 6.2.2.2 (Analyze problems, requests, and inquiries) and 6.3.4.1.1." .

ex:InquiryResolution a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:CustomerInquiry ] ;
    rdfs:label "Inquiry Resolution" ;
    skos:definition "A Descriptive Information Content Entity that records the resolution determined for a customer problem, request, or inquiry." ;
    rdfs:comment "Retained for the genuine resolution artifact. Per Gate-F, it is NO LONGER the output of P10395 (6.2.2.3), which the source describes as a routing/channeling (Act of Communication) act that produces no resolution record; any genuine end-to-end inquiry resolution would be a separate downstream act." .

ex:InquiryResponse a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:CustomerInquiry ] ;
    rdfs:label "Inquiry Response" ;
    skos:definition "A Descriptive Information Content Entity communicated to a customer that conveys the answer to their problem, request, or inquiry." ;
    rdfs:comment "Output of 6.2.2.4 (Respond to customer problems, requests, and inquiries) -> producing act is an Act of Representative Communication." .

ex:SalesLead a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Sales Lead" ;
    skos:definition "A Descriptive Information Content Entity that describes an upsell or cross-sell opportunity identified during a customer interaction." ;
    rdfs:comment "Output of 6.2.2.5 (Identify and capture upsell/cross-sell opportunities); delivered to the sales team in 6.2.2.6." .

ex:ComplaintResolution a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:CustomerComplaint ] ;
    rdfs:label "Complaint Resolution" ;
    skos:definition "A Descriptive Information Content Entity that records the redress determined for a sound and reasonable customer complaint." ;
    rdfs:comment "Output of 6.2.3.3 (Resolve customer complaints)." .

ex:ComplaintResponse a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:CustomerComplaint ] ;
    rdfs:label "Complaint Response" ;
    skos:definition "A Descriptive Information Content Entity communicated to a customer that conveys an organization's reply to their complaint." ;
    rdfs:comment "Output of 6.2.3.4 (Respond to customer complaints)." .

ex:ComplaintAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:CustomerComplaint ] ;
    rdfs:label "Complaint Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes patterns and insights drawn from complaint logs for service improvement and customer profiling." ;
    rdfs:comment "Output of 6.2.3.5 and the complaint-data analysis of 6.5.2." .

ex:ReturnReasonRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ReturnedProduct ] ;
    rdfs:label "Return Reason Record" ;
    skos:definition "A Descriptive Information Content Entity that records the reason for the return of a product." ;
    rdfs:comment "Output of 6.2.4.2 (Process return and record reason)." .

ex:RegulatoryIncidentReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Regulatory Incident Report" ;
    skos:definition "A Descriptive Information Content Entity that conveys to stakeholders and regulatory bodies an account of incidents and risks related to a return or recall." ;
    rdfs:comment "Output of 6.2.5 (Report incidents and risks to regulatory bodies) and the regulatory reports of 6.4.4 / 6.4.6." .

ex:ProductRegistration a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Product Registration" ;
    skos:definition "A Descriptive Information Content Entity that records the registration of a product, associating it with a customer for warranty and service purposes." ;
    rdfs:comment "Output of 6.3.1 (Register products)." .

ex:ClaimAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:WarrantyClaim ] ;
    rdfs:label "Claim Assessment" ;
    skos:definition "A Descriptive Information Content Entity that records the warranty team's assessment of the investigation results and corrective-action recommendation toward approving or denying a warranty claim." ;
    rdfs:comment "Minted per Gate-F as the definitional output of P20100 (6.3.2.3.5). An Act of Appraisal is definitionally judgement-producing, so omitting the output left a thin appraisal class (Gate D thin-class risk). Descriptive (a judgement), satisfying the GOLDEN PRINCIPLE. Distinct from ex:ClaimDisposition (the Directive approve/reject decision committed by the Selection act P12668): P20100 JUDGES the results, P12668 COMMITS the decision." .

ex:WarrantyClaimValidation a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Warranty Claim Validation" ;
    skos:definition "A Descriptive Information Content Entity that records the judgement of whether a warranty claim falls within the parameters of the applicable warranty." ;
    rdfs:comment "Minted: output of P12671 (validate warranty claim) and input to P12668 (approve/reject). Descriptive: it represents a finding rather than prescribing action. Distinct from ex:ClaimDisposition (the final approve/reject directive)." .

ex:WarrantyIssueDefinition a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:WarrantyClaim ] ;
    rdfs:label "Warranty Issue Definition" ;
    skos:definition "A Descriptive Information Content Entity that describes the issue underlying a warranty claim, established by reference to claim codes and collected evidence." ;
    rdfs:comment "Output of 6.3.2.3.1 (Define issue)." .

ex:RootCauseAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:DefectivePart ] ;
    rdfs:label "Root Cause Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the diagnosed root cause of a warranty issue or product fault." ;
    rdfs:comment "Output of 6.3.2.3.4 (Investigate issue / perform root cause analysis)." .

ex:ResponsiblePartyDetermination a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Responsible Party Determination" ;
    skos:definition "A Descriptive Information Content Entity that identifies the party responsible for settling a warranty claim." ;
    rdfs:comment "Output of 6.3.2.4 (Determine responsible party). Descriptive: it represents who is responsible, an information-processing judgement." .

ex:ClaimClosureRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Claim Closure Record" ;
    skos:definition "A Descriptive Information Content Entity that records the archival and closure of a warranty claim following a final approve or reject decision." ;
    rdfs:comment "Minted: output of P20105 (close claim). Descriptive closure artifact." .

ex:WarrantyTransactionReconciliation a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Warranty Transaction Reconciliation" ;
    skos:definition "A Descriptive Information Content Entity that records confirmation that a warranty transaction has been completed and is internally consistent." ;
    rdfs:comment "Minted: output of P12667 (reconcile warranty transaction). Descriptive judgement of completion." .

ex:ServiceQualityAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Service Quality Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the quality of service delivered to customers, including successes, failures, and incorporated feedback." ;
    rdfs:comment "Output of 6.3.4.4 (Ensure quality of service)." .

ex:ServiceOrderFulfillmentStatus a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Service Order Fulfillment Status" ;
    skos:definition "A Descriptive Information Content Entity that reports the current fulfillment progress of one or more service orders, including fully, partially, and unfulfilled orders." ;
    rdfs:comment "Minted: output of P10332 (monitoring); input to P10334/P10335. Descriptive state report." .

ex:CompletedServiceOrderRegister a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Completed Service Order Register" ;
    skos:definition "A Descriptive Information Content Entity that registers the service orders that have been successfully completed and delivered to the customer." ;
    rdfs:comment "Minted: output of P10334. Descriptive register." .

ex:IncompleteServiceOrderRegister a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Incomplete Service Order Register" ;
    skos:definition "A Descriptive Information Content Entity that registers the service orders that are partially or entirely incomplete or undelivered, together with associated service failures." ;
    rdfs:comment "Minted: output of P10335. Descriptive register." .

ex:AdEffectivenessAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Ad Effectiveness Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the influence of advertisements on customers' purchasing behavior." ;
    rdfs:comment "Minted per Gate-F as the definitional output of P11239 (6.5.3.2). Descriptive (a judgement), satisfying the GOLDEN PRINCIPLE for the Appraisal genus. Captures the ad-effectiveness judgement that the lead gerund 'Assessing the influence of advertisements on purchasing behavior' makes intrinsic to the act; the analysis sibling 6.5.3.4 covers product/service satisfaction generally, not ad influence specifically, so this commitment would otherwise be dropped." .

ex:CustomerSatisfactionAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Customer Satisfaction Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes measured levels of customer satisfaction with a customer service process, product, or warranty." ;
    rdfs:comment "Output of the measurement processes of 6.5 (6.5, 6.5.1, 6.5.2, 6.5.3, 6.5.4.1) -> producing act is an Act of Appraisal." .

ex:ImprovementOpportunityAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Improvement Opportunity Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes identified opportunities to improve customer service operations, products, or warranties." ;
    rdfs:comment "Output of the 'identify improvement opportunities' activities across 6.5 (6.5.1.2, 6.5.2.2, 6.5.3.4, 6.5.4.3-4) and 6.3.4.4.4." .

ex:WarrantyPerformanceReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Warranty Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes warranty management metrics and the conclusions drawn from comparing warranties." ;
    rdfs:comment "Output of 6.5.4 and 6.5.4.2 (Monitor and report on warranty management metrics)." .

ex:FraudulentClaimAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:WarrantyClaim ] ;
    rdfs:label "Fraudulent Claim Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of whether a claim contains deliberately incorrect information or was submitted to deceive." ;
    rdfs:comment "Output of 6.5.4.5 (Investigate fraudulent claims)." .

ex:HazardRiskAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:DefectiveProduct ] ;
    rdfs:label "Hazard Risk Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the identified hazards of a product, their likelihood, and their adverse consequences." ;
    rdfs:comment "Output of 6.4.2 (Assess the likelihood and consequences of occurrence of any hazards)." .

ex:RecallEffectivenessAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "Recall Effectiveness Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes an analysis of the effectiveness of a product recall." ;
    rdfs:comment "Output of 6.4.5 (Monitor and audit recall effectiveness) and the review of 6.5.5 (Evaluate recall performance)." .

ex:RecallInitiationRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:DefectiveProduct ] ;
    rdfs:label "Recall Initiation Record" ;
    skos:definition "A Descriptive Information Content Entity that records that a product recall has been commenced and the removal of the defective product launched." ;
    rdfs:comment "Minted per Gate-F as the Descriptive output of P20111 (6.4.1 'Initiate recall'). The initiation act LAUNCHES the recall by applying the standing recall strategy; it does not re-produce that strategy. Distinct from ex:RecallStrategy (the Directive procedure, output of 6.1.7), which P20111 consumes as input." .

ex:RecallCommunication a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,   # Descriptive ICE
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:DefectiveProduct ] ;
    rdfs:label "Recall Communication" ;
    skos:definition "A Descriptive Information Content Entity issued to the public and stakeholders that conveys information about a product recall." ;
    rdfs:comment "Output of 6.4.3 (Manage recall related communications) and the public communication of 6.4.6 (Manage recall termination)." .

####################################################################
# 4. PROCESS CLASSES + capabilities
#    Partonomy via cco:ont00001777 (has process part); never
#    rdfs:subClassOf between processes. The Category 6.0 itself and the
#    group node 6.3 (PCF 12658) are catalog-only (R3) -- no has-process-
#    part edges into them here.
####################################################################

####################################################################
# ===== GROUP 6.1  "Develop customer service strategy" (PCF 10378) =====
# Act genera: ex:ActOfFormulation (apqc-ext) for define/develop/establish
# of a directive; cco:ont00000684 (Act of Contract Formation) for 6.1.6.3
# (re-anchored from Act of Promising per Gate-F: two-party legal obligation);
# cco:ont00000402 (Act of Communication) for 6.1.6.4 and 6.1.6.5.
####################################################################

ex:P10378 a owl:Class ;
    ex:pcfID "10378" ;
    ex:hierarchyID "6.1" ;
    ex:apqcSourceText "Defining a plan that removes customer obstacles by gathering operational insight and competitive insight, as well as improving soft skills and forward resolution for employees. Develop customer segmentation. Define rules and regulations for customer service. Establish service levels for customers." ;
    rdfs:label "Develop customer service strategy" ;
    skos:definition "An Act of Formulation that composes a customer service strategy governing how an organization removes customer obstacles, segments customers, and sets service levels." ;
    rdfs:comment "Models APQC process group 6.1 as an occurrent. Its APQC children are process parts (cco:ont00001777), not subclasses. Output is a Directive ICE, agreeing with the ex:ActOfFormulation (Planning) genus." ;
    skos:example "A customer-service leadership team's annual cycle that issues the organization's customer service strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerServiceStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20086 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20087 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20088 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10382 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10383 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20089 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20092 ] .

ex:P20086 a owl:Class ;
    ex:pcfID "20086" ; ex:hierarchyID "6.1.1" ;
    ex:apqcSourceText "Defining a set of behaviors, skills, and policies needed to provide customer service effectively across the enterprise." ;
    rdfs:label "Define customer service requirements across the enterprise" ;
    skos:definition "An Act of Formulation that composes a customer service requirement specification enumerating the behaviors, skills, and policies needed to provide customer service across the enterprise." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (cco:ont00000511 Act of Planning): the output is a Directive ICE prescribing requirements." ;
    skos:example "A service-design team documents the enterprise-wide customer service requirement specification." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerServiceRequirementSpecification ] .

ex:P20087 a owl:Class ;
    ex:pcfID "20087" ; ex:hierarchyID "6.1.2" ;
    ex:apqcSourceText "Communicating to the customer service resources what is expected when engaging the customer. Relate service level expectations to the workforce. Ensure positive customer experience." ;
    rdfs:label "Define customer service experience" ;
    skos:definition "An Act of Formulation that articulates a customer service experience specification relating service-level expectations to the workforce for engaging customers." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the defining output is a Directive ICE (the experience specification). Communicating it to staff is the downstream method, not the definitional output." ;
    skos:example "A CX lead defines the expected tone and resolution standards for every customer interaction." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerServiceExperienceSpecification ] .

ex:P20088 a owl:Class ;
    ex:pcfID "20088" ; ex:hierarchyID "6.1.3" ;
    ex:apqcSourceText "Establishing and refining procedures for customer service and technical support." ;
    rdfs:label "Define and manage customer service channel strategy" ;
    skos:definition "An Act of Formulation that establishes and refines a customer service channel strategy governing the procedures for customer service and technical support." ;
    rdfs:comment "Despite the 'manage' label, the Element Description denotes a bounded act of establishing/refining procedures (a Directive ICE), so it is modeled as a process under ex:ActOfFormulation rather than as an Organization Capability." ;
    skos:example "A support-operations team establishes the phone, chat, and email channel procedures and revises them quarterly." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerServiceChannelStrategy ] .

ex:P10382 a owl:Class ;
    ex:pcfID "10382" ; ex:hierarchyID "6.1.4" ;
    ex:apqcSourceText "Outlining the framework of policies and methods for developing customer service strategy. Establish the rules and regulations that serve as a guideline for the customer service strategy. Take into account customer needs and behavior." ;
    rdfs:label "Define customer service policies and procedures" ;
    skos:definition "An Act of Formulation that composes a customer service policy establishing the rules and regulations that guide the customer service strategy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: output is a Directive ICE (the policy)." ;
    skos:example "A policy team publishes the customer service code of conduct and escalation rules." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerServicePolicy ] .

ex:P10383 a owl:Class ;
    ex:pcfID "10383" ; ex:hierarchyID "6.1.5" ;
    ex:apqcSourceText "Determining and implementing levels for customer services. Benchmark certain customer service practices, and base customer level services on those benchmarks. Create a service level agreement, which is a negotiated agreement designed to create a common understanding about services, priorities, and responsibilities." ;
    rdfs:label "Establish target service level for each customer segment" ;
    skos:definition "An Act of Formulation that determines target customer service levels per segment and produces a service level agreement defining services, priorities, and responsibilities." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output is a Directive ICE (the SLA). Benchmarking is a typical sub-step, not the defining output, so it is not promoted to a restriction." ;
    skos:example "An operations manager negotiates and publishes a tiered SLA for premium and standard customer segments." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceLevelAgreement ] .

ex:P20089 a owl:Class ;
    ex:pcfID "20089" ; ex:hierarchyID "6.1.6" ;
    ex:apqcSourceText "Determining the exact terms and conditions under which specific warranties apply to certain goods or services." ;
    rdfs:label "Define warranty claims" ;
    skos:definition "An Act of Formulation that determines the exact terms and conditions under which specific warranties apply to certain goods or services, producing a warranty claim definition." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: output is a Directive ICE. Its APQC activities (6.1.6.1-6.1.6.5) are process parts via cco:ont00001777." ;
    skos:example "A warranty team sets the covered defects, time windows, and product scope for each warranty type." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WarrantyClaimDefinition ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16893 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16890 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20090 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20091 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12673 ] .

ex:P16893 a owl:Class ;
    ex:pcfID "16893" ; ex:hierarchyID "6.1.6.1" ;
    ex:apqcSourceText "Establishing warranty policies to assure customers that the company will guarantee its warranties that it issues." ;
    rdfs:label "Determine and document warranty policies" ;
    skos:definition "An Act of Formulation that establishes and documents a warranty policy assuring customers that the company will guarantee the warranties it issues." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: output is a Directive ICE (ex:WarrantyPolicy, reused from the shared section vocab)." ;
    skos:example "Legal and warranty teams publish the company's warranty guarantee policy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WarrantyPolicy ] .

ex:P16890 a owl:Class ;
    ex:pcfID "16890" ; ex:hierarchyID "6.1.6.2" ;
    ex:apqcSourceText "Establishing and maintaining claims processing and routing rules. Establish and maintain claims processing and routing rules for product warranties, coverage lists, repair, fault, trouble codes, repair time setup, and warranty policy registration. This also includes rolling out the codes and rules, and the improvements/updates to these rules and codes via systematic updates." ;
    rdfs:label "Create and manage warranty rules/claim codes for products" ;
    skos:definition "An Act of Formulation that establishes warranty claims-processing and routing rules and the associated warranty claim codes for products." ;
    rdfs:comment "Despite the 'manage/maintain' framing, the dominant act is establishing the rules and codes (a Directive ICE), so it is modeled as a process under ex:ActOfFormulation. Output reuses ex:WarrantyClaimCode from the shared section vocab." ;
    skos:example "A warranty operations team defines fault and repair-time codes and rolls them out across the claims system." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WarrantyClaimCode ] .

ex:P20090 a owl:Class ;
    ex:pcfID "20090" ; ex:hierarchyID "6.1.6.3" ;
    ex:apqcSourceText "Negotiating with manufacturers and dealers the obligations of each party in upholding warranties." ;
    rdfs:label "Agree on warranty responsibilities with suppliers" ;
    skos:definition "An Act of Contract Formation in which an organization and its suppliers or dealers negotiate and commit to the warranty obligations of each party, producing a supplier warranty responsibility agreement." ;
    rdfs:comment "Re-anchored to cco:ont00000684 (Act of Contract Formation) per Gate-F review: the Element Description ('Negotiating with manufacturers and dealers the obligations of EACH PARTY') and the skos:definition describe a BILATERAL, mutual, legally-binding agreement between two or more parties. cco:ont00000684 is defined as 'An Act of Promising having a lawful object entered into voluntarily by two or more agents with legal capacity, each of whom intends to create one or more legal obligations between them.' REJECTED the prior anchor cco:ont00000821 (Act of Promising) as too generic: per its CCO definition it is a UNILATERAL speech act 'performed by declaring that THE promising agent will do, or refrain from doing, the specified action', whereas this row is a two-party legal obligation. Contract Formation is a direct child of Promising, so the closure (Promising -> Commissive Communication -> Communication -> Planned Act) still holds. NOT ex:ActOfFormulation, because the act establishes a commitment between parties, not a unilateral plan. Suppliers participate via cco:ont00001833 (has agent)." ;
    skos:example "A manufacturer and dealer sign an agreement apportioning who covers which warranty repairs." ;
    rdfs:subClassOf cco:ont00000684 ,   # Act of Contract Formation
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Contract Formation -> Act of Promising -> ... -> Planned Act in CCO; stated in-module so the standalone S2 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierWarrantyResponsibilityAgreement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001833 ; owl:someValuesFrom ex:Supplier ] .

ex:P20091 a owl:Class ;
    ex:pcfID "20091" ; ex:hierarchyID "6.1.6.4" ;
    ex:apqcSourceText "Informing customers about warranties that apply to promoted products or services." ;
    rdfs:label "Define warranty related offerings for customers" ;
    skos:definition "An Act of Communication in which a warranty offering is conveyed to customers, informing them about the warranties that apply to promoted products or services." ;
    rdfs:comment "Re-anchored to cco:ont00000402 (Act of Communication) per Gate-F review: the verbatim Element Description ('Informing customers about warranties that apply to promoted products or services') is a pure communication/informing act with no define/specify/compose verb in the source. Per D2 the genus is read from the Element Description, not the label verb 'Define'. This now mirrors the parallel sibling P12673 (6.1.6.5 'Communicate warranty policies and offerings'), whose source is likewise a communication and which is anchored at cco:ont00000402. The warranty offering being informed about is modeled as has input (cco:ont00001921), NOT a definitional has output (the source never mentions composing a specification), per the Phase-3 existential-necessity rule. The customer is the recipient (has participant). REJECTED the prior ex:ActOfFormulation anchor (and its has output some ex:WarrantyOffering) as a label-over-description false friend that anchored two near-identical informing acts to two different genera." ;
    skos:example "A product marketing team informs customers of the warranty bundled with a promoted product line." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyOffering ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P12673 a owl:Class ;
    ex:pcfID "12673" ; ex:hierarchyID "6.1.6.5" ;
    ex:apqcSourceText "Communicating rules and updates via training manuals for new products and training resources." ;
    rdfs:label "Communicate warranty policies and offerings" ;
    skos:definition "An Act of Communication in which warranty policies, rules, and updates are transferred to recipients via training manuals and training resources." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): the act transfers an existing Directive ICE (ex:WarrantyPolicy) to staff rather than composing a new directive, so it is NOT ex:ActOfFormulation. The warranty policy is the communicated input." ;
    skos:example "Trainers roll out updated warranty rules through new-product training manuals." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyPolicy ] .

ex:P20092 a owl:Class ;
    ex:pcfID "20092" ; ex:hierarchyID "6.1.7" ;
    ex:apqcSourceText "Establishing procedures to handle recalls of defective products." ;
    rdfs:label "Develop recall strategy" ;
    skos:definition "An Act of Formulation that establishes the procedures for handling recalls of defective products, producing a recall strategy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: output is a Directive ICE (ex:RecallStrategy, reused from the shared section vocab)." ;
    skos:example "A product-safety team documents the steps to execute a recall when a defect is confirmed." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RecallStrategy ] .

####################################################################
# ===== GROUP 6.2  "Plan and manage customer service contacts" (PCF 10379) =====
# 6.2 (10379) is catalog-only (group heading; R3). 6.2.1/6.2.2/6.2.3 are
# standing 'Manage' functions -> Organization Capabilities (R5/R6),
# realized in their child acts. 6.2.4/6.2.5 are bounded processes.
####################################################################

ex:CustomerServiceWorkforceManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10390 ] ,   # realized in
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10391 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10392 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10393 ] ;
    rdfs:label "Customer Service Workforce Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to plan, schedule, track, and assure the quality of the workforce deployed for customer service provision." ;
    rdfs:comment "R5/R6: models APQC 6.2.1 'Plan and manage customer service work force' (PCF 10387), a standing function with no natural end, as a capability realized in its four bounded child acts (forecast, schedule, track utilization, monitor interaction quality) rather than as a process." .

ex:CustomerInquiryManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10394 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P13482 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10395 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10396 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16928 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16937 ] ;
    rdfs:label "Customer Inquiry Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to receive, analyze, resolve, and respond to customer problems, requests, and inquiries and to surface sales opportunities arising from them." ;
    rdfs:comment "R5/R6: models APQC 6.2.2 'Manage customer service problems, requests, and inquiries' (PCF 10388), a standing 'Manage X' function, as a capability realized in its six bounded child acts rather than as a process." .

ex:CustomerComplaintManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10397 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10398 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10399 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10400 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19072 ] ;
    rdfs:label "Customer Complaint Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to receive, route, resolve, respond to, and analyze customer complaints." ;
    rdfs:comment "R5/R6: models APQC 6.2.3 'Manage customer complaints' (PCF 10389), a standing 'Manage X' function, as a capability realized in its five bounded child acts rather than as a process." .

ex:P10390 a owl:Class ;
    ex:pcfID "10390" ; ex:hierarchyID "6.2.1.1" ;
    ex:apqcSourceText "Projecting the total work force required to service customer service inquiries in order to effectively predict the volume of vendor contracts required. Estimate the number of the customer service contracts in an agreed-upon time frame in order to strategically maintain the work force necessitated for customer inquires. Analyze historical data around customer service contracts, the universe of customer inquiries, frequency of inquiries, servicing capability (per head) of the employees, etc." ;
    rdfs:label "Forecast volume of customer service contacts" ;
    skos:definition "An Act of Forecasting that has as input historical contact data and has as output a contact-volume forecast estimating the future number of customer service contacts over a given time frame." ;
    rdfs:comment "Reuses ex:ActOfForecasting (PROPOSE-EXT, section 3.0): extrapolation from historical data to a Predictive ICE. Output is descriptive/predictive (GOLDEN PRINCIPLE)." ;
    skos:example "A contact-center analyst projects next quarter's inquiry volume from last year's contact logs." ;
    rdfs:subClassOf ex:ActOfForecasting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HistoricalContactData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ContactVolumeForecast ] .

ex:P10391 a owl:Class ;
    ex:pcfID "10391" ; ex:hierarchyID "6.2.1.2" ;
    ex:apqcSourceText "Deploying the work force to manage customer service contracts. Create a systematic summary of the operations and service required, as well as the specific amount of work force that is to be deployed to the customer service operations. Ensure work force is directly proportional to the estimated forecast of customer service contracts." ;
    rdfs:label "Schedule customer service work force" ;
    skos:definition "An Act of Scheduling that has as input a contact-volume forecast and has as output a workforce schedule prescribing the customer service staff to be deployed over time." ;
    rdfs:comment "Output is a Directive ICE (a schedule), agreeing with the planning genus (GOLDEN PRINCIPLE). The forecast input is definitional (the text fixes the workforce as proportional to the forecast)." ;
    skos:example "A workforce planner builds the week's agent roster from the forecast contact volume." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ContactVolumeForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceSchedule ] .

ex:P10392 a owl:Class ;
    ex:pcfID "10392" ; ex:hierarchyID "6.2.1.3" ;
    ex:apqcSourceText "Tracking the utilization of work force deployed for managing customer service operations. Monitor the utility of the work force deployed for managing customer service operations in order to evaluate its efficiency and cost effectiveness. Calculate the overall labor effectiveness, which measures the utility, performance, and quality of the work force." ;
    rdfs:label "Track work force utilization" ;
    skos:definition "An Act of Monitoring that tracks the utilization of the deployed customer service work force and has as output a workforce-utilization report describing its efficiency and effectiveness." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (ongoing tracking yielding a descriptive status report), not Appraisal. Output is a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A team lead reviews dashboards and issues a monthly labor-effectiveness report." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceUtilizationReport ] .

ex:P10393 a owl:Class ;
    ex:pcfID "10393" ; ex:hierarchyID "6.2.1.4" ;
    ex:apqcSourceText "Tracking and determining the quality of interactions between the customer and customer representatives. Use electronic devices to record and effectively assess customer representatives' interactions." ;
    rdfs:label "Monitor and evaluate quality of customer interactions with customer service representatives" ;
    skos:definition "An Act of Monitoring that tracks the interactions between customers and customer service representatives and has as output an interaction-quality assessment describing their quality." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (ongoing tracking/recording of interaction quality yielding a descriptive assessment). The customer service representative whose interactions are tracked is a definitional participant." ;
    skos:example "A QA analyst reviews recorded calls and scores agents on an interaction-quality rubric." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InteractionQualityAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:CustomerServiceRepresentative ] .

ex:P10394 a owl:Class ;
    ex:pcfID "10394" ; ex:hierarchyID "6.2.2.1" ;
    ex:apqcSourceText "Receiving requests for information from customers over multiple channels. Receive various requests and inquiries from customers regarding products/services. Accept these inquiries through channels such as email, telephone, online forms, text messages, social media, and in person. Supply dedicated equipment, systems, and personnel." ;
    rdfs:label "Receive customer problems, requests, and inquiries" ;
    skos:definition "An Act of Communication in which a customer service representative receives a customer inquiry transferred by a customer over some channel." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication: an ICE is transferred from one Agent to another); the inquiry is received, so the inquiry ICE is a definitional input and the customer a definitional participant." ;
    skos:example "An agent picks up a phone call in which a customer asks about a product feature." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerInquiry ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P13482 a owl:Class ;
    ex:pcfID "13482" ; ex:hierarchyID "6.2.2.2" ;
    ex:apqcSourceText "Analyzing various requests and inquiries from customers regarding products/services. Provide answers and offerings to satisfy the customer's needs." ;
    rdfs:label "Analyze problems, requests, and inquiries" ;
    skos:definition "An Act of Analysis that has as input a customer inquiry and has as output an inquiry analysis describing the customer's need and candidate answers." ;
    rdfs:comment "Reuses shared ex:ActOfAnalysis. Output is a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "An agent examines an inbound request and characterizes what product information the customer needs." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerInquiry ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InquiryAnalysis ] .

ex:P10395 a owl:Class ;
    ex:pcfID "10395" ; ex:hierarchyID "6.2.2.3" ;
    ex:apqcSourceText "Routing customer inquiries in order to service them with the most apposite response. Direct customer inquires to the best suited personnel or system. Have a system or procedure capable of efficiently channeling these requests." ;
    rdfs:label "Resolve customer problems, requests, and inquiries" ;
    skos:definition "An Act of Communication in which a received customer inquiry is directed to the personnel or system best suited to service it with the most apposite response." ;
    rdfs:comment "Re-anchored to cco:ont00000402 (Act of Communication) per Gate-F review, mirroring its sibling P10398 (6.2.3.2 'Route customer complaints'). The verbatim source describes NO settlement: 'Routing customer inquiries in order to service them with the most apposite response. Direct customer inquires to the best suited personnel or system. Have a system or procedure capable of efficiently channeling these requests.' This is routing/channeling, ontologically identical to the complaint-flow sibling P10398, which this module anchors at cco:ont00000402. The inquiry flow has no separate 'route' step, so the routing description was filed under the 'Resolve' label. REJECTED the prior ex:ActOfResolution anchor as a label-over-description false friend (Step-2 trap): a routing/directing act settles nothing. The existential output ex:InquiryResolution is DEMOTED -- it is not produced by routing; the inquiry remains the definitional has input (cco:ont00001921) and the customer service representative is the routing participant. If APQC genuinely intends end-to-end resolution here, the missing investigate/decide/close sub-acts would have to be added to justify a Resolution genus; absent them, the routing reading wins as the only thing the text describes." ;
    skos:example "A triage system routes a technical request to the specialist best suited to answer it." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerInquiry ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:CustomerServiceRepresentative ] .

ex:P10396 a owl:Class ;
    ex:pcfID "10396" ; ex:hierarchyID "6.2.2.4" ;
    ex:apqcSourceText "Responding to customer requests by email, conversation, interactive voice response, mail, etc. with the most appropriate reply. Instill a robust process to locate the right information for a solution to a customer's problem." ;
    rdfs:label "Respond to customer problems, requests, and inquiries" ;
    skos:definition "An Act of Representative Communication in which a customer service representative transfers an inquiry response to the customer who raised the inquiry." ;
    rdfs:comment "Anchored to cco:ont00000379 (Act of Representative Communication: an Act of Communication committing the speaker to the truth of the asserted reply). The response ICE is the definitional output transferred to the customer." ;
    skos:example "An agent emails the customer the answer and resolution steps for their request." ;
    rdfs:subClassOf cco:ont00000379 ,   # Act of Representative Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Representative Communication is a Planned Act in CCO; stated in-module so the standalone S2 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InquiryResponse ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P16928 a owl:Class ;
    ex:pcfID "16928" ; ex:hierarchyID "6.2.2.5" ;
    ex:apqcSourceText "Utilizing customer inquiries as opportunities to either provide a comparable service to the one in question, offer additional complimentary service, or suggest a service that is better than what was initially offered." ;
    rdfs:label "Identify and capture upsell/cross-sell opportunities" ;
    skos:definition "An Act of Identification that has as input a customer inquiry and has as output a sales lead representing an upsell or cross-sell opportunity discerned from the inquiry." ;
    rdfs:comment "Reuses shared ex:ActOfIdentification (discernment sense). Output is a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "While handling a support call, an agent spots that the customer qualifies for a premium tier and records a lead." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerInquiry ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesLead ] .

ex:P16937 a owl:Class ;
    ex:pcfID "16937" ; ex:hierarchyID "6.2.2.6" ;
    ex:apqcSourceText "Providing possible sales leads to the sales team in an effort to garner more business opportunities." ;
    rdfs:label "Deliver opportunity to sales team" ;
    skos:definition "An Act of Communication in which a customer service representative transfers a sales lead to the sales team." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): the lead ICE is transferred from one Agent to another. The sales lead is the definitional input transferred and the sales team a definitional participant (recipient)." ;
    skos:example "An agent forwards a qualified cross-sell lead to the inside-sales queue." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesLead ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SalesTeam ] .

ex:P10397 a owl:Class ;
    ex:pcfID "10397" ; ex:hierarchyID "6.2.3.1" ;
    ex:apqcSourceText "Receiving any complaints or grievances from customers for the organization's products/services. Receive objections, complaints, and criticism from customers regarding products/services through email, telephone, online forms, text messages, social media, in person, etc. Dedicate equipment, systems, and personnel." ;
    rdfs:label "Receive customer complaints" ;
    skos:definition "An Act of Communication in which a customer service representative receives a customer complaint transferred by a customer over some channel." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication). The complaint ICE is the definitional input received and the customer a definitional participant." ;
    skos:example "A service desk logs a grievance submitted through an online complaint form." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerComplaint ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P10398 a owl:Class ;
    ex:pcfID "10398" ; ex:hierarchyID "6.2.3.2" ;
    ex:apqcSourceText "Routing any complaints or grievances received from customers in order to address them in the most appropriate manner. Direct complaints to the best suited personnel or system. Implement a system or procedure capable of efficiently channeling the various objections, complaints, and criticism from customers over the offerings provided by the organization." ;
    rdfs:label "Route customer complaints" ;
    skos:definition "An Act of Communication in which a received customer complaint is directed to the personnel or system best suited to address it." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): routing transfers the complaint ICE onward to the appropriate handler. The complaint is the definitional input." ;
    skos:example "A triage rule forwards a billing complaint to the finance support queue." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerComplaint ] .

ex:P10399 a owl:Class ;
    ex:pcfID "10399" ; ex:hierarchyID "6.2.3.3" ;
    ex:apqcSourceText "Resolving any customer complaints that are deemed to be sound and reasonable. Redress any objections, grievances, and complaints received from customers regarding the offerings provided by the organization. Identify the legitimate complaints, where the situation needs to be appropriately corrected. Deploy personnel who can rectify the issue within a stipulated time frame." ;
    rdfs:label "Resolve customer complaints" ;
    skos:definition "An Act of Resolution that has as input a legitimate customer complaint and has as output a complaint resolution recording the corrective action taken to redress it." ;
    rdfs:comment "Anchored to ex:ActOfResolution (PROPOSE-EXT): redressing a sound complaint and recording the settlement. Output is a Descriptive ICE (consistent with the Planned-Act genus)." ;
    skos:example "A support team issues a replacement unit and records the complaint as resolved." ;
    rdfs:subClassOf ex:ActOfResolution ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerComplaint ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ComplaintResolution ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000063 ; owl:someValuesFrom ex:P10400 ] .   # precedes Respond (6.2.3.4)

ex:P10400 a owl:Class ;
    ex:pcfID "10400" ; ex:hierarchyID "6.2.3.4" ;
    ex:apqcSourceText "Responding to customer complaints including all activities necessitated to service any objections, complaints, or grievances with the most appropriate reply. Source the right information to formulate a response that eases the discomfort being experienced by the customer. (Closely coordinate with Resolve customer complaints [10399].)" ;
    rdfs:label "Respond to customer complaints" ;
    skos:definition "An Act of Representative Communication in which a customer service representative transfers a complaint response to the customer who raised the complaint." ;
    rdfs:comment "Anchored to cco:ont00000379 (Act of Representative Communication). The response ICE is the definitional output transferred to the customer. Source text cross-references Resolve customer complaints [10399]: the resolution precedes and feeds the response." ;
    skos:example "An agent sends the customer an apology and the steps taken to fix their issue." ;
    rdfs:subClassOf cco:ont00000379 ,   # Act of Representative Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Representative Communication is a Planned Act in CCO; stated in-module so the standalone S2 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ComplaintResponse ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ComplaintResolution ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P19072 a owl:Class ;
    ex:pcfID "19072" ; ex:hierarchyID "6.2.3.5" ;
    ex:apqcSourceText "Analyzing complaint logs to provide input for continuous service improvement and customer profiling." ;
    rdfs:label "Analyze customer complaints and response/redressal" ;
    skos:definition "An Act of Analysis that has as input customer complaints and has as output a complaint analysis describing patterns that inform service improvement and customer profiling." ;
    rdfs:comment "Reuses shared ex:ActOfAnalysis. Output is a Descriptive ICE (GOLDEN PRINCIPLE). Operates over the aggregate complaint log, so the complaint input is definitional." ;
    skos:example "A quality team mines a quarter of complaint records to find recurring defect themes." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerComplaint ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ComplaintAnalysis ] .

ex:P20094 a owl:Class ;
    ex:pcfID "20094" ; ex:hierarchyID "6.2.4" ;
    ex:apqcSourceText "Acquiring returns and identify if the returns are scraped or salvaged." ;
    rdfs:label "Process returns" ;
    skos:definition "An Act of Acquisition in which an Agent takes back a returned product from a customer and determines whether it is to be scrapped or salvaged." ;
    rdfs:comment "Operations process: the returned product is a MATERIAL participant (D-operations / D4), attached via obo:has participant, not has output (has output is reserved for ICEs, D3). Reuses shared ex:ActOfAcquisition. Its two APQC children are process parts." ;
    skos:example "A returns center receives a returned appliance and routes it to refurbishment." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ReturnedProduct ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10364 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20095 ] .

ex:P10364 a owl:Class ;
    ex:pcfID "10364" ; ex:hierarchyID "6.2.4.1" ;
    ex:apqcSourceText "Approving and carrying forward the requests by the customers to return the product. This is part of the process of returning a product in order to receive a refund, replacement, or repair during the product's warranty period." ;
    rdfs:label "Authorize return" ;
    skos:definition "An Act of Formulation that has as input a customer return request and has as output a return authorization prescribing that the requested product return may proceed." ;
    rdfs:comment "Reuses shared ex:ActOfFormulation (composing a Directive ICE). Output is a Directive ICE (an authorization), agreeing with the formulation/planning genus (GOLDEN PRINCIPLE). Per Gate-F, the has input is the dedicated ex:ReturnRequest (the customer's product-return request named in the source 'requests by the customers to return the product'), REPLACING the prior false-friend reuse of ex:ServiceRequest, which is the individual-customer service-requirements ICE of 6.3.4.1 -- an unrelated informational object." ;
    skos:example "A warranty desk approves a return request and issues an RMA number." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ReturnRequest ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ReturnAuthorization ] .

ex:P20095 a owl:Class ;
    ex:pcfID "20095" ; ex:hierarchyID "6.2.4.2" ;
    ex:apqcSourceText "Notating the reason for the return of the product." ;
    rdfs:label "Process return and record reason" ;
    skos:definition "An Act of Acquisition in which an Agent takes in the returned product and produces a return-reason record documenting why the product was returned." ;
    rdfs:comment "Operations process: the returned product is a MATERIAL participant (obo:has participant). The informational output (the reason record) is a Descriptive ICE (GOLDEN PRINCIPLE), attached via has output." ;
    skos:example "A clerk inspects a returned item and records 'defective on arrival' as the return reason." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ReturnedProduct ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ReturnReasonRecord ] .

ex:P12840 a owl:Class ;
    ex:pcfID "12840" ; ex:hierarchyID "6.2.5" ;
    ex:apqcSourceText "Notifying all stakeholders, legal, and industry regulatory bodies of the incidents and risks related to a return or recall, if needed." ;
    rdfs:label "Report incidents and risks to regulatory bodies" ;
    skos:definition "An Act of Representative Communication in which an Agent transfers a regulatory incident report concerning return- or recall-related incidents and risks to regulatory bodies and other stakeholders." ;
    rdfs:comment "Anchored to cco:ont00000379 (Act of Representative Communication): reporting asserts and transfers a truth-committing report ICE to recipients. The incident report is the definitional output and the regulatory body a definitional participant (recipient)." ;
    skos:example "A compliance officer files a mandatory safety-incident notice with the industry regulator following a recall." ;
    rdfs:subClassOf cco:ont00000379 ,   # Act of Representative Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Representative Communication is a Planned Act in CCO; stated in-module so the standalone S2 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryIncidentReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryBody ] .

####################################################################
# ===== GROUP 6.3  "Service products after sales" (PCF 12658) =====
# 6.3 (PCF 12658) is catalog-only (group heading; R3) -- not minted.
# Act genera: ex:ActOfResolution (end-to-end case handling), ex:ActOf-
# ServiceProvision (service delivery), ex:ActOfScheduling, ex:ActOf-
# Analysis, ex:ActOfIdentification, ex:ActOfFormulation, ex:ActOf-
# Acquisition, ex:ActOfSelection, ex:ActOfMonitoring; plus CCO Acts of
# Information Processing / Appraisal / Communication / Maintenance / the
# generic Planned Act for prescriptive authorizations.
####################################################################

ex:P20605 a owl:Class ;
    ex:pcfID "20605" ; ex:hierarchyID "6.3.1" ;
    ex:apqcSourceText "Filing product registrations." ;
    rdfs:label "Register products" ;
    skos:definition "An Act of Information Processing that records a customer's product ownership and produces a product registration." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): filing a registration stores/records an ICE; output is a Descriptive ProductRegistration." ;
    skos:example "A customer-service system files a newly purchased appliance's registration on behalf of the buyer." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductRegistration ] .

ex:P12669 a owl:Class ;
    ex:pcfID "12669" ; ex:hierarchyID "6.3.2" ;
    ex:apqcSourceText "Identifying, investigating, and processes warranty claims. This process includes: receipt and validation of a warranty claim; definition and diagnosis /root cause analysis of an issue and recommendation for corrective action; the determination of responsibility for settlement of the claim; the transaction being approved or denied; and the originator being notified and payment authorized. In the case of a recurring event, further investigation (definition and diagnosis or root cause analysis) is performed, and a recommendation for corrective action is made and implemented in production/design. It ends when the claim is closed." ;
    rdfs:label "Process warranty claims" ;
    skos:definition "An Act of Resolution that carries a warranty claim from receipt through validation, investigation, settlement decision, and closure." ;
    rdfs:comment "Bounded occurrent: begins at claim receipt and ends when the claim is closed. Genus ex:ActOfResolution (reconciled to cco:ont00000228 Planned Act). Its APQC children are process parts, not subclasses." ;
    skos:example "A warranty team receives a claim, validates it, investigates the issue, decides approve/reject, authorizes payment, and closes the claim." ;
    rdfs:subClassOf ex:ActOfResolution ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyClaim ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ClaimDisposition ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20096 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12671 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20097 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20101 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20102 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12668 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20103 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20104 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20105 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12667 ] .

ex:P20096 a owl:Class ;
    ex:pcfID "20096" ; ex:hierarchyID "6.3.2.1" ;
    ex:apqcSourceText "Receiving incoming warranty claims. Route claim to correct department. Document claim." ;
    rdfs:label "Receive warranty claim" ;
    skos:definition "An Act of Communication that takes in an incoming warranty claim, routes it to the responsible department, and documents it." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): a warranty-claim ICE is transferred from the originator into the organization." ;
    skos:example "A service desk logs an incoming claim and routes it to the warranty team." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyClaim ] .

ex:P12671 a owl:Class ;
    ex:pcfID "12671" ; ex:hierarchyID "6.3.2.2" ;
    ex:apqcSourceText "Ensuring that the claim falls within the parameters of the warranty in question. After validation is made, the claim must be investigated." ;
    rdfs:label "Validate warranty claim" ;
    skos:definition "An Act of Appraisal that has as input a warranty claim and a warranty policy and has as output a warranty claim validation judging whether the claim falls within the warranty parameters." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): the act evaluates the claim against the warranty parameters; output is a Descriptive judgement." ;
    skos:example "An administrator checks a claim against the policy and records that it is in scope." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyClaim ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WarrantyClaimValidation ] .

ex:P20097 a owl:Class ;
    ex:pcfID "20097" ; ex:hierarchyID "6.3.2.3" ;
    ex:apqcSourceText "Executing investigational and analysis of warranty claims. This involves notification and definition of a warranty issue, includes the scheduling of a field service agent to perform further investigation; the request and receipt of defective parts; and diagnosis/root cause analysis. This concludes with the receipt of the result and recommendation for corrective action." ;
    rdfs:label "Investigate warranty issues" ;
    skos:definition "An Act of Analysis that examines a warranty issue and produces a root cause analysis and a recommendation for corrective action." ;
    rdfs:comment "Genus ex:ActOfAnalysis (apqc-ext): investigation is information processing producing a descriptive understanding. Its APQC children are process parts." ;
    skos:example "The warranty team defines the issue, schedules field service, examines a returned part, and reports a root cause." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RootCauseAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CorrectiveActionRecommendation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20098 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12677 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12678 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20099 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20100 ] .

ex:P20098 a owl:Class ;
    ex:pcfID "20098" ; ex:hierarchyID "6.3.2.3.1" ;
    ex:apqcSourceText "Defining the issue of the claim. The warranty team will look into the issue and understand whether it is covered by the claim code or if more detail is required. Field service will be scheduled to further qualify the definition of the issue and to collect more evidence." ;
    rdfs:label "Define issue" ;
    skos:definition "An Act of Analysis that has as input a warranty claim and a warranty claim code and has as output a warranty issue definition." ;
    rdfs:comment "Genus ex:ActOfAnalysis: discerning and articulating the claimed issue is information processing producing a descriptive definition." ;
    skos:example "The warranty team characterizes the reported fault against the applicable claim code." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyClaim ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyClaimCode ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WarrantyIssueDefinition ] .

ex:P12677 a owl:Class ;
    ex:pcfID "12677" ; ex:hierarchyID "6.3.2.3.2" ;
    ex:apqcSourceText "Scheduling additional investigative field service. This is performed for high priority claims or claims that require additional investigation. Field service engineers will gather additional information, perform further investigation, and qualify the definition of the issue." ;
    rdfs:label "Schedule field service" ;
    skos:definition "An Act of Scheduling that fixes the timing and assignment of investigative field service and produces a workforce schedule." ;
    rdfs:comment "Genus ex:ActOfScheduling (PROPOSE-EXT): output is a Directive WorkforceSchedule. Participant ex:FieldServiceAgent where definitional." ;
    skos:example "A high-priority claim triggers scheduling a field service agent to gather evidence." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceSchedule ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FieldServiceAgent ] .

ex:P12678 a owl:Class ;
    ex:pcfID "12678" ; ex:hierarchyID "6.3.2.3.3" ;
    ex:apqcSourceText "Requesting receipt of a defective part for further investigation." ;
    rdfs:label "Request and receive defective part" ;
    skos:definition "An Act of Acquisition that obtains a defective part for further investigation." ;
    rdfs:comment "Genus ex:ActOfAcquisition (apqc-ext): the organization obtains a part it did not previously hold. Operations category, so the defective part is a Material Entity participant (obo:BFO_0000057), not an ICE." ;
    skos:example "The warranty team requests and receives the failed component from the customer." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:DefectivePart ] .

ex:P20099 a owl:Class ;
    ex:pcfID "20099" ; ex:hierarchyID "6.3.2.3.4" ;
    ex:apqcSourceText "Investigating claims by an appropriate functional representative. Once the issue has been clearly defined and diagnosed and a recommendation for corrective action is determined, it will be provided to the warranty management team." ;
    rdfs:label "Investigate issue/perform root cause analysis" ;
    skos:definition "An Act of Analysis that has as input a warranty issue definition and has as output a root cause analysis and a recommendation for corrective action." ;
    rdfs:comment "Genus ex:ActOfAnalysis: diagnosis/root-cause analysis is information processing producing a descriptive analysis plus a directive corrective-action recommendation." ;
    skos:example "An engineer diagnoses the failure mode and recommends a design fix." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyIssueDefinition ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RootCauseAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CorrectiveActionRecommendation ] .

ex:P20100 a owl:Class ;
    ex:pcfID "20100" ; ex:hierarchyID "6.3.2.3.5" ;
    ex:apqcSourceText "Receiving investigative results to assess claim approval or denial. The warranty team will assess the results of the investigation and the recommendations for corrective action." ;
    rdfs:label "Receive investigation result/recommendation for corrective action" ;
    skos:definition "An Act of Appraisal that has as input a root cause analysis and a recommendation for corrective action and produces a claim assessment judging the claim toward approval or denial." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): the warranty team evaluates the investigation results ('the warranty team will assess the results... to assess claim approval or denial'). Per Gate-F a definitional has output (ex:ClaimAssessment, a Descriptive judgement) is added: an Act of Appraisal is definitionally judgement-producing and the source makes producing the assessment intrinsic, so omitting it under-specified the genus (Gate D thin-class risk) and the GOLDEN PRINCIPLE (appraisal -> descriptive). DIVISION OF LABOR (deliberate, documented): P20100 (Appraisal) JUDGES the results toward approve/deny and emits a Descriptive ex:ClaimAssessment; the sibling P12668 'Approve or reject' (ex:ActOfSelection) COMMITS the binary decision and emits the Directive ex:ClaimDisposition. The assess/decide split is intentional, not incidental." ;
    skos:example "The warranty team reviews the root-cause report and records an assessment recommending the claim be approved, before the decision act commits it." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RootCauseAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CorrectiveActionRecommendation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ClaimAssessment ] .

ex:P20101 a owl:Class ;
    ex:pcfID "20101" ; ex:hierarchyID "6.3.2.4" ;
    ex:apqcSourceText "Identifying responsible party for a claim. There is no negotiation with the supplier at this point. There can be multiple warranties applicable to the same part: a new part warranty, a new product warranty (for the product the part is installed on), and a supplier warranty from the company that last repaired the part. The information required for this decision would be the output of Receive component/part and analyze fault [19728]." ;
    rdfs:label "Determine responsible party" ;
    skos:definition "An Act of Identification that has as input a root cause analysis and has as output a responsible party determination identifying who is responsible for settling the claim." ;
    rdfs:comment "Genus ex:ActOfIdentification (apqc-ext, discernment sense): discerns the responsible party; output is a Descriptive determination." ;
    skos:example "The team determines which of several applicable warranties bears settlement responsibility." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RootCauseAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResponsiblePartyDetermination ] .

ex:P20102 a owl:Class ;
    ex:pcfID "20102" ; ex:hierarchyID "6.3.2.5" ;
    ex:apqcSourceText "Authorizing claims prior to submittal." ;
    rdfs:label "Manage pre-authorizations" ;
    skos:definition "A Planned Act that grants preliminary authorization of a warranty claim prior to its formal submittal, producing a claim pre-authorization." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): issuing an authorization is a prescriptive act whose output is a Directive ICE; it is not analysis, appraisal, or planning. Despite the 'Manage' label the description denotes a bounded authorization act, so it is a process (not an Organization Capability)." ;
    skos:example "A supervisor pre-authorizes a claim so it can be submitted for settlement." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ClaimPreAuthorization ] .

ex:P12668 a owl:Class ;
    ex:pcfID "12668" ; ex:hierarchyID "6.3.2.6" ;
    ex:apqcSourceText "Following Defining issue [20098], an approval or rejection with be made against the warranty claim. If it is deemed that the claim falls within the warranty parameters, the claim will be approved. If the claim is deemed to fall outside warranty parameters, the claim with be rejected." ;
    rdfs:label "Approve or reject warranty claim" ;
    skos:definition "An Act of Selection that has as input a warranty claim validation and chooses between approval and rejection, producing a claim disposition." ;
    rdfs:comment "Genus ex:ActOfSelection (apqc-ext): chooses from a binary candidate set (approve/reject) and emits a Directive ClaimDisposition, agreeing with the GOLDEN PRINCIPLE." ;
    skos:example "The warranty team approves a claim found to be within warranty parameters." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyClaimValidation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ClaimDisposition ] .

ex:P20103 a owl:Class ;
    ex:pcfID "20103" ; ex:hierarchyID "6.3.2.7" ;
    ex:apqcSourceText "Contacting the originator of whether the warranty claim has been approved or rejected." ;
    rdfs:label "Notify originator of approve/reject decision" ;
    skos:definition "An Act of Communication that transfers the claim disposition to the claim originator." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): the approve/reject decision ICE is transferred to the originator. Participant ex:Customer where definitional." ;
    skos:example "The team emails the customer that their claim was approved." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ClaimDisposition ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P20104 a owl:Class ;
    ex:pcfID "20104" ; ex:hierarchyID "6.3.2.8" ;
    ex:apqcSourceText "Allowing for a payment to be made to the claimant." ;
    rdfs:label "Authorize payment" ;
    skos:definition "A Planned Act that permits a payment to be made to the claimant, producing a payment authorization." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): issuing a payment authorization is a prescriptive act with a Directive ICE output." ;
    skos:example "The team authorizes disbursement to a customer for an approved claim." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PaymentAuthorization ] .

ex:P20105 a owl:Class ;
    ex:pcfID "20105" ; ex:hierarchyID "6.3.2.9" ;
    ex:apqcSourceText "Archiving and closing the warranty claim after a final decision has been made to either approve or reject." ;
    rdfs:label "Close claim" ;
    skos:definition "An Act of Information Processing that archives a warranty claim after a final decision and produces a claim closure record." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): closing/archiving stores the claim record; output is a Descriptive closure record." ;
    skos:example "After payment, the claim file is archived and marked closed." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ClaimDisposition ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ClaimClosureRecord ] .

ex:P12667 a owl:Class ;
    ex:pcfID "12667" ; ex:hierarchyID "6.3.2.10" ;
    ex:apqcSourceText "Assuring that the warranty transaction has been completed." ;
    rdfs:label "Reconcile warranty transaction disposition" ;
    skos:definition "An Act of Appraisal that verifies a warranty transaction has been completed and produces a warranty transaction reconciliation." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): reconciliation evaluates the completeness/consistency of the transaction; Descriptive output." ;
    skos:example "Finance confirms the warranty payout and closure are consistent and complete." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WarrantyTransactionReconciliation ] .

ex:P20106 a owl:Class ;
    ex:pcfID "20106" ; ex:hierarchyID "6.3.3" ;
    ex:apqcSourceText "Managing the recovery of costs from suppliers for individual claims." ;
    rdfs:label "Manage supplier recovery" ;
    skos:definition "An Act of Resolution that recovers the costs of an individual claim from the responsible supplier, comprising raising and negotiating a supplier recovery claim." ;
    rdfs:comment "Scoped to 'individual claims', so bounded per claim (not a standing function); modeled as a process under ex:ActOfResolution. Its APQC children are process parts." ;
    skos:example "For a settled claim, the company raises a recovery claim and negotiates reimbursement from the supplier." ;
    rdfs:subClassOf ex:ActOfResolution ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierRecoveryClaim ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20107 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20108 ] .

ex:P20107 a owl:Class ;
    ex:pcfID "20107" ; ex:hierarchyID "6.3.3.1" ;
    ex:apqcSourceText "Raising a supplier recovery claim. This is based off the decision made in Receive investigation result/recommendation for corrective action [20100]." ;
    rdfs:label "Create supplier recovery claims" ;
    skos:definition "An Act of Information Processing that has as input a responsible party determination and has as output a supplier recovery claim." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): raising/recording a recovery claim produces a Descriptive SupplierRecoveryClaim, agreeing with the section vocab's descriptive typing of that ICE." ;
    skos:example "The team raises a recovery claim against the supplier of a defective part." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ResponsiblePartyDetermination ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplierRecoveryClaim ] .

ex:P20108 a owl:Class ;
    ex:pcfID "20108" ; ex:hierarchyID "6.3.3.2" ;
    ex:apqcSourceText "Arranging the returns of recalled products to suppliers." ;
    rdfs:label "Negotiate recoveries with suppliers" ;
    skos:definition "A Planned Act that negotiates cost recoveries with suppliers and arranges the return of recalled products, producing a return authorization." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): negotiating/arranging is a prescriptive coordination act, not analysis or appraisal. Operations category: the returned product is a Material Entity participant (obo:BFO_0000057); the arrangement is a Directive ReturnAuthorization. Participant ex:Supplier where definitional." ;
    skos:example "The company arranges with the supplier to return recalled units and recover their cost." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ReturnAuthorization ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ReturnedProduct ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Supplier ] .

ex:P10218 a owl:Class ;
    ex:pcfID "10218" ; ex:hierarchyID "6.3.4" ;
    ex:apqcSourceText "Validating specific service requirements for individual customers. Determine and schedule resource to fulfill these requirements. Provide service to specific individual customers. Ensure the quality of service delivery." ;
    rdfs:label "Service products" ;
    skos:definition "An Act of Service Provision that validates a customer's service requirements, schedules resources, renders the service, and assures its quality." ;
    rdfs:comment "Genus ex:ActOfServiceProvision (operations shared genus): bounded end-to-end service delivery. Its APQC children are process parts." ;
    skos:example "A field-service operation confirms requirements, schedules a technician, performs the repair, and follows up on quality." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10320 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10321 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10322 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10323 ] .

ex:P10320 a owl:Class ;
    ex:pcfID "10320" ; ex:hierarchyID "6.3.4.1" ;
    ex:apqcSourceText "Acquiring or soliciting information about specific service requirements for individual customers through the customer service function. Obtain information about customer specific requests, process these requests, and create customer profiles to generate a service order." ;
    rdfs:label "Confirm specific service requirements for individual customer" ;
    skos:definition "An Act of Appraisal that validates and confirms an individual customer's stated service requirements and produces an individual service requirement record." ;
    rdfs:comment "Re-anchored to cco:ont00000636 (Act of Appraisal) and re-targeted output per Gate-F review. (1) OUTPUT: now ex:IndividualServiceRequirement (a newly minted Descriptive, individual-scope ICE) REPLACING the prior ex:CustomerServiceRequirementSpecification, which is DEFINED as the enterprise-wide Directive output of 6.1.1 'a Directive ICE that prescribes the behaviors, skills, and policies required to provide customer service across an enterprise'; reusing that enterprise policy as the output of an individual-customer confirmation act was a category error. The enterprise spec is retained as a Directive has input that constrains the act. (2) GENUS: the source verb is 'Acquiring or soliciting... validating/confirming' an individual customer's stated needs, i.e. information-processing/appraisal of stated requirements, not Formulation (composing a binding directive plan); the Appraisal genus yields the Descriptive individual requirement record, satisfying the GOLDEN PRINCIPLE. Its APQC children are process parts." ;
    skos:example "An agent gathers and validates a customer's repair needs and records the confirmed individual requirements." ;
    rdfs:subClassOf cco:ont00000636 ,   # Act of Appraisal
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ServiceRequest ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerServiceRequirementSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IndividualServiceRequirement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10324 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10325 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10326 ] .

ex:P10324 a owl:Class ;
    ex:pcfID "10324" ; ex:hierarchyID "6.3.4.1.1" ;
    ex:apqcSourceText "Soliciting or acquiring information using various sources such as databases, customer interactions, and customer request forms. Hand them further up the hierarchy to deal with them. Categorize the user's request, determining if the request is supportable and prioritizing the request." ;
    rdfs:label "Process customer request" ;
    skos:definition "An Act of Analysis that has as input a service request and has as output an inquiry analysis that categorizes and prioritizes the request." ;
    rdfs:comment "Genus ex:ActOfAnalysis: categorizing/prioritizing a request is information processing producing a Descriptive analysis." ;
    skos:example "An agent classifies an incoming request as supportable and high priority." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ServiceRequest ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InquiryAnalysis ] .

ex:P10325 a owl:Class ;
    ex:pcfID "10325" ; ex:hierarchyID "6.3.4.1.2" ;
    ex:apqcSourceText "Documenting the individual customer service requirements solicited, along with personal information of the customers, in order to generate customized profiles that hasten the delivery process." ;
    rdfs:label "Create customer profile" ;
    skos:definition "An Act of Information Processing that documents an individual customer's requirements and personal information and produces a customer profile." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): documenting/storing customer data; output is a Descriptive CustomerProfile." ;
    skos:example "An agent builds a profile capturing the customer's equipment and service history." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerProfile ] .

ex:P10326 a owl:Class ;
    ex:pcfID "10326" ; ex:hierarchyID "6.3.4.1.3" ;
    ex:apqcSourceText "Designing a short-term agreement between the service provider and customer. One-time services are ordered by the service recipient and resource-related billing is performed upon completion. Use the service order to document service and customer service work." ;
    rdfs:label "Generate service order" ;
    skos:definition "An Act of Formulation that designs a short-term service agreement and produces a service order." ;
    rdfs:comment "Genus ex:ActOfFormulation (apqc-ext): composing the service agreement yields a Directive ServiceOrder." ;
    skos:example "An agent creates a service order specifying the one-time repair to be performed." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerServiceRequirementSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceOrder ] .

ex:P10321 a owl:Class ;
    ex:pcfID "10321" ; ex:hierarchyID "6.3.4.2" ;
    ex:apqcSourceText "Determining and scheduling the resources required to fulfill customer service requirements. Create a detailed schedule about the service orders and development of these service orders." ;
    rdfs:label "Identify and schedule resources to meet service requirements" ;
    skos:definition "An Act of Scheduling that determines and allocates the resources required to fulfill service requirements and produces a resourcing plan and a service order fulfillment schedule." ;
    rdfs:comment "Genus ex:ActOfScheduling (PROPOSE-EXT): allocates resources over time; Directive outputs. Its APQC children are process parts." ;
    skos:example "A planner sizes the crew and equipment needed and lays out the fulfillment schedule." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ServiceOrder ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResourcingPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceOrderFulfillmentSchedule ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10327 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10328 ] .

ex:P10327 a owl:Class ;
    ex:pcfID "10327" ; ex:hierarchyID "6.3.4.2.1" ;
    ex:apqcSourceText "Developing a plan for sourcing and deploying the resources required to fulfill customer service needs. Document a detailed summary of all types of resources (equipment, finance, personnel, time, etc.) required to complete customer service requests and procure these resources. Identify and assess various sources in order to effectively create a resourcing plan." ;
    rdfs:label "Create resourcing plan and schedule" ;
    skos:definition "An Act of Scheduling that develops a plan for sourcing and deploying service resources and produces a resourcing plan." ;
    rdfs:comment "Genus ex:ActOfScheduling (PROPOSE-EXT): allocates resource types and timing; Directive ResourcingPlan output." ;
    skos:example "A planner documents the equipment, personnel, and timing needed to deliver the service." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResourcingPlan ] .

ex:P10328 a owl:Class ;
    ex:pcfID "10328" ; ex:hierarchyID "6.3.4.2.2" ;
    ex:apqcSourceText "Designing a detailed summary of customer service order requirements, along with information concerning the timing and duration for these services. Categorize the customer needs. Monitor the services delivered." ;
    rdfs:label "Create service order fulfillment schedule" ;
    skos:definition "An Act of Scheduling that designs the timing and duration of customer service orders and produces a service order fulfillment schedule." ;
    rdfs:comment "Genus ex:ActOfScheduling (PROPOSE-EXT): fixes timing/duration of service orders; Directive output." ;
    skos:example "A planner sequences each service order with its expected timing and duration." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceOrderFulfillmentSchedule ] .

ex:P10322 a owl:Class ;
    ex:pcfID "10322" ; ex:hierarchyID "6.3.4.3" ;
    ex:apqcSourceText "Dispatching resources for managing and fulfilling daily service requirements. Manage the progress of order fulfillment. Complete order blocks." ;
    rdfs:label "Provide service to specific customers" ;
    skos:definition "An Act of Service Provision that dispatches resources and carries out the daily service orders to fulfill customers' service requirements." ;
    rdfs:comment "Genus ex:ActOfServiceProvision: the rendering/execution of the service. Its APQC children are process parts." ;
    skos:example "A dispatcher sends technicians to complete the day's scheduled repairs." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ServiceOrder ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10330 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10331 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10332 ] .

ex:P10330 a owl:Class ;
    ex:pcfID "10330" ; ex:hierarchyID "6.3.4.3.1" ;
    ex:apqcSourceText "Laying out a daily plan of specific service orders that need to be fulfilled. Document and systematically order these activities to ensure high effectiveness and efficiency." ;
    rdfs:label "Organize daily service order fulfillment schedule" ;
    skos:definition "An Act of Scheduling that lays out the daily plan of specific service orders to be fulfilled and produces a service order fulfillment schedule." ;
    rdfs:comment "Genus ex:ActOfScheduling (PROPOSE-EXT): sequences the day's service orders; Directive output." ;
    skos:example "A dispatcher sequences the technician's stops for the day." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceOrderFulfillmentSchedule ] .

ex:P10331 a owl:Class ;
    ex:pcfID "10331" ; ex:hierarchyID "6.3.4.3.2" ;
    ex:apqcSourceText "Dispatching and delivering the resources needed for the specific service requirements from the source/warehouse. Manage the dispatch, transportation, and delivery of the services." ;
    rdfs:label "Dispatch and deliver service resources" ;
    skos:definition "An Act of Service Provision that dispatches, transports, and delivers from the source or warehouse the resources needed to fulfil specific service requirements." ;
    rdfs:comment "Re-anchored to ex:ActOfServiceProvision (operations delivery genus, consistent with parent P10322 'Provide service to specific customers') per Gate-F review. The verbatim apqcSourceText describes a LOGISTICS/DISPATCH act, not a repair: 'Dispatching and delivering the resources needed for the specific service requirements from the source/warehouse. Manage the dispatch, transportation, and delivery of the services.' There is NO mention of modifying/repairing a product. REJECTED the prior cco:ont00000950 (Act of Maintenance) anchor as a label-vs-source false friend that Gates A-D cannot catch: maintenance restores a Material Artifact's designed qualities, which the description never describes. The prior rdfs:label 'Execute product repair' did not match the dispatch/delivery source text and has been corrected to match the source; the ex:DefectiveProduct material participant (a repair artifact) is replaced by the field service agent who performs the dispatch/delivery. If APQC truly intends repair here, this label/description discrepancy should be confirmed with the domain owner before reverting to Act of Maintenance." ;
    skos:example "A dispatcher releases the parts and equipment from the warehouse and routes a field service agent to deliver them for the day's service orders." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FieldServiceAgent ] .

ex:P10332 a owl:Class ;
    ex:pcfID "10332" ; ex:hierarchyID "6.3.4.3.3" ;
    ex:apqcSourceText "Handling and managing orders fulfilled, along with the orders are not or partially fulfilled to track the order fulfillment progress. Use electronic devices such as trackers and GPS in order track and ensure delivery of the orders." ;
    rdfs:label "Manage service order fulfillment" ;
    skos:definition "An Act of Monitoring that tracks the fulfillment progress of service orders and produces a service order fulfillment status." ;
    rdfs:comment "Genus ex:ActOfMonitoring (PROPOSE-EXT): ongoing tracking of order progress yields a Descriptive status report. Despite the 'Manage' label the description denotes a bounded, repeatable tracking act, so it is a process." ;
    skos:example "A coordinator uses GPS trackers to monitor which service orders are delivered." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ServiceOrder ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceOrderFulfillmentStatus ] .

ex:P10323 a owl:Class ;
    ex:pcfID "10323" ; ex:hierarchyID "6.3.4.4" ;
    ex:apqcSourceText "Guaranteeing the quality of service provided to customers. Identify the successful and unsuccessful orders along with the service failures. Collect customer feedback. Process the feedback to ensure the quality of service in the future." ;
    rdfs:label "Ensure quality of service" ;
    skos:definition "An Act of Appraisal that evaluates the quality of service delivered to customers and produces a service quality assessment." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): judges service quality. Its APQC children are process parts." ;
    skos:example "A quality lead reviews completed and failed orders and customer feedback to rate service quality." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceQualityAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10334 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10335 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10336 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10337 ] .

ex:P10334 a owl:Class ;
    ex:pcfID "10334" ; ex:hierarchyID "6.3.4.4.1" ;
    ex:apqcSourceText "Determining the service orders that have been successfully delivered. Identify the service orders completed and delivered to the customer. Leverage communication systems to ensure coordination with the customers in order to avoid mishaps." ;
    rdfs:label "Identify completed service orders for feedback" ;
    skos:definition "An Act of Identification that discerns the service orders successfully completed and delivered and produces a completed service order register." ;
    rdfs:comment "Genus ex:ActOfIdentification (apqc-ext, discernment sense): enumerates the completed orders; Descriptive register output." ;
    skos:example "A team lists the orders confirmed delivered to solicit feedback on them." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ServiceOrderFulfillmentStatus ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompletedServiceOrderRegister ] .

ex:P10335 a owl:Class ;
    ex:pcfID "10335" ; ex:hierarchyID "6.3.4.4.2" ;
    ex:apqcSourceText "Determining orders which have not been completed or delivered. Identify the service orders that are partially or entirely incomplete, as well as the orders that have not been delivered to the customer. Use techniques such as project trackers to recognize the progress of the service orders." ;
    rdfs:label "Identify incomplete service orders and service failures" ;
    skos:definition "An Act of Identification that discerns the partially or entirely incomplete service orders and service failures and produces an incomplete service order register." ;
    rdfs:comment "Genus ex:ActOfIdentification (apqc-ext, discernment sense): enumerates incomplete orders/failures; Descriptive register output." ;
    skos:example "A team lists undelivered and failed orders for follow-up." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ServiceOrderFulfillmentStatus ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IncompleteServiceOrderRegister ] .

ex:P10336 a owl:Class ;
    ex:pcfID "10336" ; ex:hierarchyID "6.3.4.4.3" ;
    ex:apqcSourceText "Obtaining and procuring customer reviews or feedback on the services delivered. Design a customer feedback form, or communicate with the customer through the phone or online." ;
    rdfs:label "Solicit customer feedback on services delivered" ;
    skos:definition "An Act of Communication that obtains customer feedback on the services delivered." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): the customer-feedback ICE is transferred from the customer to the organization. Participant ex:Customer where definitional." ;
    skos:example "An agent calls the customer to collect feedback after a repair." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P10337 a owl:Class ;
    ex:pcfID "10337" ; ex:hierarchyID "6.3.4.4.4" ;
    ex:apqcSourceText "Assessing and incorporating customer reviews/feedback into the service plan to ensure high quality of service." ;
    rdfs:label "Process customer feedback on services delivered" ;
    skos:definition "An Act of Appraisal that has as input customer feedback and has as output an improvement opportunity analysis for the service plan." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): assessing feedback to judge improvement opportunities; Descriptive output." ;
    skos:example "A team reviews survey results and identifies improvements to the service plan." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementOpportunityAnalysis ] .

####################################################################
# ===== GROUP 6.4  "Manage product recalls and regulatory audits" (PCF 20110) =====
# Bounded end-to-end recall-execution occurrent (Planned Act). The
# standing 'Manage...' reading is carried by ex:RecallManagementCapability
# (declared in 2.3), realized in ex:P20110 (R6).
####################################################################

ex:P20110 a owl:Class ;
    ex:pcfID "20110" ; ex:hierarchyID "6.4" ;
    ex:apqcSourceText "Removing defective products from the distribution chain. Participate in audits from watchdog agencies." ;
    rdfs:label "Manage product recalls and regulatory audits" ;
    skos:definition "A Planned Act in which an Organization removes defective products from the distribution chain and participates in audits by regulatory authorities, comprising the initiation, hazard assessment, communication, regulatory reporting, effectiveness monitoring, and termination of a product recall." ;
    rdfs:comment "Models APQC process group 6.4 as a bounded end-to-end recall-execution occurrent. Its APQC children are process parts (cco:ont00001777), not subclasses. The standing-function 'Manage...' reading is carried by shared ex:RecallManagementCapability (Organization Capability), which is realized in this process (R6). Anchored at the generic cco:ont00000228 (Planned Act) because the group aggregates heterogeneous sub-acts (planning, appraisal, communication) under no single narrower CCO Act." ;
    skos:example "A manufacturer's end-to-end campaign to recall a defective product batch, from issuing the recall through filing closing reports with the regulator." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20111 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20112 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20113 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20114 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20115 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20116 ] .

ex:P20111 a owl:Class ;
    ex:pcfID "20111" ; ex:hierarchyID "6.4.1" ;
    ex:apqcSourceText "Commencing the removal process of defective products." ;
    rdfs:label "Initiate recall" ;
    skos:definition "A Planned Act that commences the removal of a defective product from the distribution chain by applying the standing recall strategy, producing a recall initiation record." ;
    rdfs:comment "Re-anchored to the generic cco:ont00000228 (Planned Act) per Gate-F review: the source verb 'Commencing the removal process of defective products' denotes LAUNCHING/triggering an action, not composing a directive document. REJECTED the prior ex:ActOfFormulation (cco:ont00000511 Act of Planning) anchor with has output some ex:RecallStrategy: ex:RecallStrategy is ALREADY the asserted has output of P20092 'Develop recall strategy' (6.1.7), so two distinct process classes asserting has output some <same Directive ICE> double-produces the artifact and mis-genuses a launch/trigger act as a planning act. An initiation act CONSUMES/applies the standing strategy and launches the operational removal. Fix: has input some ex:RecallStrategy (the pre-existing strategy from 6.1.7 is applied) plus a Descriptive has output some ex:RecallInitiationRecord (recording that the recall was commenced). The defective product remains the material input (operations category permits material I/O)." ;
    skos:example "A quality team applies the recall strategy to activate removal of a defective product lot from distributors and records that the recall has commenced." ;
    rdfs:subClassOf cco:ont00000228 ,   # Planned Act
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DefectiveProduct ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RecallStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RecallInitiationRecord ] .

ex:P20112 a owl:Class ;
    ex:pcfID "20112" ; ex:hierarchyID "6.4.2" ;
    ex:apqcSourceText "Performing risk analysis. Identify all dangers, evaluate how probable they are, and what kinds of negative results or or adverse side effect they carry." ;
    rdfs:label "Assess the likelihood and consequences of occurrence of any hazards" ;
    skos:definition "An Act of Appraisal that evaluates the dangers associated with a defective product, judging their probability and consequences, and produces a hazard risk assessment." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): the act evaluates and judges hazards. Output is a Descriptive ICE (a judgement), satisfying the GOLDEN PRINCIPLE (appraisal -> descriptive)." ;
    skos:example "A safety engineer assesses the burn-hazard probability and severity of a recalled appliance and issues a hazard risk assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HazardRiskAssessment ] .

ex:P20113 a owl:Class ;
    ex:pcfID "20113" ; ex:hierarchyID "6.4.3" ;
    ex:apqcSourceText "Handling communications that are related to product recalls." ;
    rdfs:label "Manage recall related communications" ;
    skos:definition "An Act of Communication in which an Agent handles and transfers information related to a product recall and produces a recall communication." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication) because the act consists of transferring recall-related ICEs among parties. Output is a Descriptive ICE (the communication content). Despite the 'Manage' label, the description denotes a bounded communication occurrent." ;
    skos:example "A communications team issues recall notices and responds to inquiries, producing recall communications for customers and retailers." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RecallCommunication ] .

ex:P20114 a owl:Class ;
    ex:pcfID "20114" ; ex:hierarchyID "6.4.4" ;
    ex:apqcSourceText "Creating and delivering reports to regulatory agencies to provide details about handling product recalls." ;
    rdfs:label "Submit regulatory reports" ;
    skos:definition "An Act of Communication in which an Agent creates and delivers a regulatory incident report to a regulatory body to detail the handling of a product recall." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): a report (an ICE) is transferred from the organization to a regulatory authority. The Regulatory Body is a definitional participant (recipient)." ;
    skos:example "A compliance officer files a recall incident report with the consumer-safety regulator." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryIncidentReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryBody ] .

ex:P20115 a owl:Class ;
    ex:pcfID "20115" ; ex:hierarchyID "6.4.5" ;
    ex:apqcSourceText "Analyzing the effectiveness of product recalls." ;
    rdfs:label "Monitor and audit recall effectiveness" ;
    skos:definition "An Act of Monitoring that examines the performance of an ongoing product recall and produces a recall effectiveness assessment." ;
    rdfs:comment "Anchored under ex:ActOfMonitoring (PROPOSE-EXT). The act analyzes/audits effectiveness over time and yields a Descriptive ICE, satisfying the GOLDEN PRINCIPLE (information-processing -> descriptive)." ;
    skos:example "An auditor tracks the return rate of a recalled batch and reports the recall's effectiveness." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RecallEffectivenessAssessment ] .

ex:P20116 a owl:Class ;
    ex:pcfID "20116" ; ex:hierarchyID "6.4.6" ;
    ex:apqcSourceText "Ending product recalls, communicating to the public and filing reports." ;
    rdfs:label "Manage recall termination" ;
    skos:definition "An Act of Resolution that brings a product recall to a definite close by communicating its conclusion to the public and filing the closing regulatory reports." ;
    rdfs:comment "Anchored under ex:ActOfResolution (PROPOSE-EXT, reconciled to cco:ont00000228 Planned Act). The public communication and report filing are sub-acts of concluding the recall; both outputs are recorded as definitional (a recall communication and a regulatory incident report)." ;
    skos:example "A recall coordinator closes out a recall, issues a public termination notice, and files the final report with the regulator." ;
    rdfs:subClassOf ex:ActOfResolution ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RecallCommunication ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryIncidentReport ] .

####################################################################
# ===== GROUP 6.5  "Evaluate customer service operations and customer
#                    satisfaction" (PCF 20595) =====
# Bounded appraisal cycle (R5: not a never-ending standing function).
####################################################################

ex:P20595 a owl:Class ;
    ex:pcfID "20595" ; ex:hierarchyID "6.5" ;
    ex:apqcSourceText "Calculating and assessing the operational activities of the customer service function. Evaluation is achieved through the customer requests/inquiries handling process, the customer complaint handling process, and product and services quality. Examine activities to ensure high levels of customer service." ;
    rdfs:label "Evaluate customer service operations and customer satisfaction" ;
    skos:definition "An Act of Appraisal that assesses the operational activities of an organization's customer service function and produces a customer satisfaction assessment of customer service operations." ;
    rdfs:comment "Models APQC process group 6.5 as a bounded occurrent (R5: an appraisal cycle, not a never-ending standing function). Its APQC children are process parts (cco:ont00001777), not subclasses. Anchored to cco:ont00000636 (Act of Appraisal): the verb 'evaluate/assess' yields a Descriptive judgement (GOLDEN PRINCIPLE: appraisal -> descriptive)." ;
    skos:example "A customer-service organization runs its annual review of inquiry-, complaint-, and product-satisfaction performance and issues an overall satisfaction assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerSatisfactionAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10401 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10402 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10403 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12672 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20121 ] .

ex:P10401 a owl:Class ;
    ex:pcfID "10401" ; ex:hierarchyID "6.5.1" ;
    ex:apqcSourceText "Calculating satisfaction levels of customers by effectively evaluating the process of handling requests/inquiries of customers. Effectively calculate the performance of customer-requests/inquiries handling and resolution. Obtain information regarding requests/inquiries handling and resolution through customer feedback. Use it to explore new ideas and opportunities for enhanced customer requests/inquiries handling and resolution process." ;
    rdfs:label "Measure customer satisfaction with customer problems, requests, and inquiries handling" ;
    skos:definition "An Act of Appraisal that evaluates how customer requests and inquiries are handled and resolved and produces a customer satisfaction assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges satisfaction/performance and yields the Descriptive ex:CustomerSatisfactionAssessment (GOLDEN PRINCIPLE). Customer feedback is a typical input gathered by its child 6.5.1.1, so it is recorded here as commentary rather than a definitional has-input restriction." ;
    skos:example "A contact-centre quality team calculates satisfaction with how inquiries were resolved last quarter and reports the result." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerSatisfactionAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11687 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11688 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18126 ] .

ex:P11687 a owl:Class ;
    ex:pcfID "11687" ; ex:hierarchyID "6.5.1.1" ;
    ex:apqcSourceText "Creating an avenue for which the customer can provide feedback on their experience with how their inquiry, problem, or request was handled." ;
    rdfs:label "Solicit customer feedback on customer service experience" ;
    skos:definition "An Act of Information Processing that engages the customer to elicit and collect customer feedback about their customer service experience." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): the act elicits, receives, and stores input ICEs (customer feedback) rather than rendering a value judgement; its definitional output is the Descriptive ex:CustomerFeedback (GOLDEN PRINCIPLE: information-processing -> descriptive). The Customer participates (has participant)." ;
    skos:example "A service desk emails a short post-resolution survey inviting the customer to rate the handling of their request." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P11688 a owl:Class ;
    ex:pcfID "11688" ; ex:hierarchyID "6.5.1.2" ;
    ex:apqcSourceText "Reviewing customer service feedback to identify areas in which improvements can be made. Engage with management to discuss issues." ;
    rdfs:label "Analyze customer service data and identify improvement opportunities" ;
    skos:definition "An Act of Analysis that has as input customer feedback and has as output an improvement opportunity analysis of the customer service function." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (shared genus, cco:ont00000366): it examines feedback ICEs and produces an understanding of where service can improve; its definitional output is the Descriptive ex:ImprovementOpportunityAnalysis. Management is a typical participant (commentary), not definitional." ;
    skos:example "An analyst reviews survey responses and writes up the top three areas where inquiry handling can be improved." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementOpportunityAnalysis ] .

ex:P18126 a owl:Class ;
    ex:pcfID "18126" ; ex:hierarchyID "6.5.1.3" ;
    ex:apqcSourceText "Handing over data to management to analyze common issues in regards to customer service." ;
    rdfs:label "Provide customer feedback to product management on customer service experience" ;
    skos:definition "An Act of Communication in which customer feedback on the customer service experience is transferred to the product management team for downstream analysis." ;
    rdfs:comment "Re-anchored to cco:ont00000402 (Act of Communication) per Gate-F review: the act is a DIRECTED hand-off of an ICE to a named recipient (ex:ProductManagementTeam), prototypically an Act of Communication. REJECTED the prior generic cco:ont00000366 (Act of Information Processing) anchor as inconsistent with the section's own treatment of structurally identical 'deliver-to-recipient' acts (e.g. ex:InquiryResponse via Act of Representative Communication; Act of Communication is verified-and-available in the module header): anchoring one directed ICE transfer under Communication and another under generic Information Processing drops the directedness (who the ICE is conveyed TO). The Descriptive output ex:CustomerFeedback is retained (the GOLDEN PRINCIPLE still holds: communication of a Descriptive ICE). The same anchor is applied to P11241 so all directed-handoff rows in 6.5 are consistent with 6.2's Respond pattern." ;
    skos:example "A service lead forwards the consolidated customer-service feedback file to the product management team." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductManagementTeam ] .

ex:P10402 a owl:Class ;
    ex:pcfID "10402" ; ex:hierarchyID "6.5.2" ;
    ex:apqcSourceText "Measuring the satisfaction level of customers as pertains to how their complaints are handled and resolved. This process element requires the organization to estimate the customers level of fulfillment with the process reconciling their complaints and towards the objective of ensuring customer retention. The feedback received can be used to develop concepts for new opportunities to boost the level of customer satisfaction." ;
    rdfs:label "Measure customer satisfaction with customer-complaint handling and resolution" ;
    skos:definition "An Act of Appraisal that evaluates how customer complaints are handled and resolved and produces a customer satisfaction assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it estimates the customers' level of fulfilment and yields the Descriptive ex:CustomerSatisfactionAssessment (GOLDEN PRINCIPLE)." ;
    skos:example "A complaints-management team measures how satisfied customers were with the resolution of their complaints to support retention." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerSatisfactionAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11236 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11237 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11689 ] .

ex:P11236 a owl:Class ;
    ex:pcfID "11236" ; ex:hierarchyID "6.5.2.1" ;
    ex:apqcSourceText "Requesting customer feedback on the process of handling and resolving customer complaints. Obtain information about the effectiveness and performance of the customer complaint handling process from the customers through various means (e.g., online and by phone)." ;
    rdfs:label "Solicit customer feedback on complaint handling and resolution" ;
    skos:definition "An Act of Information Processing that engages the customer to elicit and collect customer feedback on how complaints are handled and resolved." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): it requests, receives, and stores input ICEs (customer feedback); definitional output is the Descriptive ex:CustomerFeedback. The Customer participates (has participant)." ;
    skos:example "An agent invites the customer by phone and email to rate how their complaint was resolved." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P11237 a owl:Class ;
    ex:pcfID "11237" ; ex:hierarchyID "6.5.2.2" ;
    ex:apqcSourceText "Examining the information obtained through handling and resolving complaints for development/improvement opportunities. Categorize the customer complaints data on the basis of speed, accuracy, courtesy, price, product choice, availability, hours, location, etc. Determine complaint patterns in order to diagnose areas needing enhancement." ;
    rdfs:label "Analyze customer complaint data and identify improvement opportunities" ;
    skos:definition "An Act of Analysis that has as input customer complaints and has as output an improvement opportunity analysis of the complaint handling process." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (shared genus, cco:ont00000366): it categorizes and examines complaint data to discern improvement opportunities; definitional output is the Descriptive ex:ImprovementOpportunityAnalysis. Input modeled as ex:CustomerComplaint (the lodged complaint records being examined)." ;
    skos:example "An analyst categorizes complaints by speed and accuracy and reports which areas most need enhancement." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerComplaint ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementOpportunityAnalysis ] .

ex:P11689 a owl:Class ;
    ex:pcfID "11689" ; ex:hierarchyID "6.5.2.3" ;
    ex:apqcSourceText "Determining complaint patterns in order to identify common issues. Document common problems for correction." ;
    rdfs:label "Identify common customer complaints" ;
    skos:definition "An Act of Identification that has as input customer complaints and has as output a complaint analysis registering the recurrent complaint patterns and common problems discerned." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (shared genus, cco:ont00000366, discernment sense): it discerns and registers which complaints recur, rather than rendering a value judgement; definitional output is the Descriptive ex:ComplaintAnalysis documenting the common problems." ;
    skos:example "A team groups recurring complaints and documents the most common problems for correction." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerComplaint ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ComplaintAnalysis ] .

ex:P10403 a owl:Class ;
    ex:pcfID "10403" ; ex:hierarchyID "6.5.3" ;
    ex:apqcSourceText "Calculating satisfaction levels of customers with products/services. Obtain customer feedback on products/services, as well as the effectiveness of the advertising campaigns. Examine this information to reach meaningful conclusions, which could then be used to enhance the customer service operations." ;
    rdfs:label "Measure customer satisfaction with products and services" ;
    skos:definition "An Act of Appraisal that evaluates customers' satisfaction with an organization's products and services and produces a customer satisfaction assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it calculates and judges satisfaction levels and yields the Descriptive ex:CustomerSatisfactionAssessment (GOLDEN PRINCIPLE)." ;
    skos:example "A voice-of-customer team calculates post-sale product satisfaction and draws conclusions to improve service operations." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerSatisfactionAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11238 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11239 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20117 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11240 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11241 ] .

ex:P11238 a owl:Class ;
    ex:pcfID "11238" ; ex:hierarchyID "6.5.3.1" ;
    ex:apqcSourceText "Obtaining customer feedback/review on the quality and utility derived from the products/services after the sale is complete. Use techniques such as surveys, feedback boxes, and user activity and usability tests." ;
    rdfs:label "Gather and solicit post-sale customer feedback on products and services" ;
    skos:definition "An Act of Information Processing that engages the customer after sale to elicit and collect customer feedback on the quality and utility of products and services." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): it gathers/receives input ICEs (customer feedback) via surveys and usability tests; definitional output is the Descriptive ex:CustomerFeedback. The Customer participates (has participant)." ;
    skos:example "A team runs a post-purchase survey and usability test to collect feedback on a product's utility." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P11239 a owl:Class ;
    ex:pcfID "11239" ; ex:hierarchyID "6.5.3.2" ;
    ex:apqcSourceText "Assessing the influence of advertisements on purchasing behavior. Use techniques such as surveys and product recognition tests, questionnaires or feedback flyers, and toll-free numbers in order to encourage customer interaction after the sale." ;
    rdfs:label "Solicit post-sale customer feedback on ad effectiveness" ;
    skos:definition "An Act of Appraisal that assesses the influence of advertisements on customers' purchasing behavior and produces an ad effectiveness assessment." ;
    rdfs:comment "Re-anchored to cco:ont00000636 (Act of Appraisal) per Gate-F review: the APQC Element Description LEADS with an appraisal verb -- 'Assessing the influence of advertisements on purchasing behavior' -- and per Phase 1 the genus comes from the lead gerund ('Assessing' -> Appraisal), not the label verb 'Solicit'. REJECTED the prior cco:ont00000366 (Act of Information Processing, solicit/collect) anchor: it followed the label over the description and risked dropping the ad-effectiveness judgement entirely, since the deferred analysis sibling 6.5.3.4 is about product/service satisfaction generally, not ad influence specifically. Definitional output is the Descriptive ex:AdEffectivenessAssessment, satisfying the GOLDEN PRINCIPLE (appraisal -> descriptive). The surveys/questionnaires/toll-free numbers are the typical method of gathering the input feedback (commentary), and the customer participates." ;
    skos:example "A team uses product-recognition tests and survey responses to assess and report whether an ad campaign drove customers' purchases." ;
    rdfs:subClassOf cco:ont00000636 ,   # Act of Appraisal
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AdEffectivenessAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P20117 a owl:Class ;
    ex:pcfID "20117" ; ex:hierarchyID "6.5.3.3" ;
    ex:apqcSourceText "Engaging with the customer to understand their cross-channel experience. Find out what channels were effective and what areas need improvement." ;
    rdfs:label "Solicit customer feedback on cross-channel experience" ;
    skos:definition "An Act of Information Processing that engages the customer to elicit and collect customer feedback on their cross-channel service experience." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): it elicits and stores input ICEs (customer feedback) about channel effectiveness; definitional output is the Descriptive ex:CustomerFeedback. The Customer participates (has participant)." ;
    skos:example "A survey asks customers which channels (chat, phone, app) worked best for them and where they struggled." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P11240 a owl:Class ;
    ex:pcfID "11240" ; ex:hierarchyID "6.5.3.4" ;
    ex:apqcSourceText "Assessing the information collected on customer satisfaction levels with products/services in order to determine areas for improvement. Examine the data and information extracted from the customer feedback and reviews to measure the satisfaction levels of the customers. Identify opportunities that could enhance the customer satisfaction levels and the overall customer service strategy." ;
    rdfs:label "Analyze product and service satisfaction data and identify improvement opportunities" ;
    skos:definition "An Act of Analysis that has as input customer feedback and has as output an improvement opportunity analysis for products, services, and the customer service strategy." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (shared genus, cco:ont00000366): it examines collected feedback to discern where products/services and the service strategy can improve; definitional output is the Descriptive ex:ImprovementOpportunityAnalysis." ;
    skos:example "An analyst mines post-sale survey data and lists the improvement opportunities that would most raise satisfaction." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementOpportunityAnalysis ] .

ex:P11241 a owl:Class ;
    ex:pcfID "11241" ; ex:hierarchyID "6.5.3.5" ;
    ex:apqcSourceText "Providing feedback from customers on products/services to the product management team. Analyze information collected through Gather and solicit post-sale customer feedback on products/services [11238]. Share with the product management team for consideration while improving existing offerings or developing new products/services." ;
    rdfs:label "Provide feedback and insights to appropriate teams (product design/development, marketing, manufacturing)" ;
    skos:definition "An Act of Communication in which the insights derived from analyzing post-sale customer feedback are transferred to the product management team for consideration in improving or developing offerings." ;
    rdfs:comment "Re-anchored to cco:ont00000402 (Act of Communication) per Gate-F review, consistently with P18126: the act is a directed hand-off of an ICE to the named recipient ex:ProductManagementTeam (REJECTED the prior generic cco:ont00000366 Information Processing anchor, which dropped the directedness). OUTPUT corrected: the label promises 'feedback AND insights', so the definitional has output is ex:ImprovementOpportunityAnalysis (the 'insights' / analysis product) rather than the raw ex:CustomerFeedback, which is the analyzed input. The source de-conflates 'Analyze information collected through [11238]' (the analysis is performed by sibling P11240 6.5.3.4 producing ex:ImprovementOpportunityAnalysis) and 'Share with the product management team' (this communication act); this row models the share/transfer and conveys the insights. The cross-reference to 11238 is recorded in apqcSourceText only; precedence is not asserted as the text licenses only an informational hand-off." ;
    skos:example "A service analyst packages the improvement insights drawn from customer product feedback and shares them with product management for the next release planning." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit anchor: Act of Communication is a Planned Act in CCO; stated in-module so the standalone S2/S5 Act-anchor check resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementOpportunityAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductManagementTeam ] .

ex:P12672 a owl:Class ;
    ex:pcfID "12672" ; ex:hierarchyID "6.5.4" ;
    ex:apqcSourceText "Assessing the cost and effectiveness of warranties." ;
    rdfs:label "Evaluate and manage warranty performance" ;
    skos:definition "An Act of Appraisal that assesses the cost and effectiveness of an organization's warranties and produces a warranty performance report." ;
    rdfs:comment "R5: although the APQC label says 'manage', the Element Description ('Assessing the cost and effectiveness of warranties') is a bounded appraisal cycle, so it is modeled as a process, not a standing function. The standing 'manage warranty' capacity is already carried by the shared ex:WarrantyManagementCapability (R6) and is not re-minted here. Anchored to cco:ont00000636 (Act of Appraisal); definitional output is the Descriptive ex:WarrantyPerformanceReport (GOLDEN PRINCIPLE)." ;
    skos:example "A warranty team's periodic review of warranty cost and effectiveness culminating in a warranty performance report." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WarrantyPerformanceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20118 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12676 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20119 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12674 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20120 ] .

ex:P20118 a owl:Class ;
    ex:pcfID "20118" ; ex:hierarchyID "6.5.4.1" ;
    ex:apqcSourceText "Evaluating how satisfied customers are with how product warranties are managed and resolved." ;
    rdfs:label "Measure customer satisfaction with warranty handling and resolution" ;
    skos:definition "An Act of Appraisal that evaluates how satisfied customers are with how product warranties are handled and resolved and produces a customer satisfaction assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges customer satisfaction and yields the Descriptive ex:CustomerSatisfactionAssessment (GOLDEN PRINCIPLE)." ;
    skos:example "A warranty team surveys claimants and reports how satisfied they were with the warranty resolution." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerSatisfactionAssessment ] .

ex:P12676 a owl:Class ;
    ex:pcfID "12676" ; ex:hierarchyID "6.5.4.2" ;
    ex:apqcSourceText "Comparing warranties by using applicable metrics to see how they are handled and resolved. Develop and submit reports that summarize significant conclusions." ;
    rdfs:label "Monitor and report on warranty management metrics" ;
    skos:definition "An Act of Monitoring that tracks warranty management metrics over time and produces a warranty performance report summarizing significant conclusions." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (PROPOSE-EXT, cco:ont00000366): it repeatedly compares warranties against applicable metrics and reports status, rather than rendering a one-off value judgement; definitional output is the Descriptive ex:WarrantyPerformanceReport." ;
    skos:example "An analyst tracks warranty cost and resolution-time metrics each month and submits a summary report." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WarrantyPerformanceReport ] .

ex:P20119 a owl:Class ;
    ex:pcfID "20119" ; ex:hierarchyID "6.5.4.3" ;
    ex:apqcSourceText "Determining how warranties and warranty management can be made better and more efficient." ;
    rdfs:label "Identify improvement opportunities" ;
    skos:definition "An Act of Analysis that examines warranty management performance and produces an improvement opportunity analysis of how warranties and warranty management can be made better and more efficient." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (shared genus, cco:ont00000366): it examines warranty performance to discern improvement opportunities; definitional output is the Descriptive ex:ImprovementOpportunityAnalysis. Input (warranty performance report) is typical, recorded as commentary rather than a definitional restriction." ;
    skos:example "A warranty analyst studies the performance report and lists efficiency improvements for the warranty programme." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementOpportunityAnalysis ] .

ex:P12674 a owl:Class ;
    ex:pcfID "12674" ; ex:hierarchyID "6.5.4.4" ;
    ex:apqcSourceText "Finding ways to phase out unused or seldom used warranties." ;
    rdfs:label "Identify opportunities to eliminate warranty waste" ;
    skos:definition "An Act of Analysis that examines warranty usage and produces an improvement opportunity analysis identifying unused or seldom-used warranties that can be phased out." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (shared genus, cco:ont00000366): it examines usage to discern waste-elimination opportunities; definitional output is the Descriptive ex:ImprovementOpportunityAnalysis." ;
    skos:example "An analyst identifies seldom-claimed warranty types and recommends retiring them to cut waste." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementOpportunityAnalysis ] .

ex:P20120 a owl:Class ;
    ex:pcfID "20120" ; ex:hierarchyID "6.5.4.5" ;
    ex:apqcSourceText "Reviewing and assessing claims that contain deliberately incorrect information or that have been submitted with the goal to deceive the system." ;
    rdfs:label "Investigate fraudulent claims" ;
    skos:definition "An Act of Appraisal that has as input warranty claims and has as output a fraudulent claim assessment judging whether a claim contains deliberately incorrect or deceptive information." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it reviews and judges the legitimacy of claims; definitional output is the Descriptive ex:FraudulentClaimAssessment (GOLDEN PRINCIPLE). Input modeled as ex:WarrantyClaim (the claims under investigation)." ;
    skos:example "A claims investigator reviews a suspicious warranty claim and records an assessment that it is fraudulent." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WarrantyClaim ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FraudulentClaimAssessment ] .

ex:P20121 a owl:Class ;
    ex:pcfID "20121" ; ex:hierarchyID "6.5.5" ;
    ex:apqcSourceText "Reviewing customer service feedback to identify areas in which improvements can be made. Engage with management to discuss issues." ;
    rdfs:label "Evaluate recall performance" ;
    skos:definition "An Act of Appraisal that evaluates the performance of an organization's product recalls and produces a recall effectiveness assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the label verb 'Evaluate recall performance' judges recall performance and yields the Descriptive ex:RecallEffectivenessAssessment (GOLDEN PRINCIPLE; that ICE being Descriptive is the intended appraisal output, so the principle holds). Per Gate-F review: the apqcSourceText for 20121 is shared BOILERPLATE, verbatim IDENTICAL to P11688 (6.5.1.2) -- 'Reviewing customer service feedback to identify areas in which improvements can be made. Engage with management to discuss issues.' -- which describes an analyze/identify-improvement act and was correctly anchored at ex:ActOfAnalysis with output ex:ImprovementOpportunityAnalysis. Here the boilerplate is OVERRIDDEN by the label per the spec's boilerplate provision, so 20121 is engineered as a recall-performance appraisal rather than trusting the mismatched description; this divergence from P11688 is therefore deliberate, not an inconsistency. FLAGGED for APQC source-data correction: the 20121 Element Description should be replaced with recall-specific text so the description is not silently trusted. Customer feedback is a typical input, recorded as commentary rather than a definitional restriction." ;
    skos:example "A product-safety team evaluates how effective a recent recall was at reaching affected customers and reports its findings." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RecallEffectivenessAssessment ] .

