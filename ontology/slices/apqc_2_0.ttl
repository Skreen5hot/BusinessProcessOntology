@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC PCF -> BFO 2020 / CCO  REALITY-LAYER MODULE  (slice 2.0)
# Section 2.0 "Develop and Manage Products and Services" (Category 10003)
#
# Single assembled module covering Category 2.0 and its process groups
# 2.1 (Govern and manage product/service development program),
# 2.2 (Generate and define new product/service ideas), and
# 2.3 (Develop products and services).
#
# Every cco:ont... IRI below was verified (label + definition + parent
# read, not just label) against vendor/cco/CommonCoreOntologiesMerged.ttl.
# Verified anchors used here:
#   Act of Planning            cco:ont00000511
#   Planned Act                cco:ont00000228
#   Act of Appraisal           cco:ont00000636
#   Act of Information Proc.    cco:ont00000366
#   Act of Training            cco:ont00000234
#   Descriptive ICE            cco:ont00000853
#   Prescriptive (Directive)   cco:ont00000965
#   Information Content Entity  cco:ont00000958
#   Agent                      cco:ont00001017
#   Organization               cco:ont00001180
#   Agent Capability           cco:ont00001379
#   Organization Capability    cco:ont00000568
#   Material Artifact          cco:ont00000995
#   is about                   cco:ont00001808
#   has input                  cco:ont00001921
#   has output                 cco:ont00001986
#   has process part           cco:ont00001777
#   has capability             cco:ont00001954
#   has participant            obo:BFO_0000057
#   bearer of                  obo:BFO_0000196
#   realized in (has realiz.)  obo:BFO_0000054
#   role                       obo:BFO_0000023
#   material entity            obo:BFO_0000040
#   entity                     obo:BFO_0000001
#   precedes                   obo:BFO_0000063
####################################################################

<http://example.org/apqc/slice/2.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 2.0: Develop and Manage Products and Services" ;
    dct:source "APQC Process Classification Framework (Cross-Industry), Category 2.0" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <http://example.org/apqc/ext> ;
    rdfs:comment "Reality-layer module for APQC section 2.0 (groups 2.1-2.3). CCO pin v2.0 (2024-11-06). Follows ADR-001 two-layer policy: this is the reality layer only; the curatorial catalog (skos) lives in apqc-catalog.ttl. Imports apqc-ext.ttl (shared act genera), which anchors under CCO (which imports BFO 2020). Category 2.0 and the three process groups are catalog-only at the Category level (R3); transformation begins at the process-group level. Validate offline alongside CommonCoreOntologiesMerged.ttl." .

####################################################################
# 0. ANNOTATION PROPERTIES (provenance + catalog->reality bridge)
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "ADR-001 R4 bridge: catalog node (ex:PCF_<id>, defined in apqc-catalog.ttl) -> reality-layer process universal or capability. Populated during reality-layer modeling, NOT by the catalog generator." .

####################################################################
# 1. NEW RECURRING ACT GENERA (PROPOSE-EXT)
#    Minted locally so the section's processes can anchor now; each is
#    flagged for human promotion into apqc-ext.ttl after review. Reused
#    ext genera (ActOfAnalysis, ActOfIdentification, ActOfFormulation,
#    ActOfSelection, ActOfAcquisition) come via the apqc-ext.ttl merge.
#    Reconciled to ONE coherent definition each (the supporting-vocab
#    canonical forms): development spans informational AND material
#    outputs (e.g. building a material prototype in 2.3.1.9), so it is
#    anchored at the generic Planned Act, not at Act of Planning.
####################################################################

####################################################################
# 2. AGENTS, ORGANIZATIONS, ROLES, CAPABILITIES (D4)
#    Minted ONCE here (shared supporting vocabulary across groups
#    2.1 / 2.2 / 2.3). Realizables borne by Agents/Organizations only.
####################################################################

# --- 2a. Roles ---

ex:SeniorManagementRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;   # role
    rdfs:label "Senior Management Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of holding senior executive authority over strategy, investment, or product decisions within an Organization." ;
    rdfs:comment "Recurs where APQC says 'Enlist senior management executives' (2.1.1.2, 2.1.1.4, 2.2.1.x)." .

ex:ResearchAndDevelopmentRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Research and Development Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with discovering, developing, or assessing new technologies and product/service concepts on behalf of an Organization." ;
    rdfs:comment "Recurs across the discovery-research and concept-generation processes (group 2.2)." .

ex:DesignStaffRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Design Staff Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with creating product/service design specifications and prototypes within an Organization." ;
    rdfs:comment "Recurs across the design-and-prototype processes (group 2.3); APQC 'solutioning and/or design staff'." .

ex:RegulatoryAuthorityRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Regulatory Authority Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of issuing, administering, or enforcing public-policy and regulatory requirements that apply to another organization." ;
    rdfs:comment "Borne by the external authority Organization, not by the regulatory ICEs it issues (group 2.1.3)." .

ex:SupplyChainPartnerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Supply Chain Partner Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of supplying, distributing, or co-producing on behalf of a focal organization within its supply chain." ;
    rdfs:comment "Covers APQC 'suppliers, vendors, contractors, subcontractors, distribution partners' (2.1.2.5.3, 2.3.1.14, 2.3.3.x)." .

ex:CustomerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Customer Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of consuming, evaluating, or being targeted by a focal organization's products or services." ;
    rdfs:comment "Borne by the (organizational or individual) customer; recurs in customer-test and market-review processes (2.1.2.5, 2.3.2.2)." .

# --- 2b. Capabilities ---
# The four 'Manage ...' standing functions are Organization Capabilities
# (R5/R6), realized in their bounded child acts. Reconciled to the richer
# forms WITH realized-in restrictions, since the child process classes are
# all present in this single assembled module.

ex:ProductServicePortfolioManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P10063 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P10074 ] ;
    rdfs:label "Product/Service Portfolio Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to maintain and revamp a portfolio of product/service offerings in alignment with business strategy and market opportunities." ;
    rdfs:comment "Models APQC 2.1.1 (PCF 10061) as a standing function, not a process (R5/R6); realized in its bounded child acts. Bearer is an Organization." .

ex:ProductServiceLifecycleManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P10077 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P10078 ] ;
    rdfs:label "Product/Service Lifecycle Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to introduce, sustain, and withdraw product/service offerings across their life cycle." ;
    rdfs:comment "Models APQC 2.1.2 (PCF 10067) as a standing function, not a process (R5/R6)." .

ex:IntellectualPropertyManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P16826 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P12771 ] ;
    rdfs:label "Intellectual Property Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to protect, value, and govern patents, copyrights, and regulatory requirements for its products and services." ;
    rdfs:comment "Models APQC 2.1.3 (PCF 19985) as a standing function, not a process (R5/R6)." .

ex:ProductDataManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P11741 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P11750 ] ;
    rdfs:label "Product/Service Master Data Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to securely store, control, and govern access to product/service master data and other critical data." ;
    rdfs:comment "Models APQC 2.1.4 (PCF 11740) as a standing function, not a process (R5/R6); realized in ex:ActOfDataManagement instances." .

ex:DesignCapability a owl:Class ;
    rdfs:subClassOf cco:ont00001379 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P19995 ] ;
    rdfs:label "Design Capability" ;
    skos:definition "An Agent Capability that is realized in Acts of Design of products, services, and processes." ;
    rdfs:comment "Borne by design staff Agents; bearer-agnostic between individual and organization, hence Agent Capability. Realized in the design acts of group 2.3 (e.g. ex:P19995)." .

ex:ResearchAndDevelopmentCapability a owl:Class ;
    rdfs:subClassOf cco:ont00001379 ;
    rdfs:label "Research and Development Capability" ;
    skos:definition "An Agent Capability that is realized in Acts of discovering, developing, and assessing new technologies and product/service concepts." .

# --- 2c. Agents / Organizations ---

ex:SeniorManagement a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:SeniorManagementRole ] ;
    rdfs:label "Senior Management" ;
    skos:definition "An Agent that bears a senior management role." ;
    rdfs:comment "APQC 'senior management executives'. cco:Agent (not bare material entity) excludes non-agentive participants." .

ex:ResearchAndDevelopmentPersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001954 ;
          owl:someValuesFrom ex:ResearchAndDevelopmentCapability ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:ResearchAndDevelopmentRole ] ;
    rdfs:label "Research and Development Personnel" ;
    skos:definition "An Agent that has a research-and-development capability and bears a research-and-development role." ;
    rdfs:comment "APQC 'research division(s)', 'R&D function' (group 2.2)." .

ex:DesignStaff a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001954 ;
          owl:someValuesFrom ex:DesignCapability ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:DesignStaffRole ] ;
    rdfs:label "Design Staff" ;
    skos:definition "An Agent that has a design capability and bears a design staff role." ;
    rdfs:comment "APQC 'solutioning and/or design staff' (group 2.3)." .

ex:RegulatoryAuthority a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:RegulatoryAuthorityRole ] ;
    rdfs:label "Regulatory Authority" ;
    skos:definition "An Organization that bears a regulatory authority role in relation to a focal organization." ;
    rdfs:comment "APQC 'sovereign or multinational authorities', 'appropriate regulatory body/agencies' (group 2.1.3)." .

ex:SupplyChainPartner a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:SupplyChainPartnerRole ] ;
    rdfs:label "Supply Chain Partner" ;
    skos:definition "An Organization that bears a supply chain partner role in relation to a focal organization." ;
    rdfs:comment "APQC 'suppliers, vendors, contractors, subcontractors, distribution partners'. Use cco:Agent for individual partners." .

ex:Customer a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:CustomerRole ] ;
    rdfs:label "Customer" ;
    skos:definition "An Agent that bears a customer role in relation to a focal organization's products or services." ;
    rdfs:comment "Modeled as cco:Agent to cover both individual consumers and customer organizations participating in tests/interviews (2.3.2.2)." .

####################################################################
# 3. MATERIAL ENTITIES
#    Design/build acts genuinely produce/consume real things, so the few
#    tangible artifacts are modeled as material entities for use as
#    material has-input/has-output fillers (2.3.1.9, 2.3.3.1).
####################################################################

ex:ProductServicePrototype a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    rdfs:label "Product/Service Prototype" ;
    skos:definition "A Material Artifact that is an early built instance of a prospective product or service produced to demonstrate and test its design." ;
    rdfs:comment "Material output of 2.3.1.9 (build prototypes) and material input to in-house testing (2.3.1.12). Anchored under cco:ont00000995 (Material Artifact)." .

ex:ProductionEquipment a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    rdfs:label "Production Equipment" ;
    skos:definition "A Material Artifact that is machinery or tooling used to manufacture or deliver a product or service." ;
    rdfs:comment "APQC 'machinery - hardware and software - needed to arrange production lines' (2.3.3.1)." .

ex:RawMaterial a owl:Class ;
    rdfs:subClassOf obo:BFO_0000040 ;
    rdfs:label "Raw Material" ;
    skos:definition "A Material Entity that is feedstock or input material consumed in producing a finished product." ;
    rdfs:comment "APQC 'feedstock or raw materials needed to prepare the finished products' (2.3.3.1). Bare material entity because raw stock need not be an artifact." .

####################################################################
# 4. INPUT INFORMATION CONTENT ENTITIES (Descriptive ICE genus 853)
####################################################################

ex:ProductServicePerformanceData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Product/Service Performance Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the performance of existing products or services, including measures of profitability, market penetration, and value delivered." .

ex:MarketOpportunityData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Opportunity Data" ;
    skos:definition "A Descriptive Information Content Entity that describes opportunities, demand, and gaps present in a market." .

ex:MarketData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Data" ;
    skos:definition "A Descriptive Information Content Entity that describes features of a market, such as size, growth rate, trends, segments, and channels." ;
    rdfs:comment "Reused naming from the reference module (apqc_1_1_1.ttl); minted here because it is not in apqc-ext.ttl." .

ex:CustomerFeedback a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Feedback" ;
    skos:definition "A Descriptive Information Content Entity that describes responses, opinions, and satisfaction reported by customers about a product or service." .

ex:TechnologyData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Technology Data" ;
    skos:definition "A Descriptive Information Content Entity that describes deployed, emerging, and disruptive technologies relevant to product/service development." ;
    rdfs:comment "Reused naming from the reference module; minted here for section 2.0." .

ex:ResearchPublication a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Research Publication" ;
    skos:definition "A Descriptive Information Content Entity published as a report, brief, or article and used as analytic or developmental input." ;
    rdfs:comment "Reused naming from the reference module." .

ex:RegulatoryRequirementData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Requirement Data" ;
    skos:definition "A Descriptive Information Content Entity that describes public-policy, regulatory, and compliance requirements applicable to a product or service." ;
    rdfs:comment "Descriptive: it states which requirements obtain. The organization's own derived requirement specifications are Directive (see section 5)." .

ex:SupplyChainPerformanceData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Supply Chain Performance Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the performance and effectiveness of a supply chain and distribution network." .

ex:SalesReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sales Report" ;
    skos:definition "A Descriptive Information Content Entity that describes sales volumes, revenue, and market response for a product or service." .

ex:ProductServiceIdea a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Product/Service Idea" ;
    skos:definition "A Descriptive Information Content Entity that describes a proposed new or improved product or service offering at the ideation stage." ;
    rdfs:comment "Descriptive: an idea describes a possible offering; once a committed concept/plan is formed it is the Directive ex:ProductServiceConcept (section 5)." .

ex:BusinessStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Business Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's intended overall course of business action." ;
    rdfs:comment "Directive input the section aligns to (APQC cross-reference 'Develop a business strategy [10015]'); used as has-input where concepts are checked for alignment (2.1.1.2)." .

####################################################################
# 5. OUTPUT INFORMATION CONTENT ENTITIES
#    Descriptive (ont00000853) for evaluations/judgements/studies;
#    Directive (ont00000965) for plans/specifications/targets/decisions.
#    'is about' (cco:ont00001808) where the output describes a subject.
####################################################################

# --- 5a. Descriptive outputs ---

ex:ProductServicePerformanceEvaluation a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:ProductServiceOffering ] ;
    rdfs:label "Product/Service Performance Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the capabilities and performance of existing products or services against market opportunities." ;
    rdfs:comment "Output of 2.1.1.1; descriptive evaluation, not a prescription." .

ex:FeasibilityAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Feasibility Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of whether a proposed technology, concept, or project can practicably be realized." ;
    rdfs:comment "Output of feasibility/technical-assessment acts (2.2.1.3, 2.3.1.2, 2.3.2.4)." .

ex:StrategicAlignmentAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:ProductServiceOffering ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:BusinessStrategy ] ;
    rdfs:label "Strategic Alignment Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of whether a product/service concept aligns with the organization's business strategy." ;
    rdfs:comment "Gate-F mint: output of 2.1.1.2. Distinct from ex:FeasibilityAssessment, which judges practicability/realizability; this judges STRATEGIC ALIGNMENT, a different subject. Replacing the FeasibilityAssessment filler on ex:P10066 corrects an inclusiveness/exclusiveness violation (the output ICE described the wrong subject)." .

ex:TechnicalAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Technical Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of an organization's technical capacity and know-how to develop a product or service." ;
    rdfs:comment "Output of 2.3.1.2 / revisited in 2.3.2.4." .

ex:MarketStudy a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:Market ] ;
    rdfs:label "Market Study" ;
    skos:definition "A Descriptive Information Content Entity that describes a detailed analysis of a market's competition, size, trends, segments, channels, and profitability." ;
    rdfs:comment "Output of 2.3.2.1 (prepare detailed market study)." .

ex:PostLaunchReview a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:ProductServiceOffering ] ;
    rdfs:label "Post-Launch Review" ;
    skos:definition "A Descriptive Information Content Entity that describes the measured market acceptance, performance, and supply-chain effectiveness of a newly launched product or service." ;
    rdfs:comment "Output of 2.1.2.5 and its task-level reviews (2.1.2.5.1-.7)." .

ex:BusinessCase a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Business Case" ;
    skos:definition "A Descriptive Information Content Entity that describes an argument weighing the costs and benefits of a proposed product or service project." ;
    rdfs:comment "Reused naming from the reference module's 'business case' pattern. Descriptive: it argues for/against rather than prescribing. Output of 2.3.1.2, finalized at 2.3.2.3." .

ex:ProductServiceCharacteristicsSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:ProductServiceOffering ] ;
    rdfs:label "Product/Service Characteristics Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the finalized attributes and characteristics a new product or service is to have." ;
    rdfs:comment "Output of 2.3.2.3 (finalize characteristics) and managed at 2.1.4.4. Directive: it fixes what the offering must be." .

# --- 5b. Directive outputs ---

ex:ProductServiceConcept a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:ProductServiceOffering ] ;
    rdfs:label "Product/Service Concept" ;
    skos:definition "A Directive Information Content Entity that prescribes a defined, committed concept for a new or revised product or service offering." ;
    rdfs:comment "Directive: a settled concept fixes a course of development (formulated at 2.2.2.4, selected at 2.1.1.3). Distinct from the earlier Descriptive ex:ProductServiceIdea." .

ex:ProductServicePriorityList a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Product/Service Priority List" ;
    skos:definition "A Directive Information Content Entity that prescribes a ranked ordering of product/service concepts selected for development." ;
    rdfs:comment "Output of 2.1.1.3 (prioritize and select). Directive: it commits the organization to an ordering." .

ex:CostTarget a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Cost Target" ;
    skos:definition "A Directive Information Content Entity that prescribes a budgetary or development-cost target for a product or service portfolio." ;
    rdfs:comment "Output of 2.1.1.4." .

ex:QualityTarget a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality Target" ;
    skos:definition "A Directive Information Content Entity that prescribes the intended quality standards for a product or service portfolio." ;
    rdfs:comment "Output of 2.1.1.4; reused as input to 2.3.1.11." .

ex:DevelopmentSchedule a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Development Schedule" ;
    skos:definition "A Directive Information Content Entity that prescribes timeframes and deadlines for developing or revising products and services." ;
    rdfs:comment "Output of 2.1.1.5 (specify development timing targets)." .

ex:ProductServiceModificationPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Product/Service Modification Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes a programmatic procedure for changing, designing, processing, and delivering products or services." ;
    rdfs:comment "Output of 2.1.1.6, 2.2.2.5, and 2.3.3.2." .

ex:LaunchPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Product/Service Launch Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the program and procedures for introducing and launching a new product or service." ;
    rdfs:comment "Output of 2.1.2.1; input to launch-procedure validation (2.3.3.5)." .

ex:PerformanceIndicatorSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Performance Indicator Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the parameters and indicators used to measure product/service or development performance." ;
    rdfs:comment "Output of 2.1.2.4 and 2.3.1.13. Directive: it stipulates how performance is to be measured." .

ex:GoNoGoDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Go/No-Go Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes whether to proceed or not proceed with a course of action." ;
    rdfs:comment "Reused naming from the reference module. Directive: a decision prescribes. Used where corporate decisions gate development (2.2.3 narrative)." .

ex:ProductServiceRequirementSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:ProductServiceOffering ] ;
    rdfs:label "Product/Service Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the functional, interoperability, safety, security, regulatory-compliance, and experience requirements a product or service must satisfy." ;
    rdfs:comment "Output of 2.2.3.1 and its derive-requirement tasks (2.2.3.1.1-.8), and documented at 2.3.1.6. Directive: requirements prescribe what must hold." .

ex:SupportModelSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Post-Launch Support Model Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes service-level agreements and service-level key performance indicators for post-launch support." ;
    rdfs:comment "Output of 2.2.3.2 (define post launch support model)." .

ex:DesignSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:ProductServiceOffering ] ;
    rdfs:label "Design Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the technical, quality, ergonomic, safety, and servicing requirements to be met in the design of a product or service." ;
    rdfs:comment "Output of 2.3.1.3, 2.3.1.4 (UX), documented at 2.3.1.6, designed against at 2.3.1.8, and managed at 2.1.4.5. Directive: a specification prescribes." .

ex:WarrantyRecommendation a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Warranty Recommendation" ;
    skos:definition "A Directive Information Content Entity that prescribes a recommended warranty plan and pricing for a product or service." ;
    rdfs:comment "Output of 2.3.1.5." .

ex:EngineeringChangeOrder a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Engineering Change Order" ;
    skos:definition "A Directive Information Content Entity that prescribes requested changes to production or delivery operations for a product or service." ;
    rdfs:comment "Output of 2.3.3.3 (request engineering/process change); APQC 'engineering change order'." .

ex:RegulatoryConcernRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Concern Register" ;
    skos:definition "A Descriptive Information Content Entity that describes identified patent, copyright, and regulatory concerns and needs." ;
    rdfs:comment "Reused naming from the reference module. Output of review/determine-needs acts (2.1.3.1-.3)." .

ex:RegulatoryRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Record" ;
    skos:definition "A Descriptive Information Content Entity that records information maintained for, or submitted to, a regulatory authority." ;
    rdfs:comment "Maintained/updated at 2.1.3.5.2-.3 by ex:ActOfDataManagement instances." .

####################################################################
# 6. SUBJECT CLASSES referenced by 'is about'
####################################################################

ex:ProductServiceOffering a owl:Class ;
    rdfs:subClassOf obo:BFO_0000001 ;
    rdfs:label "Product/Service Offering" ;
    skos:definition "An Entity that is a product or service offered, or proposed to be offered, by an organization to its customers." ;
    rdfs:comment "Anchored at obo:BFO_0000001 (Entity) deliberately: APQC 'product/service' spans material products (continuants) and services (occurrents/dispositions), so no narrower common genus is asserted. Used as the subject filler of 'is about' and as the developed output of group 2.3." .

ex:Market a owl:Class ;
    rdfs:subClassOf obo:BFO_0000040 ;
    rdfs:label "Market" ;
    skos:definition "A Material Entity that is the aggregate of buyers, sellers, and offerings within which an organization's products or services compete." ;
    rdfs:comment "Subject of ex:MarketStudy. Modeled as a material aggregate of agents and goods rather than as an ICE." .

####################################################################
# 7. ADDITIONAL SUPPORTING ICEs (minted in the group modules; not in
#    the shared reuse list). All anchored under verified CCO parents.
#    DUPLICATE RECONCILED: ex:BillOfMaterials was minted as Descriptive
#    in group 2.1 and Directive in group 2.3; reconciled to ONE Directive
#    declaration (a BOM prescribes the required components/parts), so the
#    2.1 master-data act ex:P11742 and the 2.3 design act
#    ex:P16818 both reference the same coherent class.
####################################################################

# --- group 2.1 descriptive ICE outputs (cco:ont00000853) ---

ex:MarketAcceptanceAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Market ] ;
    rdfs:label "Market Acceptance Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes user engagement and a product/service's acceptance in the market following launch." ;
    rdfs:comment "Minted: no shared-list ICE captures post-launch acceptance analytics. Descriptive (represents measured acceptance)." .

ex:SupplyChainEffectivenessReview a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Supply Chain Effectiveness Review" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of whether a supply chain and distribution network meets the demands of its stakeholders." ;
    rdfs:comment "Minted: shared list has SupplyChainPerformanceData (input) but no effectiveness-review output. Descriptive (a judgement). Output of the 2.1.2.5.3 APPRAISAL act only; the sibling 2.1.2.5.4 analysis act now outputs the distinct ex:SupplyChainMethodologyAnalysis." .

ex:SupplyChainMethodologyAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Supply Chain Methodology Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes a data-analytics conclusion correlating gaps and efficiencies across an organization's existing supply-chain methodologies." ;
    rdfs:comment "Gate-F mint: output of the 2.1.2.5.4 analysis act (ex:P19647). Distinct from ex:SupplyChainEffectivenessReview (the 2.1.2.5.3 appraisal verdict): the .4 source ('Collecting and examining raw data ... drawing conclusions ... Apply the information to make better business decisions') yields an analytic conclusion, not an effectiveness judgement. Previously both sibling acts shared the same effectiveness-review filler despite different act genera (Analysis vs Appraisal); giving .4 a distinct output resolves that inconsistent anchoring. Descriptive." .

ex:QualityPerformanceReview a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Quality Performance Review" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the quality and performance of a product/service delivered to customers." ;
    rdfs:comment "Minted: no shared-list ICE captures the delivered-quality judgement. Descriptive." .

ex:FinancialReview a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Financial Review" ;
    skos:definition "A Descriptive Information Content Entity that describes an evaluation of an organization's financial reports and the return on investment of a product/service." ;
    rdfs:comment "Minted: no shared-list financial ICE. Descriptive (an evaluation record)." .

ex:NPDProcessAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "New Product Development Process Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes an analysis of the new-product-development steps and their effect on existing products, resources, and functions." ;
    rdfs:comment "Minted: process-assessment output not in shared list. Descriptive." .

ex:RegulatoryReview a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Review" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the enforcement of intellectual-property and regulatory protection processes." ;
    rdfs:comment "Minted: distinct from RegulatoryConcernRegister/RegulatoryRecord; this records a performance/enforcement review. Descriptive." .

ex:InfringementAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Infringement Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of patentability and possible infringement, including open-source licensing usage." ;
    rdfs:comment "Minted: no shared-list infringement ICE. Descriptive (a judgement)." .

ex:IPNeedsAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Intellectual Property Needs Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes an analysis of the business need for patents and copyrights for given products or services." ;
    rdfs:comment "Minted: no shared-list IP-needs ICE. Descriptive." .

# --- group 2.1 master-data ICEs (Descriptive 853; specs/decisions Directive 965) ---

ex:MaterialsMasterList a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Materials Master List" ;
    skos:definition "A Descriptive Information Content Entity that describes the storage, utilization, and supplier linkages of an organization's materials." ;
    rdfs:comment "Minted: master-data record not in shared list. Descriptive." .

ex:BillOfMaterials a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Bill of Materials" ;
    skos:definition "A Directive Information Content Entity that lists and prescribes the raw materials, components, and parts (across design, manufacturing, and service variants) required to produce an end product." ;
    rdfs:comment "DUPLICATE RECONCILED to ONE Directive class: a BOM prescribes which components/parts must be used to build the product. Output of the 2.3 design act ex:P16818 and the managed master-data object of the 2.1 act ex:P11742." ;
    skos:example "An engineering, manufacturing, and service BOM for a new appliance." .

ex:Routing a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Routing" ;
    skos:definition "A Descriptive Information Content Entity that describes the flow of operations from raw form to finished product for a specific product/service layout." ;
    rdfs:comment "Minted: routing record not in shared list. Modeled Descriptive (a record of the operation flow as managed master data)." .

ex:ProductMaterialClassification a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Product/Material Classification" ;
    skos:definition "A Descriptive Information Content Entity that describes the classification of products and input materials throughout the production process." ;
    rdfs:comment "Minted: classification record not in shared list. Descriptive." .

ex:QualityInspectionDocument a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality/Inspection Document" ;
    skos:definition "A Directive Information Content Entity that prescribes the procedures for assessing whether a product/service meets defined delivery criteria." ;
    rdfs:comment "Minted: inspection-procedure document not in shared list. Directive (it prescribes a procedure)." .

ex:ProcessSpecificationData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Process Specification Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the procedural data followed across different functions and mission-critical applications." ;
    rdfs:comment "Minted: process-spec master data not in shared list. Modeled Descriptive as managed reference data." .

ex:TraceabilityData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Traceability Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the genealogy and access history of product/material data accessible only via permitted touch points." ;
    rdfs:comment "Minted: traceability record not in shared list. Descriptive." .

ex:DataAccessRequest a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Data Access Request" ;
    skos:definition "A Descriptive Information Content Entity that describes a requester and the data accessibility being requested." ;
    rdfs:comment "Minted: input request record not in shared list. Descriptive (it describes a request, not yet a decision)." .

ex:DataAccessDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Data Access Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes whether to permit or deny a data access request according to internal data-security policy." ;
    rdfs:comment "Minted: authorization decision not in shared list. Directive (a prescriptive authorization) per the GOLDEN PRINCIPLE." .

# --- group 2.3 slice-local ICEs ---

ex:ResourceAllocationPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Resource Allocation Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the funds, personnel, and time allocated to a product or service development project." ;
    rdfs:comment "Minted: output of 2.3.1.1; not in shared list. Directive." .

ex:PartnerRequirementSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Design/Development Partner Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the essential requirements for collaborators involved in the design or development of a product or service." ;
    rdfs:comment "Minted: output of 2.3.1.1.1; not in shared list. Directive." .

ex:UserExperienceDesignSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductServiceOffering ] ;
    rdfs:label "User Experience Design Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the usability and user-experience characteristics of a product or service offering." ;
    rdfs:comment "Minted: output of 2.3.1.4; not in shared list. Directive, is about the offering." .

ex:ExternalReviewReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductServiceOffering ] ;
    rdfs:label "External Review Report" ;
    skos:definition "A Descriptive Information Content Entity that records the findings of mandatory and elective external reviews of a product or service design specification against external standards." ;
    rdfs:comment "Minted: output of 2.3.1.7; not in shared list. Descriptive." .

ex:TroubleshootingMethodologyReview a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Troubleshooting Methodology Review" ;
    skos:definition "A Descriptive Information Content Entity that records an appraisal of the design and approach for troubleshooting a product." ;
    rdfs:comment "Minted: output of 2.3.1.8.4; not in shared list. Descriptive." .

ex:PrototypeTestResult a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Prototype Test Result" ;
    skos:definition "A Descriptive Information Content Entity that records the outcome of trial runs that test a prototype production or service-delivery process." ;
    rdfs:comment "Minted: co-output of 2.3.1.10; not in shared list. Descriptive." .

ex:ProductionDeliveryProcessDesign a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Production/Delivery Process Design" ;
    skos:definition "A Directive Information Content Entity that prescribes a manufacturing or service-delivery process created for a new product or service." ;
    rdfs:comment "Minted: co-output of 2.3.1.10; not in shared list. Directive." .

ex:CustomerTestReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProductServiceOffering ] ;
    rdfs:label "Customer Test Report" ;
    skos:definition "A Descriptive Information Content Entity that records qualitative and quantitative findings from customer tests and interviews of a new product or service." ;
    rdfs:comment "Minted: output of 2.3.2.2; not in shared list. Descriptive, is about the offering." .

####################################################################
# 8. PROCESS CLASSES -- GROUP 2.1
#    "Govern and manage product/service development program" (PCF 19696)
#    Partonomy via cco:ont00001777 (has process part), never subClassOf.
#    I/O promoted to someValuesFrom only when definitional (Phase 3).
#    The four 2.1.x 'Manage' headings are Organization Capabilities
#    (section 2 above), not processes; their child acts follow.
####################################################################

# ---- 2.1.1.x (parts of the Portfolio Management Capability) ----

ex:P10063 a owl:Class ;
    ex:pcfID "10063" ; ex:hierarchyID "2.1.1.1" ;
    ex:apqcSourceText "Assessing the capabilities and performance of existing products/services, in light of market opportunities. Examine performance of the existing line of products/services, including measures of profitability, penetration, and value delivered. Identify gaps between existing solutions' portfolio or their performance levels, on the one hand, and the current market demand, available technologies, and/or customer expectations, on the other. Consider opportunities in the present market environment and any relation with the performance. Consider input from professional services providers." ;
    rdfs:label "Evaluate performance of existing products/services against market opportunities" ;
    skos:definition "An Act of Appraisal that has as input product/service performance data and market opportunity data and has as output a product/service performance evaluation that identifies gaps against market expectations." ;
    rdfs:comment "Genus is appraisal (judging capabilities/performance); output is a Descriptive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "A product team appraises current offerings on profitability and penetration and issues a performance evaluation flagging portfolio gaps." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductServicePerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketOpportunityData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServicePerformanceEvaluation ] .

ex:P10066 a owl:Class ;
    ex:pcfID "10066" ; ex:hierarchyID "2.1.1.2" ;
    ex:apqcSourceText "Checking the alignment of product/service portfolio, and its individual offerings, with the organization's overall strategy and planning for the development of new or revised solutions. Conduct reality checks on new product/service concepts prior to committing significant investment to ensure that the revamped solutions' portfolio is in line with the overall business strategy, aligns organizational processes for their development, and creates a plan for assimilating these changes in the organization's offerings. Enlist senior management executives." ;
    rdfs:label "Confirm alignment of product/service concepts with business strategy" ;
    skos:definition "An Act of Appraisal that has as input product/service concepts and a business strategy and has as output a strategic alignment assessment of the concepts, with senior management as participant." ;
    rdfs:comment "Reality-check appraisal; descriptive output (the alignment judgement). Senior-management participation is definitional per the source ('Enlist senior management executives'). Gate-F: the output filler was changed from ex:FeasibilityAssessment to the dedicated ex:StrategicAlignmentAssessment, because the act judges STRATEGIC ALIGNMENT ('Checking the alignment ... with the organization's overall strategy'), not practicability/feasibility -- an inclusiveness/exclusiveness fix. The source's directive sub-output ('creates a plan for assimilating these changes') is recorded here at comment level only, not modeled as a restriction." ;
    skos:example "Senior executives reality-check a new concept against the business strategy and confirm its alignment before funding." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductServiceConcept ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicAlignmentAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SeniorManagement ] .

ex:P10074 a owl:Class ;
    ex:pcfID "10074" ; ex:hierarchyID "2.1.1.3" ;
    ex:apqcSourceText "Selecting from among the potential new/revised solutions and capitalizing on market opportunities so that they meet the cost and quality prerequisites. Create an index of product/service concepts, and arrange them in order of preference. Base prioritization on adherence to Plan and develop cost and quality targets [10073], and choose options that would comprise the revised solution portfolio." ;
    rdfs:label "Prioritize and select new product/service concepts" ;
    skos:definition "An Act of Selection that has as input product/service concepts and has as output a product/service priority list prescribing the chosen concepts for the revised portfolio." ;
    rdfs:comment "Genus is selection (choosing from a candidate set); output is a Directive ICE (the priority list) per the GOLDEN PRINCIPLE." ;
    skos:example "A portfolio board ranks candidate concepts and selects those meeting cost/quality targets for the revised portfolio." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductServiceConcept ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServicePriorityList ] .

ex:P10073 a owl:Class ;
    ex:pcfID "10073" ; ex:hierarchyID "2.1.1.4" ;
    ex:apqcSourceText "Setting prerequisites for the cost of development and quality standards for the new solutions' portfolio and/or its individual offerings. Set targets for the budget and quality standards for the revamped portfolio of solution offerings. Prepare a plan for the outlay required for revising and adding new product/services. Identify intended levels of quality for these, bearing in mind the existing standards of solutions offered by the organization and its competitors. Enlist senior management executives, particularly those responsible for finance and budgeting, product/service design, manufacturing/processing, delivery, and quality control." ;
    rdfs:label "Plan and develop cost and quality targets" ;
    skos:definition "An Act of Formulation that has as output a cost target and a quality target prescribing the budget and quality prerequisites for the revised portfolio, with senior management as participant." ;
    rdfs:comment "Genus is formulation/planning; outputs are Directive ICEs (cost and quality targets) per the GOLDEN PRINCIPLE. Senior-management participation is definitional ('Enlist senior management executives')." ;
    skos:example "Finance and quality leaders set budget and quality targets for the revamped solution portfolio." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CostTarget ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTarget ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SeniorManagement ] .

ex:P10075 a owl:Class ;
    ex:pcfID "10075" ; ex:hierarchyID "2.1.1.5" ;
    ex:apqcSourceText "Determining the individual and collective timeframe for realizing new/revised solutions. Create a schedule that clearly demarcates the timeframes designated for the development of every new solution and/or revising each of the existing ones. Create a timetable by setting deadlines for each step in overhauling the product/service portfolio." ;
    rdfs:label "Specify development timing targets" ;
    skos:definition "An Act of Formulation that has as output a development schedule prescribing the timeframes and deadlines for developing and revising the portfolio's solutions." ;
    rdfs:comment "Genus is formulation; output is a Directive ICE (the schedule) per the GOLDEN PRINCIPLE." ;
    skos:example "A program manager sets deadlines for each development step and issues the portfolio overhaul schedule." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DevelopmentSchedule ] .

ex:P10076 a owl:Class ;
    ex:pcfID "10076" ; ex:hierarchyID "2.1.1.6" ;
    ex:apqcSourceText "Developing a programmatic procedure for changing products/services while paying heed to all stakeholders involved and the prerequisites identified. Create a plan for changing the existing portfolio of solution offerings. Develop a systematic program for the design, processing, and delivery of the new product/service concepts. Construct project-flow diagrams. Identify the stakeholders involved and personnel responsible for each stage, as well as the necessary decisions. Earmark the budgetary outlay, and conduct any strategic planning required." ;
    rdfs:label "Plan for product/service offering modifications" ;
    skos:definition "An Act of Formulation that has as output a product/service modification plan prescribing a programmatic procedure for changing the portfolio of offerings." ;
    rdfs:comment "Genus is formulation; output is a Directive ICE (the modification plan) per the GOLDEN PRINCIPLE." ;
    skos:example "A team builds a project-flow plan assigning stages, owners, and budget for modifying the offering portfolio." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceModificationPlan ] .

# ---- 2.1.2.x (parts of the Lifecycle Management Capability) ----

ex:P16824 a owl:Class ;
    ex:pcfID "16824" ; ex:hierarchyID "2.1.2.1" ;
    ex:apqcSourceText "Developing a program and managing a perspective for new product/service introduction and launch." ;
    rdfs:label "Develop plan for new product/service development and introduction/launch" ;
    skos:definition "An Act of Formulation that has as output a product/service launch plan prescribing the program for introducing and launching a new product or service." ;
    rdfs:comment "Gate-F re-anchor: from ex:ActOfDevelopment to ex:ActOfFormulation (Act of Planning). The source ('Developing a program and managing a perspective for new product/service introduction and launch') describes AUTHORING a plan, and the sole output is a Directive ICE (ex:LaunchPlan), so the act is a formulation, not a development. ex:ActOfDevelopment asserts an existent realized state that never occurs here, a genus/output disagreement under the GOLDEN PRINCIPLE; 'Develop' is a false friend. Aligns with the sibling planning rows 2.1.1.4/.5/.6 and 2.1.2.4, all anchored at ex:ActOfFormulation." ;
    skos:example "A launch team develops the go-to-market program for a new product." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LaunchPlan ] .

ex:P10077 a owl:Class ;
    ex:pcfID "10077" ; ex:hierarchyID "2.1.2.2" ;
    ex:apqcSourceText "Launching revamped product/service portfolio in to the market. Introduction in to the marketplace is done by deploying effective channels for marketing, sales, delivery, and after-sales servicing. Introduce new/revised solution offerings in a concerted effort. Coordinate a cross-functional effort." ;
    rdfs:label "Introduce new products/services" ;
    skos:definition "A Planned Act in which an Organization deploys a new or revised product/service offering into the market through marketing, sales, delivery, and after-sales channels." ;
    rdfs:comment "Operations launch occurrent (category 2.0 permits material participants). No definitional informational output; the offering deployed is ex:ProductServiceOffering (a participant, comment-level here since not every instance manifests a single material filler)." ;
    skos:example "A cross-functional team launches a revamped product line across marketing and distribution channels." ;
    rdfs:subClassOf cco:ont00000228 .

ex:P10078 a owl:Class ;
    ex:pcfID "10078" ; ex:hierarchyID "2.1.2.3" ;
    ex:apqcSourceText "Removing nonconforming products and services. Withdraw those products/services that do not conform to market realities and are not positioned to take advantage of prevailing opportunities. Coordinate with processing/delivery teams within the organization and key stakeholders in the supply chain. Create mechanisms for continued after-sales servicing, as well as deploy effective public relations efforts in order to preserve the image and goodwill of the organization through the process." ;
    rdfs:label "Retire outdated products/services" ;
    skos:definition "A Planned Act in which an Organization withdraws a nonconforming product/service offering from the market while sustaining after-sales servicing and goodwill." ;
    rdfs:comment "Operations withdrawal occurrent. Supply-chain-partner coordination is typical (comment-level), not definitional." ;
    skos:example "A firm retires an obsolete product line and stands up continued spares support." ;
    rdfs:subClassOf cco:ont00000228 .

ex:P10079 a owl:Class ;
    ex:pcfID "10079" ; ex:hierarchyID "2.1.2.4" ;
    ex:apqcSourceText "Attuning the performance measures of products/services to better reflect the revamped portfolio of solution offerings. Revise the parameters used to measure performance, apropos the organization's product/service offerings. (Modify these standards in consideration of the changes made to the portfolio by Introduce new products/services [10077] and Retire outdated products/services [10078].)" ;
    rdfs:label "Identify and refine performance indicators" ;
    skos:definition "An Act of Formulation that has as output a performance indicator specification prescribing the revised parameters for measuring product/service performance." ;
    rdfs:comment "Genus is formulation; output is a Directive ICE (the indicator specification) per the GOLDEN PRINCIPLE." ;
    skos:example "An analytics team revises product KPIs to reflect the new portfolio." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceIndicatorSpecification ] .

ex:P11423 a owl:Class ;
    ex:pcfID "11423" ; ex:hierarchyID "2.1.2.5" ;
    ex:apqcSourceText "Learning from either a test or a full production run within the consumer market. Companies use this as an opportunity to both test and react to new products, ideas, or innovations based on the initial reaction of consumers on an individual level. Within this process, analytics are used to determine the relative success of a new product offering. Within this process, companies will launch key analytics to test a products acceptance. They will also review market performance and compare to similar products and against the business case or the financial plan. Companies can also measure the effectiveness of their supply chain network, and can apply what is learned from the post launch review to other new products, processes, and procedures to ensure and enhance the product quality." ;
    rdfs:label "Conduct post launch review" ;
    skos:definition "An Act of Appraisal that has as output a post-launch review judging the market success of a newly launched product/service, and that has as process parts the constituent analytics, market, supply-chain, quality, financial, and process reviews." ;
    rdfs:comment "Genus is appraisal; output is a Descriptive ICE (the review) per the GOLDEN PRINCIPLE. Its seven task children are process parts via cco:ont00001777." ;
    skos:example "A team runs post-launch analytics and compiles a review comparing actual market performance against the business case." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PostLaunchReview ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19646 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11424 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11425 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19647 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11426 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11427 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11428 ] .

ex:P19646 a owl:Class ;
    ex:pcfID "19646" ; ex:hierarchyID "2.1.2.5.1" ;
    ex:apqcSourceText "Measuring the performance of marketing once the product/services are launched. This broadly covers measuring user engagement and product's/service's performance in the market." ;
    rdfs:label "Carry out post launch analytics to test the acceptability in the market" ;
    skos:definition "An Act of Analysis that has as input product/service performance data and has as output a market acceptance analysis of user engagement and post-launch market performance." ;
    rdfs:comment "Genus is analysis; output is a Descriptive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "Analysts measure engagement metrics after launch and report market acceptance." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductServicePerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketAcceptanceAnalysis ] .

ex:P11424 a owl:Class ;
    ex:pcfID "11424" ; ex:hierarchyID "2.1.2.5.2" ;
    ex:apqcSourceText "Conducting customer and market analysis to review progress and identify opportunities for increasing market position. Track and review product/service response through sales reports, website statistics, direct response from customers, and survey reports." ;
    rdfs:label "Review market performance" ;
    skos:definition "An Act of Analysis that has as input sales reports and customer feedback and has as output a market study about the product/service's market position." ;
    rdfs:comment "Genus is analysis; output is a Descriptive ICE that is about the Market per the GOLDEN PRINCIPLE." ;
    skos:example "A team reviews sales reports and survey responses to study a product's market position." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketStudy ] .

ex:P11425 a owl:Class ;
    ex:pcfID "11425" ; ex:hierarchyID "2.1.2.5.3" ;
    ex:apqcSourceText "Determining the performance of supply chain to all departments and logistics from input to shop floor. Seeking performance reviews at each intersection and communication channels. Review effectiveness of supply chain and distribution to check if it is meeting the demands of the various groups and organizations that are concerned with its activities (groups might include customers, partners, suppliers, and vendors)." ;
    rdfs:label "Review effectiveness of supply chain and distribution network" ;
    skos:definition "An Act of Appraisal that has as input supply chain performance data and has as output a supply chain effectiveness review judging whether the network meets stakeholder demands." ;
    rdfs:comment "Genus is appraisal; output is a Descriptive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "Logistics reviews each supply-chain intersection and judges overall network effectiveness." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SupplyChainPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplyChainEffectivenessReview ] .

ex:P19647 a owl:Class ;
    ex:pcfID "19647" ; ex:hierarchyID "2.1.2.5.4" ;
    ex:apqcSourceText "Collecting and examining raw data with the purpose of drawing conclusions about that information and correlate gaps and efficiencies to the existing supply chain channels. Apply the information to make better business decisions to the related supply chain methodologies to meet efficiency." ;
    rdfs:label "Apply data and analytics to review supply chain methodologies" ;
    skos:definition "An Act of Analysis that has as input supply chain performance data and has as output a supply chain methodology analysis correlating gaps and efficiencies across supply-chain channels." ;
    rdfs:comment "Genus is analysis; output is a Descriptive ICE per the GOLDEN PRINCIPLE. Gate-F: the output filler was changed from the shared ex:SupplyChainEffectivenessReview to the distinct ex:SupplyChainMethodologyAnalysis, so this analysis act (.4) and the sibling appraisal act (.3, ex:P11425) no longer collapse to the same output class while carrying different act genera. The .4 source is genuine analysis (drawing conclusions from raw data), producing a data-analytics conclusion distinct from the .3 effectiveness verdict." ;
    skos:example "Analysts examine raw supply-chain data to correlate efficiency gaps across channels." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SupplyChainPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupplyChainMethodologyAnalysis ] .

ex:P11426 a owl:Class ;
    ex:pcfID "11426" ; ex:hierarchyID "2.1.2.5.5" ;
    ex:apqcSourceText "Identifying the quality and performance of the product/service delivered to customers. Analyze data from the customer feedback, audits, measures of customer satisfaction (such as product quality complaints and recalls), and organizational policies on delivery." ;
    rdfs:label "Review quality and performance of the product/service" ;
    skos:definition "An Act of Appraisal that has as input customer feedback and has as output a quality performance review judging the delivered product/service's quality and performance." ;
    rdfs:comment "Genus is appraisal; output is a Descriptive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "A quality team appraises complaints, recalls, and satisfaction data to judge delivered quality." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityPerformanceReview ] .

ex:P11427 a owl:Class ;
    ex:pcfID "11427" ; ex:hierarchyID "2.1.2.5.6" ;
    ex:apqcSourceText "Evaluating organization's financial reports and financial reporting processes. Review and document the ROI catered by the product/service delivery to the customer in the market." ;
    rdfs:label "Conduct financial review" ;
    skos:definition "An Act of Appraisal that has as output a financial review documenting the return on investment of the product/service delivered to market." ;
    rdfs:comment "Genus is appraisal; output is a Descriptive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "Finance reviews the ROI of a launched product and documents the financial review." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialReview ] .

ex:P11428 a owl:Class ;
    ex:pcfID "11428" ; ex:hierarchyID "2.1.2.5.7" ;
    ex:apqcSourceText "Analyzing the steps involved in the development of new product, its effect on existing product, resources, and functions related to the development of the new product until its sale in the competitive market place." ;
    rdfs:label "Conduct new product development process assessment" ;
    skos:definition "An Act of Analysis that has as output a new-product-development process assessment of the development steps and their effect on existing products, resources, and functions." ;
    rdfs:comment "Genus is analysis; output is a Descriptive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "A team analyzes the NPD steps end-to-end and assesses their impact on resources and existing products." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:NPDProcessAssessment ] .

# ---- 2.1.3.x (parts of the IP Management Capability) ----

ex:P19941 a owl:Class ;
    ex:pcfID "19941" ; ex:hierarchyID "2.1.3.1" ;
    ex:apqcSourceText "Conducting necessary performance reviews on enforcement of processes and steps to ensure protection. Determine policies and reviews for Manage patents, copyrights, and regulatory requirements [19985]." ;
    rdfs:label "Conduct mandatory and elective reviews" ;
    skos:definition "An Act of Appraisal that has as output a regulatory review judging the enforcement of intellectual-property protection processes." ;
    rdfs:comment "Genus is appraisal; output is a Descriptive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "IP counsel runs the required reviews on protection-process enforcement and records the findings." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryReview ] .

ex:P16826 a owl:Class ;
    ex:pcfID "16826" ; ex:hierarchyID "2.1.3.2" ;
    ex:apqcSourceText "Reviewing activities in regards to patentability and infringement. The usage of Open Source in commercial product development will be reviewed in regard to licensing, community development, etc." ;
    rdfs:label "Review infringement of patents and copyrights" ;
    skos:definition "An Act of Appraisal that has as output an infringement assessment judging patentability and possible infringement, including open-source licensing usage." ;
    rdfs:comment "Genus is appraisal; output is a Descriptive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "Counsel reviews a product for patentability and open-source license compliance and issues an infringement assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InfringementAssessment ] .

ex:P16827 a owl:Class ;
    ex:pcfID "16827" ; ex:hierarchyID "2.1.3.3" ;
    ex:apqcSourceText "Determining the business need for patents and copyrights. The patents and copyrights are managed by Manage copyrights and patents [11062]." ;
    rdfs:label "Determine patent and copyright needs" ;
    skos:definition "An Act of Analysis that has as output an intellectual-property needs assessment of the business need for patents and copyrights." ;
    rdfs:comment "Genus is analysis; output is a Descriptive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "An IP team analyzes a product portfolio and determines which assets warrant patent or copyright protection." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IPNeedsAssessment ] .

ex:P19697 a owl:Class ;
    ex:pcfID "19697" ; ex:hierarchyID "2.1.3.4" ;
    ex:apqcSourceText "Defining sourcing and procurement requirements for new product technical documentation management. Make sourcing-based decisions that identify the capabilities that will be required in order to launch the new product. This documentation will be used to support the product following entry into service. It is compiled and managed in Manage product and process related data [12082], but the capability to manage and maintain this documentation must be defined and established." ;
    rdfs:label "Define product technical documentation management requirements" ;
    skos:definition "An Act of Formulation that has as output a product/service requirement specification prescribing the sourcing and capability requirements for managing new-product technical documentation." ;
    rdfs:comment "Genus is formulation; output is a Directive ICE (the requirement specification) per the GOLDEN PRINCIPLE." ;
    skos:example "A team defines the documentation-management capabilities required to support a new product in service." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] .

ex:P12771 a owl:Class ;
    ex:pcfID "12771" ; ex:hierarchyID "2.1.3.5" ;
    ex:apqcSourceText "Aligning regulatory activities related to managing industry requirements. Train employees on regulatory requirements. Records for the appropriate regulatory agencies must be maintained and the new product process must be approved by the appropriate regulatory body before it is published to the organization. The submission lifecycle - i.e. creation, review, and approval of the submission and its components must be managed in a collaborative fashion." ;
    rdfs:label "Manage regulatory requirements" ;
    skos:definition "An Act of Data Management that has as input regulatory requirement data and has as output a regulatory record maintaining the organization's regulatory submissions, and that has as process parts employee training, record maintenance, and submission-lifecycle management." ;
    rdfs:comment "Modeled as a bounded coordinating data-management occurrent (creation/review/approval of submissions) so its three tasks have a partonomy parent; regulatory-authority participation is definitional. Output is a Descriptive ICE (the maintained record)." ;
    skos:example "A regulatory affairs team manages the creation, review, and approval lifecycle of a product's regulatory submissions." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryAuthority ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12772 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12773 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P12776 ] .

ex:P12772 a owl:Class ;
    ex:pcfID "12772" ; ex:hierarchyID "2.1.3.5.1" ;
    ex:apqcSourceText "Conducting training and impart learning to existing and new employees. Training will relate to the most recent/enforced regulations of the business to meet Manage regulatory requirements [12771]." ;
    rdfs:label "Train employees on appropriate regulatory requirements" ;
    skos:definition "An Act of Training in which knowledge of the most recent enforced regulations is imparted to existing and new employees." ;
    rdfs:comment "Reuses CCO cco:ont00000234 (Act of Training): knowledge is imparted from one Agent to others. The training content is regulatory requirement data (input). Also asserts the redundant explicit anchor rdfs:subClassOf cco:ont00000228 (Planned Act): cco:ont00000234 Act of Training is a Planned Act in the pinned CCO closure, but the standalone Gate-C SHACL check (S2/S5) cannot see that cco→cco chain, so the anchor is made explicit per the house-style verify-before-assert pattern." ;
    skos:example "A compliance officer trains staff on the latest enforced industry regulations." ;
    rdfs:subClassOf cco:ont00000234 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryRequirementData ] .

ex:P12773 a owl:Class ;
    ex:pcfID "12773" ; ex:hierarchyID "2.1.3.5.2" ;
    ex:apqcSourceText "Identifying steps and procedures to manage and regularly update the records for regulatory agencies. Updates will be made to safety procedures, identity and access management, software tools and applications, internal accessibility policies, internal quality parameters, etc." ;
    rdfs:label "Maintain records for regulatory agencies" ;
    skos:definition "An Act of Data Management that has as output an updated regulatory record kept current for the appropriate regulatory agencies." ;
    rdfs:comment "Genus is data management; output is a Descriptive ICE (the maintained record). Regulatory authority is the agency for which records are kept (comment-level)." ;
    skos:example "A records team regularly updates the regulatory-agency submission archive." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryRecord ] .

ex:P12776 a owl:Class ;
    ex:pcfID "12776" ; ex:hierarchyID "2.1.3.5.3" ;
    ex:apqcSourceText "Determine and follow the timely input and update of regulatory information by assessing reforms, regulatory policies, and guidelines." ;
    rdfs:label "Manage regulatory submission life cycle" ;
    skos:definition "An Act of Data Management that has as input regulatory requirement data and has as output a regulatory record reflecting the timely input and update of regulatory submission information." ;
    rdfs:comment "Genus is data management; output is a Descriptive ICE (the maintained submission record)." ;
    skos:example "A regulatory team tracks reforms and updates the submission record on time." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryRecord ] .

# ---- 2.1.4.x (parts of the Master Data Management Capability) ----

ex:P11741 a owl:Class ;
    ex:pcfID "11741" ; ex:hierarchyID "2.1.4.1" ;
    ex:apqcSourceText "Controlling the details of materials' storage and utilization, supplier details linked to materials, in a defined sequential manner and ensuring regular updates with permissible accessibility." ;
    rdfs:label "Manage materials master lists" ;
    skos:definition "An Act of Data Management that has as output a materials master list controlling materials storage, utilization, and linked supplier details with permissible accessibility." ;
    rdfs:comment "Genus is data management; output is a Descriptive ICE (the master list)." ;
    skos:example "A master-data steward updates the materials master list with new supplier linkages." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MaterialsMasterList ] .

ex:P11742 a owl:Class ;
    ex:pcfID "11742" ; ex:hierarchyID "2.1.4.2" ;
    ex:apqcSourceText "Managing the purchase details/bills through regular and error free updates to applications. Create manual entries wherever necessary and ensure timely review of the laid processes and systems." ;
    rdfs:label "Manage bills of material" ;
    skos:definition "An Act of Data Management that has as output a bill of materials kept current through regular, error-free updates to the supporting applications." ;
    rdfs:comment "Genus is data management; output is the Directive ICE ex:BillOfMaterials (reconciled to one class)." ;
    skos:example "An engineer updates the BOM in the PLM system after a part substitution." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BillOfMaterials ] .

ex:P11743 a owl:Class ;
    ex:pcfID "11743" ; ex:hierarchyID "2.1.4.3" ;
    ex:apqcSourceText "Controlling and executing the flow of operations from raw form to finished product in a defined format using industry applications/routing sheets for the specific product/service layout." ;
    rdfs:label "Manage routings" ;
    skos:definition "An Act of Data Management that has as output a routing specifying the flow of operations from raw form to finished product for a specific product/service layout." ;
    rdfs:comment "Genus is data management; output is a Descriptive ICE (the routing) describing the operation flow." ;
    skos:example "A process engineer maintains routing sheets for a product line in the MES." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:Routing ] .

ex:P11744 a owl:Class ;
    ex:pcfID "11744" ; ex:hierarchyID "2.1.4.4" ;
    ex:apqcSourceText "Direct, supervise, and control the product/service details necessary to execute the process. Adhere to details and descriptions for product/service through identified or guided parameters towards final outcome in the market with due critical analysis formed on organizational objectives." ;
    rdfs:label "Manage specifications" ;
    skos:definition "An Act of Data Management that has as output a product/service characteristics specification controlling the product/service details necessary to execute the process." ;
    rdfs:comment "Genus is data management; output is a Directive ICE (the specification), which prescribes product/service characteristics." ;
    skos:example "A spec owner controls and versions the product characteristics specification in the PDM system." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceCharacteristicsSpecification ] .

ex:P11745 a owl:Class ;
    ex:pcfID "11745" ; ex:hierarchyID "2.1.4.5" ;
    ex:apqcSourceText "Administering the specifications of the product/service and ensure accessibility for product alteration/new product development." ;
    rdfs:label "Manage drawings" ;
    skos:definition "An Act of Data Management that has as output a design specification (drawing) administered and made accessible for product alteration and new product development." ;
    rdfs:comment "Genus is data management; output is a Directive ICE (the design specification/drawing), which prescribes the artifact's form." ;
    skos:example "A CAD librarian administers controlled access to product drawings." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DesignSpecification ] .

ex:P11746 a owl:Class ;
    ex:pcfID "11746" ; ex:hierarchyID "2.1.4.6" ;
    ex:apqcSourceText "Controlling the details of the product and the input materials. Manage classification throughout the production process, and for future accessibility to new product development or product enrichment." ;
    rdfs:label "Manage product/material classification" ;
    skos:definition "An Act of Data Management that has as output a product/material classification controlling product and input-material details throughout the production process." ;
    rdfs:comment "Genus is data management; output is a Descriptive ICE (the classification)." ;
    skos:example "A data steward maintains the product and material classification taxonomy." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductMaterialClassification ] .

ex:P11747 a owl:Class ;
    ex:pcfID "11747" ; ex:hierarchyID "2.1.4.7" ;
    ex:apqcSourceText "Determining procedures required to assess the sustainability of defined criterion for product/service delivery to customers. Retain results for further review as a procedural practice." ;
    rdfs:label "Develop and maintain quality/inspection documents" ;
    skos:definition "An Act of Data Management that has as output a quality/inspection document prescribing the procedures for assessing product/service delivery criteria, retained for further review." ;
    rdfs:comment "Genus is data management (develop and maintain the document); output is a Directive ICE (the inspection procedure document)." ;
    skos:example "A quality engineer authors and retains the inspection procedure document for a product family." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityInspectionDocument ] .

ex:P11748 a owl:Class ;
    ex:pcfID "11748" ; ex:hierarchyID "2.1.4.8" ;
    ex:apqcSourceText "Directing and handling data with respect to the procedures followed across different functions and mission critical applications." ;
    rdfs:label "Maintain process specification data" ;
    skos:definition "An Act of Data Management that has as output process specification data directing and handling the procedural data used across functions and mission-critical applications." ;
    rdfs:comment "Genus is data management; output is a Descriptive ICE (the process specification data)." ;
    skos:example "A data owner maintains process-specification records across ERP modules." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessSpecificationData ] .

ex:P11749 a owl:Class ;
    ex:pcfID "11749" ; ex:hierarchyID "2.1.4.9" ;
    ex:apqcSourceText "Identifying and handling data accessed by the permitted touch points. Ensure that no data is accessible to any unnecessary recipient. Data flow should be controlled through secured access and free from unauthorized access." ;
    rdfs:label "Manage traceability data" ;
    skos:definition "An Act of Data Management that has as output traceability data controlled through secured access so that it is reachable only by permitted touch points." ;
    rdfs:comment "Genus is data management; output is a Descriptive ICE (the traceability data) with controlled access." ;
    skos:example "A traceability administrator restricts lot-genealogy data to authorized systems." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TraceabilityData ] .

ex:P11750 a owl:Class ;
    ex:pcfID "11750" ; ex:hierarchyID "2.1.4.10" ;
    ex:apqcSourceText "Determining the requests pertaining to data accessibility. Review the requester details based on internal data security policies and permit data access only if internal policies and data access parameters are met." ;
    rdfs:label "Review and approve data access requests" ;
    skos:definition "An Act of Appraisal that has as input a data access request and has as output a data access decision permitting or denying access according to internal data-security policy." ;
    rdfs:comment "Genus is appraisal (judging the request against policy); the output is a prescriptive authorization, so it is a Directive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "A data-security reviewer evaluates an access request against policy and grants or denies it." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DataAccessRequest ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DataAccessDecision ] .

####################################################################
# 9. PROCESS CLASSES -- GROUP 2.2
#    "Generate and define new product/service ideas" (PCF 19698)
####################################################################

ex:P19698 a owl:Class ;
    ex:pcfID "19698" ; ex:hierarchyID "2.2" ;
    ex:apqcSourceText "Identifying and describing new product or service thoughts based on organizational objectives/targets." ;
    rdfs:label "Generate and define new product/service ideas" ;
    skos:definition "An Act of Formulation that conceives and articulates new product or service ideas in light of organizational objectives and produces one or more product/service concepts." ;
    rdfs:comment "Models APQC process group 2.2 as an occurrent. Its APQC children are process parts, not subclasses." ;
    skos:example "An innovation team's idea-generation cycle that yields a slate of new product concepts for the development pipeline." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceConcept ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10065 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19669 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19990 ] .

ex:P10065 a owl:Class ;
    ex:pcfID "10065" ; ex:hierarchyID "2.2.1" ;
    ex:apqcSourceText "Coordinating R&D activity to identify new technologies to integrate into the revamped portfolio of products/services. Conduct early-stage R&D activity to close gaps between existing solution offerings and changing market expectations. Triangulate appropriate technologies that can support the development of a revised product/service portfolio." ;
    rdfs:label "Perform discovery research" ;
    skos:definition "An Act of Analysis that conducts early-stage research and development on emerging technologies and produces a technical assessment of technologies able to support a revised product/service portfolio." ;
    rdfs:comment "Coordinates R&D to triangulate technologies; an information-processing act producing a descriptive technical assessment." ;
    skos:example "A research division runs an exploratory technology scan and reports which emerging technologies can close gaps in the current portfolio." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TechnologyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TechnicalAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10070 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10071 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10072 ] .

ex:P10070 a owl:Class ;
    ex:pcfID "10070" ; ex:hierarchyID "2.2.1.1" ;
    ex:apqcSourceText "Determining new technologies to revise the portfolio of solution offerings. Identify recently developed technological advances that can be leveraged in the development or advancement of the organization's product/service portfolio. Enlist senior management in conjunction with personnel responsible for the design, processing, and delivery of products/services. Have the organization's research division(s) carry out the process." ;
    rdfs:label "Identify new technologies" ;
    skos:definition "An Act of Identification that discerns recently developed technological advances leverageable for the product/service portfolio and produces a technical assessment registering them." ;
    rdfs:comment "Discernment sense (information processing), not cco:ont00001261. R&D personnel are definitional participants ('research division(s) carry out the process'); senior management is typical." ;
    skos:example "A research division registers a shortlist of emerging technologies relevant to the next portfolio refresh." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TechnologyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TechnicalAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ResearchAndDevelopmentPersonnel ] .

ex:P10071 a owl:Class ;
    ex:pcfID "10071" ; ex:hierarchyID "2.2.1.2" ;
    ex:apqcSourceText "Developing new technologies from scratch to integrate into a revised portfolio of solutions. Develop new technological processes, models, and/or implements in-house, with the objective of improving existing solutions or creating new ones. Consider market realities, as well as the portfolio of products/services. Assess the results in conjunction with senior executives and personnel responsible for the design, processing, and delivery of these solutions. Engage the R&D function, and consider external sources such as offshore providers, specialized research agencies, and crowdsourcing communities." ;
    rdfs:label "Develop new technologies" ;
    skos:definition "An Act of Development that builds new technological processes, models, or implements in-house in order to improve existing solutions or create new ones." ;
    rdfs:comment "Builds a new technology from scratch; a Planned Act of creation, distinct from analysing or appraising existing technology. R&D personnel are participants." ;
    skos:example "An R&D group engineers a novel manufacturing process to enable a new product line." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ResearchAndDevelopmentPersonnel ] .

ex:P10072 a owl:Class ;
    ex:pcfID "10072" ; ex:hierarchyID "2.2.1.3" ;
    ex:apqcSourceText "Appraising the feasibility of integrating new technologies, whether developed as a custom solution or adopted from an external source, into revised portfolio of solution offerings. Examine recently developed technological advances for suitability to incorporate them into the concept of revised and/or new solution offerings. Enlist senior management, in consultation with in-house personnel responsible for the design, processing, and delivery of these solutions, as well as key supply-chain stakeholders." ;
    rdfs:label "Assess feasibility of integrating new leading technologies into product/service concepts" ;
    skos:definition "An Act of Appraisal that judges the suitability of integrating new technologies into revised or new product/service concepts and produces a feasibility assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it evaluates/judges integration feasibility. Senior management is a definitional participant; supply-chain partners are typical." ;
    skos:example "An evaluation panel appraises whether a custom sensor technology can be integrated into the next product generation and reports its feasibility." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TechnologyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FeasibilityAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SeniorManagement ] .

ex:P19669 a owl:Class ;
    ex:pcfID "19669" ; ex:hierarchyID "2.2.2" ;
    ex:apqcSourceText "Producing and defining ideologies for new product/service offerings." ;
    rdfs:label "Generate new product/service concepts" ;
    skos:definition "An Act of Formulation that produces and defines concepts for new product or service offerings." ;
    rdfs:comment "Output is a product/service concept (Directive ICE), so the act is a formulation, not an analysis." ;
    skos:example "A concept team articulates three candidate service concepts for a new market segment." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceConcept ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19986 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19987 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19988 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19989 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10068 ] .

ex:P19986 a owl:Class ;
    ex:pcfID "19986" ; ex:hierarchyID "2.2.2.1" ;
    ex:apqcSourceText "Collecting necessary items, documents, regulatory requirements, etc., based on Generate and define new product/service ideas [19698]" ;
    rdfs:label "Gather new product/service ideas and requirements" ;
    skos:definition "An Act of Acquisition that obtains and assembles the product/service ideas, documents, and regulatory requirements not previously held, for use in concept generation." ;
    rdfs:comment "Gate-F re-anchor: from ex:ActOfDataManagement to ex:ActOfAcquisition. ex:ActOfDataManagement denotes standing maintenance/governance of a body of ICEs (store, control, update, govern access), reserved here for the 2.1.4 master-data acts. A one-time collect/gather to feed concept generation ('Collecting necessary items, documents, regulatory requirements, etc.') is acquisition/intake -- obtaining an entity the Agent did not previously hold -- not corpus governance; ex:ActOfDataManagement denoted the wrong information-processing sub-kind." ;
    skos:example "An analyst compiles submitted product ideas and the applicable regulatory requirements into a single working set." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductServiceIdea ] .

ex:P19987 a owl:Class ;
    ex:pcfID "19987" ; ex:hierarchyID "2.2.2.2" ;
    ex:apqcSourceText "Assessing and reviewing the concepts and requirements of Generate and define new product/service ideas [19698]" ;
    rdfs:label "Analyze new product/service ideas and requirements" ;
    skos:definition "An Act of Analysis that examines collected product/service ideas and requirements and produces an understanding of their suitability." ;
    rdfs:comment "Information-processing review of concepts and requirements; descriptive output." ;
    skos:example "A review board analyses the gathered ideas against the captured requirements to shortlist viable concepts." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductServiceIdea ] .

ex:P19988 a owl:Class ;
    ex:pcfID "19988" ; ex:hierarchyID "2.2.2.3" ;
    ex:apqcSourceText "Assessing and reviewing the required inputs and necessary elements such as automation, technology, hardware installation, regulatory requirements, certifications, etc., for new products/services through defined process and analysis." ;
    rdfs:label "Evaluate new product/service inputs and requirements" ;
    skos:definition "An Act of Appraisal that judges the required inputs and necessary elements for a new product or service and produces a feasibility assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): assesses/reviews inputs and elements (automation, certifications, regulatory requirements) through defined analysis." ;
    skos:example "An evaluation team appraises the automation, hardware, and certification needs of a candidate product and reports feasibility." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FeasibilityAssessment ] .

ex:P19989 a owl:Class ;
    ex:pcfID "19989" ; ex:hierarchyID "2.2.2.4" ;
    ex:apqcSourceText "Devising ideas and elements necessary for thoughts on new product/service development." ;
    rdfs:label "Formulate new product/service concepts" ;
    skos:definition "An Act of Formulation that devises the ideas and elements of a new product or service and produces a product/service concept." ;
    rdfs:comment "Output is a Directive ICE (product/service concept), consistent with a formulation act." ;
    skos:example "A design team formulates a coherent product concept from a set of candidate ideas." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceConcept ] .

ex:P10068 a owl:Class ;
    ex:pcfID "10068" ; ex:hierarchyID "2.2.2.5" ;
    ex:apqcSourceText "Defining potential enhancements to current products/services in order to take advantage of a shift in market expectations. Identify how the existing line of products/services may be revised--through enhancements to individual solutions or across-the-board renovations--in order to capitalize on present opportunities in the market." ;
    rdfs:label "Identify potential improvements to existing products and services" ;
    skos:definition "An Act of Formulation that defines potential enhancements to current products or services and produces a product/service modification plan to capitalize on shifts in market expectations." ;
    rdfs:comment "Although phrased as 'Identify', the definitional output is a prescriptive modification plan (Directive ICE), so the act is a formulation, not an Act of Identification (GOLDEN PRINCIPLE)." ;
    skos:example "A product manager defines a set of enhancements to an existing service line to match new market expectations." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketOpportunityData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceModificationPlan ] .

ex:P19990 a owl:Class ;
    ex:pcfID "19990" ; ex:hierarchyID "2.2.3" ;
    ex:apqcSourceText "Encompassing the identification and capture of new product/service requirements or potential improvements to current products/services. Collaborating with members of the supply chain to ensure the feasibility of what is being defined in the requirements. For example, a product with manufacturing requirements that supply chain cannot currently fulfill requires a corporate decision to either upgrade manufacturing capabilities or abandon the new product. Enterprise-level effects and needs must be considered. Depending on the nature of the final product or service, these requirements are often defined as a set of abilities, such as availability or reliability, that influence product development decisions." ;
    rdfs:label "Define product/service development requirements" ;
    skos:definition "An Act of Formulation that identifies and captures the requirements governing development of a new product or service and produces a product/service requirement specification." ;
    rdfs:comment "Output is a Directive requirement specification (definitional). Gate-F: the [has participant some ex:SupplyChainPartner] existential restriction was REMOVED. The source ('Collaborating with members of the supply chain ... For example ...') is illustrative, not necessary for every instance; the Phase-3 existential-necessity rule forbids promoting typical/exemplary participants to owl:someValuesFrom. Supply-chain collaboration to confirm feasibility is therefore recorded here as a typical participation / competency-question target only, not as a restriction." ;
    skos:example "A requirements team works with suppliers to define the availability and reliability requirements that will drive product development." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11331 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16815 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17389 ] .

ex:P11331 a owl:Class ;
    ex:pcfID "11331" ; ex:hierarchyID "2.2.3.1" ;
    ex:apqcSourceText "Determining requirements related to the creation of the product/service. Explain potential achievements that could be made." ;
    rdfs:label "Define product/service requirements" ;
    skos:definition "An Act of Formulation that determines the requirements related to creating a product or service and produces a product/service requirement specification." ;
    rdfs:comment "Parent of the eight requirement-derivation tasks; each is a process part." ;
    skos:example "An engineering team determines and documents the full requirement set for a new device." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19991 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16808 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16809 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16810 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16811 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16812 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19992 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16814 ] .

ex:P19991 a owl:Class ;
    ex:pcfID "19991" ; ex:hierarchyID "2.2.3.1.1" ;
    ex:apqcSourceText "Determining the operations of functions related to the product/service in the marketing environment." ;
    rdfs:label "Define basic functional requirements" ;
    skos:definition "An Act of Formulation that determines the functional operations required of a product or service and produces a product/service requirement specification." ;
    skos:example "A team specifies the core functions a new appliance must perform." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] .

ex:P16808 a owl:Class ;
    ex:pcfID "16808" ; ex:hierarchyID "2.2.3.1.2" ;
    ex:apqcSourceText "Determining the ability of products and services to work together, exchange and use information in a multi-vendor, multi-network, and multi-service environment." ;
    rdfs:label "Derive interoperability requirements for products and services" ;
    skos:definition "An Act of Formulation that determines the interoperability a product or service must exhibit across multi-vendor and multi-network environments and produces a product/service requirement specification." ;
    skos:example "An architect specifies the data-exchange standards the product must support to interoperate with third-party systems." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] .

ex:P16809 a owl:Class ;
    ex:pcfID "16809" ; ex:hierarchyID "2.2.3.1.3" ;
    ex:apqcSourceText "Developing safety requirements in line with environmental safety, occupational health and safety, and community health and safety guidelines." ;
    rdfs:label "Derive safety requirements for products and services" ;
    skos:definition "An Act of Formulation that develops the safety requirements a product or service must meet in line with health-and-safety guidelines and produces a product/service requirement specification." ;
    skos:example "A safety engineer specifies the occupational and community safety requirements for a new appliance." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] .

ex:P16810 a owl:Class ;
    ex:pcfID "16810" ; ex:hierarchyID "2.2.3.1.4" ;
    ex:apqcSourceText "Implementing security requirements through authentication and encryption of CE device data stream.  Utilize security measures such as cryptographic protocols and hardware security (smart cards)." ;
    rdfs:label "Derive security requirements for products and services" ;
    skos:definition "An Act of Formulation that determines the authentication, encryption, and hardware-security requirements a product or service must meet and produces a product/service requirement specification." ;
    skos:example "A security architect specifies the cryptographic protocols and smart-card protections required for a connected device." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] .

ex:P16811 a owl:Class ;
    ex:pcfID "16811" ; ex:hierarchyID "2.2.3.1.5" ;
    ex:apqcSourceText "Meeting regulatory requirements set forth by such directives as RoHS, WEEE, ELV, and REACH. " ;
    rdfs:label "Derive regulatory compliance requirements" ;
    skos:definition "An Act of Formulation that determines the regulatory compliance requirements a product or service must satisfy under directives such as RoHS, WEEE, ELV, and REACH and produces a product/service requirement specification." ;
    rdfs:comment "Input regulatory requirement data is definitional; its source is the external regulatory authority. Gate-F: the [has participant some ex:RegulatoryAuthority] restriction was DROPPED. The regulatory authority does NOT partake in the organization's internal act of deriving requirements; it merely issued the external directives the org must comply with (bfo:has participant requires the entity to be present in and partake of the occurrent). The authority dependency is expressed instead through the ex:RegulatoryRequirementData input, whose source is the authority -- not via has-participant (a Phase-4 R-relation fix that avoids conflating 'source of the constraint' with 'participant of the act')." ;
    skos:example "A compliance engineer specifies the RoHS and REACH requirements a new electronic product must meet." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] .

ex:P16812 a owl:Class ;
    ex:pcfID "16812" ; ex:hierarchyID "2.2.3.1.6" ;
    ex:apqcSourceText "Complying with consumer electronic industry standards developed by the Consumer Technology Association (CTA)." ;
    rdfs:label "Derive requirements from industry standards" ;
    skos:definition "An Act of Formulation that determines the requirements a product or service must meet to comply with industry standards and produces a product/service requirement specification." ;
    skos:example "An engineer derives the device requirements needed to conform to the relevant CTA industry standards." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] .

ex:P19992 a owl:Class ;
    ex:pcfID "19992" ; ex:hierarchyID "2.2.3.1.7" ;
    ex:apqcSourceText "Identifying and creating steps and tools to develop the user experience. " ;
    rdfs:label "Develop user experience requirements" ;
    skos:definition "An Act of Formulation that determines the steps and tools needed to shape the user experience of a product or service and produces a product/service requirement specification." ;
    skos:example "A UX team specifies the interaction requirements and tooling for a new application." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] .

ex:P16814 a owl:Class ;
    ex:pcfID "16814" ; ex:hierarchyID "2.2.3.1.8" ;
    ex:apqcSourceText "Productizing the service by defining the scope of the service/cost.  Target market for the service and make the service more tangible." ;
    rdfs:label "Derive 'services-as-a-product' offering" ;
    skos:definition "An Act of Formulation that productizes a service by defining its scope and cost and produces a product/service concept for the resulting offering." ;
    rdfs:comment "Defines a tangible service offering (its scope and cost), i.e. articulates a product/service concept (Directive ICE)." ;
    skos:example "A team packages a consulting service into a fixed-scope, fixed-price offering." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceConcept ] .

ex:P16815 a owl:Class ;
    ex:pcfID "16815" ; ex:hierarchyID "2.2.3.2" ;
    ex:apqcSourceText "Defining SLAs (Service Level Agreement) and service level KPIs (Key Performance Indicator). " ;
    rdfs:label "Define post launch support model" ;
    skos:definition "An Act of Formulation that defines the service-level agreements and service-level KPIs for post-launch support and produces a post-launch support model specification." ;
    skos:example "A service team specifies the SLAs and KPIs that will govern support after a product's launch." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SupportModelSpecification ] .

ex:P17389 a owl:Class ;
    ex:pcfID "17389" ; ex:hierarchyID "2.2.3.3" ;
    ex:apqcSourceText "Establishing areas of growth and further development of product/service mix, customization, market based changes, etc., to further demonstrate value to the customer in the competition." ;
    rdfs:label "Identify product/service bundling opportunities" ;
    skos:definition "An Act of Identification that discerns areas of growth in the product/service mix and produces a representation of the bundling opportunities available to demonstrate value to customers." ;
    rdfs:comment "Discernment sense (information processing); descriptive output. No precise shared output ICE exists for a 'bundling-opportunity register', so the output is recorded here rather than as a definitional restriction. Input is market opportunity data." ;
    skos:example "A marketing analyst identifies opportunities to bundle complementary products to increase customer value." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketOpportunityData ] .

####################################################################
# 10. PROCESS CLASSES -- GROUP 2.3
#    "Develop products and services" (PCF 10062)
####################################################################

ex:P10062 a owl:Class ;
    ex:pcfID "10062" ; ex:hierarchyID "2.3" ;
    ex:apqcSourceText "Developing new products/services from scratch, including all activities associated with the design, prototyping, evaluation, and market testing of these planned offerings." ;
    rdfs:label "Develop products and services" ;
    skos:definition "An Act of Development that creates new products or services from concept through design, prototyping, market testing, and preparation for production." ;
    rdfs:comment "APQC Process Group 2.3 modeled as an occurrent. Its APQC children are process parts, not subclasses. The parent Category 2.0 is catalog-only (R3) and has no has-process-part to this group. The developed product/service offering (ex:ProductServiceOffering, anchored at BFO Entity, not an ICE) is the thing realized by the act, so it is its has-participant, not its informational has-output: section 2.0 is a develop/plan category whose informational outputs (per D3) are ICEs, and ex:ProductServiceOffering is produced through the design/prototype/build parts below rather than emitted as a single definitional output of the group." ;
    skos:example "A firm's end-to-end new-product development programme from idea to production launch." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductServiceOffering ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19993 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19996 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19997 ] .

ex:P19993 a owl:Class ;
    ex:pcfID "19993" ; ex:hierarchyID "2.3.1" ;
    ex:apqcSourceText "Sketching and standardizing product and service based on the market. Analyze the data market competitiveness and innovation attained for the product and service development." ;
    rdfs:label "Design and prototype products and services" ;
    skos:definition "An Act of Development that designs and prototypes products and services in light of market data, producing a design specification (informational output) and building a product/service prototype (a material participant)." ;
    rdfs:comment "Models APQC 2.3.1. Children below are process parts via cco:ont00001777. The informational has-output (per D3) is the Directive ICE ex:DesignSpecification; the built prototype (ex:ProductServicePrototype, a Material Artifact) is a has-participant of the act, not an ICE output -- section 2.0 is a develop/plan category, so material things participate rather than fill the informational output slot." ;
    skos:example "A design team sketches a new offering, drafts specifications, and builds a working prototype." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DesignSpecification ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductServicePrototype ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10083 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10084 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10085 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16813 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16817 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10086 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10087 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19995 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10088 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10098 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10089 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10090 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10091 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10092 ] .

ex:P10083 a owl:Class ;
    ex:pcfID "10083" ; ex:hierarchyID "2.3.1.1" ;
    ex:apqcSourceText "Allocating resources to the design, development, and evaluation of product/service concepts. Allocate funds, personnel, and time for developing the new and/or revised products/services. Begin to design the potential new product/service concepts that have been prioritized and selected for further development." ;
    rdfs:label "Assign resources to product/service project" ;
    skos:definition "An Act of Planning that allocates funds, personnel, and time to a product or service development project and produces a resource allocation plan." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): the act produces a prescriptive allocation (Directive ICE)." ;
    skos:example "A programme manager assigns budget and engineers to a prioritized concept." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResourceAllocationPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19994 ] .

ex:P19994 a owl:Class ;
    ex:pcfID "19994" ; ex:hierarchyID "2.3.1.1.1" ;
    ex:apqcSourceText "Determining essential elements for collaborators involved in blueprint/development of product/service." ;
    rdfs:label "Identify requirements for product/service design/development partners" ;
    skos:definition "An Act of Formulation that determines the essential requirements for design and development collaborators and produces a partner requirement specification." ;
    rdfs:comment "Gate-F re-anchor: from ex:ActOfIdentification to ex:ActOfFormulation. The definitional output is a Directive ICE (ex:PartnerRequirementSpecification, a directive specification of partner requirements), so a discernment genus disagrees with the directive output (GOLDEN PRINCIPLE). Aligns with the entire ex:P11331 / 2.2.3.1.x 'Derive ... requirements' family, all anchored at ex:ActOfFormulation -- a sibling-consistency fix as well." ;
    skos:example "A team specifies the certifications a co-development supplier must hold." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PartnerRequirementSpecification ] .

ex:P10084 a owl:Class ;
    ex:pcfID "10084" ; ex:hierarchyID "2.3.1.2" ;
    ex:apqcSourceText "Preparing a business-level business case and a technical feasibility assessment in order to move the product/service projects forward. Weigh the costs and benefits of designing, developing, and evaluating the shortlisted product/service concepts. Prepare a business case to justify the product/service projects. Conduct a technical appraisal to ensure that the organization has the technical know-how and resources to further develop these concepts." ;
    rdfs:label "Prepare high-level business case and technical assessment" ;
    skos:definition "An Act of Appraisal that weighs the costs and benefits and technical feasibility of shortlisted concepts and produces a business case and a technical assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): both outputs are descriptive judgements." ;
    skos:example "A team prepares a cost-benefit business case and a technical-feasibility appraisal for two concepts." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessCase ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TechnicalAssessment ] .

ex:P10085 a owl:Class ;
    ex:pcfID "10085" ; ex:hierarchyID "2.3.1.3" ;
    ex:apqcSourceText "Creating design specifications. Create specifications for the design of new or revised product/service concepts as a measure to meet during development. Have the senior functional-level solutioning or design staff create a framework of compliance standards for these products/services." ;
    rdfs:label "Develop product/service design specifications" ;
    skos:definition "An Act of Design that creates design specifications for new or revised product or service concepts as a standard to meet during development." ;
    rdfs:comment "Genus ex:ActOfDesign (output is a Directive ICE). Senior/design staff participate." ;
    skos:example "Design staff draft a compliance-standard framework for a new product." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DesignSpecification ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:DesignStaff ] .

ex:P16813 a owl:Class ;
    ex:pcfID "16813" ; ex:hierarchyID "2.3.1.4" ;
    ex:apqcSourceText "Determining the usability and user experience of products and the business impact it creates." ;
    rdfs:label "Develop user experience design specifications" ;
    skos:definition "An Act of Design that determines the usability and user experience of a product or service and produces a user experience design specification." ;
    rdfs:comment "Genus ex:ActOfDesign: prescribes UX characteristics (Directive ICE about the offering)." ;
    skos:example "A UX team specifies the interaction model and usability targets for an app." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:UserExperienceDesignSpecification ] .

ex:P16817 a owl:Class ;
    ex:pcfID "16817" ; ex:hierarchyID "2.3.1.5" ;
    ex:apqcSourceText "Providing warranty plan and pricing specifications for recommendation." ;
    rdfs:label "Provide warranty-related recommendations" ;
    skos:definition "An Act of Planning that devises warranty plan and pricing specifications and produces a warranty recommendation." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): output is a prescriptive recommendation (Directive ICE)." ;
    skos:example "A product team recommends a two-year warranty plan with tiered pricing." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WarrantyRecommendation ] .

ex:P10086 a owl:Class ;
    ex:pcfID "10086" ; ex:hierarchyID "2.3.1.6" ;
    ex:apqcSourceText "Documenting requirements to meet in the design of new or revised products/services. Specify technical, quality, and costing requirements, as well as ergonomic, safety, and servicing requirements for such products/services. Ensure the information presented can be understood by the personnel executing the design and includes examples, anecdotal references, and illustrations." ;
    rdfs:label "Document design specifications" ;
    skos:definition "An Act of Data Management that records and structures the technical, quality, cost, ergonomic, safety, and servicing requirements to be met in the design of a product or service, producing a documented requirement specification." ;
    rdfs:comment "Genus ex:ActOfDataManagement: the act records/organizes requirement ICEs. Output is a Directive requirement specification." ;
    skos:example "An engineer compiles an illustrated requirements document for the design team." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceRequirementSpecification ] .

ex:P10087 a owl:Class ;
    ex:pcfID "10087" ; ex:hierarchyID "2.3.1.7" ;
    ex:apqcSourceText "Conducting any mandatory and elective appraisals of the product/service design specifications in order to ensure compliance with external standards. Carry out external reviews of specifications created for the development of new product/service designs. Conduct mandatory appraisals such as legal and regulatory, as well as any optional assessments that, for instance, pitch the specifications against industrial benchmarks." ;
    rdfs:label "Conduct mandatory and elective external reviews" ;
    skos:definition "An Act of Appraisal that reviews a product or service design specification against external legal, regulatory, and industrial standards and produces an external review report." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal). Input is the design specification; a regulatory authority participates in mandatory reviews." ;
    skos:example "A regulator reviews a medical-device spec for legal compliance." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DesignSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExternalReviewReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RegulatoryAuthority ] .

ex:P19995 a owl:Class ;
    ex:pcfID "19995" ; ex:hierarchyID "2.3.1.8" ;
    ex:apqcSourceText "Creating a sketch of the customer focused product/service in Develop and Manage Products and Services [10003]." ;
    rdfs:label "Design products/services" ;
    skos:definition "An Act of Design that creates a customer-focused sketch and design of a product or service and produces a design specification." ;
    rdfs:comment "Genus ex:ActOfDesign. The six APQC tasks below are facet-specific design parts via cco:ont00001777." ;
    skos:example "A designer produces a customer-focused product sketch and detailed design." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DesignSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16819 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16820 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16821 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16822 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16818 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16823 ] .

ex:P16819 a owl:Class ;
    ex:pcfID "16819" ; ex:hierarchyID "2.3.1.8.1" ;
    ex:apqcSourceText "Carrying out the steps necessary to appropriately manufacture correct parts.  This includes designing application, product hardware, mold, casting, mechanical, and electrical aspects of the product." ;
    rdfs:label "Design for manufacturing" ;
    skos:definition "An Act of Design that devises the application, hardware, mold, casting, mechanical, and electrical aspects of a product so that correct parts can be manufactured, producing a design specification." ;
    skos:example "An engineer designs injection-mold tooling so a housing can be mass-produced." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DesignSpecification ] .

ex:P16820 a owl:Class ;
    ex:pcfID "16820" ; ex:hierarchyID "2.3.1.8.2" ;
    ex:apqcSourceText "Creating product application service view to allow for product servicing and refurbishing." ;
    rdfs:label "Design for product servicing" ;
    skos:definition "An Act of Design that creates a product service view enabling servicing and refurbishing, producing a serviceability design specification." ;
    skos:example "A designer adds access panels and a service view so a unit can be refurbished." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DesignSpecification ] .

ex:P16821 a owl:Class ;
    ex:pcfID "16821" ; ex:hierarchyID "2.3.1.8.3" ;
    ex:apqcSourceText "Replacing core components and republishing." ;
    rdfs:label "Design for re-manufacturing" ;
    skos:definition "An Act of Design that devises how core components are replaced and republished for re-manufacturing, producing a re-manufacturing design specification." ;
    skos:example "An engineer designs a product so worn cores can be swapped and re-certified." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DesignSpecification ] .

ex:P16822 a owl:Class ;
    ex:pcfID "16822" ; ex:hierarchyID "2.3.1.8.4" ;
    ex:apqcSourceText "Reviewing the design and approach for troubleshooting the product." ;
    rdfs:label "Review product troubleshooting methodology" ;
    skos:definition "An Act of Appraisal that reviews the design and approach for troubleshooting a product and produces a troubleshooting methodology review." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): reviewing yields a descriptive judgement, not a design." ;
    skos:example "A reliability engineer reviews and critiques the product's diagnostic flow." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TroubleshootingMethodologyReview ] .

ex:P16818 a owl:Class ;
    ex:pcfID "16818" ; ex:hierarchyID "2.3.1.8.5" ;
    ex:apqcSourceText "Designing the BOM-Bill of material, manufacturing BOM and Service BOMA bill of materials list for all the raw materials and components/parts used in the producing end product." ;
    rdfs:label "Design and manage product data, design, and bill of materials" ;
    skos:definition "An Act of Data Management that designs and maintains product data, design records, and the engineering, manufacturing, and service bills of materials for a product." ;
    rdfs:comment "Genus ex:ActOfDataManagement: structuring product data and the BOM (a Directive ICE listing required materials/parts)." ;
    skos:example "A PLM engineer builds the manufacturing and service BOMs for a new appliance." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BillOfMaterials ] .

ex:P16823 a owl:Class ;
    ex:pcfID "16823" ; ex:hierarchyID "2.3.1.8.6" ;
    ex:apqcSourceText "Designing hardware and software upgrade techniques." ;
    rdfs:label "Design for product upgrades" ;
    skos:definition "An Act of Design that devises hardware and software upgrade techniques for a product, producing an upgrade design specification." ;
    skos:example "An engineer designs a modular slot so the device's firmware and memory can be upgraded." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DesignSpecification ] .

ex:P10088 a owl:Class ;
    ex:pcfID "10088" ; ex:hierarchyID "2.3.1.9" ;
    ex:apqcSourceText "Building prototypes for shortlisted product/service concepts. Develop prototypes for those product/service concepts that have been identified for further development. Provide proof-of-concepts, and test any processes involved. Build prototypes in line with the design specifications already outlined. Enlist the solutioning and/or design staff." ;
    rdfs:label "Build prototypes/proof of concepts" ;
    skos:definition "An Act of Development that builds a product or service prototype in line with the design specification, taking the design specification as input and yielding a built prototype as its material participant." ;
    rdfs:comment "The prototype is a cco:Material Artifact (ex:ProductServicePrototype); in this develop/plan category (2.0) the built material is the act's has-participant rather than an informational has-output (D3: informational outputs are ICEs). Design staff participate." ;
    skos:example "Design staff build a working proof-of-concept from the approved spec." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DesignSpecification ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductServicePrototype ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:DesignStaff ] .

ex:P10098 a owl:Class ;
    ex:pcfID "10098" ; ex:hierarchyID "2.3.1.10" ;
    ex:apqcSourceText "Creating the new manufacturing/delivery processes for the new products/services, and testing them to ensure proper functioning. Create the production/delivery process for the prototypes that have been built for the new products/services. Conduct trial-runs to test these processes and their integration with the organization's other processes." ;
    rdfs:label "Develop and test prototype production and/or service delivery process" ;
    skos:definition "An Act of Development that creates the production or service-delivery process for prototyped offerings and tests it through trial runs, producing a production/delivery process design and a prototype test result." ;
    rdfs:comment "Output includes both a Directive ICE (the process design) and a Descriptive ICE (the trial-run test result). The prototype (ex:ProductServicePrototype, a Material Artifact) is the material participant whose production process is being created and trial-run, not an informational has-input (D3: informational I/O in this develop/plan category are ICEs)." ;
    skos:example "An operations team builds and trial-runs a pilot assembly line for a prototype." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductServicePrototype ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductionDeliveryProcessDesign ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PrototypeTestResult ] .

ex:P10089 a owl:Class ;
    ex:pcfID "10089" ; ex:hierarchyID "2.3.1.11" ;
    ex:apqcSourceText "Eliminating any problems relating to utility of the product/service over the course of its expected lifetime. Tweak the prototype in order to comply with the required quality and reliability standards. Further refine the prototype, so it may be subjected to testing." ;
    rdfs:label "Eliminate quality and reliability problems" ;
    skos:definition "An Act of Development that refines a product or service prototype to comply with required quality and reliability standards, taking quality and reliability targets as input and acting on the prototype as its material participant." ;
    rdfs:comment "The refined prototype (ex:ProductServicePrototype, a Material Artifact) is the act's has-participant rather than an informational has-output: section 2.0 is a develop/plan category whose informational outputs (D3) are ICEs. Quality targets are definitional input." ;
    skos:example "Engineers tweak a prototype until it meets reliability targets." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityTarget ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductServicePrototype ] .

ex:P10090 a owl:Class ;
    ex:pcfID "10090" ; ex:hierarchyID "2.3.1.12" ;
    ex:apqcSourceText "Carrying out an in-house appraisal of the prototypes in order to validate design and feasibility. Test the product/service prototypes to confirm their compliance with design and usability standards. Corroborate the viability of the design, and validate the feasibility of their production. Identify any areas for improvement." ;
    rdfs:label "Conduct in-house product/service testing and evaluate feasibility" ;
    skos:definition "An Act of Verification that tests product or service prototypes against design and usability standards and produces a feasibility assessment." ;
    rdfs:comment "Genus ex:ActOfVerification (under Act of Appraisal): checks the prototype against standards, yielding a descriptive feasibility judgement. The prototype under test (ex:ProductServicePrototype, a Material Artifact) is the material participant of the verification, not an informational has-input (D3: informational I/O in this develop/plan category are ICEs)." ;
    skos:example "A QA team validates a prototype's design and production feasibility in-house." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductServicePrototype ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FeasibilityAssessment ] .

ex:P10091 a owl:Class ;
    ex:pcfID "10091" ; ex:hierarchyID "2.3.1.13" ;
    ex:apqcSourceText "Identifying performance parameters. Determine the parameters to measure performance of the design and development of the product/service concepts into prototypes." ;
    rdfs:label "Identify design/development performance indicators" ;
    skos:definition "An Act of Planning that determines the parameters for measuring design and development performance and produces a performance indicator specification." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): defining indicators to measure against is a prescriptive specification (Directive ICE). GOLDEN PRINCIPLE: 'identify parameters to measure' here sets directive targets, not a descriptive finding." ;
    skos:example "A team defines the KPIs that will gate the prototype phase." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceIndicatorSpecification ] .

ex:P10092 a owl:Class ;
    ex:pcfID "10092" ; ex:hierarchyID "2.3.1.14" ;
    ex:apqcSourceText "Interacting with suppliers and manufactures to determine design decisions. Collaborate with vendors, suppliers, contractors, and subcontractors to verify feasibility of co-producing the prototype's design. Ensure that efforts can be coordinated with other stakeholders in the organization's supply chain ecosystem at the time of manufacturing, producing, or packaging the finished product/service." ;
    rdfs:label "Collaborate on design with suppliers and external partners" ;
    skos:definition "An Act of Verification that, with suppliers and external partners, checks the feasibility of co-producing the prototype's design and produces a feasibility assessment." ;
    rdfs:comment "Genus ex:ActOfVerification: the text says 'verify feasibility'. Supply-chain partners participate via has participant." ;
    skos:example "Engineers and a contract manufacturer confirm a design can be co-produced." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DesignSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FeasibilityAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SupplyChainPartner ] .

# ---- 2.3.2.x  Test market (PCF 19996) ----

ex:P19996 a owl:Class ;
    ex:pcfID "19996" ; ex:hierarchyID "2.3.2" ;
    ex:apqcSourceText "Expanding on the marketplace analysis that took place earlier in the product development lifecycle by testing the market against offerings. The results from this in-depth analysis will help the organization finalize product/service characteristics and technical requirements and also identify any needed changes in the manufacturing and delivery processes that support market delivery. To prepare a detailed market study that accounts for any changes in the global environment, the organization may want to conduct a series of interviews, workshops, and focus groups with potential and existing customers." ;
    rdfs:label "Test market for new or revised products and services" ;
    skos:definition "An Act of Analysis that tests the market against new or revised offerings and produces a market study used to finalize product/service characteristics and technical requirements." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (information processing): the group's defining output is a descriptive market study. Children are process parts." ;
    skos:example "A marketing team runs focus groups and finalizes the offering's attributes." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketStudy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10093 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10094 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10095 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10096 ] .

ex:P10093 a owl:Class ;
    ex:pcfID "10093" ; ex:hierarchyID "2.3.2.1" ;
    ex:apqcSourceText "Composing a detailed study of the market ecosystem in light of new products/services. Conduct a detailed analysis of the targeted market(s) in order to Introduce new products/services [10077]. Examine the competition, market size and growth rate, market trends, customer segments and their characteristics, market influencers, distribution channels, and profitability. Enlist in-house marketing and/or solutioning teams, or outsource to specialized professional services agencies." ;
    rdfs:label "Prepare detailed market study" ;
    skos:definition "An Act of Analysis that examines the targeted market and produces a detailed market study about the market." ;
    rdfs:comment "Output ex:MarketStudy carries is-about ex:Market in the shared vocab. Input is market data." ;
    skos:example "A marketing team studies market size, trends, and segments for a new product." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketStudy ] .

ex:P10094 a owl:Class ;
    ex:pcfID "10094" ; ex:hierarchyID "2.3.2.2" ;
    ex:apqcSourceText "Conducting both qualitative and quantitative studies to determine the fit between the newly developed products/services and the customers. Conduct external tests of the new product/service, and then refine them to maximize the customer uptake. Gather feedback from prospective customers and targeted populations by conducting surveys, focus groups, interviews, and detailed studies. Enlist professional services such as public relations or market research organizations." ;
    rdfs:label "Conduct customer tests and interviews" ;
    skos:definition "An Act of Analysis that conducts qualitative and quantitative customer tests and interviews of a new product or service and produces a customer test report capturing customer feedback." ;
    rdfs:comment "Customers participate (has participant). The report is descriptive and about the offering." ;
    skos:example "A team runs surveys and focus groups and reports prospective-customer feedback." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerTestReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P10095 a owl:Class ;
    ex:pcfID "10095" ; ex:hierarchyID "2.3.2.3" ;
    ex:apqcSourceText "Finalizing the characteristics of new products/services by appropriately weighing feedback from prospective customers against a cost-benefit analysis in order to produce a profitable business proposition. Refine the attributes of the newly developed products/services, in light of the feedback and insights collected during Conduct customer tests and interviews [10094]. Revisit the high-level business case to justify the resources assigned to the product/service project against the anticipated benefits." ;
    rdfs:label "Finalize product/service characteristics and business cases" ;
    skos:definition "An Act of Formulation that finalizes the characteristics of a new product or service by weighing customer feedback against a cost-benefit analysis, producing a product/service characteristics specification." ;
    rdfs:comment "Genus ex:ActOfFormulation (under Act of Planning): composes a Directive characteristics specification (the genuine defining output). Customer feedback is definitional input. Gate-F: the existential has-output to ex:BusinessCase (Descriptive) was DROPPED. The business case is sourced from 'Revisit the high-level business case' -- a revisit of an artifact produced earlier at 2.3.1.2, i.e. typical/intermediate, not necessary for every instance; promoting a Descriptive co-output to owl:someValuesFrom on a directive-aligned Formulation act both over-committed per the Phase-3 existential-necessity rule and created GOLDEN-PRINCIPLE tension. The revisited business case is recorded here at comment level / as a CQ target only." ;
    skos:example "A team locks down the feature set and revises the business case after testing." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceCharacteristicsSpecification ] .

ex:P10096 a owl:Class ;
    ex:pcfID "10096" ; ex:hierarchyID "2.3.2.4" ;
    ex:apqcSourceText "Reassessing the technical requirements in light of the final product/service attributes. Revisit the technical assessment to revalidate the organization's capacity for progressing with new product/service projects, in light of the revised product/service characteristics." ;
    rdfs:label "Finalize technical requirements" ;
    skos:definition "An Act of Appraisal that reassesses technical requirements in light of the finalized product or service characteristics and produces a revised technical assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): re-evaluates technical capacity, a descriptive judgement. Input is the characteristics specification." ;
    skos:example "Engineering revalidates technical feasibility after the feature set is locked." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProductServiceCharacteristicsSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TechnicalAssessment ] .

# ---- 2.3.3.x  Prepare for production/delivery (PCF 19997) ----

ex:P19997 a owl:Class ;
    ex:pcfID "19997" ; ex:hierarchyID "2.3.3" ;
    ex:apqcSourceText "Devising business plans and procedures for manufacturing/operations/production and delivery of services offered by the organization. Further in general terms the total amount of output that the manufacturing department is responsible to produce for each period." ;
    rdfs:label "Prepare for production/service delivery" ;
    skos:definition "An Act of Development that devises and installs the plans, procedures, equipment, and processes needed to produce and deliver an organization's new products and services." ;
    rdfs:comment "Anchored to ex:ActOfDevelopment: the group brings production capability into being. Children are process parts." ;
    skos:example "An operations group sources equipment and installs the production line for a new product." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10099 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10097 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11418 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10100 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19998 ] .

ex:P10099 a owl:Class ;
    ex:pcfID "10099" ; ex:hierarchyID "2.3.3.1" ;
    ex:apqcSourceText "Developing and/or sourcing the essential machinery needed for creating purpose-built processes, as well as the raw materials, to produce the new products/services. Either design the equipment and materials needed internally, or source from external vendors. Obtain the feedstock or raw materials needed to prepare the finished products, as well as the machinery - hardware and software - needed to arrange production lines, factory operations, assemblies, and manufacturing processes. Revisit the technologies that underpin the new or revised products/services in order to source the right equipment and materials." ;
    rdfs:label "Design and obtain necessary capabilities/materials and equipment" ;
    skos:definition "A Planned Act of Acquisition that designs or sources, and obtains, the production equipment and raw materials needed to produce a new product or service." ;
    rdfs:comment "Genus ex:ActOfAcquisition (Planned Act): the defining outcome is obtaining held material entities. The obtained production equipment and raw materials (ex:ProductionEquipment, ex:RawMaterial) are the material participants the act brings under the organization's control, not informational has-outputs -- in this develop/plan category (2.0) material things participate rather than fill the informational output slot (D3: informational outputs are ICEs). Supply-chain partners (vendors) participate." ;
    skos:example "A plant sources CNC machinery and feedstock from external vendors for a new line." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductionEquipment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:RawMaterial ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SupplyChainPartner ] .

ex:P10097 a owl:Class ;
    ex:pcfID "10097" ; ex:hierarchyID "2.3.3.2" ;
    ex:apqcSourceText "Identifying any changes that need to be effectuated in the organization's internal processes for manufacturing, and delivering the newly developed products/services. Determine if any changes need to be made to the production and distribution processes, in light of the new products/services. Begin production process planning. Prepare for factory layout planning. Generate shop-floor instructions and changes to the supply chain." ;
    rdfs:label "Identify requirements for changes to manufacturing/delivery processes" ;
    skos:definition "An Act of Formulation that determines the changes required in manufacturing and delivery processes for a new product or service and produces a product/service modification plan." ;
    rdfs:comment "Gate-F re-anchor: from ex:ActOfIdentification to ex:ActOfFormulation. Although phrased as 'Identify', the definitional output is a prescriptive modification plan (Directive ICE, shop-floor and supply-chain changes), so the act composes a directive and is a formulation, not an Act of Identification (GOLDEN PRINCIPLE override of the surface verb). Mirrors the parallel row ex:P10068 (2.2.2.5), which has the identical Identify+ProductServiceModificationPlan shape and was likewise anchored at ex:ActOfFormulation." ;
    skos:example "Industrial engineers determine the line and supply-chain changes a new SKU requires." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServiceModificationPlan ] .

ex:P11418 a owl:Class ;
    ex:pcfID "11418" ; ex:hierarchyID "2.3.3.3" ;
    ex:apqcSourceText "Requesting changes in the production and/or delivery operations for processing the new or revised products/services. Rectify any problems identified in the manufacturing or delivery processes (through Monitor production runs [11417]). Seek changes in components, repair machinery, optimize production lines, and tweak factory assemblies through a formal notice to the concerned division, known as an engineering change order." ;
    rdfs:label "Request engineering/process change" ;
    skos:definition "An Act of Formulation that requests changes to production or delivery operations by issuing a formal engineering change order." ;
    rdfs:comment "Genus ex:ActOfFormulation (under Act of Planning): the ECO is a prescriptive directive. Performance data from monitoring (11417) is a typical, non-definitional input." ;
    skos:example "An engineer files an ECO to repair tooling and optimize an assembly step." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EngineeringChangeOrder ] .

ex:P10100 a owl:Class ;
    ex:pcfID "10100" ; ex:hierarchyID "2.3.3.4" ;
    ex:apqcSourceText "Finalizing production process or methodology. Install and initiate the production process to manufacture the new products, using the equipment and machinery already assembled. In the case of new services, implement delivery processes and methodologies. Validate processes for the accuracy of their operation and proper functioning." ;
    rdfs:label "Install and validate production/service delivery process" ;
    skos:definition "An Act of Development that installs and initiates the production or service-delivery process using assembled equipment and validates its proper functioning." ;
    rdfs:comment "Installation brings the process into operation (development); the validation step is captured by the monitoring process part (11417). The production equipment used (ex:ProductionEquipment, a Material Artifact) is the act's definitional material participant, not an informational has-input (D3: informational I/O in this develop/plan category are ICEs)." ;
    skos:example "A plant installs the line, starts production, and validates output accuracy." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProductionEquipment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11417 ] .

ex:P11417 a owl:Class ;
    ex:pcfID "11417" ; ex:hierarchyID "2.3.3.4.1" ;
    ex:apqcSourceText "Regularly monitoring production runs of the production and/or delivery operations." ;
    rdfs:label "Monitor initial production runs" ;
    skos:definition "An Act of Information Processing that regularly monitors and logs initial production runs of the production or delivery operations and produces product/service performance data." ;
    rdfs:comment "Gate-F re-anchor: from cco:ont00000636 (Act of Appraisal) to cco:ont00000366 (Act of Information Processing). The only output is ex:ProductServicePerformanceData -- raw measured/logged run metrics, NOT a descriptive evaluative judgement against a standard. Act of Appraisal (an Act of Measuring that yields a verdict) over-committed the act to a judgement it does not produce; monitoring/logging is a measuring/information-processing act whose output is data (GOLDEN PRINCIPLE: Information-Processing -> Descriptive ICE). The judgement is deferred to the downstream engineering-change act (11418), which this precedes (and feeds)." ;
    skos:example "A line supervisor logs yield and defect rates across the first production runs." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductServicePerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000063 ; owl:someValuesFrom ex:P11418 ] .

ex:P19998 a owl:Class ;
    ex:pcfID "19998" ; ex:hierarchyID "2.3.3.5" ;
    ex:apqcSourceText "Verifying the measures/processes/techniques through systems and tools involved in the introduction of products and services." ;
    rdfs:label "Validate launch procedures" ;
    skos:definition "An Act of Verification that checks the measures, processes, and techniques involved in introducing a product or service and produces a feasibility assessment of the launch procedures." ;
    rdfs:comment "Genus ex:ActOfVerification (under Act of Appraisal): the text says 'verify ... measures/processes'. Input is the launch plan." ;
    skos:example "A launch team verifies the go-to-market procedures and tooling before release." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:LaunchPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FeasibilityAssessment ] .

####################################################################
# 11. FLOW / PRECEDENCE
#    Only one cross-reference licenses ordering in section 2.0:
#    monitoring initial runs (11417) feeds requesting an engineering
#    change (11418) -- asserted as bfo:precedes on ex:P11417 above.
#    The design-task facets of 2.3.1.8 and the parallel scans of 2.3.2
#    are not ordered.
####################################################################

####################################################################
# 12. CATALOG -> REALITY BRIDGES (ADR-001 R4)
#    Each catalog node (ex:PCF_<id>, defined in apqc-catalog.ttl)
#    designates the reality-layer process universal or capability minted
#    above. The four 'Manage' headings (2.1.1-2.1.4) designate the
#    Organization Capabilities; all other nodes designate process types.
####################################################################

ex:PCF_10061 ex:designatesProcessType ex:ProductServicePortfolioManagementCapability .
