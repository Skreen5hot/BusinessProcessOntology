@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC reality-layer slice 8.0 "Manage Information Technology (IT)"
####################################################################

<http://example.org/apqc/slice/8.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 8.0: Manage Information Technology (IT)" ;
    dct:source "APQC Process Classification Framework (Cross-Industry)" ;
    owl:versionInfo "0.1.0" ;
    rdfs:comment "Reality-layer module for APQC section 8.0. CCO pin v2.0 (2024-11-06); modeled per ADR-001 (two-layer model, R5 bounded-occurrent test). Self-contained: the shared act genera it uses are inlined from the apqc-ext.ttl registry, so it validates standalone against the pinned CCO/BFO closure with no extension merge." .

####################################################################
# ACT GENERA -- SELF-CONTAINED (canonical defs mirrored from
# apqc-ext.ttl, the D9 shared registry). Inlined so this module
# validates standalone against CCO without merging the extension.
####################################################################

ex:ActOfAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Analysis" ;
    skos:definition "An Act of Information Processing in which an Agent examines one or more input Information Content Entities and produces an Information Content Entity that represents an understanding of their subject matter." ;
    rdfs:comment "Local extension (D9). CCO 2.0 has no generic analysis class; analysis is information processing, so it is anchored under cco:ont00000366." .

ex:ActOfCommunication a owl:Class ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication (VERIFIED)
        cco:ont00000228 ;               # Planned Act -- explicit allowlist anchor: the SHACL S2 graph does not merge the CCO closure, so the verified ont00000402 ⊑ ont00000228 edge is asserted here so the chain resolves to an allowlisted Act.
    rdfs:label "Act of Communication (shared anchor)" ;
    skos:definition "A Planned Act in which an Agent transfers one or more Information Content Entities to one or more other Agents." ;
    rdfs:comment "PROPOSE-EXT (D9). Shared anchor that wraps the VERIFIED cco:ont00000402 (Act of Communication, def: 'A Planned Act in which some Information Content Entity is transferred from some Agent to Another'; parent cco:ont00000228) so the recurring 'communicate'/'convey'/'escalate'/'route' rows reuse one consistent, D6-verified parent rather than re-citing the raw IRI per class. NOT cco:ont00000379 'Act of Representative Communication' (the methodology's flagged false-friend, the truth-committing subclass): plain conveyance/escalation does not assert truth, whereas reporting (ex:ActOfReporting) does and therefore anchors under ont00000379. The cco:ont00000228 co-anchor is retained because SHACL S2 evaluates rdfs:subClassOf+ over the module graph only. Recurs in 8.0." .

ex:ActOfDataManagement a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Data Management" ;
    skos:definition "An Act of Information Processing in which an Agent stores, controls, updates, maintains, or governs access to a body of Information Content Entities so as to keep it accurate, secure, and available." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000366 (Act of Information Processing: ICEs are received, manipulated, transferred, or stored). Covers maintain-records / maintain-repository / control-access / document acts. Rejected cco:ont00001158 (Act of Data Transformation: requires executing an algorithm to transform inputs into outputs) and cco:ont00000950 (Act of Maintenance: modifies Material Artifacts, not ICEs). A standing 'Manage business information' function with no natural end is an Organization Capability (cco:ont00000568) realized in such acts, not itself a process. Recurs in information-management categories (2.0, 8.0)." .

ex:ActOfDeployment a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Deployment" ;
    skos:definition "A Planned Act in which an Agent installs, configures, distributes, or otherwise makes operationally available an IT component, software release, or solution within an organization's environment." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored at the generic cco:ont00000228 (Planned Act) because deployment places and configures a (often material) IT component into operation: it acts on material participants (IT infrastructure components / software releases, attached via obo:BFO_0000057 has participant), so it is neither a pure information-processing act nor a service-rendering act. Rejected ex:ActOfServiceProvision (renders an intangible service rather than installing/configuring a discrete component), cco:ont00000950 (Act of Maintenance: restores/preserves an existing artifact's qualities rather than first making it operational), and cco:ont00000908 (Act of Material Artifact Processing: fabricates/transforms matter rather than installing/configuring an already-built component). Recurs in IT/operations install-and-configure activities (8.0, 9.0)." .

ex:ActOfDesign a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Design" ;
    skos:definition "An Act of Planning in which an Agent devises and specifies the form, structure, and behavior of a prospective product, service, solution, process, or architecture and produces a Directive Information Content Entity (a design specification) that prescribes how it is to be realized." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic design act; designing produces a Directive ICE (a design/architecture specification) prescribing an artifact-to-be, so it is anchored under cco:ont00000511 (Act of Planning), not under cco:ont00000908 (Act of Material Artifact Processing), which physically operates on existing matter. Rejected cco:ont00000051 (Act of Construction) and cco:ont00001359 (Act of Manufacturing) as both build/mass-produce finished goods rather than authoring a concept-stage design. Recurs across develop/design categories (2.0, 4.0, 7.0, 8.0)." .

ex:ActOfDevelopment a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Development" ;
    skos:definition "A Planned Act in which an Agent brings a novel product, service, solution, technology, component, prototype, or process from a specification or concept into an existent realized state." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored at the generic cco:ont00000228 (Planned Act) because development spans both informational and material outputs (new technologies, software/hardware components, prototypes, delivery processes) and is broader than cco:ont00001359 (Act of Manufacturing, mass production) and cco:ont00000051 (Act of Construction, building to contract); a development act whose product is specifically a built/mass-produced material artifact should instead use those narrower CCO acts, attaching the material product via obo:BFO_0000057 (has participant), not has output (reserved for ICEs). Recurs across develop/build categories (2.0, 4.0, 8.0)." .

ex:ActOfFormulation a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Formulation" ;
    skos:definition "An Act of Planning in which an Agent composes and articulates a Directive Information Content Entity - such as a mission, strategy, objective, design, roadmap, or business model - that prescribes an organization's intended course of action." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000511 (Act of Planning) because formulating a strategy/mission/design is making a plan to achieve an objective; its output is a Directive ICE. Recurs across develop/define/compose-a-directive processes corpus-wide." .

ex:ActOfIdentification a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Identification (discernment sense)" ;
    skos:definition "An Act of Information Processing in which an Agent discerns and enumerates entities of a given kind and produces an Information Content Entity that registers them." ;
    rdfs:comment "Local extension (D9). NOT cco:ont00001261 'Act of Identifying' (a communication act). APQC 'Identify ...' denotes discernment, i.e. information processing." .

ex:ActOfMonitoring a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Monitoring" ;
    skos:definition "An Act of Information Processing in which an Agent repeatedly or continuously observes the state, progress, or performance of some process, system, or quantity over time and produces a Descriptive Information Content Entity that represents its tracked status against expected conditions, targets, or requirements." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic monitoring/tracking class. Anchored under cco:ont00000366 (Act of Information Processing) because monitoring ingests repeated observations (including electronic records, not only senses) and yields a descriptive status/deviation ICE -- the GOLDEN PRINCIPLE (descriptive output => information-processing genus) holds. Rejected cco:ont00000037 (Act of Observation: a single sense-based acquisition, too narrow -- monitoring also processes ICEs and is sustained); cco:ont00000636 (Act of Appraisal: renders a single bounded value/quality judgement rather than tracking status over time); and cco:ont00000345 (Act of Measuring: a single quantification against a standard at one time -- at most a method sub-step of the monitoring cycle; a node that is purely one quantification, e.g. Calculate performance measures, anchors to cco:ont00000345 directly, not here). Distinct from ex:ActOfAnalysis (one-shot examination of a fixed input set) by its continuous, longitudinal character. A standing 'Manage/Monitor X' function with no natural end is an Organization Capability (cco:ont00000568) realized in such acts, not itself a process. Recurs corpus-wide (slices 3.0/4.0/5.0/6.0/8.0/9.0/10.0/11.0/12.0/13.0). Reconciled from 10 divergent slice restatements to one definition." .

ex:ActOfScheduling a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Scheduling" ;
    skos:definition "An Act of Planning in which an Agent fixes the timing, sequencing, and resource allocation of future activities and produces a schedule (a Directive Information Content Entity) that prescribes when, in what order, and by whom those activities are to be performed." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000511 (Act of Planning, verified: 'A Planned Act that involves making a Plan to achieve some specified Objective'): a schedule is a plan whose differentia is the temporal/resource ordering of activities; its output is a Directive ICE, satisfying the GOLDEN PRINCIPLE. Distinct from ex:ActOfFormulation (mission/strategy/design) by its specifically temporal/resource-allocation product. Recurs across operations and project categories (4.0, 6.0, 8.0)." .

ex:ActOfSelection a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Selection" ;
    skos:definition "An Act of Information Processing in which an Agent chooses one or more options from a set of candidates and produces a Directive Information Content Entity that prescribes the chosen option(s)." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000366 (Act of Information Processing): receives candidate-option ICEs and yields a decision ICE. Distinct from Act of Appraisal (judges without committing) and Act of Planning. NOTE: ratifying a single already-settled option is NOT selection (no candidate set) -- anchor such acts at cco:ont00000228 (Planned Act)." .

ex:ActOfServiceProvision a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Service Provision" ;
    skos:definition "A Planned Act in which an Agent renders a service to a customer by carrying out and completing the tasks that fulfil an agreed service need." ;
    rdfs:comment "PROPOSE-EXT (D9). Operations-category signature genus for 'deliver/render/execute/deploy/operate a service' processes. Anchored at the generic cco:ont00000228 (Planned Act) because service provision need not produce or modify an artifact and need not transfer an ICE. Rejected cco:ont00000908 (Act of Material Artifact Processing: its product is a modified Material Artifact, whereas a service need not modify matter) and cco:ont00000402 (Act of Communication: mere ICE transfer). Recurs in operations/IT-service categories (4.0, 5.0, 6.0, 8.0, 9.0, 10.0)." .

ex:ActOfVerification a owl:Class ;
    rdfs:subClassOf cco:ont00000636 ;   # Act of Appraisal
    rdfs:label "Act of Verification" ;
    skos:definition "An Act of Appraisal in which an Agent subjects a product, service, solution, system, plan, control, or process to a test, audit, trial, or review against specified requirements and produces a Descriptive Information Content Entity that records whether and to what extent the requirements are met." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic verification/checking/testing class. ANCHOR CONFLICT RESOLVED: slices 2.0 and 8.0 anchored under cco:ont00000636 (Act of Appraisal); slice 11.0 anchored under cco:ont00000366 (Act of Information Processing). CHOSEN cco:ont00000636 'Act of Appraisal' (verified: 'An Act of Measuring that involves evaluating, assessing, estimating, or judging the nature, value, importance, condition, or quality of something or someone'; parent cco:ont00000345 Act of Measuring -> cco:ont00000228). Verification is the criterion-referenced JUDGEMENT of conformance of a realized artifact, system, or run against a standard -- it acts on a real entity and renders a measured pass/fail or conformance value, which is exactly what Act of Appraisal/Measuring captures (it determines quality 'relative to some standard'). The 11.0 information-processing reading over-generalizes (it would collapse audit/test/validate into mere ICE manipulation) and loses the standard-referenced measuring genus; the 2.0/8.0 appraisal reading is the nearer correct parent. Per the GOLDEN PRINCIPLE the definitional output remains a Descriptive (conformance) ICE, which is consistent under Appraisal. Rejected cco:ont00000366 (Act of Information Processing: too generic -- omits the against-a-standard measuring that individuates verification) and cco:ont00000345 (Act of Measuring per se: lacks the evaluative judgement). Distinct from ex:ActOfAnalysis (examines input ICEs) by acting on a realized artifact or run. Recurs in test/review/validate/audit/penetration-test processes corpus-wide (2.0, 4.0, 6.0, 8.0, 9.0, 11.0)." .

####################################################################
# 0. ANNOTATION PROPERTIES (provenance / traceability)
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "Catalog-to-reality bridge: links an APQC catalog node (ex:PCF_<pcfID>) to the reality-layer class (process or capability) it designates." .

####################################################################
# 1. ACT-GENUS LAYER -- PROPOSE-EXT genera (promote to apqc-ext.ttl
#    after review). REUSED from apqc-ext.ttl (NOT re-minted here):
#    ex:ActOfAnalysis, ex:ActOfIdentification, ex:ActOfFormulation,
#    ex:ActOfSelection, ex:ActOfAcquisition. The eight genera below are
#    section-8.0 PROPOSE-EXT proposals; each appears ONCE (the group
#    modules' standalone re-declarations are reconciled to these single
#    canonical definitions). Every cco: anchor verified against
#    CommonCoreOntologiesMerged v2.0 (2024-11-06): definition + parent.
####################################################################

####################################################################
# 2. SECTION-8.0 SHARED SUPPORTING VOCABULARY
#    Minted ONCE for the whole section so all seven group modules
#    (8.1-8.7) reuse one consistent set of ICEs, material entities,
#    agents/orgs, roles, and capabilities. Contains NO process classes.
#    Every cco:ont... IRI verified against CommonCoreOntologiesMerged
#    v2.0 (definition + parent read, not just label).
####################################################################

####################################################################
# 2a. AGENTS / ORGANIZATIONS (independent continuants; realizables
#     borne here only -- D4)
####################################################################

ex:ITCustomer a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ITCustomerRole ] ;
    rdfs:label "IT Customer" ;
    skos:definition "An Agent that bears an IT customer role in virtue of consuming or depending on the information-technology services and solutions provided by an organization's IT function." ;
    rdfs:comment "Section-8.0 shared. APQC 8.1 'staff dependent on information technology' / internal IT user base. Modeled as Agent (may be an individual user or, where APQC says 'community', a Group); use cco:ont00001180 (Organization) when the customer is specifically an organizational unit." .

ex:ITServiceProvider a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ITServiceProviderRole ] ;
    rdfs:label "IT Service Provider" ;
    skos:definition "An Organization that bears an IT service provider role in virtue of designing, delivering, and supporting information-technology services and solutions for its customers." ;
    rdfs:comment "Section-8.0 shared. The focal IT function / organization across 8.1, 8.5, 8.6, 8.7. Organization (a Group of Agents) per APQC 'the IT function'." .

ex:ExternalITSupportProvider a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ITServiceProviderRole ] ;
    rdfs:label "External IT Support Provider" ;
    skos:definition "An Organization that bears an IT service provider role and is external to the focal organization, engaged to supply IT support or service-delivery resources under contract." ;
    rdfs:comment "Section-8.0 shared. APQC 8.7.5.8 'coordinate with external support providers', 8.3.7.3 'external IT service provider', 8.7.1.5 sourcing. Distinguished from ex:ITServiceProvider only by being external; both bear the same provider role." .

ex:ITRiskOwner a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ITRiskOwnerRole ] ;
    rdfs:label "IT Risk Owner" ;
    skos:definition "An Agent that bears an IT risk owner role in virtue of being accountable for ensuring that a defined category of IT risk is managed appropriately." ;
    rdfs:comment "Section-8.0 shared. APQC 8.3.1.4 'establish risk ownership' -- an individual or group ultimately accountable for IT risk. Agent (individual or group)." .

ex:ITUser a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ITUserRole ] ;
    rdfs:label "IT User" ;
    skos:definition "An Agent that bears an IT user role in virtue of holding an established identity by which it is authenticated and authorized to access an organization's applications, systems, IT components, or networks." ;
    rdfs:comment "Section-8.0 shared. APQC 8.3.8 user identity and authorization, 8.6.5 / 8.7.8 user support. Distinct from ex:ITCustomer (the demand-side relationship counterpart); a user is the access-side identity holder." .

ex:EnterpriseArchitect a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:EnterpriseArchitectRole ] ;
    rdfs:label "Enterprise Architect" ;
    skos:definition "An Agent that bears an enterprise-architect role within an organization's IT function." ;
    rdfs:comment "Section-8.0 shared. Bearer of ex:EnterpriseArchitectRole. Participant in the enterprise-architecture definition and governance acts (8.2.3) where the role is definitional." .

####################################################################
# 2b. ROLES (borne by Agents/Organizations only -- D4)
####################################################################

ex:ITCustomerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;   # role
    rdfs:label "IT Customer Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of consuming or depending on the IT services and solutions delivered by an organization's IT function." .

ex:ITServiceProviderRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "IT Service Provider Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of being responsible for designing, delivering, and supporting IT services and solutions for customers." .

ex:ITRiskOwnerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "IT Risk Owner Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being accountable for ensuring that a defined category of IT risk is managed appropriately." ;
    rdfs:comment "APQC 8.3.1.4 / 8.3.1.5 risk ownership and risk-management roles." .

ex:ITUserRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "IT User Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of holding an established identity authorized to access an organization's IT applications, systems, components, or networks." .

ex:EnterpriseArchitectRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Enterprise Architect Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being responsible for defining, governing, and maintaining an organization's enterprise IT architecture." ;
    rdfs:comment "APQC 8.2.3 define and maintain enterprise architecture; 8.5.3 service/solution architecture." .

####################################################################
# 2c. ORGANIZATION CAPABILITIES (Agent/Organization Capabilities -- D4).
#     Standing 'Manage/Develop and manage X' headings of 8.0 that fail
#     the R5 process test are modeled as these capabilities, realized in
#     the section's acts (R6). Realized-in restrictions contributed by
#     the group modules are merged onto each shared capability here.
####################################################################

ex:ITServiceManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20632 ] ;   # realized in
    rdfs:label "IT Service Management Capability" ;
    skos:definition "An Organization Capability that inheres in an IT service provider in virtue of its capacity to design, deliver, manage, and improve the IT services used within an organization." ;
    rdfs:comment "Section-8.0 shared. Carries the standing 'Define IT service management strategy' heading (8.2.4) that fails the R5 bounded-occurrent test. Organization Capability per CCO (realized in Intentional Acts of a certain type). Gate-F fix on P20632: 8.1.5 'Develop and manage IT service levels' is modeled as a bounded ex:ActOfFormulation (its concrete deliverable, the SLA, passes R5), so it is NOT listed here as an R5 failure; the standing 'manage service levels' aspect is wired up via the obo:BFO_0000054 (realized in) restriction onto ex:P20632 above, mirroring how ex:ITCustomerRelationshipManagementCapability is realized in ex:P20608." .

ex:ITRiskManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "IT Risk Management Capability" ;
    skos:definition "An Organization Capability that inheres in an IT service provider in virtue of its capacity to identify, evaluate, mitigate, and control risks to its IT operations and assets." ;
    rdfs:comment "Section-8.0 shared. Target for standing 'Develop and manage IT resilience and risk' / 'Control IT risk, compliance, and security' headings (8.3, 8.3.3) that fail the R5 test." .

ex:InformationManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20766 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20770 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20776 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20779 ] ;
    rdfs:label "Information Management Capability" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to govern, administer, and control its information and content across the information lifecycle." ;
    rdfs:comment "Section-8.0 shared. Target for the standing 'Manage information' / 'Manage business information' headings (8.4 [PCF 20765], 8.4.4) that fail the R5 test. Realized (R6) in its four bounded child processes 8.4.1-8.4.4; the capability gets no has-process-part to its children (R3)." .

ex:ITSupportCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "IT Support Capability" ;
    skos:definition "An Organization Capability that inheres in an IT service provider in virtue of its capacity to provide support to users of its IT services and solutions, including issue and request resolution." ;
    rdfs:comment "Section-8.0 shared. Target for standing 'Create and manage support services/solutions' / 'Operate IT user support' headings (8.7, 8.7.8) and the standing rollout-support nodes 8.6.5.3/.5/.6 [PCF 20861/20863/20864] that fail the R5 test. APQC 8.7.8.2 / 8.6.5.6 'IT resolution capabilities'." .

ex:ITInfrastructureManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "IT Infrastructure Management Capability" ;
    skos:definition "An Organization Capability that inheres in an IT service provider in virtue of its capacity to plan, administer, and maintain the IT infrastructure resources, inventory, and assets that support business operations." ;
    rdfs:comment "Section-8.0 shared. Target for standing 'Develop and manage infrastructure resource planning' / 'Manage infrastructure resource administration' headings (8.7.4, 8.7.7) that fail the R5 test." .

ex:ITCustomerRelationshipManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20608 ] ;
    rdfs:label "IT Customer Relationship Management Capability" ;
    skos:definition "An Organization Capability that inheres in an IT service provider in virtue of its capacity to establish, coordinate, and sustain relationships with its IT customers over multiple touch points." ;
    rdfs:comment "Section-8.0 shared. Target for standing 'Develop and manage IT customer relationships' / 'Manage IT customer relationships' headings (8.1, 8.1.6) that fail the R5 test. 8.1.3.1 (PCF 20618) and 8.1.6 (PCF 20641) are standing functions realized (R6) in the bounded IT-customer-relationship acts of group 8.1." .

####################################################################
# 2d. MATERIAL ENTITIES (IT assets / infrastructure / components.
#     Legal as material I/O in operations category 8.0 -- D-operations.)
####################################################################

ex:ITAsset a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ,   # Material Artifact
        obo:BFO_0000040 ;   # material entity -- explicit anchor (Material Artifact is a BFO material entity in CCO; asserted here so the standalone SHACL input-kind chain resolves)
    rdfs:label "IT Asset" ;
    skos:definition "A Material Artifact that is a hardware or software resource owned or used by an organization to store, retrieve, transmit, or manipulate data in support of business operations." ;
    rdfs:comment "Section-8.0 shared material entity. APQC 8.1.2.2 / 8.3 'IT Assets', 8.7.7.4 'IT asset records'. Genus Material Artifact (cco:ont00000995); use the narrower ex:ITInfrastructureComponent for deployed computing/network hardware. Material I/O is legal in operations category 8.0." .

ex:ITInfrastructureComponent a owl:Class ;
    rdfs:subClassOf ex:ITAsset ,
        cco:ont00000117 ;   # Information Processing Artifact
    rdfs:label "IT Infrastructure Component" ;
    skos:definition "An IT Asset that is also an Information Processing Artifact, comprising a discrete hardware, software, or network element of an organization's IT infrastructure (such as a server, network device, or installed software package)." ;
    rdfs:comment "Section-8.0 shared. APQC 8.5.4.1.3 'build and test components', 8.6.4 / 8.7.7.3 install/configure/upgrade components, 8.7.7.1 configuration items. Doubly anchored: an IT Asset (cco:ont00000995) and an Information Processing Artifact (cco:ont00000117, designed to transform ICEs)." .

ex:ITServiceSolution a owl:Class ;
    rdfs:subClassOf cco:ont00000117 ;   # Information Processing Artifact
    rdfs:label "IT Service/Solution" ;
    skos:definition "An Information Processing Artifact that is an assembled, deployable information-technology offering (a configured system, application, or service package) made available by an IT function for use by its customers." ;
    rdfs:comment "Section-8.0 shared. The realized, deployable 'IT service/solution' that 8.5 creates/tests, 8.6 deploys, and 8.7 supports -- as a built artifact (material output of development/deployment via obo:BFO_0000057 has participant, never has output which is reserved for ICEs). Distinct from the INFORMATIONAL descriptors ex:ITServiceCatalog / ex:ITSolutionDesignSpecification, which are ICEs about it." .

####################################################################
# 2e. INPUT INFORMATION CONTENT ENTITIES (Descriptive unless noted)
####################################################################

ex:ITCustomerRequirements a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "IT Customer Requirements" ;
    skos:definition "A Descriptive Information Content Entity that describes the needs, expectations, and business requirements that IT customers place on the IT services and solutions to be delivered." ;
    rdfs:comment "Section-8.0 shared input. APQC 8.1.4.2 collect, 8.1.4.3 analyze, 8.2.4.2 / 8.5.4.1.1 requirements. Descriptive: it states needs rather than prescribing action." .

ex:BusinessObjectives a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "Business Objectives" ;
    skos:definition "A Directive Information Content Entity that prescribes the overall business goals an organization intends its IT function to advance." ;
    rdfs:comment "Section-8.0 shared input. Recurs across 8.2 (align IT to business objectives), 8.5.1, 8.6.1, 8.7.1.1, 8.7.4.2. Directive: objectives prescribe an intended end-state." .

ex:ITLandscapeData a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Landscape Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the logical structure, hardware and software configuration, and working of an organization's existing IT environment." ;
    rdfs:comment "Section-8.0 shared input. APQC 8.1.2.2 'understand IT landscape', 8.7.4.3 existing infrastructure capabilities, 8.7.7.1 configuration, 8.7.7.4 asset records. Descriptive." .

ex:EmergingTechnologyData a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Emerging Technology Data" ;
    skos:definition "A Descriptive Information Content Entity that describes new, emerging, and potentially disruptive technologies relevant to an organization's IT capabilities." ;
    rdfs:comment "Section-8.0 shared input. APQC 8.2.1.2 monitor/map technologies, 8.2.7.2 analyze emerging concepts, 8.5.2.1 track capabilities. Descriptive." .

ex:ITPerformanceData a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Performance Data" ;
    skos:definition "A Descriptive Information Content Entity that describes measured values of IT cost, utilization, availability, quality, and service-level attainment used to evaluate IT performance." ;
    rdfs:comment "Section-8.0 shared input. APQC 8.1.7, 8.2.5.x monitor/analyze performance, 8.7.6.4. Descriptive: it records measured values. Distinct from ex:ITPerformanceReport (the analysed output)." .

ex:RegulatoryRequirementData a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Requirement Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the IT-relevant regulatory, audit, and legal requirements imposed on an organization by external authorities." ;
    rdfs:comment "Section-8.0 shared input. APQC 8.3.1.1 determine/evaluate regulatory and audit requirements, 8.3.6, 8.3.5.1. Descriptive: it states externally-imposed requirements." .

ex:ITSecurityThreatData a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Security Threat Data" ;
    skos:definition "A Descriptive Information Content Entity that describes threats, vulnerabilities, and breach points affecting an organization's critical IT assets and data flows." ;
    rdfs:comment "Section-8.0 shared input. APQC 8.3.3.2 analyze threat impact, 8.3.8.2 network breaches, 8.3.8.7 pen testing, 8.7.6.7. Descriptive." .

ex:ITCustomerFeedback a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Customer Feedback" ;
    skos:definition "A Descriptive Information Content Entity that describes IT customers' evaluations of the effectiveness and satisfaction of delivered IT products and services." ;
    rdfs:comment "Section-8.0 shared input. APQC 8.1.7.3 collect feedback, 8.1.5.2 customer feedback in forecasting. Descriptive." .

ex:ITIssueRequest a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Issue/Request" ;
    skos:definition "A Descriptive Information Content Entity that describes a reported IT incident, problem, or service request raised by a user for routing, tracking, and resolution." ;
    rdfs:comment "Section-8.0 shared input/work item. APQC 8.7.8 operate IT user support (triage/manage/escalate/resolve requests), 8.7.5.9 triage incidents. Descriptive: it records the reported matter." .

####################################################################
# 2f. OUTPUT INFORMATION CONTENT ENTITIES -- DIRECTIVE
#     (strategies / plans / policies / standards / objectives / specs /
#      catalogs / SLAs / roadmaps / decisions)
####################################################################

ex:ITStrategy a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;   # Directive ICE
    rdfs:label "IT Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization-wide direction for the IT function, aligning IT investments, capabilities, and activities with business objectives." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.2.1 business technology and governance strategy, 8.2.1.6 digital transformation strategy, 8.2.4 service-management strategy, 8.5.1, 8.7.1/8.7.2 delivery/support strategy. Directive: it prescribes a direction." .

ex:ITVision a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Vision" ;
    skos:definition "A Directive Information Content Entity that prescribes the long-term goals, direction, and intended future state of an organization's information technology." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.2.3 'develop IT visioning'. Directive: a vision prescribes an intended end-state. Distinct from the broader ex:ITStrategy." .

ex:ITRoadmap a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Roadmap" ;
    skos:definition "A Directive Information Content Entity that prescribes a sequenced plan of milestones for moving the IT environment from its current state to a planned future state." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.2.4 service expectations roadmap, 8.1.4.9 transformation roadmap. Directive: a roadmap prescribes a course of action over time." .

ex:ITTransformationPlan a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Transformation Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes how an organization is to replace or upgrade its IT operating model, governance, service delivery, and workforce from a current to an expected state." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.4.1 develop transformation plans, 8.7.4.4 infrastructure change. Directive." .

ex:ITServiceCatalog a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Service Catalog" ;
    skos:definition "A Directive Information Content Entity that constitutes an organized, curated collection of the IT-related services that may be performed by, for, or within an organization, together with their deliverables, prices, contact points, and request processes." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.3 plan and communicate IT services, 8.1.5.3 maintain catalog, 8.2.4.3 / 8.7.1.2 define catalog/portfolio. Directive: a catalog prescribes the available offerings and how to obtain them (a curated specification), not a mere description of reality." .

ex:ServiceLevelAgreement a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Service Level Agreement" ;
    skos:definition "A Directive Information Content Entity that prescribes the negotiated commitments, service targets, priorities, and responsibilities governing the provision of IT services to a customer." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.5.4 / 8.1.5.6 define/negotiate SLAs, 8.1.7.1 SLA compliance, 8.7.5.1 SLAs. Directive: an SLA prescribes commitments." .

ex:ITPolicy a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes rules and standards governing the creation, use, security, privacy, access, and disposition of an organization's IT services, data, and infrastructure." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.3.3.4 / 8.3.5.3 security and privacy policies, 8.4.3.1 information policies, 8.6.1.2 deployment policies, 8.3.8.1 authorization policies. Directive." .

ex:ITStandard a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Standard" ;
    skos:definition "A Directive Information Content Entity that prescribes the principles, criteria, and conformance requirements that govern IT architecture, development, change, and deployment decisions." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.2.3.1 architecture principles, 8.5.1.2 development standards, 8.6.1.4 change/release standards, 8.3.3.7 communication standards. Directive: a standard prescribes required criteria." .

ex:ITRiskMitigationStrategy a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Risk Mitigation Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes activities and approaches for reducing threats to, and improving the resilience of, an organization's IT operations and projects." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.3.1.10 / 8.3.2.4 mitigation strategies and approaches, 8.3.2 resilience strategy. Directive." .

ex:ITContinuityPlan a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Continuity Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the resources, procedures, and actions required to maintain or rapidly recover critical IT services when exposed to internal or external disruption." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.3.7.2 business continuity planning, 8.3.4 plan and manage IT continuity, 8.7.8.6 continuity and recovery action. Directive." .

ex:ITComplianceRequirementSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Compliance Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the compliance standards and control requirements an organization's IT must satisfy to meet regulatory and audit obligations." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.3.3.3 create/maintain compliance requirements, 8.3.1.6 compliance objectives. Directive." .

ex:EnterpriseArchitectureSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Enterprise Architecture Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the principles, components, frameworks, and governance rules that constitute an organization's enterprise IT architecture." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.2.3 define and maintain enterprise architecture, 8.4.2 information architecture, 8.5.3 service/solution architecture. Directive: an architecture specification prescribes how IT is to be structured." .

ex:ITSolutionDesignSpecification a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Solution Design Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the form, structure, and behavior of a prospective IT service or solution so that it may be built and deployed." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.4.5 facilitate solution design, 8.5.4.1.2 create service/solution design, 8.5.5.1.2 modify design, 8.6.1.3 deployment workflow. Directive: a design specification prescribes an artifact-to-be (output of ex:ActOfDesign)." .

ex:ITServiceManagementPlan a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Service Management Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the processes, people, technology, and lifecycle approach by which IT services are designed, delivered, supported, and improved within an organization." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.2.4 define IT service management strategy/framework, 8.5.2 lifecycle planning, 8.7.1.3 / 8.7.2.3 delivery/support model. Directive." .

ex:DeploymentPlan a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Deployment Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the schedule, sequence, procedures, and roll-back arrangements for deploying a change to IT services or solutions." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.6.1 deployment strategy, 8.6.2 plan implementation, 8.6.2.2 schedule/roll-out sequence, 8.6.4.7 / 8.6.4.9 roll-back plan. Directive." .

ex:ITPortfolioPlan a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Portfolio Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the prioritized allocation of resources across an organization's IT investments, projects, and activities to achieve business objectives." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.2.2 manage IT portfolio strategy, 8.2.6.4 portfolio adjustments, 8.2.7.7 plan investment projects, 8.7.1.2 / 8.7.2.2 delivery/support portfolio. Directive: it prescribes resource allocation and prioritization." .

ex:ResourceSchedule a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Resource Schedule" ;
    skos:definition "A Directive Information Content Entity that prescribes the timing, sequencing, and resource allocation of IT service-delivery, batch, change/release, or backup activities." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.7.3.1.x schedule service-delivery resources / batch jobs / change-release windows / backup activities, 8.6.2.2 / 8.6.3.5 deployment schedule. Directive (output of ex:ActOfScheduling)." .

ex:ITTrainingProgram a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Training Program" ;
    skos:definition "A Directive Information Content Entity that prescribes the content, audience, and delivery of instruction provided to IT staff or users on IT services, risk, resilience, or change." ;
    rdfs:comment "Section-8.0 shared output / instrument. APQC 8.3.3.5 risk-management training, 8.3.7.4 resilience training, 8.6.2.5 / 8.6.5.1 IT training. Directive: a program prescribes what is to be taught and to whom." .

ex:RemediationPlan a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Remediation Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes corrective actions, resources, and responsibilities for closing identified IT gaps, compliance issues, or service/solution defects." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.7.2 triage and plan remediation, 8.3.6.4 remediation requirements, 8.5.5.1.3 service/solution remediation, 8.6.4.9 roll-back plan. Directive." .

####################################################################
# 2g. OUTPUT INFORMATION CONTENT ENTITIES -- DESCRIPTIVE
#     (assessments / analyses / reports / audits / monitoring results /
#      confirmations / forecasts)
####################################################################

ex:ITCustomerNeedsAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;   # Descriptive ICE
    rdfs:label "IT Customer Needs Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes an understanding of IT customers' needs, capabilities, and usage gathered from interaction and evaluation." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.1 understand IT customer needs, 8.1.1.2 assess operational capabilities. Descriptive: it represents an understanding (GOLDEN PRINCIPLE)." .

ex:ITRequirementsAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ;
          owl:onProperty cco:ont00001808 ;   # is about
          owl:someValuesFrom ex:ITCustomerRequirements ] ;
    rdfs:label "IT Requirements Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the result of assessing collected IT customer requirements, including identified gaps between expected and current business outcomes." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.4.3 analyze requirements, 8.5.4.1.1 assess/validate requirements. Descriptive analysis; carries 'is about' its subject IT customer requirements." .

ex:ITRiskAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Risk Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes identified IT risks together with a judgement of their likelihood, impact, and criticality to IT operations and objectives." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.3.1.8 identify and evaluate IT risk, 8.3.2.2 critical risks, 8.3.3.8 risk and threat assessments. Descriptive: an assessment reports a judgement." .

ex:ITSecurityThreatAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Security Threat Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the analyzed impact of security threats on an organization's critical IT assets and functions." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.3.3.2 analyze IT security threat impact, 8.3.8.7 penetration-test findings, 8.7.6.7 infrastructure security. Descriptive." .

ex:ITComplianceAuditReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Compliance Audit Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the findings of an audit evaluating whether IT capability and resources conform to applicable regulations, standards, and legislation." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.3.6 conduct and analyze IT compliance assessments, 8.3.6.2 compliance control auditing, 8.3.6.3 compliance reporting, 8.3.8.5 audit identity systems, 8.4.4.3 usage audits, 8.6.3.2 confirm change compliance. Descriptive: an audit report records findings (output of ex:ActOfVerification)." .

ex:ITPerformanceReport a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the analyzed performance of IT services, projects, finances, and value against established measures and targets." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.2.5 control IT management system, 8.2.5.8 report performance, 8.1.7.4 synthesize/distribute performance, 8.7.6.4 infrastructure performance. Descriptive: it reports measured/analysed performance." .

ex:SLAComplianceAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ;
          owl:onProperty cco:ont00001808 ;   # is about
          owl:someValuesFrom ex:ServiceLevelAgreement ] ;
    rdfs:label "SLA Compliance Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the measured attainment of the service targets defined in a service level agreement over a review period." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.7.1 assess SLA compliance. Descriptive; carries 'is about' the service level agreement it evaluates." .

ex:ITDeploymentImpactAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Deployment Impact Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the business impact, benefit, and risk of deploying an IT change or release." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.6.1.1 assess deployment business impact, 8.6.1.6 analyze outcomes, 8.6.3.1 change/release impact, 8.6.2.1 / 8.6.3.3 deployment risk. Descriptive: an assessment reports a judgement." .

ex:ITSolutionValidationResult a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Solution Validation Result" ;
    skos:definition "A Descriptive Information Content Entity that describes the result of testing or validating that an IT service or solution is feasible and meets the customer requirements it is intended to satisfy." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.5.4.1.5 validation, 8.6.4.6 verify implementation success, 8.6.4.4 confirm completion, 8.6.4.1 confirm operational status. Descriptive: it records a validation judgement (output of ex:ActOfVerification)." .

ex:ITServiceDemandForecast a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Service Demand Forecast" ;
    skos:definition "A Descriptive Information Content Entity that describes the anticipated future demand and usage of an organization's IT services." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.1.5.2 forecast IT service demand, 8.1.3.2 define future IT services, 8.7.5.1 support demand patterns. Descriptive (a forecast describes an expected future state)." .

ex:TechnologyAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Technology Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of current, emerging, and disruptive technologies relevant to an organization's IT vision and capabilities." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.2.1.2 monitor/map technologies, 8.2.7.2 analyze emerging concepts, 8.5.2.1 track capabilities, 8.7.2.6 support tools. Descriptive. (Mirrors the reference-module ex:TechnologyAssessment of slice 1.1.1; kept identically labeled and defined for cross-section consistency.)" .

ex:ITResearchFindings a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Research Findings" ;
    skos:definition "A Descriptive Information Content Entity that describes the insights and conclusions reached by systematically investigating technologies and sources to innovate IT services and solutions." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.2.3.3 research technologies to innovate, 8.2.7.3 / 8.2.7.4 execute research projects, 8.2.7.5 evaluate outcomes. Descriptive." .

ex:ITValueContributionAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Value Contribution Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a quantified judgement of the value and benefits that IT investments, services, and projects contribute to business operations." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.2.6 manage IT value portfolio, 8.2.6.2 quantify value, 8.2.5.5 monitor value and benefits, 8.2.6.3 communicate value, 8.7.1.1 / 8.7.2.1 / 8.7.4.2 assess value contribution. Descriptive." .

ex:BusinessTechnologyValueCommunication a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ;
          owl:onProperty cco:ont00001808 ;   # is about
          owl:someValuesFrom ex:ITValueContributionAssessment ] ;
    rdfs:label "Business Technology Value Communication" ;
    skos:definition "A Descriptive Information Content Entity that describes, for a stakeholder audience, the value contribution delivered through adopting technology for profitable business operations." ;
    rdfs:comment "Minted (8.2.6.3) as the communicated descriptive product of P20696 'Communicate business technology value contribution'. Descriptive: an Act of Reporting (cco:ont00000151) characteristically yields a communicated Descriptive ICE, so this is the has-output that the bare has-input previously lacked -- Gate-F fix restoring sibling consistency with P20690 (input+output) and GOLDEN-PRINCIPLE traceability. Carries 'is about' the IT value contribution assessment it conveys." .

ex:ITServiceSupportRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Service Support Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the disposition of a resolved IT issue or request, including the diagnosis and corrective actions taken." ;
    rdfs:comment "Section-8.0 shared output. APQC 8.7.8.5 resolve issues/requests, 8.7.8.3 manage requests. Descriptive: it records what was done. Distinct from the input ex:ITIssueRequest. SCOPE: confined to 8.7.8 incident/request resolution; change/release control and outcome documentation (8.6.3 / 8.6.3.7) now use the dedicated ex:ITChangeControlRecord (Gate-F fix on P20840/P20847)." .

ex:ITChangeControlRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Change Control Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the control disposition of an IT change or release, including the impact, compliance, and risk findings, the approval decision, and the recorded deployment outcome." ;
    rdfs:comment "Section-8.0 shared output. Minted for the change/release control gate and documentation outputs (8.6.3 manage change deployment control, 8.6.3.7 document change/release outcome). Descriptive: it records the change-control disposition and outcome. Distinct from ex:ITServiceSupportRecord, which is scoped to 8.7.8 help-desk incident/request resolution (whose definition is the disposition of a resolved issue/request) -- Gate-F fix on P20840/P20847, where the output filler previously mismatched the skos:definition." .

ex:ITKnowledgeRepository a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Knowledge Repository" ;
    skos:definition "A Descriptive Information Content Entity that constitutes a maintained body of service-support knowledge stored for access, revision, and reuse in resolving IT issues." ;
    rdfs:comment "Section-8.0 shared output/asset. APQC 8.7.5.3 maintain knowledge repository, 8.7.5.4 maintain support learning. Descriptive: it consists of knowledge describing IT and its issues." .

####################################################################
# 3. GROUP-LOCAL SUPPORTING ICEs (minted per group; each once).
#    Genus per GOLDEN PRINCIPLE: Descriptive (cco:ont00000853) vs
#    Directive (cco:ont00000965).
####################################################################

# ----- group 8.1 -----

ex:ITPerformanceIndicatorSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Performance Indicator Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the key performance indicators by which IT performance is to be measured across an organization." ;
    rdfs:comment "Minted locally (8.1.3.3): no shared ICE captures a KPI-definition artifact. Directive because it prescribes what to measure rather than describing a measurement." ;
    skos:example "A definition document fixing IT cost as a percentage of revenue, IT maintenance ratio, and system downtime as the official IT KPIs." .

ex:ITMarketingMessage a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Marketing Message" ;
    skos:definition "A Directive Information Content Entity that positions the value proposition of IT offerings to a segment of IT customers in order to influence their choices." ;
    rdfs:comment "Minted locally (8.1.3.4): no shared ICE captures persuasive marketing content. Directive (persuasive) rather than descriptive." ;
    skos:example "A one-line value statement promoting a self-service portal to internal IT users." .

ex:ITMarketingPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Service Marketing Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the budget, media, content, and promotional activities for marketing IT offerings to customers." ;
    rdfs:comment "Minted locally (8.1.3.5): no shared ICE captures a marketing plan. Directive because it prescribes a course of action." ;
    skos:example "A quarterly plan allocating budget across newsletters and webinars to promote a new IT service." .

ex:ITPrioritizationDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Prioritization Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes a ranking of IT opportunities or outcomes by their relative importance, effectiveness, and efficiency." ;
    rdfs:comment "Minted locally (8.1.4.4 & 8.1.4.6): shared vocab has no prioritization-decision ICE. Directive because a ranking commits to a course of action." ;
    skos:example "A ranked list designating three IT opportunities as high priority for the coming year." .

ex:ITBusinessCase a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Business Case" ;
    skos:definition "A Descriptive Information Content Entity that describes the current situation, proposed solution, financial analysis, and measurable benefits of a proposed IT initiative for its customers." ;
    rdfs:comment "Minted locally (8.1.4.7 & 8.1.4.8): no shared ICE captures a business case. Descriptive (an argument/representation) per the gold-template treatment of business cases." ;
    skos:example "A document justifying an ERP upgrade with cost-benefit figures and projected savings." .

ex:ITCustomerContract a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Customer Contract" ;
    skos:definition "A Directive Information Content Entity that records a binding commitment of IT service or product provision to a customer, including delivery and support channels." ;
    rdfs:comment "Minted locally (8.1.5.5): distinct from a Service Level Agreement (a contract may bundle hardware/software provision and support channels). Directive because it prescribes obligations." ;
    skos:example "A signed agreement to provide and support a hardware refresh for a department." .

ex:ITRelationshipManagementMechanismSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Relationship Management Mechanism Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the mechanisms and touch points for managing public relations and goodwill with IT customers." ;
    rdfs:comment "Minted locally (8.1.6.1): no shared ICE captures a relationship-mechanism design. Directive because it prescribes how relations are to be conducted." ;
    skos:example "A defined cadence of newsletters, social-media outreach, and direct conversations for an IT customer segment." .

ex:ITCapabilityCommunication a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:BusinessObjectives ] ;   # is about
    rdfs:label "IT Capability Communication" ;
    skos:definition "A Descriptive Information Content Entity that conveys, to staff and departments across an organization, the goals and objectives of the IT function and how it contributes to the overall business objectives." ;
    rdfs:comment "Minted locally (8.1.6.4) as the communicated descriptive product of P20645 'Communicate IT capabilities'. Descriptive: it gives an account of IT's goals and contribution rather than prescribing action -- the has-output the communication act previously lacked (Gate-F fix). Carries 'is about' the business objectives it relates IT capability to." ;
    skos:example "A town-hall deck describing the IT function's goals and its contribution to corporate objectives." .

# ----- group 8.2 -----

ex:BusinessTechnologyStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Business Technology and Governance Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's intended use of technology in business together with the governance of its IT investments and security." ;
    rdfs:comment "8.2.1 supporting class. Directive (GOLDEN PRINCIPLE): a strategy prescribes a course of action. Output of an Act of Formulation." .

ex:ITStrategicAlignmentSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Strategic Alignment Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes how an organization's business divisions, staff, and resources are to be aligned with its planned IT objectives." ;
    rdfs:comment "8.2 supporting class. Directive: prescribes the intended alignment. Output of develop/align acts (8.2.1.4, 8.2.2.5, 8.2.2.6)." .

ex:ITAlignmentPrinciples a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Alignment Principles" ;
    skos:definition "A Directive Information Content Entity that prescribes the guiding principles governing how information technology is used in relation to business objectives." ;
    rdfs:comment "8.2.1.5 output. Directive: principles prescribe rather than describe." .

ex:ITValueCriteria a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Value Criteria" ;
    skos:definition "A Directive Information Content Entity that prescribes the standards used to determine the value of IT investments, projects, and activities for business objectives." ;
    rdfs:comment "8.2.2.1 output. Directive: criteria/standards prescribe how value is to be judged." .

ex:ITProjectPrioritization a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Project Prioritization" ;
    skos:definition "A Directive Information Content Entity that prescribes a ranked ordering of IT projects from most to least critical to business operations." ;
    rdfs:comment "8.2.2.4 / 8.2.3.4 output. Directive: a ranked decision prescribing which projects take precedence." .

ex:EnterpriseArchitecturePrinciples a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Enterprise Architecture Principles" ;
    skos:definition "A Directive Information Content Entity that prescribes the high-level fundamental values guiding IT decision-making and forming the foundation for enterprise architecture." ;
    rdfs:comment "8.2.3.1 output. Directive: principles prescribe; foundation for the EA specification." .

ex:EnterpriseArchitectureGovernanceModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Enterprise Architecture Governance Model" ;
    skos:definition "A Directive Information Content Entity that prescribes the rules, regulations, policies, and standards governing the components of an enterprise's IT architecture and the architecture as a whole." ;
    rdfs:comment "8.2.3.2 output. Directive: a governance model prescribes how the architecture is to be governed." .

ex:ITControlGovernanceModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Control and Assurance Governance Model" ;
    skos:definition "A Directive Information Content Entity that prescribes the control points, evaluation procedures, and quality-control procedures by which control is exercised over the IT management system." ;
    rdfs:comment "8.2.5.2 output. Directive: prescribes the control/assurance structure and procedures." .

ex:ITPerformanceMeasureSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Performance Measure Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the key performance indicators and measures, including the IT services performance index, used to evaluate IT performance." ;
    rdfs:comment "8.2.5.1 output. Directive: a measure/KPI specification prescribes how performance is to be measured." .

ex:ITResourceOptimizationPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Resource Optimization Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the process for assigning and managing IT assets in support of an organization's strategic goals." ;
    rdfs:comment "8.2.5.6 output. Directive: prescribes the resource-allocation process." .

ex:ITPortfolioAdjustmentDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Portfolio Adjustment Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes adjustments to IT investments, projects, and activities in response to technological advancements in pursuit of business objectives." ;
    rdfs:comment "8.2.6.4 output. Directive: a decision prescribing the adjustments to enact." .

ex:ITResearchSelectionCriteria a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Research Selection Criteria" ;
    skos:definition "A Directive Information Content Entity that prescribes the standards for selecting IT research initiatives so they align with organizational criteria for implementing future technologies." ;
    rdfs:comment "8.2.7.1 output. Directive: criteria prescribe which research initiatives qualify." .

ex:ITInnovationPromotionDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Innovation Promotion Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes which viable IT innovation concepts are to be promoted in pursuit of business objectives." ;
    rdfs:comment "8.2.7.6 output. Directive: selects and prescribes the concepts to advance." .

ex:DigitalTransformationStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Digital Transformation Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes the integration of digital technology into an organization's business operations and service delivery." ;
    rdfs:comment "8.2.1.3 output. Directive: prescribes the transformation course of action. (Distinct from the shared ex:ITTransformationPlan, which is the broader execution plan.)" .

ex:ITInvestmentBalanceAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Investment Balance Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the uninvested portion of the total approved amount for IT management, investments, projects, and activities." ;
    rdfs:comment "8.2.2.2 output. Descriptive: reports a state of the portfolio." .

ex:ITInvestmentProjectEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Investment Project Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes the assessed implementation feasibility, efficiency, and profitability of proposed IT investment projects relative to business objectives." ;
    rdfs:comment "8.2.2.3 output. Descriptive: judges proposed projects without prescribing the portfolio decision." .

ex:ITResearchOutcomeAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Research Outcome Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the assessed results of IT research projects against their defined outcome expectations." ;
    rdfs:comment "8.2.7.5 output. Descriptive: appraises research outcomes." .

# ----- group 8.3 -----

ex:ITRegulatoryAuditRequirementAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Regulatory and Audit Requirement Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the IT regulatory and audit requirements applicable to an organization together with an evaluation of their implications." ;
    rdfs:comment "8.3.1.1 output. Descriptive." ;
    skos:example "A compliance team's documented evaluation of which audit and regulatory obligations apply to a new IT product." .

ex:ITRiskToleranceSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Risk Tolerance Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the maximum acceptable risk, in quantitative terms, for each relevant IT risk sub-category (strategic, operational, financial, and compliance)." ;
    rdfs:comment "8.3.1.3 output. Directive." ;
    skos:example "A board-approved statement that operational IT downtime risk shall not exceed a stated annual loss threshold." .

ex:BusinessUnitRiskToleranceProfile a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Business Unit Risk Tolerance Profile" ;
    skos:definition "A Descriptive Information Content Entity that describes the risk tolerance levels of individual business units given their risk-return trade-offs." ;
    rdfs:comment "8.3.1.2 output. Descriptive." ;
    skos:example "A summary of each business unit's appetite for IT-service disruption." .

ex:ITComplianceObjective a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Compliance Objective" ;
    skos:definition "A Directive Information Content Entity that prescribes a compliance objective ensuring that an organization has systems of internal controls adequately measuring and managing IT risk." ;
    rdfs:comment "8.3.1.6 output. Directive." ;
    skos:example "An objective requiring all IT changes to pass a documented control review before release." .

ex:ITRiskOwnershipAssignment a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Risk Ownership Assignment" ;
    skos:definition "A Directive Information Content Entity that prescribes which individual or group is ultimately accountable for ensuring that IT risks are managed appropriately." ;
    rdfs:comment "8.3.1.4 output. Directive." ;
    skos:example "A RACI entry naming the CISO as accountable owner of cyber-security risk." .

ex:ITRiskManagementRoleSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Risk Management Role Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the specialized risk-management roles for each IT risk area together with their escalation structure." ;
    rdfs:comment "8.3.1.5 output. Directive." ;
    skos:example "A definition of a 'Cloud Risk Lead' role and its escalation path to the IT risk committee." .

ex:ITComplianceSupportSystemIdentification a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Compliance Support System Identification" ;
    skos:definition "A Descriptive Information Content Entity that describes the information-technology solutions identified and adopted to support changing regulatory compliance." ;
    rdfs:comment "8.3.1.7 output. Descriptive." ;
    skos:example "A shortlist of GRC tools selected to track regulatory obligations." .

ex:ITResilienceAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Resilience Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of an organization's IT resilience strategies and its ability to manage and recover from risk." ;
    rdfs:comment "8.3.1.9 / 8.3.2.1 / 8.3.4.1 output. Descriptive." ;
    skos:example "An assessment rating the resilience of IT delivery against named disruption scenarios." .

ex:ITResilienceStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Resilience Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes how IT across an organization is to adapt to and avoid prospective risks and disruptions." ;
    rdfs:comment "8.3.2 output. Directive." ;
    skos:example "An enterprise IT resilience strategy specifying redundancy, recovery, and adaptation measures." .

ex:ITRiskPrioritization a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Risk Prioritization" ;
    skos:definition "A Directive Information Content Entity that prescribes a ranked ordering of potential IT risks by business need, committing the organization to a mitigation sequence so as to support overall IT stability." ;
    rdfs:comment "8.3.2.3 output. Gate-F fix: reclassified from Descriptive (cco:ont00000853) to Directive (cco:ont00000965) for consistency with the parallel ranking outputs ex:ITProjectPrioritization and ex:ITPrioritizationDecision, both Directive. A risk ranking that commits to a mitigation order prescribes a course of action (output of ex:ActOfSelection at P20719). Also serves as the Directive input to P20720 'Establish mitigation approaches for IT risks'." ;
    skos:example "A ranked risk register placing data-loss risk above intermittent-latency risk, fixing the mitigation order." .

ex:RegulatoryComplianceObligationEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory and Compliance Obligation Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes an evaluation of an organization's enterprise regulatory requirements and compliance obligations." ;
    rdfs:comment "8.3.3.1 / 8.3.5.1 output. Descriptive." ;
    skos:example "A report mapping enterprise IT obligations to applicable regulations." .

ex:ITRiskReportingSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Risk Reporting Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the processes, capabilities, and responsibilities for communicating IT risk throughout an organization." ;
    rdfs:comment "8.3.3.6 output. Directive." ;
    skos:example "A reporting matrix specifying who escalates which IT risk to whom and when." .

ex:ITCommunicationStandard a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Communication Standard" ;
    skos:definition "A Directive Information Content Entity that prescribes standards for communications within an organization, creating a road map for understanding strategic IT and business initiatives." ;
    rdfs:comment "8.3.3.7 output. Directive." ;
    skos:example "A standard mandating a common template for IT-change communications." .

ex:ITSecurityGovernanceSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Security and Privacy Governance Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's approach to governing IT security and the privacy of data flows, together with the tools supporting that governance." ;
    rdfs:comment "8.3.5.2 output. Directive." ;
    skos:example "A governance charter defining decision rights and tooling for data-privacy controls." .

ex:ITSecurityControlReview a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Security Control Review" ;
    skos:definition "A Descriptive Information Content Entity that describes the findings of identifying, examining, and reviewing IT security controls or measures (physical, logical, application, or environmental)." ;
    rdfs:comment "8.3.5.4/.5/.6 output. Descriptive." ;
    skos:example "A review documenting that access-control and cryptographic measures meet policy." .

ex:NetworkIntrusionThreatResolution a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Network Intrusion Threat Resolution" ;
    skos:definition "A Descriptive Information Content Entity that describes malicious activity or policy violations detected in network intrusion data together with the gaps identified and threats resolved." ;
    rdfs:comment "8.3.5.7 output. Descriptive." ;
    skos:example "An incident record describing a blocked intrusion and the network-security gap it exposed." .

ex:ITContinuityGapRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Continuity Gap Register" ;
    skos:definition "A Descriptive Information Content Entity that describes the limitations of an IT organization's ability to remediate disruptions in IT services." ;
    rdfs:comment "8.3.4.2 output. Descriptive." ;
    skos:example "A register listing services lacking a tested recovery procedure." .

ex:ITComplianceIssueRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Compliance Issue and Remediation Requirement Register" ;
    skos:definition "A Descriptive Information Content Entity that describes identified and escalated IT compliance issues together with the corrective and remediation requirements they call for." ;
    rdfs:comment "8.3.6.4 output. Descriptive." ;
    skos:example "An escalated finding that a service breaches a retention regulation, with the required remediation noted." .

ex:NetworkIntrusionDetectionData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Network Intrusion Detection Data" ;
    skos:definition "A Descriptive Information Content Entity that describes events captured by network intrusion detection sensors for assessment of malicious activity or policy violations." ;
    rdfs:comment "8.3.5.7 input. Descriptive." ;
    skos:example "A stream of IDS alerts for a monitored network segment." .

ex:PenetrationTestFinding a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Penetration Test Finding" ;
    skos:definition "A Descriptive Information Content Entity that describes security weaknesses in an IT environment discovered through an authorized simulated attack." ;
    rdfs:comment "8.3.8.7 output. Descriptive." ;
    skos:example "A pen-test report listing an exploitable misconfiguration and its severity." .

ex:ITUserAuthorizationPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT User Identity and Authorization Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes how authorization policies are integrated with the authorized profiles of users permitted to access network resources." ;
    rdfs:comment "8.3.8.1 output. Directive." ;
    skos:example "A policy binding role-based access entitlements to authenticated user profiles." .

ex:ITUserDirectory a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT User Directory" ;
    skos:definition "A Descriptive Information Content Entity that describes user profiles and access requirements across different levels of an organization's IT network." ;
    rdfs:comment "8.3.8.2 entity managed. Descriptive." ;
    skos:example "An LDAP directory of user accounts and group memberships." .

ex:ITSecurityBreach a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Security Breach Record" ;
    skos:definition "A Descriptive Information Content Entity that describes an unauthorized network breach - such as unauthorized access to or usage of data, applications, services, networks, or devices - together with its root cause and corrective resolution." ;
    rdfs:comment "8.3.8.6 output. Descriptive." ;
    skos:example "An incident record of an unauthorized data-exfiltration event and its remediation." .

ex:ITAuditReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Audit Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the findings of examining IT processes or systems - such as user identity and authorization systems or their integration - against required regulations." ;
    rdfs:comment "8.3.8.5/.8 output. Descriptive." ;
    skos:example "An audit report confirming that the identity-management system meets access-review regulations." .

# ----- group 8.4 -----

ex:DataInformationAnalyticObjectives a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Data, Information, and Analytic Objectives" ;
    skos:definition "A Directive Information Content Entity that prescribes the organization's intended objectives for the security, privacy, and proper use of its data, information, and analytic capabilities." ;
    rdfs:comment "8.4.1.1 output. Directive per the GOLDEN PRINCIPLE (output of a formulation act)." ;
    skos:example "A signed-off statement of data-privacy and analytics-use objectives for the coming fiscal year." .

ex:InformationGovernanceFramework a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Information Governance Framework" ;
    skos:definition "A Directive Information Content Entity that prescribes the guidelines, decision rights, and accountabilities ensuring the effective and efficient use of an organization's data, information, and analytics." ;
    rdfs:comment "8.4.1.2 output. Distinct from a single ex:ITPolicy in that it is the overarching set of governance guidelines. Directive." ;
    skos:example "An information-governance charter defining data stewardship roles and usage rules." .

ex:EnterpriseDataModelSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Enterprise Data Model Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the representation, usage, and identification of data entities and their relationships across the organization's independent or interdependent sources." ;
    rdfs:comment "8.4.2.2 output. A data model is a prescriptive design artifact, hence Directive, agreeing with its design-act genus (GOLDEN PRINCIPLE)." ;
    skos:example "An enterprise logical data model of customer, product, and order entities." .

ex:ExternalDataSourceAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "External Data Source Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes identified external data sources with respect to their reliability, security, and authenticity." ;
    rdfs:comment "8.4.2.3 output. Descriptive (it characterizes sources rather than prescribing action), agreeing with its identification-act genus (GOLDEN PRINCIPLE)." ;
    skos:example "A register rating third-party data feeds by trustworthiness and provenance." .

ex:DataStewardshipAssignment a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Data Stewardship Assignment" ;
    skos:definition "A Directive Information Content Entity that prescribes which entities are responsible for the accuracy, integrity, and timeliness of given data and who may authorize or deny access to it." ;
    rdfs:comment "8.4.2.4 output. Assigning ownership/stewardship responsibilities is prescriptive, hence Directive, agreeing with its formulation-act genus (GOLDEN PRINCIPLE)." ;
    skos:example "A RACI matrix naming the data owner and stewards for each master-data domain." .

# ----- group 8.5 -----

ex:ITDevelopmentValueAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Development Value Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the cost-effectiveness and development value of candidate IT service/solution development methods." ;
    rdfs:comment "8.5.1.1 output. Descriptive." ;
    skos:example "A pros/cons cost-benefit memo comparing two solution-development approaches." .

ex:ITServiceSolutionApproach a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Service/Solution Delivery Approach" ;
    skos:definition "A Directive Information Content Entity that prescribes the approach for delivering an IT service/solution in alignment with business needs and cost/delivery controls." ;
    rdfs:comment "8.5.2.3 output. Directive." ;
    skos:example "An agreed delivery-approach document selecting an iterative build with managed cost gates." .

ex:ServiceComponentSelectionCriteria a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Service Component Selection Criteria" ;
    skos:definition "A Directive Information Content Entity that prescribes the standards by which IT service components are selected." ;
    rdfs:comment "8.5.1.4 output / 8.5.1.5 input. Directive." ;
    skos:example "A checklist of mandatory criteria a reusable component must satisfy to be adopted." .

ex:ITServiceSolutionRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Service/Solution Register" ;
    skos:definition "A Descriptive Information Content Entity that enumerates the IT services and solutions offered to customers and the procedures that realize them." ;
    rdfs:comment "8.5.2.2 output. Descriptive." ;
    skos:example "A register listing each offered IT service with its design, delivery, and control procedures." .

ex:ITReuseOpportunityRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Component Reuse Opportunity Register" ;
    skos:definition "A Descriptive Information Content Entity that registers identified opportunities for reusing IT components." ;
    rdfs:comment "8.5.3.4 output. Descriptive." ;
    skos:example "A list of existing modules that could be reused in new solutions to cut cost." .

ex:ITArchitectureConstraintAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Architecture Constraint Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes limitations in IT application and infrastructure architecture that may hinder expected performance." ;
    rdfs:comment "8.5.3.1 output. Descriptive." ;
    skos:example "A findings note that the current message bus caps throughput below the target SLA." .

ex:ITBusinessConstraintAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Business Constraint Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes business limitations that may hinder the performance of an IT service/solution." ;
    rdfs:comment "8.5.3.2 output. Descriptive." ;
    skos:example "An assessment that a fixed annual budget constrains the chosen solution's scaling." .

ex:ITArchitectureConformanceAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Architecture Conformance Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the functional compliance of an IT service/solution architecture with applicable architecture guidelines." ;
    rdfs:comment "8.5.3.7 output. Descriptive." ;
    skos:example "A conformance report flagging two deviations from the reference architecture." .

ex:ITArchitectureExceptionResolution a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Architecture Exception Resolution" ;
    skos:definition "A Directive Information Content Entity that prescribes how an identified architectural exception is to be resolved or waived." ;
    rdfs:comment "8.5.3.8 output. Directive." ;
    skos:example "A signed waiver permitting a non-standard database for one legacy integration." .

ex:ITProcessExceptionResolution a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Service/Solution Process Exception Resolution" ;
    skos:definition "A Directive Information Content Entity that prescribes how an internal service/solution process exception or inquiry is to be resolved." ;
    rdfs:comment "8.5.4.1.7 output. Directive." ;
    skos:example "A documented decision granting an exceptional build path for an urgent feature." .

ex:ITServiceSolutionSunsetPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Service/Solution Sunset Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the retirement of IT service/solution resources once the service/solution is no longer feasible." ;
    rdfs:comment "8.5.2.5 output. Directive." ;
    skos:example "A decommissioning plan scheduling shutdown of a deprecated reporting service." .

ex:ITDevelopmentToolStandard a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Development Methodology and Tool Standard" ;
    skos:definition "A Directive Information Content Entity that prescribes the development methodologies and tools adopted for building IT services/solutions." ;
    rdfs:comment "8.5.1.3 output. Directive." ;
    skos:example "A standards page mandating the approved CI/CD pipeline and IDE toolchain." .

# ----- group 8.6 -----

ex:DeploymentApprovalAssignment a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Deployment Approval Assignment" ;
    skos:definition "A Directive Information Content Entity that prescribes which agents or roles hold deployment-approval responsibility for IT changes and releases." ;
    rdfs:comment "8.6.1.5 output. Directive (not Descriptive) because it prescribes responsibility allocation rather than describing reality." .

ex:UserTestingPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "User Testing Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the methodologies, resources, and sequence for user testing of an IT deployment." ;
    rdfs:comment "8.6.2.4 output. Directive because a plan prescribes a course of action." .

ex:ITDeploymentCommunication a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IT Deployment Communication" ;
    skos:definition "A Directive Information Content Entity that conveys to employees and stakeholders the forthcoming changes to IT services and solutions and the actions expected of them." ;
    rdfs:comment "Output of 8.6.2.6 and 8.6.5.2. Treated as Directive because deployment notices prescribe expected user actions; demote to cco:ont00000853 if a given instance is purely informational." .

ex:ChangeReleaseApproval a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Change/Release Deployment Approval" ;
    skos:definition "A Directive Information Content Entity that prescribes that a specified IT change or release deployment is permitted to proceed." ;
    rdfs:comment "8.6.3.6 output. Directive (a decision permitting an action), analogous to the GOLD ex:GoNoGoDecision pattern." .

# ----- group 8.7 -----

ex:ITIssueRequestData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Issue/Request Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the recorded history of IT issues and requests used as analytic input for demand profiling." ;
    rdfs:comment "Minted because group 8.7 demand analysis consumes a corpus of past issues/requests; distinct from the shared ex:ITIssueRequest (a single issue/request instance)." .

####################################################################
# 4. GROUP-LOCAL ORGANIZATION CAPABILITIES (R5/R6 standing functions
#    that carry a pcfID because they replace a specific catalog node).
#    Borne by an Organization (cco:ont00001180), realized in the acts
#    that exercise them (obo:BFO_0000054).
####################################################################

# --- 8.2.1.1 (PCF 20654) ---
ex:ITStrategicIntelligenceCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20655 ] ;
    rdfs:label "IT Strategic Intelligence Capability" ;
    ex:pcfID "20654" ;
    ex:hierarchyID "8.2.1.1" ;
    ex:apqcSourceText "Building and maintaining intelligence towards changing organizational goals, supporting management, and operational or functional levels of the business. It is the ability to understand business trends that present threats or opportunities for IT in an organization." ;
    skos:definition "An Organization Capability that inheres in an IT service provider in virtue of its capacity to understand business trends presenting threats or opportunities for IT and to maintain intelligence supporting management and operational levels." ;
    rdfs:comment "R5/R6 fix for APQC 8.2.1.1 [20654]: the source explicitly states 'It is the ability to understand business trends', a standing capacity with no natural end, so it is modeled as an Organization Capability rather than a bounded act. Realized in ex:P20655 (Monitor and map current and emerging technologies), the bounded acts that exercise this intelligence. The catalog node ex:PCF_20654 designates this capability per the ADR-001 R4 bridge." ;
    skos:example "An IT strategy office's standing market-and-technology-intelligence function feeding IT planning." .

# --- 8.2.1.6 (PCF 20659) ---
ex:ITStrategicAlignmentMaintenanceCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20657 ] ;
    rdfs:label "IT Strategic Alignment Maintenance Capability" ;
    ex:pcfID "20659" ;
    ex:hierarchyID "8.2.1.6" ;
    ex:apqcSourceText "Maintaining alignment of the organization's business divisions and staff members with the organization's planned objectives for IT." ;
    skos:definition "An Organization Capability that inheres in an IT service provider in virtue of its capacity to keep the organization's business divisions and staff continuously aligned with its planned IT objectives." ;
    rdfs:comment "R5/R6 fix for APQC 8.2.1.6 [20659]: 'Maintaining alignment ...' is a standing function with no natural end, modeled as an Organization Capability rather than a bounded act. Realized in ex:P20657 (Develop IT strategic alignment), the bounded act that establishes the alignment this capability sustains. The catalog node ex:PCF_20659 designates this capability." ;
    skos:example "An IT governance team's ongoing function of keeping business units aligned to IT objectives." .

# --- 8.2.5.7 (PCF 20689) ---
ex:ITInterdependencyManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20690 ] ;
    rdfs:label "IT Projects and Services Interdependency Management Capability" ;
    ex:pcfID "20689" ;
    ex:hierarchyID "8.2.5.7" ;
    ex:apqcSourceText "Manage capabilities required for the successful delivery of information technology projects, which, by extension, affect the success of the overall IT services." ;
    skos:definition "An Organization Capability that inheres in an IT service provider in virtue of its capacity to manage the interdependencies among IT projects and services required for their successful delivery." ;
    rdfs:comment "R5/R6 fix for APQC 8.2.5.7 [20689]: managing interdependencies among projects and services is a standing coordination function with no natural end, modeled as an Organization Capability rather than a bounded act. Realized in ex:P20690 (Report IT service and project performance), among the bounded control acts that exercise this coordination. The catalog node ex:PCF_20689 designates this capability." ;
    skos:example "A portfolio office's continuous coordination of cross-project and cross-service dependencies." .

# --- 8.5 (PCF 20784) group umbrella ---
ex:DevelopAndManageServicesSolutionsCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20785 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20808 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20817 ] ;
    rdfs:label "Develop and Manage Services/Solutions Capability" ;
    ex:pcfID "20784" ;
    ex:hierarchyID "8.5" ;
    ex:apqcSourceText "Develop and manage services/solutions. Create a strategy, plan the lifecycle, develop the architecture, create and test, and maintain IT services and solutions." ;
    skos:definition "An Organization Capability that inheres in an IT service provider in virtue of its capacity to develop, build, deploy, and maintain IT services and solutions." ;
    rdfs:comment "APQC group 8.5 [PCF 20784] is a standing 'develop and manage' function with no natural end, so it is modeled as an Organization Capability (R5/R6) realized in its bounded child processes, not as a process with existential has-process-part (R3). The catalog node ex:PCF_20784 designates this capability." ;
    skos:example "An IT service provider's standing capability to design, build, release, and maintain its service catalogue." .

# --- 8.6.2.7 (PCF 20839) ---
ex:ITRollBackManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20857 ] ;
    rdfs:label "IT Roll-Back Management Capability" ;
    ex:pcfID "20839" ;
    ex:hierarchyID "8.6.2.7" ;
    ex:apqcSourceText "Manage IT roll-back procedures to return a deployment to its previous operating state when a change or release impedes operational expectations." ;
    skos:definition "An Organization Capability that is realized in acts of executing IT roll-back plans to return a deployment to its previous operating state." ;
    rdfs:comment "R5/R6: APQC 8.6.2.7 [20839] 'Manage IT roll-back procedures' is a standing roll-back governance function with no natural end, so it is an Organization Capability (cco:ont00000568), not a process. Realized in ex:P20857 (Execute roll-back plan). Specialization of the shared ex:ITServiceManagementCapability." .

# --- 8.7 (PCF 20866) group umbrella ---
ex:P20866 a owl:Class ;
    ex:pcfID "20866" ; ex:hierarchyID "8.7" ;
    ex:apqcSourceText "Establishing and managing services for providing support to users of IT services and solutions. Define the plethora of services by which the organization assists users of computers, software products, or other information technology products." ;
    rdfs:label "Create and manage support services/solutions" ;
    skos:definition "An Organization Capability that an organization realizes in the acts by which it establishes and manages services for supporting users of IT services and solutions." ;
    rdfs:comment "R5/R6: the process-group node names a standing capability (no natural end), not a bounded occurrent. Modeled as cco:ont00000568 (Organization Capability) realized in its bounded child acts; no has-process-part is asserted to children (R3-style), avoiding a false universal restriction. The child 8.7.7 [20914] is itself a capability (continuant), not an act, so it takes no obo:BFO_0000054 (realized-in) edge here — that property's range is process; the partonomy to it is carried by the catalog node ex:PCF_20914." ;
    skos:example "An IT organization's standing ability to run and govern its support-services portfolio." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20867 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20873 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20880 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20888 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20895 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20905 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20921 ] .

# --- 8.7.7 (PCF 20914) ---
ex:P20914 a owl:Class ;
    ex:pcfID "20914" ; ex:hierarchyID "8.7.7" ;
    ex:apqcSourceText "Managing the resources required for administration of IT infrastructure. Manage the IT inventory and assets. Take care of the organization's IT resource capacity." ;
    rdfs:label "Manage infrastructure resource administration" ;
    skos:definition "An Organization Capability that an organization realizes in the acts by which it administers IT infrastructure resources, inventory, assets, and capacity." ;
    rdfs:comment "R5/R6: 'Manage ... administration' is a standing function with no natural end. Modeled as cco:ont00000568 (Organization Capability) realized in its bounded child acts (configuration, maintenance, deployment, records, licensing, provisioning)." ;
    skos:example "An IT department's ongoing ability to administer its infrastructure estate." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20915 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20916 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20917 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20918 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20919 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20920 ] .

# --- 8.7.5.7 (PCF 20901) ---
ex:P20901 a owl:Class ;
    ex:pcfID "20901" ; ex:hierarchyID "8.7.5.7" ;
    ex:apqcSourceText "Managing resources required for administration of IT service support. Establish sources that will make use of e-mail, live support software online, or a tool where users can log a call or incident in order to retrieve IT support." ;
    rdfs:label "Manage IT service support resources" ;
    skos:definition "An Act of Service Provision that administers and establishes the concrete support channels and resources (e-mail, live-support software, incident-logging tools) by which users retrieve IT support." ;
    rdfs:comment "Gate-F fix (R5 consistency across 'Manage X' rows): ADOPTED R5 DISCRIMINATOR for 8.0 'Manage X' rows -- 'manage <a standing estate/administration with no natural end>' => Organization Capability (cco:ont00000568); 'manage <a flow of discrete work items / a recurring operational cycle acting on concrete resources>' => bounded act. By this rule P20901 'Manage IT service support resources' is RE-CLASSIFIED from an Organization Capability to a bounded ex:ActOfServiceProvision (cco:ont00000228): like its parallels P20913 'Manage IT infrastructure/data recovery' (ActOfServiceProvision) and P20925 'Manage IT user requests' (ActOfServiceProvision), it administers concrete support channels/resources -- a recurring operational act on material participants -- and its source is no more open-ended than theirs. This removes the prior split where like-worded standing-management rows landed on opposite sides of the process/continuant divide. The same discriminator is recorded on the still-standing capability P20914 'Manage infrastructure resource administration' (which manages a standing administration/estate => kept as Organization Capability)." ;
    skos:example "A service-desk team stands up and administers its e-mail, chat, and ticketing support channels." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] .

####################################################################
# 5. PROCESS CLASSES
#    Partonomy via cco:ont00001777 (has process part); never
#    rdfs:subClassOf between processes (D1). Each ex:P<pcfID> appears
#    once. Genus per the GOLDEN PRINCIPLE.
####################################################################

# ================================================================
# GROUP 8.1  Develop and manage IT customer relationships
# ================================================================

ex:P20608 a owl:Class ;
    ex:pcfID "20608" ;
    ex:hierarchyID "8.1" ;
    ex:apqcSourceText "Creating and administering relationships with IT customers. Understanding customer needs including high-level business requirements for IT transformation. Plan for and communicate IT services along with establishing IT service levels, providing transformation guidance, and performance analysis that foster IT customer relationships." ;
    rdfs:label "Develop and manage IT customer relationships" ;
    skos:definition "An Act of Service Provision that coordinates the understanding of IT customer needs, the planning and communication of IT services, the provision of transformation guidance, and the analysis of service performance in order to foster relationships with IT customers." ;
    rdfs:comment "Models APQC process group 8.1 as a coordinating occurrent whose APQC children are process parts, not subclasses. The standing 'manage' aspect is carried by ex:ITCustomerRelationshipManagementCapability (R6)." ;
    skos:example "An IT service organization's end-to-end customer-relationship lifecycle for a fiscal year." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20609 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20612 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20617 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20623 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20632 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20648 ] .

ex:P20609 a owl:Class ;
    ex:pcfID "20609" ; ex:hierarchyID "8.1.1" ;
    ex:apqcSourceText "Assessing the customer communities along with current IT operational capabilities and usage." ;
    rdfs:label "Understand IT customer needs" ;
    skos:definition "An Act of Analysis that examines IT customer communities and their current operational capabilities and usage and produces an IT customer needs assessment." ;
    rdfs:comment "Descriptive output (needs assessment) per the GOLDEN PRINCIPLE; anchored under ex:ActOfAnalysis." ;
    skos:example "An IT relationship team reviews usage data and community input and issues a needs assessment." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCustomerNeedsAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20610 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20611 ] .

ex:P20610 a owl:Class ;
    ex:pcfID "20610" ; ex:hierarchyID "8.1.1.1" ;
    ex:apqcSourceText "Interacting with IT customers to understand the IT needs through a collaborative community through involvement, connection, and informed communication." ;
    rdfs:label "Understand IT customer communities" ;
    skos:definition "An Act of Analysis that examines IT customer communities through collaborative interaction and produces an IT customer needs assessment." ;
    skos:example "An IT liaison engages a user community forum and records the needs surfaced there." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCustomerNeedsAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITCustomer ] .

ex:P20611 a owl:Class ;
    ex:pcfID "20611" ; ex:hierarchyID "8.1.1.2" ;
    ex:apqcSourceText "Evaluate the ability of the group of staff dependent on information technology, to align resources and critical processes according to organizational vision being able to deliver effectively and efficiently." ;
    rdfs:label "Assess IT customer operational capabilities" ;
    skos:definition "An Act of Appraisal that evaluates the ability of an IT-dependent staff group to align resources and processes with organizational vision and produces an IT customer needs assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal) because it evaluates/judges a capability; descriptive output." ;
    skos:example "An analyst appraises a department's readiness to use a new platform effectively." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCustomerNeedsAssessment ] .

ex:P20612 a owl:Class ;
    ex:pcfID "20612" ; ex:hierarchyID "8.1.2" ;
    ex:apqcSourceText "Identifying changing needs of staff dependent on information technology based on continuous improvement to deliver results according to organizational goals." ;
    rdfs:label "Identify IT customer transformation needs" ;
    skos:definition "An Act of Identification that discerns the changing IT needs of IT-dependent staff and produces an IT customer needs assessment registering them." ;
    rdfs:comment "Discernment sense of identification (ex:ActOfIdentification, under information processing); descriptive output." ;
    skos:example "A relationship manager registers the evolving needs of staff as goals shift." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCustomerNeedsAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20613 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20614 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20615 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20616 ] .

ex:P20613 a owl:Class ;
    ex:pcfID "20613" ; ex:hierarchyID "8.1.2.1" ;
    ex:apqcSourceText "Understanding business requirements for the existing IT environment as well as future IT needs." ;
    rdfs:label "Understand business requirements for IT capabilities" ;
    skos:definition "An Act of Analysis that examines the business requirements for the existing and future IT environment and produces an IT requirements analysis." ;
    skos:example "A business analyst documents current and future IT requirements for a business unit." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITCustomerRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20614 a owl:Class ;
    ex:pcfID "20614" ; ex:hierarchyID "8.1.2.2" ;
    ex:apqcSourceText "Understanding the complete logical structure and working of the organization's IT landscape. Assess the configuration of hardware and software (IT Assets) across the organization that supports overall business operations." ;
    rdfs:label "Understand IT landscape" ;
    skos:definition "An Act of Analysis that examines the logical structure and configuration of the organization's IT assets and produces IT landscape data describing the landscape." ;
    rdfs:comment "IT Assets (hardware/software) are material inputs, legal in operations category 8.0 (D4); informational output is the IT landscape description." ;
    skos:example "An architect maps the hardware/software estate and records the resulting landscape model." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITAsset ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITLandscapeData ] .

ex:P20615 a owl:Class ;
    ex:pcfID "20615" ; ex:hierarchyID "8.1.2.3" ;
    ex:apqcSourceText "Developing goals to define IT vision. Define and document ideas, direction, and activities which enable information technology to reach these goals." ;
    rdfs:label "Develop IT visioning" ;
    skos:definition "An Act of Formulation that composes goals, ideas, and direction for information technology and produces an IT vision." ;
    rdfs:comment "Directive output (vision) per the GOLDEN PRINCIPLE; anchored under ex:ActOfFormulation (Act of Planning)." ;
    skos:example "An IT leadership team articulates a five-year IT vision document." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITVision ] .

ex:P20616 a owl:Class ;
    ex:pcfID "20616" ; ex:hierarchyID "8.1.2.4" ;
    ex:apqcSourceText "Defining a roadmap to meet organizational expectations from information technology services while considering how it will affect the business." ;
    rdfs:label "Outline IT service expectations" ;
    skos:definition "An Act of Formulation that composes a roadmap for meeting organizational expectations of IT services and produces an IT roadmap." ;
    skos:example "A service manager lays out a roadmap of IT service milestones for the year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRoadmap ] .

ex:P20617 a owl:Class ;
    ex:pcfID "20617" ; ex:hierarchyID "8.1.3" ;
    ex:apqcSourceText "Create and design an organized and curated collection of all IT-related services that can be performed by, for, or within the organization. Maintain and convey information about deliverables, prices, contact points, and processes for requesting an information technology service." ;
    rdfs:label "Plan and communicate IT services" ;
    skos:definition "An Act of Formulation that composes a curated collection of IT-related services and produces an IT service catalog conveying their deliverables, prices, and request processes." ;
    rdfs:comment "Directive output (service catalog). The 'manage IT customer expectations' child is a capability (R6), not a process part." ;
    skos:example "An IT organization compiles and publishes its service catalog." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceCatalog ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20619 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20620 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20621 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20622 ] .

ex:P20619 a owl:Class ;
    ex:pcfID "20619" ; ex:hierarchyID "8.1.3.2" ;
    ex:apqcSourceText "Defining the expected demand and usage of information technology services to meet organization's future business goals. Gather necessary information about the processes, resource requirements, and structures pertaining to planned business growth." ;
    rdfs:label "Define future IT services" ;
    skos:definition "An Act of Formulation that composes a forward definition of IT services aligned to future business goals and produces an IT service catalog covering planned services." ;
    rdfs:comment "An IT service demand forecast is a typical input, recorded here rather than as a restriction since it is not present for every instance." ;
    skos:example "A planning team specifies the services needed to support next year's business growth." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceCatalog ] .

ex:P20620 a owl:Class ;
    ex:pcfID "20620" ; ex:hierarchyID "8.1.3.3" ;
    ex:apqcSourceText "Determining IT KPIs crucial to the organization's success. Measure indicators such as IT costs as percentage of revenue, IT maintenance ratio, and system downtime in an effort to evaluate the performance of IT across the organization." ;
    rdfs:label "Determine IT performance indicators" ;
    skos:definition "An Act of Formulation that selects and fixes the key performance indicators for IT and produces an IT performance indicator specification." ;
    rdfs:comment "Directive output: determining KPIs prescribes what shall be measured. Anchored under ex:ActOfFormulation." ;
    skos:example "An IT governance group designates IT-cost-to-revenue and system downtime as official KPIs." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceIndicatorSpecification ] .

ex:P20621 a owl:Class ;
    ex:pcfID "20621" ; ex:hierarchyID "8.1.3.4" ;
    ex:apqcSourceText "Developing concise statements that position the value proposition around the pressing concerns of the internal IT user base, thereby showing how the IT offerings are the right fit for a segment of IT customers." ;
    rdfs:label "Create IT marketing messages" ;
    skos:definition "An Act of Formulation that composes value-proposition statements for IT offerings and produces an IT marketing message targeted at a customer segment." ;
    skos:example "A team drafts a value statement promoting a managed-device service to a user segment." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITMarketingMessage ] .

ex:P20622 a owl:Class ;
    ex:pcfID "20622" ; ex:hierarchyID "8.1.3.5" ;
    ex:apqcSourceText "Creating a marketing strategy for IT offerings to customers. Plan processes for making budgets; identifying and developing media; and managing marketing content and promotional activities." ;
    rdfs:label "Create IT service marketing plan" ;
    skos:definition "An Act of Formulation that composes a marketing strategy for IT offerings and produces an IT service marketing plan covering budgets, media, and promotion." ;
    skos:example "A marketing lead builds the annual IT-services promotion plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITMarketingPlan ] .

ex:P20623 a owl:Class ;
    ex:pcfID "20623" ; ex:hierarchyID "8.1.4" ;
    ex:apqcSourceText "Understanding the necessity of IT transformation for the business. Collect and analyze customer requirements. Identify opportunities and prioritize outcomes. Develop and support business case for transformation. Develop transformation plan and roadmap." ;
    rdfs:label "Provide IT transformation guidance" ;
    skos:definition "An Act of Formulation that consolidates analyzed IT customer requirements and prioritized opportunities and produces an IT transformation plan guiding the business through transformation." ;
    rdfs:comment "Directive output (transformation plan); its requirements/opportunity children are process parts." ;
    skos:example "A transformation office assembles requirements and a business case into a guiding transformation plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITTransformationPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20624 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20625 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20937 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20626 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20627 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20628 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20629 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20630 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20631 ] .

ex:P20624 a owl:Class ;
    ex:pcfID "20624" ; ex:hierarchyID "8.1.4.1" ;
    ex:apqcSourceText "Developing a robust plan to replace or upgrade an organization's information technology systems. Understanding the business need of IT transformation from current to an expected state for the business. Developing a strategic plan for IT operating model, governance, service delivery, and workforce transformation." ;
    rdfs:label "Develop IT transformation plans" ;
    skos:definition "An Act of Formulation that composes a strategic plan for transforming the IT operating model, governance, service delivery, and workforce and produces an IT transformation plan." ;
    skos:example "A program team writes the plan to migrate from legacy systems to a target operating model." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITTransformationPlan ] .

ex:P20625 a owl:Class ;
    ex:pcfID "20625" ; ex:hierarchyID "8.1.4.2" ;
    ex:apqcSourceText "Identifying existing or potential IT gaps between the expected business performance levels and current business outcomes." ;
    rdfs:label "Collect IT customer requirements" ;
    skos:definition "An Act of Identification that discerns existing and potential IT gaps between expected and current business outcomes and produces an IT customer requirements register." ;
    skos:example "An analyst catalogs the gaps between target and actual performance for a business unit." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCustomerRequirements ] .

ex:P20937 a owl:Class ;
    ex:pcfID "20937" ; ex:hierarchyID "8.1.4.3" ;
    ex:apqcSourceText "Assessing identified IT gaps to plan for remediation efforts to allow outcomes to meet established performance levels." ;
    rdfs:label "Analyze IT customer requirements" ;
    skos:definition "An Act of Analysis that examines identified IT gaps in order to plan remediation and produces an IT requirements analysis." ;
    skos:example "A team analyzes catalogued gaps and recommends remediation priorities." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITCustomerRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20626 a owl:Class ;
    ex:pcfID "20626" ; ex:hierarchyID "8.1.4.4" ;
    ex:apqcSourceText "Identifying IT opportunities on the basis of collection and analysis of IT customer requirements, then prioritize the identified IT opportunities on the basis of their importance." ;
    rdfs:label "Identify and prioritize IT opportunities" ;
    skos:definition "An Act of Selection that ranks identified IT opportunities by their importance and produces an IT prioritization decision." ;
    rdfs:comment "Anchored under ex:ActOfSelection: the committing act is the prioritization; the prior identification feeds it. Directive output." ;
    skos:example "A board ranks candidate IT opportunities and designates the top three." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPrioritizationDecision ] .

ex:P20627 a owl:Class ;
    ex:pcfID "20627" ; ex:hierarchyID "8.1.4.5" ;
    ex:apqcSourceText "Providing a plan of action to provide solution to IT customers. The solution design should be based on the collection and analysis of IT customer requirements." ;
    rdfs:label "Facilitate solution design activities" ;
    skos:definition "An Act of Design that composes a plan of action for an IT solution based on analyzed customer requirements and produces an IT solution design specification." ;
    rdfs:comment "Anchored under ex:ActOfDesign (Act of Planning); directive output." ;
    skos:example "A solution architect drafts a design specification answering a set of customer requirements." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSolutionDesignSpecification ] .

ex:P20628 a owl:Class ;
    ex:pcfID "20628" ; ex:hierarchyID "8.1.4.6" ;
    ex:apqcSourceText "Prioritizing IT outcomes based on need, effectiveness, and efficiency." ;
    rdfs:label "Prioritize IT outcomes" ;
    skos:definition "An Act of Selection that ranks IT outcomes by need, effectiveness, and efficiency and produces an IT prioritization decision." ;
    skos:example "A steering group orders desired IT outcomes by efficiency and need." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPrioritizationDecision ] .

ex:P20629 a owl:Class ;
    ex:pcfID "20629" ; ex:hierarchyID "8.1.4.7" ;
    ex:apqcSourceText "Create a business case with value proposition indicating current situation, proposed solution, financial analysis, and measurable benefits to the IT customers." ;
    rdfs:label "Develop business cases" ;
    skos:definition "An Act of Analysis that examines the current situation, proposed solution, and financial benefits of a proposed IT initiative and produces an IT business case." ;
    rdfs:comment "Anchored under ex:ActOfAnalysis because the business case is a descriptive argument/representation, not a prescription." ;
    skos:example "An analyst builds the cost-benefit business case for an infrastructure upgrade." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITBusinessCase ] .

ex:P20630 a owl:Class ;
    ex:pcfID "20630" ; ex:hierarchyID "8.1.4.8" ;
    ex:apqcSourceText "Supporting business case with supporting research, business analysis, and background information on IT transformation." ;
    rdfs:label "Support business case" ;
    skos:definition "An Act of Analysis that gathers and examines research and background information for an IT business case and produces IT research findings supporting it." ;
    skos:example "A team compiles benchmark research substantiating a transformation business case." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITBusinessCase ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITResearchFindings ] .

ex:P20631 a owl:Class ;
    ex:pcfID "20631" ; ex:hierarchyID "8.1.4.9" ;
    ex:apqcSourceText "Creating a blueprint for execution of IT transformation from the existing state to the planned organizational structure based on the value proposition and projected business growth." ;
    rdfs:label "Develop transformation roadmap" ;
    skos:definition "An Act of Formulation that composes a blueprint for executing IT transformation from the current to the planned state and produces an IT roadmap." ;
    skos:example "A program lead sequences the transformation milestones into an execution roadmap." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRoadmap ] .

ex:P20632 a owl:Class ;
    ex:pcfID "20632" ; ex:hierarchyID "8.1.5" ;
    ex:apqcSourceText "Establishing and maintaining service levels for the provision of IT services and solutions. Design and maintain the IT services and solution catalogue, as well as service level agreements. Evaluate the performance of IT service level agreements. Communicate the results to the management." ;
    rdfs:label "Develop and manage IT service levels" ;
    skos:definition "An Act of Formulation that establishes service levels for IT services and solutions and produces a service level agreement, coordinating the maintenance and evaluation of those service levels." ;
    rdfs:comment "Directive output (SLA). Maintenance/evaluation aspects are decomposed into the data-management and appraisal children below. Gate-F R5/R6 reconciliation: 8.1.5 is kept as this bounded ex:ActOfFormulation because its concrete deliverable (the SLA) passes the R5 bounded-occurrent test; the standing 'manage service levels' aspect is carried separately by ex:ITServiceManagementCapability, which is obo:BFO_0000054 (realized in) this act (R6). The earlier self-contradiction -- the capability claiming 8.1.5 fails R5 while 8.1.5 was a bounded process with no realized-in back-edge -- is resolved: one model (bounded process + realizing capability), consistently wired." ;
    skos:example "A service-management function defines and publishes the IT SLAs for the year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceLevelAgreement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20633 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20634 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20635 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20636 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20637 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20638 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20640 ] .

ex:P20633 a owl:Class ;
    ex:pcfID "20633" ; ex:hierarchyID "8.1.5.1" ;
    ex:apqcSourceText "Understand requirements related to information technology services considering enterprise-level effects and understand potential achievements in the business environment." ;
    rdfs:label "Understand IT service requirements" ;
    skos:definition "An Act of Analysis that examines IT service requirements and their enterprise-level effects and produces an IT requirements analysis." ;
    skos:example "An analyst documents the enterprise-wide requirements for a shared IT service." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITCustomerRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20634 a owl:Class ;
    ex:pcfID "20634" ; ex:hierarchyID "8.1.5.2" ;
    ex:apqcSourceText "Forecasting demand for IT services using current business growth, research, and customer feedback. Refine these forecasts, inspect the approach used in creating forecasts, and determine its accuracy." ;
    rdfs:label "Forecast IT service demand" ;
    skos:definition "An Act of Analysis that examines business growth, research, and customer feedback and produces an IT service demand forecast." ;
    rdfs:comment "Descriptive output (a forecast representing expected demand)." ;
    skos:example "A capacity planner projects next year's demand for a cloud service." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITCustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceDemandForecast ] .

ex:P20635 a owl:Class ;
    ex:pcfID "20635" ; ex:hierarchyID "8.1.5.3" ;
    ex:apqcSourceText "Maintain information about IT deliverables, prices, contact points, and processes for requesting a service." ;
    rdfs:label "Maintain IT services catalog" ;
    skos:definition "An Act of Data Management that records and updates information about IT deliverables, prices, contact points, and request processes so as to keep the IT service catalog current." ;
    rdfs:comment "Each maintenance instance is a bounded act (R5), not a standing function; anchored under ex:ActOfDataManagement." ;
    skos:example "An administrator updates catalog pricing and contact entries after a service change." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceCatalog ] .

ex:P20636 a owl:Class ;
    ex:pcfID "20636" ; ex:hierarchyID "8.1.5.4" ;
    ex:apqcSourceText "Designing and maintaining commitment of service by performance evaluation of IT services and communicate the results to the management." ;
    rdfs:label "Define service level agreement" ;
    skos:definition "An Act of Formulation that composes a commitment of IT service informed by performance evaluation and produces a service level agreement." ;
    skos:example "A service owner drafts the SLA terms for an application support service." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceLevelAgreement ] .

ex:P20637 a owl:Class ;
    ex:pcfID "20637" ; ex:hierarchyID "8.1.5.5" ;
    ex:apqcSourceText "Maintaining and documenting commitment of service to staff for information technology contracts including providing software or hardware solution through communication channels like phone, email, and on-site services." ;
    rdfs:label "Maintain IT customer contracts" ;
    skos:definition "An Act of Data Management that records and updates IT customer contracts documenting service commitments and support channels." ;
    rdfs:comment "Repeatable bounded act of updating contract records; anchored under ex:ActOfDataManagement." ;
    skos:example "A contract administrator updates support-channel terms in a customer's IT contract." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCustomerContract ] .

ex:P20638 a owl:Class ;
    ex:pcfID "20638" ; ex:hierarchyID "8.1.5.6" ;
    ex:apqcSourceText "Establish a service level agreement, which is a negotiated agreement designed to create a common understanding about services, priorities, and responsibilities." ;
    rdfs:label "Negotiate and establish service level agreements" ;
    skos:definition "An Act of Formulation that negotiates with an IT customer and composes a common understanding of services, priorities, and responsibilities, producing a service level agreement." ;
    rdfs:comment "The IT customer is a definitional participant of the negotiation." ;
    skos:example "A service manager and a department head negotiate and sign an SLA." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceLevelAgreement ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITCustomer ] .

ex:P20640 a owl:Class ;
    ex:pcfID "20640" ; ex:hierarchyID "8.1.5.7" ;
    ex:apqcSourceText "Conveying the improvement opportunities for the business and level of IT services. Leverage the results obtained from the performance metrics of the business and IT service levels to identify and recognize any opportunities that would improve or enhance the efficiency of the business and IT service-level structure. Communicate these opportunities to management in order for the improvements to take effect." ;
    rdfs:label "Develop and maintain improvement processes" ;
    skos:definition "An Act of Formulation that examines IT service-level performance metrics to identify improvement opportunities and produces a remediation plan for enhancing the service-level structure." ;
    rdfs:comment "IT performance data is a typical input recorded here; directive output (remediation/improvement plan)." ;
    skos:example "A service-improvement team turns SLA metrics into an improvement plan for management." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RemediationPlan ] .

ex:P20642 a owl:Class ;
    ex:pcfID "20642" ; ex:hierarchyID "8.1.6.1" ;
    ex:apqcSourceText "Create mechanisms for effective public relationship in order to preserve the image and goodwill of the organization through the process." ;
    rdfs:label "Establish relationship management mechanisms" ;
    skos:definition "An Act of Formulation that composes mechanisms for public relations with IT customers and produces an IT relationship management mechanism specification." ;
    rdfs:comment "Realizes ex:ITCustomerRelationshipManagementCapability (R6). Parent 8.1.6 is a capability, so this act is not given a process-part edge from a process parent." ;
    skos:example "A relationship team defines outreach mechanisms to protect organizational goodwill." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRelationshipManagementMechanismSpecification ] .

ex:P20643 a owl:Class ;
    ex:pcfID "20643" ; ex:hierarchyID "8.1.6.2" ;
    ex:apqcSourceText "Understanding the strategy for staff dependent on information technology. Create a plan to create services and solutions, conduct daily operations, and train new employees." ;
    rdfs:label "Understand IT customer strategy" ;
    skos:definition "An Act of Analysis that examines the strategy of IT-dependent staff and produces an IT customer needs assessment of that strategy." ;
    rdfs:comment "An IT strategy is a typical input; descriptive output. Realizes ex:ITCustomerRelationshipManagementCapability (R6)." ;
    skos:example "A relationship manager studies a department's IT strategy to align services." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCustomerNeedsAssessment ] .

ex:P20644 a owl:Class ;
    ex:pcfID "20644" ; ex:hierarchyID "8.1.6.3" ;
    ex:apqcSourceText "Understanding the environment of staff dependent on information technology. Assess and evaluate services and solutions used by customers to conduct daily operations, and train new employees." ;
    rdfs:label "Understand IT customer environment" ;
    skos:definition "An Act of Analysis that examines the IT environment and the services and solutions used by IT-dependent staff and produces an IT customer needs assessment." ;
    rdfs:comment "Realizes ex:ITCustomerRelationshipManagementCapability (R6)." ;
    skos:example "A liaison reviews the tools a department uses day to day and records its environment." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITLandscapeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCustomerNeedsAssessment ] .

ex:P20645 a owl:Class ;
    ex:pcfID "20645" ; ex:hierarchyID "8.1.6.4" ;
    ex:apqcSourceText "Conveying the goals and objectives of the IT function and how it contributes to the overall business objectives to staff and departments across the organization." ;
    rdfs:label "Communicate IT capabilities" ;
    skos:definition "An Act of Communication that transfers the goals and objectives of the IT function and its contribution to business objectives to staff and departments across the organization, producing an IT capability communication." ;
    rdfs:comment "Anchored to the shared ex:ActOfCommunication (wraps the D6-VERIFIED cco:ont00000402 'Act of Communication': 'A Planned Act in which some Information Content Entity is transferred from some Agent to Another.', parent cco:ont00000228). Verification recorded in the §6 record at the ex:ActOfCommunication declaration. NOT cco:ont00000379 'Act of Representative Communication' (the flagged false-friend, truth-committing). Gate-F fix: re-anchored from the raw IRI to the shared genus and added a has-output (ex:ITCapabilityCommunication, Descriptive) so the communication act now produces the conveyed ICE it characteristically transfers. Keeps has-input ex:BusinessObjectives. Realizes ex:ITCustomerRelationshipManagementCapability (R6)." ;
    skos:example "An IT director presents the IT function's goals and business contribution at a town hall." ;
    rdfs:subClassOf ex:ActOfCommunication ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCapabilityCommunication ] .

ex:P20646 a owl:Class ;
    ex:pcfID "20646" ; ex:hierarchyID "8.1.6.5" ;
    ex:apqcSourceText "Managing the IT requirements for business objectives. Identify the requirements of hardware and software equipment to store, retrieve, transmit, and manipulate data related to business operations. Consider factors such as functional, design, growth phases, and delivery schedule while managing IT requirements." ;
    rdfs:label "Manage IT requirements" ;
    skos:definition "An Act of Identification that discerns the hardware and software requirements needed to support business objectives and produces an IT customer requirements register." ;
    rdfs:comment "Despite the 'Manage' lead verb, the concrete deliverable is the bounded identification of hardware/software requirements (R5), so this is modeled as a process, not a standing capability. Realizes ex:ITCustomerRelationshipManagementCapability (R6)." ;
    skos:example "An analyst identifies the hardware and software needed to support a business process." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCustomerRequirements ] .

ex:P20648 a owl:Class ;
    ex:pcfID "20648" ; ex:hierarchyID "8.1.7" ;
    ex:apqcSourceText "Proactively manage IT service levels against IT customer requirements." ;
    rdfs:label "Analyze service performance" ;
    skos:definition "An Act of Analysis that examines IT service levels against IT customer requirements and produces an IT performance report." ;
    rdfs:comment "Descriptive output (performance report); parent of the performance children." ;
    skos:example "A service-management team reviews SLA results against requirements and reports performance." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20649 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20650 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20647 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20938 ] .

ex:P20649 a owl:Class ;
    ex:pcfID "20649" ; ex:hierarchyID "8.1.7.1" ;
    ex:apqcSourceText "Gather data from each service target defined in an SLA for a time segment or review period to evaluate an overall performance percentage." ;
    rdfs:label "Assess SLA compliance" ;
    skos:definition "An Act of Appraisal that evaluates IT performance data against each SLA service target for a review period and produces an SLA compliance assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal); descriptive output." ;
    skos:example "An analyst computes the quarterly compliance percentage against an SLA's targets." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SLAComplianceAssessment ] .

ex:P20650 a owl:Class ;
    ex:pcfID "20650" ; ex:hierarchyID "8.1.7.2" ;
    ex:apqcSourceText "Prioritizing SLA compliance issues and plan for remediation." ;
    rdfs:label "Triage SLA compliance issues" ;
    skos:definition "An Act of Selection that ranks SLA compliance issues by priority for remediation and produces a remediation plan." ;
    rdfs:comment "Triage = prioritization (selection); the remediation plan is the directive output." ;
    skos:example "A team triages breached SLA targets and schedules the highest-impact fixes." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SLAComplianceAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RemediationPlan ] .

ex:P20647 a owl:Class ;
    ex:pcfID "20647" ; ex:hierarchyID "8.1.7.3" ;
    ex:apqcSourceText "Collecting customer feedback about IT products and services effectiveness based on overall satisfaction. The data is collected through surveys, customer responses, and feedbacks based on the delivered products/services." ;
    rdfs:label "Collect feedback about IT products and services" ;
    skos:definition "An Act of Data Management that gathers customer feedback about the effectiveness of IT products and services through surveys and responses and produces recorded IT customer feedback." ;
    rdfs:comment "Anchored under ex:ActOfDataManagement (gathering/recording ICEs); descriptive output." ;
    skos:example "A team runs a satisfaction survey and compiles the responses as feedback data." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCustomerFeedback ] .

ex:P20938 a owl:Class ;
    ex:pcfID "20938" ; ex:hierarchyID "8.1.7.4" ;
    ex:apqcSourceText "Providing stakeholders with collected IT performance measures for further development based on evaluation." ;
    rdfs:label "Synthesize and distribute IT performance information" ;
    skos:definition "An Act of Analysis that synthesizes collected IT performance measures for stakeholders and produces an IT performance report." ;
    rdfs:comment "Synthesis yields a descriptive report; the distribution to stakeholders is a typical follow-on communication noted here rather than restricted." ;
    skos:example "An analyst consolidates measures into a stakeholder performance report." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

# ================================================================
# GROUP 8.2  Develop and manage IT business strategy
# ================================================================

ex:P20652 a owl:Class ;
    ex:pcfID "20652" ; ex:hierarchyID "8.2" ;
    ex:apqcSourceText "Handling the business of IT. Create a organization-wide strategy for the IT function. Define the organization's IT architecture. Manage the IT portfolio. Research and innovate in the field of IT. Assess and convey the performance and the value of the IT function." ;
    rdfs:label "Develop and manage IT business strategy" ;
    skos:definition "An Act of Planning that develops and manages the business strategy of an organization's IT function by formulating its technology strategy, defining its enterprise architecture, managing its portfolio, innovating, and appraising its performance and value." ;
    rdfs:comment "Models APQC process group 8.2 as an occurrent whose APQC children are process parts (cco:ont00001777). Not given existential has-process-part from Category 8.0 (R3). Standing-function children (8.2.1.1, 8.2.1.6, 8.2.5.7) are modeled as Organization Capabilities and so are not listed as process parts." ;
    skos:example "An organization's annual cycle of setting and managing its IT business strategy." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20653 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20660 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20668 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20674 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20682 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20693 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20699 ] .

ex:P20653 a owl:Class ;
    ex:pcfID "20653" ; ex:hierarchyID "8.2.1" ;
    ex:apqcSourceText "Defining the need of technology in business and systematic implementation of IT investments. It comprises of assessing competitive technology components to ensure structural analysis, development, usage and security of technology for efficient business operations." ;
    rdfs:label "Define business technology and governance strategy" ;
    skos:definition "An Act of Formulation that composes an organization's business-technology and governance strategy defining the need for technology in business and the governance of its IT investments and security." ;
    rdfs:comment "Models APQC 8.2.1 as an occurrent. Its bounded APQC children are process parts; the standing children 8.2.1.1 and 8.2.1.6 are Organization Capabilities and are not listed as parts." ;
    skos:example "An IT strategy team drafts the firm's business-technology strategy and governance approach." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessTechnologyStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20655 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20656 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20657 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20658 ] .

ex:P20655 a owl:Class ;
    ex:pcfID "20655" ; ex:hierarchyID "8.2.1.2" ;
    ex:apqcSourceText "Monitoring and evaluating existing and forthcoming technologies to meet the current and future growth plans for business operations." ;
    rdfs:label "Monitor and map current and emerging technologies" ;
    skos:definition "An Act of Monitoring that has as input emerging technology data and has as output a technology assessment of existing and forthcoming technologies relevant to business growth plans." ;
    skos:example "A technology-scouting team tracks emerging technologies and maps them to the firm's growth plans." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmergingTechnologyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TechnologyAssessment ] .

ex:P20656 a owl:Class ;
    ex:pcfID "20656" ; ex:hierarchyID "8.2.1.3" ;
    ex:apqcSourceText "Defining the integration of digital technology into business operations and service delivery, and convey the strategy to different segments of business. It is always backed by continuous improvement followed by periodic review and change per requirement of the business." ;
    rdfs:label "Define and communicate digital transformation strategy" ;
    skos:definition "An Act of Formulation that composes a digital transformation strategy prescribing the integration of digital technology into business operations and service delivery." ;
    rdfs:comment "Communication of the strategy to business segments is a typical follow-on, not definitional, so it is noted here rather than as a restriction (Phase-3)." ;
    skos:example "A CIO's office defines a digital transformation strategy and rolls it out across business units." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DigitalTransformationStrategy ] .

ex:P20657 a owl:Class ;
    ex:pcfID "20657" ; ex:hierarchyID "8.2.1.4" ;
    ex:apqcSourceText "Developing the process of aligning the organization's business divisions and staff members with the organization's planned objectives for IT." ;
    rdfs:label "Develop IT strategic alignment" ;
    skos:definition "An Act of Formulation that develops an IT strategic alignment specification prescribing how business divisions and staff are aligned with planned IT objectives." ;
    skos:example "An IT planning team develops the alignment between business units and IT objectives." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategicAlignmentSpecification ] .

ex:P20658 a owl:Class ;
    ex:pcfID "20658" ; ex:hierarchyID "8.2.1.5" ;
    ex:apqcSourceText "Systematic approach to clearly communicate and operate the usage of information technology as it relates to business objectives." ;
    rdfs:label "Articulate IT alignment principles" ;
    skos:definition "An Act of Formulation that composes and states IT alignment principles prescribing how information technology is used in relation to business objectives." ;
    skos:example "An enterprise IT council articulates the principles governing IT use against business goals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITAlignmentPrinciples ] .

ex:P20660 a owl:Class ;
    ex:pcfID "20660" ; ex:hierarchyID "8.2.2" ;
    ex:apqcSourceText "Strategy for systematic management of IT investments, projects, and activities. Analyze and examine the value of the IT portfolio and allocate resources based on business objectives." ;
    rdfs:label "Manage IT portfolio strategy" ;
    skos:definition "An Act of Planning that manages an organization's IT portfolio strategy by analyzing and examining the value of IT investments, projects, and activities and allocating resources according to business objectives." ;
    rdfs:comment "Models APQC 8.2.2 as a bounded portfolio-management cycle whose APQC children are process parts." ;
    skos:example "An IT portfolio board's planning cycle balancing and aligning IT investments." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20661 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20662 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20663 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20664 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20665 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20667 ] .

ex:P20661 a owl:Class ;
    ex:pcfID "20661" ; ex:hierarchyID "8.2.2.1" ;
    ex:apqcSourceText "Create and certify the standards to determine the value of the investments, projects, and activities of IT function for the overall business objectives." ;
    rdfs:label "Establish and validate IT value criteria" ;
    skos:definition "An Act of Formulation that composes and certifies IT value criteria prescribing the standards for determining the value of IT investments, projects, and activities for business objectives." ;
    skos:example "An IT value office establishes and signs off the criteria for judging IT investment value." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITValueCriteria ] .

ex:P20662 a owl:Class ;
    ex:pcfID "20662" ; ex:hierarchyID "8.2.2.2" ;
    ex:apqcSourceText "Determining the uninvested amount out of the total approved amount for overall IT management, IT investments, projects, and activities." ;
    rdfs:label "Determine IT portfolio investment balance" ;
    skos:definition "An Act of Appraisal that has as input IT performance data and has as output an IT investment balance assessment describing the uninvested portion of the approved IT budget." ;
    skos:example "A finance analyst determines how much of the approved IT budget remains uninvested." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITInvestmentBalanceAssessment ] .

ex:P20663 a owl:Class ;
    ex:pcfID "20663" ; ex:hierarchyID "8.2.2.3" ;
    ex:apqcSourceText "Evaluating IT investment projects to achieve overall business objectives in regard to implementation, efficiency, and profitability." ;
    rdfs:label "Evaluate proposed IT investment projects" ;
    skos:definition "An Act of Appraisal that has as input IT performance data and has as output an IT investment project evaluation judging proposed projects by implementation, efficiency, and profitability." ;
    skos:example "An investment committee evaluates candidate IT projects for feasibility and return." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITInvestmentProjectEvaluation ] .

ex:P20664 a owl:Class ;
    ex:pcfID "20664" ; ex:hierarchyID "8.2.2.4" ;
    ex:apqcSourceText "Listing the IT projects in the order of most important to the least. Determining which of many IT projects are most important or critical to business operations." ;
    rdfs:label "Prioritize IT projects" ;
    skos:definition "An Act of Selection that chooses and ranks IT projects from a candidate set and produces an IT project prioritization ordering them from most to least critical." ;
    rdfs:comment "ex:ActOfSelection (Info Processing) because it chooses/orders from a candidate set; its output is a Directive ICE (the ranking)." ;
    skos:example "A portfolio board ranks the year's IT projects by business criticality." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITProjectPrioritization ] .

ex:P20665 a owl:Class ;
    ex:pcfID "20665" ; ex:hierarchyID "8.2.2.5" ;
    ex:apqcSourceText "Aligning physical IT resources like software, IT infrastructure, networks, and non-physical resources like technology expertise, to strategic objectives ranked by their importance in achieving the strategic goals." ;
    rdfs:label "Align IT resources to strategic priorities" ;
    skos:definition "An Act of Formulation that produces an IT strategic alignment specification mapping physical and non-physical IT resources to ranked strategic objectives." ;
    skos:example "An IT planning office allocates infrastructure and expertise against ranked strategic goals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategicAlignmentSpecification ] .

ex:P20667 a owl:Class ;
    ex:pcfID "20667" ; ex:hierarchyID "8.2.2.6" ;
    ex:apqcSourceText "Aligning IT investments, projects, and activities to achieve overall business objectives." ;
    rdfs:label "Align IT portfolio to business objectives" ;
    skos:definition "An Act of Formulation that produces an IT strategic alignment specification mapping IT investments, projects, and activities to overall business objectives." ;
    skos:example "A portfolio office aligns the IT investment mix to corporate objectives." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategicAlignmentSpecification ] .

ex:P20668 a owl:Class ;
    ex:pcfID "20668" ; ex:hierarchyID "8.2.3" ;
    ex:apqcSourceText "Outlining and maintaining the organization's IT architecture. Establish the IT architecture definition and framework. Ensure the relevance of IT. Create and confirm the approach for IT maintenance. Create rules and regulations to guide IT architecture. Authenticate and finalize all IT related research and innovation that takes place within the organization." ;
    rdfs:label "Define and maintain enterprise architecture" ;
    skos:definition "An Act of Formulation that defines and maintains an organization's enterprise architecture, producing an enterprise architecture specification together with its principles and governance." ;
    rdfs:comment "Models APQC 8.2.3 as an occurrent. The 'maintain' aspect is recurrent re-execution of the same definitional act type, so the row remains a process rather than a capability. APQC children are process parts." ;
    skos:example "An enterprise-architecture team defines and keeps current the firm's IT architecture." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnterpriseArchitectureSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20670 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20671 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20672 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20673 ] .

ex:P20670 a owl:Class ;
    ex:pcfID "20670" ; ex:hierarchyID "8.2.3.1" ;
    ex:apqcSourceText "Creating and publishing high level statements of the fundamental values (principles) based on the organization's objectives that guide Information Technology decision-making and activities, and are the foundation for enterprise architecture." ;
    rdfs:label "Create and publish enterprise architecture principles" ;
    skos:definition "An Act of Formulation that composes and publishes enterprise architecture principles prescribing the fundamental values that guide IT decision-making." ;
    skos:example "An EA board publishes the principles underpinning the enterprise architecture." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnterpriseArchitecturePrinciples ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:EnterpriseArchitect ] .

ex:P20671 a owl:Class ;
    ex:pcfID "20671" ; ex:hierarchyID "8.2.3.2" ;
    ex:apqcSourceText "Establishing and operating a structure by which an enterprise defines appropriate strategies and ensures development alignment with those strategies. Create and establish the rules, regulations, policies, and standards that will govern the individual components of the IT architecture, as well as the architecture in its entirety." ;
    rdfs:label "Establish and operate enterprise architecture governance" ;
    skos:definition "An Act of Formulation that composes an enterprise architecture governance model prescribing the rules, regulations, policies, and standards governing the IT architecture and its components." ;
    rdfs:comment "The definitional product is the governance model; 'operate' it is recurrent realization of that model and is noted rather than restricted (Phase-3)." ;
    skos:example "An architecture review board establishes the governance rules for the IT architecture." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnterpriseArchitectureGovernanceModel ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:EnterpriseArchitect ] .

ex:P20672 a owl:Class ;
    ex:pcfID "20672" ; ex:hierarchyID "8.2.3.3" ;
    ex:apqcSourceText "Systematically investigating and studying materials and sources relevant to the IT function. Reach meaningful insights and conclusions in the form of new ideas and innovation for delivering IT services and solutions." ;
    rdfs:label "Research technologies to innovate IT services and solutions" ;
    skos:definition "An Act of Analysis that has as input emerging technology data and has as output IT research findings comprising insights and new ideas for delivering IT services and solutions." ;
    skos:example "A research group studies emerging tech and reports ideas for new IT service offerings." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmergingTechnologyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITResearchFindings ] .

ex:P20673 a owl:Class ;
    ex:pcfID "20673" ; ex:hierarchyID "8.2.3.4" ;
    ex:apqcSourceText "Analyze the value driven through IT projects and redefine and/or reprioritize. Evaluate planning, organizing, and implementation of IT projects based on research outcomes and business objectives." ;
    rdfs:label "Provide input to definition and prioritization of IT projects" ;
    skos:definition "An Act of Appraisal that has as input IT research findings and has as output an IT value contribution assessment informing the (re)definition and (re)prioritization of IT projects." ;
    skos:example "An EA team appraises project value from research outcomes and feeds reprioritization." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITResearchFindings ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITValueContributionAssessment ] .

ex:P20674 a owl:Class ;
    ex:pcfID "20674" ; ex:hierarchyID "8.2.4" ;
    ex:apqcSourceText "Defining perspective, position, plans, and patterns needed to execute designing, delivering, managing, and improving the way information technology is used within an organization." ;
    rdfs:label "Define IT service management strategy" ;
    skos:definition "An Act of Formulation that composes an IT service management plan defining the perspective, position, plans, and patterns for designing, delivering, managing, and improving IT services." ;
    rdfs:comment "Models APQC 8.2.4 as an occurrent. APQC children are process parts." ;
    skos:example "An ITSM lead defines the service-management strategy for the IT organization." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceManagementPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20675 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20676 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20677 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20678 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20679 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20680 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20681 ] .

ex:P20675 a owl:Class ;
    ex:pcfID "20675" ; ex:hierarchyID "8.2.4.1" ;
    ex:apqcSourceText "Implementing strategy for designing, delivering, managing, and improving the way information technology be used in the organization. The goal of IT Service Management is to ensure that the right processes, people, and technology are in place to meet business goals." ;
    rdfs:label "Establish IT service management strategy and goals" ;
    skos:definition "An Act of Formulation that composes an IT service management plan establishing the strategy and goals for designing, delivering, managing, and improving IT services." ;
    skos:example "An ITSM office sets the service-management goals ensuring processes, people, and technology meet business goals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceManagementPlan ] .

ex:P20676 a owl:Class ;
    ex:pcfID "20676" ; ex:hierarchyID "8.2.4.2" ;
    ex:apqcSourceText "Identifying operating and process requirement for designing, delivering, managing, and improving the way information technology be used in the organization." ;
    rdfs:label "Identify IT service operating and process requirements" ;
    skos:definition "An Act of Identification that discerns the operating and process requirements for IT services and produces an IT requirements analysis registering them." ;
    skos:example "An ITSM analyst enumerates the operating requirements for delivering IT services." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20677 a owl:Class ;
    ex:pcfID "20677" ; ex:hierarchyID "8.2.4.3" ;
    ex:apqcSourceText "Create and design an organized and curated collection of all IT-related services that can be performed by, for, or within the organization." ;
    rdfs:label "Define IT service catalog" ;
    skos:definition "An Act of Design that specifies the structure and contents of an IT service catalog cataloguing all IT-related services the organization can perform." ;
    rdfs:comment "ex:ActOfDesign because the act creates a structured, curated artifact (the catalog); its output is a Directive ICE." ;
    skos:example "An ITSM team designs the organization's catalog of available IT services." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceCatalog ] .

ex:P20678 a owl:Class ;
    ex:pcfID "20678" ; ex:hierarchyID "8.2.4.4" ;
    ex:apqcSourceText "Create a layered structure for IT service management framework ensuring right processes, people, and technology are in place to meet business goals." ;
    rdfs:label "Establish IT service management framework" ;
    skos:definition "An Act of Design that specifies a layered IT service management framework ensuring the right processes, people, and technology are in place to meet business goals." ;
    rdfs:comment "ex:ActOfDesign because the act specifies a structured framework; its output is a Directive ICE (here the ITSM plan as the framework specification)." ;
    skos:example "An ITSM architect lays out the layered structure of the service-management framework." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceManagementPlan ] .

ex:P20679 a owl:Class ;
    ex:pcfID "20679" ; ex:hierarchyID "8.2.4.5" ;
    ex:apqcSourceText "Defining and implementing activities involved in designing, creating, delivering, supporting, and managing the lifecycle of information technology services within an organization." ;
    rdfs:label "Define and implement IT service management" ;
    skos:definition "An Act of Deployment that puts IT service management into operational use by defining and implementing the activities across the lifecycle of IT services." ;
    rdfs:comment "ex:ActOfDeployment because the act stands up operational ITSM, not merely a directive; the ITSM plan that prescribes it is noted as the governing directive." ;
    skos:example "An IT organization rolls out its service-management processes into day-to-day operation." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITServiceManagementPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] .

ex:P20680 a owl:Class ;
    ex:pcfID "20680" ; ex:hierarchyID "8.2.4.6" ;
    ex:apqcSourceText "Establishing services for providing support to users of IT services and solutions. Define the plethora of services along with tools and methods by which the organization assists users of computers, software products, or other electronic/mechanical products." ;
    rdfs:label "Define and deploy support service management process tools and methods" ;
    skos:definition "An Act of Deployment that establishes and puts into use the support services, tools, and methods by which an organization assists users of IT services and solutions." ;
    rdfs:comment "ex:ActOfDeployment because the act stands up operational support services and tooling (material IT infrastructure components)." ;
    skos:example "An IT support function deploys a service desk and its supporting toolset." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] .

ex:P20681 a owl:Class ;
    ex:pcfID "20681" ; ex:hierarchyID "8.2.4.7" ;
    ex:apqcSourceText "Supervising, analyzing, and reporting performance of information technology to ensure they are on-course and on-schedule in meeting the organizational objectives and performance targets." ;
    rdfs:label "Monitor and report IT performance" ;
    skos:definition "An Act of Monitoring that has as input IT performance data and has as output an IT performance report tracking IT against organizational objectives and performance targets." ;
    skos:example "An IT operations team monitors and reports whether IT is on-course against targets." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20682 a owl:Class ;
    ex:pcfID "20682" ; ex:hierarchyID "8.2.5" ;
    ex:apqcSourceText "Regulating the IT management system through performance measures, governance, analysis, and monitoring through a variety of analytic tools. Evaluate IT finances, resource, services, projects, and value for report out." ;
    rdfs:label "Control IT management system" ;
    skos:definition "An Act of Appraisal that controls an organization's IT management system by evaluating its finances, resources, services, projects, and value through performance measures, governance, analysis, and monitoring for report-out." ;
    rdfs:comment "Models APQC 8.2.5 as a bounded control/appraisal cycle. APQC children that are bounded acts are process parts; the standing child 8.2.5.7 is an Organization Capability and is not listed as a part." ;
    skos:example "An IT control function's periodic cycle of measuring and reporting IT system performance." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20683 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20684 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20685 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20686 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20687 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20688 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20690 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20692 ] .

ex:P20683 a owl:Class ;
    ex:pcfID "20683" ; ex:hierarchyID "8.2.5.1" ;
    ex:apqcSourceText "Determining measures for evaluating the performance of IT services in the organization. Establish key performance indicators, including the IT services performance index." ;
    rdfs:label "Determine IT performance measures" ;
    skos:definition "An Act of Formulation that composes an IT performance measure specification establishing the key performance indicators, including the IT services performance index, for evaluating IT performance." ;
    skos:example "An IT controller defines the KPIs and performance index for IT services." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceMeasureSpecification ] .

ex:P20684 a owl:Class ;
    ex:pcfID "20684" ; ex:hierarchyID "8.2.5.2" ;
    ex:apqcSourceText "Establishing a governance model with its own structure and functions from where full or partial control can be exercised over the entire IT management system. Specify evaluation and quality control procedures in the structure." ;
    rdfs:label "Define IT control points and assurance procedures governance model" ;
    skos:definition "An Act of Formulation that composes an IT control and assurance governance model prescribing the control points, evaluation, and quality-control procedures for the IT management system." ;
    skos:example "An IT governance team defines the control points and assurance procedures for IT." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITControlGovernanceModel ] .

ex:P20685 a owl:Class ;
    ex:pcfID "20685" ; ex:hierarchyID "8.2.5.3" ;
    ex:apqcSourceText "Monitoring and analyzing information technology performance measures to ensure timely completion, and that quality assurance is met at all steps of IT services." ;
    rdfs:label "Monitor and analyze overall IT performance" ;
    skos:definition "An Act of Monitoring that has as input IT performance data and has as output an IT performance report on overall IT timeliness and quality assurance." ;
    skos:example "An IT control team monitors overall IT performance against quality and timing targets." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20686 a owl:Class ;
    ex:pcfID "20686" ; ex:hierarchyID "8.2.5.4" ;
    ex:apqcSourceText "Checking and analyzing predetermined financial targets and timelines of IT management system. Monitoring their profitability, feasibility, and consistency. Study the revenues generated." ;
    rdfs:label "Monitor and analyze IT financial performance" ;
    skos:definition "An Act of Monitoring that has as input IT performance data and has as output an IT performance report on IT financial targets, profitability, feasibility, and revenues." ;
    skos:example "An IT finance team monitors IT spend and revenue against financial targets." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20687 a owl:Class ;
    ex:pcfID "20687" ; ex:hierarchyID "8.2.5.5" ;
    ex:apqcSourceText "Examining and analyzing the value and benefits of IT service management to ensure benefits outweigh incurred costs." ;
    rdfs:label "Monitor and analyze IT value and benefits" ;
    skos:definition "An Act of Appraisal that has as input IT performance data and has as output an IT value contribution assessment judging whether the benefits of IT service management outweigh its costs." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the act judges value/benefit against cost, producing a value judgement (Descriptive ICE)." ;
    skos:example "An IT value office assesses whether ITSM benefits exceed their costs." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITValueContributionAssessment ] .

ex:P20688 a owl:Class ;
    ex:pcfID "20688" ; ex:hierarchyID "8.2.5.6" ;
    ex:apqcSourceText "Create process to assign and manage IT assets that support organization's strategic goals." ;
    rdfs:label "Optimize IT resource allocation" ;
    skos:definition "An Act of Formulation that composes an IT resource optimization plan prescribing the process for assigning and managing IT assets in support of strategic goals." ;
    skos:example "An IT operations team designs the process for allocating IT assets to strategic goals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITResourceOptimizationPlan ] .

ex:P20690 a owl:Class ;
    ex:pcfID "20690" ; ex:hierarchyID "8.2.5.8" ;
    ex:apqcSourceText "Process of collecting, analyzing, and reporting information regarding the performance of IT services and projects." ;
    rdfs:label "Report IT service and project performance" ;
    skos:definition "An Act of Reporting that has as input IT performance data and has as output an IT performance report giving a detailed account of IT service and project performance." ;
    rdfs:comment "Reuses cco:ont00000151 (Act of Reporting), a Representative Communication that gives a detailed account; its output is a Descriptive ICE (the report)." ;
    skos:example "An IT PMO collects, analyzes, and issues the IT service-and-project performance report." ;
    rdfs:subClassOf cco:ont00000151 ,
        cco:ont00000228 ,   # Planned Act -- explicit allowlist anchor (Act of Reporting is a Planned Act in CCO; asserted here so the standalone SHACL subclass chain resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20692 a owl:Class ;
    ex:pcfID "20692" ; ex:hierarchyID "8.2.5.9" ;
    ex:apqcSourceText "Select, establish, and operate analytics tool to analyze data and extract actionable and commercially relevant information on IT performance to evaluate or increase performance." ;
    rdfs:label "Select, deploy, and operate IT performance analytics tools" ;
    skos:definition "An Act of Deployment that selects, establishes, and operates IT performance analytics tools to extract actionable information on IT performance." ;
    rdfs:comment "ex:ActOfDeployment because the act stands up and operates analytics tooling (a material IT infrastructure component), beyond producing a directive." ;
    skos:example "An IT analytics team stands up a performance-analytics platform and runs it." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] .

ex:P20693 a owl:Class ;
    ex:pcfID "20693" ; ex:hierarchyID "8.2.6" ;
    ex:apqcSourceText "Creating and establishing the value portfolio. Defining, analyzing, and examining the value of projects, investments, and activities of the IT function." ;
    rdfs:label "Manage IT value portfolio" ;
    skos:definition "An Act of Appraisal that manages an IT value portfolio by defining, analyzing, and examining the value of IT projects, investments, and activities." ;
    rdfs:comment "Models APQC 8.2.6 as a bounded value-appraisal cycle. APQC children are process parts." ;
    skos:example "An IT value office's cycle of assessing and reporting the IT portfolio's value." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20694 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20695 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20696 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20697 ] .

ex:P20694 a owl:Class ;
    ex:pcfID "20694" ; ex:hierarchyID "8.2.6.1" ;
    ex:apqcSourceText "Process of evaluating performance to collect and analyze IT services and projects. Ensure expected IT service and project value based on established criteria." ;
    rdfs:label "Assess performance against IT service and project value criteria" ;
    skos:definition "An Act of Appraisal that has as input IT performance data and IT value criteria and has as output an IT value contribution assessment of IT services and projects against established criteria." ;
    skos:example "An IT value analyst assesses service and project performance against the value criteria." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITValueCriteria ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITValueContributionAssessment ] .

ex:P20695 a owl:Class ;
    ex:pcfID "20695" ; ex:hierarchyID "8.2.6.2" ;
    ex:apqcSourceText "Evaluate the value of the investments, projects, and activities of IT function by assigning it a quantifiable value with a profitable return to business operations." ;
    rdfs:label "Quantify value of IT service and project portfolio investments" ;
    skos:definition "An Act of Appraisal that has as input IT performance data and has as output an IT value contribution assessment assigning a quantifiable value to IT investments, projects, and activities." ;
    skos:example "An IT finance analyst quantifies the monetary value of the IT investment portfolio." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITValueContributionAssessment ] .

ex:P20696 a owl:Class ;
    ex:pcfID "20696" ; ex:hierarchyID "8.2.6.3" ;
    ex:apqcSourceText "Conveying the value addition through adopting technology targeting towards integrated profitable business operations." ;
    rdfs:label "Communicate business technology value contribution" ;
    skos:definition "An Act of Reporting that has as input an IT value contribution assessment and has as output a business technology value communication giving a detailed account of the value addition delivered through adopting technology for profitable business operations." ;
    rdfs:comment "Reuses cco:ont00000151 (Act of Reporting; D6-verified in the §6 record at ex:ActOfCommunication -- parent chain ont00000379 -> ont00000402 -> ont00000228), a Representative Communication that conveys an already-formed value assessment to stakeholders; its product is a communicated Descriptive ICE. Gate-F fix: added the has-output (ex:BusinessTechnologyValueCommunication, Descriptive) that the act-genus implies, restoring sibling consistency with P20690 (which carries both has-input and has-output) and GOLDEN-PRINCIPLE traceability. Keeps has-input ex:ITValueContributionAssessment." ;
    skos:example "A CIO communicates IT's value contribution to the executive board." ;
    rdfs:subClassOf cco:ont00000151 ,
        cco:ont00000228 ,   # Planned Act -- explicit allowlist anchor (Act of Reporting is a Planned Act in CCO; SHACL S2 does not merge the CCO closure, so the verified ont00000151 -> ... -> ont00000228 chain is asserted here for Gate C)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITValueContributionAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessTechnologyValueCommunication ] .

ex:P20697 a owl:Class ;
    ex:pcfID "20697" ; ex:hierarchyID "8.2.6.4" ;
    ex:apqcSourceText "Determining and implementing IT investments, projects, and activities based on trending technological advancements in the existing environment in order to achieve overall business objectives." ;
    rdfs:label "Determine and implement IT portfolio adjustments" ;
    skos:definition "An Act of Deployment that determines and implements adjustments to IT investments, projects, and activities, guided by an IT portfolio adjustment decision, to achieve business objectives." ;
    rdfs:comment "ex:ActOfDeployment because the act not only decides but enacts the portfolio changes; the decision is the directive guiding it (has input)." ;
    skos:example "A portfolio board reweights and enacts changes to the IT investment mix." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPortfolioAdjustmentDecision ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] .

ex:P20699 a owl:Class ;
    ex:pcfID "20699" ; ex:hierarchyID "8.2.7" ;
    ex:apqcSourceText "Outline and manage the innovation of technology within the organization. Research and understand emerging future technological concepts and capabilities. Plan for IT innovation investments. Plan and execute viable innovation projects." ;
    rdfs:label "Define and manage technology innovation" ;
    skos:definition "An Act of Planning that defines and manages technology innovation by researching emerging concepts, planning IT innovation investments, and executing viable innovation projects." ;
    rdfs:comment "Models APQC 8.2.7 as a bounded innovation cycle. APQC children are process parts." ;
    skos:example "An IT innovation lab's program of researching, selecting, and executing innovation projects." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20700 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20701 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20702 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20703 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20939 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20704 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20705 ] .

ex:P20700 a owl:Class ;
    ex:pcfID "20700" ; ex:hierarchyID "8.2.7.1" ;
    ex:apqcSourceText "Establishing the standard for selecting IT research initiatives to align with organizational criteria for implementing future technologies." ;
    rdfs:label "Establish selection criteria for research initiatives" ;
    skos:definition "An Act of Formulation that composes IT research selection criteria prescribing the standards for selecting IT research initiatives aligned with organizational criteria." ;
    skos:example "An R&D council sets the criteria for choosing which IT research initiatives to fund." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITResearchSelectionCriteria ] .

ex:P20701 a owl:Class ;
    ex:pcfID "20701" ; ex:hierarchyID "8.2.7.2" ;
    ex:apqcSourceText "Assessing new and future technologies relevant to the organization's vision of its IT capabilities." ;
    rdfs:label "Analyze emerging technology concepts" ;
    skos:definition "An Act of Analysis that has as input emerging technology data and has as output a technology assessment of new and future technologies relevant to the organization's IT vision." ;
    skos:example "An innovation analyst assesses emerging technologies against the firm's IT vision." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmergingTechnologyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TechnologyAssessment ] .

ex:P20702 a owl:Class ;
    ex:pcfID "20702" ; ex:hierarchyID "8.2.7.3" ;
    ex:apqcSourceText "Identification of conceptual elements that define the benefits of technology to business." ;
    rdfs:label "Identify technology concepts and capabilities" ;
    skos:definition "An Act of Identification that discerns the conceptual elements defining the benefits of technology to business and produces a technology assessment registering them." ;
    skos:example "An innovation team enumerates the technology concepts that could benefit the business." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmergingTechnologyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TechnologyAssessment ] .

ex:P20703 a owl:Class ;
    ex:pcfID "20703" ; ex:hierarchyID "8.2.7.4" ;
    ex:apqcSourceText "Implement information technology research projects that focus on meeting the goals of the organization's IT services and capabilities." ;
    rdfs:label "Execute IT research projects" ;
    skos:definition "An Act of Analysis that carries out IT research projects focused on the goals of the organization's IT services and capabilities and produces IT research findings." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfDevelopment to ex:ActOfAnalysis (cco:ont00000366, Act of Information Processing) for consistency with the parallel research row P20672 'Research technologies to innovate', which yields the SAME descriptive output (ex:ITResearchFindings). REJECTED ex:ActOfDevelopment: its genus rule states a development act's material product attaches via obo:BFO_0000057 (has participant), NOT has output, yet this row's definitional product is descriptive research findings (insights/conclusions), which is information processing/analysis, not bringing a realized artifact into existence. If running the project also realizes a prototype artifact, that would be modeled separately via obo:BFO_0000057 on a development sub-act; the row's definitional descriptive output sits under the information-processing genus. Descriptive output per the GOLDEN PRINCIPLE." ;
    skos:example "An IT research team runs a project on a candidate technology and reports its findings." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITResearchFindings ] .

ex:P20939 a owl:Class ;
    ex:pcfID "20939" ; ex:hierarchyID "8.2.7.5" ;
    ex:apqcSourceText "Assessing IT research projects based on defined outcome expectations." ;
    rdfs:label "Evaluate IT research project outcomes" ;
    skos:definition "An Act of Appraisal that has as input IT research findings and has as output an IT research outcome assessment judging research projects against their defined outcome expectations." ;
    skos:example "An R&D review board assesses each research project against its expected outcomes." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITResearchFindings ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITResearchOutcomeAssessment ] .

ex:P20704 a owl:Class ;
    ex:pcfID "20704" ; ex:hierarchyID "8.2.7.6" ;
    ex:apqcSourceText "Determine project viability. Promote relevant IT innovations that meet business objectives." ;
    rdfs:label "Identify and promote viable concepts" ;
    skos:definition "An Act of Selection that determines the viability of innovation concepts, chooses those meeting business objectives, and produces an IT innovation promotion decision." ;
    rdfs:comment "ex:ActOfSelection because the act chooses viable concepts from candidates; its output is a Directive ICE (the promotion decision)." ;
    skos:example "An innovation board selects and promotes the viable concepts for further investment." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITResearchOutcomeAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITInnovationPromotionDecision ] .

ex:P20705 a owl:Class ;
    ex:pcfID "20705" ; ex:hierarchyID "8.2.7.7" ;
    ex:apqcSourceText "Develop and plan long-term allocation of funds for information technology endeavors to meet business goals." ;
    rdfs:label "Develop and plan IT investment projects" ;
    skos:definition "An Act of Formulation that develops and plans the long-term allocation of funds for IT endeavors and produces an IT portfolio plan for meeting business goals." ;
    skos:example "An IT finance team plans the multi-year funding allocation for innovation projects." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPortfolioPlan ] .

# ================================================================
# GROUP 8.3  Develop and manage IT resilience and risk
# ================================================================

ex:P20706 a owl:Class ;
    ex:pcfID "20706" ; ex:hierarchyID "8.3" ;
    ex:apqcSourceText "Develop and include the processes required to rapidly adapt and respond to any internal or external opportunity, demand, disruption, or threat to IT. Develop a more dynamic, strategic, and integrated approach to managing risk and compliance obligations." ;
    rdfs:label "Develop and manage IT resilience and risk" ;
    skos:definition "A Planned Act that develops and operates the integrated set of processes by which an organization manages IT risk, resilience, compliance, security, and continuity." ;
    rdfs:comment "Models APQC process group 8.3 as an occurrent whose APQC children are process parts, not subclasses. Anchored at the generic cco:ont00000228 (Planned Act) because the group spans both formulation (develop strategies) and execution (control/operate) acts." ;
    skos:example "An organization's end-to-end annual cycle of building and running its IT risk and resilience program." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20707 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20716 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20721 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20731 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20735 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20743 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20749 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20756 ] .

ex:P20707 a owl:Class ;
    ex:pcfID "20707" ; ex:hierarchyID "8.3.1" ;
    ex:apqcSourceText "Ensuring that the organization effectively manages risk. Develop rules and standards for robust IT operations, manage risk, and adopt measures to protect integrity, confidentiality, and security of IT assets." ;
    rdfs:label "Develop IT compliance, risk, and security strategy" ;
    skos:definition "An Act of Formulation that develops the rules, standards, and measures governing IT compliance, risk, and security, producing an IT strategy and related directive specifications." ;
    rdfs:comment "Output anchors to a Directive ICE (strategy/policies), satisfying the GOLDEN PRINCIPLE for a formulation act." ;
    skos:example "An IT governance team drafting the annual IT compliance, risk, and security strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20708 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20940 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20709 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20710 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20711 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20712 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20941 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20713 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20714 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20715 ] .

ex:P20708 a owl:Class ;
    ex:pcfID "20708" ; ex:hierarchyID "8.3.1.1" ;
    ex:apqcSourceText "Determining and evaluating IT regulatory and audit requirements. Train employees on regulatory and audit requirements. Records for the appropriate regulatory and audit agencies must be maintained and the new product process must be approved by the appropriate regulatory body before it is published to the organization." ;
    rdfs:label "Determine and evaluate IT regulatory and audit requirements" ;
    skos:definition "An Act of Appraisal that has as input regulatory requirement data and has as output an IT regulatory and audit requirement assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): determining-and-evaluating judges requirements and yields a descriptive assessment. Employee training and record-keeping are method notes, not definitional I/O." ;
    skos:example "A compliance analyst evaluates which audit requirements apply before a new IT product is published." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRegulatoryAuditRequirementAssessment ] .

ex:P20940 a owl:Class ;
    ex:pcfID "20940" ; ex:hierarchyID "8.3.1.2" ;
    ex:apqcSourceText "Understand the risk tolerance levels of individual business units, given risk-return trade-offs for one or more anticipated and predictable consequences." ;
    rdfs:label "Understand business unit risk tolerance" ;
    skos:definition "An Act of Analysis that examines the risk-return trade-offs of individual business units and produces a business-unit risk-tolerance profile." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (cco:ont00000366): producing an understanding (Descriptive ICE) of unit risk tolerance." ;
    skos:example "A risk team profiles each division's appetite for IT-service disruption." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessUnitRiskToleranceProfile ] .

ex:P20709 a owl:Class ;
    ex:pcfID "20709" ; ex:hierarchyID "8.3.1.3" ;
    ex:apqcSourceText "Determine the specific maximum risk to take in quantitative terms for each relevant risk sub-category, including strategic, operational, financial, and compliance risks." ;
    rdfs:label "Establish IT risk tolerance" ;
    skos:definition "An Act of Planning that determines the maximum acceptable IT risk per sub-category and produces an IT risk tolerance specification." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): fixing risk thresholds is prescriptive, yielding a Directive ICE." ;
    skos:example "A board sets a quantitative ceiling on tolerable operational IT loss." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskToleranceSpecification ] .

ex:P20710 a owl:Class ;
    ex:pcfID "20710" ; ex:hierarchyID "8.3.1.4" ;
    ex:apqcSourceText "Establish an individual or a group who is ultimately accountable for ensuring that IT risks are managed appropriately." ;
    rdfs:label "Establish risk ownership" ;
    skos:definition "An Act of Planning that assigns ultimate accountability for managing IT risk and produces an IT risk ownership assignment." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): assigning accountability is prescriptive (Directive ICE). The accountable party is an ex:ITRiskOwner." ;
    skos:example "Executive leadership names the CISO as accountable owner of cyber risk." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskOwnershipAssignment ] .

ex:P20711 a owl:Class ;
    ex:pcfID "20711" ; ex:hierarchyID "8.3.1.5" ;
    ex:apqcSourceText "Determine and maintain roles that are specialized in each risk areas and coordinating all risk management activities for IT function with due escalation structure." ;
    rdfs:label "Establish and maintain risk management roles" ;
    skos:definition "An Act of Planning that determines specialized IT risk-management roles and their escalation structure and produces an IT risk management role specification." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning). The standing 'maintain' aspect is the IT Risk Management Capability (R6); the bounded determinable act of establishing/refreshing roles is the modeled occurrent (Directive ICE output)." ;
    skos:example "An IT risk office defines a Cloud Risk Lead role and its escalation path." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskManagementRoleSpecification ] .

ex:P20712 a owl:Class ;
    ex:pcfID "20712" ; ex:hierarchyID "8.3.1.6" ;
    ex:apqcSourceText "Establishing compliance objectives which ensures that the organization has systems of internal controls that adequately measure and manage IT risk." ;
    rdfs:label "Establish compliance objectives" ;
    skos:definition "An Act of Planning that sets compliance objectives for internal controls measuring and managing IT risk and produces an IT compliance objective." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): objectives are prescriptive (Directive ICE)." ;
    skos:example "A control objective requiring documented review of every IT change before release." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITComplianceObjective ] .

ex:P20941 a owl:Class ;
    ex:pcfID "20941" ; ex:hierarchyID "8.3.1.7" ;
    ex:apqcSourceText "Identifying and adopting information technology solutions to support changing regulatory compliance. Safeguard compliance and manage risk by outlining the risk policies and procedures." ;
    rdfs:label "Identify systems to support compliance" ;
    skos:definition "An Act of Identification that discerns the IT solutions suited to support changing regulatory compliance and produces an IT compliance support system identification." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (cco:ont00000366): discerning/enumerating supporting systems yields a Descriptive ICE registering them." ;
    skos:example "A compliance architect identifies GRC tooling to track new regulations." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITComplianceSupportSystemIdentification ] .

ex:P20713 a owl:Class ;
    ex:pcfID "20713" ; ex:hierarchyID "8.3.1.8" ;
    ex:apqcSourceText "Developing a timely and continuous process to identify and evaluate activities that might hinder IT operations or an IT project's goals." ;
    rdfs:label "Identify and evaluate IT risk" ;
    skos:definition "An Act of Analysis that identifies and evaluates activities that might hinder IT operations or project goals and produces an IT risk assessment." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (cco:ont00000366): identifying-and-evaluating risk yields a descriptive IT risk assessment. The 'continuous process' is operationalized as repeatable instances of this act." ;
    skos:example "A risk analyst reviews a project plan and records the IT risks threatening its goals." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskAssessment ] .

ex:P20714 a owl:Class ;
    ex:pcfID "20714" ; ex:hierarchyID "8.3.1.9" ;
    ex:apqcSourceText "Assess IT-related risk resilience strategies to ensure that the organization effectively manages its risk." ;
    rdfs:label "Evaluate IT-related risks resiliency" ;
    skos:definition "An Act of Appraisal that assesses IT-related risk resilience strategies and produces an IT resilience assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): assessing resilience strategies yields a descriptive judgement." ;
    skos:example "A risk committee rates the resilience of IT delivery against disruption scenarios." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITResilienceAssessment ] .

ex:P20715 a owl:Class ;
    ex:pcfID "20715" ; ex:hierarchyID "8.3.1.10" ;
    ex:apqcSourceText "Developing activities to improve performance opportunities and lessen threats in IT. Evolve strategies and policies to attain organizational objectives." ;
    rdfs:label "Create IT risk mitigation strategies and approaches" ;
    skos:definition "An Act of Formulation that develops strategies and policies to improve IT opportunities and lessen IT threats and produces an IT risk mitigation strategy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (cco:ont00000511): composing mitigation strategies/policies yields a Directive ICE." ;
    skos:example "A risk team drafts mitigation approaches for the top-ranked IT threats." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITRiskAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskMitigationStrategy ] .

ex:P20716 a owl:Class ;
    ex:pcfID "20716" ; ex:hierarchyID "8.3.2" ;
    ex:apqcSourceText "Developing resilience strategies of IT across the organization so that prospective risks can be avoided." ;
    rdfs:label "Develop IT resilience strategy" ;
    skos:definition "An Act of Formulation that develops IT resilience strategies across an organization and produces an IT resilience strategy." ;
    rdfs:comment "Output is a Directive ICE (resilience strategy), satisfying the GOLDEN PRINCIPLE for a formulation act." ;
    skos:example "An IT strategy team drafts the enterprise IT resilience strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITResilienceStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20717 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20718 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20719 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20720 ] .

ex:P20717 a owl:Class ;
    ex:pcfID "20717" ; ex:hierarchyID "8.3.2.1" ;
    ex:apqcSourceText "Determining resilience strategies to ensure that IT effectively manages it's delivery process to mitigate risk." ;
    rdfs:label "Determine IT delivery resiliency" ;
    skos:definition "An Act of Appraisal that determines the resilience of IT's delivery process and produces an IT resilience assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): judging delivery resilience yields a descriptive assessment." ;
    skos:example "An analyst assesses how resilient the IT delivery pipeline is to outages." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITResilienceAssessment ] .

ex:P20718 a owl:Class ;
    ex:pcfID "20718" ; ex:hierarchyID "8.3.2.2" ;
    ex:apqcSourceText "Determining risks that could disrupt objectives of IT." ;
    rdfs:label "Determine critical IT risks" ;
    skos:definition "An Act of Analysis that determines the risks that could disrupt IT objectives and produces an IT risk assessment." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (cco:ont00000366): examining and registering critical risks yields a descriptive IT risk assessment." ;
    skos:example "A risk team identifies the failures that would most disrupt IT objectives." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskAssessment ] .

ex:P20719 a owl:Class ;
    ex:pcfID "20719" ; ex:hierarchyID "8.3.2.3" ;
    ex:apqcSourceText "Prioritize potential IT risks based on business need to ensure overall IT stability." ;
    rdfs:label "Prioritize IT risks" ;
    skos:definition "An Act of Selection that chooses and ranks potential IT risks from a candidate set by business need and produces an IT risk prioritization committing the organization to a mitigation sequence." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfAnalysis to ex:ActOfSelection (cco:ont00000366, Act of Information Processing) for cross-row consistency with the parallel 'Prioritize' acts P20664 'Prioritize IT projects' and P20626 'Identify and prioritize IT opportunities', both ex:ActOfSelection with a DIRECTIVE prioritization output. A risk ranking that drives mitigation sequencing is a committing (Selection) act whose ranking is a Directive ICE, not a neutral descriptive examination; ex:ITRiskPrioritization is correspondingly reclassified as a Directive ICE (cco:ont00000965). The three parallel rows are no longer silently split across genera and output kinds." ;
    skos:example "A risk team ranks the risk register by business impact and commits to the mitigation order." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITRiskAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskPrioritization ] .

ex:P20720 a owl:Class ;
    ex:pcfID "20720" ; ex:hierarchyID "8.3.2.4" ;
    ex:apqcSourceText "Establishing activities to improve opportunities and lessen threats for IT." ;
    rdfs:label "Establish mitigation approaches for IT risks" ;
    skos:definition "An Act of Formulation that establishes activities to improve IT opportunities and lessen IT threats and produces an IT risk mitigation strategy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (cco:ont00000511): composing mitigation approaches yields a Directive ICE." ;
    skos:example "A risk team defines mitigation actions for each prioritized IT risk." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITRiskPrioritization ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskMitigationStrategy ] .

ex:P20721 a owl:Class ;
    ex:pcfID "20721" ; ex:hierarchyID "8.3.3" ;
    ex:apqcSourceText "Ensure effective control in overall IT risk management, formulate and execute guidelines in-line with regulatory bodies, and manage organizational security throughout the business operations." ;
    rdfs:label "Control IT risk, compliance, and security" ;
    skos:definition "A Planned Act that exercises ongoing control over IT risk, compliance, and security by formulating and executing guidelines aligned with regulatory bodies." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act) because the control process spans formulation, monitoring, and execution acts. Decomposes into its activities via has process part." ;
    skos:example "An IT risk function running its quarterly control and compliance cycle." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20722 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20723 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20724 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20942 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20725 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20726 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20727 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20728 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20729 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20730 ] .

ex:P20722 a owl:Class ;
    ex:pcfID "20722" ; ex:hierarchyID "8.3.3.1" ;
    ex:apqcSourceText "Evaluation of dynamic, strategic, and integrated approach to manage regulatory requirements and compliance obligations." ;
    rdfs:label "Evaluate enterprise regulatory and compliance obligations" ;
    skos:definition "An Act of Appraisal that evaluates an organization's enterprise regulatory requirements and compliance obligations and produces a regulatory and compliance obligation evaluation." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): evaluating obligations yields a descriptive judgement." ;
    skos:example "A compliance team evaluates the enterprise's standing against its regulatory obligations." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryComplianceObligationEvaluation ] .

ex:P20723 a owl:Class ;
    ex:pcfID "20723" ; ex:hierarchyID "8.3.3.2" ;
    ex:apqcSourceText "Analyzing the impact of threats to critical IT assets across different departments and functions in the organization in terms of quantifiable results." ;
    rdfs:label "Analyze IT security threat impact" ;
    skos:definition "An Act of Analysis that has as input IT security threat data and has as output an IT security threat analysis about the impact of threats on critical IT assets." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (cco:ont00000366): examining threat data yields a descriptive impact analysis." ;
    skos:example "A security analyst quantifies the impact of a ransomware threat across departments." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITSecurityThreatData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSecurityThreatAnalysis ] .

ex:P20724 a owl:Class ;
    ex:pcfID "20724" ; ex:hierarchyID "8.3.3.3" ;
    ex:apqcSourceText "Develop and maintain IT compliance standards. Maintaining requirements set forth by such directives as GRCP, PMI RMP, CGRC, CGEIT, CRMA." ;
    rdfs:label "Create and maintain IT compliance requirements" ;
    skos:definition "An Act of Formulation that develops and updates IT compliance standards and produces an IT compliance requirement specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (cco:ont00000511): composing compliance requirements yields a Directive ICE. The standing 'maintain' function is the IT Risk Management Capability (R6); the bounded create/update act is the modeled occurrent." ;
    skos:example "A compliance lead updates the IT compliance standard to reflect a new regulation." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITComplianceRequirementSpecification ] .

ex:P20942 a owl:Class ;
    ex:pcfID "20942" ; ex:hierarchyID "8.3.3.4" ;
    ex:apqcSourceText "Develop and maintain an architecture for securing and ensuring the privacy of data flows throughout the organization. Create, test, evaluate, and implement IT security policies to ensure the safe use of IT services and solutions." ;
    rdfs:label "Create and maintain IT security policies, standards, and procedures" ;
    skos:definition "An Act of Formulation that develops, tests, evaluates, and implements IT security policies, standards, and procedures and produces an IT policy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (cco:ont00000511): composing security policies yields a Directive ICE. Test/evaluate steps are method notes; the standing 'maintain' is the IT Risk Management Capability (R6)." ;
    skos:example "A security architect issues a data-flow privacy policy after testing it." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPolicy ] .

ex:P20725 a owl:Class ;
    ex:pcfID "20725" ; ex:hierarchyID "8.3.3.5" ;
    ex:apqcSourceText "Develop and implement training in regard to managing IT risks, understanding criticality, impact, and opportunities associated with business objectives." ;
    rdfs:label "Develop and deploy risk management training" ;
    skos:definition "An Act of Development that develops an IT risk management training program and deploys it for delivery to employees." ;
    rdfs:comment "Anchored to ex:ActOfDevelopment (cco:ont00000228): bringing a training program into existence; the deploy step is the related ex:ActOfDeployment. Output is the IT training program (a Directive ICE in the shared vocab)." ;
    skos:example "A risk office builds and rolls out an annual IT-risk awareness course." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITTrainingProgram ] .

ex:P20726 a owl:Class ;
    ex:pcfID "20726" ; ex:hierarchyID "8.3.3.6" ;
    ex:apqcSourceText "Establishing processes to communicate IT risk to the organization." ;
    rdfs:label "Establish risk reporting capabilities and responsibilities" ;
    skos:definition "An Act of Planning that establishes the processes and responsibilities for communicating IT risk and produces an IT risk reporting specification." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): establishing reporting processes/responsibilities is prescriptive (Directive ICE)." ;
    skos:example "A risk office defines who reports which IT risks to the board and when." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskReportingSpecification ] .

ex:P20727 a owl:Class ;
    ex:pcfID "20727" ; ex:hierarchyID "8.3.3.7" ;
    ex:apqcSourceText "Establishing standards for communications within the organization which creates the road map for successful understanding of strategic initiatives for both business units and information technology services." ;
    rdfs:label "Establish communication standards" ;
    skos:definition "An Act of Planning that establishes standards for communications within an organization and produces an IT communication standard." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): standards are prescriptive (Directive ICE)." ;
    skos:example "An IT office mandates a common template for change communications." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITCommunicationStandard ] .

ex:P20728 a owl:Class ;
    ex:pcfID "20728" ; ex:hierarchyID "8.3.3.8" ;
    ex:apqcSourceText "Evaluate IT risk and threat assessments by way of IT assets, information security, and breach points within the organization." ;
    rdfs:label "Conduct IT risk and threat assessments" ;
    skos:definition "An Act of Appraisal that evaluates IT risk and threats across IT assets, information security, and breach points and produces an IT risk assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): conducting risk/threat assessments yields a descriptive IT risk assessment." ;
    skos:example "A security team runs a threat assessment across the organization's breach points." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITSecurityThreatData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskAssessment ] .

ex:P20729 a owl:Class ;
    ex:pcfID "20729" ; ex:hierarchyID "8.3.3.9" ;
    ex:apqcSourceText "Monitoring and managing risks related to IT adoption within the organization." ;
    rdfs:label "Monitor and manage IT activity risk" ;
    skos:definition "An Act of Monitoring that continuously observes risks related to IT adoption and produces an IT performance report representing their tracked condition." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (cco:ont00000366). The standing 'manage' function is the IT Risk Management Capability (R6); the recurring monitor act is the modeled occurrent (Descriptive ICE output)." ;
    skos:example "A risk dashboard tracking the risk profile of newly adopted IT tools." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20730 a owl:Class ;
    ex:pcfID "20730" ; ex:hierarchyID "8.3.3.10" ;
    ex:apqcSourceText "Identifying and supervising a blueprint of measures for managing risk in IT. Monitor actions to enhance opportunities and reduce threats to project objectives." ;
    rdfs:label "Identify, supervise and monitor IT risk mitigation measures" ;
    skos:definition "An Act of Monitoring that supervises and tracks the blueprint of IT risk mitigation measures and produces an IT performance report on their effectiveness." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (cco:ont00000366): ongoing supervision/tracking of mitigation measures yields a descriptive report. Has the IT risk mitigation strategy as input." ;
    skos:example "A risk manager tracks whether mitigation actions are reducing project threats." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITRiskMitigationStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20731 a owl:Class ;
    ex:pcfID "20731" ; ex:hierarchyID "8.3.4" ;
    ex:apqcSourceText "Planning and managing IT's ability to recover from exposure to internal and external threats." ;
    rdfs:label "Plan and manage IT continuity" ;
    skos:definition "A Planned Act that plans and operates an organization's ability to recover IT from exposure to internal and external threats." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act) because the process spans planning and execution. The standing 'manage continuity' function is the IT Risk Management Capability (R6); this bounded plan-and-execute cycle is the modeled occurrent." ;
    skos:example "An IT continuity team's recovery-planning-and-execution cycle." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20732 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20733 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20734 ] .

ex:P20732 a owl:Class ;
    ex:pcfID "20732" ; ex:hierarchyID "8.3.4.1" ;
    ex:apqcSourceText "Evaluating IT business needs and IT's ability to recover from internal or external threat exposure." ;
    rdfs:label "Evaluate IT continuity" ;
    skos:definition "An Act of Appraisal that evaluates IT business needs and IT's ability to recover from threat exposure and produces an IT resilience assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): judging recovery ability yields a descriptive assessment." ;
    skos:example "A continuity analyst rates the recoverability of each critical IT service." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITResilienceAssessment ] .

ex:P20733 a owl:Class ;
    ex:pcfID "20733" ; ex:hierarchyID "8.3.4.2" ;
    ex:apqcSourceText "Identifying the limitations of the IT organization's ability to remediate disruptions in IT services." ;
    rdfs:label "Identify IT continuity gaps" ;
    skos:definition "An Act of Identification that discerns the limitations of an IT organization's ability to remediate disruptions in IT services and produces an IT continuity gap register." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (cco:ont00000366): discerning/registering gaps yields a Descriptive ICE." ;
    skos:example "A continuity team registers the services that lack a tested recovery procedure." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITContinuityGapRegister ] .

ex:P20734 a owl:Class ;
    ex:pcfID "20734" ; ex:hierarchyID "8.3.4.3" ;
    ex:apqcSourceText "Integrating the disciplines of Emergency Response, Crisis Management, Disaster Recovery (technology continuity) and Business Continuity for IT." ;
    rdfs:label "Manage IT business continuity" ;
    skos:definition "A Planned Act that integrates emergency response, crisis management, disaster recovery, and business continuity for IT into operational continuity execution." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act): the bounded act of integrating and running the continuity disciplines. Has the IT continuity plan as input directing it." ;
    skos:example "An IT team invokes its disaster-recovery and crisis-management procedures during an outage." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITContinuityPlan ] .

ex:P20735 a owl:Class ;
    ex:pcfID "20735" ; ex:hierarchyID "8.3.5" ;
    ex:apqcSourceText "Creating and deploying an architecture for securing and ensuring the privacy of data flows throughout the organization. Create and develop protocols that ensure proper and efficient use of IT services and solutions" ;
    rdfs:label "Develop and manage IT security, privacy, and data protection" ;
    skos:definition "An Act of Development that creates and deploys the architecture and protocols for securing IT and ensuring the privacy of data flows throughout an organization." ;
    rdfs:comment "Anchored to ex:ActOfDevelopment (cco:ont00000228): building the security/privacy architecture. The standing 'manage' function is the IT Risk Management Capability (R6). Decomposes into its activities." ;
    skos:example "A security team builds and runs the enterprise data-protection architecture." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20736 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20737 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20738 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20739 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20740 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20741 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20742 ] .

ex:P20736 a owl:Class ;
    ex:pcfID "20736" ; ex:hierarchyID "8.3.5.1" ;
    ex:apqcSourceText "Evaluate principles or rules employed in controlling, directing, or managing IT services. Assessing requirements and policies related to confidentiality." ;
    rdfs:label "Assess IT regulatory and confidentiality requirements and policies" ;
    skos:definition "An Act of Appraisal that evaluates the rules, requirements, and policies governing IT services and confidentiality and produces a regulatory and compliance obligation evaluation." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): assessing requirements/policies yields a descriptive judgement." ;
    skos:example "A privacy officer assesses confidentiality policies against regulatory requirements." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryComplianceObligationEvaluation ] .

ex:P20737 a owl:Class ;
    ex:pcfID "20737" ; ex:hierarchyID "8.3.5.2" ;
    ex:apqcSourceText "Defining and managing organization's approach to governing IT security and ensuring the privacy of data flows throughout the organization. Establish and manage tools to support the governance process in order to avoid misuse of information and breach of organizational privacy." ;
    rdfs:label "Create IT security, privacy, and data protection risk governance" ;
    skos:definition "An Act of Formulation that defines an organization's approach to governing IT security and data privacy and produces an IT security and privacy governance specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (cco:ont00000511): defining a governance approach yields a Directive ICE. The standing 'manage tools' is the IT Risk Management Capability (R6)." ;
    skos:example "A CISO defines the data-privacy governance model and supporting tooling." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSecurityGovernanceSpecification ] .

ex:P20738 a owl:Class ;
    ex:pcfID "20738" ; ex:hierarchyID "8.3.5.3" ;
    ex:apqcSourceText "Outlining and establishing policies, regulations, standards, and procedures for IT data security and privacy." ;
    rdfs:label "Define IT data security and privacy policies, standards, and procedures" ;
    skos:definition "An Act of Formulation that outlines and establishes policies, standards, and procedures for IT data security and privacy and produces an IT policy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (cco:ont00000511): composing policies/standards yields a Directive ICE." ;
    skos:example "A security team issues the data-encryption and access policies." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPolicy ] .

ex:P20739 a owl:Class ;
    ex:pcfID "20739" ; ex:hierarchyID "8.3.5.4" ;
    ex:apqcSourceText "Identifying, examining, and reviewing physical and logical IT data security measures such as hardware security (smart cards), cryptographic protocols, and access control." ;
    rdfs:label "Review and monitor physical and logical IT data security measures" ;
    skos:definition "An Act of Monitoring that identifies, examines, and reviews physical and logical IT data security measures and produces an IT security control review." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (cco:ont00000366): ongoing review/examination of security measures yields a descriptive review." ;
    skos:example "A security team reviews smart-card and cryptographic controls quarterly." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSecurityControlReview ] .

ex:P20740 a owl:Class ;
    ex:pcfID "20740" ; ex:hierarchyID "8.3.5.5" ;
    ex:apqcSourceText "Identifying, examining, and reviewing security control for IT applications. Test, analyze, and implement security protocols in order to safeguard IT applications." ;
    rdfs:label "Review and monitor application security controls" ;
    skos:definition "An Act of Monitoring that identifies, examines, and reviews security controls for IT applications and produces an IT security control review." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (cco:ont00000366): ongoing review of application controls yields a descriptive review. Test/implement steps are method notes." ;
    skos:example "An AppSec team reviews and tests the controls protecting a web application." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSecurityControlReview ] .

ex:P20741 a owl:Class ;
    ex:pcfID "20741" ; ex:hierarchyID "8.3.5.6" ;
    ex:apqcSourceText "Identifying and examining security controls for physical environment of information technology such as business facilities, equipment, and resources." ;
    rdfs:label "Review and monitor IT physical environment security controls" ;
    skos:definition "An Act of Monitoring that identifies and examines security controls for the physical environment of information technology and produces an IT security control review." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (cco:ont00000366): ongoing examination of physical-environment controls yields a descriptive review." ;
    skos:example "A facilities-security team reviews data-center access and equipment controls." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSecurityControlReview ] .

ex:P20742 a owl:Class ;
    ex:pcfID "20742" ; ex:hierarchyID "8.3.5.7" ;
    ex:apqcSourceText "Monitoring and evaluating network intrusion detection for any malicious activity or policy violations. Identify the gaps in order to resolve threats and enhance existing network security." ;
    rdfs:label "Monitor/analyze network intrusion detection data and resolve threats" ;
    skos:definition "An Act of Monitoring that has as input network intrusion detection data and has as output a network intrusion threat resolution describing detected malicious activity, identified gaps, and resolved threats." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (cco:ont00000366): continuous monitoring/evaluating of IDS data yields a descriptive resolution record." ;
    skos:example "A SOC analyst triages IDS alerts, closes a gap, and resolves the threat." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:NetworkIntrusionDetectionData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:NetworkIntrusionThreatResolution ] .

ex:P20743 a owl:Class ;
    ex:pcfID "20743" ; ex:hierarchyID "8.3.6" ;
    ex:apqcSourceText "Evaluate and analyze the IT environment for the compliance of industry regulations and government legislation. Ensure that IT capability and resources meet the set standards." ;
    rdfs:label "Conduct and analyze IT compliance assessments" ;
    skos:definition "An Act of Appraisal that evaluates and analyzes the IT environment for compliance with industry regulations and government legislation and produces an IT compliance audit report." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): conducting compliance assessments yields a descriptive judgement. Decomposes into its activities." ;
    skos:example "A compliance function's annual review of the IT estate against regulations." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITComplianceAuditReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20744 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20745 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20746 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20747 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20748 ] .

ex:P20744 a owl:Class ;
    ex:pcfID "20744" ; ex:hierarchyID "8.3.6.1" ;
    ex:apqcSourceText "Conducting projects in order to enhance set standards, established guidelines, and risk preventive measures for IT risk and resilience." ;
    rdfs:label "Conduct projects to enhance IT compliance and remediate risk" ;
    skos:definition "A Planned Act that conducts projects to enhance IT compliance standards and remediate IT risk and produces a remediation plan." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act): executing remediation/enhancement projects is a bounded planned operation." ;
    skos:example "A team runs a project to close audit findings and harden controls." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RemediationPlan ] .

ex:P20745 a owl:Class ;
    ex:pcfID "20745" ; ex:hierarchyID "8.3.6.2" ;
    ex:apqcSourceText "Examine compliance control systems and tools implemented for internal and external IT services." ;
    rdfs:label "Conduct IT compliance control auditing of internal and external services" ;
    skos:definition "An Act of Verification that examines the compliance control systems and tools implemented for internal and external IT services and produces an IT compliance audit report." ;
    rdfs:comment "Anchored to ex:ActOfVerification (cco:ont00000636): auditing controls against requirements yields a descriptive audit report." ;
    skos:example "An auditor reviews the control tooling protecting an outsourced IT service." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITComplianceAuditReport ] .

ex:P20746 a owl:Class ;
    ex:pcfID "20746" ; ex:hierarchyID "8.3.6.3" ;
    ex:apqcSourceText "Execute IT compliance reporting in order to review processes, standards, regulations, and laws are followed as laid out by the regulatory bodies." ;
    rdfs:label "Perform IT compliance reporting" ;
    skos:definition "An Act of Information Processing that compiles the results of IT compliance review and produces an IT compliance audit report." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): compiling compliance results into a report manipulates input ICEs into a descriptive report." ;
    skos:example "A compliance analyst issues the quarterly IT compliance report to regulators." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITComplianceAuditReport ] .

ex:P20747 a owl:Class ;
    ex:pcfID "20747" ; ex:hierarchyID "8.3.6.4" ;
    ex:apqcSourceText "Identify and escalate issues related to IT compliance to ensure that corrective measures are taken." ;
    rdfs:label "Identify and escalate IT compliance issues and remediation requirements" ;
    skos:definition "An Act of Identification that discerns IT compliance issues and their remediation requirements and produces an IT compliance issue and remediation requirement register." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (cco:ont00000366): discerning/registering compliance issues yields a Descriptive ICE. Escalation is a downstream communication, not definitional output." ;
    skos:example "An auditor flags a retention-rule breach and records the required fix." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITComplianceAuditReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITComplianceIssueRegister ] .

ex:P20748 a owl:Class ;
    ex:pcfID "20748" ; ex:hierarchyID "8.3.6.5" ;
    ex:apqcSourceText "Supporting audits and reports through external resources. This process requires the organization to follow all the regulations set forth by external auditors." ;
    rdfs:label "Support external audits and reports" ;
    skos:definition "A Planned Act that supports external audits and reports by furnishing the evidence and cooperation required by external auditors." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act): supporting an external audit is a bounded planned activity with an external auditor as participant." ;
    skos:example "An IT team provides logs and walkthroughs to support an external SOC 2 audit." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITComplianceAuditReport ] .

ex:P20749 a owl:Class ;
    ex:pcfID "20749" ; ex:hierarchyID "8.3.7" ;
    ex:apqcSourceText "Create and execute a process to rapidly adapt and respond to any internal or external opportunity, demand, disruption, or threat in IT. Maintain continuous IT operations to protect employees, assets, and overall brand equity." ;
    rdfs:label "Develop and execute IT resilience and continuity operations" ;
    skos:definition "A Planned Act that creates and executes the operations by which IT rapidly adapts and responds to opportunities, demands, disruptions, and threats while maintaining continuous IT operations." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act) because the process spans development and execution. Decomposes into its activities." ;
    skos:example "An IT team's standing resilience-operations program executed through an outage." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20750 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20751 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20752 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20753 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20754 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20755 ] .

ex:P20750 a owl:Class ;
    ex:pcfID "20750" ; ex:hierarchyID "8.3.7.1" ;
    ex:apqcSourceText "Conducting projects to improve the strategy and process for rapidly adapting to any threat in IT." ;
    rdfs:label "Conduct IT resilience improvement projects" ;
    skos:definition "A Planned Act that conducts projects to improve the strategy and process for rapidly adapting to IT threats." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act): executing improvement projects is a bounded planned operation." ;
    skos:example "A team runs a project to shorten IT incident-recovery time." ;
    rdfs:subClassOf cco:ont00000228 .

ex:P20751 a owl:Class ;
    ex:pcfID "20751" ; ex:hierarchyID "8.3.7.2" ;
    ex:apqcSourceText "Develop, document, and maintain plans to ensure uninterrupted operations of critical IT services. Determine resources such as specialized personnel, equipment, support infrastructure, legal and financial aspects." ;
    rdfs:label "Develop, document, and maintain IT business continuity planning" ;
    skos:definition "An Act of Formulation that develops and documents plans ensuring uninterrupted operation of critical IT services and produces an IT continuity plan." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (cco:ont00000511): composing continuity plans yields a Directive ICE. The standing 'maintain' is the IT Risk Management Capability (R6)." ;
    skos:example "A continuity team authors and documents the disaster-recovery plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITContinuityPlan ] .

ex:P20752 a owl:Class ;
    ex:pcfID "20752" ; ex:hierarchyID "8.3.7.3" ;
    ex:apqcSourceText "Implement and enforce procedures and policies in order to control changes in IT services and solutions. Manage changes in a rational and predictable manner for optimum resource utilization." ;
    rdfs:label "Implement and enforce change control procedures" ;
    skos:definition "A Planned Act that implements and enforces procedures and policies to control changes in IT services and solutions." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act): enacting and enforcing change-control procedures is a bounded planned operation directed by an IT policy." ;
    skos:example "A change-management board enforces the change-control workflow for a release." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPolicy ] .

ex:P20753 a owl:Class ;
    ex:pcfID "20753" ; ex:hierarchyID "8.3.7.4" ;
    ex:apqcSourceText "Review and implement resources (including external parties) necessary to support uninterrupted operations of critical IT services." ;
    rdfs:label "Execute recurring IT service provider business continuity" ;
    skos:definition "An Act of Deployment that reviews and makes operationally available the resources, including external parties, needed to support uninterrupted operation of critical IT services." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfServiceProvision to ex:ActOfDeployment (cco:ont00000228). REJECTED ex:ActOfServiceProvision: its definition renders a service to a CUSTOMER by carrying out tasks fulfilling an agreed service need, but the source text ('Review and implement resources ... necessary to support uninterrupted operations of critical IT services') is internal continuity execution -- reviewing and making standby resources operationally available -- not the rendering of a customer-facing service; the customer-service framing was imported from the genus, not the source. The 'review and implement resources' verb fits Deployment (install/configure/make-operationally-available). Has an external IT support provider as participant; guided by ex:ITContinuityPlan as input. Same decision applied to its sibling P20755." ;
    skos:example "An IT operations team reviews and stands up a third-party failover capability for continuity." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITContinuityPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ExternalITSupportProvider ] .

ex:P20754 a owl:Class ;
    ex:pcfID "20754" ; ex:hierarchyID "8.3.7.5" ;
    ex:apqcSourceText "Conduct and manage employee training programs on IT resilience so that prospective risks can be avoided." ;
    rdfs:label "Provide IT resilience training" ;
    skos:definition "An Act of Service Provision that conducts employee training programs on IT resilience." ;
    rdfs:comment "Anchored to ex:ActOfServiceProvision (cco:ont00000228): delivering training to employees. Has the IT training program as input directing the delivery." ;
    skos:example "An instructor runs the annual IT-resilience training session for staff." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITTrainingProgram ] .

ex:P20755 a owl:Class ;
    ex:pcfID "20755" ; ex:hierarchyID "8.3.7.6" ;
    ex:apqcSourceText "Implement regular resources supporting uninterrupted operations of critical IT services." ;
    rdfs:label "Execute recurring IT business operations continuity" ;
    skos:definition "An Act of Deployment that implements and makes operationally available the regular internal resources that support uninterrupted operation of critical IT services, guided by an IT continuity plan." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfServiceProvision to ex:ActOfDeployment (cco:ont00000228), consistent with sibling P20753. REJECTED ex:ActOfServiceProvision (customer-service rendering): the source ('Implement regular resources supporting uninterrupted operations of critical IT services') is internal operations execution, not a customer service. Also added a differentiating restriction (has input ex:ITContinuityPlan and has participant ex:ITServiceProvider for the internal-resource reading) so the class is logically distinguishable from its genus and from P20753 (which has ex:ExternalITSupportProvider) rather than relying on a comment alone, resolving the prior thin-class/Gate-F exclusiveness gap." ;
    skos:example "An operations team stands up the scheduled internal failover resources keeping services available." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITContinuityPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceProvider ] .

ex:P20756 a owl:Class ;
    ex:pcfID "20756" ; ex:hierarchyID "8.3.8" ;
    ex:apqcSourceText "The process of identifying, authenticating, and authorizing IT users to have access to applications, systems, IT components, or networks by associating user rights and restrictions with established identities." ;
    rdfs:label "Manage IT user identity and authorization" ;
    skos:definition "A Planned Act that identifies, authenticates, and authorizes IT users to access applications, systems, IT components, or networks by associating user rights and restrictions with established identities." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act): the bounded identify-authenticate-authorize cycle. The standing identity-and-access 'manage' function is the IT Risk Management Capability (R6). Decomposes into its activities." ;
    skos:example "An IAM team's onboarding cycle granting a new hire scoped access." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITUser ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20757 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20758 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20759 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20760 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20761 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20762 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20763 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20764 ] .

ex:P20757 a owl:Class ;
    ex:pcfID "20757" ; ex:hierarchyID "8.3.8.1" ;
    ex:apqcSourceText "Create and implement policies that integrate authorization policies with authorized profiles of users meant to access network resources." ;
    rdfs:label "Support integration of identity and authorization policies" ;
    skos:definition "An Act of Formulation that creates policies integrating authorization with the authorized profiles of users permitted to access network resources and produces an IT user identity and authorization policy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (cco:ont00000511): composing integration policies yields a Directive ICE." ;
    skos:example "An IAM architect issues a policy binding entitlements to authenticated profiles." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITUserAuthorizationPolicy ] .

ex:P20758 a owl:Class ;
    ex:pcfID "20758" ; ex:hierarchyID "8.3.8.2" ;
    ex:apqcSourceText "Managing directory of user profiles and access requirements across different levels in the organization's IT network." ;
    rdfs:label "Manage IT user directory" ;
    skos:definition "An Act of Data Management that stores, controls, and updates the directory of user profiles and access requirements across an organization's IT network." ;
    rdfs:comment "Anchored to ex:ActOfDataManagement (cco:ont00000366): maintaining the user directory governs a body of ICEs. The IT user directory is the entity managed." ;
    skos:example "An admin updates group memberships and access requirements in the directory." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITUserDirectory ] .

ex:P20759 a owl:Class ;
    ex:pcfID "20759" ; ex:hierarchyID "8.3.8.3" ;
    ex:apqcSourceText "Managing the process of authorizing IT users to access applications, systems, IT components, or networks by associating user rights." ;
    rdfs:label "Manage IT user authorization" ;
    skos:definition "A Planned Act that authorizes IT users to access applications, systems, IT components, or networks by associating user rights with their identities." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act): granting access rights is a bounded authorization operation with an IT user as participant. No verified CCO 'Act of Authorization' exists; the generic Planned Act is the nearest fit." ;
    skos:example "An IAM operator grants a user the entitlements for a new application." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITUser ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITUserDirectory ] .

ex:P20760 a owl:Class ;
    ex:pcfID "20760" ; ex:hierarchyID "8.3.8.4" ;
    ex:apqcSourceText "Create and manage the process to authenticate IT users from user directory based on the internal policies." ;
    rdfs:label "Manage IT user authentication mechanisms" ;
    skos:definition "A Planned Act that creates and operates the process to authenticate IT users from the user directory according to internal policies." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act): operating authentication is a bounded planned operation directed by an IT policy and drawing on the user directory." ;
    skos:example "An IAM team configures and runs multi-factor authentication against the directory." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITUserDirectory ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPolicy ] .

ex:P20761 a owl:Class ;
    ex:pcfID "20761" ; ex:hierarchyID "8.3.8.5" ;
    ex:apqcSourceText "Examine the processes responsible for reviewing IT user identity and authorization." ;
    rdfs:label "Audit IT user identity and authorization systems" ;
    skos:definition "An Act of Verification that examines the processes responsible for reviewing IT user identity and authorization and produces an IT audit report." ;
    rdfs:comment "Anchored to ex:ActOfVerification (cco:ont00000636): auditing the identity/authorization processes yields a descriptive audit report." ;
    skos:example "An auditor reviews the access-recertification process and reports findings." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITAuditReport ] .

ex:P20762 a owl:Class ;
    ex:pcfID "20762" ; ex:hierarchyID "8.3.8.6" ;
    ex:apqcSourceText "Address any form of unauthorized network breach such as unauthorized access or usage of data, applications, services, networks, and/or devices. Identify the root cause and take corrective measures to resolve the breach." ;
    rdfs:label "Respond to IT information security and network breaches" ;
    skos:definition "A Planned Act that addresses an unauthorized network breach by identifying its root cause and taking corrective measures to resolve it, producing an IT security breach record." ;
    rdfs:comment "Anchored at the generic cco:ont00000228 (Planned Act): responding to a breach is a bounded planned operation; the breach record (Descriptive ICE) documents the resolution." ;
    skos:example "An incident-response team contains a breach, finds its root cause, and remediates." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSecurityBreach ] .

ex:P20763 a owl:Class ;
    ex:pcfID "20763" ; ex:hierarchyID "8.3.8.7" ;
    ex:apqcSourceText "Conduct penetration testing (pen test) through an authorized stimulated attack to identify security weakness in an IT environment by evaluating the system or network with various harmful techniques." ;
    rdfs:label "Conduct penetration testing" ;
    skos:definition "An Act of Verification that subjects an IT environment to an authorized simulated attack to identify security weaknesses and produces a penetration test finding." ;
    rdfs:comment "Anchored to ex:ActOfVerification (cco:ont00000636): testing the environment against security expectations yields a descriptive finding." ;
    skos:example "A red team pen-tests a network and reports exploitable weaknesses." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITSecurityThreatData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PenetrationTestFinding ] .

ex:P20764 a owl:Class ;
    ex:pcfID "20764" ; ex:hierarchyID "8.3.8.8" ;
    ex:apqcSourceText "Reviewing the processes responsible for integration of user identity and access authorization in order to confirm that all the required regulations are followed." ;
    rdfs:label "Audit integration of user identity and authorization systems" ;
    skos:definition "An Act of Verification that reviews the processes responsible for integrating user identity and access authorization to confirm regulatory conformance and produces an IT audit report." ;
    rdfs:comment "Anchored to ex:ActOfVerification (cco:ont00000636): auditing the integration processes against regulations yields a descriptive audit report." ;
    skos:example "An auditor confirms that the federated-identity integration meets access regulations." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITAuditReport ] .

# ================================================================
# GROUP 8.4  Manage information
# (group node 8.4 [PCF 20765] = ex:InformationManagementCapability, R6,
#  declared in the shared vocabulary above)
# ================================================================

ex:P20766 a owl:Class ;
    ex:pcfID "20766" ; ex:hierarchyID "8.4.1" ;
    ex:apqcSourceText "Create an organization-wide strategy for the IT function by combining skills, technologies, applications, and processes in order to attain organizations objectives." ;
    rdfs:label "Define business information and analytics strategy" ;
    skos:definition "An Act of Formulation that composes an organization-wide information and analytics strategy and has as output an IT strategy prescribing how skills, technologies, applications, and processes are combined to attain organizational objectives." ;
    rdfs:comment "Genus is formulation; output is a Directive ICE (the strategy) per the GOLDEN PRINCIPLE. Its three APQC activities are process parts." ;
    skos:example "An IT leadership team formulates the enterprise's three-year data and analytics strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20767 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20768 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20769 ] .

ex:P20767 a owl:Class ;
    ex:pcfID "20767" ; ex:hierarchyID "8.4.1.1" ;
    ex:apqcSourceText "Implementing strategies for securing and ensuring the privacy of data flows throughout the organization. Create protocols and guidelines for individual IT components. Outline analytic objectives in order to avoid misuse of information." ;
    rdfs:label "Establish data, information, and analytic objectives" ;
    skos:definition "An Act of Formulation that has as output data, information, and analytic objectives prescribing the securing, privacy, and proper use of the organization's data and analytics." ;
    rdfs:comment "Genus is formulation; output is a Directive ICE (the objectives) per the GOLDEN PRINCIPLE." ;
    skos:example "A data office outlines analytic objectives and privacy protocols to prevent misuse of information." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DataInformationAnalyticObjectives ] .

ex:P20768 a owl:Class ;
    ex:pcfID "20768" ; ex:hierarchyID "8.4.1.2" ;
    ex:apqcSourceText "Creating a set of guidelines that ensure effective and efficient use of IT. Define data, information, and analytic governance to reach the organization's goal." ;
    rdfs:label "Establish data, information, and analytic governance" ;
    skos:definition "An Act of Formulation that has as output an information governance framework prescribing the guidelines that ensure effective and efficient use of the organization's data, information, and analytics." ;
    rdfs:comment "Genus is formulation; output is a Directive ICE (the governance framework) per the GOLDEN PRINCIPLE." ;
    skos:example "A governance board defines the data and analytics governance framework for the enterprise." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InformationGovernanceFramework ] .

ex:P20769 a owl:Class ;
    ex:pcfID "20769" ; ex:hierarchyID "8.4.1.3" ;
    ex:apqcSourceText "Determining the request for data accessibility and analysis. Review the details based on internal data security policies and permit data access only if internal policies and data access parameters are met." ;
    rdfs:label "Access IT data/analytic capabilities" ;
    skos:definition "An Act of Data Management that reviews a data-access request against internal security policies and governs access to the requested data and analytic capabilities, permitting access only when policy parameters are met." ;
    rdfs:comment "Genus is data management (governing access to ICEs). The access request is a typical input (comment-level); input ex:ITPolicy is the security policy consulted." ;
    skos:example "A data-access committee reviews a request against security policy and grants scoped read access." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPolicy ] .

ex:P20770 a owl:Class ;
    ex:pcfID "20770" ; ex:hierarchyID "8.4.2" ;
    ex:apqcSourceText "Creating strategies to manage the organization's information and content. Outline the architecture for information collection and communication. Administer information resources, data management and content." ;
    rdfs:label "Define and maintain business information architecture" ;
    skos:definition "An Act of Design that devises the architecture for the organization's information collection and communication and has as output an enterprise architecture specification prescribing how information resources are structured and managed." ;
    rdfs:comment "Genus is design; output is a Directive ICE (the architecture specification) per the GOLDEN PRINCIPLE. Its five APQC activities are process parts." ;
    skos:example "An enterprise architecture team defines and maintains the business information architecture." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnterpriseArchitectureSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20771 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20772 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20773 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20774 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20775 ] .

ex:P20771 a owl:Class ;
    ex:pcfID "20771" ; ex:hierarchyID "8.4.2.1" ;
    ex:apqcSourceText "Determining strategies to manage the enterprise wide flow of business information and content. Outline the required architecture for information resources." ;
    rdfs:label "Determine enterprise business information requirements" ;
    skos:definition "An Act of Analysis that examines the enterprise-wide flow of business information and content and has as output an IT requirements analysis describing the required information-resource architecture." ;
    rdfs:comment "Genus is analysis; output is a Descriptive ICE (the requirements analysis) per the GOLDEN PRINCIPLE." ;
    skos:example "An analyst determines the enterprise's business-information requirements ahead of an architecture refresh." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20772 a owl:Class ;
    ex:pcfID "20772" ; ex:hierarchyID "8.4.2.2" ;
    ex:apqcSourceText "Define different ways of representation, usage, and identification of data with independent or interdependent sources across the organization." ;
    rdfs:label "Define enterprise data models" ;
    skos:definition "An Act of Design that specifies the representation, usage, and identification of data entities across the organization's sources and has as output an enterprise data model specification." ;
    rdfs:comment "Genus is design; output is a Directive ICE (the data model specification) per the GOLDEN PRINCIPLE." ;
    skos:example "A data architect defines the enterprise logical data model spanning interdependent sources." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnterpriseDataModelSpecification ] .

ex:P20773 a owl:Class ;
    ex:pcfID "20773" ; ex:hierarchyID "8.4.2.3" ;
    ex:apqcSourceText "Identifying and understanding external sources of data in relevance of reliability, security, and authenticity." ;
    rdfs:label "Identify and understand external data sources" ;
    skos:definition "An Act of Identification that discerns external data sources and has as output an external data source assessment describing their reliability, security, and authenticity." ;
    rdfs:comment "Genus is identification (discernment sense); output is a Descriptive ICE (the source assessment) per the GOLDEN PRINCIPLE." ;
    skos:example "A data team identifies and rates candidate external feeds by trustworthiness." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExternalDataSourceAssessment ] .

ex:P20774 a owl:Class ;
    ex:pcfID "20774" ; ex:hierarchyID "8.4.2.4" ;
    ex:apqcSourceText "Establishing entities responsible for data accuracy, integrity, and timeliness that can authorize or deny access to certain data. Develop data utilizing governance processes to ensure fitness of data elements." ;
    rdfs:label "Establish data ownership and stewardship responsibilities" ;
    skos:definition "An Act of Formulation that has as output a data stewardship assignment prescribing the entities responsible for data accuracy, integrity, and timeliness and their authority over data access." ;
    rdfs:comment "Genus is formulation; output is a Directive ICE (the stewardship assignment) per the GOLDEN PRINCIPLE." ;
    skos:example "A data office assigns owners and stewards for each master-data domain." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DataStewardshipAssignment ] .

ex:P20775 a owl:Class ;
    ex:pcfID "20775" ; ex:hierarchyID "8.4.2.5" ;
    ex:apqcSourceText "Creating and maintaining the process of designing, creating, deploying, and managing strategies to maintain enterprise data and information architecture." ;
    rdfs:label "Maintain and evolve enterprise data and information architecture" ;
    skos:definition "An Act of Data Management that keeps the enterprise data and information architecture current and has as output an updated enterprise architecture specification reflecting its evolution." ;
    rdfs:comment "Genus is data management (the architecture artifact is governed and updated as an ICE); output is the maintained Directive ICE (architecture specification). Rejected ex:ActOfDesign as the primary genus because the differentia here is ongoing upkeep of an existing artifact, not authoring a new one." ;
    skos:example "An architecture team versions and updates the enterprise information architecture each quarter." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnterpriseArchitectureSpecification ] .

ex:P20776 a owl:Class ;
    ex:pcfID "20776" ; ex:hierarchyID "8.4.3" ;
    ex:apqcSourceText "Develop and implement strategies to plan and manage the flow of an information system's data from creation and initial storage to the time when it becomes obsolete and deleted." ;
    rdfs:label "Define and execute business information lifecycle planning and control" ;
    skos:definition "An Act of Formulation that plans the management of information from creation and initial storage through obsolescence and deletion and has as output an IT policy prescribing the information lifecycle, coordinating its policy-setting and data-administration activities." ;
    rdfs:comment "Genus is formulation (the headline output is a lifecycle plan/policy, a Directive ICE) per the GOLDEN PRINCIPLE; its execution facets are carried by its data-administration child. Its two APQC activities are process parts." ;
    skos:example "An information-management office defines and runs the data lifecycle policy from capture to deletion." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20777 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20778 ] .

ex:P20777 a owl:Class ;
    ex:pcfID "20777" ; ex:hierarchyID "8.4.3.1" ;
    ex:apqcSourceText "Outlining and establishing policies for information and setting information standards and procedures. Establish policies to regulate the creation, use, storage, access, communication, and dissemination of information." ;
    rdfs:label "Define and maintain enterprise information policies, standards, and procedures" ;
    skos:definition "An Act of Formulation that has as output an IT policy and an IT standard prescribing how the creation, use, storage, access, communication, and dissemination of information are to be regulated." ;
    rdfs:comment "Genus is formulation; outputs are Directive ICEs (policy and standard) per the GOLDEN PRINCIPLE." ;
    skos:example "A governance team establishes information-handling policies and the accompanying standards." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPolicy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStandard ] .

ex:P20778 a owl:Class ;
    ex:pcfID "20778" ; ex:hierarchyID "8.4.3.2" ;
    ex:apqcSourceText "Implementing and executing strategies for processes and technologies that support the collection, managing, and storing of data." ;
    rdfs:label "Implement and execute data administration responsibilities" ;
    skos:definition "An Act of Data Management that executes the processes and technologies supporting the collection, management, and storage of the organization's data." ;
    rdfs:comment "Genus is data management (ICEs are collected, managed, and stored). No single definitional output artifact beyond the administered data itself; specific outputs are instance-level (comment-level)." ;
    skos:example "A data-administration team operates the pipelines that collect and store enterprise data." ;
    rdfs:subClassOf ex:ActOfDataManagement .

ex:P20779 a owl:Class ;
    ex:pcfID "20779" ; ex:hierarchyID "8.4.4" ;
    ex:apqcSourceText "Creating strategies to administer information and content. Understand the needs of the organization for information and content management. Realize the role of IT services for implementing the overall business strategy. Assess the implications of new technologies for managing information and content. Identify and prioritize the most effective and efficient actions for managing information and content." ;
    rdfs:label "Manage business information" ;
    skos:definition "An Act of Data Management that administers the organization's business information and content and coordinates the monitoring, maintenance, auditing, and access-administration of that information as its process parts." ;
    rdfs:comment "Modeled as a bounded coordinating data-management occurrent (an APQC Process-typed node with four bounded children), not as a standing capability: the standing 'Manage information' function is captured separately at group level by ex:InformationManagementCapability (R6). Its four APQC activities are process parts." ;
    skos:example "An information-management team runs a cycle of administering, monitoring, and auditing business information." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20780 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20781 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20782 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20783 ] .

ex:P20780 a owl:Class ;
    ex:pcfID "20780" ; ex:hierarchyID "8.4.4.1" ;
    ex:apqcSourceText "Defining the rules, diction, and logic that make up the framework of the organization's information architecture. Monitoring and controlling information attributes that flow through the IT framework." ;
    rdfs:label "Monitor and control business information" ;
    skos:definition "An Act of Monitoring that continuously observes the information attributes flowing through the IT framework and has as output an IT performance report recording their state and any deviations." ;
    rdfs:comment "Genus is monitoring; output is a Descriptive ICE (the state/deviation report) per the GOLDEN PRINCIPLE. Gate-F DE-CONFLATION (Phase 1, recorded choice not omission): the APQC source fuses two facets -- (1) a DIRECTIVE rule/framework-defining facet ('Defining the rules, diction, and logic that make up the framework of the organization's information architecture', i.e. authoring a prescriptive information-architecture framework, a Directive ICE; this is an ex:ActOfFormulation/ex:ActOfDesign concern, covered at the section-8.4 information-architecture design rows under 8.4.2) and (2) the MONITORING facet modeled here ('Monitoring and controlling information attributes that flow through the IT framework'). This class deliberately anchors only the monitoring facet; the rule-definition facet is NOT given a separate process sub-step here because a non-PCF supporting process would fail Gate-C S1 (every ex: process needs ex:pcfID) -- it is instead represented at the dedicated 8.4.2 information-architecture design rows. The 'control' (enforcement) verb is the corrective follow-on to monitoring and is left as a typical, non-definitional aspect (Phase-3)." ;
    skos:example "An operations team tracks data-quality attributes across the information pipeline and reports anomalies." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20781 a owl:Class ;
    ex:pcfID "20781" ; ex:hierarchyID "8.4.4.2" ;
    ex:apqcSourceText "Maintain information feedstock along with IT hardware and software needed for storage, access, and retrieval of business information." ;
    rdfs:label "Maintain business information feeds and repositories" ;
    skos:definition "An Act of Data Management that keeps the organization's information feeds and repositories current and available for storage, access, and retrieval, and has as output a maintained IT knowledge repository." ;
    rdfs:comment "Genus is data management; output is the maintained Descriptive ICE (the knowledge repository). The supporting IT hardware/software is an operational resource (comment-level), not a definitional ICE I/O." ;
    skos:example "A data-platform team keeps the enterprise content repository and its feeds running and retrievable." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITKnowledgeRepository ] .

ex:P20782 a owl:Class ;
    ex:pcfID "20782" ; ex:hierarchyID "8.4.4.3" ;
    ex:apqcSourceText "Verification of information access and usage through regular reports on organizational performance." ;
    rdfs:label "Perform internal usage audits" ;
    skos:definition "An Act of Verification that examines information access and usage against expected organizational performance and has as output an IT compliance audit report recording the findings." ;
    rdfs:comment "Genus is verification; output is a Descriptive ICE (the audit report) per the GOLDEN PRINCIPLE." ;
    skos:example "An internal audit team reviews information access logs and issues a usage-compliance report." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITComplianceAuditReport ] .

ex:P20783 a owl:Class ;
    ex:pcfID "20783" ; ex:hierarchyID "8.4.4.4" ;
    ex:apqcSourceText "Implement and manage the process for accessing information including issues related to copyright, open source, privacy, and security." ;
    rdfs:label "Implement and administer business information access" ;
    skos:definition "An Act of Data Management that implements and administers the process for accessing business information, governing copyright, open-source, privacy, and security concerns." ;
    rdfs:comment "Genus is data management (governing access to ICEs). Input ex:ITPolicy is the copyright/privacy/security policy applied; specific access grants are instance-level (comment-level)." ;
    skos:example "An access-management team enforces copyright and privacy controls when provisioning information access." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPolicy ] .

# ================================================================
# GROUP 8.5  Develop and manage services/solutions
# (group node 8.5 [PCF 20784] = ex:DevelopAndManageServicesSolutionsCapability,
#  R6, declared in the group-capability section above)
# ================================================================

ex:P20785 a owl:Class ;
    ex:pcfID "20785" ; ex:hierarchyID "8.5.1" ;
    ex:apqcSourceText "Developing service/solution along with creating a strategy that provides a base for delivering service/solution aligned with overall business needs. Conduct research within the services/solutions field for development and integration." ;
    rdfs:label "Develop service/solution and integration strategy" ;
    skos:definition "An Act of Formulation that examines business needs and the services/solutions field and produces an IT strategy for developing and integrating IT services and solutions." ;
    rdfs:comment "Models APQC 8.5.1 as a bounded formulation occurrent; its APQC children are process parts, not subclasses." ;
    skos:example "An IT planning team drafts the service/solution development and integration strategy for the coming year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20786 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20787 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20788 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20789 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20790 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20791 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20792 ] .

ex:P20786 a owl:Class ;
    ex:pcfID "20786" ; ex:hierarchyID "8.5.1.1" ;
    ex:apqcSourceText "Determining the development of IT service/solution. Analyze the pros and cons of IT service/solution and it's methods on the basis of their cost effectiveness and development value." ;
    rdfs:label "Determine IT service/solution development" ;
    skos:definition "An Act of Appraisal that evaluates candidate IT service/solution development methods by cost-effectiveness and development value and produces an IT development value assessment." ;
    skos:example "An architect weighs build-vs-buy options and issues a cost-effectiveness assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITDevelopmentValueAssessment ] .

ex:P20787 a owl:Class ;
    ex:pcfID "20787" ; ex:hierarchyID "8.5.1.2" ;
    ex:apqcSourceText "Establishing the methods and processes as the foundation for developing new IT platforms, components, software, and explore new standards for better IT usage in the organization." ;
    rdfs:label "Define IT service/solution development processes/standards" ;
    skos:definition "An Act of Formulation that composes the methods, processes, and standards governing development of new IT platforms, components, and software, and produces an IT standard." ;
    skos:example "An engineering office publishes the organization's solution-development process standard." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStandard ] .

ex:P20788 a owl:Class ;
    ex:pcfID "20788" ; ex:hierarchyID "8.5.1.3" ;
    ex:apqcSourceText "Identifying and implementing techniques and tools for development based on overall value addition to the IT environment." ;
    rdfs:label "Identify, deploy, and support development methodologies and tools" ;
    skos:definition "An Act of Selection that chooses development methodologies and tools on the basis of their value addition to the IT environment and produces an IT development methodology and tool standard prescribing the adopted set." ;
    rdfs:comment "Anchored under ex:ActOfSelection (choice from candidates yielding a directive). Deployment/support of the chosen tools is downstream and not definitional here." ;
    skos:example "A platform team selects and rolls out an approved CI/CD toolchain." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITDevelopmentToolStandard ] .

ex:P20789 a owl:Class ;
    ex:pcfID "20789" ; ex:hierarchyID "8.5.1.4" ;
    ex:apqcSourceText "Establishing standards for selection of IT service components." ;
    rdfs:label "Establish service component criteria" ;
    skos:definition "An Act of Formulation that composes the standards for selecting IT service components and produces service component selection criteria." ;
    skos:example "An architecture board issues the criteria a component must meet to be approved." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ServiceComponentSelectionCriteria ] .

ex:P20790 a owl:Class ;
    ex:pcfID "20790" ; ex:hierarchyID "8.5.1.5" ;
    ex:apqcSourceText "Understanding and selecting reusable service components so that they can be cost-effective and efficient." ;
    rdfs:label "Understand and select reusable service components" ;
    skos:definition "An Act of Selection that chooses cost-effective reusable service components from candidates and has as input service component selection criteria." ;
    rdfs:comment "Has as input the criteria produced by 8.5.1.4 (definitional: selection requires the criteria)." ;
    skos:example "A designer picks two pre-approved reusable modules for a new service." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ServiceComponentSelectionCriteria ] .

ex:P20791 a owl:Class ;
    ex:pcfID "20791" ; ex:hierarchyID "8.5.1.6" ;
    ex:apqcSourceText "Creating and establishing service component portfolio by defining investments, and activities. Analyze and examine the value of the service component portfolio, and allocate resources towards it." ;
    rdfs:label "Maintain service component portfolio" ;
    skos:definition "An Act of Formulation that defines investments and activities for the service component portfolio and produces an IT portfolio plan with allocated resources." ;
    rdfs:comment "Despite the label 'Maintain', the description denotes bounded create/establish/allocate acts producing a portfolio plan; modeled as a process, not a standing function." ;
    skos:example "A portfolio manager (re)baselines the component portfolio and assigns its budget." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPortfolioPlan ] .

ex:P20792 a owl:Class ;
    ex:pcfID "20792" ; ex:hierarchyID "8.5.1.7" ;
    ex:apqcSourceText "Creating standards and procedures for developing IT services/solutions outside of defined business parameters." ;
    rdfs:label "Establish development standards exception governance" ;
    skos:definition "An Act of Formulation that composes standards and procedures for developing IT services/solutions outside defined business parameters and produces an IT policy." ;
    skos:example "Governance defines the waiver procedure for out-of-standard solution builds." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPolicy ] .

ex:P20793 a owl:Class ;
    ex:pcfID "20793" ; ex:hierarchyID "8.5.2" ;
    ex:apqcSourceText "Executing life-cycle planning for IT services and solutions. Develop new requirements and feature-function enhancements. Create and design a life cycle plan that addresses the current and future state of IT services and solutions." ;
    rdfs:label "Manage service/solution lifecycle planning" ;
    skos:definition "An Act of Formulation that performs lifecycle planning for IT services and solutions and produces an IT roadmap addressing their current and future state." ;
    rdfs:comment "Modeled as a bounded planning occurrent (the description is 'executing life-cycle planning ... create and design a life cycle plan'), not as a standing 'manage' function." ;
    skos:example "A lifecycle planning cycle yields the roadmap for the service portfolio." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRoadmap ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20794 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20795 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20796 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20797 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20798 ] .

ex:P20794 a owl:Class ;
    ex:pcfID "20794" ; ex:hierarchyID "8.5.2.1" ;
    ex:apqcSourceText "Perform a systematic investigation to new and future technology capabilities for future upgrades." ;
    rdfs:label "Monitor and track emerging technology capabilities" ;
    skos:definition "An Act of Monitoring that systematically investigates new and future technology capabilities and has as input emerging technology data and as output a technology assessment." ;
    skos:example "A horizon-scanning team tracks emerging platform capabilities for planned upgrades." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmergingTechnologyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TechnologyAssessment ] .

ex:P20795 a owl:Class ;
    ex:pcfID "20795" ; ex:hierarchyID "8.5.2.2" ;
    ex:apqcSourceText "Identifying processes and supporting procedures that are performed by an organization to design, plan, deliver, operate, and control information technology services/solutions offered to customers." ;
    rdfs:label "Identify IT services/solutions" ;
    skos:definition "An Act of Identification that discerns the IT services/solutions offered to customers and the procedures that realize them and produces an IT service/solution register." ;
    skos:example "An analyst catalogues every customer-facing IT service and its supporting procedures." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceSolutionRegister ] .

ex:P20796 a owl:Class ;
    ex:pcfID "20796" ; ex:hierarchyID "8.5.2.3" ;
    ex:apqcSourceText "Determining an approach to create a base for delivering IT service/solution aligned with overall business needs while maintaining a tight control on delivery and costs." ;
    rdfs:label "Determine IT service/solution approach" ;
    skos:definition "An Act of Formulation that composes a delivery approach for an IT service/solution aligned with business needs and cost/delivery controls and produces an IT service/solution delivery approach." ;
    skos:example "A delivery lead settles on a phased rollout approach with cost gates." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceSolutionApproach ] .

ex:P20797 a owl:Class ;
    ex:pcfID "20797" ; ex:hierarchyID "8.5.2.4" ;
    ex:apqcSourceText "Defining solutions to satisfy business needs. IT solution lifecycle provides a means to address the full life cycle of an information technology solution and addresses the current and future state of IT services and solutions." ;
    rdfs:label "Define IT solution lifecycle" ;
    skos:definition "An Act of Formulation that composes the full lifecycle of an IT solution addressing its current and future state and produces an IT roadmap." ;
    skos:example "A lifecycle owner documents the end-to-end lifecycle stages for a solution." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRoadmap ] .

ex:P20798 a owl:Class ;
    ex:pcfID "20798" ; ex:hierarchyID "8.5.2.5" ;
    ex:apqcSourceText "Developing plans to retire IT service/solution resources when the service/solution is no longer feasible." ;
    rdfs:label "Develop IT service/solution sunset plans" ;
    skos:definition "An Act of Formulation that composes plans to retire IT service/solution resources once they are no longer feasible and produces an IT service/solution sunset plan." ;
    skos:example "A team drafts the decommissioning plan for a legacy service." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceSolutionSunsetPlan ] .

ex:P20799 a owl:Class ;
    ex:pcfID "20799" ; ex:hierarchyID "8.5.3" ;
    ex:apqcSourceText "Creating the architecture for the IT services and solutions. Assess architecture and business constraints in order to understand integration requirements. Promote existing architecture. Manage exceptions." ;
    rdfs:label "Develop and manage service/solution architecture" ;
    skos:definition "An Act of Design that creates the architecture for IT services and solutions and produces an enterprise architecture specification." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfFormulation to ex:ActOfDesign (the registry-sanctioned, more specific genus -- the ex:ActOfDesign recurrence registry explicitly lists '8.5.3 (service/solution architecture)' as an ActOfDesign site, and ActOfDesign is defined precisely for authoring a design/architecture specification). ex:ActOfDesign remains a subclass of cco:ont00000511 (Act of Planning), so Gates A-D are unaffected; the output ex:EnterpriseArchitectureSpecification stays Directive, preserving the GOLDEN PRINCIPLE. This makes P20799 consistent with its leaf sibling P20805 (also re-anchored to ex:ActOfDesign) and with 8.5.4.1.2 P20811 'Create service/solution design'. Modeled as the bounded architecture-design occurrent that hosts its child parts; the standing 'manage/promote/exception' coordinating facets are realized in the same parts." ;
    skos:example "An architecture program produces and governs the service/solution architecture." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnterpriseArchitectureSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20800 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20801 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20802 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20803 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20804 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20805 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20806 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20807 ] .

ex:P20800 a owl:Class ;
    ex:pcfID "20800" ; ex:hierarchyID "8.5.3.1" ;
    ex:apqcSourceText "Assessing limitations in IT application and infrastructure architecture that may hinder expected performance." ;
    rdfs:label "Assess IT application and infrastructure architecture constraints" ;
    skos:definition "An Act of Appraisal that evaluates limitations in IT application and infrastructure architecture and produces an IT architecture constraint assessment." ;
    skos:example "An architect documents throughput ceilings in the current platform." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITLandscapeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITArchitectureConstraintAssessment ] .

ex:P20801 a owl:Class ;
    ex:pcfID "20801" ; ex:hierarchyID "8.5.3.2" ;
    ex:apqcSourceText "Evaluate business limitations that may hinder IT service/solution performance." ;
    rdfs:label "Assess business constraints on IT service/solution" ;
    skos:definition "An Act of Appraisal that evaluates business limitations bearing on IT service/solution performance and produces an IT business constraint assessment." ;
    skos:example "An assessment notes budget and compliance limits on a solution." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITBusinessConstraintAssessment ] .

ex:P20802 a owl:Class ;
    ex:pcfID "20802" ; ex:hierarchyID "8.5.3.3" ;
    ex:apqcSourceText "Determining the requirements to integrate IT components such as hardware, software, database, telecommunication, and network." ;
    rdfs:label "Determine IT component integration requirements" ;
    skos:definition "An Act of Analysis that examines IT components and produces an IT requirements analysis of the integration requirements among them." ;
    skos:example "An analyst specifies the interface and data requirements to integrate two systems." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20803 a owl:Class ;
    ex:pcfID "20803" ; ex:hierarchyID "8.5.3.4" ;
    ex:apqcSourceText "Identification of opportunities for reusing IT components so that they can be cost-effective and efficient." ;
    rdfs:label "Identify opportunities for IT component reuse" ;
    skos:definition "An Act of Identification that discerns opportunities for reusing IT components and produces an IT component reuse opportunity register." ;
    skos:example "An architect lists existing services that could be reused in a new solution." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITReuseOpportunityRegister ] .

ex:P20804 a owl:Class ;
    ex:pcfID "20804" ; ex:hierarchyID "8.5.3.5" ;
    ex:apqcSourceText "Encouraging acceptance of existing IT service/solution architecture in the organization." ;
    rdfs:label "Promote adoption of existing service/solution architecture" ;
    skos:definition "A Planned Act that encourages organizational acceptance of the existing IT service/solution architecture." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): a persuasion/change-management act. No informational output is definitional (the enterprise architecture specification it promotes is its input, not its product), so no has-output someValuesFrom is asserted (Phase-3)." ;
    skos:example "An architecture team runs brown-bag sessions to drive adoption of the reference architecture." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EnterpriseArchitectureSpecification ] .

ex:P20805 a owl:Class ;
    ex:pcfID "20805" ; ex:hierarchyID "8.5.3.6" ;
    ex:apqcSourceText "Creating and maintaining a services and solutions architecture over a network that can be revised as needed or even eliminated in case of inefficiencies." ;
    rdfs:label "Develop and maintain service/solution architectures" ;
    skos:definition "An Act of Design that creates and revises a services/solutions architecture and produces an enterprise architecture specification." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfFormulation to ex:ActOfDesign for consistency with its parent P20799 (also re-anchored), the build-a-design sibling 8.5.4.1.2 P20811, and the ex:ActOfDesign registry entry for 8.5.3. 'Creating ... a services and solutions architecture' is exactly the concept-stage authoring ex:ActOfDesign was minted for. ex:ActOfDesign is a subclass of cco:ont00000511 (Act of Planning), so Gates A-D are unaffected and the output ex:EnterpriseArchitectureSpecification stays Directive (GOLDEN PRINCIPLE). The 'develop' facet is dominant and bounded; ongoing maintenance/revision is realized by re-instances of this same act type." ;
    skos:example "An architect publishes and later revises the network service architecture." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnterpriseArchitectureSpecification ] .

ex:P20806 a owl:Class ;
    ex:pcfID "20806" ; ex:hierarchyID "8.5.3.7" ;
    ex:apqcSourceText "Assessing functional compliance of the IT service/solution architecture. Safeguard compliance with guidelines for the architecture." ;
    rdfs:label "Assess IT service/solution architecture conformance" ;
    skos:definition "An Act of Appraisal that evaluates the functional compliance of an IT service/solution architecture with its guidelines and produces an IT architecture conformance assessment." ;
    skos:example "A review confirms a solution conforms to the reference architecture except for two waivers." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EnterpriseArchitectureSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITArchitectureConformanceAssessment ] .

ex:P20807 a owl:Class ;
    ex:pcfID "20807" ; ex:hierarchyID "8.5.3.8" ;
    ex:apqcSourceText "Identifying and resolving any architectural exceptions. Address the internal inquiries related to architecture that cannot be addressed immediately. Research inquiries that require the need of exceptional methods." ;
    rdfs:label "Manage architectural exceptions" ;
    skos:definition "An Act of Formulation that identifies and resolves architectural exceptions and produces an IT architecture exception resolution." ;
    rdfs:comment "Modeled as a bounded resolution occurrent (identify-and-resolve), not as a standing function despite the 'Manage' label." ;
    skos:example "An architecture board issues a waiver resolving a non-standard integration request." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITArchitectureExceptionResolution ] .

ex:P20808 a owl:Class ;
    ex:pcfID "20808" ; ex:hierarchyID "8.5.4" ;
    ex:apqcSourceText "Understanding customer requirements. Design the IT services and solutions based on the requirements. Develop components for providing the requirements. Train resources to provide support. Test the IT services and solutions in advance. Confirm the customer experience post-sale." ;
    rdfs:label "Execute IT service/solution creation and testing" ;
    skos:definition "An Act of Development that designs, builds, and tests IT services and solutions from customer requirements and produces an IT service/solution." ;
    rdfs:comment "Operations category (8.0): the built IT service/solution is a material participant attached via obo:BFO_0000057 (has participant), not has output (reserved for ICEs)." ;
    skos:example "A delivery team designs, builds, and tests a new customer-facing service end to end." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITCustomerRequirements ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20809 ] .

ex:P20809 a owl:Class ;
    ex:pcfID "20809" ; ex:hierarchyID "8.5.4.1" ;
    ex:apqcSourceText "Executing an information system, aiming to produce a high quality system that meets or exceeds customer expectations, reaches completion within time and cost estimates, and is inexpensive to maintain and cost-effective to enhance." ;
    rdfs:label "Execute IT service/solution development lifecycle" ;
    skos:definition "An Act of Development that executes the full development lifecycle of an IT service/solution and produces an IT service/solution meeting customer expectations." ;
    rdfs:comment "Operations category: the built IT service/solution is a material participant (obo:BFO_0000057)." ;
    skos:example "A scrum team runs the SDLC from requirements to release for a new module." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITCustomerRequirements ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20810 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20811 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20812 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20813 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20814 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20815 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20816 ] .

ex:P20810 a owl:Class ;
    ex:pcfID "20810" ; ex:hierarchyID "8.5.4.1.1" ;
    ex:apqcSourceText "Evaluating and validating the requirements and needs of IT service/solution." ;
    rdfs:label "Assess and validate IT service/solution requirements" ;
    skos:definition "An Act of Verification that checks the requirements and needs of an IT service/solution and has as input IT customer requirements and as output an IT requirements analysis." ;
    skos:example "An analyst validates that captured requirements are complete and testable." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITCustomerRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20811 a owl:Class ;
    ex:pcfID "20811" ; ex:hierarchyID "8.5.4.1.2" ;
    ex:apqcSourceText "Formulating a design for service/solution that helps an organization to meet its objectives. Develop a new framework for molding the service/solution processes into a coherent and structured form." ;
    rdfs:label "Create service/solution design" ;
    skos:definition "An Act of Design that composes a coherent design for a service/solution and produces an IT solution design specification." ;
    skos:example "A solution architect produces the design specification for a new service." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSolutionDesignSpecification ] .

ex:P20812 a owl:Class ;
    ex:pcfID "20812" ; ex:hierarchyID "8.5.4.1.3" ;
    ex:apqcSourceText "Building and testing new components required for the development of IT services and solutions." ;
    rdfs:label "Build and test IT service/solution components" ;
    skos:definition "An Act of Development that builds and tests new IT service/solution components from a design specification, the built components participating as IT infrastructure components." ;
    rdfs:comment "Operations category: the built components are material entities (ex:ITInfrastructureComponent), attached via obo:BFO_0000057 (has participant), not has output (D4)." ;
    skos:example "Developers code and unit-test the modules called out in the design." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITSolutionDesignSpecification ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] .

ex:P20813 a owl:Class ;
    ex:pcfID "20813" ; ex:hierarchyID "8.5.4.1.4" ;
    ex:apqcSourceText "Combining the newly built IT component along with IT services in order to gain optimum output." ;
    rdfs:label "Integrate IT components and services" ;
    skos:definition "An Act of Development that combines newly built IT components with IT services to produce an integrated IT service/solution as material participant." ;
    rdfs:comment "Operations category: the IT infrastructure components consumed and the integrated IT service/solution are material participants (obo:BFO_0000057), not ICE outputs." ;
    skos:example "An integration engineer wires the new module into the existing service mesh." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] .

ex:P20814 a owl:Class ;
    ex:pcfID "20814" ; ex:hierarchyID "8.5.4.1.5" ;
    ex:apqcSourceText "Validating that the proposed IT service/solution is feasible and provides the needed services for the customer." ;
    rdfs:label "Execute IT service/solution validation" ;
    skos:definition "An Act of Verification that confirms an IT service/solution is feasible and meets customer needs and produces an IT solution validation result." ;
    rdfs:comment "Operations category: the validated IT service/solution is a material participant (obo:BFO_0000057); the validation result is the ICE output." ;
    skos:example "A test team runs acceptance tests and records the validation result." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSolutionValidationResult ] .

ex:P20815 a owl:Class ;
    ex:pcfID "20815" ; ex:hierarchyID "8.5.4.1.6" ;
    ex:apqcSourceText "Creating and implementing a strategy for the deployment of IT service/solution by defining all of the activities that make the IT function available for use. Define the deployment process, procedures, and tools. Select the most feasible and practical methodologies for the deployment process." ;
    rdfs:label "Bundle service/solution deployment packaging" ;
    skos:definition "An Act of Formulation that defines the deployment process, procedures, and tools for an IT service/solution and produces a deployment plan." ;
    rdfs:comment "Produces the deployment plan (directive); the actual release is ex:ActOfDeployment downstream and not part of this act. The packaged IT service/solution is a material participant (obo:BFO_0000057)." ;
    skos:example "A release manager packages the build and writes the deployment runbook." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DeploymentPlan ] .

ex:P20816 a owl:Class ;
    ex:pcfID "20816" ; ex:hierarchyID "8.5.4.1.7" ;
    ex:apqcSourceText "Identifying and resolving internal needs/inquiries for service/solution that cannot be resolved immediately. Research inquiries that require the need of exceptional solutions." ;
    rdfs:label "Manage service/solution process exceptions" ;
    skos:definition "An Act of Formulation that identifies and resolves internal service/solution process exceptions and produces an IT service/solution process exception resolution." ;
    rdfs:comment "Bounded identify-and-resolve occurrent, not a standing function despite the 'Manage' label." ;
    skos:example "A lead researches and resolves a blocking exception with a one-off workaround." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITIssueRequest ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITProcessExceptionResolution ] .

ex:P20817 a owl:Class ;
    ex:pcfID "20817" ; ex:hierarchyID "8.5.5" ;
    ex:apqcSourceText "Engaging in all aspects of service/solution maintenance and testing includes all preventative, routine, and corrective activates. Ensure that IT service/solution are functioning properly and regulations where applicable." ;
    rdfs:label "Perform service/solution maintenance and testing" ;
    skos:definition "A Planned Act of performing preventative, routine, and corrective maintenance and testing on IT services/solutions to keep them functioning properly." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act). Rejected cco:ont00000950 Act of Maintenance because its definition restricts the modified entity to a Material Artifact, whereas IT services/solutions are largely informational/configured systems; the IT service/solution acted upon is a material participant (obo:BFO_0000057)." ;
    skos:example "An operations team runs the quarterly maintenance and regression cycle for a service." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20818 ] .

ex:P20818 a owl:Class ;
    ex:pcfID "20818" ; ex:hierarchyID "8.5.5.1" ;
    ex:apqcSourceText "Executing IT service/solution maintenance lifecycle in order to reduce maintenance costs and increase reliability of IT infrastructure concerning service/solution related problems." ;
    rdfs:label "Execute IT service/solution maintenance lifecycle" ;
    skos:definition "A Planned Act that executes the maintenance lifecycle of an IT service/solution to reduce maintenance costs and increase reliability." ;
    skos:example "A run team executes the maintenance lifecycle for a production service." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20819 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20820 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20821 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20822 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20823 ] .

ex:P20819 a owl:Class ;
    ex:pcfID "20819" ; ex:hierarchyID "8.5.5.1.1" ;
    ex:apqcSourceText "Evaluate plans to address information technology environmental adulteration for rectification efforts." ;
    rdfs:label "Assess IT remediation" ;
    skos:definition "An Act of Appraisal that evaluates plans to remediate degradation of the IT environment and produces an IT deployment impact assessment." ;
    skos:example "An engineer appraises remediation options for a failing component." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RemediationPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITDeploymentImpactAssessment ] .

ex:P20820 a owl:Class ;
    ex:pcfID "20820" ; ex:hierarchyID "8.5.5.1.2" ;
    ex:apqcSourceText "Redesign the roadmap to seek solution or service with an overall process flow and impact timeframe." ;
    rdfs:label "Modify service/solution design" ;
    skos:definition "An Act of Design that revises the design of a service/solution and produces a revised IT solution design specification." ;
    skos:example "An architect updates the solution design to address a defect's root cause." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITSolutionDesignSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSolutionDesignSpecification ] .

ex:P20821 a owl:Class ;
    ex:pcfID "20821" ; ex:hierarchyID "8.5.5.1.3" ;
    ex:apqcSourceText "Administering the efforts and activities for IT service/solution remediation. This process element requires the organization to create plans for corrective action in collaboration with government agencies and pertinent professional services agencies which specialize in remediation efforts relevant to the organization's service/solution. Additionally, the organization needs to consult experts to validate the plan, determine resources allocation, resolve any legal concerns, and formulate a company-wide policy for IT service/solution remediation." ;
    rdfs:label "Perform IT service/solution remediation" ;
    skos:definition "An Act of Service Provision that administers and carries out the remediation of an IT service/solution, guided by a remediation plan and acting on the IT service/solution being remediated." ;
    rdfs:comment "Gate-F fix: re-anchored from ex:ActOfFormulation to ex:ActOfServiceProvision (cco:ont00000228) -- the row's lead/verb ('Administering the efforts and activities for IT service/solution remediation') is an execution/operations act performed ON the IT service, not mere plan-authoring, and the prior model collapsed it to plan-formulation, dropping the execution facet and the material thing acted upon. Added the operated-on IT service/solution as a material participant (obo:BFO_0000057 some ex:ITServiceSolution), matching the participant pattern of the sibling operations act 8.5.5.1.4 P20822 'Manage service/solution operations'. ex:RemediationPlan is retained as the directive INPUT that guides the remediation (it is authored upstream at the formulation/triage rows); the corrective-action-plan authoring described in the body is the input-producing step, not this execution act's product." ;
    skos:example "A remediation lead executes the corrective actions on the affected service per the remediation plan, with external specialists." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RemediationPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] .

ex:P20822 a owl:Class ;
    ex:pcfID "20822" ; ex:hierarchyID "8.5.5.1.4" ;
    ex:apqcSourceText "Understanding customer requirements. Managing services/solutions based on the requirements. Develop components for providing the requirements. Train resources to provide support. Confirm the customer experience post-sale. Evaluate the performance of service/solution. Communicate the results to the management." ;
    rdfs:label "Manage service/solution operations" ;
    skos:definition "An Act of Service Provision that operates an IT service/solution per customer requirements and produces an IT performance report." ;
    rdfs:comment "Operations occurrent; the service/solution is operated (material participant) and performance is reported (descriptive output)." ;
    skos:example "An operations team runs a live service and reports its performance to management." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITCustomerRequirements ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20823 a owl:Class ;
    ex:pcfID "20823" ; ex:hierarchyID "8.5.5.1.5" ;
    ex:apqcSourceText "Developing packaging for fixed/enhanced service/solution based on the standalone or bundled offerings to be used by the organization." ;
    rdfs:label "Prepare fixed/enhanced service/solution packaging" ;
    skos:definition "An Act of Formulation that develops deployment packaging for a fixed or enhanced service/solution and produces a deployment plan." ;
    rdfs:comment "The packaged IT service/solution is a material participant (obo:BFO_0000057); the deployment plan is the ICE output." ;
    skos:example "A release manager packages a patched service as a standalone deployable unit." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DeploymentPlan ] .

# ================================================================
# GROUP 8.6  Deploy services/solutions
# ================================================================

ex:P20824 a owl:Class ;
    ex:pcfID "20824" ; ex:hierarchyID "8.6" ;
    ex:apqcSourceText "Executing IT services/solutions by creating a strategy for deployment. Plan and execute the changes. Plan and administer the release of its IT services and solutions." ;
    rdfs:label "Deploy services/solutions" ;
    skos:definition "An Act of Deployment that puts an organization's IT services and solutions into operational use, comprising the formulation of a deployment strategy, the planning of implementation, the control of change deployment, the implementation of technology solutions, and the rollout to end users." ;
    rdfs:comment "Models APQC process group 8.6 as a bounded occurrent. Its APQC children are process parts, not subclasses." ;
    skos:example "An IT organization's end-to-end release of a new ERP module: strategy, plan, change control, install, and user rollout." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20825 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20832 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20840 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20848 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20858 ] .

ex:P20825 a owl:Class ;
    ex:pcfID "20825" ; ex:hierarchyID "8.6.1" ;
    ex:apqcSourceText "Creating and implementing a strategy for the deployment of IT service/solution. Define all of the activities that make the IT function available for use. Establish the change policies for IT services and solutions. Define the deployment process, procedures, and tools. Select the most feasible and practical methodologies for the deployment process." ;
    rdfs:label "Develop and manage service/solution deployment strategy" ;
    skos:definition "An Act of Formulation that composes a deployment strategy prescribing the activities, change policies, procedures, tools, and methodologies by which an organization's IT services and solutions are made available for use." ;
    rdfs:comment "Lead act is the bounded formulation of a deployment strategy (a Directive ICE); the standing 'manage' facet of APQC 8.6.1 is realized by ex:ITServiceManagementCapability and is not part of this process universal." ;
    skos:example "An IT release-management team drafts the organization's deployment strategy and change policy set." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DeploymentPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20826 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20827 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20828 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20829 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20830 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20831 ] .

ex:P20826 a owl:Class ;
    ex:pcfID "20826" ; ex:hierarchyID "8.6.1.1" ;
    ex:apqcSourceText "Evaluate the impact of IT deployment (products/services) on the business. Compare pre and post development performance, behavior of resources, and cost to assess organizational benefit." ;
    rdfs:label "Assess IT deployment business impact" ;
    skos:definition "An Act of Appraisal that compares pre- and post-deployment performance, resource behavior, and cost and produces an IT deployment impact assessment of the organizational benefit." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the act evaluates and judges deployment impact, yielding a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "An analyst compares help-desk volumes before and after a rollout to quantify the deployment's business benefit." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITDeploymentImpactAssessment ] .

ex:P20827 a owl:Class ;
    ex:pcfID "20827" ; ex:hierarchyID "8.6.1.2" ;
    ex:apqcSourceText "Defining deployment policies regarding IT services and solutions to allow employees to plan accordingly. Reduce the negative impact to the user community." ;
    rdfs:label "Establish IT deployment policies" ;
    skos:definition "An Act of Formulation that composes IT deployment policies prescribing how IT services and solutions are deployed so as to reduce negative impact on the user community." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): defining a policy yields a Directive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "An IT governance board issues a deployment-blackout policy for month-end periods." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPolicy ] .

ex:P20828 a owl:Class ;
    ex:pcfID "20828" ; ex:hierarchyID "8.6.1.3" ;
    ex:apqcSourceText "Outlining processes, methods, and equipment for deployment of IT solutions. Manage core operations servers like subversion server, production server, and development server, to make the IT services and solutions available for internal/client use." ;
    rdfs:label "Define and create deployment procedure workflow" ;
    skos:definition "An Act of Design that outlines the processes, methods, and equipment for deploying IT solutions and produces a deployment design specification of the procedure workflow." ;
    rdfs:comment "Anchored to ex:ActOfDesign (Act of Planning): designing a workflow yields a Directive design spec (GOLDEN PRINCIPLE). The 'manage core servers' facet is operational and not part of this design universal." ;
    skos:example "A release engineer designs the build->staging->production promotion workflow and tooling chain." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSolutionDesignSpecification ] .

ex:P20829 a owl:Class ;
    ex:pcfID "20829" ; ex:hierarchyID "8.6.1.4" ;
    ex:apqcSourceText "Establishing guidelines for the changed/released IT services and solutions to meet business objectives with optimum utilization." ;
    rdfs:label "Define IT change/release standards" ;
    skos:definition "An Act of Formulation that composes IT change/release standards prescribing guidelines for changed or released IT services and solutions to meet business objectives with optimum utilization." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: defining a standard yields a Directive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A change-advisory board sets the naming, versioning, and rollback-readiness standards for releases." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStandard ] .

ex:P20830 a owl:Class ;
    ex:pcfID "20830" ; ex:hierarchyID "8.6.1.5" ;
    ex:apqcSourceText "Coordinating development approval responsibilities based on defined change standards." ;
    rdfs:label "Assign deployment approval responsibilities" ;
    skos:definition "An Act of Planning that coordinates and assigns deployment-approval responsibilities on the basis of defined change standards and produces a directive assignment of those responsibilities." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): allocating responsibilities yields a Directive ICE. Has the change standards (a Directive ICE) as a typical input; left as comment, not a restriction, per Phase-3 necessity." ;
    skos:example "A release manager assigns each environment's go-live sign-off owner per the change standard." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DeploymentApprovalAssignment ] .

ex:P20831 a owl:Class ;
    ex:pcfID "20831" ; ex:hierarchyID "8.6.1.6" ;
    ex:apqcSourceText "Evaluating the impact (pros and cons) of IT services deployment." ;
    rdfs:label "Analyze deployments outcomes" ;
    skos:definition "An Act of Analysis that examines the pros and cons of IT services deployment and produces an IT deployment impact assessment of the outcomes." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (Act of Information Processing): examining outcomes yields a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A post-implementation review tallies the benefits and drawbacks of a completed rollout." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITDeploymentImpactAssessment ] .

ex:P20832 a owl:Class ;
    ex:pcfID "20832" ; ex:hierarchyID "8.6.2" ;
    ex:apqcSourceText "Strategizing and executing changes in IT solutions and services. Create a plan for deploying the changes. Communicate with stakeholders about the changes. Administer and implement the changes. Train the resources who will be affected by these changes. Install changes and verify their effect." ;
    rdfs:label "Plan service and solution implementation" ;
    skos:definition "An Act of Formulation that composes a plan for deploying changes to IT services and solutions, prescribing the schedule, requirements, testing, training, and communications for implementation." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the lead act of 8.6.2 is creating a deployment/implementation plan (a Directive ICE). Its execution-oriented facets are realized by sibling implementation/rollout processes." ;
    skos:example "An implementation team builds the rollout plan, schedule, and training approach for a system upgrade." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DeploymentPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20833 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20834 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20835 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20836 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20837 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20838 ] .

ex:P20833 a owl:Class ;
    ex:pcfID "20833" ; ex:hierarchyID "8.6.2.1" ;
    ex:apqcSourceText "Accessing threats and potential failures related to the deployment of IT services/solutions." ;
    rdfs:label "Assess IT deployment risk" ;
    skos:definition "An Act of Appraisal that evaluates the threats and potential failures related to the deployment of IT services and solutions and produces an IT risk assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): judging deployment risk yields a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A risk analyst rates the failure modes of a database migration before approving its plan." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskAssessment ] .

ex:P20834 a owl:Class ;
    ex:pcfID "20834" ; ex:hierarchyID "8.6.2.2" ;
    ex:apqcSourceText "Defining the schedule for implementation of change. Plan and carry out a process or procedure to implement the predefined changes." ;
    rdfs:label "Define implementation schedule and roll-out sequence" ;
    skos:definition "An Act of Scheduling that defines the schedule and roll-out sequence for implementing predefined changes and produces a resource schedule." ;
    rdfs:comment "Anchored to ex:ActOfScheduling (Act of Planning): defining a schedule/sequence yields a Directive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A release manager sequences the wave-by-wave rollout calendar across regions." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResourceSchedule ] .

ex:P20835 a owl:Class ;
    ex:pcfID "20835" ; ex:hierarchyID "8.6.2.3" ;
    ex:apqcSourceText "Determine requirements for implementation of IT deployment. Carry out a pre-implementation audit to assess the impact and use case. Gauge the possible vulnerabilities and impact the business operations during and after the implementation." ;
    rdfs:label "Determine implementation requirements" ;
    skos:definition "An Act of Analysis that carries out a pre-implementation audit of impact, use cases, and vulnerabilities and produces an IT requirements analysis of the implementation requirements." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (Act of Information Processing): a pre-implementation audit examining impact yields a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "An analyst audits a target environment and lists the prerequisites and vulnerabilities for go-live." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20836 a owl:Class ;
    ex:pcfID "20836" ; ex:hierarchyID "8.6.2.4" ;
    ex:apqcSourceText "Plan methodologies and align resources for user testing of IT deployment." ;
    rdfs:label "Plan and align user testing and resources" ;
    skos:definition "An Act of Formulation that plans the methodologies and aligns the resources for user testing of an IT deployment and produces a directive user-testing plan." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): planning test methodologies and resource alignment yields a Directive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A QA lead plans the UAT cycles and assigns testers and environments." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:UserTestingPlan ] .

ex:P20837 a owl:Class ;
    ex:pcfID "20837" ; ex:hierarchyID "8.6.2.5" ;
    ex:apqcSourceText "Create and manage employee training programs by considering the need and availability of these programs. Manage all aspects related to the training programs." ;
    rdfs:label "Develop IT training" ;
    skos:definition "An Act of Development that creates an employee IT training program, considering the need for and availability of such programs, and produces an IT training program." ;
    rdfs:comment "Anchored to ex:ActOfDevelopment (Planned Act): the lead act creates a training program (a Directive ICE) (GOLDEN PRINCIPLE). The standing 'manage all aspects' facet is realized by ex:ITServiceManagementCapability, not modeled here." ;
    skos:example "An L&D team builds the courseware and schedule for training users on a new ticketing tool." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITTrainingProgram ] .

ex:P20838 a owl:Class ;
    ex:pcfID "20838" ; ex:hierarchyID "8.6.2.6" ;
    ex:apqcSourceText "Coordinating change implementation in IT services and solutions communications with employees and stakeholders." ;
    rdfs:label "Create implementation communications" ;
    skos:definition "An Act of Communication that coordinates and transfers communications about IT change implementation to employees and stakeholders, producing an IT deployment communication." ;
    rdfs:comment "Anchored to the shared ex:ActOfCommunication (wraps the D6-VERIFIED cco:ont00000402 'Act of Communication'; verification recorded in the §6 record at the ex:ActOfCommunication declaration). Gate-F consistency: re-anchored from the per-class raw IRI + redundant cco:ont00000228 co-anchor to the shared genus, which supplies the chain to the allowlisted Planned Act for the SHACL S2 graph. Has-output ex:ITDeploymentCommunication (the prepared/transferred deployment notice)." ;
    skos:example "A change manager drafts and sends the go-live notice and FAQ to affected departments." ;
    rdfs:subClassOf ex:ActOfCommunication ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITDeploymentCommunication ] .

ex:P20840 a owl:Class ;
    ex:pcfID "20840" ; ex:hierarchyID "8.6.3" ;
    ex:apqcSourceText "Creating and deploying an architecture for securing the changes deployed in the organization. Create and develop protocols that ensure proper and efficient use of deployed IT services and solutions. Test, evaluate, and implement the policies and protocols." ;
    rdfs:label "Manage change deployment control" ;
    skos:definition "A Planned Act that runs a per-release change-control gate -- creating and deploying the securing architecture, developing and testing the policies and protocols, and appraising, confirming, approving, and documenting the change -- and produces an IT change-control record." ;
    rdfs:comment "Gate-F fix (genus false-friend): re-anchored from ex:ActOfMonitoring to the generic cco:ont00000228 (Planned Act). REJECTED ex:ActOfMonitoring, whose definition is repeated/continuous longitudinal observation of an ongoing process; the source ('Creating and deploying an architecture for securing the changes ... Create and develop protocols ... Test, evaluate, and implement the policies and protocols') and the seven process-part children form a BOUNDED per-release control gate (appraise->confirm->approve->document) culminating in an approval decision -- design/formulation plus appraisal/verification, not continuous observation; the 'control' label was a false-friend for 'monitoring'. ex:ActOfMonitoring is reserved for the genuinely longitudinal sibling 8.6.5.7 P20865. R5: although titled 'Manage', each change/release cycle is a bounded control occurrent, so it is modeled as a process. Gate-F fix (output mismatch): output filler corrected from ex:ITServiceSupportRecord (a help-desk incident/request disposition record, 8.7.8) to the dedicated ex:ITChangeControlRecord, matching the skos:definition's 'IT change-control record'." ;
    skos:example "A change-advisory board runs its control gate for a release, recording impact, compliance, and the approval decision." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITChangeControlRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20841 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20842 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20843 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20844 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20845 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20846 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20847 ] .

ex:P20841 a owl:Class ;
    ex:pcfID "20841" ; ex:hierarchyID "8.6.3.1" ;
    ex:apqcSourceText "Evaluating the impact of IT change/release on the business." ;
    rdfs:label "Asses IT change/release impact" ;
    skos:definition "An Act of Appraisal that evaluates the impact of an IT change or release on the business and produces an IT deployment impact assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): judging change/release impact yields a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A reviewer scores the blast radius of a proposed configuration change." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITDeploymentImpactAssessment ] .

ex:P20842 a owl:Class ;
    ex:pcfID "20842" ; ex:hierarchyID "8.6.3.2" ;
    ex:apqcSourceText "Ensure that change/release meets change guidelines set by the organization." ;
    rdfs:label "Confirm change/release compliance" ;
    skos:definition "An Act of Verification that checks an IT change or release against the organization's change guidelines and produces an IT compliance audit report." ;
    rdfs:comment "Anchored to ex:ActOfVerification (Act of Appraisal): confirming conformance to guidelines yields a Descriptive ICE (GOLDEN PRINCIPLE). Has the change guidelines (a Directive ICE) as a typical input; left as comment per Phase-3 necessity." ;
    skos:example "A compliance officer confirms a release followed the mandated approval and testing gates." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITComplianceAuditReport ] .

ex:P20843 a owl:Class ;
    ex:pcfID "20843" ; ex:hierarchyID "8.6.3.3" ;
    ex:apqcSourceText "Evaluating for any kind of risks or threats which could be caused due to IT change/release deployment." ;
    rdfs:label "Assess IT change/release risk" ;
    skos:definition "An Act of Appraisal that evaluates the risks and threats arising from an IT change or release deployment and produces an IT risk assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): judging change/release risk yields a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A security reviewer assesses the threats introduced by a firewall-rule release." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRiskAssessment ] .

ex:P20844 a owl:Class ;
    ex:pcfID "20844" ; ex:hierarchyID "8.6.3.4" ;
    ex:apqcSourceText "Integrate all forms of changes in IT in order to make more efficient use of resources and down time, and optimizing results." ;
    rdfs:label "Consolidate IT change" ;
    skos:definition "An Act of Development that integrates all forms of IT change into a consolidated change to the IT service/solution so as to use resources and downtime more efficiently." ;
    rdfs:comment "Anchored to ex:ActOfDevelopment (Planned Act). Operations category: the consolidated IT service/solution is a material participant (obo:BFO_0000057), not has output (D4)." ;
    skos:example "A release engineer batches several pending patches into a single maintenance window." ;
    rdfs:subClassOf ex:ActOfDevelopment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] .

ex:P20845 a owl:Class ;
    ex:pcfID "20845" ; ex:hierarchyID "8.6.3.5" ;
    ex:apqcSourceText "Defining and communicating the schedule for implementation to related stakeholders and functions." ;
    rdfs:label "Create and communicate deployment schedule" ;
    skos:definition "An Act of Scheduling that defines the implementation schedule and communicates it to related stakeholders and functions, producing a resource schedule." ;
    rdfs:comment "Anchored to ex:ActOfScheduling (Act of Planning): defining a schedule yields a Directive ICE (GOLDEN PRINCIPLE); the communicate facet is a typical follow-on, left as comment per Phase-3 necessity." ;
    skos:example "A release manager publishes the deployment calendar to operations and business owners." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResourceSchedule ] .

ex:P20846 a owl:Class ;
    ex:pcfID "20846" ; ex:hierarchyID "8.6.3.6" ;
    ex:apqcSourceText "Permitting for the change/release deployment. Approve deployment based on the evaluation of business impact due to change/release." ;
    rdfs:label "Approve change/release deployment" ;
    skos:definition "A Planned Act that permits a change or release deployment on the basis of its evaluated business impact and produces a change/release deployment approval." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): ratifying a single already-evaluated deployment is not a selection over a candidate set (per ex:ActOfSelection scope note), so it anchors at the generic Planned Act; its output is a Directive approval decision. Has the impact assessment (Descriptive ICE) as a typical input; left as comment per Phase-3 necessity." ;
    skos:example "A change manager signs off the production go-live after reviewing the impact assessment." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeReleaseApproval ] .

ex:P20847 a owl:Class ;
    ex:pcfID "20847" ; ex:hierarchyID "8.6.3.7" ;
    ex:apqcSourceText "Recording outcomes related to the change/release deployment." ;
    rdfs:label "Document IT change/release outcome" ;
    skos:definition "An Act of Data Management that records the outcomes of a change or release deployment and produces an IT change-control record." ;
    rdfs:comment "Anchored to ex:ActOfDataManagement (Act of Information Processing): recording outcomes stores a Descriptive ICE (GOLDEN PRINCIPLE). Gate-F fix (output mismatch): output filler corrected from ex:ITServiceSupportRecord (scoped to 8.7.8 incident/request resolution) to the dedicated ex:ITChangeControlRecord for change/release outcome documentation, matching the source ('Recording outcomes related to the change/release deployment')." ;
    skos:example "A release engineer files the post-deployment record with results and incidents." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITChangeControlRecord ] .

ex:P20848 a owl:Class ;
    ex:pcfID "20848" ; ex:hierarchyID "8.6.4" ;
    ex:apqcSourceText "Deploy the identified solutions for information technology important for healthy business operations. Confirm status and operational availability of IT resources. Perform testing and distribution of change. Execute roll-back protocol if necessary." ;
    rdfs:label "Implement technology solutions" ;
    skos:definition "An Act of Deployment that puts identified IT solutions into operational use, confirming their status and availability, distributing and testing changes, and rolling back where necessary." ;
    rdfs:comment "Anchored to ex:ActOfDeployment. Operations category: the IT service/solution is a material participant (obo:BFO_0000057), not has output (D4)." ;
    skos:example "An operations team installs and validates a new service across the production estate." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20849 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20850 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20851 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20852 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20853 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20854 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20855 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20856 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20857 ] .

ex:P20849 a owl:Class ;
    ex:pcfID "20849" ; ex:hierarchyID "8.6.4.1" ;
    ex:apqcSourceText "Confirm if hardware/software are operating as per the expectation." ;
    rdfs:label "Confirm hardware/software operational status" ;
    skos:definition "An Act of Verification that checks whether deployed hardware and software are operating as expected and produces an IT solution validation result." ;
    rdfs:comment "Anchored to ex:ActOfVerification (Act of Appraisal): confirming operating status yields a Descriptive ICE (GOLDEN PRINCIPLE). The hardware/software is a typical Material Entity subject; left as comment per Phase-3 necessity." ;
    skos:example "An engineer checks that the new server cluster is healthy after install." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSolutionValidationResult ] .

ex:P20850 a owl:Class ;
    ex:pcfID "20850" ; ex:hierarchyID "8.6.4.2" ;
    ex:apqcSourceText "Confirm if operational activities of IT services could be performed." ;
    rdfs:label "Confirm operational availability" ;
    skos:definition "An Act of Verification that checks whether the operational activities of deployed IT services can be performed and produces an IT solution validation result." ;
    rdfs:comment "Anchored to ex:ActOfVerification (Act of Appraisal): confirming availability yields a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A team runs smoke tests to confirm core transactions succeed post-deployment." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSolutionValidationResult ] .

ex:P20851 a owl:Class ;
    ex:pcfID "20851" ; ex:hierarchyID "8.6.4.3" ;
    ex:apqcSourceText "Executing IT implementation plan to make the IT services and solutions available for internal use." ;
    rdfs:label "Execute internal IT implementation plan" ;
    skos:definition "An Act of Deployment that executes the IT implementation plan to make IT services and solutions available for internal use." ;
    rdfs:comment "Anchored to ex:ActOfDeployment. Consumes the deployment plan (Directive ICE) as a definitional input; the resulting IT service/solution is a material participant (obo:BFO_0000057)." ;
    skos:example "An operations team runs the documented cutover to enable a service for staff." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DeploymentPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] .

ex:P20852 a owl:Class ;
    ex:pcfID "20852" ; ex:hierarchyID "8.6.4.4" ;
    ex:apqcSourceText "Confirming the completion of IT implementation." ;
    rdfs:label "Confirm implementation completion" ;
    skos:definition "An Act of Verification that confirms the completion of an IT implementation and produces an IT solution validation result." ;
    rdfs:comment "Anchored to ex:ActOfVerification (Act of Appraisal): confirming completion yields a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A project lead signs off that all implementation tasks are complete." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSolutionValidationResult ] .

ex:P20853 a owl:Class ;
    ex:pcfID "20853" ; ex:hierarchyID "8.6.4.5" ;
    ex:apqcSourceText "Executing changes in software and services as per change/release schedule." ;
    rdfs:label "Implement software change/release" ;
    skos:definition "An Act of Deployment that executes changes to software and services according to the change/release schedule, modifying the IT service/solution." ;
    rdfs:comment "Anchored to ex:ActOfDeployment. Consumes the release schedule (Directive ICE) as a definitional input; the IT service/solution is a material participant (obo:BFO_0000057)." ;
    skos:example "A deployment pipeline applies the scheduled release to production." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ResourceSchedule ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] .

ex:P20854 a owl:Class ;
    ex:pcfID "20854" ; ex:hierarchyID "8.6.4.6" ;
    ex:apqcSourceText "Perform testing after installation to confirm expected performance is met." ;
    rdfs:label "Perform post-installation testing" ;
    skos:definition "An Act of Verification that tests an installed IT solution to confirm that expected performance is met and produces an IT solution validation result." ;
    rdfs:comment "Anchored to ex:ActOfVerification (Act of Appraisal): testing to confirm performance yields a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A QA engineer runs the post-install performance suite against the new build." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSolutionValidationResult ] .

ex:P20855 a owl:Class ;
    ex:pcfID "20855" ; ex:hierarchyID "8.6.4.7" ;
    ex:apqcSourceText "Distributing and implementing the release of changed IT solutions. Administer, implement, and install the releases onto internal systems. Provide methods for installing releases on client users." ;
    rdfs:label "Distribute software components network-wide" ;
    skos:definition "An Act of Deployment that distributes and installs the release of changed IT solutions onto internal systems and client users across the network, updating the IT service/solution." ;
    rdfs:comment "Anchored to ex:ActOfDeployment. Operations category: the distributed IT service/solution is a material participant (obo:BFO_0000057)." ;
    skos:example "A configuration manager pushes the new client package to every workstation." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] .

ex:P20856 a owl:Class ;
    ex:pcfID "20856" ; ex:hierarchyID "8.6.4.8" ;
    ex:apqcSourceText "Confirming that the release has met expectations." ;
    rdfs:label "Verify change/release implementation success" ;
    skos:definition "An Act of Verification that confirms a change or release has met expectations and produces an IT solution validation result." ;
    rdfs:comment "Anchored to ex:ActOfVerification (Act of Appraisal): confirming success yields a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A release owner verifies success criteria against the deployment's acceptance tests." ;
    rdfs:subClassOf ex:ActOfVerification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSolutionValidationResult ] .

ex:P20857 a owl:Class ;
    ex:pcfID "20857" ; ex:hierarchyID "8.6.4.9" ;
    ex:apqcSourceText "Execution of plan to return to the previous operating state if the change/release impedes operational expectations." ;
    rdfs:label "Execute roll-back plan" ;
    skos:definition "An Act of Deployment that executes a roll-back plan to return the environment to its previous operating state when a change or release impedes operational expectations." ;
    rdfs:comment "Anchored to ex:ActOfDeployment. Consumes a remediation (roll-back) plan (Directive ICE) as a definitional input; restores the IT service/solution (material participant, obo:BFO_0000057)." ;
    skos:example "An operator reverts the production deployment after a failed go-live." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RemediationPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] .

ex:P20858 a owl:Class ;
    ex:pcfID "20858" ; ex:hierarchyID "8.6.5" ;
    ex:apqcSourceText "Strategizing and executing changes in IT solutions and services. Create a plan for deploying the changes. Communicate with stakeholders about the changes. Administer and implement the changes. Train the resources who will be affected by these changes. Install changes and verify their effect." ;
    rdfs:label "Perform service and solution rollout" ;
    skos:definition "An Act of Deployment that rolls out IT services and solutions to the organization's end-user base, training users, communicating changes, executing the rollout, and monitoring issues." ;
    rdfs:comment "Anchored to ex:ActOfDeployment. Operations category: the rolled-out IT service/solution is a material participant (obo:BFO_0000057)." ;
    skos:example "An IT team rolls a new collaboration suite out to all staff with training and support." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20859 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20860 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20862 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20865 ] .

ex:P20859 a owl:Class ;
    ex:pcfID "20859" ; ex:hierarchyID "8.6.5.1" ;
    ex:apqcSourceText "Preparing users for changes in IT solutions. Conduct training sessions and engagement activities to familiarize users with the new changes. Implementing the programs for training IT employees." ;
    rdfs:label "Conduct IT training" ;
    skos:definition "An Act of Training in which knowledge of new IT solutions is imparted to users through training sessions and engagement activities to familiarize them with the changes." ;
    rdfs:comment "Reuse cco:ont00000234 (Act of Training): 'A Planned Act in which knowledge, skills or values are imparted from one or more Agents to at least one other Agent' fits conducting user training exactly (D5)." ;
    skos:example "An L&D team runs hands-on sessions for staff on the newly deployed HR portal." ;
    rdfs:subClassOf cco:ont00000234 ,
        cco:ont00000228 ,   # Planned Act -- explicit allowlist anchor (Act of Training is a Planned Act in CCO; asserted here so the standalone SHACL subclass chain resolves)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITTrainingProgram ] .

ex:P20860 a owl:Class ;
    ex:pcfID "20860" ; ex:hierarchyID "8.6.5.2" ;
    ex:apqcSourceText "Coordinating communications regarding the changes in IT services and solutions with employees in the organization." ;
    rdfs:label "Prepare and distribute service/solution communications" ;
    skos:definition "An Act of Communication that prepares and transfers communications regarding changes in IT services and solutions to employees in the organization, producing an IT deployment communication." ;
    rdfs:comment "Anchored to the shared ex:ActOfCommunication (wraps the D6-VERIFIED cco:ont00000402 'Act of Communication'; verification recorded in the §6 record at the ex:ActOfCommunication declaration). Gate-F consistency: re-anchored from the per-class raw IRI + redundant cco:ont00000228 co-anchor to the shared genus, which supplies the chain to the allowlisted Planned Act for the SHACL S2 graph. Has-output ex:ITDeploymentCommunication." ;
    skos:example "A communications lead emails the rollout schedule and what-changes summary to all staff." ;
    rdfs:subClassOf ex:ActOfCommunication ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITDeploymentCommunication ] .

ex:P20862 a owl:Class ;
    ex:pcfID "20862" ; ex:hierarchyID "8.6.5.4" ;
    ex:apqcSourceText "Executing a plan for introducing the IT services and solutions to the organization's end user base." ;
    rdfs:label "Execute rollout plans" ;
    skos:definition "An Act of Deployment that executes a plan for introducing IT services and solutions to the organization's end-user base." ;
    rdfs:comment "Anchored to ex:ActOfDeployment. Consumes the rollout/deployment plan (Directive ICE) as a definitional input; the IT service/solution made available is a material participant (obo:BFO_0000057)." ;
    skos:example "An IT team enables the new service for successive user cohorts per the rollout plan." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DeploymentPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITServiceSolution ] .

ex:P20865 a owl:Class ;
    ex:pcfID "20865" ; ex:hierarchyID "8.6.5.7" ;
    ex:apqcSourceText "Track and record any issues being faced due to rollout. Define methodology of assessment for measuring and monitoring issues." ;
    rdfs:label "Monitor and record rollout issues" ;
    skos:definition "An Act of Monitoring that tracks and records the issues encountered during a rollout and produces IT issue/request records." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring (Act of Information Processing): tracking and recording issues yields a Descriptive ICE (GOLDEN PRINCIPLE)." ;
    skos:example "A support lead logs and trends the tickets raised in the first week after rollout." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITIssueRequest ] .

# ================================================================
# GROUP 8.7  Create and manage support services/solutions
# (group node 8.7 [PCF 20866], 8.7.7 [PCF 20914], 8.7.5.7 [PCF 20901]
#  are Organization Capabilities declared in the group-capability
#  section above.)
# ================================================================

ex:P20867 a owl:Class ;
    ex:pcfID "20867" ; ex:hierarchyID "8.7.1" ;
    ex:apqcSourceText "Defining and establishing strategy for delivering IT services and solutions to the users. Design an IT service delivery model that defines the processes and procedures needed to deliver the IT services and solutions." ;
    rdfs:label "Define and establish service delivery strategy" ;
    skos:definition "An Act of Formulation that has as input business objectives and has as output an IT strategy prescribing how IT services and solutions are delivered to users." ;
    rdfs:comment "Formulation (Directive output) because it composes a delivery strategy, a prescriptive course of action." ;
    skos:example "An IT leadership team articulates a multi-year service-delivery strategy and delivery model." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20868 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20869 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20870 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20871 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20872 ] .

ex:P20868 a owl:Class ;
    ex:pcfID "20868" ; ex:hierarchyID "8.7.1.1" ;
    ex:apqcSourceText "Assessing the goals and objectives of IT service delivery and how it contributes to the overall business objectives. Align with the business objectives of the organization." ;
    rdfs:label "Assess business objectives and IT service delivery" ;
    skos:definition "An Act of Appraisal that has as input business objectives and has as output an IT value contribution assessment judging how IT service delivery contributes to overall business objectives." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it evaluates/judges contribution, yielding a Descriptive ICE." ;
    skos:example "An analyst appraises how the service-delivery roadmap supports corporate objectives." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITValueContributionAssessment ] .

ex:P20869 a owl:Class ;
    ex:pcfID "20869" ; ex:hierarchyID "8.7.1.2" ;
    ex:apqcSourceText "Creating and establishing a repository of IT service delivery offerings." ;
    rdfs:label "Define IT service delivery portfolio" ;
    skos:definition "An Act of Formulation that has as output an IT portfolio plan establishing a repository of IT service delivery offerings." ;
    rdfs:comment "Formulation (Directive output): the portfolio prescribes the catalog of offerings the organization commits to deliver." ;
    skos:example "A service manager compiles the catalog of IT service-delivery offerings into a delivery portfolio." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPortfolioPlan ] .

ex:P20870 a owl:Class ;
    ex:pcfID "20870" ; ex:hierarchyID "8.7.1.3" ;
    ex:apqcSourceText "Design and maintaining an IT service delivery model that defines the processes and procedures needed to deliver the IT services and solutions." ;
    rdfs:label "Create and maintain IT service delivery model" ;
    skos:definition "An Act of Design that has as output an IT service management plan defining the processes and procedures needed to deliver IT services and solutions." ;
    rdfs:comment "Design (Directive output): the delivery model is a prescriptive specification of delivery processes and procedures." ;
    skos:example "An architect drafts and revises the IT service-delivery operating model." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceManagementPlan ] .

ex:P20871 a owl:Class ;
    ex:pcfID "20871" ; ex:hierarchyID "8.7.1.4" ;
    ex:apqcSourceText "Determining locations and types of IT services and solutions which need to be delivered." ;
    rdfs:label "Determine IT service delivery locations and activities" ;
    skos:definition "An Act of Analysis that has as input IT landscape data and has as output an IT requirements analysis identifying the locations and types of IT services and solutions to be delivered." ;
    rdfs:comment "Analysis (Descriptive output): it discerns and represents where and what is delivered rather than prescribing a plan." ;
    skos:example "A team maps which sites require on-premise versus cloud delivery." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITLandscapeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20872 a owl:Class ;
    ex:pcfID "20872" ; ex:hierarchyID "8.7.1.5" ;
    ex:apqcSourceText "Defining a strategy for sourcing delivery of IT services and solutions. Examine the pros and cons of various sources that can support the delivery process. Select the most feasible and cost-effective sources." ;
    rdfs:label "Define IT service delivery sourcing strategy" ;
    skos:definition "An Act of Formulation that has as output an IT strategy prescribing the sources to be used for delivering IT services and solutions." ;
    rdfs:comment "Formulation (Directive output): examining and selecting sources culminates in a prescriptive sourcing strategy." ;
    skos:example "A sourcing lead weighs in-house versus vendor options and commits to a sourcing strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategy ] .

ex:P20873 a owl:Class ;
    ex:pcfID "20873" ; ex:hierarchyID "8.7.2" ;
    ex:apqcSourceText "Defining and creating a strategy for provision of support to users of IT services and solutions." ;
    rdfs:label "Define and develop service support strategy" ;
    skos:definition "An Act of Formulation that has as input business objectives and has as output an IT strategy prescribing how support is provided to users of IT services and solutions." ;
    rdfs:comment "Formulation (Directive output): composes a support strategy." ;
    skos:example "A support director defines the organization's IT service-support strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20874 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20875 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20876 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20877 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20878 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20879 ] .

ex:P20874 a owl:Class ;
    ex:pcfID "20874" ; ex:hierarchyID "8.7.2.1" ;
    ex:apqcSourceText "Assessing the goals of IT service support delivery and how it aligns to contribute to the overall business objectives." ;
    rdfs:label "Assess business objectives and IT service support delivery" ;
    skos:definition "An Act of Appraisal that has as input business objectives and has as output an IT value contribution assessment judging how IT service support delivery aligns with overall business objectives." ;
    rdfs:comment "Appraisal (Descriptive output): evaluates alignment/contribution." ;
    skos:example "An analyst appraises how the support function advances business goals." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITValueContributionAssessment ] .

ex:P20875 a owl:Class ;
    ex:pcfID "20875" ; ex:hierarchyID "8.7.2.2" ;
    ex:apqcSourceText "Defining different IT support services and solutions such as remote support and cloud support. Include planned IT initiatives and ongoing IT services (such as application support)." ;
    rdfs:label "Define IT service support portfolio" ;
    skos:definition "An Act of Formulation that has as output an IT portfolio plan establishing the set of IT support services and solutions offered." ;
    rdfs:comment "Formulation (Directive output): defines the committed support offerings." ;
    skos:example "A support lead enumerates remote, cloud, and application support offerings into a support portfolio." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPortfolioPlan ] .

ex:P20876 a owl:Class ;
    ex:pcfID "20876" ; ex:hierarchyID "8.7.2.3" ;
    ex:apqcSourceText "Design and maintaining an IT support model that defines the processes and procedures needed to support users of IT services and solutions." ;
    rdfs:label "Create and maintain IT support model" ;
    skos:definition "An Act of Design that has as output an IT service management plan defining the processes and procedures needed to support users of IT services and solutions." ;
    rdfs:comment "Design (Directive output): the support model is a prescriptive specification of support processes." ;
    skos:example "An architect drafts and revises the IT support operating model." ;
    rdfs:subClassOf ex:ActOfDesign ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceManagementPlan ] .

ex:P20877 a owl:Class ;
    ex:pcfID "20877" ; ex:hierarchyID "8.7.2.4" ;
    ex:apqcSourceText "Developing a strategy for sourcing resources to support users of IT services and solutions. Establish sources that will make use of e-mail, live support software online, or a tool where users can log a call or incident in order to retrieve IT support." ;
    rdfs:label "Develop IT support service sourcing strategy" ;
    skos:definition "An Act of Formulation that has as output an IT strategy prescribing the sources of resources used to support users of IT services and solutions." ;
    rdfs:comment "Formulation (Directive output): composes a support sourcing strategy." ;
    skos:example "A manager defines the channels (email, live chat, ticketing) sourcing the support function." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategy ] .

ex:P20878 a owl:Class ;
    ex:pcfID "20878" ; ex:hierarchyID "8.7.2.5" ;
    ex:apqcSourceText "Creating an agenda for the rules and regulations of support service that deal with providing support to users of IT services and solutions." ;
    rdfs:label "Establish support service framework" ;
    skos:definition "An Act of Formulation that has as output an IT policy prescribing the rules and regulations governing the provision of support to users of IT services and solutions." ;
    rdfs:comment "Formulation (Directive output): a rules/regulations framework is a prescriptive policy." ;
    skos:example "A governance team codifies the support-service rulebook." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPolicy ] .

ex:P20879 a owl:Class ;
    ex:pcfID "20879" ; ex:hierarchyID "8.7.2.6" ;
    ex:apqcSourceText "Providing the tools and techniques to support users of IT services and solutions, and choosing the most appropriate tools and techniques. Evaluate the pros and cons of all the methodologies and tools available. Choose the most efficient and effective methodology." ;
    rdfs:label "Provide service support tools and technology" ;
    skos:definition "An Act of Selection that has as input technology assessment data and has as output an IT standard specifying the chosen support tools and technologies provisioned to the support function." ;
    rdfs:comment "Selection (ex:ActOfSelection): evaluates candidate tools/methodologies and commits to the chosen set; the choice is a Directive ICE." ;
    skos:example "A support team evaluates ticketing platforms and selects one to deploy." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TechnologyAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStandard ] .

ex:P20880 a owl:Class ;
    ex:pcfID "20880" ; ex:hierarchyID "8.7.3" ;
    ex:apqcSourceText "Determine and manage service delivery flow across different business functions. Understand the level of services needed by different stakeholders. Identify major service delivery touch points and criticality associated. Ensure timely communication with users." ;
    rdfs:label "Plan and manage service delivery control" ;
    skos:definition "An Act of Formulation that has as input IT customer requirements and has as output an IT service management plan governing the flow and control of service delivery across business functions." ;
    rdfs:comment "Lead verb Plan; Formulation (Directive output). Children are planning sub-acts under this control plan." ;
    skos:example "A delivery manager plans service-delivery touchpoints and control mechanisms across functions." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITCustomerRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceManagementPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20881 ] .

ex:P20881 a owl:Class ;
    ex:pcfID "20881" ; ex:hierarchyID "8.7.3.1" ;
    ex:apqcSourceText "Planning different delivery services for operational activities within the IT function. Use service delivery systems to manage the IT service delivery services." ;
    rdfs:label "Plan operational activities for IT service delivery" ;
    skos:definition "An Act of Formulation that has as output an IT service management plan prescribing the operational activities for delivering IT services." ;
    rdfs:comment "Formulation (Directive output). Its scheduling sub-acts are process parts." ;
    skos:example "An operations lead lays out the daily/periodic IT delivery operations plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceManagementPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20882 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20883 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20884 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20885 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20886 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20887 ] .

ex:P20882 a owl:Class ;
    ex:pcfID "20882" ; ex:hierarchyID "8.7.3.1.1" ;
    ex:apqcSourceText "Scheduling resources to provide service delivery to IT users. Ensure design, development, deployment, and operations are aligned with the business objectives." ;
    rdfs:label "Schedule service delivery resources" ;
    skos:definition "An Act of Scheduling that has as output a resource schedule assigning resources to deliver IT services to users over time." ;
    rdfs:comment "Scheduling (Directive output): a resource schedule prescribes when/which resources act." ;
    skos:example "A coordinator builds the weekly roster of delivery resources." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResourceSchedule ] .

ex:P20883 a owl:Class ;
    ex:pcfID "20883" ; ex:hierarchyID "8.7.3.1.2" ;
    ex:apqcSourceText "Maintaining and scheduling batch jobs to run in the background at a certain date and time." ;
    rdfs:label "Maintain/optimize batch job schedule" ;
    skos:definition "An Act of Scheduling that has as output a resource schedule specifying when batch jobs run in the background." ;
    rdfs:comment "Scheduling (Directive output): the batch schedule prescribes job execution times." ;
    skos:example "An operator tunes the nightly batch window to avoid contention." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResourceSchedule ] .

ex:P20884 a owl:Class ;
    ex:pcfID "20884" ; ex:hierarchyID "8.7.3.1.3" ;
    ex:apqcSourceText "Determine the timely change or release of IT services or support. Assign periodic release/change to IT systems or services." ;
    rdfs:label "Schedule change/release windows" ;
    skos:definition "An Act of Scheduling that has as output a resource schedule assigning the windows for changes and releases to IT systems or services." ;
    rdfs:comment "Scheduling (Directive output): change/release windows are prescribed time slots." ;
    skos:example "A release manager allocates the monthly maintenance window." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResourceSchedule ] .

ex:P20885 a owl:Class ;
    ex:pcfID "20885" ; ex:hierarchyID "8.7.3.1.4" ;
    ex:apqcSourceText "Schedule or optimize backup and archive activities for IT services and solutions. Use a backup system or application and archive operations data for future retrieval." ;
    rdfs:label "Schedule/optimize backup and archive activities" ;
    skos:definition "An Act of Scheduling that has as output a resource schedule specifying when backup and archive activities run for IT services and solutions." ;
    rdfs:comment "Scheduling (Directive output): backup/archive timing is prescribed." ;
    skos:example "A storage admin sets the incremental and full backup cadence." ;
    rdfs:subClassOf ex:ActOfScheduling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResourceSchedule ] .

ex:P20886 a owl:Class ;
    ex:pcfID "20886" ; ex:hierarchyID "8.7.3.1.5" ;
    ex:apqcSourceText "Balancing workloads of all the processes and services that are provisioned to their internal or external clients, across available components of IT infrastructure. No component should be over or under utilized with the workflow of the IT operations." ;
    rdfs:label "Balance operational workloads across available infrastructure components" ;
    skos:definition "An Act of Service Provision that distributes operational workloads across available IT infrastructure components so that no component is over- or under-utilized." ;
    rdfs:comment "Service Provision (operations): acts on material IT infrastructure components, attached via obo:BFO_0000057 (has participant), legal in operations category 8.0 (D4)." ;
    skos:example "A capacity engineer rebalances VM workloads across the cluster." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] .

ex:P20887 a owl:Class ;
    ex:pcfID "20887" ; ex:hierarchyID "8.7.3.1.6" ;
    ex:apqcSourceText "Determining process and procedure to provide support for specific IT service problems." ;
    rdfs:label "Determine specific problem support procedures" ;
    skos:definition "An Act of Formulation that has as output an IT standard prescribing the processes and procedures for supporting specific IT service problems." ;
    rdfs:comment "Formulation (Directive output): support procedures are prescriptive." ;
    skos:example "A support lead documents the runbook for a recurring database fault." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStandard ] .

ex:P20888 a owl:Class ;
    ex:pcfID "20888" ; ex:hierarchyID "8.7.4" ;
    ex:apqcSourceText "Developing and managing the resources required for administration of infrastructure. Manage the IT inventory and assets to meet organization's IT resource capacity." ;
    rdfs:label "Develop and manage infrastructure resource planning" ;
    skos:definition "An Act of Formulation that has as input IT landscape data and has as output an IT portfolio plan governing the resources required for IT infrastructure administration and capacity." ;
    rdfs:comment "Lead verb Develop; Formulation (Directive output). Its assessment/planning sub-acts are process parts." ;
    skos:example "An infrastructure planner sets the resource and capacity plan for the year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITLandscapeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPortfolioPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20889 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20890 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20891 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20892 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20893 ] .

ex:P20889 a owl:Class ;
    ex:pcfID "20889" ; ex:hierarchyID "8.7.4.1" ;
    ex:apqcSourceText "Creating a strategy for delivering IT services and solutions. Establish the sourcing strategy. Establish the delivery process procedures and tools. Examine and choose the most effective methodologies and tools." ;
    rdfs:label "Develop IT service delivery strategy" ;
    skos:definition "An Act of Formulation that has as output an IT strategy prescribing how IT services and solutions are delivered, including sourcing and delivery procedures." ;
    rdfs:comment "Formulation (Directive output): composes a delivery strategy." ;
    skos:example "An infrastructure team drafts the delivery strategy and toolchain choices." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategy ] .

ex:P20890 a owl:Class ;
    ex:pcfID "20890" ; ex:hierarchyID "8.7.4.2" ;
    ex:apqcSourceText "Assessing the goals and objectives of IT infrastructure and how it contributes to the overall business objectives." ;
    rdfs:label "Assess IT infrastructure business objectives" ;
    skos:definition "An Act of Appraisal that has as input business objectives and has as output an IT value contribution assessment judging how IT infrastructure contributes to overall business objectives." ;
    rdfs:comment "Appraisal (Descriptive output): evaluates contribution." ;
    skos:example "An analyst appraises infrastructure investment against business goals." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessObjectives ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITValueContributionAssessment ] .

ex:P20891 a owl:Class ;
    ex:pcfID "20891" ; ex:hierarchyID "8.7.4.3" ;
    ex:apqcSourceText "Determining existing IT infrastructure capabilities. Identify the gaps and needs in order to enhance the existing IT infrastructure to meet growth objectives." ;
    rdfs:label "Determine ongoing IT infrastructure capabilities" ;
    skos:definition "An Act of Analysis that has as input IT landscape data and has as output an IT requirements analysis describing existing IT infrastructure capabilities and the gaps to be closed." ;
    rdfs:comment "Analysis (Descriptive output): discerns current capabilities and gaps." ;
    skos:example "An architect assesses current infrastructure capacity versus growth needs." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITLandscapeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20892 a owl:Class ;
    ex:pcfID "20892" ; ex:hierarchyID "8.7.4.4" ;
    ex:apqcSourceText "Identify the gaps and needs of existing IT infrastructure. Plan and develop strategies to upgrade/replace existing IT infrastructure." ;
    rdfs:label "Plan IT infrastructure change" ;
    skos:definition "An Act of Formulation that has as input an IT requirements analysis and has as output an IT transformation plan to upgrade or replace existing IT infrastructure." ;
    rdfs:comment "Formulation (Directive output): an upgrade/replacement plan is prescriptive." ;
    skos:example "A team plans a phased datacenter refresh." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITTransformationPlan ] .

ex:P20893 a owl:Class ;
    ex:pcfID "20893" ; ex:hierarchyID "8.7.4.5" ;
    ex:apqcSourceText "Creating a plan associated with usage volumes of IT licenses. Develop a framework to govern the licensing of an IT services along with identified usage volumes. Determine the amount of investment in IT license usage volumes and how would the license volumes be financed." ;
    rdfs:label "Plan and budget IT license usage volumes" ;
    skos:definition "An Act of Formulation that has as output an IT portfolio plan governing IT license usage volumes and their associated investment and financing." ;
    rdfs:comment "Formulation (Directive output): a license-volume and budget plan is prescriptive." ;
    skos:example "A software asset manager sets the annual license entitlement and budget." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPortfolioPlan ] .

ex:P20895 a owl:Class ;
    ex:pcfID "20895" ; ex:hierarchyID "8.7.5" ;
    ex:apqcSourceText "Develop strategies and methodologies to provide service support. Examine service levels, support complexity, stakeholder requirements to offer service support." ;
    rdfs:label "Define service support planning" ;
    skos:definition "An Act of Formulation that has as input IT customer requirements and has as output an IT service management plan prescribing the strategies and methodologies for providing service support." ;
    rdfs:comment "Formulation (Directive output): composes the support plan. Its analysis/planning/management sub-acts are process parts." ;
    skos:example "A support architect defines the support-planning framework for the year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITCustomerRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceManagementPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20896 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20897 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20898 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20943 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20899 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20900 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20902 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20903 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20904 ] ,
        # P20901 (8.7.5.7) is now a bounded process (Gate-F R5 fix), so 8.7.5 gains a process-part edge to it.
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20901 ] .

ex:P20896 a owl:Class ;
    ex:pcfID "20896" ; ex:hierarchyID "8.7.5.1" ;
    ex:apqcSourceText "Evaluate criticality catered by the IT support and expectations to resolve raised or identified issues. Determine the usual requests received for IT support for each area of IT operations. Ensure resolution to every identified or reported issue within specified SLAs." ;
    rdfs:label "Understand IT support demand patterns" ;
    skos:definition "An Act of Analysis that has as input IT issue/request data and has as output an IT service demand forecast describing the usual support demand for each area of IT operations." ;
    rdfs:comment "Analysis (Descriptive output): characterizes demand patterns." ;
    skos:example "A support analyst profiles ticket volumes by category to forecast demand." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITIssueRequestData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceDemandForecast ] .

ex:P20897 a owl:Class ;
    ex:pcfID "20897" ; ex:hierarchyID "8.7.5.2" ;
    ex:apqcSourceText "Determining levels of required support resources along with their responsibilities, and capabilities to resolve IT issues. Evaluate and ensure that support resources are fulfilling their responsibilities n a timely manner." ;
    rdfs:label "Determine required support resource levels, responsibilities, and capabilities" ;
    skos:definition "An Act of Analysis that has as input an IT service demand forecast and has as output an IT requirements analysis specifying the required support resource levels, responsibilities, and capabilities." ;
    rdfs:comment "Analysis (Descriptive output): determines required resource levels from demand." ;
    skos:example "A manager derives staffing tiers from the forecast support demand." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITServiceDemandForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] .

ex:P20898 a owl:Class ;
    ex:pcfID "20898" ; ex:hierarchyID "8.7.5.3" ;
    ex:apqcSourceText "Create and maintain service support knowledge repository. Store, maintain, access, revise, and use knowledge for IT services. Review knowledge trends and implement knowledge transfer methodologies for competitive advantage." ;
    rdfs:label "Maintain service support knowledge repository" ;
    skos:definition "An Act of Data Management that stores, revises, and maintains an IT knowledge repository for service support." ;
    rdfs:comment "Data Management (acts on a Descriptive ICE store): creates/maintains the knowledge repository." ;
    skos:example "A knowledge manager curates the support knowledge base." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITKnowledgeRepository ] .

ex:P20943 a owl:Class ;
    ex:pcfID "20943" ; ex:hierarchyID "8.7.5.4" ;
    ex:apqcSourceText "Maintaining and transfer of knowledge towards service support with the change/upgrade in technology over a stipulated period. Ensure IT staff is well trained and tested on the new learning of service support." ;
    rdfs:label "Maintain service support learning" ;
    skos:definition "An Act of Data Management that maintains and transfers service-support knowledge from an IT knowledge repository as technology changes, keeping IT staff trained on new learning." ;
    rdfs:comment "Data Management (knowledge transfer): maintains and disseminates the knowledge ICE; training of staff is the downstream effect rather than the definitional output." ;
    skos:example "A trainer refreshes the support team on a newly adopted platform." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITKnowledgeRepository ] .

ex:P20899 a owl:Class ;
    ex:pcfID "20899" ; ex:hierarchyID "8.7.5.5" ;
    ex:apqcSourceText "Conveying service support needs within the organization, with the objective of providing required support services. Define processes and procedures needed to support users of IT services and solutions. Convey these procedures to appropriate governing authority." ;
    rdfs:label "Communicate service support needs" ;
    skos:definition "An Act of Communication that conveys the defined service-support needs and procedures to the appropriate governing authority within the organization, producing the conveyed IT standard." ;
    rdfs:comment "Anchored to the shared ex:ActOfCommunication (wraps the D6-VERIFIED cco:ont00000402 'Act of Communication'; verification recorded in the §6 record at the ex:ActOfCommunication declaration). NOT cco:ont00000379 'Act of Representative Communication' (the flagged false-friend). Gate-F DE-CONFLATION: the source fuses (1) a Formulation facet ('Define processes and procedures needed to support users', authored as the Directive ex:ITStandard upstream/at the support-planning rows) with (2) the Communication facet modeled here ('Convey these procedures to appropriate governing authority'); the lead gerund is 'Conveying', so this row is the conveyance act. Gate-F fix: added a has-output (ex:ITStandard, the conveyed procedures, Directive) so the I/O is coherent with the conveyance -- the has-input ex:ITRequirementsAnalysis (the analysis informing the needs) is retained, and the procedures-defining step is the upstream Formulation it transfers." ;
    skos:example "A support lead briefs IT governance on resourcing and the support procedures to adopt." ;
    rdfs:subClassOf ex:ActOfCommunication ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITRequirementsAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStandard ] .

ex:P20900 a owl:Class ;
    ex:pcfID "20900" ; ex:hierarchyID "8.7.5.6" ;
    ex:apqcSourceText "Determining mechanisms to report for a higher degree of decision making depending on the criticality of IT escalations. Define the processes and procedures needed to follow for IT escalation at different levels. Convey the mechanisms within the organization." ;
    rdfs:label "Define IT escalation mechanisms" ;
    skos:definition "An Act of Formulation that has as output an IT standard prescribing the processes and procedures for escalating IT issues at different criticality levels." ;
    rdfs:comment "Formulation (Directive output): escalation procedures are prescriptive." ;
    skos:example "A support architect codifies the tiered escalation path." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStandard ] .

ex:P20902 a owl:Class ;
    ex:pcfID "20902" ; ex:hierarchyID "8.7.5.8" ;
    ex:apqcSourceText "Developing a strategy that will make use of multiple resources to coordinate with external support providers in order to make the support services work more smoother." ;
    rdfs:label "Coordinate with external support providers" ;
    skos:definition "An Act of Formulation that has as output an IT strategy for coordinating multiple resources with external support providers, and that has an external IT support provider as participant." ;
    rdfs:comment "Formulation (Directive output): a coordination strategy is prescriptive; the external provider is a definitional participant." ;
    skos:example "A vendor manager designs the multi-vendor support coordination model." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITStrategy ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ExternalITSupportProvider ] .

ex:P20903 a owl:Class ;
    ex:pcfID "20903" ; ex:hierarchyID "8.7.5.9" ;
    ex:apqcSourceText "Sorting the incidents of IT service delivery in certain order so that the services could be delivered based on the criticality." ;
    rdfs:label "Triage IT service delivery incidents" ;
    skos:definition "An Act of Analysis that has as input IT issue/request data and has as output an IT service support record sorting service-delivery incidents by criticality." ;
    rdfs:comment "Analysis (Descriptive output): triage prioritizes/represents incidents; the routing record is descriptive." ;
    skos:example "A duty operator orders incoming delivery incidents by severity." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITIssueRequest ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceSupportRecord ] .

ex:P20904 a owl:Class ;
    ex:pcfID "20904" ; ex:hierarchyID "8.7.5.10" ;
    ex:apqcSourceText "Defining methodology and frequency of assessment for measuring and monitoring performance of various processes and activities of IT service support against standard set goals." ;
    rdfs:label "Monitor IT service support performance" ;
    skos:definition "An Act of Monitoring that has as input IT performance data and has as output an IT performance report measuring IT service support performance against set goals." ;
    rdfs:comment "Monitoring (Descriptive output): measures performance over time, yielding a performance report." ;
    skos:example "A service manager tracks support KPIs against SLA targets monthly." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20905 a owl:Class ;
    ex:pcfID "20905" ; ex:hierarchyID "8.7.6" ;
    ex:apqcSourceText "Developing and managing different delivery services using service delivery systems for operational activities within the IT function in order to achieve organizations goal." ;
    rdfs:label "Develop and manage service delivery operations" ;
    skos:definition "An Act of Service Provision that operates the IT service-delivery systems to carry out the operational activities of the IT function." ;
    rdfs:comment "Operations process: the bounded operate cycle is composed of concrete operational children (operate, monitor, respond, produce, recover)." ;
    skos:example "An operations center runs the daily IT service-delivery operations." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20906 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20907 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20908 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20909 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20910 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20911 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20912 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20913 ] .

ex:P20906 a owl:Class ;
    ex:pcfID "20906" ; ex:hierarchyID "8.7.6.1" ;
    ex:apqcSourceText "Operating and defining methodology of assessment for measuring and monitoring performance of online systems against its expected result." ;
    rdfs:label "Operate and monitor online systems" ;
    skos:definition "An Act of Monitoring that has as input IT performance data and has as output an IT performance report measuring online-system performance against expected results." ;
    rdfs:comment "Monitoring (Descriptive output): operate-and-monitor yields a performance representation." ;
    skos:example "An operator watches live dashboards for the transaction systems." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20907 a owl:Class ;
    ex:pcfID "20907" ; ex:hierarchyID "8.7.6.2" ;
    ex:apqcSourceText "Operate and monitor the application of scheduling batch jobs to be run in the background at a certain date and time." ;
    rdfs:label "Run and monitor batch job schedule" ;
    skos:definition "An Act of Monitoring that has as input IT performance data and has as output an IT performance report tracking the execution of scheduled batch jobs." ;
    rdfs:comment "Monitoring (Descriptive output): runs and watches batch execution." ;
    skos:example "An operator confirms overnight batch jobs completed successfully." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20908 a owl:Class ;
    ex:pcfID "20908" ; ex:hierarchyID "8.7.6.3" ;
    ex:apqcSourceText "Analyze and manage workload needs in relation to service delivery. Plan resources and mechanism around those workload needs so that services could be delivered smoothly." ;
    rdfs:label "Manage service delivery workloads" ;
    skos:definition "An Act of Service Provision that allocates resources to meet service-delivery workload needs so that services are delivered smoothly." ;
    rdfs:comment "Service Provision (operations): provisions material infrastructure components (obo:BFO_0000057) against live workload demand." ;
    skos:example "A delivery lead shifts capacity to absorb a month-end processing spike." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] .

ex:P20909 a owl:Class ;
    ex:pcfID "20909" ; ex:hierarchyID "8.7.6.4" ;
    ex:apqcSourceText "Managing the performance and capacity of infrastructure by using key performance indicators to routinely track the performance and capacity levels. Review performance. Evaluate the efficiency and effectiveness of the infrastructure." ;
    rdfs:label "Manage infrastructure performance and capacity" ;
    skos:definition "An Act of Monitoring that has as input IT performance data and has as output an IT performance report tracking and evaluating IT infrastructure performance and capacity against key performance indicators." ;
    rdfs:comment "Monitoring (Descriptive output): routine KPI tracking and evaluation yields a performance report." ;
    skos:example "A capacity team reviews monthly utilization and headroom metrics." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITPerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20910 a owl:Class ;
    ex:pcfID "20910" ; ex:hierarchyID "8.7.6.5" ;
    ex:apqcSourceText "Addressing to an issue in operational activities within the IT function, that occur outside of normal routine or preventative maintenance." ;
    rdfs:label "Respond to unplanned operational issues" ;
    skos:definition "An Act of Service Provision that has as input an IT issue/request and addresses an operational issue arising outside normal routine or preventative maintenance." ;
    rdfs:comment "Service Provision (operations): an incident-response act." ;
    skos:example "An on-call engineer restores a service after an unexpected outage." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITIssueRequest ] .

ex:P20911 a owl:Class ;
    ex:pcfID "20911" ; ex:hierarchyID "8.7.6.6" ;
    ex:apqcSourceText "Identify and introduce resources to display output in a viewable form to key decision makers and evaluators." ;
    rdfs:label "Produce and distribute output media" ;
    skos:definition "An Act of Service Provision that produces and distributes output media in a viewable form to key decision makers and evaluators, and has as output an IT performance report." ;
    rdfs:comment "Service Provision (operations): produces and delivers output artifacts (the IT performance report as informational output) to recipients." ;
    skos:example "An operations team generates and circulates the daily processing report." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPerformanceReport ] .

ex:P20912 a owl:Class ;
    ex:pcfID "20912" ; ex:hierarchyID "8.7.6.7" ;
    ex:apqcSourceText "Identifying, examining, and recognizing any flaw or breach in security of IT infrastructure. Ensure that protocols and guidelines for individual IT components are being followed and there is no misuse of information and breach of individual or organizational privacy." ;
    rdfs:label "Monitor IT infrastructure security" ;
    skos:definition "An Act of Monitoring that has as input IT security threat data and has as output an IT security threat analysis identifying flaws or breaches in IT infrastructure security." ;
    rdfs:comment "Monitoring (Descriptive output): surveils for security flaws/breaches, yielding a threat analysis." ;
    skos:example "A SOC analyst watches the SIEM for intrusion indicators." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITSecurityThreatData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITSecurityThreatAnalysis ] .

ex:P20913 a owl:Class ;
    ex:pcfID "20913" ; ex:hierarchyID "8.7.6.8" ;
    ex:apqcSourceText "Managing resources of IT infrastructure and their recovery capacity. Manage storage, computer hardware, software, and infrastructure resources that can be stored as inventory or provided by the organization as needed. Managing backup/recovery for IT services and solutions. Use a backup system or application." ;
    rdfs:label "Manage IT infrastructure/data recovery" ;
    skos:definition "An Act of Service Provision that performs backup and recovery operations on IT infrastructure components to safeguard and restore IT services and solutions." ;
    rdfs:comment "Service Provision (operations): acts on material infrastructure components (obo:BFO_0000057) for backup/recovery." ;
    skos:example "A backup operator validates restores from the previous night's backup." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] .

ex:P20915 a owl:Class ;
    ex:pcfID "20915" ; ex:hierarchyID "8.7.7.1" ;
    ex:apqcSourceText "Identifying and tracking individual configuration items, documenting functional capabilities and interdependencies of IT infrastructure. Determining the gaps and needs in order to enhance existing infrastructure configuration." ;
    rdfs:label "Manage infrastructure configuration" ;
    skos:definition "An Act of Data Management that identifies, tracks, and documents the configuration items, capabilities, and interdependencies of IT infrastructure, producing IT landscape data." ;
    rdfs:comment "Data Management (Descriptive output): maintains the configuration record (a CMDB-like ICE)." ;
    skos:example "A config manager updates the CMDB with new server dependencies." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITLandscapeData ] .

ex:P20916 a owl:Class ;
    ex:pcfID "20916" ; ex:hierarchyID "8.7.7.2" ;
    ex:apqcSourceText "Evaluating and maintaining all aspects of infrastructure component maintenance. Ensure that all components of an IT infrastructure are functioning properly as per the expectation. Maintenance includes all preventative, routine, and corrective measures." ;
    rdfs:label "Perform infrastructure component maintenance" ;
    skos:definition "An Act of Maintenance that modifies IT infrastructure components to preserve or restore their designed functions and qualities." ;
    rdfs:comment "Reuses cco:ont00000950 (Act of Maintenance). Gate-F D6 fix -- VERIFICATION RECORD (add to methodology §6 'Verified core terms'): cco:ont00000950 PINNED against CommonCoreOntologiesMerged v2.0 (2024-11-06) by reading its actual triples: label 'Act of Maintenance'; definition 'An Act of Artifact Modification in which a Material Artifact is modified in order to preserve or restore one or more of its designed Qualities or Functions.'; parent chain ont00000950 rdfs:subClassOf cco:ont00000970 (Act of Artifact Modification). The definition fits component maintenance exactly, so the reuse is now auditable rather than asserted from a remembered definition. Operates on a Material Entity participant (obo:BFO_0000057 some ex:ITInfrastructureComponent), legal in operations category 8.0; this class carries only a has-participant restriction (no has input/output/process-part), so it is outside the SHACL ProcessShape target and its anchor is not subject to the S2 Act-allowlist." ;
    skos:example "A field tech replaces failing disks and applies firmware patches." ;
    rdfs:subClassOf cco:ont00000950 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] .

ex:P20917 a owl:Class ;
    ex:pcfID "20917" ; ex:hierarchyID "8.7.7.3" ;
    ex:apqcSourceText "Installing/configuring/upgrading all the components required for operational activities within IT infrastructure. Ensure that all components of an IT infrastructure are functioning properly and updated to latest version/technology." ;
    rdfs:label "Install/configure/upgrade infrastructure components" ;
    skos:definition "An Act of Deployment that installs, configures, and upgrades IT infrastructure components required for operational activities, bringing them into functioning, up-to-date service." ;
    rdfs:comment "Deployment (operations): places/updates material infrastructure components into service (obo:BFO_0000057). Distinct from maintenance (which preserves/restores existing function)." ;
    skos:example "An engineer racks, images, and configures new servers." ;
    rdfs:subClassOf ex:ActOfDeployment ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] .

ex:P20918 a owl:Class ;
    ex:pcfID "20918" ; ex:hierarchyID "8.7.7.4" ;
    ex:apqcSourceText "Maintaining the complete list of IT items or resources available with the organization with the details on date of purchase, licenses, deployment and SLAs." ;
    rdfs:label "Maintain IT asset records" ;
    skos:definition "An Act of Data Management that maintains an IT landscape data register of the organization's IT items and resources, including purchase, license, deployment, and SLA details." ;
    rdfs:comment "Data Management (Descriptive output): maintains the asset register ICE; the records describe material IT assets but the act manipulates the ICE." ;
    skos:example "An asset manager updates the inventory when new laptops are issued." ;
    rdfs:subClassOf ex:ActOfDataManagement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITLandscapeData ] .

ex:P20919 a owl:Class ;
    ex:pcfID "20919" ; ex:hierarchyID "8.7.7.5" ;
    ex:apqcSourceText "Administering and overseeing the terms and policies associated with licensing the IT intellectual property. Create and manage the policies and terms governing the possible granting of a license to any external agent. Demarcate a clear framework that governs the licensing of any patents or copyrights held by the organization." ;
    rdfs:label "Administer IT licenses/user agreements" ;
    skos:definition "An Act of Formulation that has as output an IT policy prescribing the terms and conditions governing the licensing of the organization's IT intellectual property." ;
    rdfs:comment "Formulation (Directive output): licensing policies and terms are prescriptive." ;
    skos:example "Legal and IT jointly set the terms for licensing the firm's patented software." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITPolicy ] .

ex:P20920 a owl:Class ;
    ex:pcfID "20920" ; ex:hierarchyID "8.7.7.6" ;
    ex:apqcSourceText "Providing all the infrastructure services and capabilities required for operational activities within the IT function supporting overall business objectives." ;
    rdfs:label "Provide IT infrastructure service and capabilities" ;
    skos:definition "An Act of Service Provision that provisions the IT infrastructure services and capabilities required for the operational activities of the IT function." ;
    rdfs:comment "Service Provision (operations): delivers infrastructure services/capacity (a Material Entity, IT infrastructure component, as participant via obo:BFO_0000057) to consumers." ;
    skos:example "An infrastructure team provisions compute, storage, and network capacity to application teams." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ITInfrastructureComponent ] .

ex:P20921 a owl:Class ;
    ex:pcfID "20921" ; ex:hierarchyID "8.7.8" ;
    ex:apqcSourceText "Managing systematic user support functionality and capability through defined procedures. Determine, record, and monitor user requests. Execute issue/request resolution. Utilize escalation path when needed. Resolve issue/request." ;
    rdfs:label "Operate IT user support" ;
    skos:definition "An Act of Service Provision that runs the systematic IT user-support function, recording user requests and driving them to resolution through defined procedures." ;
    rdfs:comment "Operations process: the bounded support-operation cycle is composed of triage, resolution, escalation, and recovery children." ;
    skos:example "A service desk operates the end-to-end ticket lifecycle for users." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITIssueRequest ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20922 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20923 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20925 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20926 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20927 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20928 ] .

ex:P20922 a owl:Class ;
    ex:pcfID "20922" ; ex:hierarchyID "8.7.8.1" ;
    ex:apqcSourceText "Evaluate and assign IT issues/requests accordingly to allow for the correct routing of IT issues to the relevant support teams." ;
    rdfs:label "Triage IT issues/requests" ;
    skos:definition "An Act of Analysis that has as input an IT issue/request and has as output an IT service support record assigning and routing the issue to the relevant support team." ;
    rdfs:comment "Analysis (Descriptive output): evaluates and classifies the request; the routing assignment is a descriptive record." ;
    skos:example "A first-line agent categorizes a ticket and routes it to the network team." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITIssueRequest ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceSupportRecord ] .

ex:P20923 a owl:Class ;
    ex:pcfID "20923" ; ex:hierarchyID "8.7.8.2" ;
    ex:apqcSourceText "Providing the necessary skills and competencies required to efficiently provide IT resolution through the support structure." ;
    rdfs:label "Provide IT resolution capabilities" ;
    skos:definition "An Act of Service Provision that supplies the skills and competencies needed to resolve IT issues through the support structure." ;
    rdfs:comment "Service Provision (operations): makes resolution capability available through the support structure." ;
    skos:example "A support team staffs specialists to handle complex incidents." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITIssueRequest ] .

ex:P20925 a owl:Class ;
    ex:pcfID "20925" ; ex:hierarchyID "8.7.8.3" ;
    ex:apqcSourceText "Creating an effective plan and structure to address and resolve requests of IT users. Determine, record, and monitor user requests. Obtain information about the effectiveness and performance of the user request handling process from the IT users through various means." ;
    rdfs:label "Manage IT user requests" ;
    skos:definition "An Act of Service Provision that has as input an IT issue/request and has as output an IT service support record, recording and monitoring IT user requests through the handling process." ;
    rdfs:comment "Service Provision (operations): records and tracks user requests to resolution." ;
    skos:example "A service desk logs, updates, and monitors each user request to closure." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITIssueRequest ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceSupportRecord ] .

ex:P20926 a owl:Class ;
    ex:pcfID "20926" ; ex:hierarchyID "8.7.8.4" ;
    ex:apqcSourceText "Follow processes and procedures to escalate IT requests to required levels for resolution or effective decision making when necessary." ;
    rdfs:label "Escalate IT requests" ;
    skos:definition "An Act of Communication that conveys an unresolved IT request to a higher support or decision-making level per defined escalation procedures." ;
    rdfs:comment "Gate-F D6 fix: re-anchored to the shared ex:ActOfCommunication, which wraps the D6-VERIFIED cco:ont00000402 'Act of Communication' ('A Planned Act in which some Information Content Entity is transferred from some Agent to Another.', parent cco:ont00000228); verification recorded in the §6 record at the ex:ActOfCommunication declaration. The verified CCO Act of Communication denotes GENERIC ICE-transfer (not only the truth-committing cco:ont00000379 'Act of Representative Communication'), so escalation-as-conveyance of the request ICE fits. The prior per-class raw cco:ont00000402 IRI and the explanatory-only cco:ont00000228 co-anchor are REMOVED: the chain to the allowlisted Planned Act now comes from the shared genus ex:ActOfCommunication (which carries cco:ont00000228 for the SHACL S2 graph), so the workaround no longer masks an unverified IRI." ;
    skos:example "A second-line agent escalates a major incident to the on-call manager." ;
    rdfs:subClassOf ex:ActOfCommunication ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITIssueRequest ] .

ex:P20927 a owl:Class ;
    ex:pcfID "20927" ; ex:hierarchyID "8.7.8.5" ;
    ex:apqcSourceText "Creating a structure to resolve issues/requests of IT services using different mechanisms." ;
    rdfs:label "Resolve IT issues/requests" ;
    skos:definition "An Act of Service Provision that has as input an IT issue/request and has as output an IT service support record resolving the issue or request through available support mechanisms." ;
    rdfs:comment "Service Provision (operations): performs the resolution and records its outcome." ;
    skos:example "An engineer fixes a user's mailbox sync issue and closes the ticket." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITIssueRequest ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITServiceSupportRecord ] .

ex:P20928 a owl:Class ;
    ex:pcfID "20928" ; ex:hierarchyID "8.7.8.6" ;
    ex:apqcSourceText "Successfully implement preventive measures to manage IT risk of exposure to internal and external threats. Integrating the disciplines of Emergency Response, Crisis Management, Disaster Recovery (technology continuity) and Business Continuity for IT." ;
    rdfs:label "Execute IT continuity and recovery action" ;
    skos:definition "An Act of Service Provision that has as input an IT continuity plan and implements preventive and recovery measures integrating emergency response, crisis management, disaster recovery, and business continuity for IT." ;
    rdfs:comment "Service Provision (operations): executes the continuity plan; the plan is the directive input that guides the act." ;
    skos:example "An IT team invokes the disaster-recovery runbook after a datacenter failure." ;
    rdfs:subClassOf ex:ActOfServiceProvision ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ITContinuityPlan ] .

