@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC reality-layer slice 7.0 "Develop and Manage Human Capital"
####################################################################

<http://example.org/apqc/slice/7.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 7.0: Develop and Manage Human Capital" ;
    dct:source "APQC Process Classification Framework (Cross-Industry)" ;
    owl:versionInfo "0.3.0" ;
    rdfs:comment "Reality-layer module for APQC section 7.0. CCO pin v2.0 (2024-11-06); modeled per ADR-001 (two-layer model, R5 bounded-occurrent test). Self-contained: the shared act genera it uses are inlined from the apqc-ext.ttl registry, so it validates standalone against the pinned CCO/BFO closure with no extension merge." .

####################################################################
# ACT GENERA -- SELF-CONTAINED (canonical defs mirrored from
# apqc-ext.ttl, the D9 shared registry). Inlined so this module
# validates standalone against CCO without merging the extension.
####################################################################

ex:ActOfAcquisition a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Acquisition" ;
    skos:definition "A Planned Act in which an Agent obtains from some authority or supplier an entity (such as an authorization, license, or resource) that the Agent did not previously hold." ;
    rdfs:comment "Local extension (D9). Rejected cco:ont00000950 'Act of Maintenance' (modifying Material Artifacts) and cco:ont00000402 'Act of Communication' (mere ICE transfer). Securing/obtaining a held entity anchors at the generic Planned Act. Expected to recur in procurement/asset-acquisition categories (4.0, 10.0)." .

ex:ActOfAdministration a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Administration" ;
    skos:definition "A Planned Act in which an Agent carries out, enforces, delivers, coordinates, and maintains an already-established arrangement (such as a policy, program, plan, scheme, record set, or relationship) on behalf of an Organization in accordance with a Directive Information Content Entity, without itself creating that arrangement." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored at the generic cco:ont00000228 (Planned Act), neutral on output kind, so administrative acts yielding a Descriptive record or a Directive schedule both fit. Rejected cco:ont00000950 'Act of Maintenance' (modifies Material Artifacts to restore designed Qualities/Functions, whereas administration executes a directive arrangement rather than repairing an artifact), cco:ont00000511 'Act of Planning' (planning creates the arrangement; administering merely runs an existing one), and cco:ont00000366 'Act of Information Processing' (too narrow: administration provisions resources and enacts directives, not only ICE manipulation). Differentia is execution-and-upkeep of a settled arrangement. Recurs in 7.0." .

ex:ActOfAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Analysis" ;
    skos:definition "An Act of Information Processing in which an Agent examines one or more input Information Content Entities and produces an Information Content Entity that represents an understanding of their subject matter." ;
    rdfs:comment "Local extension (D9). CCO 2.0 has no generic analysis class; analysis is information processing, so it is anchored under cco:ont00000366." .

ex:ActOfFormulation a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Formulation" ;
    skos:definition "An Act of Planning in which an Agent composes and articulates a Directive Information Content Entity - such as a mission, strategy, objective, design, roadmap, or business model - that prescribes an organization's intended course of action." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000511 (Act of Planning) because formulating a strategy/mission/design is making a plan to achieve an objective; its output is a Directive ICE. Recurs across develop/define/compose-a-directive processes corpus-wide." .

ex:ActOfIdentification a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Identification (discernment sense)" ;
    skos:definition "An Act of Information Processing in which an Agent discerns and enumerates entities of a given kind and produces an Information Content Entity that registers them." ;
    rdfs:comment "Local extension (D9). NOT cco:ont00001261 'Act of Identifying' (a communication act). APQC 'Identify ...' denotes discernment, i.e. information processing." .

ex:ActOfNegotiation a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Negotiation" ;
    skos:definition "A Planned Act in which two or more Agents confer and bargain over terms and conditions, exchanging proposals and concessions, in order to reach and record a mutually binding Directive Information Content Entity such as an agreement or contract." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000228 (Planned Act): negotiation is two or more agents conferring and bargaining over terms to reach a mutually binding directive (an agreement or contract). Rejected cco:ont00001327 (Social Act) as too generic; Act of Contract Formation (cco:ont00000684) models only the consummating promise, narrower than the bargaining process." .

ex:ActOfSelection a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Selection" ;
    skos:definition "An Act of Information Processing in which an Agent chooses one or more options from a set of candidates and produces a Directive Information Content Entity that prescribes the chosen option(s)." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000366 (Act of Information Processing): receives candidate-option ICEs and yields a decision ICE. Distinct from Act of Appraisal (judges without committing) and Act of Planning. NOTE: ratifying a single already-settled option is NOT selection (no candidate set) -- anchor such acts at cco:ont00000228 (Planned Act)." .

####################################################################
# 0. ANNOTATION PROPERTIES (provenance / traceability)
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "Catalog-to-reality bridge: links an APQC catalog node (ex:PCF_<pcfID>) to the reality-layer class (process or capability) it designates." .

####################################################################
# 1. DOMAIN ACT-GENUS LAYER
#    Reused from apqc-ext.ttl (NOT re-minted): ex:ActOfAnalysis,
#    ex:ActOfIdentification, ex:ActOfFormulation, ex:ActOfSelection,
#    ex:ActOfAcquisition.
#    One NEW recurring genus is minted locally AND proposed for ext.
####################################################################

####################################################################
# 2. AGENTS / ORGANIZATIONS
#    Independent continuants bearing roles/capabilities (D4).
####################################################################

ex:HumanResourcesFunction a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;   # bearer of
          owl:someValuesFrom ex:HumanResourcesFunctionRole ] ;
    rdfs:label "Human Resources Function" ;
    skos:definition "An Organization that bears a human-resources-function role within a larger organization in virtue of being tasked with developing and managing the organization's human capital." ;
    rdfs:comment "The HR department/function as an organizational unit. Bearer of the HR management capability and the agent of most section 7.0 acts." .

ex:HumanResourcesProfessional a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:HumanResourcesProfessionalRole ] ;
    rdfs:label "Human Resources Professional" ;
    skos:definition "An Agent that bears a human-resources-professional role in virtue of performing human-capital management activities on behalf of an organization." .

ex:Employee a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:EmployeeRole ] ;
    rdfs:label "Employee" ;
    skos:definition "An Agent that bears an employee role in virtue of being engaged by an organization to perform assigned activities in exchange for compensation." ;
    rdfs:comment "Modeled as cco:Agent (a Material Entity bearing an Agent Capability), subsuming individual persons; reused as the participant/subject across recruiting, development, reward, and separation acts." .

ex:JobCandidate a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:JobCandidateRole ] ;
    rdfs:label "Job Candidate" ;
    skos:definition "An Agent that bears a job-candidate role in virtue of being considered by an organization to fill an open position." ;
    rdfs:comment "Applicant/candidate prior to hire; participant of sourcing, screening, selection, and offer acts in group 7.2." .

ex:HiringManager a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:HiringManagerRole ] ;
    rdfs:label "Hiring Manager" ;
    skos:definition "An Agent that bears a hiring-manager role in virtue of being responsible for deciding which candidate fills an open position." .

ex:ManagementPersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:ManagerRole ] ;
    rdfs:label "Management Personnel" ;
    skos:definition "An Agent that bears a manager role in virtue of exercising managerial authority within an organization." ;
    rdfs:comment "Shared with the reference template's ManagementPersonnel pattern; reused for participant fillers in strategy, performance, and relations acts." .

ex:Stakeholder a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:StakeholderRole ] ;
    rdfs:label "Stakeholder" ;
    skos:definition "An Agent that bears a stakeholder role in virtue of being able to affect or be affected by an organization's HR actions, objectives, and policies." ;
    rdfs:comment "Recipient of HR plan communications and source of requirements in groups 7.1, 7.7." .

ex:RecruitmentVendor a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:RecruitmentVendorRole ] ;
    rdfs:label "Recruitment Vendor" ;
    skos:definition "An Organization that bears a recruitment-vendor role in virtue of supplying candidate-sourcing services to a focal organization under contract." ;
    rdfs:comment "Third-party staffing/recruiting agency in group 7.2." .

ex:CertificationAuthority a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:CertificationAuthorityRole ] ;
    rdfs:label "Certification Authority" ;
    skos:definition "An Organization that bears a certification-authority role in virtue of being empowered to issue and maintain certifications attesting to an agent's qualifications." ;
    rdfs:comment "External certification body in group 7.3 (7.3.4.6.x)." .

ex:LaborOrganization a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ;
          owl:someValuesFrom ex:LaborOrganizationRole ] ;
    rdfs:label "Labor Organization" ;
    skos:definition "An Organization that bears a labor-organization role in virtue of representing a group of employees in collective bargaining and labor-management relations." ;
    rdfs:comment "Union / employee-representative body in group 7.4." .

####################################################################
# 3. ROLES  (BFO role; borne only by Agents/Organizations, D4)
####################################################################

ex:HumanResourcesFunctionRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;   # role
    rdfs:label "Human Resources Function Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of being charged with developing and managing the human capital of a larger organization." .

ex:HumanResourcesProfessionalRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Human Resources Professional Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with carrying out human-capital management activities on behalf of an organization." .

ex:EmployeeRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Employee Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being engaged by an organization to perform assigned activities in exchange for compensation." .

ex:JobCandidateRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Job Candidate Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being considered by an organization to fill an open position." .

ex:HiringManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Hiring Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being responsible for deciding which candidate fills an open position." .

ex:ManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of exercising managerial authority within an organization." .

ex:StakeholderRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Stakeholder Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being able to affect or be affected by an organization's HR actions, objectives, and policies." .

ex:RecruitmentVendorRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Recruitment Vendor Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of supplying candidate-sourcing services to a focal organization under contract." .

ex:CertificationAuthorityRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Certification Authority Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of being empowered to issue and maintain certifications attesting to an agent's qualifications." .

ex:LaborOrganizationRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Labor Organization Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of representing a group of employees in collective bargaining and labor-management relations." .

####################################################################
# 4. CAPABILITIES  (Organization Capability ont00000568 for standing
#    HR functions read as R5 capabilities; realized in the underlying
#    acts. Group agents attach 'realized in' to the specific processes.)
####################################################################

ex:HumanCapitalManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Human Capital Management Capability" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to develop and manage its human capital, realized in the human-resources acts of section 7.0." ;
    rdfs:comment "Top shared capability for 'Manage human capital / HR function' standing functions." .

ex:WorkforcePlanningCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Workforce Planning Capability" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to plan, develop, and maintain its workforce strategy, plans, and policies." ;
    rdfs:comment "For standing functions in group 7.1." .

ex:TalentAcquisitionCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Talent Acquisition Capability" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to recruit, source, screen, and select employees." ;
    rdfs:comment "For standing functions in group 7.2." .

ex:EmployeeDevelopmentCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Employee Development Capability" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to onboard, train, develop, and manage the performance of its employees." ;
    rdfs:comment "For standing functions in group 7.3 (onboarding, performance, career development, training)." .

ex:EmployeeRelationsCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Employee Relations Capability" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to develop, maintain, and improve relationships with and among employees, including labor relations and grievance handling." ;
    rdfs:comment "For standing functions in group 7.4." .

ex:CompensationAndBenefitsCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Compensation and Benefits Capability" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to reward, recognize, compensate, and retain its employees and to administer their benefits and payroll." ;
    rdfs:comment "For standing functions in group 7.5. Group 7.5's group node (PCF 10412) is mapped to this capability; its R6 realized-in axioms for group 7.5 are added in the group 7.5 section." .

ex:WorkforceDeploymentCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Workforce Deployment Capability" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to redeploy, schedule, relocate, separate, and retire its employees." ;
    rdfs:comment "For standing functions in group 7.6." .

ex:WorkforceAnalyticsCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Workforce Analytics Capability" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to manage employee information, metrics, systems, and analytics in support of decision-making." ;
    rdfs:comment "For standing functions in group 7.7." .

ex:EmployeeCommunicationCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Employee Communication Capability" ;
    skos:definition "An Organization Capability that inheres in an organization in virtue of its capacity to plan, deliver, and manage communication and engagement with and among its employees." ;
    rdfs:comment "For standing functions in group 7.8." .

####################################################################
# 5. INPUT INFORMATION CONTENT ENTITIES
#    Genus = Descriptive ICE (ont00000853).
####################################################################

ex:StrategicGoals a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Strategic Goals" ;
    skos:definition "A Descriptive Information Content Entity that describes the strategic goals of an organization against which human-resource requirements are to be aligned." .

ex:SkillRequirementData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Skill Requirement Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the skills, knowledge, and competencies required by an organization or a position." .

ex:WorkforceData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Workforce Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the size, composition, capabilities, and characteristics of an organization's workforce." .

ex:EmployeeData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Employee Data" ;
    skos:definition "A Descriptive Information Content Entity that records information about individual employees, including their attributes, status, and history." .

ex:CandidateData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Candidate Data" ;
    skos:definition "A Descriptive Information Content Entity that describes a job candidate, including qualifications, experience, and application details." .

ex:CandidateBackgroundInformation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Candidate Background Information" ;
    skos:definition "A Descriptive Information Content Entity that records the criminal, commercial, and financial background of a job candidate." .

ex:MarketCompensationData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Compensation Data" ;
    skos:definition "A Descriptive Information Content Entity that describes prevailing compensation, benefits, and reward practices in a labor market or industry." .

ex:HRPolicyData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "HR Policy Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the financial, benefits, and human-resources policies of an organization bearing on compensation and benefits decisions." .

ex:PerformanceData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Data" ;
    skos:definition "A Descriptive Information Content Entity that records the performance of employees or of an HR program against defined measures." .

ex:LegalAndRegulatoryRequirements a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Legal and Regulatory Requirements" ;
    skos:definition "A Descriptive Information Content Entity that describes the employment-related legislation and regulatory requirements applicable to an organization's jurisdictions." .

ex:StakeholderRequirements a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Stakeholder Requirements" ;
    skos:definition "A Descriptive Information Content Entity that describes the requirements expressed by enterprise stakeholders, used as input to analytics and planning." .

ex:EmployeeFeedback a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Employee Feedback" ;
    skos:definition "A Descriptive Information Content Entity that records suggestions, opinions, attitudes, or survey responses gathered from employees." .

ex:SuggestionRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Employee Suggestion Register" ;
    skos:definition "A Descriptive Information Content Entity that records and tracks the suggestions and ideas collected from employees through an organization's suggestion program." ;
    rdfs:comment "Minted as the output of the suggestion-program-management facet de-conflated out of compound row P10530 (see ex:P10530_SuggestionProgram)." .

ex:BenefitClaim a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Benefit Claim" ;
    skos:definition "A Descriptive Information Content Entity that records a formal request by an employee asserting entitlement to a benefit." .

####################################################################
# 6. OUTPUT INFORMATION CONTENT ENTITIES
####################################################################
# 6a. DIRECTIVE ICEs (ont00000965): plans, strategies, policies,
#     programs, specifications, models, decisions -- prescribe action.

ex:HumanResourcesStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Human Resources Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes a long-term plan associating human-resource requirements with the strategic goals of an organization." .

ex:WorkforceStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Workforce Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's approach to administering, resourcing, and developing its workforce." .

ex:WorkforcePlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Workforce Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the current and future workforce and skill requirements of an organization or its units." .

ex:StaffingPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Staffing Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes how many people with which skills are to be hired to meet an organization's requirements." .

ex:HRPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "HR Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes rules and regulations governing the human-resources function." .

ex:CompensationStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Compensation Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes the combination of wages, salaries, and benefits employees receive and the terms on which it is paid." .

ex:CompensationStructure a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Compensation Structure" ;
    skos:definition "A Directive Information Content Entity that prescribes the components and pay bands of an organization's salary and compensation framework." .

ex:BenefitsAndRewardsPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Benefits and Rewards Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the rewards, commissions, and benefits to be provided to employees." .

ex:IncentivePlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Incentive Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes a scheme of awards and recognition designed to elicit desired employee outcomes." .

ex:SuccessionPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Succession Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes how key positions within an organization are to be continued, including identified successors and their development." .

ex:DiversityEquityInclusionPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Diversity, Equity, and Inclusion Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes measures for ensuring a diverse, equitable, and inclusive workforce." .

ex:HRProgramSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "HR Program Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the design and operation of a human-resources program such as a talent-development, talent-acquisition, engagement, or leadership program." ;
    rdfs:comment "Shared output class for the many 'Design/Develop ... program' nodes across groups 7.1, 7.3, 7.5." .

ex:WorkforceStrategyModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Workforce Strategy Model" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's overall approach to maximizing workforce performance by defining workforce goals, objectives, and expectations." .

ex:CompetencyManagementModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Competency Management Model" ;
    skos:definition "A Directive Information Content Entity that prescribes how an organization manages the competency levels of its human resources, integrating HR planning with business planning." .

ex:HRTechnologyStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "HR Technology Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes the selection and use of systems, technologies, and tools for operating the human-resources function." .

ex:HRMeasureSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "HR Measure Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the measures, metrics, and procedures used to evaluate the performance of the human-resources function." .

ex:JobRequisition a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Job Requisition" ;
    skos:definition "A Directive Information Content Entity that prescribes an authorized request to fill a vacant position, specifying the title, department, fill date, and required qualifications." .

ex:JobDescription a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Job Description" ;
    skos:definition "A Descriptive Information Content Entity that describes the responsibilities, essential functions, required knowledge and skills, and working conditions of a position." ;
    rdfs:comment "Descriptive (not Directive): it characterizes a position's nature rather than prescribing a specific course of action; distinct from the prescriptive JobRequisition that authorizes filling it." .

ex:JobOffer a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Job Offer" ;
    skos:definition "A Directive Information Content Entity that prescribes the terms (role, reporting, salary, bonus, benefits) on which an organization proposes to employ a selected candidate." .

ex:RecruitmentMethodSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Recruitment Method Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the methods and channels to be used for recruiting candidates." .

ex:OnboardingProgramSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Onboarding Program Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the induction and onboarding program through which new employees acquire the knowledge, skills, and behaviors to become effective organizational members." .

ex:PerformanceObjective a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Performance Objective" ;
    skos:definition "A Directive Information Content Entity that prescribes a target state of employee performance against which performance is to be assessed." .

ex:DevelopmentGuideline a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Employee Development Guideline" ;
    skos:definition "A Directive Information Content Entity that prescribes policies and procedures for identifying and addressing employee growth areas." .

ex:CareerPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Career Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes a future career path and development steps for an employee." .

ex:TrainingProgramSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Training Program Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the content, format, and delivery of an employee or management training program." .

ex:EmployeeCommunicationPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Employee Communication Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes how communication and engagement with and among employees are to be managed." .

ex:FamilySupportProgramSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Family Support Program Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's family-support provisions such as maternity leave, family-member care, and extended sick leave, aligned with applicable law." ;
    rdfs:comment "Minted as the definitional Directive output of P10509 (Develop family support systems), mirroring the directive outputs of the other 7.5 formulation acts (CompensationStructure, BenefitsAndRewardsPlan)." .

ex:WorkforceAnalysisMethodology a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Workforce Analysis Methodology" ;
    skos:definition "A Directive Information Content Entity that prescribes the research methodology selected for conducting workforce analytics." .

ex:CandidateSelectionDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Candidate Selection Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes which candidates are to be approved and which rejected for a position." .

ex:CollectiveBargainingAgreement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Collective Bargaining Agreement" ;
    skos:definition "A Directive Information Content Entity that prescribes the conditions of employment agreed between an employer and a group of employees." ;
    rdfs:comment "Directive: an agreement prescribing working conditions, output of the collective-bargaining acts in group 7.4." .

# Locally-minted Directive ICEs (no shared-vocab equivalent).

ex:HRDeliveryModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "HR Delivery Model" ;
    skos:definition "A Directive Information Content Entity that prescribes how an organization's human resources function delivers services to and interacts with employees." ;
    rdfs:comment "Minted locally (group 7.1, used by P21431): no shared-vocab ICE covers the HR service-delivery model specifically. Directive because it prescribes a service-delivery arrangement." ;
    skos:example "An HR shared-services and business-partner operating-model specification." .

ex:LearningProgramAlignmentSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Learning Program Alignment Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes how learning and training programs are to be contextualized and aligned with the core competencies and capabilities of the organization." ;
    rdfs:comment "Minted locally (group 7.3, used by P10491). Directive: it prescribes how programs are to be configured rather than merely describing them." ;
    skos:example "A specification mapping each training module to the organizational competencies it must build." .

ex:RelocationPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Relocation Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the arrangements for transferring an employee, their family, or a department to a new work location for an assignment." ;
    rdfs:comment "Minted locally (group 7.6, used by P17055/P10520). Directive because it prescribes relocation logistics/terms rather than describing a portion of reality." ;
    skos:example "A relocation package and timeline issued for an employee moving to an overseas posting." .

# 6b. DESCRIPTIVE ICEs (ont00000853): analyses, assessments,
#     registers, reports, records -- describe/represent reality.
#     'is about' (ont00001808) added where the artifact describes a
#     definite subject kind.

ex:StrategicHRNeedsAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Strategic HR Needs Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the current and future human-resource needs of an organization." .

ex:HRCostAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "HR Cost Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the costs and investments of the human-resources function." .

ex:CompensationBenchmark a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Compensation Benchmark" ;
    skos:definition "A Descriptive Information Content Entity that describes a comparison of an organization's benefits and rewards against those of other organizations." .

ex:PerformanceAppraisal a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;   # is about
          owl:someValuesFrom ex:Employee ] ;
    rdfs:label "Performance Appraisal" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of an employee's performance against defined objectives." ;
    rdfs:comment "Descriptive (Appraisal/judgement output, GOLDEN PRINCIPLE) and about the appraised Employee." .

ex:CandidateAssessment a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:JobCandidate ] ;
    rdfs:label "Candidate Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of a candidate's suitability derived from interviews and tests." ;
    rdfs:comment "Descriptive (Appraisal output) and about the assessed JobCandidate." .

ex:SkillsGapAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Skills Gap Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the difference between the skills required by an organization and those currently available in its workforce." .

ex:WorkforceAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:Employee ] ;
    rdfs:label "Workforce Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes insights derived from analyzing workforce data in support of organizational requirements." ;
    rdfs:comment "Output of the workforce-analytics acts in group 7.7; about the workforce (Employees)." .

ex:ResearchQuestion a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Research Question" ;
    skos:definition "A Descriptive Information Content Entity that registers a discrete research question framed from stakeholder requirements to guide workforce analytics." .

ex:HRReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "HR Report" ;
    skos:definition "A Descriptive Information Content Entity that describes employee-related information compiled and provided to management or stakeholders." .

ex:ObjectiveRealizationReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Objective Realization Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the extent to which HR goals and objectives have been achieved, measured against defined metrics." .

ex:ApplicantRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:JobCandidate ] ;
    rdfs:label "Applicant Record" ;
    skos:definition "A Descriptive Information Content Entity that records the application and disposition of an individual job candidate." ;
    rdfs:comment "About the JobCandidate it records; maintained in applicant-tracking systems (group 7.2.5)." .

ex:EmployeeRecord a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:Employee ] ;
    rdfs:label "Employee Record" ;
    skos:definition "A Descriptive Information Content Entity that records the information and history of an individual employee." ;
    rdfs:comment "About the Employee it records; captured and maintained in group 7.7." .

ex:EmployeeMetric a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Employee Metric" ;
    skos:definition "A Descriptive Information Content Entity that describes a measured indicator of employee productivity, efficiency, training, retention, or motivation." .

ex:CertificationRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Certification Record" ;
    skos:definition "A Descriptive Information Content Entity that records an agent's attained certification and its maintenance status." .

ex:BenefitReconciliationStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Benefit Reconciliation Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes the comparison between the benefits claimed by and the benefits owed to an employee." .

ex:PayStatement a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ;
          owl:someValuesFrom ex:Employee ] ;
    rdfs:label "Pay Statement" ;
    skos:definition "A Descriptive Information Content Entity that records an employee's wages, bonuses, deductions, gross pay, and net pay for a pay period." ;
    rdfs:comment "Pay slip output of payroll administration (7.5.4); about the paid Employee." .

ex:GrievanceResolution a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Grievance Resolution" ;
    skos:definition "A Descriptive Information Content Entity that records the disposition of a complaint raised by an employee." .

ex:EngagementSurveyResult a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Engagement Survey Result" ;
    skos:definition "A Descriptive Information Content Entity that describes employees' overall workplace satisfaction as ascertained through an engagement survey." .

# Locally-minted Descriptive ICEs (no shared-vocab equivalent).

ex:OnboardingProgramEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Onboarding Program Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the performance and effectiveness of an employee onboarding program based on new-employee feedback and reviews." ;
    rdfs:comment "Minted locally (group 7.3, used by P11243). Descriptive: it represents how the program performed rather than prescribing a course of action." ;
    skos:example "A written report summarizing new hires' survey responses on the induction program's usefulness." .

ex:PerformanceProgramEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Program Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the effectiveness of an organization's employee-performance-management program and the instruments used to measure performance." ;
    rdfs:comment "Minted locally (group 7.3, used by P10481)." ;
    skos:example "An HR review report concluding that the appraisal rubric should be revised." .

ex:LearningProgramEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Learning Program Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the coverage and effectiveness of an organization's learning and training programs." ;
    rdfs:comment "Minted locally (group 7.3, used by P21436)." ;
    skos:example "A quarterly oversight report on the impact of the organization's training catalog." .

ex:WorkforceDevelopmentNeedsAlignment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Workforce Development Needs Alignment" ;
    skos:definition "A Descriptive Information Content Entity that describes the correspondence between individual employee development needs and the development needs of the organization." ;
    rdfs:comment "Minted locally (group 7.3, used by P10490). Descriptive: it represents the reconciled needs picture; the prescriptive programs that act on it are separate Directive ICEs." ;
    skos:example "A matrix mapping each role's growth needs to organizational capability gaps." .

ex:ExperienceQualificationAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Experience Qualification Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the experience level required to qualify for a specific job or certification." ;
    rdfs:comment "Minted locally (group 7.3, used by P20128)." ;
    skos:example "A determination that a senior technician certification requires three years of practical field experience." .

ex:CertificationTestResult a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Certification Test Result" ;
    skos:definition "A Descriptive Information Content Entity that describes the outcome of a certification test administered to a member of the workforce." ;
    rdfs:comment "Minted locally (group 7.3, used by P20127)." ;
    skos:example "A score report recording that an employee passed the welding certification examination." .

ex:PositionClassification a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Position Classification" ;
    skos:definition "A Descriptive Information Content Entity that describes the classification of a position together with the experience and skills required to perform it." ;
    rdfs:comment "Minted locally (group 7.2, used by P20124): no shared-vocab ICE captured a position's classification/level-of-experience determination. Descriptive because it represents requirements rather than prescribing action." .

ex:EmployeeGrievance a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Employee Grievance" ;
    skos:definition "A Descriptive Information Content Entity that describes a complaint raised by an employee concerning the terms or conditions of employment." ;
    rdfs:comment "Minted locally (group 7.4, used by P10531): no provided input ICE captures an employee-raised complaint specifically. Descriptive because it represents a complaint rather than prescribing action." ;
    skos:example "A written complaint that a shift assignment violated the collective agreement." .

ex:RegulatoryEnvironmentAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Employment Regulatory Environment Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the employment-related legislation and regulatory requirements currently in force across the jurisdictions relevant to an organization." ;
    rdfs:comment "Minted locally (group 7.4, used by P21437) as the definitional output of monitoring the legal/regulatory environment. Descriptive: it represents the regulatory state of affairs rather than prescribing a course of action." ;
    skos:example "A quarterly brief summarizing labor-law changes in each operating country." .

ex:CompensationRequirement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Compensation Requirement" ;
    skos:definition "A Descriptive Information Content Entity that describes the compensation an employee or role requires given the organization's financial, benefits, and HR policies." ;
    rdfs:comment "Minted locally (group 7.5, used by P10501): no reuse-list ICE captures discerned compensation requirements; SkillRequirementData concerns skills, not pay. Descriptive (it represents requirements) rather than Directive." .

####################################################################
# ============ PROCESS CLASSES + GROUP CAPABILITIES ============
####################################################################

####################################################################
# GROUP 7.1 "Develop and manage human resources planning, policies,
#   and strategies" (group node PCF 17043 = catalog-only)
####################################################################

# --- group-7.1 standing functions modeled as capabilities (R5/R6) ---

ex:EmployerBrandingCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Employer Branding Capability" ;
    skos:definition "An Organization Capability that inheres in an organization's human resources function in virtue of its capacity to create, maintain, and communicate the organization's reputation and values so as to retain and attract employees." ;
    rdfs:comment "R5: APQC 7.1.1.9 (PCF 20606) 'Manage employer branding' is a standing function (ongoing create/maintain/communicate) with no natural end, so it is modeled as a capability, not a process." ;
    skos:example "An HR function's ongoing ability to sustain a positive employer brand across recruiting channels." .

ex:JobFamilyManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Job Family Management Capability" ;
    skos:definition "An Organization Capability that inheres in an organization's human resources function in virtue of its capacity to oversee groupings of positions sharing similar education, skills, training, or experience." ;
    rdfs:comment "R5: APQC 7.1.1.10 (PCF 21432) 'Manage job families and positions' is a standing oversight function with no natural end, so it is modeled as a capability, not a process." ;
    skos:example "An HR function's continuing management of job-family architecture and position classifications." .

####################################################################
# 7.1.1  (PCF 20958)  "Develop human resources strategy"
####################################################################

ex:P20958 a owl:Class ;
    ex:pcfID "20958" ; ex:hierarchyID "7.1.1" ;
    ex:apqcSourceText "Creating a long-term plan to associate human resource requirements with the strategic goals of the company to ensure that there is enough qualified staffing to achieve those goals, to maintain competitive advantage and to reduce employee turnover." ;
    rdfs:label "Develop human resources strategy" ;
    skos:definition "An Act of Formulation that has as input strategic goals and produces a human resources strategy associating human-resource requirements with the organization's strategic goals." ;
    rdfs:comment "Models APQC 7.1.1 as a bounded occurrent. Its APQC children are process parts (cco:ont00001777), not subclasses." ;
    skos:example "An HR leadership team formulates a three-year HR strategy aligned to corporate goals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicGoals ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HumanResourcesStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10418 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10419 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21430 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21431 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10420 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10421 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10422 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10432 ] .

ex:P10418 a owl:Class ;
    ex:pcfID "10418" ; ex:hierarchyID "7.1.1.1" ;
    ex:apqcSourceText "Strategically defining the current and future needs for developing an efficient HR strategy." ;
    rdfs:label "Identify strategic HR needs" ;
    skos:definition "An Act of Analysis that has as input strategic goals and workforce data and produces a strategic HR needs assessment of the organization's current and future human-resource needs." ;
    rdfs:comment "Genus is Act of Analysis (Information Processing): the output is a descriptive needs assessment, not a prescription (GOLDEN PRINCIPLE)." ;
    skos:example "An HR analyst assesses current and projected staffing needs ahead of strategy development." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicGoals ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicHRNeedsAssessment ] .

ex:P10419 a owl:Class ;
    ex:pcfID "10419" ; ex:hierarchyID "7.1.1.2" ;
    ex:apqcSourceText "Outlining the charge and duty of the HR function by defining its responsibility areas, as well as ensuring its accountability. Establish the HR function by laying out the roles and responsibilities for this function and the rules and regulations guiding HR. Define the goals and objectives of the HR, as well as a mission and vision for this function. Create a mechanism involving a set of policies, code of conduct, and institutional procedure to ensure HR accountability." ;
    rdfs:label "Define HR and business function roles and accountability" ;
    skos:definition "An Act of Formulation that produces an HR program specification laying out the roles, responsibilities, goals, mission, and accountability mechanisms of the human resources function." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive specification of roles/accountability (Directive ICE)." ;
    skos:example "HR leadership documents the HR function's charter, responsibilities, and accountability rules." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRProgramSpecification ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:HumanResourcesProfessional ] .

ex:P21430 a owl:Class ;
    ex:pcfID "21430" ; ex:hierarchyID "7.1.1.3" ;
    ex:apqcSourceText "Establishing the roles that are required to execute the HR function.  This process also examines the organizational structure required to support the organization." ;
    rdfs:label "Determine HR function roles and structure" ;
    skos:definition "An Act of Formulation that produces an HR program specification establishing the roles and supporting organizational structure required to execute the human resources function." ;
    rdfs:comment "Genus is Act of Formulation: output prescribes roles and structure (Directive ICE)." ;
    skos:example "HR defines the role set and reporting structure needed to run the HR function." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRProgramSpecification ] .

ex:P21431 a owl:Class ;
    ex:pcfID "21431" ; ex:hierarchyID "7.1.1.4" ;
    ex:apqcSourceText "Determining how an organization's human resources department offers services to and interacts with employees." ;
    rdfs:label "Determine HR delivery model" ;
    skos:definition "An Act of Formulation that produces an HR delivery model prescribing how the human resources department delivers services to and interacts with employees." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive delivery-model specification (Directive ICE)." ;
    skos:example "HR adopts a shared-services-plus-business-partner delivery model." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRDeliveryModel ] .

ex:P10420 a owl:Class ;
    ex:pcfID "10420" ; ex:hierarchyID "7.1.1.5" ;
    ex:apqcSourceText "Ascertaining the costs and expenses of the HR function. Identify and report HR investments using, for example, a cost approach or a present value of future earnings approach." ;
    rdfs:label "Determine HR costs" ;
    skos:definition "An Act of Analysis that has as input HR policy data and produces an HR cost analysis ascertaining and reporting the costs and investments of the human resources function." ;
    rdfs:comment "Genus is Act of Analysis: output is a descriptive cost analysis, not a prescription (GOLDEN PRINCIPLE)." ;
    skos:example "An HR analyst reports the fully loaded cost of the HR function for the fiscal year." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRCostAnalysis ] .

ex:P10421 a owl:Class ;
    ex:pcfID "10421" ; ex:hierarchyID "7.1.1.6" ;
    ex:apqcSourceText "Evaluating the performance of HR function. Lay out the course of HR procedures that would formulate a plan of action needed to fulfill strategic HR needs. Deploy measures such as hiring policies, leave management, internal code of conducts, and compensation structure." ;
    rdfs:label "Establish HR measures" ;
    skos:definition "An Act of Formulation that produces an HR measure specification laying out the HR procedures and measures needed to fulfill strategic HR needs." ;
    rdfs:comment "Genus is Act of Formulation: despite 'evaluating', the definitional output is a prescriptive specification of measures/procedures (Directive ICE)." ;
    skos:example "HR establishes the set of policies and measures (hiring, leave, conduct) implementing the HR strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRMeasureSpecification ] .

ex:P10422 a owl:Class ;
    ex:pcfID "10422" ; ex:hierarchyID "7.1.1.7" ;
    ex:apqcSourceText "Conveying the strategies of HR function to employees and management. Effectively explain the vision, plans, and anticipated benefits of the HR strategy employees, as well as the public. Develop statements and messages that are easy to read, informative, and relevant to the audience." ;
    rdfs:label "Communicate HR strategies" ;
    skos:definition "An Act of Communication that disseminates a held human resources strategy to employees and management in accordance with an employee communication plan, conveying the strategy's vision, plans, and benefits." ;
    rdfs:comment "Re-anchored from ex:ActOfAdministration to cco:ont00000402 (Act of Communication, verified: a Planned Act transferring an ICE from one Agent to another). Administration was a false-friend genus driven by 'Manage'-style framing; the source ('Conveying the strategies ... explain the vision, plans ...') is dissemination, consistent with P10532 and the 7.2/7.7 communication rows. Per the GOLDEN PRINCIPLE the act disseminates a held directive rather than producing one: ex:HumanResourcesStrategy is the disseminated has-input and ex:EmployeeCommunicationPlan is a governing has-input (changed from has-output), mirroring P10532; employees and management personnel are definitional recipients." ;
    skos:example "HR rolls out the new HR strategy to all staff in line with the employee communication plan." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; entailed by CCO, asserted for standalone SHACL S2/S5)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HumanResourcesStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeCommunicationPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ManagementPersonnel ] .

ex:P10432 a owl:Class ;
    ex:pcfID "10432" ; ex:hierarchyID "7.1.1.8" ;
    ex:apqcSourceText "Creating a strategy for the use of systems/technologies/tools in operating the HR function. Create a strategy concerning the use and utility of HR support tools and technologies. Decide what specific tools to use and in what quantity. Determine the levels of technology required for the HR management." ;
    rdfs:label "Develop strategy for HR systems/technologies/tools" ;
    skos:definition "An Act of Formulation that produces an HR technology strategy prescribing the systems, technologies, and tools to be used in operating the human resources function." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive technology strategy (Directive ICE)." ;
    skos:example "HR formulates a roadmap selecting its HRIS, payroll, and talent tooling." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRTechnologyStrategy ] .

####################################################################
# 7.1.2  (PCF 17045)  "Develop and implement workforce strategy and
#   policies"
####################################################################

ex:P17045 a owl:Class ;
    ex:pcfID "17045" ; ex:hierarchyID "7.1.2" ;
    ex:apqcSourceText "Creating and executing strategies and policies for smooth administration of work force. Determine and gather skill requirements. Plan the requirements for employee resourcing per unit. Create compensation, succession, HR program, and employee diversity plans. Develop and administer policies for HR. Develop benefits for employees. Create models for work force strategies." ;
    rdfs:label "Develop and implement workforce strategy and policies" ;
    skos:definition "An Act of Formulation that has as input skill requirement data and produces a workforce strategy together with the compensation, succession, diversity, benefit, and policy artifacts that govern the workforce." ;
    rdfs:comment "Models APQC 7.1.2 as a bounded occurrent. Its APQC children are process parts (cco:ont00001777). Output generalized as ex:WorkforceStrategy; specific plan artifacts are produced by the child processes." ;
    skos:example "An HR function develops and rolls out its annual workforce strategy and supporting policies." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SkillRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10423 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10424 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10425 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10426 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16938 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10427 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21433 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11622 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11623 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10428 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10429 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10430 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10431 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10433 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20122 ] .

ex:P10423 a owl:Class ;
    ex:pcfID "10423" ; ex:hierarchyID "7.1.2.1" ;
    ex:apqcSourceText "Evaluating the current and future skill requirements of the organization with regard to the overall corporate strategy of the organization and market conditions. Identify and establish the minimum skills needed for the requisite HR needs." ;
    rdfs:label "Perform workforce planning" ;
    skos:definition "An Act of Formulation that has as input skill requirement data and strategic goals and produces a workforce plan establishing the skills and staffing the organization requires." ;
    rdfs:comment "Genus is Act of Formulation: the definitional output is a prescriptive workforce plan (Directive ICE)." ;
    skos:example "HR plans the skills and headcount the organization will need over the planning horizon." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SkillRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforcePlan ] .

ex:P10424 a owl:Class ;
    ex:pcfID "10424" ; ex:hierarchyID "7.1.2.2" ;
    ex:apqcSourceText "Determining the requirements for employees and the need for employee resourcing for each every unit/function. Lay out a plan detailing employee resourcing requirements of individual functions and the organization as a whole." ;
    rdfs:label "Perform operational workforce planning" ;
    skos:definition "An Act of Formulation that has as input workforce data and produces a staffing plan detailing employee-resourcing requirements for each unit and for the organization as a whole." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive staffing plan (Directive ICE)." ;
    skos:example "HR lays out per-department headcount and resourcing requirements for the year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StaffingPlan ] .

ex:P10425 a owl:Class ;
    ex:pcfID "10425" ; ex:hierarchyID "7.1.2.3" ;
    ex:apqcSourceText "Designing a plan that specifies the combination of wages, salaries, and benefits the employees receive in exchange for work. Define the total amount of compensation, in addition to the manner in which the compensation is paid and the purposes for which employees can receive bonuses, salary increases, and incentives." ;
    rdfs:label "Develop compensation strategy" ;
    skos:definition "An Act of Formulation that has as input market compensation data and produces a compensation strategy specifying the combination of wages, salaries, and benefits employees receive in exchange for work." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive compensation strategy (Directive ICE). Has process part 7.1.2.3.1 (establish incentive strategy)." ;
    skos:example "Total-rewards team designs the firm's compensation strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketCompensationData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompensationStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10210 ] .

ex:P10210 a owl:Class ;
    ex:pcfID "10210" ; ex:hierarchyID "7.1.2.3.1" ;
    ex:apqcSourceText "Creating a scheme of awards and recognition for sales employees to promote a results-based culture. Create specific incentives to reach desired outcomes, such as landing key clients, growing the customer base, providing exceptional servicing, and increasing profit margins." ;
    rdfs:label "Establish incentive strategy" ;
    skos:definition "An Act of Formulation that produces an incentive plan specifying a scheme of awards and recognition designed to drive desired employee outcomes." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive incentive plan (Directive ICE). Process part of 7.1.2.3." ;
    skos:example "HR designs a sales-incentive program rewarding new-client acquisition." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IncentivePlan ] .

ex:P10426 a owl:Class ;
    ex:pcfID "10426" ; ex:hierarchyID "7.1.2.4" ;
    ex:apqcSourceText "Creating and implementing the plan for continuation of key positions within the organization. Identify internal people with the potential to fill key business leadership positions. Provide critical development experiences to employees who can move into important roles. Engage leaders to support the development of high-potential leaders." ;
    rdfs:label "Develop succession plan" ;
    skos:definition "An Act of Formulation that has as input employee data and produces a succession plan for the continuation of key positions within the organization." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive succession plan (Directive ICE)." ;
    skos:example "HR identifies high-potential leaders and documents a succession plan for key roles." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SuccessionPlan ] .

ex:P16938 a owl:Class ;
    ex:pcfID "16938" ; ex:hierarchyID "7.1.2.5" ;
    ex:apqcSourceText "Creating a program that incorporates incentives and compensation put forth by the organization to recognize high performing workers and excellence in leadership." ;
    rdfs:label "Develop high performers/leadership programs" ;
    skos:definition "An Act of Formulation that produces an HR program specification for recognizing high-performing workers and excellence in leadership through incentives and compensation." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive program specification (Directive ICE)." ;
    skos:example "HR creates a leadership-excellence recognition program with tied incentives." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRProgramSpecification ] .

ex:P10427 a owl:Class ;
    ex:pcfID "10427" ; ex:hierarchyID "7.1.2.6" ;
    ex:apqcSourceText "Creating and implementing the plan for ensuring a diverse work force. Develop and hire employees with varying characteristics including, but not limited to, religious and political beliefs, gender, ethnicity, education, socioeconomic background, sexual orientation, and geographic location." ;
    rdfs:label "Develop diversity, equity, and inclusion plan" ;
    skos:definition "An Act of Formulation that produces a diversity, equity, and inclusion plan for ensuring a diverse workforce." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive DEI plan (Directive ICE). Implementation of the plan is the sibling process 7.1.2.7." ;
    skos:example "HR develops a DEI plan setting representation goals and hiring practices." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DiversityEquityInclusionPlan ] .

ex:P21433 a owl:Class ;
    ex:pcfID "21433" ; ex:hierarchyID "7.1.2.7" ;
    ex:apqcSourceText "Execution of diversity, equity, and inclusion plans within an organization.  Often called a DEI plan." ;
    rdfs:label "Implement diversity, equity, and inclusion plan" ;
    skos:definition "A Planned Act that has as input a diversity, equity, and inclusion plan and carries out that plan within the organization." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): implementation is the execution of a held Directive ICE (the DEI plan), not the formulation of a new directive (GOLDEN PRINCIPLE -- no formulation output)." ;
    skos:example "HR rolls out the DEI plan's hiring and inclusion initiatives across business units." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DiversityEquityInclusionPlan ] .

ex:P11622 a owl:Class ;
    ex:pcfID "11622" ; ex:hierarchyID "7.1.2.8" ;
    ex:apqcSourceText "Identifying skills, knowledge, and attributes that need enhancement in order to perform a job. Develop the appropriate training programs. These programs can be computer-based, classroom, or on-the-job training, etc." ;
    rdfs:label "Design talent development program" ;
    skos:definition "An Act of Formulation that has as input a skills gap analysis and produces a training program specification for enhancing the skills, knowledge, and attributes needed to perform jobs." ;
    rdfs:comment "Genus is Act of Formulation: definitional output is a prescriptive training program specification (Directive ICE)." ;
    skos:example "L&D designs a blended training program closing identified skill gaps." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SkillsGapAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TrainingProgramSpecification ] .

ex:P11623 a owl:Class ;
    ex:pcfID "11623" ; ex:hierarchyID "7.1.2.9" ;
    ex:apqcSourceText "Developing a program to entice prospective resources to engage with the organization for a position of employment." ;
    rdfs:label "Design talent acquisition program" ;
    skos:definition "An Act of Formulation that produces an HR program specification for attracting prospective candidates to engage with the organization for employment." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive talent-acquisition program specification (Directive ICE)." ;
    skos:example "Recruiting designs an employer-attraction and sourcing program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRProgramSpecification ] .

ex:P10428 a owl:Class ;
    ex:pcfID "10428" ; ex:hierarchyID "7.1.2.10" ;
    ex:apqcSourceText "Creating HR programs and services such as employee engagements programs to promote positive employee behavior. Create a variety of programs and services to support employees' professional and personal needs at work and at home." ;
    rdfs:label "Develop other HR programs" ;
    skos:definition "An Act of Formulation that produces an HR program specification for additional HR programs and services supporting employees' professional and personal needs." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive program specification (Directive ICE)." ;
    skos:example "HR launches an employee-engagement and wellbeing program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRProgramSpecification ] .

ex:P10429 a owl:Class ;
    ex:pcfID "10429" ; ex:hierarchyID "7.1.2.11" ;
    ex:apqcSourceText "Creating rules and regulations that govern the HR function. Develop a policy plan that serves as a guideline for setting rules and regulations that help in achieving the HR goals and objectives." ;
    rdfs:label "Develop HR policies" ;
    skos:definition "An Act of Formulation that produces an HR policy comprising the rules and regulations that govern the human resources function." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive HR policy (Directive ICE)." ;
    skos:example "HR drafts the leave, conduct, and remote-work policies." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRPolicy ] .

ex:P10430 a owl:Class ;
    ex:pcfID "10430" ; ex:hierarchyID "7.1.2.12" ;
    ex:apqcSourceText "Ensuring rules and regulations are followed and are flexible enough to accommodate indispensable deviations." ;
    rdfs:label "Administer HR policies" ;
    skos:definition "An Act of Administration that has as input an HR policy and enforces its rules and regulations while accommodating necessary deviations." ;
    rdfs:comment "Genus is Act of Administration: the act enacts and enforces a held directive (the HR policy) rather than producing a new directive. R5: treated as a repeatable bounded administration act, not a standing capacity." ;
    skos:example "HR reviews a policy-exception request and grants a documented deviation." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HRPolicy ] .

ex:P10431 a owl:Class ;
    ex:pcfID "10431" ; ex:hierarchyID "7.1.2.13" ;
    ex:apqcSourceText "Planning benefits in kind (also called fringe benefits, perquisites, or perks). Include various types of non-wage compensations provided to employees in addition to normal wages or salaries." ;
    rdfs:label "Plan employee benefits" ;
    skos:definition "An Act of Formulation that produces a benefits and rewards plan specifying the non-wage benefits provided to employees in addition to wages or salaries." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive benefits and rewards plan (Directive ICE)." ;
    skos:example "Total-rewards plans the fringe-benefit package for the coming year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BenefitsAndRewardsPlan ] .

ex:P10433 a owl:Class ;
    ex:pcfID "10433" ; ex:hierarchyID "7.1.2.14" ;
    ex:apqcSourceText "Creating and implementing models for effectively strategizing the work force of the organization. Develop a model that specifies the organization's overall approach for maximizing the performance of its work force by defining the goals, objectives, and expectations of the work force. Manage all aspects of performance required for the work force to function, including recruitment, selection, retention, and professional development." ;
    rdfs:label "Develop workforce strategy models" ;
    skos:definition "An Act of Formulation that produces a workforce strategy model specifying the organization's overall approach for maximizing workforce performance." ;
    rdfs:comment "Genus is Act of Formulation: output is a prescriptive workforce strategy model (Directive ICE). Implementation is the sibling process 7.1.2.15." ;
    skos:example "HR builds a workforce strategy model covering recruitment, retention, and development." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceStrategyModel ] .

ex:P20122 a owl:Class ;
    ex:pcfID "20122" ; ex:hierarchyID "7.1.2.15" ;
    ex:apqcSourceText "Implementing models for effectively strategizing the work force of the organization. Carry out all aspects of performance required for the work force to function, including recruitment, selection, retention, and professional development." ;
    rdfs:label "Implement workforce strategy models" ;
    skos:definition "A Planned Act that has as input a workforce strategy model and carries out that model across recruitment, selection, retention, and development." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): implementation executes a held Directive ICE (the workforce strategy model), not formulate a new one (GOLDEN PRINCIPLE)." ;
    skos:example "HR operationalizes the workforce strategy model across all functions." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforceStrategyModel ] .

####################################################################
# 7.1.3  (PCF 10417)  "Monitor and update strategy, plans, and policies"
####################################################################

ex:P10417 a owl:Class ;
    ex:pcfID "10417" ; ex:hierarchyID "7.1.3" ;
    ex:apqcSourceText "Supervising the HR strategy, plans, and policies in order to refurbish them whenever needed. Determine the performance of HR plans and policies by measuring the objective achievement rate and its contribution to the overall business strategy. Ensure that information about these plans and strategies is effectively communicated to various stakeholders. Incorporate any suggestions by these stakeholders when revising HR plans and policies." ;
    rdfs:label "Monitor and update strategy, plans, and policies" ;
    skos:definition "An Act of Administration that has as input performance data and an HR policy and oversees and revises the organization's HR strategy, plans, and policies." ;
    rdfs:comment "Models APQC 7.1.3 as a bounded occurrent (a monitoring-and-revision cycle). Its APQC children are process parts (cco:ont00001777). Anchored at Act of Administration since the umbrella act supervises and maintains held directives." ;
    skos:example "HR runs its annual review cycle measuring and revising the HR strategy." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10434 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10435 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10436 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10438 ] .

ex:P10434 a owl:Class ;
    ex:pcfID "10434" ; ex:hierarchyID "7.1.3.1" ;
    ex:apqcSourceText "Determining the accomplishment of HR goals and objectives. Evaluate the effectiveness of the HR function by estimating the present rate of achievement of the established objectives. Use metrics to determine if the objectives are being realized. Leverage measures such as turnover, training, return on human capital, costs of labor, and expenses per employee." ;
    rdfs:label "Measure realization of objectives" ;
    skos:definition "An Act of Appraisal that has as input performance data and produces an objective realization report estimating the achievement rate of established HR objectives." ;
    rdfs:comment "Genus is Act of Appraisal (cco:ont00000636): the act evaluates/judges attainment; its output is a descriptive report (GOLDEN PRINCIPLE)." ;
    skos:example "HR computes turnover and ROI metrics to gauge objective attainment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ObjectiveRealizationReport ] .

ex:P10435 a owl:Class ;
    ex:pcfID "10435" ; ex:hierarchyID "7.1.3.2" ;
    ex:apqcSourceText "Determining the role of HR function in implementing the organizational strategy. Measure the correlation between the HR performance and the overall business strategy. Calculate the amount of contribution of the HR function to the overall business growth." ;
    rdfs:label "Measure contribution to business strategy" ;
    skos:definition "An Act of Appraisal that has as input performance data and produces an HR report assessing the human resources function's contribution to the overall business strategy." ;
    rdfs:comment "Genus is Act of Appraisal: the act judges HR's strategic contribution; output is a descriptive report (GOLDEN PRINCIPLE)." ;
    skos:example "HR quantifies its correlation with business growth in a contribution report." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRReport ] .

ex:P10436 a owl:Class ;
    ex:pcfID "10436" ; ex:hierarchyID "7.1.3.3" ;
    ex:apqcSourceText "Conveying the plans for HR function to stakeholders. Ensure that the HR plans and strategy are effectively communicated to the people who can affect or be affected by the organization's actions, objectives, and policies such as the creditors, shareholders, employees, and suppliers. Provide regular updates to these stakeholders to ensure effective communication." ;
    rdfs:label "Communicate plans and provide updates to stakeholders" ;
    skos:definition "An Act of Communication that disseminates a held human resources strategy and regular updates to stakeholders in accordance with an employee communication plan." ;
    rdfs:comment "Re-anchored from ex:ActOfAdministration to cco:ont00000402 (Act of Communication, verified). Same defect as P10422: Administration was a false-friend genus and inconsistent with the module's other communication anchors. Per the GOLDEN PRINCIPLE conveying plans disseminates held directives rather than producing a communication plan, so ex:EmployeeCommunicationPlan is changed from has-output to a governing has-input (mirroring P10532) and ex:HumanResourcesStrategy is the disseminated has-input; ex:Stakeholder remains the definitional recipient participant." ;
    skos:example "HR issues quarterly HR-strategy updates to creditors, shareholders, employees, and suppliers per the communication plan." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; entailed by CCO, asserted for standalone SHACL S2/S5)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HumanResourcesStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeCommunicationPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

ex:P10438 a owl:Class ;
    ex:pcfID "10438" ; ex:hierarchyID "7.1.3.4" ;
    ex:apqcSourceText "Reassessing the strategies, plans, and policies of the HR function, with the objective of revising them. Revisit the schematic plans for the HR function. Taking stock of any suggestions or feedback from the stakeholders, revamp the blueprint of HR strategies and plans." ;
    rdfs:label "Review and revise HR plans" ;
    skos:definition "An Act of Formulation that has as input HR policy data and employee feedback and produces a revised HR policy reflecting reassessed HR strategies and plans." ;
    rdfs:comment "Genus is Act of Formulation: although it begins by reassessing, the definitional output is the revised prescriptive plan/policy (Directive ICE), per GOLDEN PRINCIPLE." ;
    skos:example "HR revamps its plans incorporating stakeholder feedback from the review." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HRPolicyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRPolicy ] .

####################################################################
# 7.1.4  (PCF 17046)  "Develop competency management models"
####################################################################

ex:P17046 a owl:Class ;
    ex:pcfID "17046" ; ex:hierarchyID "7.1.4" ;
    ex:apqcSourceText "Creating and implementing the tools for managing the competency levels of HR. Design a model for integrating HR planning with business planning. Assess current HR capacity based on the competencies against the capacity needed to achieve the vision, mission, and business goals of the organization. Consider factors such as employee development, career path, compensation policies, and performance management." ;
    rdfs:label "Develop competency management models" ;
    skos:definition "An Act of Formulation that has as input workforce data and produces a competency management model integrating HR planning with business planning to manage HR competency levels." ;
    rdfs:comment "Models APQC 7.1.4 as a bounded occurrent. Genus is Act of Formulation: output is a prescriptive competency management model (Directive ICE)." ;
    skos:example "HR builds a competency model mapping role competencies to business goals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetencyManagementModel ] .

####################################################################
# GROUP 7.2 "Recruit, source, and select employees" (PCF 10410)
####################################################################

# --- group-7.2 standing functions modeled as capabilities (R5/R6) ---

ex:RecruitmentVendorManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;   # realized in
          owl:someValuesFrom ex:P10440 ] ;
    rdfs:label "Recruitment Vendor Management Capability" ;
    skos:definition "An Organization Capability that is realized in Acts of establishing and maintaining ongoing relationships with recruitment vendors to support sourcing." ;
    rdfs:comment "APQC 7.2.2.3 (PCF 10455) is a standing function ('establishing and maintaining relationships', no natural end), so per R5/R6 it is modeled as a capability rather than a process class. R6 fix: realized-in relaxed from the narrow ex:P10454 (Perform recruiting activities/events = career fairs/campus events, which does not realize vendor-relationship management) to the group sourcing process ex:P10440 (Recruit/Source candidates), whose source text explicitly covers 'Manage relationships with third-party agencies'." .

ex:EmployeeReferralProgramCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P10440 ] ;
    rdfs:label "Employee Referral Program Capability" ;
    skos:definition "An Organization Capability that is realized in Acts of operating an employee-referral program in which employees are rewarded for referring qualified candidates." ;
    rdfs:comment "APQC 7.2.2.4 (PCF 17047) is a standing function (ongoing program/strategy management), modeled as a capability per R5/R6. R6 fix: realized-in corrected from the narrow ex:P10454 (Perform recruiting activities/events) -- a copy-paste mis-anchor, since running career fairs does not realize referral-program operation -- to the group sourcing process ex:P10440 (Recruit/Source candidates), whose source text explicitly covers 'Manage employee referral programs'." .

ex:RecruitmentChannelManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;
          owl:someValuesFrom ex:P10440 ] ;
    rdfs:label "Recruitment Channel Management Capability" ;
    skos:definition "An Organization Capability that is realized in Acts of establishing and maintaining recruitment channels and the processes that operate them." ;
    rdfs:comment "APQC 7.2.2.5 (PCF 17048) is a standing function ('establishing and maintaining channels', open-ended), modeled as a capability per R5/R6. R6 fix: realized-in corrected from the narrow ex:P10454 (Perform recruiting activities/events) -- which does not realize channel-management -- to the group sourcing process ex:P10440 (Recruit/Source candidates), under which recruitment-channel operation occurs (P10453 Determine recruitment methods and channels is a part of P10440)." .

####################################################################
# 7.2 (PCF 10410) + 7.2.1 (PCF 10439) and children
####################################################################

ex:P10410 a owl:Class ;
    ex:pcfID "10410" ; ex:hierarchyID "7.2" ;
    ex:apqcSourceText "Determining and handling employee requirements. Recruit or source the candidates as per the requirements. Screen and select the most appropriate candidates. Take care of the newly hired and re-hired employees. Maintain records of information for all applicants." ;
    rdfs:label "Recruit, source, and select employees" ;
    skos:definition "An Act of Administration that handles employee requisitions, sources and screens candidates, hires the selected candidates, and maintains applicant records, so as to staff an organization's open positions." ;
    rdfs:comment "Models APQC process group 7.2 as an occurrent. Its APQC Process children are process parts (cco:ont00001777), not subclasses." ;
    skos:example "An organization's recruiting team runs an end-to-end hiring cycle for a set of open positions." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10439 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10440 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20123 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10443 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10444 ] .

ex:P10439 a owl:Class ;
    ex:pcfID "10439" ; ex:hierarchyID "7.2.1" ;
    ex:apqcSourceText "Handling the requirements for new employees. Create and open job requisitions by clearly defining the job descriptions. Post these requirements internally and externally, and modify them as appropriate. Manage the dates of the whole requisition process." ;
    rdfs:label "Manage employee requisitions" ;
    skos:definition "An Act of Administration that creates, opens, posts, modifies, and schedules job requisitions in order to handle an organization's requirements for new employees." ;
    rdfs:comment "Modeled as a bounded administration process (not a standing function): each requisition cycle has an identifiable beginning and end." ;
    skos:example "An HR team opens, posts, and tracks a batch of requisitions for a hiring round." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10445 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10447 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10446 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10448 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10450 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10451 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10452 ] .

ex:P10445 a owl:Class ;
    ex:pcfID "10445" ; ex:hierarchyID "7.2.1.1" ;
    ex:apqcSourceText "Creating a correspondence between the plan for hiring new employees and the desired employee requirements. Staff an adequate amount of people with the appropriate skills to effectively accomplish its legislative, regulatory, service, and production requirements." ;
    rdfs:label "Align staffing plan to work force plan and business unit strategies/resource needs" ;
    skos:definition "An Act of Formulation that takes a workforce plan as input and produces a staffing plan brought into correspondence with the organization's workforce requirements." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (Act of Planning) because aligning produces a directive staffing plan; output and genus agree (GOLDEN PRINCIPLE)." ;
    skos:example "An HR planner reconciles the hiring plan with the approved workforce plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforcePlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StaffingPlan ] .

ex:P10447 a owl:Class ;
    ex:pcfID "10447" ; ex:hierarchyID "7.2.1.2" ;
    ex:apqcSourceText "Creating descriptions for job requisitions. Define the normal components of a job description, such as the overall position description with general areas of responsibility listed, essential functions of the job described with a couple of examples of each, required knowledge, skills, abilities, required education and experience, a description of the physical demands, and a description of the work environment." ;
    rdfs:label "Develop and maintain job descriptions" ;
    skos:definition "An Act of Information Processing that composes and maintains a job description detailing a position's responsibilities, required competencies, and work environment." ;
    rdfs:comment "Anchored under cco:ont00000366 (Act of Information Processing), not Act of Planning, because a job description is a Descriptive ICE (it describes a position); genus agrees with descriptive output (GOLDEN PRINCIPLE)." ;
    skos:example "A recruiter drafts the job description for an open analyst role." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:JobDescription ] .

ex:P10446 a owl:Class ;
    ex:pcfID "10446" ; ex:hierarchyID "7.2.1.3" ;
    ex:apqcSourceText "Developing specific job requisitions, and ensuring their accessibility. Create and open a job requisition to fill the vacant positions within the organization. Clearly describe the job title, department, fill date, and the requisite skills and qualifications for the job." ;
    rdfs:label "Open job requisitions" ;
    skos:definition "An Act of Formulation that creates and opens a job requisition prescribing the title, department, fill date, and required qualifications for a vacant position." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (Act of Planning): a job requisition is a Directive ICE authorizing a hire; output and genus agree." ;
    skos:example "A hiring manager opens a requisition to fill a vacated engineering seat." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:JobRequisition ] .

ex:P10448 a owl:Class ;
    ex:pcfID "10448" ; ex:hierarchyID "7.2.1.4" ;
    ex:apqcSourceText "Posting and advertising job descriptions. Display open job descriptions internally and externally. Use public portals, online portals, and websites to upload these requisitions in order for applications to be received." ;
    rdfs:label "Post job requisitions" ;
    skos:definition "An Act of Communication that disseminates open job requisitions internally and externally through portals and websites so that applications can be received." ;
    rdfs:comment "Anchored under cco:ont00000402 (Act of Communication): the act transfers an existing requisition ICE to prospective applicants rather than producing a new artifact." ;
    skos:example "Recruiting posts a requisition to the careers site and a job board." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; entailed by CCO, asserted for standalone SHACL S2/S5)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:JobRequisition ] .

ex:P10450 a owl:Class ;
    ex:pcfID "10450" ; ex:hierarchyID "7.2.1.5" ;
    ex:apqcSourceText "Making the necessary alterations to job requisitions. Revamp or revise the job requisitions in case a position is filled or is not vacant anymore, as well as in case of any new openings. (It involves Manage the internal/external job posting websites [10449] to make the necessary changes.)" ;
    rdfs:label "Modify job requisitions" ;
    skos:definition "An Act of Administration that revises existing job requisitions to reflect filled positions, closed vacancies, or new openings." ;
    rdfs:comment "Administration (not formulation) because it amends an existing directive artifact rather than composing a new one. Output is the revised ex:JobRequisition (non-definitional revision, recorded here)." ;
    skos:example "A recruiter updates a requisition's status after the role is filled." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:JobRequisition ] .

ex:P10451 a owl:Class ;
    ex:pcfID "10451" ; ex:hierarchyID "7.2.1.6" ;
    ex:apqcSourceText "Informing and communicating with the hiring manager. Notify the manager responsible for the hiring process in cases of any new position openings or changes." ;
    rdfs:label "Notify hiring manager" ;
    skos:definition "An Act of Communication that informs the hiring manager of new position openings or changes to a requisition." ;
    rdfs:comment "Anchored under cco:ont00000402 (Act of Communication); has the hiring manager as participant." ;
    skos:example "HR emails the hiring manager that a new requisition has opened for their team." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; entailed by CCO, asserted for standalone SHACL S2/S5)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:HiringManager ] .

ex:P10452 a owl:Class ;
    ex:pcfID "10452" ; ex:hierarchyID "7.2.1.7" ;
    ex:apqcSourceText "Determining and managing the dates for the employee requisition process." ;
    rdfs:label "Manage requisition dates" ;
    skos:definition "An Act of Administration that determines and manages the schedule of dates governing an employee requisition process." ;
    rdfs:comment "Bounded administrative act applied per requisition (open/post/fill dates); no definitional informational output." ;
    skos:example "A coordinator sets and tracks the posting and target-fill dates for a requisition." ;
    rdfs:subClassOf ex:ActOfAdministration .

####################################################################
# 7.2.2 (PCF 10440) Recruit/Source candidates + children
####################################################################

ex:P10440 a owl:Class ;
    ex:pcfID "10440" ; ex:hierarchyID "7.2.2" ;
    ex:apqcSourceText "Recruiting new candidates for deployment across various functional areas inside the organization. Select methods for sourcing new employees. Manage relationships with third-party agencies. Stage recruitment fairs and drives. Manage employee referral programs." ;
    rdfs:label "Recruit/Source candidates" ;
    skos:definition "An Act of Administration that determines recruitment methods and conducts recruiting activities to source candidates for an organization's open positions." ;
    rdfs:comment "Process parts are the two bounded sub-acts (determine methods, perform events). The 'manage relationships/programs/channels' children are standing functions modeled as Organization Capabilities (ex:RecruitmentVendorManagementCapability, ex:EmployeeReferralProgramCapability, ex:RecruitmentChannelManagementCapability), realized in this process's acts, not asserted as process parts." ;
    skos:example "A talent team selects sourcing channels and runs a campus recruiting drive." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10453 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10454 ] .

ex:P10453 a owl:Class ;
    ex:pcfID "10453" ; ex:hierarchyID "7.2.2.1" ;
    ex:apqcSourceText "Defining the methods and channels for recruitments in order to maximize the amount of candidate availability. Use channels such as headhunting, job postings, job portals, networking websites, and media advertising. Choose from the various methods of recruitment such as internal/external third-party sourcing." ;
    rdfs:label "Determine recruitment methods and channels" ;
    skos:definition "An Act of Selection that chooses recruitment methods and channels from available options and produces a recruitment-method specification." ;
    rdfs:comment "Anchored under ex:ActOfSelection: the act chooses from candidate methods/channels and yields a Directive ICE (the chosen-method specification); genus agrees with directive output." ;
    skos:example "A recruiter selects job-board and referral channels for a hard-to-fill role." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RecruitmentMethodSpecification ] .

ex:P10454 a owl:Class ;
    ex:pcfID "10454" ; ex:hierarchyID "7.2.2.2" ;
    ex:apqcSourceText "Organizing and executing recruiting activities and events. Activities and events include on-campus hiring, refresher courses, information sessions, career fairs, etc. to increase the coverage of the sourcing in order to ensure that the most deserving and appropriate candidates are hired." ;
    rdfs:label "Perform recruiting activities/events" ;
    skos:definition "An Act of Administration that organizes and executes recruiting activities and events, such as campus hiring and career fairs, to broaden candidate sourcing." ;
    rdfs:comment "No definitional informational output; the act is the organized conduct of events. Realizes the recruitment vendor/referral/channel-management capabilities." ;
    skos:example "A team stages a campus career fair to source graduate candidates." ;
    rdfs:subClassOf ex:ActOfAdministration .

####################################################################
# 7.2.3 (PCF 20123) Screen and select candidates + children
####################################################################

ex:P20123 a owl:Class ;
    ex:pcfID "20123" ; ex:hierarchyID "7.2.3" ;
    ex:apqcSourceText "Evaluating and selecting potential employees through interviews, tests, etc." ;
    rdfs:label "Screen and select candidates" ;
    skos:definition "An Act of Administration that screens candidates through selection tools, interviews, and tests, and selects the most appropriate among them." ;
    rdfs:comment "Composite process; parts are the four screening/selection sub-acts. Culminates in ex:P10459 (the selection decision)." ;
    skos:example "A panel interviews and tests shortlisted candidates and chooses two to advance." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10456 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10457 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10458 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10459 ] .

ex:P10456 a owl:Class ;
    ex:pcfID "10456" ; ex:hierarchyID "7.2.3.1" ;
    ex:apqcSourceText "Identifying and implementing tools for the selection of candidates. Recognize candidate selection tools such as screening, telephone interviews, hiring manager interviews, drug testing, and skills assessment. Effectively deploy these tools to check if the candidates fit in the workplace or not, as well as to ensure workplace safety." ;
    rdfs:label "Identify and deploy candidate selection tools" ;
    skos:definition "An Act of Administration that identifies and puts into use the tools by which candidates are screened and selected." ;
    rdfs:comment "Administration (set-up of the selection toolset) rather than a single info-processing output; no definitional informational output." ;
    skos:example "Recruiting configures phone-screen, skills-test, and drug-test steps for a role." ;
    rdfs:subClassOf ex:ActOfAdministration .

ex:P10457 a owl:Class ;
    ex:pcfID "10457" ; ex:hierarchyID "7.2.3.2" ;
    ex:apqcSourceText "Assessing the candidates by their performance in the interviews. Conduct HR interview, technical interview, hiring manager interview, etc. Understand the mindset of the candidate, and comprehend his/her personal and professional lives." ;
    rdfs:label "Interview candidates" ;
    skos:definition "An Act of Appraisal that assesses a candidate's performance in interviews and produces a candidate assessment." ;
    rdfs:comment "Anchored under cco:ont00000636 (Act of Appraisal): it judges the candidate and yields a Descriptive ICE; genus agrees with descriptive output (GOLDEN PRINCIPLE). The candidate is a participant." ;
    skos:example "A panel conducts technical and HR interviews and records its assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CandidateAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:JobCandidate ] .

ex:P10458 a owl:Class ;
    ex:pcfID "10458" ; ex:hierarchyID "7.2.3.3" ;
    ex:apqcSourceText "Examining the candidates through tests. Prepare tools such as aptitude, technical, and grammar tests. Test the skills of the candidate through a written, oral, or computerized test." ;
    rdfs:label "Test candidates" ;
    skos:definition "An Act of Appraisal that examines a candidate's skills through tests and produces a candidate assessment." ;
    rdfs:comment "Anchored under cco:ont00000636 (Act of Appraisal); descriptive output and genus agree. The candidate is a participant." ;
    skos:example "A candidate sits an aptitude and technical test; results feed the assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CandidateAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:JobCandidate ] .

ex:P10459 a owl:Class ;
    ex:pcfID "10459" ; ex:hierarchyID "7.2.3.4" ;
    ex:apqcSourceText "Approving the deserving candidates, and rejecting the others. Examining the performance of candidates. Ensure candidates would fit well with the organization. (Assess performance from Interview candidates [10457] and Test candidates [10458].)" ;
    rdfs:label "Select and reject candidates" ;
    skos:definition "An Act of Selection that chooses which candidates to approve and which to reject, taking candidate assessments as input and producing a candidate selection decision." ;
    rdfs:comment "Anchored under ex:ActOfSelection: chooses from a candidate set and yields a Directive ICE (the decision); genus agrees with directive output. Inputs are the interview/test assessments (cross-reference 10457/10458)." ;
    skos:example "A hiring committee approves one candidate and rejects the rest." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CandidateAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CandidateSelectionDecision ] .

####################################################################
# 7.2.4 (PCF 10443) Manage new hire/re-hire + children
####################################################################

ex:P10443 a owl:Class ;
    ex:pcfID "10443" ; ex:hierarchyID "7.2.4" ;
    ex:apqcSourceText "Creating and making job offers to the selected candidates. Fairly negotiate the job offers. Agree on terms with the candidate to complete the hiring process." ;
    rdfs:label "Manage new hire/re-hire" ;
    skos:definition "An Act of Administration that draws up and extends a job offer, negotiates it with the selected candidate, and completes the hire." ;
    rdfs:comment "Composite process; parts are draw-up/make offer, negotiate offer, and hire candidate." ;
    skos:example "HR makes, negotiates, and finalizes an offer with the chosen candidate." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10463 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10464 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10465 ] .

ex:P10463 a owl:Class ;
    ex:pcfID "10463" ; ex:hierarchyID "7.2.4.1" ;
    ex:apqcSourceText "Compiling job-related information for the selected candidates in order to make up a job. Include information about the job description, reporting relationship, salary, bonus potential, benefits, and vacation allotment." ;
    rdfs:label "Draw up and make offer" ;
    skos:definition "An Act of Formulation that compiles job, compensation, and benefits terms into a job offer extended to a selected candidate." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (Act of Planning): a job offer is a Directive ICE prescribing terms of employment; output and genus agree." ;
    skos:example "A recruiter assembles salary, bonus, and benefits into a written offer." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:JobOffer ] .

ex:P10464 a owl:Class ;
    ex:pcfID "10464" ; ex:hierarchyID "7.2.4.2" ;
    ex:apqcSourceText "Negotiating an offer with selected candidates. Discuss the job offer with the candidate to ensure a mutual understanding." ;
    rdfs:label "Negotiate offer" ;
    skos:definition "An Act of Administration that conducts negotiation of a job offer with a selected candidate to reach mutual agreement on its terms." ;
    rdfs:comment "Modeled as administration of a bilateral negotiation; the revised ex:JobOffer is a typical but non-definitional output, recorded here rather than as a restriction. The candidate is a participant." ;
    skos:example "HR and the candidate negotiate the start date and signing bonus." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:JobOffer ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:JobCandidate ] .

ex:P10465 a owl:Class ;
    ex:pcfID "10465" ; ex:hierarchyID "7.2.4.3" ;
    ex:apqcSourceText "Wrapping up the process for hiring candidates. Agree to all hiring terms and conditions. Have the candidate accept and sign the job offer." ;
    rdfs:label "Hire candidate" ;
    skos:definition "An Act of Acquisition in which a candidate accepts and signs the job offer and the organization thereby obtains a new employee it did not previously hold." ;
    rdfs:comment "Anchored under ex:ActOfAcquisition (Planned Act): hiring obtains an employee not previously held. Takes the accepted job offer as input and produces an employee record. The candidate is a participant." ;
    skos:example "The candidate signs the offer and is onboarded as a new employee." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:JobOffer ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:JobCandidate ] .

####################################################################
# 7.2.5 (PCF 10444) Manage applicant information + children
####################################################################

ex:P10444 a owl:Class ;
    ex:pcfID "10444" ; ex:hierarchyID "7.2.5" ;
    ex:apqcSourceText "Creating and maintaining a system for managing the information of applicants. Create records for all candidates who apply. Maintain and track information through the use applicant-tracking systems." ;
    rdfs:label "Manage applicant information" ;
    skos:definition "An Act of Administration that obtains, creates, tracks, and archives applicant records across the recruitment cycle." ;
    rdfs:comment "Composite process; parts are obtain-background, create-record, the bounded position-classification act, and archive-non-hires. Modeled as a bounded administration process rather than a standing function because each act operates on a determinate applicant pool. NOTE: the open-ended applicant-data-tracking standing function (PCF 10467) is modeled as ex:ApplicantDataManagementCapability (R5/R6), not a process part; its bounded child P20124 is linked here directly so the partonomy still reaches the position-classification act." ;
    skos:example "HR records, tracks, and archives all applicants for a hiring round." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10460 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10466 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20124 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10468 ] .

ex:P10460 a owl:Class ;
    ex:pcfID "10460" ; ex:hierarchyID "7.2.5.1" ;
    ex:apqcSourceText "Conducting a background investigation on the candidates with the objective of looking up and compiling criminal, commercial, and financial records." ;
    rdfs:label "Obtain candidate background information" ;
    skos:definition "An Act of Information Processing that conducts a background investigation on a candidate and compiles candidate background information." ;
    rdfs:comment "Anchored under cco:ont00000366 (Act of Information Processing): it gathers and compiles records into a Descriptive ICE; genus agrees with descriptive output. The candidate is a participant." ;
    skos:example "A vendor compiles a candidate's criminal and financial background check." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CandidateBackgroundInformation ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:JobCandidate ] .

ex:P10466 a owl:Class ;
    ex:pcfID "10466" ; ex:hierarchyID "7.2.5.2" ;
    ex:apqcSourceText "Creating and documenting the records of all applicants. Manage all individual applicants, including hires and non-hires. Maintain records to avoid any duplication and promote efficiency." ;
    rdfs:label "Create applicant record" ;
    skos:definition "An Act of Information Processing that creates and documents an applicant record for each candidate who applies." ;
    rdfs:comment "Anchored under cco:ont00000366 (Act of Information Processing); produces a Descriptive ICE (the applicant record); genus agrees with descriptive output." ;
    skos:example "An ATS creates a record for each new applicant." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ApplicantRecord ] .

# R5 fix: 'Manage/track applicant data' (PCF 10467) is an open-ended standing
# tracking function with no natural terminus -- the same R5 profile that demoted
# its sibling 'Manage X' rows (PCF 10455 RecruitmentVendorManagementCapability,
# PCF 17048 RecruitmentChannelManagementCapability) to capabilities. Decision
# rule (recorded for all 'Manage X-data/channel/relationship' siblings in this
# group): a standing 'Manage X' function with no natural end -> Organization
# Capability (R5/R6), realized in its bounded acts; only the per-round bounded
# tracking/classification acts are processes. P10467 is therefore demoted from a
# bounded ex:ActOfAdministration process to a capability, and its former bounded
# task child P20124 (position classification) is re-parented as a realizing act
# (a capability cannot carry has-process-part).
ex:ApplicantDataManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ;   # realized in
          owl:someValuesFrom ex:P20124 ] ;
    ex:hierarchyID "7.2.5.3" ;
    ex:apqcSourceText "Keeping track of all the information about the candidates who apply for jobs. Use applicant-tracking systems that can be accessed online as a central location and database for recruitment efforts." ;
    rdfs:label "Applicant Data Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to keep track of and maintain applicant information through an applicant-tracking system, realized in the bounded acts of classifying and recording applicants." ;
    rdfs:comment "Models APQC 7.2.5.3 (PCF 10467) 'Manage/track applicant data' under R5/R6: an open-ended standing function ('Keeping track of all the information ... a central location and database'), with no natural end, so an Organization Capability (cco:ont00000568) realized in its bounded acts rather than a process. This matches the R5 treatment of its sibling 'Manage X' rows (PCF 10455, 17048). Operates on ex:ApplicantRecord (non-definitional). The former process-part link to P20124 is re-expressed as a realized-in axiom because capabilities cannot carry has-process-part." ;
    skos:example "An organization's standing ability to maintain applicant records in its ATS across hiring rounds." .

ex:P20124 a owl:Class ;
    ex:pcfID "20124" ; ex:hierarchyID "7.2.5.3.1" ;
    ex:apqcSourceText "Identifying the requirements for the position to be filled. Determine the experience and skills necessary to perform the tasks outlined." ;
    rdfs:label "Complete position classification and level of experience" ;
    skos:definition "An Act of Identification that discerns the experience and skills required for a position and produces a position classification." ;
    rdfs:comment "Anchored under ex:ActOfIdentification (discernment sense, Act of Information Processing): it determines/registers requirements; output is a Descriptive ICE; genus agrees." ;
    skos:example "A recruiter classifies a role as senior and lists its required skills." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PositionClassification ] .

ex:P10468 a owl:Class ;
    ex:pcfID "10468" ; ex:hierarchyID "7.2.5.4" ;
    ex:apqcSourceText "Retaining and storing the records of the candidates who were rejected and not hired to ensure future availability in case the need arises. Create a centralized repository of profiles. Label these records in order to readily identify them. Add remarks for any future consideration." ;
    rdfs:label "Archive and retain records of non-hires" ;
    skos:definition "An Act of Information Processing that retains and stores the records of non-hired candidates in a centralized, labeled repository for future reference." ;
    rdfs:comment "Anchored under cco:ont00000366 (Act of Information Processing), whose definition includes the storing of ICEs. Takes applicant records as input." ;
    skos:example "Rejected candidates' profiles are labeled and archived for future openings." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ApplicantRecord ] .

####################################################################
# GROUP 7.3 "Manage employee onboarding, training, and development"
#   (PCF 20599)
####################################################################

# --- group-7.3 standing functions modeled as capabilities (R5/R6) ---

ex:EmployeeOrientationAndDeploymentCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10474 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11243 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P17050 ] ;
    ex:hierarchyID "7.3.1" ;
    ex:apqcSourceText "Creating and maintaining various employee on-boarding programs typically known as induction programs in order to ensure that the new employees are effectively introduced to the organization and its existing employees. Examine and evaluate the performance of these induction programs. Execute these programs on the ground level." ;
    rdfs:label "Employee Orientation and Deployment Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization to the extent of its capacity to create, maintain, evaluate, and execute employee onboarding and orientation programs." ;
    rdfs:comment "R6 (R5 = standing function): APQC 7.3.1 'Manage employee orientation and deployment' (PCF 10469) has no natural end, so it is modeled as an Organization Capability realized in its bounded onboarding acts, not as a process." ;
    skos:example "A firm's standing ability to onboard and deploy new hires through its induction program." .

ex:EmployeePerformanceManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10479 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21434 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10481 ] ;
    ex:hierarchyID "7.3.2" ;
    ex:apqcSourceText "Defining individual performance objectives. Review performance in order to provide appraisals. Evaluate the efficiency and effectiveness of the current performance program. Update it regularly." ;
    rdfs:label "Employee Performance Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization to the extent of its capacity to define performance objectives, appraise employee performance, and evaluate and revise its performance-management program." ;
    rdfs:comment "R6: APQC 7.3.2 'Manage employee performance' (PCF 10470) is a standing function realized in its bounded acts. The sibling APQC node 7.3.2.3 (PCF 21435), itself the standing 'management of reviewing', is subsumed by this capability rather than minted as a process." ;
    skos:example "An organization's standing ability to run its annual performance-review cycle." .

ex:EmployeeCareerDevelopmentCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10487 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10488 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P17051 ] ;
    ex:hierarchyID "7.3.3" ;
    ex:apqcSourceText "Establishing employee development guidelines. Lay out career paths and plans for them. Manage the development of their skills to enhance their skills, ability, and knowledge." ;
    rdfs:label "Employee Career Development Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization to the extent of its capacity to establish development guidelines, lay out career plans and paths, and administer the development of employee skills and competencies." ;
    rdfs:comment "R6: APQC 7.3.3 'Manage employee career development' (PCF 10472) is a standing function realized in its bounded acts." ;
    skos:example "A firm's standing ability to maintain career ladders and grow its employees' competencies." .

ex:EmployeeTrainingCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10490 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16940 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10491 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10492 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10493 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20125 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21436 ] ;
    ex:hierarchyID "7.3.4" ;
    ex:apqcSourceText "Creating a link between employee and organizational development needs. Conduct and manage employee training programs by considering the need and availability of these programs." ;
    rdfs:label "Employee Training Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization to the extent of its capacity to align development needs, define competencies, and conduct and manage employee and management training programs." ;
    rdfs:comment "R6: APQC 7.3.4 'Develop and train employees' (PCF 10473) is a standing function with no natural end, realized in its bounded training acts. Narrower companion to the shared ex:EmployeeDevelopmentCapability." ;
    skos:example "A firm's standing ability to run its corporate training and certification programs." .

####################################################################
# 7.3 process classes
####################################################################

ex:P10474 a owl:Class ;
    ex:pcfID "10474" ; ex:hierarchyID "7.3.1.1" ;
    ex:apqcSourceText "Creating and maintaining a mechanism through which new employees acquire the necessary knowledge, skills, and behaviors to become effective organizational members and insiders. Conduct formal meetings, lectures, videos, printed materials, and/or computer-based orientations to introduce newcomers to their new jobs and the organization." ;
    rdfs:label "Create/maintain employee onboarding program" ;
    skos:definition "An Act of Formulation that composes and maintains an onboarding program specification through which new employees acquire the knowledge, skills, and behaviors to become effective organizational members." ;
    rdfs:comment "Formulation (directive output) per GOLDEN PRINCIPLE: its definitional output OnboardingProgramSpecification is a Directive ICE. Decomposes into develop and maintain/update tasks." ;
    skos:example "HR drafts and keeps current the new-hire induction program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OnboardingProgramSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10477 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10478 ] .

ex:P10477 a owl:Class ;
    ex:pcfID "10477" ; ex:hierarchyID "7.3.1.1.1" ;
    ex:apqcSourceText "Designing a program to systematically introduce newly hired employees to the organizational culture of the company." ;
    rdfs:label "Develop employee induction program" ;
    skos:definition "An Act of Formulation that designs an onboarding program specification systematically introducing newly hired employees to the organizational culture." ;
    rdfs:comment "Formulation (directive output): an OnboardingProgramSpecification is a Directive ICE." ;
    skos:example "An HR designer builds the slide deck, schedule, and materials for a new induction program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OnboardingProgramSpecification ] .

ex:P10478 a owl:Class ;
    ex:pcfID "10478" ; ex:hierarchyID "7.3.1.1.2" ;
    ex:apqcSourceText "Managing the orientation and training of new employees about the organizational culture of the company." ;
    rdfs:label "Maintain/Update employee induction program" ;
    skos:definition "An Act of Administration that keeps current and revises an existing onboarding program specification for orienting new employees to the organizational culture." ;
    rdfs:comment "Administration (not Formulation): it maintains/updates an already-established program rather than composing a new directive from scratch. The program specification is the entity acted upon (rdfs:comment, not a definitional output)." ;
    skos:example "HR refreshes the induction deck each year to reflect updated policies." ;
    rdfs:subClassOf ex:ActOfAdministration .

ex:P11243 a owl:Class ;
    ex:pcfID "11243" ; ex:hierarchyID "7.3.1.2" ;
    ex:apqcSourceText "Assessing the performance and effectiveness of employee on-boarding program. Examine the performance of on-boarding program through feedback and reviews from the new employees. Create web and written forms. Obtain information through face-to-face discussions." ;
    rdfs:label "Evaluate the effectiveness of the employee onboarding program" ;
    skos:definition "An Act of Appraisal that has as input employee feedback and has as output an onboarding program evaluation judging the performance and effectiveness of the onboarding program." ;
    rdfs:comment "Appraisal genus (cco:ont00000636) with a Descriptive output per GOLDEN PRINCIPLE." ;
    skos:example "HR reviews new-hire surveys and reports on how well the induction program worked." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OnboardingProgramEvaluation ] .

ex:P17050 a owl:Class ;
    ex:pcfID "17050" ; ex:hierarchyID "7.3.1.3" ;
    ex:apqcSourceText "Bringing the employee on-boarding program into effect. Implement Create/Maintain employee on-boarding program [10474]. Conduct training sessions and employee engagement programs." ;
    rdfs:label "Execute onboarding program" ;
    skos:definition "An Act of Administration that brings an onboarding program specification into effect by conducting the training sessions and employee-engagement activities it prescribes." ;
    rdfs:comment "Administration (execution). Per the APQC cross-reference to 10474, it realizes the OnboardingProgramSpecification produced by ex:P10474 (recorded as input below)." ;
    skos:example "HR runs the first-week induction sessions for a cohort of new hires." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:OnboardingProgramSpecification ] .

ex:P10479 a owl:Class ;
    ex:pcfID "10479" ; ex:hierarchyID "7.3.2.1" ;
    ex:apqcSourceText "Outlining the objectives for employee performance. Establish key performance objectives and measures such as customer-focus objectives, financially focused objectives, and employee growth objectives." ;
    rdfs:label "Define employee performance objectives" ;
    skos:definition "An Act of Formulation that composes and articulates performance objectives and measures for an employee." ;
    rdfs:comment "Formulation (directive output): a PerformanceObjective is a Directive ICE that prescribes a target." ;
    skos:example "A manager sets quarterly objectives covering customer, financial, and growth goals for a direct report." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceObjective ] .

ex:P21434 a owl:Class ;
    ex:pcfID "21434" ; ex:hierarchyID "7.3.2.2" ;
    ex:apqcSourceText "Execution of employee reviews/performance on a frequent basis." ;
    rdfs:label "Review employee performance" ;
    skos:definition "An Act of Appraisal that has as input performance data and performance objectives and has as output a performance appraisal of an employee." ;
    rdfs:comment "Appraisal genus with a Descriptive output (PerformanceAppraisal) per GOLDEN PRINCIPLE." ;
    skos:example "A manager conducts a mid-year review and records the employee's appraisal." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceObjective ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceAppraisal ] .

ex:P10481 a owl:Class ;
    ex:pcfID "10481" ; ex:hierarchyID "7.3.2.4" ;
    ex:apqcSourceText "Assessing and revamping performance programs, including the instruments used to measure employee performance standards. Review and upgrade these performance programs to avoid any deprivations and ensure effectiveness." ;
    rdfs:label "Evaluate and review performance program" ;
    skos:definition "An Act of Appraisal that judges the effectiveness of an employee-performance-management program and its measurement instruments and has as output a performance program evaluation." ;
    rdfs:comment "Appraisal (the assessing/reviewing facet drives the genus); the subsequent revamping is downstream. Descriptive output per GOLDEN PRINCIPLE." ;
    skos:example "HR reviews the appraisal rubric and recommends upgrades to the rating scale." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceProgramEvaluation ] .

ex:P10487 a owl:Class ;
    ex:pcfID "10487" ; ex:hierarchyID "7.3.3.1" ;
    ex:apqcSourceText "Outlining the guidelines for development of employees. Design development policies and procedures to identify areas of growth for employees, either in their current position or in preparation for future roles. Include topics related to knowledge and skill development." ;
    rdfs:label "Define employee development guidelines" ;
    skos:definition "An Act of Formulation that composes employee development guidelines prescribing policies and procedures for identifying employee growth areas." ;
    rdfs:comment "Formulation (directive output): an employee DevelopmentGuideline is a Directive ICE." ;
    skos:example "HR drafts the development-planning policy that managers use to plan staff growth." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DevelopmentGuideline ] .

ex:P10488 a owl:Class ;
    ex:pcfID "10488" ; ex:hierarchyID "7.3.3.2" ;
    ex:apqcSourceText "Designing a future career path for the employees that encourages them to explore and gather information." ;
    rdfs:label "Develop employee career plans and career paths" ;
    skos:definition "An Act of Formulation that designs a career plan laying out a future career path for an employee." ;
    rdfs:comment "Formulation (directive output): a CareerPlan is a Directive ICE prescribing a path." ;
    skos:example "A manager and employee jointly map a three-step promotion path." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CareerPlan ] .

ex:P17051 a owl:Class ;
    ex:pcfID "17051" ; ex:hierarchyID "7.3.3.3" ;
    ex:apqcSourceText "Administering the development of employee skills. Conduct training, coaching and mentoring, job-rotation and cross training, lateral moves, etc." ;
    rdfs:label "Manage employee skill and competency development" ;
    skos:definition "An Act of Administration that carries out the development of an employee's skills and competencies through training, coaching, mentoring, and job rotation." ;
    rdfs:comment "Administration: the source verb is 'Administering the development', i.e. executing concrete development activities, a bounded recurrent act (R5 OK; not the standing 7.3.3 function). Phase-3 fix: the prior [has input some ex:DevelopmentGuideline] existential restriction is removed -- the source ('Administering the development of employee skills. Conduct training, coaching and mentoring, job-rotation and cross training, lateral moves, etc.') never cites a development guideline, so a guideline is at best a typical/background input (a competency-question target pending domain review), not a definitional one. Replaced with [has participant some ex:Employee], which the source DOES support (the developed employee)." ;
    skos:example "A development lead arranges a mentor and a cross-training rotation for an employee." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10490 a owl:Class ;
    ex:pcfID "10490" ; ex:hierarchyID "7.3.4.1" ;
    ex:apqcSourceText "Aligning the needs of the employees to development needs." ;
    rdfs:label "Align employee with organization development needs" ;
    skos:definition "An Act of Analysis that reconciles individual employee development needs with organizational development needs and has as output a workforce development needs alignment." ;
    rdfs:comment "Analysis (information processing) with a Descriptive output per GOLDEN PRINCIPLE." ;
    skos:example "L&D maps each team's skill gaps against the company's strategic capability needs." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceDevelopmentNeedsAlignment ] .

ex:P16940 a owl:Class ;
    ex:pcfID "16940" ; ex:hierarchyID "7.3.4.2" ;
    ex:apqcSourceText "Defining the skills, knowledge, abilities, and attributes needed to carry out a specific job." ;
    rdfs:label "Define employee competencies and skills" ;
    skos:definition "An Act of Formulation that composes a competency management model specifying the skills, knowledge, abilities, and attributes needed to carry out a specific job." ;
    rdfs:comment "Formulation (directive output): a CompetencyManagementModel prescribes the required competency set." ;
    skos:example "HR defines the competency framework for the data-analyst role." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetencyManagementModel ] .

ex:P10491 a owl:Class ;
    ex:pcfID "10491" ; ex:hierarchyID "7.3.4.3" ;
    ex:apqcSourceText "Aligning the learning programs with the core capabilities and competencies of the organization. Contextualize the training programs so that employees can expand their knowledge base and add new skills in line with the core competencies of the organization." ;
    rdfs:label "Align learning programs with competencies and skills" ;
    skos:definition "An Act of Formulation that composes a learning program alignment specification aligning the organization's learning programs to its core capabilities and competencies." ;
    rdfs:comment "Re-anchored from ex:ActOfAdministration to ex:ActOfFormulation (Act of Planning) for sibling consistency: its parallel 7.3.4 rows that also yield a Directive ICE -- P10487 (Define guidelines) and P16940 (Define competencies) -- are Formulation, and composing the directive ex:LearningProgramAlignmentSpecification reads as authoring a directive, not running a settled arrangement. Genus now agrees with the directive output (GOLDEN PRINCIPLE). Phase-3 fix: the prior [has input some ex:CompetencyManagementModel] existential restriction is demoted to commentary -- the source ('Aligning the learning programs with the core capabilities and competencies') cites competencies as the alignment TARGET, not a necessary input ICE present in every instance; it is a competency-question/annotation target pending domain review." ;
    skos:example "L&D re-maps the training catalog so each course builds a named core competency." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LearningProgramAlignmentSpecification ] .

ex:P10492 a owl:Class ;
    ex:pcfID "10492" ; ex:hierarchyID "7.3.4.4" ;
    ex:apqcSourceText "Determining the training necessitated by business processes, using an examination of skill sets that are needed by the organization and those already possessed. Examine the various skills required by individual employees. Design training in light of the availability of resources to provide specific segments of training." ;
    rdfs:label "Establish training needs by analysis of required and available skills" ;
    skos:definition "An Act of Analysis that has as input skill requirement data and has as output a skills gap analysis comparing skills required by the organization with those already possessed in order to establish training needs." ;
    rdfs:comment "Analysis (the examination/comparison of skill sets drives the genus); Descriptive output per GOLDEN PRINCIPLE." ;
    skos:example "L&D compares the required and current skills matrices to determine which courses are needed." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SkillRequirementData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SkillsGapAnalysis ] .

ex:P10493 a owl:Class ;
    ex:pcfID "10493" ; ex:hierarchyID "7.3.4.5" ;
    ex:apqcSourceText "Creating, implementing, and managing the programs for training employees. Create and design sessions on the basis of the needs and the availability of the skills. Conduct the sessions on the ground. Manage all aspects related to the training programs. Consider including literacy training, interpersonal skills training, technical training, problem-solving training, diversity or sensitivity training, etc." ;
    rdfs:label "Develop, conduct, and manage employee and/or management training programs" ;
    skos:definition "An Act of Training in which an organization imparts knowledge, skills, or values to its employees and managers by developing, conducting, and managing training programs." ;
    rdfs:comment "Anchored to CCO cco:ont00000234 (Act of Training). VERIFIED against the pinned CCO v2.0 closure (D6/§6): label 'Act of Training', definition 'A Planned Act in which knowledge, skills or values are imparted from one or more Agents to at least one other Agent', parent cco:ont00000228 (Planned Act) -- confirmed in CommonCoreOntologiesMerged.ttl. (cco:ont00000234 is hereby added to the module's verified-term set; the §6 table in apqc_to_bfo_cco_methodology.md should be updated to list it.) This sense fits the conduct/deliver facet that dominates this node. Compound-row de-conflation: the equally-labelled 'develop' (design a TrainingProgramSpecification = directive output, a Formulation/Planning facet) and 'manage' (Administration) facets are NOT collapsed into this genus -- the design facet's directive output is handled by the separate/downstream formulation node, and this primary PCF class is reduced to the dominant 'conduct/deliver' facet. Its guiding TrainingProgramSpecification is recorded as input; the trained Employee is the definitional participant (trainee), modeled with has participant rather than has input (an Agent is not an informational input)." ;
    skos:example "Trainers run a technical-skills bootcamp for a cohort of engineers." ;
    rdfs:subClassOf cco:ont00000234 ,   # Act of Training
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; entailed by CCO, asserted for standalone SHACL S2/S5)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TrainingProgramSpecification ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P20125 a owl:Class ;
    ex:pcfID "20125" ; ex:hierarchyID "7.3.4.6" ;
    ex:apqcSourceText "Managing identified training programs for employees. Engage with industries to provide certifications, administer certification test, and maintain active certification." ;
    rdfs:label "Manage examinations and certifications" ;
    skos:definition "An Act of Administration that runs an organization's certification program by liaising with certification authorities, administering tests, appraising qualifications, and issuing and maintaining certificates." ;
    rdfs:comment "Administration: a bounded episode of running the certification program (distinct from a standing 'Manage' function because it decomposes into concrete, completable child tasks). Decomposes via has process part into its four APQC children." ;
    skos:example "The certification office runs an annual cycle of qualifying, testing, and certifying technicians." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20126 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20127 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20128 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20129 ] .

ex:P20126 a owl:Class ;
    ex:pcfID "20126" ; ex:hierarchyID "7.3.4.6.1" ;
    ex:apqcSourceText "Coordinating with third party certification authorities to provide training and certifications for necessary skills." ;
    rdfs:label "Liaise with external certification authorities" ;
    skos:definition "An Act of Administration that coordinates with third-party certification authorities to provide training and certifications for required skills." ;
    rdfs:comment "Administration (coordination facet). The certification authority is a definitional participant." ;
    skos:example "The training office negotiates a certification partnership with an industry body." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:CertificationAuthority ] .

ex:P20127 a owl:Class ;
    ex:pcfID "20127" ; ex:hierarchyID "7.3.4.6.2" ;
    ex:apqcSourceText "Providing tests to the workforce that will satisfy completion of certifications." ;
    rdfs:label "Administer certification tests" ;
    skos:definition "An Act of Administration that provides certification tests to the workforce and has as output a certification test result." ;
    rdfs:comment "Administration (delivery of tests); the test result record is its descriptive output." ;
    skos:example "The certification office proctors the year-end welding examination." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CertificationTestResult ] .

ex:P20128 a owl:Class ;
    ex:pcfID "20128" ; ex:hierarchyID "7.3.4.6.3" ;
    ex:apqcSourceText "Ascertaining the experience level needed to qualify for a specific job or certification within the organization. Some certificates require practical experience as well as training programs." ;
    rdfs:label "Appraise experience qualifications" ;
    skos:definition "An Act of Identification that discerns the experience level needed to qualify for a specific job or certification and has as output an experience qualification assessment." ;
    rdfs:comment "Re-anchored from cco:ont00000636 (Act of Appraisal) to ex:ActOfIdentification (discernment sense, an Act of Information Processing). 'Ascertaining the level needed to qualify' is discernment of a standing requirement threshold (information processing), not judging the quality or worth of an individual or entity; the label word 'Appraise' was a false-friend that drove the prior genus. This is the same act-kind as P20124 (Complete position classification), which discerns 'the experience and skills required for a position' and is anchored under ex:ActOfIdentification -- cross-referenced here for sibling/parallel-row consistency. The Descriptive output ex:ExperienceQualificationAssessment is retained and satisfies the GOLDEN PRINCIPLE under the information-processing genus." ;
    skos:example "An assessor determines that the certification requires three years of field experience to qualify." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExperienceQualificationAssessment ] .

ex:P20129 a owl:Class ;
    ex:pcfID "20129" ; ex:hierarchyID "7.3.4.6.4" ;
    ex:apqcSourceText "Administering certificates to all candidates that have successfully met experience qualifications, and passed all tests necessary to obtain the certificate." ;
    rdfs:label "Administer certificate issue and maintenance" ;
    skos:definition "An Act of Administration that issues and maintains certificates for candidates who have met the experience qualifications and passed the required tests, and has as output a certification record." ;
    rdfs:comment "Administration (issuance/upkeep); the CertificationRecord is its descriptive output." ;
    skos:example "The certification office issues and renews certificates for employees who passed their exams." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CertificationRecord ] .

ex:P21436 a owl:Class ;
    ex:pcfID "21436" ; ex:hierarchyID "7.3.4.7" ;
    ex:apqcSourceText "Oversight of the organization's learning programs. This process also includes the effectiveness of these programs." ;
    rdfs:label "Monitor and evaluate learning programs" ;
    skos:definition "An Act of Appraisal that oversees and judges the coverage and effectiveness of an organization's learning programs and has as output a learning program evaluation." ;
    rdfs:comment "Appraisal (monitor/evaluate effectiveness); Descriptive output per GOLDEN PRINCIPLE." ;
    skos:example "L&D reports quarterly on which training programs are delivering measurable skill gains." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LearningProgramEvaluation ] .

####################################################################
# GROUP 7.4 "Manage employee relations" (PCF 17052)
#   7.4 itself reuses the shared ex:EmployeeRelationsCapability.
####################################################################

# --- group-7.4 standing functions modeled as capabilities (R5/R6) ---

ex:LaborRelationsCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10484 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10531 ] ;
    rdfs:label "Labor Relations Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to administer the relationship between labor and management, realized in acts of collective bargaining and employee-grievance resolution." ;
    rdfs:comment "Models APQC 7.4.1 'Manage labor relations' (PCF 10483) under R5/R6: a standing function with no natural end, so an Organization Capability (cco:ont00000568) realized in the underlying bounded acts, not a process. Narrower than the shared ex:EmployeeRelationsCapability." .

ex:LaborManagementPartnershipCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Labor-Management Partnership Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to develop and sustain a lasting cooperative relationship between labor and management for mutual benefit." ;
    rdfs:comment "Models APQC 7.4.3 'Manage labor management partnerships' (PCF 10485) under R5/R6: the source seeks a 'lasting two-way relationship', a standing relationship-maintenance function with no natural end, hence an Organization Capability rather than a process. No bounded child acts are enumerated by the source, so no realized-in restriction is asserted (would be non-definitional)." .

####################################################################
# 7.4 process classes
####################################################################

ex:P10484 a owl:Class ;
    ex:pcfID "10484" ; ex:hierarchyID "7.4.2" ;
    ex:apqcSourceText "Managing any negotiations between an employer and a group of employees that determine the conditions of employment. Engage employees to reach agreements in regulating working conditions." ;
    rdfs:label "Manage collective bargaining process" ;
    skos:definition "An Act of Negotiation in which an employer and a group of employees confer and bargain over the conditions of employment and jointly produce a collective bargaining agreement that regulates working conditions." ;
    rdfs:comment "Re-anchored from ex:ActOfAdministration to ex:ActOfNegotiation. Administration was a false-friend genus driven by the label word 'Manage': its differentia is carrying out an ALREADY-ESTABLISHED arrangement 'without itself creating that arrangement', whereas collective bargaining CREATES a novel Directive ICE (the CBA) -- the source says 'reach agreements in regulating working conditions'. Producing a binding directive agreement is agreement-formation/negotiation, not administration; the new shared genus ex:ActOfNegotiation (PROPOSE-EXT, anchored under cco:ont00000228 Planned Act, differentia 'two or more parties jointly producing a binding directive agreement') is reusable for parallel bargaining/agreement nodes corpus-wide. Output ex:CollectiveBargainingAgreement is a Directive ICE (definitional, promoted) and the Employee/ManagementPersonnel participant restrictions remain correct under the new genus; genus now agrees with the directive output (GOLDEN PRINCIPLE)." ;
    skos:example "An HR team and a labor union negotiate a new two-year contract setting wages and shift rules." ;
    rdfs:subClassOf ex:ActOfNegotiation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CollectiveBargainingAgreement ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ManagementPersonnel ] .

ex:P10531 a owl:Class ;
    ex:pcfID "10531" ; ex:hierarchyID "7.4.4" ;
    ex:apqcSourceText "Taking care or resolving any complaint raised by an employee by procedures provided for in a collective agreement, an employment contract, or by other mechanisms established by an employer." ;
    rdfs:label "Manage employee grievances" ;
    skos:definition "An Act of Administration in which an Agent processes and resolves a complaint raised by an employee according to procedures established by a collective agreement, employment contract, or other employer mechanism, producing a grievance resolution." ;
    rdfs:comment "Genus is ex:ActOfAdministration (Planned Act): handling a grievance per established procedures. Both the input ex:EmployeeGrievance (the complaint being resolved) and the output ex:GrievanceResolution are definitional and promoted to restrictions. The complaining employee is a definitional participant." ;
    skos:example "An HR officer reviews a worker's overtime complaint against the contract and issues a written resolution." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeGrievance ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GrievanceResolution ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P21437 a owl:Class ;
    ex:pcfID "21437" ; ex:hierarchyID "7.4.5" ;
    ex:apqcSourceText "Awareness of the employee legislature that is in place for the organization. The regulatory environment could include areas, regions, or countries." ;
    rdfs:label "Monitor legal and regulatory environment" ;
    skos:definition "An Act of Analysis that examines the employment-related legal and regulatory requirements in force across the jurisdictions relevant to an organization and produces an assessment describing the current regulatory environment." ;
    rdfs:comment "Genus is ex:ActOfAnalysis (Act of Information Processing): monitoring is the examination of regulatory inputs to yield awareness. Per the GOLDEN PRINCIPLE the output is a Descriptive ICE (ex:RegulatoryEnvironmentAssessment represents the regulatory state, it does not prescribe). Input ex:LegalAndRegulatoryRequirements and the descriptive output are definitional." ;
    skos:example "An HR compliance team reviews labor-law changes across its operating regions and circulates a regulatory-awareness brief." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:LegalAndRegulatoryRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryEnvironmentAssessment ] .

####################################################################
# GROUP 7.5 "Reward and retain employees" (PCF 10412)
#   7.5 group node maps to the shared ex:CompensationAndBenefitsCapability;
#   only the R6 'realized in' axioms for group 7.5 are added here.
####################################################################

ex:CompensationAndBenefitsCapability rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21438 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10495 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21439 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10497 ] .

####################################################################
# 7.5.1 (PCF 21438) and activities
####################################################################

ex:P21438 a owl:Class ;
    ex:pcfID "21438" ; ex:hierarchyID "7.5.1" ;
    ex:apqcSourceText "Developing a salary/compensation structure and plan; developing a benefits and reward plan; develop commission plan; performing competitive analyses of benefits and rewards; identifying compensation requirements based on compensation, benefits, and HR policies; administering compensation, commission, and rewards to employees; and rewarding and motivating employees." ;
    rdfs:label "Develop and manage reward, recognition, and motivation programs" ;
    skos:definition "An Act of Administration that develops and manages an organization's reward, recognition, and motivation programs, comprising the formulation of compensation and benefits plans and the administration of compensation and rewards to employees." ;
    rdfs:comment "Models APQC 7.5.1 as a bounded, recurring administrative procedure; its APQC children are process parts, not subclasses." ;
    skos:example "An HR compensation team's annual cycle of refreshing the pay structure and benefits plan and administering rewards." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:HumanResourcesProfessional ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10498 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10499 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10500 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10501 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10502 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10503 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10510 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10511 ] .

ex:P10498 a owl:Class ;
    ex:pcfID "10498" ; ex:hierarchyID "7.5.1.1" ;
    ex:apqcSourceText "Creating the framework for the provision of salary/compensation to employees. Break down the salary structure into different components such as fixed pay, variable pay, bonus, and allowances such medical allowance, and rent allowance, etc. Develop, adjust, and maintain a pay structure." ;
    rdfs:label "Develop salary/compensation structure and plan" ;
    skos:definition "An Act of Formulation that composes a compensation structure prescribing the components of employee pay such as fixed pay, variable pay, bonus, and allowances." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (Act of Planning): it composes a Directive ICE (the pay structure). Market compensation data is a typical, not definitional, input." ;
    skos:example "A compensation analyst designs a banded pay structure with fixed, variable, and allowance components." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompensationStructure ] .

ex:P10499 a owl:Class ;
    ex:pcfID "10499" ; ex:hierarchyID "7.5.1.2" ;
    ex:apqcSourceText "Developing a plan for provision of rewards, commission, and benefits to employees. Plan health benefits, retirement benefits, non-monetary benefits, etc." ;
    rdfs:label "Develop benefits and rewards plan" ;
    skos:definition "An Act of Formulation that composes a benefits and rewards plan prescribing the rewards, commission, and benefits to be provided to employees." ;
    rdfs:comment "Anchored under ex:ActOfFormulation: output is a Directive ICE (the plan)." ;
    skos:example "A benefits manager drafts the annual plan covering health, retirement, and non-monetary benefits." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BenefitsAndRewardsPlan ] .

ex:P10500 a owl:Class ;
    ex:pcfID "10500" ; ex:hierarchyID "7.5.1.3" ;
    ex:apqcSourceText "Analyzing and evaluating the organization's benefits and rewards plan. Compare/Benchmark the benefits and employees plan with other organizations to adhere to industry standard practices." ;
    rdfs:label "Perform competitive analysis of benefits and rewards" ;
    skos:definition "An Act of Analysis that has as input market compensation data and has as output a compensation benchmark juxtaposing the organization's benefits and rewards against industry practice." ;
    rdfs:comment "GOLDEN PRINCIPLE: analysis/benchmarking produces a Descriptive ICE (the benchmark)." ;
    skos:example "An analyst benchmarks the firm's benefits against peer employers and reports the gaps." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketCompensationData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompensationBenchmark ] .

ex:P10501 a owl:Class ;
    ex:pcfID "10501" ; ex:hierarchyID "7.5.1.4" ;
    ex:apqcSourceText "Recognizing the employee requirements for compensation on the basis of the financial, benefits, and HR policies of the organization. Recognize individual compensation requirements regarding the financial policies of the organization. Consider the benefits plan and overall HR policies while selecting compensation requirements." ;
    rdfs:label "Identify compensation requirements based on financial, benefits, and HR policies" ;
    skos:definition "An Act of Identification that has as input HR policy data and has as output a compensation requirement discerned from the organization's financial, benefits, and HR policies." ;
    rdfs:comment "GOLDEN PRINCIPLE: discernment/identification produces a Descriptive ICE (the requirement representation). Anchored under ex:ActOfIdentification (information processing)." ;
    skos:example "An HR analyst identifies the compensation a role requires given the firm's pay and benefits policy." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:HRPolicyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompensationRequirement ] .

ex:P10502 a owl:Class ;
    ex:pcfID "10502" ; ex:hierarchyID "7.5.1.5" ;
    ex:apqcSourceText "Managing the provision of compensations and rewards to the employees while maintaining consistency with the compensation and benefits plan. Follow the compensation and benefits plan rigorously in order to avoid any discrepancies." ;
    rdfs:label "Administer compensation and rewards to employees" ;
    skos:definition "An Act of Administration that provisions compensation and rewards to employees in accordance with the compensation and benefits plan and produces a pay statement." ;
    rdfs:comment "The benefits and rewards plan is a definitional directive input; the compensation structure constrains it but is typical, so recorded here rather than as a restriction." ;
    skos:example "Payroll disburses bonuses and allowances to employees per the approved plan and issues statements." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BenefitsAndRewardsPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PayStatement ] .

ex:P10503 a owl:Class ;
    ex:pcfID "10503" ; ex:hierarchyID "7.5.1.6" ;
    ex:apqcSourceText "Rewarding and stimulating the performance efforts of employees. Create methods for motivating employees. Spur extrinsic and intrinsic motivation." ;
    rdfs:label "Reward and motivate employees" ;
    skos:definition "An Act of Administration that rewards employees and applies extrinsic and intrinsic methods to stimulate their performance efforts." ;
    rdfs:comment "Typical output: an incentive plan / motivation method (ex:IncentivePlan) and recognition of employees; not definitional for every instance, so recorded as a comment rather than an owl:someValuesFrom restriction. Participant: Employee." ;
    skos:example "A manager grants spot bonuses and public recognition to motivate a high-performing team." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10510 a owl:Class ;
    ex:pcfID "10510" ; ex:hierarchyID "7.5.1.7" ;
    ex:apqcSourceText "Reassessing the indicators for retention and motivation of employees. Monitor the indicators that signal the levels of motivation and retention. Regularly update and upgrade indicators to avoid depreciation and ensure high efficiency." ;
    rdfs:label "Review retention and motivation indicators" ;
    skos:definition "An Act of Appraisal that has as input employee metrics signalling retention and motivation and judges their adequacy and currency." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the act reassesses and judges indicators. GOLDEN PRINCIPLE: appraisal yields a Descriptive judgement; the updated indicator set is a typical output, recorded as a comment." ;
    skos:example "An HR analytics team reviews turnover and engagement indicators and flags ones needing recalibration." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeMetric ] .

ex:P10511 a owl:Class ;
    ex:pcfID "10511" ; ex:hierarchyID "7.5.1.8" ;
    ex:apqcSourceText "Analyzing existing compensation plans and making changes necessary to continue to retain employees." ;
    rdfs:label "Review compensation plan" ;
    skos:definition "An Act of Appraisal that has as input the existing compensation structure and judges what changes are necessary to retain employees." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it evaluates the existing plan. The resulting change recommendations are a typical output, recorded as a comment rather than a restriction." ;
    skos:example "A compensation committee reviews the pay plan against attrition data and recommends adjustments." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CompensationStructure ] .

####################################################################
# 7.5.2 (PCF 10495) and activities
####################################################################

ex:P10495 a owl:Class ;
    ex:pcfID "10495" ; ex:hierarchyID "7.5.2" ;
    ex:apqcSourceText "Managing and ensuring benefits enrollment by the employees. Process any benefit claims made by the employees. Balance the estimated amount and entitled amount of benefits." ;
    rdfs:label "Manage and administer benefits" ;
    skos:definition "An Act of Administration that manages employee benefits enrollment, processes benefit claims, and reconciles delivered benefits, comprising its constituent benefit-administration activities." ;
    rdfs:comment "Models APQC 7.5.2 as a bounded, recurring administrative procedure; its APQC children are process parts, not subclasses." ;
    skos:example "A benefits operations team runs the open-enrollment, claims, and reconciliation cycle for a plan year." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:HumanResourcesProfessional ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10504 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10505 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10506 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10507 ] .

ex:P10504 a owl:Class ;
    ex:pcfID "10504" ; ex:hierarchyID "7.5.2.1" ;
    ex:apqcSourceText "Implementing the programs that specify employee benefits, other than salary provided, such as those concerning medical care, death, and disability." ;
    rdfs:label "Deliver employee benefits program" ;
    skos:definition "An Act of Administration that implements the employee benefits program specifying non-salary benefits such as medical care, death, and disability coverage." ;
    rdfs:comment "The benefits and rewards plan is the definitional directive input being implemented; participants are employees." ;
    skos:example "HR operations stands up the year's medical, life, and disability benefit offerings for staff." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BenefitsAndRewardsPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10505 a owl:Class ;
    ex:pcfID "10505" ; ex:hierarchyID "7.5.2.2" ;
    ex:apqcSourceText "Handling the employee enrollment for obtaining benefits. Manage employee enrollment and eligibility. Encourage employees to enroll for benefits." ;
    rdfs:label "Administer benefit enrollment" ;
    skos:definition "An Act of Administration that handles employee enrollment and eligibility for benefits and produces an employee record of enrollment." ;
    rdfs:comment "Participant: Employee. Output is the enrollment/eligibility record (ex:EmployeeRecord)." ;
    skos:example "A benefits administrator enrolls a new hire in the medical plan and records eligibility." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeRecord ] .

ex:P10506 a owl:Class ;
    ex:pcfID "10506" ; ex:hierarchyID "7.5.2.3" ;
    ex:apqcSourceText "Processing any formal requests or demands made by the employees claiming that they have earned some benefits. Send the request further up the managerial hierarchy to ensure approval." ;
    rdfs:label "Process claims" ;
    skos:definition "An Act of Administration that has as input an employee benefit claim and processes it, routing it for managerial approval." ;
    rdfs:comment "Benefit claim is the definitional input. The approval decision and managerial routing are typical, recorded here rather than as restrictions." ;
    skos:example "A claims clerk validates a disability-benefit claim and forwards it to a manager for approval." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BenefitClaim ] .

ex:P10507 a owl:Class ;
    ex:pcfID "10507" ; ex:hierarchyID "7.5.2.4" ;
    ex:apqcSourceText "Carrying out reconciliation of benefits delivered to employees. Compare the estimated benefit requirement made by the employee and the actual amount of benefits the employee is entitled to receive." ;
    rdfs:label "Perform benefit reconciliation" ;
    skos:definition "An Act of Analysis that compares the estimated and entitled benefit amounts for employees and has as output a benefit reconciliation statement." ;
    rdfs:comment "GOLDEN PRINCIPLE: reconciliation analysis produces a Descriptive ICE (the reconciliation statement)." ;
    skos:example "A benefits accountant reconciles claimed against entitled benefits and issues a reconciliation statement." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BenefitReconciliationStatement ] .

####################################################################
# 7.5.3 (PCF 21439) and activities
####################################################################

ex:P21439 a owl:Class ;
    ex:pcfID "21439" ; ex:hierarchyID "7.5.3" ;
    ex:apqcSourceText "Managing activities centered around delivering programs to support work/life balance for employees; developing family support systems; reviewing retention and motivation indicators; and reviewing compensation plans." ;
    rdfs:label "Manage employee assistance and retention" ;
    skos:definition "An Act of Administration that manages employee assistance and retention by delivering work/life-balance programs and developing family support systems." ;
    rdfs:comment "Models APQC 7.5.3 as a bounded, recurring administrative procedure; its APQC children are process parts, not subclasses." ;
    skos:example "An HR well-being team operates the work/life-balance and family-support programs for a benefit year." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:HumanResourcesProfessional ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10508 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10509 ] .

ex:P10508 a owl:Class ;
    ex:pcfID "10508" ; ex:hierarchyID "7.5.3.1" ;
    ex:apqcSourceText "Designing programs that prompt proper balance between work (i.e., career and ambition) and lifestyle (i.e., health, pleasure, leisure, family, and spiritual development/meditation). Account for dependent care, flexible working arrangements, leaves of absence, on-the-job training, etc." ;
    rdfs:label "Deliver programs to support work/life balance for employees" ;
    skos:definition "An Act of Administration that designs and delivers programs promoting balance between employees' work and lifestyle, covering arrangements such as dependent care, flexible working, and leaves of absence." ;
    rdfs:comment "Typical output: a work/life-balance program specification (a Directive ICE); not definitional for every instance, recorded as a comment. Has process part 7.5.3.1.1 Manage flexible working." ;
    skos:example "An HR team launches a flexible-hours and dependent-care program for staff." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21440 ] .

ex:P21440 a owl:Class ;
    ex:pcfID "21440" ; ex:hierarchyID "7.5.3.1.1" ;
    ex:apqcSourceText "Creation and execution of a plan that might allow for work from home days, or alternate hours." ;
    rdfs:label "Manage flexible working" ;
    skos:definition "An Act of Administration that creates and executes a flexible-working plan permitting arrangements such as work-from-home days or alternate hours." ;
    rdfs:comment "The flexible-working plan is created and then executed within this act; as both an intermediate artifact and operational provisioning, the plan is recorded here rather than as a restriction." ;
    skos:example "A manager sets up and runs a hybrid work-from-home schedule for the team." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10509 a owl:Class ;
    ex:pcfID "10509" ; ex:hierarchyID "7.5.3.2" ;
    ex:apqcSourceText "Creating a support structure that aligns with local and federal laws that allow for support for families. This could include things like maternity leave, care for a family member, or in some cases, extended sick leave." ;
    rdfs:label "Develop family support systems" ;
    skos:definition "An Act of Formulation that composes a family support structure, aligned with local and federal law, prescribing provisions such as maternity leave, family-member care, and extended sick leave." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (Act of Planning): the output is a Directive ICE (a family-support program specification). Phase-3 fix: the directive output is now promoted to an existential restriction on the newly-minted ex:FamilySupportProgramSpecification rather than left in commentary -- for a Formulation act the directive output IS definitional (it is what makes the act a formulation), matching the other 7.5 formulation acts (P10498->CompensationStructure, P10499->BenefitsAndRewardsPlan, P20958->HumanResourcesStrategy). The earlier 'no shared ICE captures it' rationale did not justify omission, since the module already mints local Directive ICEs for this situation. Legal and regulatory requirements remain a definitional input." ;
    skos:example "HR drafts a family-leave policy compliant with statutory entitlements." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:LegalAndRegulatoryRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FamilySupportProgramSpecification ] .

####################################################################
# 7.5.4 (PCF 10497) Administer payroll
####################################################################

ex:P10497 a owl:Class ;
    ex:pcfID "10497" ; ex:hierarchyID "7.5.4" ;
    ex:apqcSourceText "Managing the sum of all financial records of salaries for an employee, including wages, bonuses, and deductions. Use a payroll management system to deal with the financial aspects of employees' salaries, allowances, deductions, gross pay, net pay, etc. Generate pay slips for a specific period." ;
    rdfs:label "Administer payroll" ;
    skos:definition "An Act of Administration that has as input employee data and manages the financial records of employee salaries, including wages, bonuses, and deductions, producing pay statements for a given period." ;
    rdfs:comment "Has no modeled APQC children. Employee data is a definitional input; the pay statement (pay slip) is the definitional output." ;
    skos:example "Payroll runs the monthly cycle computing gross and net pay and issuing pay slips." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PayStatement ] .

####################################################################
# GROUP 7.6 "Redeploy and retire employees" (PCF 10413)
####################################################################

ex:P10413 a owl:Class ;
    ex:pcfID "10413" ; ex:hierarchyID "7.6" ;
    ex:apqcSourceText "Managing the reassignment and retirement of employees. Manage the process of employee promotion and demotion. Administer separation, retirement, and leaves of absence. Outplace employees. Deploy personnel. Relocate employees in order to manage assignments." ;
    rdfs:label "Redeploy and retire employees" ;
    skos:definition "An Act of Administration that carries out the organization's procedures for reassigning, redeploying, and separating employees, comprising the administration of promotions and demotions, separations, retirements, leaves of absence, outplacement, scheduling, and relocations." ;
    rdfs:comment "Models APQC process group 7.6 as a bounded occurrent. Its APQC children are process parts (cco:ont00001777), not subclasses. Has the affected employee as participant." ;
    skos:example "An HR operations team runs the end-to-end cycle of moving, retiring, and offboarding employees over a quarter." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10512 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10513 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10514 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10515 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10516 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20132 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17055 ] .

ex:P10512 a owl:Class ;
    ex:pcfID "10512" ; ex:hierarchyID "7.6.1" ;
    ex:apqcSourceText "Administering the process of promoting and demoting employees. Design a system for advancing or demoting an employee's rank or position. Leverage techniques such as horizontal promotion, vertical promotion, dry promotion, and involuntary/voluntary demotion." ;
    rdfs:label "Manage promotion and demotion process" ;
    skos:definition "An Act of Administration that has as input employee data and produces an updated employee record registering an advancement or reduction in an employee's rank or position." ;
    rdfs:comment "Output is a Descriptive ICE (the updated record) because it registers a status change rather than prescribing future action. The promotion/demotion techniques are method, not tracked process parts." ;
    skos:example "HR processes a vertical promotion and updates the employee's grade in the personnel record." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10513 a owl:Class ;
    ex:pcfID "10513" ; ex:hierarchyID "7.6.2" ;
    ex:apqcSourceText "Managing the process of employee separation, including resignations, discharges, and layoffs. Inform the employee of the termination. Complete paperwork for continuation of benefits." ;
    rdfs:label "Manage separation" ;
    skos:definition "An Act of Administration that has as input employee data and produces an updated employee record terminating the employment relationship by resignation, discharge, or layoff." ;
    rdfs:comment "Benefits-continuation paperwork is a typical further output, recorded here rather than as an existential restriction. Informing the employee is a method step, not a tracked process part." ;
    skos:example "HR processes a layoff, notifies the employee, and closes out their employment record." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10514 a owl:Class ;
    ex:pcfID "10514" ; ex:hierarchyID "7.6.3" ;
    ex:apqcSourceText "Managing and administering instances where a person stops employment completely." ;
    rdfs:label "Manage retirement" ;
    skos:definition "An Act of Administration that has as input employee data and produces an updated employee record recording the complete and permanent cessation of a person's employment by retirement." ;
    rdfs:comment "Distinct from separation (7.6.2) in that retirement is the employee's permanent exit from the workforce." ;
    skos:example "HR processes a worker's retirement and finalizes their pension and personnel record." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10515 a owl:Class ;
    ex:pcfID "10515" ; ex:hierarchyID "7.6.4" ;
    ex:apqcSourceText "Managing the period of time that an employee must be away from their primary job, while maintaining the status of employee (i.e., paid and unpaid leave of absence but not vacations, holidays, hiatuses, sabbaticals, and work-from-home programs)." ;
    rdfs:label "Manage leave of absence" ;
    skos:definition "An Act of Administration that has as input employee data and produces an updated employee record governing a period during which an employee is away from their primary job while retaining employee status." ;
    rdfs:comment "Scoped by APQC to paid/unpaid leave, excluding vacations, holidays, hiatuses, sabbaticals, and work-from-home." ;
    skos:example "HR records and tracks an employee's approved unpaid medical leave." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10516 a owl:Class ;
    ex:pcfID "10516" ; ex:hierarchyID "7.6.5" ;
    ex:apqcSourceText "Helping former employees transition to new jobs or to re-orient themselves in the job market. Deliver help through one-on-one sessions or in a group format. Provide guidance in career evaluation, resume writing, interview preparation, developing networks, and job searching." ;
    rdfs:label "Develop and implement employee outplacement" ;
    skos:definition "An Act of Information Processing that delivers transition guidance to a departing or former employee -- through one-on-one or group sessions on career evaluation, resume writing, interview preparation, networking, and job searching -- to help them transition to a new job or re-orient in the job market." ;
    rdfs:comment "Re-anchored from ex:ActOfAdministration to cco:ont00000366 (Act of Information Processing) per FIX option (a). The source describes DELIVERY of counseling/help ('Helping former employees transition ... Deliver help through one-on-one sessions or in a group format. Provide guidance ...') -- an information-handling service rendered to a person, not the authoring of a prescriptive guideline document. Phase-3 fix: ex:DevelopmentGuideline is demoted from an existential has-output to a has-input (the transition guidance being delivered, not produced) -- a transition-guidance document is content delivered, not an artifact every instance definitionally produces. ex:Employee (the departing/former employee receiving the service) is the definitional participant. One-on-one vs group delivery is method, not a tracked part." ;
    skos:example "An outplacement counselor runs resume and interview-prep sessions for laid-off staff." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DevelopmentGuideline ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P20132 a owl:Class ;
    ex:pcfID "20132" ; ex:hierarchyID "7.6.6" ;
    ex:apqcSourceText "Organizing the workforce so that all positions are covered for all shifts with the necessary skilled resources in place. Have a system in place to backfill positions while an employee is on leave." ;
    rdfs:label "Manage workforce scheduling" ;
    skos:definition "An Act of Administration that has as input workforce data and produces a staffing plan that covers all positions across all shifts with appropriately skilled resources." ;
    rdfs:comment "Output is the Directive ex:StaffingPlan because the schedule prescribes who works which shift. Decomposes into receiving resources (20133) and managing deployment (10517)." ;
    skos:example "A scheduler builds the weekly shift roster and arranges backfill for staff on leave." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StaffingPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20133 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10517 ] .

ex:P20133 a owl:Class ;
    ex:pcfID "20133" ; ex:hierarchyID "7.6.6.1" ;
    ex:apqcSourceText "Obtaining resources necessary to fill a position utilizing specific skills and capabilities." ;
    rdfs:label "Receive required resources/skills and capabilities" ;
    skos:definition "An Act of Administration that has as input skill requirement data and allocates the skilled resources necessary to fill a position within the organization's workforce schedule." ;
    rdfs:comment "Re-anchored from ex:ActOfAcquisition to ex:ActOfAdministration for parent/sibling consistency. ex:ActOfAcquisition denotes obtaining 'an entity ... that the Agent did not previously hold' (external procurement); but read in its parent context -- P20132 'Manage workforce scheduling' is about covering shifts and BACKFILLING positions with EXISTING staff -- 'receiving required skills/capabilities' is internal allocation/deployment of already-held workforce, so the surface verb 'Obtaining' was a false-friend. REJECTED reading: external procurement of a new resource (contractor/agency hire); under that reading ex:ActOfAcquisition would be correct, but the workforce-scheduling parent does not license it and the verb alone is insufficient grounds (§6 Step 2). Now matches parent P20132 and sibling P10517 (both ex:ActOfAdministration). Output as a staffing plan filler is typical, kept in comment." ;
    skos:example "A supervisor allocates an available skilled employee to cover an open shift." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SkillRequirementData ] .

ex:P10517 a owl:Class ;
    ex:pcfID "10517" ; ex:hierarchyID "7.6.6.2" ;
    ex:apqcSourceText "Allocating employees. Deploy personnel to ensure that the labor of the organization is continuously in an optimal relation to the jobs and organizational structure." ;
    rdfs:label "Manage resource deployment" ;
    skos:definition "An Act of Administration that has as input workforce data and produces a staffing plan that allocates and deploys personnel so that the organization's labor stays in optimal relation to its jobs and structure." ;
    rdfs:comment "Output is the Directive ex:StaffingPlan (the deployment allocation). Has the deployed employee as participant. Act of Motion (cco:ont00000357) was considered but the act administers allocation rather than effecting physical relocation." ;
    skos:example "A workforce manager reassigns staff across teams to balance current demand." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StaffingPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P17055 a owl:Class ;
    ex:pcfID "17055" ; ex:hierarchyID "7.6.7" ;
    ex:apqcSourceText "Managing the relocation of employees in order to carry out assignments. Manage internal business processes to transfer employees, their families, and/or entire departments of a business to a new location." ;
    rdfs:label "Relocate employees and manage assignments" ;
    skos:definition "An Act of Administration that has as input employee data and produces a relocation plan for transferring an employee, their family, or a department to a new location in order to carry out an assignment." ;
    rdfs:comment "Output is the Directive ex:RelocationPlan. Act of Motion (cco:ont00000357) was considered but the lead commitment is administering the transfer (internal processes, terms), not the physical motion itself. Decomposes into managing expatriates (10520)." ;
    skos:example "HR coordinates the transfer of an employee and their family to a regional office." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RelocationPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10520 ] .

ex:P10520 a owl:Class ;
    ex:pcfID "10520" ; ex:hierarchyID "7.6.7.1" ;
    ex:apqcSourceText "Managing foreign resources. Manage employees who are sent to live abroad for a defined time period, as well as non-native employees." ;
    rdfs:label "Manage expatriates" ;
    skos:definition "An Act of Administration that has as input employee data and produces a relocation plan governing the assignment of an employee sent to live abroad for a defined period, as well as non-native employees." ;
    rdfs:comment "Specialization of relocation (7.6.7) for cross-border assignments. Output is the Directive ex:RelocationPlan covering the foreign-posting terms." ;
    skos:example "HR administers an expatriate package, visa, and term of an employee posted overseas." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RelocationPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

####################################################################
# GROUP 7.7 "Manage employee information and analytics" (PCF 17056)
####################################################################

ex:P10522 a owl:Class ;
    ex:pcfID "10522" ; ex:hierarchyID "7.7.1" ;
    ex:apqcSourceText "Providing information and reports regarding employees to management." ;
    rdfs:label "Manage reporting processes" ;
    skos:definition "An Act of Administration that compiles employee information and produces an HR report supplied to management." ;
    rdfs:comment "Anchored to ex:ActOfAdministration: the source describes a bounded, repeatable act of providing employee reports, not a standing function. Output ex:HRReport is Descriptive (a report represents rather than prescribes), agreeing with its information-handling character (GOLDEN PRINCIPLE)." ;
    skos:example "HR runs the monthly headcount-and-turnover report and delivers it to the leadership team." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:HumanResourcesProfessional ] .

ex:P10523 a owl:Class ;
    ex:pcfID "10523" ; ex:hierarchyID "7.7.2" ;
    ex:apqcSourceText "Handling instances where an employee believes that he/she has been inappropriately treated or he/she desires clarification. Encourage employees to inquire when needed. Record and clarify the issues for which the enquiry has been made." ;
    rdfs:label "Manage employee inquiry process" ;
    skos:definition "An Act of Administration that records and clarifies the issue raised in an employee inquiry and produces a grievance resolution." ;
    rdfs:comment "Anchored to ex:ActOfAdministration: each inquiry is a bounded, repeatable occurrent (record then clarify). Input ex:EmployeeFeedback (the inquiry as raised). Output ex:GrievanceResolution is Descriptive (it records the resolved issue)." ;
    skos:example "An HR representative logs an employee's pay-discrepancy inquiry, investigates, and records the clarification provided." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GrievanceResolution ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10524 a owl:Class ;
    ex:pcfID "10524" ; ex:hierarchyID "7.7.3" ;
    ex:apqcSourceText "Capturing and updating employee information and data and information on the employees." ;
    rdfs:label "Manage and maintain employee data" ;
    skos:definition "An Act of Administration that captures and updates employee information and produces an employee record." ;
    rdfs:comment "Anchored to ex:ActOfAdministration: despite 'manage and maintain' in the label, the source describes the concrete, repeatable capture-and-update act. Input ex:EmployeeData; output ex:EmployeeRecord (Descriptive)." ;
    skos:example "HR updates an employee's address and dependents in the personnel system after a life-event notification." ;
    rdfs:subClassOf ex:ActOfAdministration ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeRecord ] .

ex:P10526 a owl:Class ;
    ex:pcfID "10526" ; ex:hierarchyID "7.7.5" ;
    ex:apqcSourceText "Creating and maintaining performance metrics for employees. Create and manage a strategic system of data and statistics to accurately gauge each employee's information. Consider productivity metrics, efficiency metrics, training metrics, etc." ;
    rdfs:label "Develop and manage employee measures" ;
    skos:definition "An Act of Measuring that derives and maintains performance metrics gauging each employee's productivity, efficiency, and training relative to a standard, and produces an employee metric." ;
    rdfs:comment "Re-anchored from ex:ActOfAdministration to cco:ont00000345 (Act of Measuring, VERIFIED against CCO v2.0: 'A Planned Act that involves determining the extent, dimensions, quanity, or quality of an Entity relative to some standard', parent cco:ont00000228). The source ('Creating and maintaining performance metrics ... to accurately gauge each employee's information ... productivity metrics, efficiency metrics, training metrics') is deriving metrics that GAUGE/MEASURE employee performance -- measuring, not execution-of-a-settled-arrangement. REJECTED ex:ActOfAdministration: its differentia explicitly excludes creating the arrangement, whereas this act derives the metrics; the label word 'manage' pulled the prior anchor. The output ex:EmployeeMetric is Descriptive (a measured indicator), which agrees with a measuring/information-processing genus far better than with administration (GOLDEN PRINCIPLE). Input ex:EmployeeData retained." ;
    skos:example "An HR analyst computes and updates productivity, efficiency, and training-completion metrics for each employee." ;
    rdfs:subClassOf cco:ont00000345 ,   # Act of Measuring (under Planned Act)
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; entailed by CCO, asserted for standalone SHACL S2/S5)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeMetric ] .

ex:P21441 a owl:Class ;
    ex:pcfID "21441" ; ex:hierarchyID "7.7.7" ;
    ex:apqcSourceText "Understand, develop, and gather workforce data in support of stakeholder requirements." ;
    rdfs:label "Develop workforce analytics" ;
    skos:definition "An Act of Acquisition that scopes, sources, and gathers workforce data in support of stakeholder requirements and produces a body of workforce data for analytics." ;
    rdfs:comment "Re-anchored from ex:ActOfAnalysis to ex:ActOfAcquisition (Planned Act: obtaining workforce data the function did not previously hold). REJECTED ex:ActOfAnalysis: neither the source ('Understand, develop, and gather workforce data in support of stakeholder requirements') nor the modeling is an analysis -- ex:ActOfAnalysis is defined as examining input ICEs to produce 'an ICE that represents an understanding of their subject matter', whereas the output ex:WorkforceData is a raw gathered dataset, not an understanding. The genus was driven by the label word 'analytics'. None of its five process-part children is an analysis act (21442/21443/21445 Identification, 21444 Selection, 21446 Acquisition); the actual analysis facet is realized by the SIBLING P21447 (Implement workforce analytics). This is a scoping-and-data-gathering aggregate. Output ex:WorkforceData retained. Its APQC children (21442-21446) are process parts, not subclasses." ;
    skos:example "A people-analytics team turns leadership's questions into a sourced, gathered workforce dataset ready for analysis." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StakeholderRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21442 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21443 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21444 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21445 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21446 ] .

ex:P21442 a owl:Class ;
    ex:pcfID "21442" ; ex:hierarchyID "7.7.7.1" ;
    ex:apqcSourceText "Collect and manage requirements from various enterprise stakeholders about workforce analytics." ;
    rdfs:label "Determine stakeholder requirements" ;
    skos:definition "An Act of Identification that collects and discerns workforce-analytics requirements from enterprise stakeholders and produces a stakeholder-requirements record." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (information processing): the act discerns and registers requirements. Output ex:StakeholderRequirements is Descriptive (it records what stakeholders need)." ;
    skos:example "An analyst interviews HR, finance, and operations leaders and consolidates their workforce-analytics requirements." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StakeholderRequirements ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

ex:P21443 a owl:Class ;
    ex:pcfID "21443" ; ex:hierarchyID "7.7.7.2" ;
    ex:apqcSourceText "Summarize stakeholder requirements into discrete research questions in support of workforce analytics." ;
    rdfs:label "Identify research questions" ;
    skos:definition "An Act of Identification that summarizes stakeholder requirements into discrete research questions and produces a research question." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (information processing): the act discerns and enumerates research questions. Input ex:StakeholderRequirements; output ex:ResearchQuestion is Descriptive." ;
    skos:example "Requirements about attrition risk are restated as the question 'which factors predict voluntary turnover within 12 months?'." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StakeholderRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ResearchQuestion ] .

ex:P21444 a owl:Class ;
    ex:pcfID "21444" ; ex:hierarchyID "7.7.7.3" ;
    ex:apqcSourceText "Consider stakeholder requirements, research questions, and organizations standards around research to select appropriate research methodology in support of workforce analytics." ;
    rdfs:label "Select workforce analysis methodology" ;
    skos:definition "An Act of Selection that chooses an appropriate research methodology from candidate approaches in light of stakeholder requirements and research questions and produces a workforce analysis methodology." ;
    rdfs:comment "Anchored to ex:ActOfSelection: a methodology is chosen from candidates. Output ex:WorkforceAnalysisMethodology is Directive (it prescribes how the analysis is to be conducted), so selection (directive output) satisfies the GOLDEN PRINCIPLE." ;
    skos:example "Given the turnover question, the team selects a survival-analysis methodology over simple cross-tabulation." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StakeholderRequirements ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ResearchQuestion ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceAnalysisMethodology ] .

ex:P21445 a owl:Class ;
    ex:pcfID "21445" ; ex:hierarchyID "7.7.7.4" ;
    ex:apqcSourceText "Identify appropriate data sources for workforce analytics data while considering organizational standards for data sources." ;
    rdfs:label "Identify workforce data sources" ;
    skos:definition "An Act of Identification that discerns the appropriate data sources for workforce-analytics data in light of organizational data-source standards." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (information processing): the act discerns and registers suitable data sources. Phase-3: the output (a register of identified workforce data sources) is left in this comment rather than promoted to a has-output restriction because no shared ICE filler exists for it and minting one is not warranted for this leaf." ;
    skos:example "The team confirms the HRIS, payroll, and an external benchmarking feed as the approved sources for the study." ;
    rdfs:subClassOf ex:ActOfIdentification .

ex:P21446 a owl:Class ;
    ex:pcfID "21446" ; ex:hierarchyID "7.7.7.5" ;
    ex:apqcSourceText "Collect and procure, as needed, workforce data from internal and external data sources in support of workforce analytics." ;
    rdfs:label "Gather workforce data" ;
    skos:definition "An Act of Acquisition that collects and procures workforce data from internal and external sources and produces a body of workforce data." ;
    rdfs:comment "Anchored to ex:ActOfAcquisition (Planned Act): the act obtains workforce data the analytics function did not previously hold (collected or purchased). Output ex:WorkforceData is the descriptive data so obtained. Rejected ex:ActOfAdministration because the emphasis is on procuring new data, not maintaining existing records." ;
    skos:example "The team extracts internal HRIS records and purchases an external labor-market dataset for the analysis." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceData ] .

ex:P21447 a owl:Class ;
    ex:pcfID "21447" ; ex:hierarchyID "7.7.8" ;
    ex:apqcSourceText "Transform, develop, and communicate workforce data into analytics in support of organizational requirements." ;
    rdfs:label "Implement workforce analytics" ;
    skos:definition "An Act of Analysis that transforms workforce data, develops insights, and communicates them, producing a workforce analysis in support of organizational requirements." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (information processing): input workforce data is manipulated into an analytic representation. Its APQC children (21448-21450) are process parts, not subclasses." ;
    skos:example "The people-analytics team validates the dataset, models attrition drivers, and briefs leadership on the findings." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21448 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21449 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21450 ] .

ex:P21448 a owl:Class ;
    ex:pcfID "21448" ; ex:hierarchyID "7.7.8.1" ;
    ex:apqcSourceText "Logically and statistically validate collected or purchased data in support of analytics needs" ;
    rdfs:label "Transform workforce analysis data" ;
    skos:definition "An Act of Data Transformation that logically and statistically validates collected or purchased workforce data and produces validated workforce data." ;
    rdfs:comment "Reuses CCO cco:ont00001158 (Act of Data Transformation) directly: input ICEs are validated/cleaned into output ICEs. Input and output are ex:WorkforceData (the dataset before and after validation), Descriptive throughout." ;
    skos:example "The analyst removes duplicates, checks ranges, and runs validation statistics on the gathered dataset." ;
    rdfs:subClassOf cco:ont00001158 ,   # Act of Data Transformation (under Act of Information Processing)
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; entailed by CCO, asserted for standalone SHACL S2/S5)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceData ] .

ex:P21449 a owl:Class ;
    ex:pcfID "21449" ; ex:hierarchyID "7.7.8.2" ;
    ex:apqcSourceText "Synthesize insights from workforce analytics data" ;
    rdfs:label "Develop insights into workforce analytics outcomes" ;
    skos:definition "An Act of Analysis that synthesizes insights from validated workforce-analytics data and produces a workforce analysis." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (information processing): the act manipulates the validated dataset into an analytic representation. Input ex:WorkforceData; output ex:WorkforceAnalysis is Descriptive." ;
    skos:example "From the validated data the team derives the finding that overtime intensity predicts attrition in two units." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:WorkforceAnalysis ] .

ex:P21450 a owl:Class ;
    ex:pcfID "21450" ; ex:hierarchyID "7.7.8.3" ;
    ex:apqcSourceText "Summarize, package, and distribute results of workforce analysis." ;
    rdfs:label "Communicate workforce analysis outcomes" ;
    skos:definition "An Act of Communication that summarizes and packages a workforce analysis and distributes it to its recipients as an HR report." ;
    rdfs:comment "Reuses CCO cco:ont00000402 (Act of Communication): an Information Content Entity (the packaged workforce analysis) is transferred from the analytics team to recipients. Input ex:WorkforceAnalysis; output ex:HRReport (the packaged, distributed result), Descriptive." ;
    skos:example "The team turns the analysis into a dashboard and briefing deck and distributes it to the requesting leaders." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; entailed by CCO, asserted for standalone SHACL S2/S5)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:WorkforceAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:HRReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

ex:P10530 a owl:Class ;
    ex:pcfID "10530" ; ex:hierarchyID "7.7.9" ;
    ex:apqcSourceText "Procuring and handling suggestions from employees, and performing research on employees. Manage and analyze the programs that help the organization to tap into employee ideas for improving the organization's processes and/or products. Use surveys, focus groups, and other data-gathering methods to find out the attitudes, opinions, and feelings of members of an organization." ;
    rdfs:label "Manage/Collect employee suggestions and perform employee research" ;
    skos:definition "An Act of Analysis that performs employee research through surveys and focus groups and produces an engagement survey result describing employee attitudes and opinions." ;
    rdfs:comment "Compound-row de-conflation (§4): the source fuses (a) managing/collecting employee suggestions and running the suggestion PROGRAMS ('Manage and analyze the programs that help the organization to tap into employee ideas') -- administrative/program-management -- and (b) performing employee research via surveys and focus groups -- analysis. The primary PCF class is reduced to the research facet (ex:ActOfAnalysis -> ex:EngagementSurveyResult) and carries the PCF identifiers; the dropped suggestion-program-management facet is modeled in the supporting class ex:P10530_SuggestionProgram (ex:ActOfAdministration, input ex:EmployeeFeedback, output ex:SuggestionRegister) and linked here via has process part so it is not silently lost. Input ex:EmployeeFeedback; output ex:EngagementSurveyResult is Descriptive. Participant ex:Employee is the research subject. NOTE: the EmployeeFeedback-as-input pattern recurs at P16944 (7.8.2)." ;
    skos:example "HR runs an annual engagement survey and a set of focus groups and reports the workforce's sentiment to leadership." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EngagementSurveyResult ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10530_SuggestionProgram ] .

# Supporting process class for the suggestion-program-management facet
# de-conflated out of compound row P10530 (§4). Carries NO PCF identifiers
# (the primary PCF class P10530 retains them).
ex:P10530_SuggestionProgram a owl:Class ;
    rdfs:label "Manage employee suggestion program" ;
    skos:definition "An Act of Administration that collects and handles employee suggestions and runs the programs through which an organization taps into employee ideas, recording them in a suggestion register." ;
    rdfs:comment "Supporting class minted to carry the administrative suggestion-program-management facet de-conflated from compound row P10530 (§4); it is NOT a PCF-derived class, so per §4 it bears no ex:pcfID/ex:hierarchyID/ex:apqcSourceText and is intentionally left without has-input/has-output someValuesFrom restrictions (so it is not subject to the PCF-provenance ProcessShape, which targets only ex: classes carrying an I/O or part restriction). Its I/O is recorded here: input ex:EmployeeFeedback (the suggestions collected); output ex:SuggestionRegister; participant ex:Employee. Anchored at ex:ActOfAdministration (running an established suggestion program); linked from P10530 by has process part." ;
    skos:example "HR operates the staff suggestion scheme, logging and triaging submitted ideas." ;
    rdfs:subClassOf ex:ActOfAdministration .

# --- group-7.7 standing system-administration functions (R5/R6) ---

ex:HumanResourcesInformationSystemCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:ActOfAdministration ] ;
    rdfs:label "Human Resources Information System Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to administer and maintain the HR information systems supporting HR, accounting, management, and payroll activities, realized in repeated acts of HR-system administration." ;
    rdfs:comment "R5/R6: APQC 7.7.4 (PCF 10525) 'Manage human resource information systems HRIS' is a standing function with no natural end ('administering and maintaining' a system), so it is modeled as an Organization Capability rather than a process. Realized in Acts of Administration." .

ex:TimeAndAttendanceManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:ActOfAdministration ] ;
    rdfs:label "Time and Attendance Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to develop and maintain the systems that track employee time and attendance, realized in repeated acts of time-and-attendance system administration." ;
    rdfs:comment "R5/R6: APQC 7.7.6 (PCF 10527) 'Develop and manage time and attendance systems' is a standing system-administration function with no natural end, so it is modeled as an Organization Capability rather than a process. Realized in Acts of Administration." .

# R6: the shared standing analytics function is realized in the bounded
# analytics acts modeled above.
ex:WorkforceAnalyticsCapability rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21441 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21447 ] .

####################################################################
# GROUP 7.8 "Manage employee communication" (PCF 21451)
#   7.8 itself is a standing function -> reuses the shared
#   ex:EmployeeCommunicationCapability; only R6 'realized in' added here.
#   Its three children are bounded acts modeled as processes.
####################################################################

ex:P10529 a owl:Class ;
    ex:pcfID "10529" ; ex:hierarchyID "7.8.1" ;
    ex:apqcSourceText "Creating a plan for managing communication among employees. Inform employees of direction. Counter resistance with change management approaches. Seek specific areas of input to the decision-making process. Seek varying degrees of involvement and co-creation." ;
    rdfs:label "Develop employee communication plan" ;
    skos:definition "An Act of Formulation that composes a plan governing communication and engagement among employees and between employees and management, and has as output an employee communication plan." ;
    rdfs:comment "Genus ex:ActOfFormulation (Act of Planning): the act articulates a Directive ICE (the plan). Employee feedback and stakeholder requirements may be sought as input for co-creation but are optional, so they are not promoted to existential restrictions (Phase-3)." ;
    skos:example "An HR team drafts the annual internal-communications and engagement plan, incorporating change-management messaging." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EmployeeCommunicationPlan ] .

ex:P16944 a owl:Class ;
    ex:pcfID "16944" ; ex:hierarchyID "7.8.2" ;
    ex:apqcSourceText "Questioning employees to ascertain overall workplace satisfaction." ;
    rdfs:label "Conduct employee engagement surveys" ;
    skos:definition "An Act of Analysis that questions employees and processes their responses to ascertain overall workplace satisfaction, and has as output an engagement survey result." ;
    rdfs:comment "Genus ex:ActOfAnalysis (Act of Information Processing): employee responses are elicited and manipulated into a representation of satisfaction. Output is descriptive (a finding), not prescriptive (GOLDEN PRINCIPLE). Phase-3 / has-input fix: the prior [has input some ex:EmployeeFeedback] existential restriction is DROPPED -- has input (cco:ont00001921) requires a continuant PRESENT AT START, but the survey responses are PRODUCED DURING the act of questioning (ex:EmployeeFeedback's own definition has the responses 'gathered from employees', i.e. on the output/internal side), so they are not antecedent inputs and were being double-counted. The engagement-survey-result output plus the Employee participant already capture the definitional content; any survey instrument/questionnaire that does pre-exist is left to commentary. The Employee participant restriction is retained (definitional to a survey)." ;
    skos:example "HR runs a quarterly engagement survey and compiles the results into a workplace-satisfaction report." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EngagementSurveyResult ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

ex:P10532 a owl:Class ;
    ex:pcfID "10532" ; ex:hierarchyID "7.8.3" ;
    ex:apqcSourceText "Implementing the communication plan for employees. Initiate dialogues and engagement by monitoring the exchange of ideas and opinions, the development of personal relationships, etc." ;
    rdfs:label "Deliver employee communications" ;
    skos:definition "An Act of Communication that transfers information to employees in execution of an employee communication plan, initiating dialogue and engagement." ;
    rdfs:comment "Anchored directly under cco:ont00000402 (Act of Communication, verified: a Planned Act transferring an ICE from one Agent to another) rather than minting a genus; reuse before mint (D5/D6). The employee communication plan it implements is a definitional input; employees are definitional participants (recipients). The specific informational content transferred varies by message and is therefore left as commentary rather than an existential output restriction." ;
    skos:example "Internal communications publishes the planned messaging to staff and hosts town-hall dialogues to gather responses." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication
        cco:ont00000228 ,   # Planned Act (explicit allowlist anchor; entailed by CCO, asserted for standalone SHACL S2/S5)
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmployeeCommunicationPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Employee ] .

# R6: the shared standing 'Manage employee communication' function is
# realized in its three constituent acts (additive wiring only; the
# shared class is not redefined here).
ex:EmployeeCommunicationCapability rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10529 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16944 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10532 ] .

####################################################################
# 7. CATALOG -> REALITY BRIDGES
#    Each ex:PCF_<pcfID> catalog node designates its reality-layer
#    class (process ex:P<pcfID>, or a capability for standing functions).
#    Group/heading nodes that model nothing in the reality layer (R3)
#    carry no bridge.
####################################################################

