@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC PCF -> BFO 2020 / CCO 2.0  REALITY-LAYER MODULE
# Section 3.0 "Market and Sell Products and Services" (PCF 10004)
#
# Assembled, reconciled single module covering process groups
# 3.1 - 3.5 plus the section-wide shared supporting vocabulary.
# House style + prefixes mirror the GOLD reference
# ontology/slices/apqc_1_1_1.ttl.
#
# CCO pin: v2.0 (2024-11-06). Every cco:ont... IRI below was verified
# against vendor/cco/CommonCoreOntologiesMerged.ttl (definition read,
# not just label). Verified anchors:
#   Act of Information Processing  cco:ont00000366
#   Act of Appraisal               cco:ont00000636
#   Act of Prediction              cco:ont00000371
#   Act of Planning                cco:ont00000511
#   Planned Act                    cco:ont00000228
#   Act of Communication           cco:ont00000402
#   Descriptive ICE                cco:ont00000853
#   Prescriptive (Directive) ICE   cco:ont00000965
#   Predictive ICE                 cco:ont00000626
#   Agent                          cco:ont00001017
#   Organization                   cco:ont00001180
#   Organization Capability        cco:ont00000568
#   Agent Capability               cco:ont00001379
#   is about                       cco:ont00001808
#   has input / has output         cco:ont00001921 / cco:ont00001986
#   has process part               cco:ont00001777
#   role / bearer of / realized in / has participant
#       obo:BFO_0000023 / obo:BFO_0000196 / obo:BFO_0000054 / obo:BFO_0000057
#   material entity                obo:BFO_0000040
####################################################################

<http://example.org/apqc/slice/3.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 3.0: Market and Sell Products and Services" ;
    dct:source "APQC Process Classification Framework (Cross-Industry)" ;
    owl:versionInfo "0.3.0" ;
    rdfs:comment "Reality-layer module for APQC section 3.0 (groups 3.1-3.5) plus the section-wide shared supporting vocabulary. CCO pin v2.0 (2024-11-06); two-layer policy per ADR-001 (reality layer only; the SKOS catalog lives in apqc-catalog.ttl). Self-contained: the shared act genera it uses are inlined from the apqc-ext.ttl registry, so it validates standalone against the pinned CCO/BFO closure with no extension merge." .

####################################################################
# ACT GENERA -- SELF-CONTAINED (canonical defs mirrored from
# apqc-ext.ttl, the D9 shared registry). Inlined so this module
# validates standalone against CCO without merging the extension.
####################################################################

ex:ActOfAcquisition a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Acquisition" ;
    skos:definition "A Planned Act in which an Agent obtains from some authority or supplier an entity (such as an authorization, license, or resource) that the Agent did not previously hold." ;
    rdfs:comment "Local extension (D9). Rejected cco:ont00000950 'Act of Maintenance' (modifying Material Artifacts) and cco:ont00000402 'Act of Communication' (mere ICE transfer). Securing/obtaining a held entity anchors at the generic Planned Act. Expected to recur in procurement/asset-acquisition categories (4.0, 10.0)." .

ex:ActOfAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Analysis" ;
    skos:definition "An Act of Information Processing in which an Agent examines one or more input Information Content Entities and produces an Information Content Entity that represents an understanding of their subject matter." ;
    rdfs:comment "Local extension (D9). CCO 2.0 has no generic analysis class; analysis is information processing, so it is anchored under cco:ont00000366." .

ex:ActOfForecasting a owl:Class ;
    rdfs:subClassOf cco:ont00000371 ,   # Act of Prediction
        cco:ont00000228 ;               # Planned Act (explicit; Act of Prediction ⊑ Planned Act in CCO, asserted so the standalone SHACL S2 Act-anchor chain resolves)
    rdfs:label "Act of Forecasting" ;
    skos:definition "An Act of Prediction in which an Agent extrapolates from historical and current Information Content Entities to produce a Predictive Information Content Entity that estimates a future quantity such as demand, volume, revenue, or value." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000371 (Act of Prediction, verified: 'A Planned Act that involves the generation of a Predictive Information Content entity that is intended to describe an uncertain possible future event, value, entity, or attribute'; parent cco:ont00000228), whose definitional output is a Predictive ICE (cco:ont00000626 ⊑ cco:ont00000853 Descriptive ICE) -- exactly the genus of a sales/demand/volume/ROI forecast. A thin specialization (quantitative, history-driven business projection) kept shared so slice agents need not re-derive the anchor. Output is a PREDICTIVE ICE (a Descriptive ICE about an uncertain future), per the GOLDEN PRINCIPLE. Recurs in 3.0 and 6.0." .

ex:ActOfFormulation a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Formulation" ;
    skos:definition "An Act of Planning in which an Agent composes and articulates a Directive Information Content Entity - such as a mission, strategy, objective, design, roadmap, or business model - that prescribes an organization's intended course of action." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000511 (Act of Planning) because formulating a strategy/mission/design is making a plan to achieve an objective; its output is a Directive ICE. Recurs across develop/define/compose-a-directive processes corpus-wide." .

ex:ActOfIdentification a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Identification (discernment sense)" ;
    skos:definition "An Act of Information Processing in which an Agent discerns and enumerates entities of a given kind and produces an Information Content Entity that registers them." ;
    rdfs:comment "Local extension (D9). NOT cco:ont00001261 'Act of Identifying' (a communication act). APQC 'Identify ...' denotes discernment, i.e. information processing." .

ex:ActOfMonitoring a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Monitoring" ;
    skos:definition "An Act of Information Processing in which an Agent repeatedly or continuously observes the state, progress, or performance of some process, system, or quantity over time and produces a Descriptive Information Content Entity that represents its tracked status against expected conditions, targets, or requirements." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic monitoring/tracking class. Anchored under cco:ont00000366 (Act of Information Processing) because monitoring ingests repeated observations (including electronic records, not only senses) and yields a descriptive status/deviation ICE -- the GOLDEN PRINCIPLE (descriptive output => information-processing genus) holds. Rejected cco:ont00000037 (Act of Observation: a single sense-based acquisition, too narrow -- monitoring also processes ICEs and is sustained); cco:ont00000636 (Act of Appraisal: renders a single bounded value/quality judgement rather than tracking status over time); and cco:ont00000345 (Act of Measuring: a single quantification against a standard at one time -- at most a method sub-step of the monitoring cycle; a node that is purely one quantification, e.g. Calculate performance measures, anchors to cco:ont00000345 directly, not here). Distinct from ex:ActOfAnalysis (one-shot examination of a fixed input set) by its continuous, longitudinal character. A standing 'Manage/Monitor X' function with no natural end is an Organization Capability (cco:ont00000568) realized in such acts, not itself a process. Recurs corpus-wide (slices 3.0/4.0/5.0/6.0/8.0/9.0/10.0/11.0/12.0/13.0). Reconciled from 10 divergent slice restatements to one definition." .

ex:ActOfSelection a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Selection" ;
    skos:definition "An Act of Information Processing in which an Agent chooses one or more options from a set of candidates and produces a Directive Information Content Entity that prescribes the chosen option(s)." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000366 (Act of Information Processing): receives candidate-option ICEs and yields a decision ICE. Distinct from Act of Appraisal (judges without committing) and Act of Planning. NOTE: ratifying a single already-settled option is NOT selection (no candidate set) -- anchor such acts at cco:ont00000228 (Planned Act)." .

ex:ActOfSelling a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Selling" ;
    skos:definition "A Planned Act in which an Agent (the seller) transfers ownership of a good or the provision of a service to another Agent (the buyer) in exchange for a Financial Instrument." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 models only the BUYER side (cco:ont00001334 Act of Purchasing, cco:ont00000389 Act of Buying, cco:ont00000836 Act of Financial Instrument Use); APQC 3.5 makes the seller the focal Agent, so a complementary seller-side act is anchored at the generic cco:ont00000228 (Planned Act). Rejected cco:ont00000402 (Act of Communication: a sale transfers a good/value, not merely an ICE). A transactional Planned Act, neutral on ICE output. Recurs across sell-product/service processes (3.0)." .

####################################################################
# 0. ANNOTATION PROPERTIES (provenance + catalog->reality bridge)
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "ADR-001 R4 bridge: catalog node (ex:PCF_<id>, defined in apqc-catalog.ttl) -> reality-layer process universal or capability. Populated during reality-layer modeling, NOT by the catalog generator." .

####################################################################
# 1. ACT-GENUS LAYER  (PROPOSE-EXT: new recurring genera section 3.0
#    are section-specific). Inlined from the apqc-ext.ttl registry:
#      ex:ActOfAnalysis, ex:ActOfIdentification, ex:ActOfFormulation,
#      ex:ActOfSelection, ex:ActOfAcquisition.
#    Reused-as-is from CCO: cco:ont00000371 (Act of Prediction);
#      cco:ont00000636 (Act of Appraisal); cco:ont00000402 (Act of
#      Communication); cco:ont00000511 (Act of Planning);
#      cco:ont00000228 (Planned Act); cco:ont00000366 (Act of
#      Information Processing).
####################################################################

####################################################################
# 2. SHARED SUPPORTING VOCABULARY  (section-3.0 single source of truth)
#    Mints ONCE every input/output ICE, agent/organization, role, and
#    capability used by groups 3.1-3.5. NO process classes here.
####################################################################

# ---- 2a. INPUT INFORMATION CONTENT ENTITIES (Descriptive ICE) ----

ex:CustomerData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Data" ;
    skos:definition "A Descriptive Information Content Entity that describes customers, their attributes, needs, and behavior." ;
    rdfs:comment "Minted because section 3.0 repeatedly consumes customer descriptions as input (3.1, 3.3, 3.5). Descriptive: it represents customers rather than prescribing action." .

ex:MarketData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Data" ;
    skos:definition "A Descriptive Information Content Entity that describes features, conditions, and dynamics of a market." ;
    rdfs:comment "Minted as a recurring input across 3.1-3.4. Reuses the same intent as the 1.1.1 reference MarketData; re-stated here so section 3.0 modules need not import the reference slice." .

ex:CompetitorData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Competitor Data" ;
    skos:definition "A Descriptive Information Content Entity that describes competing organizations and their products or services." ;
    rdfs:comment "Recurring input in 3.1.1.4, 3.5.3.4. Descriptive representation of rivals." .

ex:IndustryTrendData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Industry Trend Data" ;
    skos:definition "A Descriptive Information Content Entity that describes large-scale shifts and movements in an industry or wider market relevant to an organization's offerings." ;
    rdfs:comment "Input to 3.1.1.3. Descriptive." .

ex:SalesOrderData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sales Order Data" ;
    skos:definition "A Descriptive Information Content Entity that describes current and historical sales orders, including product, quantity, customer, price, and terms." ;
    rdfs:comment "Input to 3.4.1 (forecast) and 3.5.4 (order management). Descriptive record of orders." .

ex:CustomerFeedback a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Feedback" ;
    skos:definition "A Descriptive Information Content Entity that describes responses, opinions, and reactions expressed by customers about an organization's offerings." ;
    rdfs:comment "Input to 3.2.1.3 (validation), 3.3.6 (respond to insight). Descriptive." .

ex:ChannelData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Channel Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the attributes, partners, costs, and performance of marketing and distribution channels." ;
    rdfs:comment "Input to 3.2.3 and 3.2.4. Descriptive." .

ex:CostData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Cost Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the production, distribution, marketing, and overhead costs associated with offerings or activities." ;
    rdfs:comment "Input to pricing (3.2.2, 3.3.3) and budgeting (3.3.2, 3.4.3). Descriptive." .

ex:RequestForProposal a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Request for Proposal (RFP/RFQ)" ;
    skos:definition "A Descriptive Information Content Entity issued by a prospective customer that describes requirements, scope, and evaluation criteria solicited from suppliers." ;
    rdfs:comment "Input received in 3.5.3.1. Descriptive: it states the customer's requirements (a description), not the supplier's prescribed plan." .

# ---- 2b. OUTPUT INFORMATION CONTENT ENTITIES ----
# Descriptive ICE (cco:ont00000853) for analyses/judgements/records;
# Directive ICE  (cco:ont00000965) for strategies/plans/specs/decisions;
# Predictive ICE (cco:ont00000626) for forecasts.

# -- 3.1 Understand markets, customers, capabilities (DESCRIPTIVE) --

ex:MarketIntelligenceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Intelligence Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the attributes, behavior, and trends of market and customer segments gathered as intelligence." ;
    rdfs:comment "Output of 3.1.1. Descriptive (Analysis/Info-Processing genus)." .

ex:CustomerResearchFindings a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Customer Research Findings" ;
    skos:definition "A Descriptive Information Content Entity that describes the behavior, characteristics, drives, and desires of prospective and current customers as discovered through research." ;
    rdfs:comment "Output of 3.1.1.1. Descriptive; is about the Customer studied." .

ex:CustomerBehaviorModel a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Customer Behavior Model" ;
    skos:definition "A Descriptive Information Content Entity that describes patterns in customer purchasing behavior, including a forecast of future purchasing." ;
    rdfs:comment "Output of 3.1.1.1.1 and 3.1.1.1.2. Descriptive model; is about the Customer. (A purely forward-looking purchasing prediction is a Predictive ICE; see ex:PurchasingForecast.)" .

ex:PurchasingForecast a owl:Class ; rdfs:subClassOf cco:ont00000626 , cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Customer Purchasing Forecast" ;
    skos:definition "A Predictive Information Content Entity that describes the expected future purchasing behavior of a customer segment." ;
    rdfs:comment "Output of 3.1.1.1.2 (predict customer purchasing behavior). Predictive ICE: describes an uncertain future. is about the Customer." .

ex:MarketSegmentation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Segmentation" ;
    skos:definition "A Descriptive Information Content Entity that describes a partition of the customer population into market segments." ;
    rdfs:comment "Output of 3.1.1.2 (identify market segments). Descriptive partition, not a directive to act." .

ex:MarketShareAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Share Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the gain or loss of an organization's sales volume in targeted markets and its underlying causes." ;
    rdfs:comment "Output of 3.1.1.2.1 and 3.4.3.1. Descriptive analysis." .

ex:IndustryTrendAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Industry and Market Trend Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes large-scale shifts and trends affecting the uptake of an organization's products or services." ;
    rdfs:comment "Output of 3.1.1.3. Descriptive." .

ex:CompetitiveAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:CompetingOrganization ] ;
    rdfs:label "Competitive Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the strengths, weaknesses, and attributes of competing organizations and substitute products relative to a focal organization." ;
    rdfs:comment "Output of 3.1.1.4 and 3.5.3.4. Descriptive; is about the CompetingOrganization." .

ex:ProductPortfolioAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Product Portfolio Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the relative market position of an organization's existing brands and products." ;
    rdfs:comment "Output of 3.1.1.5 (evaluate existing products/services). Descriptive (Appraisal genus)." .

ex:BusinessEnvironmentAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Business Environment Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the internal and external environment in which an organization operates and its bearing on bringing offerings to market." ;
    rdfs:comment "Output of 3.1.1.6. Descriptive (Appraisal genus). Distinct from the 1.1.1 ExternalEnvironmentAssessment by covering internal as well as external factors for a market-entry lens." .

ex:MarketOpportunity a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Opportunity Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes an identified opportunity to capture value in a market." ;
    rdfs:comment "Subject matter carried forward through 3.1.2 and identified in 3.4.2.1. Descriptive representation of an opportunity; quantification/prioritization/validation act on it." .

ex:OpportunityQuantification a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Opportunity Quantification" ;
    skos:definition "A Descriptive Information Content Entity that describes quantified value indicators attached to identified market opportunities." ;
    rdfs:comment "Output of 3.1.2.1. Descriptive." .

ex:TargetSegmentDefinition a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Target Segment Definition" ;
    skos:definition "A Directive Information Content Entity that prescribes which customer segments the organization will target." ;
    rdfs:comment "Output of 3.1.2.2 and 3.3.4.3. Directive: selecting/committing to target segments prescribes a course of marketing action (Selection genus)." .

ex:OpportunityPrioritization a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Opportunity Prioritization" ;
    skos:definition "A Directive Information Content Entity that prescribes a ranked ordering of market opportunities consistent with organizational capabilities and strategy." ;
    rdfs:comment "Output of 3.1.2.3. Directive: a ranked index that prescribes which opportunities to pursue first (Selection/Formulation genus)." .

ex:OpportunityValidation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Opportunity Validation Result" ;
    skos:definition "A Descriptive Information Content Entity that describes confirmation of the feasibility and reasonableness of identified market opportunities, including whether a sales lead meets requirements for pursuit." ;
    rdfs:comment "Output of 3.1.2.4 (and tasks 3.1.2.4.1, 3.1.2.4.2) and of 3.5.1.3 (validate/qualify leads). Descriptive judgement of feasibility (Appraisal genus)." .

ex:UnderservedSegmentFinding a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Under-served and Saturated Segment Finding" ;
    skos:definition "A Descriptive Information Content Entity that describes which market segments lack access to (under-served) or already have access to (saturated) an organization's offerings." ;
    rdfs:comment "Output of 3.1.2.2.1 (PCF 18941). Descriptive because it registers a state of affairs rather than prescribing action." .

ex:CapabilityConfirmation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Internal Capability Confirmation" ;
    skos:definition "A Descriptive Information Content Entity that describes a verification that an organization has sufficient infrastructure and resources to deliver and scale its offerings to an identified market segment." ;
    rdfs:comment "Output of 3.1.2.4.2 (PCF 10121). Descriptive because it reports the result of a verification rather than prescribing action." .

# -- 3.2 Develop marketing strategy (mostly DIRECTIVE) --

ex:ValueProposition a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Customer Value Proposition" ;
    skos:definition "A Directive Information Content Entity that prescribes the suite of benefits an organization's offering delivers to a customer and how it is positioned." ;
    rdfs:comment "Output of 3.2.1 and 3.2.1.1/.2. Directive: a value proposition commits the organization to a positioning (Formulation genus)." .

ex:BrandPositioning a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Brand Positioning" ;
    skos:definition "A Directive Information Content Entity that prescribes how a brand is projected and differentiated for target customer segments." ;
    rdfs:comment "Output of 3.2.1.2. Directive (Formulation)." .

ex:BrandingCollateral a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Branding Collateral" ;
    skos:definition "A Directive Information Content Entity, such as a name, design, symbol, or campaign, that prescribes the projected identity of an organization's offering." ;
    rdfs:comment "Output of 3.2.1.4 (develop new branding) and 3.3.4.5 (execute promotional activities). Directive: collateral encodes a prescribed brand identity to be applied (Formulation genus). Modeled as an ICE (its content), not the physical artifact." .

ex:PricingStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Pricing Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes the strategy and methodology guiding the pricing of an organization's products and services." ;
    rdfs:comment "Output of 3.2.2, 3.3.3.3, 3.3.3.6. Directive (Formulation)." .

ex:PricingAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Pricing Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the analysis of demand, attributes, competitor pricing, and trends used to determine optimum prices, including estimated delivery costs, fees, and timelines for a proposed solution." ;
    rdfs:comment "Output of 3.2.2.1 and 3.5.3.9 pricing work. Descriptive (Analysis genus); feeds the directive PricingStrategy/PricingGuideline." .

ex:PricingGuideline a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Pricing Guideline" ;
    skos:definition "A Directive Information Content Entity that prescribes a uniform methodology and rules for setting and discounting the price of individual offerings." ;
    rdfs:comment "Output of 3.2.2.2. Directive: guidelines prescribe how to price (Formulation genus)." .

ex:PricingTarget a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Pricing Target" ;
    skos:definition "A Directive Information Content Entity that prescribes the optimum price set for individual products or services." ;
    rdfs:comment "Output of 3.2.2.3. Directive: a target price prescribes what to charge (Formulation genus)." .

ex:PricingApproval a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Pricing Approval" ;
    skos:definition "A Directive Information Content Entity that prescribes ratification of a pricing strategy, policy, or target as authorized for use." ;
    rdfs:comment "Output of 3.2.2.4 and 3.3.3.10. Directive: an approval is a prescriptive decision authorizing action." .

ex:ChannelStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Channel Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes which marketing and distribution channels an organization will use and how they align with strategy for each segment." ;
    rdfs:comment "Output of 3.2.3. Directive (Formulation)." .

ex:ChannelEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:MarketingChannel ] ;
    rdfs:label "Channel Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes the assessed attributes, fit, and partner capabilities of marketing channels." ;
    rdfs:comment "Output of 3.2.3.3 and 3.2.3.6. Descriptive (Appraisal); is about the MarketingChannel." .

ex:ChannelSelection a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Channel Selection" ;
    skos:definition "A Directive Information Content Entity that prescribes the marketing channels chosen for target segments." ;
    rdfs:comment "Output of 3.2.3.1 and 3.2.3.4. Directive (Selection genus): commits to chosen channels." .

ex:ChannelRequirements a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Channel Requirements" ;
    skos:definition "A Directive Information Content Entity that prescribes the capabilities and preconditions a channel must satisfy to be adopted." ;
    rdfs:comment "Output of 3.2.3.2, 3.2.3.5, 3.2.3.7.2. Directive (Formulation)." .

ex:OmniChannelStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Omni-Channel Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes how to market and serve customers seamlessly across all supported channels." ;
    rdfs:comment "Output of 3.2.3.7, 3.2.3.7.1. Directive (Formulation)." .

ex:PolicyAndProcedure a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Policy and Procedure" ;
    skos:definition "A Directive Information Content Entity that prescribes detailed policies and procedures to be followed in conducting an activity." ;
    rdfs:comment "Output of 3.2.3.7.3 and 3.2.5.8. Directive (Formulation)." .

ex:ExecutionRoadmap a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Execution Roadmap" ;
    skos:definition "A Directive Information Content Entity that prescribes the actions, ordering, timing, and dependencies for executing a strategy or delivering a proposed solution." ;
    rdfs:comment "Output of 3.2.3.8, 3.4.2.6, and 3.5.3.7. Directive (Formulation)." .

ex:PerformanceMeasure a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Measure Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the metrics, benchmarks, and targets used to gauge performance." ;
    rdfs:comment "Output of 3.2.4.1, 3.3.1, 3.4.4. Directive: establishing a measure prescribes what to track and the target to meet (Formulation genus)." .

ex:PerformanceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes tracked performance trends and deviations for a process, channel, or program." ;
    rdfs:comment "Output of 3.2.4.2, 3.2.4.3, 3.2.6.4 monitoring acts. Descriptive (Monitoring genus)." .

ex:ChannelPerformanceAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:MarketingChannel ] ;
    rdfs:label "Channel Performance Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes channel performance reviewed against chosen metrics, benchmarks, and targets." ;
    rdfs:comment "Output of 3.2.4.4. Descriptive (Analysis); is about the MarketingChannel." .

ex:ImprovementPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Improvement Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes actions to improve under-performing channels, programs, or processes and to expand those exceeding expectations." ;
    rdfs:comment "Output of 3.2.4.5, 3.2.6.5, 3.3.4.7, 3.3.4.8. Directive (Formulation)." .

ex:MarketingStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Marketing Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's overall go-to-market course, comprising its value proposition, pricing strategy, channel strategy, marketing communication strategy, and customer loyalty program." ;
    rdfs:comment "Minted (Gate-F) as the overall deliverable of 3.2 (P10102 Develop marketing strategy). Distinct from and broader than ex:MarketingCommunicationStrategy, which is only the communication sub-strategy authored by its child 3.2.5 (P16848). Directive (Formulation): it prescribes a course of action." .

ex:MarketingCommunicationStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Marketing Communication Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes how promotional messages are delivered in a coordinated way across marketing channels." ;
    rdfs:comment "Output of 3.2.5 and its sub-strategies (PR 3.2.5.2, direct 3.2.5.3, internal 3.2.5.4, new-media 3.2.5.6, POS 3.2.5.7). Directive (Formulation). Narrower than ex:MarketingStrategy: it is only the communication sub-strategy, not the whole go-to-market strategy." .

ex:CommunicationCalendar a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Communication Calendar" ;
    skos:definition "A Directive Information Content Entity that prescribes the timing and scheduling of marketing message delivery." ;
    rdfs:comment "Output of 3.2.5.1. Directive: a schedule prescribes when to act (Formulation genus). Reuse corrected (Gate-F): formerly also assigned to 3.4.2.10 (P11522) and 3.4.2.12 (P11468), but those concern a trade-event timetable, not message-delivery scheduling; they now use the dedicated ex:TradeMarketingCalendar." .

ex:TradeMarketingCalendar a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Trade Marketing Calendar" ;
    skos:definition "A Directive Information Content Entity that prescribes the timing of promotional, category-management, and trade-marketing events combined into a unified timetable." ;
    rdfs:comment "Minted (Gate-F) for 3.4.2.10 (P11522 output) and 3.4.2.12 (P11468 input). Distinct from ex:CommunicationCalendar, whose definition denotes marketing-MESSAGE-delivery scheduling, not a trade/promotion EVENT timetable; reusing that ICE here was a subject-matter mismatch (D5). Directive: a schedule prescribes when to act." .

ex:CustomerLoyaltyProgram a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Customer Loyalty Program Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the procedures, rewards, and mechanisms of a customer loyalty program." ;
    rdfs:comment "Output of 3.2.6, 3.2.6.1 (define loyalty program). Directive (Formulation). The program's content is the ICE; its enrolled members are independent continuants modeled elsewhere." .

ex:NewMediaAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "New Media Assessment" ;
    skos:definition "A Descriptive Information Content Entity that registers and describes emerging media channels identified as candidates for marketing communication." ;
    rdfs:comment "Output of 3.2.5.5. Descriptive: it identifies and describes candidate media; the strategy that capitalizes on them is the separate Directive ex:MarketingCommunicationStrategy (3.2.5.6)." .

ex:ValuePropositionValidation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Value Proposition Validation Result" ;
    skos:definition "A Descriptive Information Content Entity that records the substantiated desirability and benefits of an offering's value proposition as corroborated against a target customer segment." ;
    rdfs:comment "Output of 3.2.1.3. Descriptive (not Directive): it reports a validation judgement gathered from customer feedback. Distinct from ex:OpportunityValidation (about market opportunities)." .

# -- 3.3 Develop and manage marketing plans --

ex:MarketingGoal a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Marketing Goal and Objective" ;
    skos:definition "A Directive Information Content Entity that prescribes qualitative and quantitative targets to be achieved by marketing for offerings by channel and segment." ;
    rdfs:comment "Output of 3.3.1. Directive (Formulation)." .

ex:MarketingBudget a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Marketing Budget" ;
    skos:definition "A Directive Information Content Entity that prescribes the planned allocation of resources to marketing activities." ;
    rdfs:comment "Output of 3.3.2, 3.3.2.3. Directive: a budget prescribes resource allocation (Formulation genus)." .

ex:SalesBudget a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sales Budget" ;
    skos:definition "A Directive Information Content Entity that prescribes the planned revenue, costs, and resource outlay for the sales function." ;
    rdfs:comment "Output of 3.4.3, 3.4.3.6. Directive (Formulation)." .

ex:CostAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Cost Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the calculated costs of marketing, producing, distributing, or selling offerings." ;
    rdfs:comment "Output of 3.3.2.2, 3.3.3.1 and the cost-calculation activities of 3.4.3 (3.4.3.3-.4). Descriptive (Analysis/Info-Processing genus)." .

ex:ROIForecast a owl:Class ; rdfs:subClassOf cco:ont00000626 , cco:ont00000853 ;
    rdfs:label "Return-on-Investment Forecast" ;
    skos:definition "A Predictive Information Content Entity that describes the expected return on a marketing or sales investment." ;
    rdfs:comment "Output of 3.3.2.4 (projected ROI). Predictive ICE: describes an uncertain future return (Forecasting genus)." .

ex:PricingPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Pricing Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes a pricing mechanism producing prices for all offerings across their lifecycle." ;
    rdfs:comment "Output/instrument of 3.3.3 (develop and manage pricing), 3.3.3.8. Directive (Formulation)." .

ex:PriceList a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Price List" ;
    skos:definition "A Directive Information Content Entity that prescribes the set prices for an organization's offerings." ;
    rdfs:comment "Output of 3.3.3.4 (execute pricing plan), 3.3.3.7, 3.3.3.9. Directive: a price prescribes what is to be charged (Formulation genus)." .

ex:PricingPerformanceEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Pricing Performance Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes the assessed efficiency and revenue impact of an organization's pricing." ;
    rdfs:comment "Output of 3.3.3.5. Descriptive (Appraisal genus)." .

ex:IncentiveScheme a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Incentive Scheme" ;
    skos:definition "A Directive Information Content Entity that prescribes financial inducements, such as discounts, offered to intermediaries or customers." ;
    rdfs:comment "Output of 3.3.3.2 (corporate incentives), 3.3.3.7 (promotional pricing), 3.4.2.5 (trade funding). Directive (Formulation)." .

ex:PromotionalPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Promotional Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the concept, objectives, scheme, and scheduling of a promotional program or campaign." ;
    rdfs:comment "Output of 3.3.4.1, 3.3.4.4. Directive (Formulation)." .

ex:MarketingMessage a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Marketing Message" ;
    skos:definition "A Directive Information Content Entity that prescribes a central promotional statement positioning an offering's value for a customer segment." ;
    rdfs:comment "Output of 3.3.4.2. Directive: this is the approved/prescribed message SPECIFICATION, crafted to persuade and to be disseminated (Formulation genus). The message content as actually communicated to a customer is descriptive/representational and, where a group needs it, is modeled separately as a Descriptive ICE." .

ex:PromotionalPerformanceEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Promotional Performance Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes the measured success and impact of promotional programs." ;
    rdfs:comment "Output of 3.3.4.6, 3.3.6.5. Descriptive (Appraisal genus)." .

ex:CustomerMetricAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Customer Metric Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes analyzed measures of customer value, revenue, attrition, retention, and behavior." ;
    rdfs:comment "Output of 3.3.5, 3.3.5.2, 3.3.5.3, 3.3.5.4, 3.3.6.2. Descriptive (Analysis); is about the Customer." .

ex:CustomerLifetimeValue a owl:Class ; rdfs:subClassOf cco:ont00000626 , cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Customer Lifetime Value Estimate" ;
    skos:definition "A Predictive Information Content Entity that describes the estimated total future contribution of a customer over their relationship with the organization." ;
    rdfs:comment "Output of 3.3.5.1 (determine customer lifetime value). Predictive ICE (Forecasting genus): an estimate of uncertain future value. is about the Customer." .

ex:BusinessRule a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Business Rule" ;
    skos:definition "A Directive Information Content Entity that prescribes a formula or condition governing personalized offers, recommendations, or targeted advertisements." ;
    rdfs:comment "Output of 3.3.6.4 (develop business rules). Directive (Formulation)." .

ex:CustomerInsight a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Customer Insight" ;
    skos:definition "A Descriptive Information Content Entity that describes understanding derived from customer feedback, social media, website activity, and the customer's field of operation and business needs." ;
    rdfs:comment "Output of 3.3.6 (analyze and respond to customer insight), 3.3.6.1, and 3.5.3.6. Descriptive (Analysis); is about the Customer." .

ex:PackagingStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Packaging Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes how products and services are bundled and wrapped into marketable offerings." ;
    rdfs:comment "Output of 3.3.7.1, 3.3.7.4. Directive (Formulation)." .

ex:GoToMarketStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Go-to-Market Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes how a company will execute a product release, promotion, and sale to customers." ;
    rdfs:comment "Output of 3.3.8. Directive (Formulation)." .

ex:ProductMarketingContent a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Offering ] ;
    rdfs:label "Product Marketing Content" ;
    skos:definition "A Descriptive Information Content Entity, consisting of text and optionally images, that describes a product promotionally and informatively to initiate or increase sales." ;
    rdfs:comment "Output of 3.3.9.1 (images), 3.3.9.2 (copy). Descriptive: it describes the product (is about the Offering). Persuasive intent does not make it directive -- it states facts/claims about the offering." .

ex:MarketingAlignmentAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Marketing Alignment Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of whether an organization's marketing plan corroborates its overall business strategy." ;
    rdfs:comment "Output of 3.3.2.1. Descriptive (not Directive) because it represents a confirmation rather than prescribing a course of action." .

# -- 3.4 Develop sales strategy --

ex:SalesForecast a owl:Class ; rdfs:subClassOf cco:ont00000626 , cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Offering ] ;
    rdfs:label "Sales Forecast" ;
    skos:definition "A Predictive Information Content Entity that describes the estimated future demand for an organization's portfolio of offerings." ;
    rdfs:comment "Output of 3.4.1, 3.4.1.3. Predictive ICE (Forecasting genus). is about the Offering(s) being forecast." .

ex:SalesTrendAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sales Trend Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes patterns and trends discerned in sales order data." ;
    rdfs:comment "Output of 3.4.1.2, 3.4.1.4. Descriptive (Analysis genus)." .

ex:AllianceStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Partner and Alliance Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes how an organization identifies, selects, manages, and develops partner and alliance relationships." ;
    rdfs:comment "Output of 3.4.2, 3.4.2.2, 3.4.2.7. Directive (Formulation)." .

ex:AllianceAgreement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Alliance Agreement" ;
    skos:definition "A Directive Information Content Entity that prescribes the ratified terms, responsibilities, and benefits binding an organization and its alliance partners." ;
    rdfs:comment "Output of 3.4.2.9 (establish partner and alliance agreements). Directive: an agreement prescribes mutual obligations. The ratification act is anchored at cco:ont00000228 (Planned Act)." .

ex:SalesGoal a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sales Goal and Target" ;
    skos:definition "A Directive Information Content Entity that prescribes quantitative and qualitative sales targets and the measures used to track them." ;
    rdfs:comment "Output of 3.4.4, and the goal-setting in 3.4.2.4, 3.4.2.8. Directive (Formulation)." .

ex:CustomerManagementMeasure a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Customer Management Measure" ;
    skos:definition "A Directive Information Content Entity that prescribes the measures used to track customer activity, satisfaction, and account management." ;
    rdfs:comment "Output of 3.4.5 (and revised in 3.3.5.5). Directive (Formulation): selecting a measure prescribes what to track." .

ex:SalesPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sales Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes strategic and tactical sales actions, objectives, and resource use for a customer or account." ;
    rdfs:comment "Output of 3.4.2.11 (11523) and 3.5.2.2 (key account plan). Directive (Formulation)." .

ex:CustomerTradeStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Customer Trade Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's category-management and trade strategy, objectives, and long-term targets for its customers." ;
    rdfs:comment "Output of 3.4.2.4 (11465). Directive (Formulation). Distinct from ex:AllianceStrategy (partners) and ex:SalesPlan (single account). PROPOSE-VOCAB candidate." .

ex:AllianceSelection a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Alliance Selection" ;
    skos:definition "A Directive Information Content Entity that prescribes the alliance partners chosen from a candidate set as those the organization will commit to." ;
    rdfs:comment "Output of 3.4.2.3 (10140). Directive (Selection genus): committing to chosen partners prescribes a course of action. Distinct from the descriptive ex:PartnerEvaluation (judges performance) and from ex:AllianceAgreement (ratified terms). PROPOSE-VOCAB candidate." .

ex:RevenueEstimate a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Revenue Estimate" ;
    skos:definition "A Descriptive Information Content Entity that describes the estimated revenue from the sale of an organization's products and services, computed as anticipated sales multiplied by selling price." ;
    rdfs:comment "Output of 3.4.3.2 (10143). Descriptive (Analysis genus): a computed quantity, not a prescription. Distinct from ex:SalesForecast (a Predictive demand estimate). PROPOSE-VOCAB candidate." .

ex:ProfitabilityAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Profitability Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the analyzed profitability of a proposal, product, or sales activity." ;
    rdfs:comment "Output of 3.4.3.5 (net profit) and 3.5.3.10. Descriptive (Analysis genus)." .

# -- 3.5 Develop and manage sales plans --

ex:SalesLead a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProspectiveCustomer ] ;
    rdfs:label "Sales Lead" ;
    skos:definition "A Descriptive Information Content Entity that describes a qualified prospective customer and their potential as a sales opportunity." ;
    rdfs:comment "Output of 3.5.1, 3.5.1.1, 3.5.1.2. Descriptive (the lead record represents a prospect); is about the ProspectiveCustomer. The prospect itself is an Agent/Organization modeled separately." .

ex:OpportunityWinPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Opportunity Win Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes how to close a lead and win a sales opportunity." ;
    rdfs:comment "Output of 3.5.1.5. Directive (Formulation)." .

ex:SalesProposal a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sales Proposal/Bid/Quote" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's proposed solution, pricing, and schedule in response to a customer requirement." ;
    rdfs:comment "Output of 3.5.3, 3.5.1.8.2, 3.5.3.14. Directive: a proposal/bid prescribes what the supplier will deliver and on what terms (Formulation genus)." .

ex:SalesAgreement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sales Agreement" ;
    skos:definition "A Directive Information Content Entity that prescribes the agreed terms, price, and conditions of a concluded sale." ;
    rdfs:comment "Output of 3.5.1.8.4 (close the sale). Directive: a contract/agreement prescribes mutual obligations." .

ex:SalesOrder a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sales Order" ;
    skos:definition "A Directive Information Content Entity that prescribes a customer's order of products or services to be fulfilled by the organization." ;
    rdfs:comment "Output of 3.5.4 (manage sales orders) and the sales-execution channels 3.5.6-8. Directive: an accepted order prescribes what must be delivered. Distinct from ex:SalesOrderData (the descriptive aggregate record used as forecasting input)." .

ex:FulfillmentPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Order Fulfillment Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the sequence of activities required to deliver a sales order to the customer." ;
    rdfs:comment "Output of 3.5.4.4 (determine fulfillment process). Directive (Formulation)." .

ex:CustomerMasterData a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Customer Master Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the maintained corpus of account, contact, address, and communication data for an organization's customers." ;
    rdfs:comment "Subject of 3.5.4.2 and 3.5.2.5 (manage/collect/de-duplicate customer data). Descriptive; is about the Customer." .

ex:PartnerMasterData a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:SalesPartner ] ;
    rdfs:label "Partner/Alliance Master Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the maintained corpus of data on an organization's sales partners and alliances." ;
    rdfs:comment "Subject of 3.5.5.4 (manage partner/alliance master data). Descriptive; is about the SalesPartner." .

ex:PartnerEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:SalesPartner ] ;
    rdfs:label "Partner/Alliance Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes the assessed performance of an organization's sales partners and alliances." ;
    rdfs:comment "Output of 3.2.3.6 and 3.5.5.3 (evaluate partner/alliance results). Descriptive (Appraisal); is about the SalesPartner." .

ex:SalesTrainingMaterial a owl:Class ; rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Offering ] ;
    rdfs:label "Sales Training Material" ;
    skos:definition "A Descriptive Information Content Entity that describes an organization's products and services for the instruction of sales partners and personnel." ;
    rdfs:comment "Distributed in 3.5.5.1, 3.5.5.1.1. Descriptive; is about the Offering." .

####################################################################
# 2c. REALIZABLES (ROLES + CAPABILITIES)
#     D4: borne by Agents/Organizations only -- never by an ICE.
####################################################################

# ---- Roles (obo:BFO_0000023) ----

ex:CustomerRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Customer Role" ;
    skos:definition "A Role that is borne by an Agent or Organization in virtue of purchasing or being marketed an organization's products or services." ;
    rdfs:comment "Borne by an independent continuant (the purchasing Agent/Organization)." .

ex:ProspectiveCustomerRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Prospective Customer Role" ;
    skos:definition "A Role that is borne by an Agent or Organization in virtue of being a potential but not-yet-converted target of an organization's sales and marketing." ;
    rdfs:comment "Borne by the prospect (lead). Distinct from CustomerRole (already purchasing)." .

ex:MarketingProfessionalRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Marketing Professional Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with marketing an organization's offerings." ;
    rdfs:comment "Covers the 'marketing head/function' enlisted across 3.2 and 3.3." .

ex:SalesProfessionalRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Sales Professional Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with selling an organization's offerings." ;
    rdfs:comment "Covers sales personnel across 3.4 and 3.5." .

ex:SalesPartnerRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Sales Partner/Alliance Role" ;
    skos:definition "A Role that is borne by an Organization or Agent in virtue of partnering with a focal organization to market, sell, or distribute its offerings." ;
    rdfs:comment "Covers channel partners, alliance partners, distributors, resellers (3.2.3, 3.4.2, 3.5.5). Borne by the partner Organization/Agent." .

ex:ChannelPartnerRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Channel Partner Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of serving as a distributor, wholesaler, or retailer in an organization's marketing or distribution channel." ;
    rdfs:comment "Narrower than SalesPartnerRole, specific to distribution intermediaries (3.2.3)." .

ex:CompetitorRole a owl:Class ; rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Competitor Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of competing with a focal organization in a market." ;
    rdfs:comment "Reused intent from the 1.1.1 reference module; re-stated for section 3.0 (3.1.1.4, 3.5.3.4)." .

# ---- Capabilities (Organization Capability cco:ont00000568) ----

ex:MarketIntelligenceCapability a owl:Class ; rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Market Intelligence Capability" ;
    skos:definition "An Organization Capability that is realized in Acts of gathering and analyzing market and customer intelligence." ;
    rdfs:comment "Standing capability behind 3.1 (R6)." .

ex:MarketingManagementCapability a owl:Class ; rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Marketing Management Capability" ;
    skos:definition "An Organization Capability that is realized in Acts of formulating and managing marketing strategy, plans, channels, and promotions." ;
    rdfs:comment "Standing capability behind the 'Manage...' nodes of 3.2 and 3.3 (R6). Realized-in axioms for groups 3.3 (PCF 20010 / 10154 / 16629) are attached additively below." .

ex:PricingCapability a owl:Class ; rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Pricing Capability" ;
    skos:definition "An Organization Capability that is realized in Acts of formulating, executing, and refining pricing." ;
    rdfs:comment "Standing capability behind 3.2.2 and 3.3.3 (R6, the 'Develop and manage pricing' standing function PCF 20593). Realized-in axioms attached additively below." .

ex:SalesManagementCapability a owl:Class ; rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:ManageCustomerRelationships ] ;
    rdfs:label "Sales Management Capability" ;
    skos:definition "An Organization Capability that is realized in Acts of managing leads, accounts, proposals, orders, and sales execution, and the ongoing relationships with customers." ;
    rdfs:comment "Standing capability behind the 'Manage...' nodes of 3.5 (R6). R6 target for PCF 11174 'Manage customer relationships' (a standing function with no natural end, NOT minted as a process); realized in the bounded customer-relationship-management acts (ex:ManageCustomerRelationships)." .

ex:ChannelManagementCapability a owl:Class ; rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Channel Management Capability" ;
    skos:definition "An Organization Capability that is realized in Acts of defining, analyzing, and managing marketing and distribution channels." ;
    rdfs:comment "Standing capability behind 3.2.3, 3.2.4 ('Define and manage channel strategy', 'Analyze and manage channel performance') (R6). Realized-in axioms for PCF 20006 are attached additively below." .

ex:PartnerManagementCapability a owl:Class ; rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Partner and Alliance Management Capability" ;
    skos:definition "An Organization Capability that is realized in Acts of developing and managing sales partner and alliance relationships." ;
    rdfs:comment "Standing capability behind 3.4.2 and 3.5.5 (R6)." .

####################################################################
# 2d. AGENTS / ORGANIZATIONS / OTHER INDEPENDENT CONTINUANTS
#     Agent cco:ont00001017 . Organization cco:ont00001180 .
#     Subjects of 'is about' ICEs (Customer, Offering, Channel, etc.).
####################################################################

ex:Customer a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent (a customer may be a person or organization)
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:CustomerRole ] ;
    rdfs:label "Customer" ;
    skos:definition "An Agent that bears a customer role with respect to an organization's offerings." ;
    rdfs:comment "Anchored at cco:Agent because a customer may be an individual person; an organizational customer is also an Agent via the role. Bears CustomerRole." .

ex:ProspectiveCustomer a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ProspectiveCustomerRole ] ;
    rdfs:label "Prospective Customer" ;
    skos:definition "An Agent that bears a prospective-customer role as a potential target of sales and marketing." ;
    rdfs:comment "Subject of sales leads (3.5.1). Bears ProspectiveCustomerRole." .

ex:CompetingOrganization a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:CompetitorRole ] ;
    rdfs:label "Competing Organization" ;
    skos:definition "An Organization that bears a competitor role in relation to some focal organization or market." ;
    rdfs:comment "Subject of CompetitiveAnalysis. Modeled as Organization per APQC 'competing organizations'." .

ex:SalesPartner a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:SalesPartnerRole ] ;
    rdfs:label "Sales Partner" ;
    skos:definition "An Organization that bears a sales-partner role, collaborating with a focal organization to market, sell, or distribute its offerings." ;
    rdfs:comment "Subject of PartnerMasterData / PartnerEvaluation (3.4.2, 3.5.5). Modeled as Organization (economic agent)." .

ex:MarketingChannel a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ChannelPartnerRole ] ;
    rdfs:label "Marketing Channel" ;
    skos:definition "An Organization, such as a distributor, wholesaler, or retailer, through which an organization markets and distributes its offerings to customers." ;
    rdfs:comment "Subject of ChannelEvaluation / ChannelPerformanceAnalysis (is about). Modeled as the partner Organization that constitutes the channel; this class denotes ONLY an organizational channel partner -- NOT a medium, route, platform, or distribution arrangement (print, radio, digital, etc.), which are left to group modules if needed." .

ex:Offering a owl:Class ;
    rdfs:subClassOf obo:BFO_0000040 ;   # material entity
    rdfs:label "Offering (product)" ;
    skos:definition "A Material Entity that an organization produces or provides and markets and sells to customers." ;
    rdfs:comment "Subject of marketing content, sales forecasts, training material (is about). Anchored at bfo:material entity (a product is a material object); operations material I/O is legal for this section. A service offering, where a group needs it specifically, should be modeled separately -- this shared class covers the predominant product sense and the generic 'offering' subject of descriptive ICEs." .

ex:MarketingPersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:MarketingProfessionalRole ] ;
    rdfs:label "Marketing Personnel" ;
    skos:definition "An Agent that bears a marketing-professional role." ;
    rdfs:comment "The 'marketing head/function' participant enlisted across 3.2, 3.3." .

ex:SalesPersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:SalesProfessionalRole ] ;
    rdfs:label "Sales Personnel" ;
    skos:definition "An Agent that bears a sales-professional role." ;
    rdfs:comment "The sales-function participant across 3.4, 3.5." .

# ---- Realization filler for the standing CRM capability (PCF 11174) ----
ex:ManageCustomerRelationships a owl:Class ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Act of Managing a Customer Relationship" ;
    skos:definition "An Act of Selling in which an organization coordinates an interaction with a customer across a touchpoint to maintain an ongoing relationship." ;
    rdfs:comment "Bounded relationization act; the recurring instances of this type are what ex:SalesManagementCapability (PCF 11174, R6) is realized in. Not a PCF-numbered process node." .

####################################################################
# 3. PROCESS CLASSES  --  GROUP 3.1  Understand markets, customers,
#    and capabilities (PCF 10101). Partonomy via cco:ont00001777.
####################################################################

ex:P10101 a owl:Class ;
    ex:pcfID "10101" ; ex:hierarchyID "3.1" ;
    ex:apqcSourceText "Making sense of the market and customers to identify the right opportunities to be capitalized, given the organization's competencies. Discern trends and shift in the market and customers. Identify the right market opportunities that fit closely with the organization's capabilities and strategy by gathering intelligence on various attributes of different market/customer segments." ;
    rdfs:label "Understand markets, customers, and capabilities" ;
    skos:definition "An Act of Analysis that examines market and customer segments and the organization's capabilities and produces an understanding of where the right market opportunities lie." ;
    rdfs:comment "Models APQC process group 3.1 as a bounded occurrent. Its APQC children are process parts (cco:ont00001777), not subclasses." ;
    skos:example "An organization's annual market-and-customer intelligence cycle culminating in a shortlist of validated opportunities." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10106 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10107 ] .

ex:P10106 a owl:Class ;
    ex:pcfID "10106" ; ex:hierarchyID "3.1.1" ;
    ex:apqcSourceText "Gathering intelligence on the market and customers. Closely examine the inherent attributes and collective behavior of the various market and customer segments. Track trends in the market. Determine what drives the customers to make purchasing decisions in order to identify opportunities in the market." ;
    rdfs:label "Perform customer and market intelligence analysis" ;
    skos:definition "An Act of Analysis that has as input market data and customer data and has as output a market intelligence report covering market and customer segments, their behavior, and market trends." ;
    skos:example "An intelligence team aggregates segment, behavioral, and trend data into a market intelligence report." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketIntelligenceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10108 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10109 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10110 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10111 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10112 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10113 ] .

ex:P10108 a owl:Class ;
    ex:pcfID "10108" ; ex:hierarchyID "3.1.1.1" ;
    ex:apqcSourceText "Carrying out research studies to understand the behavior of customers and the realities of the market. Undertake research to understand the market conditions as well as the characteristics, drives, and desires of prospective customers. Gather highly contextualized intelligence through primary and secondary research methods, with the objective of gaining insights over how to best seize a market opportunity. Consider assistance from professional research services." ;
    rdfs:label "Conduct customer and market research" ;
    skos:definition "An Act of Analysis that has as input market data and customer data and has as output customer research findings about customer behavior and market conditions." ;
    skos:example "A research team runs primary and secondary studies and reports findings on prospective-customer drives." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerResearchFindings ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10114 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21424 ] .

ex:P10114 a owl:Class ;
    ex:pcfID "10114" ; ex:hierarchyID "3.1.1.1.1" ;
    ex:apqcSourceText "Identifying the factors that drive the targeted market segment. Model customer purchasing patterns, and forecast their future purchasing behavior." ;
    rdfs:label "Understand consumer needs and historical behaviors" ;
    skos:definition "An Act of Analysis that has as input customer data and has as output a customer behavior model that represents historical purchasing patterns and the factors driving a targeted segment." ;
    rdfs:comment "Genus is Analysis: the definitional output is a descriptive behavior model of past/present patterns. The text's forward-looking 'forecast' step is realized by its sibling process ex:P21424 (Predict customer purchasing behavior) and is therefore not asserted here as a predictive output." ;
    skos:example "An analyst models a segment's historical buying patterns and the drivers behind them." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerBehaviorModel ] .

ex:P21424 a owl:Class ;
    ex:pcfID "21424" ; ex:hierarchyID "3.1.1.1.2" ;
    ex:apqcSourceText "Using customer segmentation tools to examine past customer behavior to predict future purchasing patterns." ;
    rdfs:label "Predict customer purchasing behavior" ;
    skos:definition "An Act of Forecasting that has as input customer data and has as output a customer purchasing forecast that describes expected future purchasing patterns of a customer segment." ;
    rdfs:comment "Anchored to ex:ActOfForecasting (PROPOSE-EXT, under cco:ont00000371 Act of Prediction) because the output is a Predictive ICE about uncertain future behavior, satisfying the GOLDEN PRINCIPLE for predictive output." ;
    skos:example "A team applies segmentation tools to historical data and forecasts next-quarter purchasing." ;
    rdfs:subClassOf ex:ActOfForecasting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PurchasingForecast ] .

ex:P10109 a owl:Class ;
    ex:pcfID "10109" ; ex:hierarchyID "3.1.1.2" ;
    ex:apqcSourceText "Identifying a section of the customer population to target for marketing products/services. Create segments within the customer population for targeted marketing campaigns, which increase the efficacy of marketing outlay. Determine the right customer segments, craft effective marketing messages, and efficiently communicate them. Determine the optimal pricing mix. Consider assistance from professional services for market segmentation studies, with coordination and oversight from the marketing/sales functions." ;
    rdfs:label "Identify market segments" ;
    skos:definition "An Act of Analysis that has as input customer data and market data and has as output a market segmentation that partitions the customer population into targetable segments." ;
    rdfs:comment "Genus is Analysis (information processing yielding a descriptive partition). The cross-referenced message-crafting and pricing-mix steps belong to other groups and are not asserted as outputs here." ;
    skos:example "A marketing team segments the customer base for targeted campaigns." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketSegmentation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10115 ] .

ex:P10115 a owl:Class ;
    ex:pcfID "10115" ; ex:hierarchyID "3.1.1.2.1" ;
    ex:apqcSourceText "Determining the increase or decrease of the company's sales volume in the targeted markets. Conduct an analysis to determine the factors and underlying causes that affect the changes in the demand for products or services offered. Consider changes in offerings or in the business strategy to regain or increase the market share." ;
    rdfs:label "Determine market share gain/loss" ;
    skos:definition "An Act of Analysis that has as input market data and has as output a market share analysis that represents the change in the organization's sales volume in targeted markets and its underlying causes." ;
    skos:example "An analyst explains a quarter's market-share decline and its drivers." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketShareAnalysis ] .

ex:P10110 a owl:Class ;
    ex:pcfID "10110" ; ex:hierarchyID "3.1.1.3" ;
    ex:apqcSourceText "Examining large-scale shifts and trends, with relevance to the organization's products/services. Vet the industrial and larger market landscape to identify broad-based movements that could have a direct or tangential impact on the uptake of the organization's products/services. Examine, among other things, the market capitalization of similar products, the profitability of organizations offering competing products/services, the stock price of key vendors/suppliers in the organizational value-chain, the rate and scale of innovation activity in the organization's product/service category, the price and availability of raw materials, and the shelf-life of similar products/services. Conduct primary and secondary research, and consider enlisting professional services." ;
    rdfs:label "Analyze market and industry trends" ;
    skos:definition "An Act of Analysis that has as input industry trend data and market data and has as output an industry and market trend analysis of large-scale shifts relevant to the organization's offerings." ;
    skos:example "A team reports the industry shifts likely to affect product uptake over the coming years." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:IndustryTrendData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IndustryTrendAnalysis ] .

ex:P10111 a owl:Class ;
    ex:pcfID "10111" ; ex:hierarchyID "3.1.1.4" ;
    ex:apqcSourceText "Examining the strengths and weaknesses of competing organizations. Assess competing organizations for offerings, product strategy, marketing and delivery channels, etc. Analyze the usability experience, durability, USP, and other key attributes of competing and substitute products. Gather competitive intelligence, and consider enlisting professional services." ;
    rdfs:label "Analyze competing organizations, competitive/substitute products/services" ;
    skos:definition "An Act of Analysis that has as input competitor data and has as output a competitive analysis about competing organizations and their products and substitutes." ;
    skos:example "A competitive-intelligence team profiles rivals' strengths, weaknesses, and substitute products." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CompetitorData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetitiveAnalysis ] .

ex:P10112 a owl:Class ;
    ex:pcfID "10112" ; ex:hierarchyID "3.1.1.5" ;
    ex:apqcSourceText "Examining the brands owned and products offered in the market. Determine the relative position of the existing products/brands in the marketplace." ;
    rdfs:label "Evaluate existing products/services" ;
    skos:definition "An Act of Appraisal that has as input market data and has as output a product portfolio assessment of the relative market position of the organization's existing products and brands." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal) because the act evaluates and judges the relative position of existing products; output is a Descriptive ICE, satisfying the GOLDEN PRINCIPLE." ;
    skos:example "A brand team judges where each owned product stands against the market." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductPortfolioAssessment ] .

ex:P10113 a owl:Class ;
    ex:pcfID "10113" ; ex:hierarchyID "3.1.1.6" ;
    ex:apqcSourceText "Understanding the culture and environment in which you're operating. Analyze how internal decision-making, thought processes, financial circumstances, and more affect the ability to bring new products to market. Survey or analyze the market into which the products would be introduced." ;
    rdfs:label "Assess internal and external business environment" ;
    skos:definition "An Act of Appraisal that has as input market data and has as output a business environment assessment of the internal and external conditions affecting the organization's ability to bring products to market." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the act judges the operating environment (internal culture, finances, external market); output is a Descriptive ICE." ;
    skos:example "A planning team appraises the internal and external readiness to launch a new product line." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessEnvironmentAssessment ] .

ex:P10107 a owl:Class ;
    ex:pcfID "10107" ; ex:hierarchyID "3.1.2" ;
    ex:apqcSourceText "Appraising market opportunities by quantifying and subjecting them to prioritization, as well as validation tests. Closely examine the market opportunities that have been identified by Perform customer and market intelligence analysis [10106]. Triangulate those opportunities to capitalize by finding a fit between identified opportunities and the composite of organizational capabilities and business strategy." ;
    rdfs:label "Evaluate and prioritize market opportunities" ;
    skos:definition "An Act of Appraisal that has as input market opportunity statements and has as output an opportunity validation result, by quantifying, prioritizing, and validating identified market opportunities against organizational capabilities and strategy." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the overall act evaluates opportunities. Its child ex:P10117 (Determine target segments) and ex:P10118 (Prioritize opportunities) are Selection acts producing Directive ICEs, decomposed via has process part." ;
    skos:example "A strategy team quantifies, ranks, and validates the opportunities surfaced by the intelligence cycle." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketOpportunity ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OpportunityValidation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10116 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10117 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10118 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10119 ] .

ex:P10116 a owl:Class ;
    ex:pcfID "10116" ; ex:hierarchyID "3.1.2.1" ;
    ex:apqcSourceText "Attaching quantifiable indicators to opportunities that have been identified in the market. Compute estimated figures of the approximate value that can be captured with the provision of existing products/services (i.e., the extent of financial benefits that can be reaped in the market)." ;
    rdfs:label "Quantify market opportunities" ;
    skos:definition "An Act of Analysis that has as input market opportunity statements and has as output an opportunity quantification that estimates the value capturable from each identified opportunity." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (reused from apqc-ext.ttl; an Act of Information Processing under cco:ont00000366): computing estimated value figures and attaching quantifiable indicators is a measurement/calculation/estimation act -- an information-processing examination that yields a Descriptive ICE -- not a value-judgement. RE-ANCHORED (Gate-F): rejected cco:ont00000636 (Act of Appraisal), whose proper use (siblings P10119 validate, P10113) is judging worth/feasibility; quantification computes magnitudes. Output ex:OpportunityQuantification is Descriptive, so the GOLDEN PRINCIPLE holds under the Analysis genus. The earlier 'species of Act of Measuring' parenthetical was an unverified parent-chain assertion and is removed." ;
    skos:example "An analyst computes the estimated revenue capturable from each opportunity." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketOpportunity ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OpportunityQuantification ] .

ex:P10117 a owl:Class ;
    ex:pcfID "10117" ; ex:hierarchyID "3.1.2.2" ;
    ex:apqcSourceText "Identifying the targeted segment of customers. Deduce those particular customer segments that are to be targeted from among the market segments." ;
    rdfs:label "Determine target segments" ;
    skos:definition "An Act of Selection that has as input a market segmentation and has as output a target segment definition that prescribes which customer segments are to be targeted." ;
    rdfs:comment "Anchored to ex:ActOfSelection (reused from apqc-ext.ttl) because the act chooses target segments from a candidate set of market segments and yields a Directive ICE (a committing decision), satisfying the GOLDEN PRINCIPLE for directive output." ;
    skos:example "Marketing selects three segments to target from the segmentation." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketSegmentation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TargetSegmentDefinition ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18941 ] .

ex:P18941 a owl:Class ;
    ex:pcfID "18941" ; ex:hierarchyID "3.1.2.2.1" ;
    ex:apqcSourceText "Determining which groups of potential customers do not yet, or already do have access to the product or a service that the company produces or markets. Use those findings to create specialized product offerings and differentiated marketing campaigns." ;
    rdfs:label "Identify under-served and saturated market segments" ;
    skos:definition "An Act of Identification that has as input a market segmentation and has as output an under-served and saturated segment finding that registers which segments lack or already have access to the organization's offerings." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (reused from apqc-ext.ttl, discernment sense): the act discerns and registers under-served vs saturated segments; output is a Descriptive ICE." ;
    skos:example "A team flags two under-served segments and one saturated segment for differentiated campaigns." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketSegmentation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:UnderservedSegmentFinding ] .

ex:P10118 a owl:Class ;
    ex:pcfID "10118" ; ex:hierarchyID "3.1.2.3" ;
    ex:apqcSourceText "Creating an index of market opportunities, and arrange them in order of preference. Prioritize based on the opportunities' adherence to the overall business strategy. Correlate with the competencies and capacities that the organization, as a whole, processes." ;
    rdfs:label "Prioritize opportunities consistent with capabilities and overall business strategy" ;
    skos:definition "An Act of Selection that has as input market opportunity statements and has as output an opportunity prioritization that prescribes the rank order of opportunities by fit to strategy and capabilities." ;
    rdfs:comment "Anchored to ex:ActOfSelection (reused): ranking opportunities by preference is a committing choice over a candidate set; output is a Directive ICE, satisfying the GOLDEN PRINCIPLE." ;
    skos:example "A committee ranks the validated opportunities by strategic fit." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketOpportunity ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OpportunityPrioritization ] .

ex:P10119 a owl:Class ;
    ex:pcfID "10119" ; ex:hierarchyID "3.1.2.4" ;
    ex:apqcSourceText "Confirming the practicability and reasonableness of the market opportunities that have been identified. Give substance to the real-time feasibility of the market opportunities." ;
    rdfs:label "Validate opportunities" ;
    skos:definition "An Act of Appraisal that has as input market opportunity statements and has as output an opportunity validation result confirming the practicability and feasibility of the identified opportunities." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the act judges feasibility/reasonableness; output is a Descriptive ICE." ;
    skos:example "A team confirms which opportunities are realistically feasible before launch." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketOpportunity ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OpportunityValidation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10120 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10121 ] .

ex:P10120 a owl:Class ;
    ex:pcfID "10120" ; ex:hierarchyID "3.1.2.4.1" ;
    ex:apqcSourceText "Validating identified market opportunities by testing company's offerings on limited-size samples of the consumer population that are hypothesized to be representative of the target market at large and to have similar purchasing behavior. The feedback gained through consumer testing can be used to modify or reject product offerings before their full scale launch, saving the company valuable resources, should the initial offering not be successful." ;
    rdfs:label "Test with customers/consumers" ;
    skos:definition "An Act of Appraisal that tests an organization's offerings on representative consumer samples and has as output customer feedback and an opportunity validation result." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the act judges an opportunity by sample testing; outputs are Descriptive ICEs. I/O DIRECTIONALITY CORRECTED (Gate-F): the source says feedback is gained THROUGH the test and 'can be used to modify or reject product offerings', so customer feedback is PRODUCED by the test (has output / present at the end), not consumed by it. Per CCO has-input/has-output semantics it was wrongly modeled as a has-input filler; it is now a has-output ICE alongside the opportunity validation result. (The definitional start-of-process input is the offering/sample under test, a material entity not asserted here under the Phase-3 necessity rule.)" ;
    skos:example "A pilot test on a representative sample validates or rejects an offering before launch." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OpportunityValidation ] .

ex:P10121 a owl:Class ;
    ex:pcfID "10121" ; ex:hierarchyID "3.1.2.4.2" ;
    ex:apqcSourceText "Verifying that the company has sufficient infrastructure and resources to deliver their offerings in a timely and cost-effective manner, and that it is able to scale up from the small-scale market samples, used for consumer testing, to the entire identified market segment." ;
    rdfs:label "Confirm internal capabilities" ;
    skos:definition "An Act of Appraisal that has as output a capability confirmation that verifies the organization has sufficient infrastructure and resources to deliver and scale its offerings to the identified market segment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the act judges internal sufficiency and scalability; output is a Descriptive ICE." ;
    skos:example "Operations confirms the firm can scale delivery from pilot to the full target segment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CapabilityConfirmation ] .

####################################################################
# 4. PROCESS CLASSES  --  GROUP 3.2  Develop marketing strategy
#    (PCF 10102). Partonomy via cco:ont00001777.
####################################################################

ex:P10102 a owl:Class ;
    ex:pcfID "10102" ; ex:hierarchyID "3.2" ;
    ex:apqcSourceText "Charting a strategic course for marketing products/services. This will include defining the value proposition, creating a mechanism for pricing, and determining the right mix of marketing channels. Create a specific positioning and branding for the organization's offerings. Enlist marketing head to lead, with inputs from the business development and sales functions." ;
    rdfs:label "Develop marketing strategy" ;
    skos:definition "An Act of Formulation that composes an organization's marketing strategy, comprising the definition of the customer value proposition, the pricing strategy, the channel strategy, the marketing communication strategy, and the customer loyalty program." ;
    rdfs:comment "Models APQC group 3.2 (PCF 10102) as a bounded strategy-development cycle whose output is a Directive marketing strategy; its APQC children are process parts (cco:ont00001777), not subclasses. OUTPUT CORRECTED (Gate-F): the asserted output was ex:MarketingCommunicationStrategy, which is actually the narrow communication sub-strategy authored by the child 3.2.5 (P16848); it is replaced with the minted ex:MarketingStrategy (the overall go-to-market deliverable) to agree with this class's genus-differentia definition. 3.2.4 is the standing ex:ChannelManagementCapability (R5/R6): a capability is a specifically dependent continuant, NOT an occurrent, so it cannot be a cco:has process part (occurrent range) of this act -- wiring it as one made P10102 unsatisfiable. It is instead modeled in its own block (realized in its bounded child acts) and is intentionally not asserted as a part of the bounded 3.2 strategy act." ;
    skos:example "A marketing head leads a planning cycle that produces the firm's go-to-market marketing strategy for a product line." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingStrategy ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:MarketingPersonnel ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11168 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10123 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20000 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16848 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18924 ] .

ex:P11168 a owl:Class ;
    ex:pcfID "11168" ; ex:hierarchyID "3.2.1" ;
    ex:apqcSourceText "Refining the attributes of organizational offerings to define their value proposition for the customer. Clearly define the suite of offerings in terms of the value delivered, from the perspective of what the customer desires. Validate the benefits delivered to the customers against target market segments, using techniques such as minimum viable product. Position brands for the respective products/services, in line with their unique value proposition and aligned with customers needs." ;
    rdfs:label "Define offering and customer value proposition" ;
    skos:definition "An Act of Formulation that articulates the value an organization's offerings deliver from the customer's perspective and produces a customer value proposition." ;
    rdfs:comment "Output is the Directive ex:ValueProposition; agrees with the Formulation genus (GOLDEN PRINCIPLE)." ;
    skos:example "A product-marketing team defines and validates the value proposition for a new offering across target segments." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ValueProposition ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11169 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11170 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11171 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11172 ] .

ex:P11169 a owl:Class ;
    ex:pcfID "11169" ; ex:hierarchyID "3.2.1.1" ;
    ex:apqcSourceText "Defining problem(s) that the organization's products/services solve for the customers, thereby determining how they are positioned in the market. Refine the product/service concepts from the perspective of customers. Succinctly outline the problem the organization's offerings solves for the customers, making a case for why the customer should buy a product or use a service. Define the offering's unique value." ;
    rdfs:label "Define offering and positioning" ;
    skos:definition "An Act of Formulation that defines the problem an organization's offerings solve for customers and produces a statement of the offering's unique value and market positioning." ;
    skos:example "A team frames the customer problem a product solves and drafts its positioning statement." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ValueProposition ] .

ex:P11170 a owl:Class ;
    ex:pcfID "11170" ; ex:hierarchyID "3.2.1.2" ;
    ex:apqcSourceText "Boosting the attractiveness of products/services to the targeted customers, and creating a unique brand projection around these features. Identify and enhance those product/service features that reinforce the attractiveness of these offerings, for these segment of customers. Underscore the perceived value delivered to the customers by clearly specifying the relevance and desirability of these products/services. Once it has been clarified how the organization's offerings meet the customer's expectations or deliver specific benefits, position the brands around these benefits." ;
    rdfs:label "Develop value proposition including brand positioning for target segments" ;
    skos:definition "An Act of Formulation that enhances the attractiveness of offerings to targeted customers and produces a value proposition together with brand positioning for those segments." ;
    skos:example "A brand team positions a product's brand around the benefits most desired by a target segment." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ValueProposition ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BrandPositioning ] .

ex:P11171 a owl:Class ;
    ex:pcfID "11171" ; ex:hierarchyID "3.2.1.3" ;
    ex:apqcSourceText "Validating the desirability of the perceived value delivered by the organization's offerings, to the targeted customer segment. Substantiate the value of the benefits accrued to the customers through the organization's offerings. Justify the value proposition in light of the targeted segments by gathering feedback (using teaser demonstrations, surveys, interviews, primary research studies, and customer case studies). Corroborate the benefits of the organization's offerings." ;
    rdfs:label "Validate value proposition with target segments" ;
    skos:definition "An Act of Appraisal that substantiates an offering's value proposition against a target segment by gathering customer feedback and produces a value-proposition validation result." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): validation evaluates the value proposition against evidence and yields a Descriptive judgement (ex:ValuePropositionValidation), agreeing with the GOLDEN PRINCIPLE. ex:CustomerFeedback is a definitional input (the text says the value is justified 'by gathering feedback')." ;
    skos:example "A team runs surveys and MVP demos to corroborate a product's value proposition with its target segment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ValuePropositionValidation ] .

ex:P11172 a owl:Class ;
    ex:pcfID "11172" ; ex:hierarchyID "3.2.1.4" ;
    ex:apqcSourceText "Creating branding collaterals and campaigns that carve a significant and differentiated presence for the organization's offerings. Create new collaterals, which include names, designs, and symbols, for their products/services. Ensure collaterals reflect the unique value proposition of the respective offerings through a consistent theme. Create advertising and promotion campaigns." ;
    rdfs:label "Develop new branding" ;
    skos:definition "An Act of Formulation that creates branding collaterals and campaigns establishing a differentiated presence for an organization's offerings." ;
    rdfs:comment "Output ex:BrandingCollateral is a Directive ICE (names, designs, symbols, and campaign specifications prescribing the brand's expression), agreeing with the Formulation genus." ;
    skos:example "A creative team produces a new brand name, logo, and launch campaign for a product line." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BrandingCollateral ] .

ex:P10123 a owl:Class ;
    ex:pcfID "10123" ; ex:hierarchyID "3.2.2" ;
    ex:apqcSourceText "Creating a pricing strategy and mechanism that aligns with the benefits of the products/services, as perceived by customers. Chart a strategic course and a methodology that can guide the pricing of products/services. Draw heavily from the customer value proposition, and balance the expectations of different divisions inside the organization, while delivering the maximum ROI." ;
    rdfs:label "Define pricing strategy" ;
    skos:definition "An Act of Formulation that charts a strategic course and methodology for pricing an organization's offerings and produces a pricing strategy." ;
    rdfs:comment "Output ex:PricingStrategy is Directive, agreeing with the Formulation genus. ex:ValueProposition is a typical (not definitional) input - the text says it draws 'heavily from' it - so it is noted here rather than asserted as a restriction (Phase-3)." ;
    skos:example "A pricing team charts a value-based pricing methodology aligned to the customer value proposition." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P13169 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10124 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19999 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10125 ] .

ex:P13169 a owl:Class ;
    ex:pcfID "13169" ; ex:hierarchyID "3.2.2.1" ;
    ex:apqcSourceText "Analyzing marketing objectives, consumer demand, product attributes, competitors' pricing, and economic trends to determine optimum prices for the set of products and services that the company offers or intends to offer by delivering maximum ROI." ;
    rdfs:label "Conduct pricing analysis" ;
    skos:definition "An Act of Analysis that examines marketing objectives, consumer demand, competitor pricing, and economic trends and produces a pricing analysis recommending optimum prices." ;
    rdfs:comment "Output ex:PricingAnalysis is Descriptive, agreeing with the Information-Processing genus. ex:CompetitorData and ex:MarketData are definitional inputs (the analysis is over competitors' pricing and economic trends)." ;
    skos:example "An analyst models demand and rival prices to recommend optimum price points for a product set." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CompetitorData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingAnalysis ] .

ex:P10124 a owl:Class ;
    ex:pcfID "10124" ; ex:hierarchyID "3.2.2.2" ;
    ex:apqcSourceText "Creating a framework that allows for a uniform methodology while determining the price of individual offerings. Devise a blueprint for establishing the pricing of specific products/services. Create guidelines that factor in the cost of production/servicing, price sensitivity, product lifecycle, and the price of competing/substitute products." ;
    rdfs:label "Establish guidelines for applying pricing and discounting of products/services" ;
    skos:definition "An Act of Formulation that devises a uniform framework for pricing and discounting individual offerings and produces pricing guidelines." ;
    rdfs:comment "Output ex:PricingGuideline is Directive (a prescriptive framework), agreeing with the Formulation genus." ;
    skos:example "A pricing committee issues guidelines that fix how production cost and competitor prices feed individual list prices." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingGuideline ] .

ex:P19999 a owl:Class ;
    ex:pcfID "19999" ; ex:hierarchyID "3.2.2.3" ;
    ex:apqcSourceText "Determining optimum prices for individual products or services on the basis of the cost of producing, distributing and marketing the offerings, pricing analysis and general pricing strategy." ;
    rdfs:label "Establish pricing targets" ;
    skos:definition "An Act of Formulation that determines optimum target prices for individual offerings and produces pricing targets." ;
    rdfs:comment "Output ex:PricingTarget is Directive, agreeing with the Formulation genus. ex:PricingAnalysis is a definitional input (the text bases targets 'on ... pricing analysis')." ;
    skos:example "A pricing manager sets the target price for each SKU from the pricing analysis and strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PricingAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingTarget ] .

ex:P10125 a owl:Class ;
    ex:pcfID "10125" ; ex:hierarchyID "3.2.2.4" ;
    ex:apqcSourceText "Confirming the strategy and specifications developed for pricing the organization's products/services. Approve pricing guidelines by vetting the soundness of the methodology and the guidelines' alignment with the value proposition." ;
    rdfs:label "Approve pricing strategies/policies and targets" ;
    skos:definition "A Planned Act that confirms the already-developed pricing strategy, guidelines, and targets and produces a pricing approval." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act), NOT ex:ActOfSelection: approval ratifies a single already-settled option (there is no candidate set to choose among), per the ActOfSelection scope note. Output ex:PricingApproval is Directive (a prescriptive ratification). ex:PricingGuideline is the definitional input being vetted." ;
    skos:example "A pricing director signs off on the pricing guidelines after checking their alignment with the value proposition." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PricingGuideline ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingApproval ] .

ex:P20000 a owl:Class ;
    ex:pcfID "20000" ; ex:hierarchyID "3.2.3" ;
    ex:apqcSourceText "Establishing all the activities needed to identify the appropriate channels to market to different customer segments as defined in Determine target segments [10117]. This involves finding channel partners, ensuring that the channels align with organizational strategy for each segment, and the final channel selection process." ;
    rdfs:label "Define and manage channel strategy" ;
    skos:definition "An Act of Formulation that identifies and selects the appropriate marketing channels for each customer segment and produces a channel strategy." ;
    rdfs:comment "R5: modeled as a process because its dominant act produces a bounded Directive ex:ChannelStrategy; the standing channel-performance-management function is separately modeled as ex:ChannelManagementCapability (3.2.4). Its APQC children are process parts." ;
    skos:example "A channel team finds partners, fits channels to segments, and finalizes the channel strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChannelStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20001 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20002 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10127 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10128 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20003 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10126 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20004 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20005 ] .

ex:P20001 a owl:Class ;
    ex:pcfID "20001" ; ex:hierarchyID "3.2.3.1" ;
    ex:apqcSourceText "Deciding which distributors, wholesalers and retailers the company will use to promote its offerings and to distribute its products and services to the target market. Narrowing down which intermediaries the company will use will affect retail prices of individual products, and should therefore be included in the pricing analysis." ;
    rdfs:label "Determine channels to be supported" ;
    skos:definition "An Act of Selection that chooses, from the available distributors, wholesalers, and retailers, the intermediaries the company will use and produces a channel selection." ;
    rdfs:comment "Anchored to ex:ActOfSelection: it chooses from a candidate set of intermediaries and yields a Directive decision (ex:ChannelSelection)." ;
    skos:example "A distribution lead narrows the wholesaler list down to the chosen set of supported channels." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChannelSelection ] .

ex:P20002 a owl:Class ;
    ex:pcfID "20002" ; ex:hierarchyID "3.2.3.2" ;
    ex:apqcSourceText "Identifying the role that each chosen marketing channels plays in the larger distribution network with respect to the organizational marketing strategy. Determine intermediary costs for shipping, handling, transporting, warehousing, insurance and marketing that incur and accumulate in the distribution channel." ;
    rdfs:label "Establish channel objectives" ;
    skos:definition "An Act of Formulation that specifies the role each chosen channel plays in the distribution network and produces channel requirements covering those roles and intermediary costs." ;
    rdfs:comment "Output reuses ex:ChannelRequirements (Directive: what each channel is required to do and bear in cost), agreeing with the Formulation genus. ex:CostData is a typical input (intermediary costs), noted rather than asserted (Phase-3)." ;
    skos:example "A channel manager assigns each channel its role and documents the intermediary cost structure." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChannelRequirements ] .

ex:P10127 a owl:Class ;
    ex:pcfID "10127" ; ex:hierarchyID "3.2.3.3" ;
    ex:apqcSourceText "Analyze the various channels for their relevance to the targeted segments. Identify the channel that can effectively market to the targeted customers in regard to the drives, desires, and characteristics of these populations, their uptake, extent of engagement, frequency of use, and effectiveness in communicating." ;
    rdfs:label "Determine channel role and fit with target segments" ;
    skos:definition "An Act of Analysis that examines marketing channels for their relevance to targeted segments and produces a channel evaluation of their fit." ;
    rdfs:comment "Output ex:ChannelEvaluation is Descriptive (is-about MarketingChannel), agreeing with the Information-Processing genus. ex:ChannelData is a definitional input." ;
    skos:example "An analyst rates which channels best reach a target segment given its engagement patterns." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ChannelData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChannelEvaluation ] .

ex:P10128 a owl:Class ;
    ex:pcfID "10128" ; ex:hierarchyID "3.2.3.4" ;
    ex:apqcSourceText "Choose the most pertinent marketing channel for the targeted segments (based on Determine channel fit with target segments [10127])." ;
    rdfs:label "Select channels for target segments" ;
    skos:definition "An Act of Selection that chooses the most pertinent marketing channel for each target segment and produces a channel selection." ;
    rdfs:comment "Anchored to ex:ActOfSelection (chooses from candidates, Directive output). ex:ChannelEvaluation is the definitional input (the text bases the choice on 10127)." ;
    skos:example "A channel team picks the single best channel per target segment from the fit analysis." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ChannelEvaluation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChannelSelection ] .

ex:P20003 a owl:Class ;
    ex:pcfID "20003" ; ex:hierarchyID "3.2.3.5" ;
    ex:apqcSourceText "Determining the maximum output rate required from a distribution channel to optimally market and deliver the products and services the company offers or would like to offer. Ideally, a channel should be able to adapt to a certain degree of variability in the demand for the offerings, and able scale up if needed." ;
    rdfs:label "Identify required channel capabilities" ;
    skos:definition "An Act of Formulation that determines the throughput and adaptability a distribution channel must provide and produces channel requirements." ;
    rdfs:comment "Output ex:ChannelRequirements is Directive (the required capacities a channel must meet), agreeing with the Formulation genus." ;
    skos:example "A planner specifies the peak throughput and scalability each channel must support." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChannelRequirements ] .

ex:P10126 a owl:Class ;
    ex:pcfID "10126" ; ex:hierarchyID "3.2.3.6" ;
    ex:apqcSourceText "Assessing the attributes of all marketing channels, and evaluating the key partners in those channels. Closely examine the various characteristics of all available marketing channels such as the cost of using them, durability of impact, applicability to the organization's products/services, turn-around time, involvement of middlemen, and conversion rate. Analyze key partners in the marketing channels including those who have been associated with the organization; evaluate their capabilities, the scale and scope of their operations, quality of support provided, etc." ;
    rdfs:label "Evaluate channel attributes and potential partners" ;
    skos:definition "An Act of Appraisal that assesses the attributes of marketing channels and the capabilities of their key partners and produces a channel evaluation and a partner evaluation." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it evaluates channels and partners against criteria and yields Descriptive judgements (ex:ChannelEvaluation, ex:PartnerEvaluation), agreeing with the GOLDEN PRINCIPLE. ex:ChannelData is a definitional input." ;
    skos:example "An analyst rates each channel's cost and conversion and assesses its partners' capabilities." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ChannelData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChannelEvaluation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PartnerEvaluation ] .

ex:P20004 a owl:Class ;
    ex:pcfID "20004" ; ex:hierarchyID "3.2.3.7" ;
    ex:apqcSourceText "Coordinating marketing and distribution efforts across different channels that integrate well with each other, are in conformance with company values, visual identity and branding, and offer uniform customer service experience that drives customer loyalty and repeat business." ;
    rdfs:label "Orchestrate seamless customer experience across supported channels" ;
    skos:definition "An Act of Formulation that coordinates marketing and distribution across channels into an integrated, uniform customer experience and produces an omni-channel strategy." ;
    rdfs:comment "R5: modeled as a process because its bounded deliverable is an omni-channel orchestration design (Directive ex:OmniChannelStrategy); its three Task children are process parts." ;
    skos:example "A team aligns branding and service across web, retail, and mobile into one omni-channel experience." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OmniChannelStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16590 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16591 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16592 ] .

ex:P16590 a owl:Class ;
    ex:pcfID "16590" ; ex:hierarchyID "3.2.3.7.1" ;
    ex:apqcSourceText "Devising a strategy to market company's products or services seamlessly through all or most channels that are in widespread use among the target market. This may mean cross-channel access to customer preferences and purchasing history to accept returned merchandise, provide refunds, resolve payment issues or to provide technical support." ;
    rdfs:label "Define omni-channel strategy" ;
    skos:definition "An Act of Formulation that devises a strategy to market seamlessly across the channels in widespread use among the target market and produces an omni-channel strategy." ;
    skos:example "A team designs a cross-channel strategy giving customers a unified returns and support experience." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OmniChannelStrategy ] .

ex:P16591 a owl:Class ;
    ex:pcfID "16591" ; ex:hierarchyID "3.2.3.7.2" ;
    ex:apqcSourceText "Identifying necessary preconditions that a channel should fulfill in order to be included as one of the adopted channels, such as required throughput capacities, service capabilities, competitive pricing, and alignment with organizational marketing strategies." ;
    rdfs:label "Define omni-channel requirements" ;
    skos:definition "An Act of Formulation that specifies the preconditions a channel must fulfill to be adopted and produces channel requirements." ;
    skos:example "A team documents the throughput and service preconditions a channel must meet to join the omni-channel mix." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChannelRequirements ] .

ex:P16592 a owl:Class ;
    ex:pcfID "16592" ; ex:hierarchyID "3.2.3.7.3" ;
    ex:apqcSourceText "Determining the detailed policies and procedures that each of the channels needs to follow in order to conform to the organizational marketing strategy and to provide seamless customer service experience." ;
    rdfs:label "Develop omni-channel policies and procedures" ;
    skos:definition "An Act of Formulation that determines the detailed policies and procedures each channel must follow and produces a set of policies and procedures." ;
    skos:example "A team writes the per-channel service policies that enforce a seamless customer experience." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PolicyAndProcedure ] .

ex:P20005 a owl:Class ;
    ex:pcfID "20005" ; ex:hierarchyID "3.2.3.8" ;
    ex:apqcSourceText "Determining the actions that need to be taken for successful multichannel marketing, the ordering, timing and dependencies of the steps, and the governance mechanism for reviewing and changing the protocol, if needed." ;
    rdfs:label "Develop and manage execution roadmap" ;
    skos:definition "An Act of Formulation that determines the actions, ordering, timing, and governance for multichannel marketing and produces an execution roadmap." ;
    rdfs:comment "R5: modeled as a process because the dominant act 'develop ... roadmap' produces a bounded Directive ex:ExecutionRoadmap; the 'manage'/governance aspect is content of that roadmap, not a separate standing function." ;
    skos:example "A program lead sequences the multichannel rollout steps and their review checkpoints into a roadmap." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExecutionRoadmap ] .

# 3.2.4 (PCF 20006) Analyze and manage channel performance -- CAPABILITY (R5/R6).
ex:ChannelManagementCapability
    ex:pcfID "20006" ;
    ex:hierarchyID "3.2.4" ;
    ex:apqcSourceText "Monitoring marketing and distribution efforts of all channels individually and as a network. Re-distribute or add resources to channels that perform better than expected. Purge or consolidate under-performing channels, and find more promising replacements." ;
    skos:altLabel "Analyze and manage channel performance" ;
    rdfs:comment "Models APQC 3.2.4 (PCF 20006) as a standing Organization Capability (R5/R6), NOT a process: 'monitor ... re-distribute ... purge or consolidate ... find replacements' is an ongoing management function with no natural end. The IRI ex:ChannelManagementCapability (subClassOf cco:ont00000568) is declared in the shared supporting vocab; the realized-in axioms below wire it to this group's bounded child acts." ;
    rdfs:subClassOf
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16573 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16574 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16575 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16500 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16501 ] .

ex:P16573 a owl:Class ;
    ex:pcfID "16573" ; ex:hierarchyID "3.2.4.1" ;
    ex:apqcSourceText "Determining measurable parameters to be used for comparing the performance of different marketing channels. Decide on benchmarks and values for optimum or desired performance." ;
    rdfs:label "Establish channel-specific measures and targets" ;
    skos:definition "An Act of Formulation that determines the measurable parameters, benchmarks, and target values for comparing channel performance and produces a performance measure specification." ;
    rdfs:comment "Output ex:PerformanceMeasure is Directive (a prescriptive specification of metrics and targets), agreeing with the Formulation genus." ;
    skos:example "A team defines conversion-rate and cost-per-sale targets per channel." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceMeasure ] .

ex:P16574 a owl:Class ;
    ex:pcfID "16574" ; ex:hierarchyID "3.2.4.2" ;
    ex:apqcSourceText "Tracking trends and changes in performance inside individual marketing channels and in channels collectively. Summarize and document results. Alert relevant parties about significant or unexpected deviations from expected behaviors." ;
    rdfs:label "Monitor and report performance" ;
    skos:definition "An Act of Monitoring that tracks trends and changes in channel performance over time and produces a performance report summarizing results and deviations." ;
    rdfs:comment "Output ex:PerformanceReport is Descriptive, agreeing with the Monitoring (Information-Processing) genus." ;
    skos:example "An analyst tracks weekly channel metrics and circulates a performance report flagging anomalies." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceReport ] .

ex:P16575 a owl:Class ;
    ex:pcfID "16575" ; ex:hierarchyID "3.2.4.3" ;
    ex:apqcSourceText "Analyzing the factors and circumstances that influence desired outcomes. Communicate core findings to relevant parties." ;
    rdfs:label "Monitor and report events influencing factors" ;
    skos:definition "An Act of Monitoring that tracks the factors and circumstances influencing desired channel outcomes and produces a performance report communicating the core findings." ;
    rdfs:comment "Output ex:PerformanceReport is Descriptive, agreeing with the Monitoring genus." ;
    skos:example "An analyst watches seasonal and competitive factors affecting channel results and reports the findings." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceReport ] .

ex:P16500 a owl:Class ;
    ex:pcfID "16500" ; ex:hierarchyID "3.2.4.4" ;
    ex:apqcSourceText "Conducting an analysis to review channel performance with respect to chosen metrics, benchmarks and performance targets [16573]. Compare to past performance and forecasts for the channel." ;
    rdfs:label "Analyze channel performance" ;
    skos:definition "An Act of Analysis that reviews channel performance against chosen metrics, benchmarks, and targets and produces a channel performance analysis." ;
    rdfs:comment "Output ex:ChannelPerformanceAnalysis is Descriptive (is-about MarketingChannel), agreeing with the Information-Processing genus. ex:PerformanceMeasure (the metrics/targets from 16573) and ex:PerformanceReport are definitional inputs." ;
    skos:example "An analyst compares this quarter's channel results to targets and prior periods." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceMeasure ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChannelPerformanceAnalysis ] .

ex:P16501 a owl:Class ;
    ex:pcfID "16501" ; ex:hierarchyID "3.2.4.5" ;
    ex:apqcSourceText "Devising a course of action to be taken to improve under-performing channels and to promote or expand channels that surpass expectations." ;
    rdfs:label "Develop plan for channel improvements" ;
    skos:definition "An Act of Formulation that devises a course of action to improve under-performing channels and expand over-performing ones and produces an improvement plan." ;
    rdfs:comment "Output ex:ImprovementPlan is Directive, agreeing with the Formulation genus. ex:ChannelPerformanceAnalysis is a definitional input (the plan acts on the performance review)." ;
    skos:example "A manager drafts a plan to fix two lagging channels and double down on a top performer." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ChannelPerformanceAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementPlan ] .

ex:P16848 a owl:Class ;
    ex:pcfID "16848" ; ex:hierarchyID "3.2.5" ;
    ex:apqcSourceText "Establishing marketing communications that deliver promotional messages, in a coordinated way, through multiple marketing channels, such as print, radio, television, direct mail, online or mobile advertising, email, social media or personal selling." ;
    rdfs:label "Develop marketing communication strategy" ;
    skos:definition "An Act of Formulation that establishes coordinated marketing communications across multiple channels and produces a marketing communication strategy." ;
    rdfs:comment "Output ex:MarketingCommunicationStrategy is Directive, agreeing with the Formulation genus. Its APQC children are process parts." ;
    skos:example "A communications team sets a coordinated multichannel promotional strategy for a campaign season." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingCommunicationStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16849 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16850 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16851 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16852 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16853 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16854 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16855 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18627 ] .

ex:P16849 a owl:Class ;
    ex:pcfID "16849" ; ex:hierarchyID "3.2.5.1" ;
    ex:apqcSourceText "Timing and scheduling the delivery of marketing messages to maximize their impact on customer purchasing behavior. Integrate individual messages to larger marketing campaigns and to seasonal purchasing patterns." ;
    rdfs:label "Develop customer communication calendar" ;
    skos:definition "An Act of Formulation that times and schedules the delivery of marketing messages and produces a communication calendar." ;
    skos:example "A planner schedules email and social messages around seasonal purchasing peaks." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CommunicationCalendar ] .

ex:P16850 a owl:Class ;
    ex:pcfID "16850" ; ex:hierarchyID "3.2.5.2" ;
    ex:apqcSourceText "Deciding how to promote and maintain a favorable public image of the company in the eyes of its employees, customers, investors, suppliers, politicians or the general public. This may involve various means but is frequently conducted through publicity, education, corporate social responsibility, charitable causes or civic engagements." ;
    rdfs:label "Define public relations (PR) strategy" ;
    skos:definition "An Act of Formulation that decides how to promote and maintain a favorable public image of the company and produces a marketing communication strategy for public relations." ;
    skos:example "A PR lead sets a strategy of publicity and CSR initiatives to strengthen the company's public image." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingCommunicationStrategy ] .

ex:P16851 a owl:Class ;
    ex:pcfID "16851" ; ex:hierarchyID "3.2.5.3" ;
    ex:apqcSourceText "Devising a master plan how to select potential customers or qualified clients for customized offers, and contact them on one-to-one basis through chat, phone, email or regular mail. The strategy would need to take into account that personalizing offers and contacting customers individually is an effective but resource-intensive marketing technique, and that ill-targeted offers risk at angering and alienating the contactees." ;
    rdfs:label "Define direct marketing strategy" ;
    skos:definition "An Act of Formulation that devises a master plan for selecting and contacting potential customers with customized one-to-one offers and produces a marketing communication strategy for direct marketing." ;
    skos:example "A team plans a personalized email-and-phone outreach program to qualified prospects." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingCommunicationStrategy ] .

ex:P16852 a owl:Class ;
    ex:pcfID "16852" ; ex:hierarchyID "3.2.5.4" ;
    ex:apqcSourceText "Developing a program to promote the objectives, values, products and services of the company to its employees by treating them as potential customers, in order to extend company client base, increase employee engagement or to foster brand advocacy." ;
    rdfs:label "Define internal marketing communication strategy" ;
    skos:definition "An Act of Formulation that develops a program promoting the company's objectives, values, and offerings to its own employees and produces a marketing communication strategy for internal marketing." ;
    skos:example "A team builds an internal campaign to turn employees into brand advocates." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingCommunicationStrategy ] .

ex:P16853 a owl:Class ;
    ex:pcfID "16853" ; ex:hierarchyID "3.2.5.5" ;
    ex:apqcSourceText "Finding emerging media based on digital or other technologies that would enable the company to increase the speed and volume of marketing communications, to make communications more interactive and to customize promotional messages more easily to the target audience, thus rendering them more effective." ;
    rdfs:label "Identify new media for marketing communication" ;
    skos:definition "An Act of Identification that discerns emerging digital and technological media for marketing communication and produces a new media assessment registering them." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment sense): it finds and registers candidate media. Output ex:NewMediaAssessment is Descriptive, agreeing with the Information-Processing genus." ;
    skos:example "A digital team scouts emerging social platforms suitable for promotional messaging." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:NewMediaAssessment ] .

ex:P16854 a owl:Class ;
    ex:pcfID "16854" ; ex:hierarchyID "3.2.5.6" ;
    ex:apqcSourceText "Developing a marketing strategy that is maximally effective in a new or emerging media channel by capitalizing on its novel attributes and capabilities." ;
    rdfs:label "Define new media communication strategy" ;
    skos:definition "An Act of Formulation that develops a marketing approach tailored to a new or emerging media channel and produces a marketing communication strategy for that channel." ;
    rdfs:comment "ex:NewMediaAssessment (from 16853) is a typical input, noted rather than asserted (Phase-3)." ;
    skos:example "A team designs a short-form-video strategy that exploits a new platform's native features." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingCommunicationStrategy ] .

ex:P16855 a owl:Class ;
    ex:pcfID "16855" ; ex:hierarchyID "3.2.5.7" ;
    ex:apqcSourceText "Establishing a framework for coordinated marketing to increase the profitability and increase brand awareness at the point of sale. This may include promotional posters on product shelves or island displays, advertisements in shopping carts, stickers on the floor that lead consumers to the promoted product, multi-buy promotions, coupons on sales receipts, etc." ;
    rdfs:label "Define point of sale (POS) communication strategy" ;
    skos:definition "An Act of Formulation that establishes a framework for coordinated marketing at the point of sale and produces a marketing communication strategy for point-of-sale promotion." ;
    skos:example "A retail-marketing team plans shelf displays and cart ads to lift point-of-sale brand awareness." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingCommunicationStrategy ] .

ex:P18627 a owl:Class ;
    ex:pcfID "18627" ; ex:hierarchyID "3.2.5.8" ;
    ex:apqcSourceText "Establishing standardized procedures for effective communication that maximizes ROI, promotes brand awareness and respects customers. In its simplest form, it includes a message (what is to be said), a target (to whom the message is reaching) and a medium or a channel (where the message is to be said)." ;
    rdfs:label "Define communication guidelines and mechanisms" ;
    skos:definition "An Act of Formulation that establishes standardized procedures for effective marketing communication and produces a set of communication policies and procedures." ;
    rdfs:comment "Output ex:PolicyAndProcedure is Directive, agreeing with the Formulation genus." ;
    skos:example "A team writes the house style and approval procedure for all outbound marketing messages." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PolicyAndProcedure ] .

ex:P18924 a owl:Class ;
    ex:pcfID "18924" ; ex:hierarchyID "3.2.6" ;
    ex:apqcSourceText "Creating and managing a customer loyalty program. The loyalty program is a key part of marketing, with an elaborate strategy and process for acquiring, retaining, and engaging with members. Members are engaged and acquainted to the loyalty program, thus growing relationship and adding value through the program." ;
    rdfs:label "Design and manage customer loyalty program" ;
    skos:definition "An Act of Formulation that creates a customer loyalty program for acquiring, retaining, and engaging members and produces a customer loyalty program specification." ;
    rdfs:comment "R5: modeled as a process because its dominant act 'create ... a loyalty program' yields a bounded Directive ex:CustomerLoyaltyProgram; the program's ongoing operation is decomposed into its bounded child acts (acquire/engage/monitor/optimize). Its APQC children are process parts." ;
    skos:example "A loyalty team designs and launches a points-based customer loyalty program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerLoyaltyProgram ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20007 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18925 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18926 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16633 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18927 ] .

ex:P20007 a owl:Class ;
    ex:pcfID "20007" ; ex:hierarchyID "3.2.6.1" ;
    ex:apqcSourceText "Devising procedures and mechanisms to retain existing customers, promote repeat business and increase the likelihood that previous customers to continue to buy products or services from the company. This may be achieved by rewarding customers for repeat business by means of gifts, discounts, redeemable points, or prioritized access to new products, events or services." ;
    rdfs:label "Define customer loyalty program" ;
    skos:definition "An Act of Formulation that devises the procedures and reward mechanisms to retain customers and promote repeat business and produces a customer loyalty program specification." ;
    rdfs:comment "Output ex:CustomerLoyaltyProgram is Directive, agreeing with the Formulation genus." ;
    skos:example "A team specifies the points and rewards rules of a new loyalty program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerLoyaltyProgram ] .

ex:P18925 a owl:Class ;
    ex:pcfID "18925" ; ex:hierarchyID "3.2.6.2" ;
    ex:apqcSourceText "Convincing customers to register their personal information with the company and be assigned a unique identifier that they use when making purchases. The identifier makes it easier for the company to track customer purchases. Customers are rewarded by various incentives that encourage repeat business [20007]." ;
    rdfs:label "Acquire members to customer loyalty program" ;
    skos:definition "An Act of Acquisition in which the organization obtains a customer's registration and assigns a unique loyalty identifier, producing customer master data for the enrolled member." ;
    rdfs:comment "Anchored to ex:ActOfAcquisition (reused from apqc-ext): the organization obtains a member's registered information it did not previously hold. Output ex:CustomerMasterData is Descriptive (is-about Customer) - the registered personal information and identifier." ;
    skos:example "A cashier signs a shopper up to the loyalty program, capturing their details under a member ID." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P18926 a owl:Class ;
    ex:pcfID "18926" ; ex:hierarchyID "3.2.6.3" ;
    ex:apqcSourceText "Building deeper relationships between a customer and a brand in order to promote customer loyalty and derive repeat business. Besides making frequent purchases, highly engaged customers refer family, friends and colleagues to make purchases as well, consume and re-broadcast promotional materials, provide feedback to the purchases they make and do not support competing brands." ;
    rdfs:label "Build engagement and relationship with members" ;
    skos:definition "A Planned Act in which an organization engages loyalty-program members through interactions that deepen the customer-brand relationship and promote repeat business." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): this is an operational relationship-building act, not information-processing, planning, appraisal, or selection. Its members are participants. No informational output is definitional (the deepened relationship is a quality of the bearer, not an ICE), so none is asserted (Phase-3); ex:CustomerFeedback is a typical by-product, noted here." ;
    skos:example "A brand runs an engagement program that turns members into repeat buyers and referrers." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Customer ] .

ex:P16633 a owl:Class ;
    ex:pcfID "16633" ; ex:hierarchyID "3.2.6.4" ;
    ex:apqcSourceText "Surveying and tracking the benefits of customer loyalty programs both for the company and for customers. Compare with comparable loyalty programs instituted in competitor companies. Propose changes as needed to keep up with market trends." ;
    rdfs:label "Monitor customer loyalty program benefits to the enterprise and the customer" ;
    skos:definition "An Act of Monitoring that surveys and tracks the benefits of a customer loyalty program for the enterprise and its customers and produces a performance report." ;
    rdfs:comment "Output ex:PerformanceReport is Descriptive, agreeing with the Monitoring genus." ;
    skos:example "A team tracks loyalty-program redemption and retention benefits versus competitor programs." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceReport ] .

ex:P18927 a owl:Class ;
    ex:pcfID "18927" ; ex:hierarchyID "3.2.6.5" ;
    ex:apqcSourceText "Enhancing the customer loyalty program so that it will yield maximum value both for the company and for the patrons enrolled in the program, increasing customer retention and continued engagement." ;
    rdfs:label "Optimize loyalty program value to both the enterprise and the customer" ;
    skos:definition "An Act of Formulation that enhances a customer loyalty program to maximize its value to the enterprise and its members and produces an improvement plan." ;
    rdfs:comment "Output ex:ImprovementPlan is Directive, agreeing with the Formulation genus. ex:PerformanceReport (from 16633) is a definitional input - the optimization acts on the monitored benefits." ;
    skos:example "A manager revises reward tiers to lift both retention and program margin." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementPlan ] .

####################################################################
# 5. PROCESS CLASSES  --  GROUP 3.3  Develop and manage marketing
#    plans (PCF 20008). 20008 is catalog-only (R3 grouping); 20593,
#    20010, 10154, 16629 are Organization Capabilities (R6 standing
#    functions); the rest are bounded processes. Capability realized-in
#    axioms are attached additively to the shared-vocabulary IRIs.
####################################################################

# 3.3.3 (PCF 20593) "Develop and manage pricing" -> PricingCapability
ex:PricingCapability rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20009 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P18948 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10163 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10164 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10165 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10166 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11495 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11496 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11497 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P17684 ] .

# 3.3.4 (PCF 20010), 3.3.7 (PCF 10154), 3.3.9 (PCF 16629) -> MarketingManagementCapability
ex:MarketingManagementCapability rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10167 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10159 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10160 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10168 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10169 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10170 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10171 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10172 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10178 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10179 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10180 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P10181 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16630 ] ,
    [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P18130 ] .

ex:P10148 a owl:Class ;
    ex:pcfID "10148" ; ex:hierarchyID "3.3.1" ;
    ex:apqcSourceText "Determining what to achieve by marketing. Create qualitative and quantitative targets. Establish metrics to track performance (for individual Market segments [10109] and Channels for target segments [10129]). Enlist the head of marketing to determine marketing priorities and the related measures. (The decision in establishing these goals, objectives, and metrics is founded in Develop marketing strategy [10102] and takes cues from current priorities and organizational strategy.)" ;
    rdfs:label "Establish goals, objectives, and measures for products/services by channel/segment" ;
    skos:definition "An Act of Formulation that composes qualitative and quantitative marketing goals and the performance measures used to track their attainment by channel and segment." ;
    rdfs:comment "Directive output (goals + performance-measure specifications) agrees with the planning genus per the GOLDEN PRINCIPLE." ;
    skos:example "A marketing leader sets target market-share and conversion goals with the metrics that will track them." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingGoal ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceMeasure ] .

ex:P10149 a owl:Class ;
    ex:pcfID "10149" ; ex:hierarchyID "3.3.2" ;
    ex:apqcSourceText "Creating a budget for the organization's marketing efforts, in line with the business-wide strategic outlook. Create a plan to distribute resources for achieving the marketing strategy in light of the overall business strategy. Make cost assumptions; calculate the estimated total revenue from the marketing activities against the costs/expenses of these activities. Forecast the return on investment. Attribute costs to the appropriate marketing activities such as promotional campaigns, advertising, marketing communications, PR campaigns, personnel, and office space. Enlist the financial and marketing functions." ;
    rdfs:label "Establish marketing budgets" ;
    skos:definition "An Act of Formulation that composes a marketing budget allocating resources across marketing activities in line with the overall business strategy." ;
    rdfs:comment "Directive output (a budget plan) agrees with the planning genus. Its four APQC children are process parts, not subclasses." ;
    skos:example "The marketing and finance functions agree an annual marketing budget with costs attributed to each campaign." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingBudget ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10155 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10156 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10157 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17683 ] .

ex:P10155 a owl:Class ;
    ex:pcfID "10155" ; ex:hierarchyID "3.3.2.1" ;
    ex:apqcSourceText "Ensuring corroboration of the marketing strategy and the organizational strategy. Ensure the organization's marketing strategy/plan aligns with the overall business strategy. Fine-tune the marketing plan according to the organizational strategy." ;
    rdfs:label "Confirm marketing alignment to business strategy" ;
    skos:definition "An Act of Appraisal that judges whether the marketing plan corroborates the overall business strategy and produces a marketing alignment assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal) because the act evaluates/confirms alignment. Descriptive output (an alignment judgement) agrees with the appraisal genus." ;
    skos:example "A planner checks the marketing plan against corporate strategy and confirms the two are aligned." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingAlignmentAssessment ] .

ex:P10156 a owl:Class ;
    ex:pcfID "10156" ; ex:hierarchyID "3.3.2.2" ;
    ex:apqcSourceText "Calculating the total cost of marketing the organization's portfolio of products/services. Calculate the total outlay needed for promoting, selling, and delivering the organization's products/services to customers. Account for all costs to acquire customers and sustain a relationship with them. Include the expenses needed for promotional actives, warehousing, transactional costs, and distribution of the organization's offering." ;
    rdfs:label "Determine costs of marketing" ;
    skos:definition "An Act of Analysis that has as input cost data and produces a cost analysis of the total outlay required to market the organization's portfolio." ;
    rdfs:comment "Descriptive output (a cost analysis) agrees with the information-processing genus." ;
    skos:example "An analyst totals promotion, warehousing, and distribution costs to determine the cost of marketing the portfolio." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CostAnalysis ] .

ex:P10157 a owl:Class ;
    ex:pcfID "10157" ; ex:hierarchyID "3.3.2.3" ;
    ex:apqcSourceText "Estimating the outlay required for promoting, selling, and distributing the products/services of the organization. Add up the expenses of all activities necessitated in marketing, such as promotional campaigns, advertising, marketing communications, PR campaigns, employing skilled personnel, and office space." ;
    rdfs:label "Create marketing budget" ;
    skos:definition "An Act of Formulation that composes a marketing budget by estimating and aggregating the outlay required for all marketing activities." ;
    rdfs:comment "Directive output (a budget) agrees with the planning genus. Cost data is a typical input recorded here, not an existential restriction." ;
    skos:example "A budget owner sums campaign, personnel, and overhead expenses into the marketing budget." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingBudget ] .

ex:P17683 a owl:Class ;
    ex:pcfID "17683" ; ex:hierarchyID "3.3.2.4" ;
    ex:apqcSourceText "Estimating how much profit the company would generate for its expenses on marketing . Forecasted return on investment, used as a metric to gauge the efficiency of marketing, is beneficial in revising marketing budgets and adjusting costs to improve the overall yield." ;
    rdfs:label "Determine projected ROI for marketing investment" ;
    skos:definition "An Act of Forecasting that estimates the uncertain future return on marketing investment and produces a return-on-investment forecast." ;
    rdfs:comment "Predictive output (an ROI forecast) agrees with the forecasting genus per the GOLDEN PRINCIPLE." ;
    skos:example "An analyst forecasts the ROI of the planned marketing spend to inform budget revisions." ;
    rdfs:subClassOf ex:ActOfForecasting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ROIForecast ] .

ex:P20009 a owl:Class ;
    ex:pcfID "20009" ; ex:hierarchyID "3.3.3.1" ;
    ex:apqcSourceText "Determining the production and distribution costs for each product or service, and each channel or method as factors in determining overall pricing." ;
    rdfs:label "Understand resource requirements for each product/service and delivery channel/method" ;
    skos:definition "An Act of Analysis that has as input cost data and produces a cost analysis of the production and distribution resource requirements per offering and channel." ;
    rdfs:comment "Descriptive output (a cost analysis) agrees with the information-processing genus." ;
    skos:example "A pricing analyst breaks out per-product and per-channel costs as inputs to pricing." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CostAnalysis ] .

ex:P18948 a owl:Class ;
    ex:pcfID "18948" ; ex:hierarchyID "3.3.3.2" ;
    ex:apqcSourceText "Introducing financial inducements, such as discounts, to distributors, resellers or vendors as a motivation to prioritize selling company's products or services over those of its competitors." ;
    rdfs:label "Determine corporate incentives" ;
    skos:definition "An Act of Formulation that composes an incentive scheme of financial inducements offered to distributors, resellers, or vendors." ;
    rdfs:comment "Directive output (an incentive scheme) agrees with the planning genus." ;
    skos:example "A pricing team designs a volume-discount scheme to motivate resellers." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IncentiveScheme ] .

ex:P10163 a owl:Class ;
    ex:pcfID "10163" ; ex:hierarchyID "3.3.3.3" ;
    ex:apqcSourceText "Establishing a dynamic pricing mechanism for the organization's offerings that is supported by the number of units in production. Outline a system for determining the optimum price point for each product/service. Based this model on an estimation of the volume of anticipated sales for each offering and variable costs." ;
    rdfs:label "Determine pricing based on volume/unit forecast" ;
    skos:definition "An Act of Formulation that composes a pricing strategy determining optimum price points from a forecast of sales volume and variable costs." ;
    rdfs:comment "Directive output (a pricing strategy) agrees with the planning genus. Sales forecast is a typical input recorded here, not an existential restriction." ;
    skos:example "A team builds a unit-volume pricing model that sets each offering's price point." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingStrategy ] .

ex:P10164 a owl:Class ;
    ex:pcfID "10164" ; ex:hierarchyID "3.3.3.4" ;
    ex:apqcSourceText "Implementing the pricing mechanism to determine prices for all individual offerings in the organizational portfolio. Calculate the prices of all offerings based on the established methodology and/or formulaic structure." ;
    rdfs:label "Execute pricing plan" ;
    skos:definition "A Planned Act that applies an established pricing methodology to all offerings and produces a price list." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): it executes a held pricing plan rather than making one. Directive output (a price list) is the priced realization of the methodology; pricing plan is a typical input recorded here." ;
    skos:example "Pricing software applies the agreed formula to every SKU and emits the new price list." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PriceList ] .

ex:P10165 a owl:Class ;
    ex:pcfID "10165" ; ex:hierarchyID "3.3.3.5" ;
    ex:apqcSourceText "Examining the efficiency of pricing with the objective of identifying any divergence from the equilibrium prices and avoiding any deadweight loss. Gauge the performance of the pricing plan by tracking growth in the revenue and/or customer uptake, secured as a result of new prices. Measure the performance of pricing by periodically checking the profits generated from the sale of each of the organization's offerings against the backdrop of any events that may have influenced the uptake of a certain good/service by the customer base." ;
    rdfs:label "Evaluate pricing performance" ;
    skos:definition "An Act of Appraisal that gauges the efficiency of the pricing plan and produces a pricing performance evaluation." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal). Descriptive output (a performance evaluation) agrees with the appraisal genus." ;
    skos:example "An analyst measures revenue growth attributable to new prices and reports pricing performance." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingPerformanceEvaluation ] .

ex:P10166 a owl:Class ;
    ex:pcfID "10166" ; ex:hierarchyID "3.3.3.6" ;
    ex:apqcSourceText "Refining the pricing mechanism to create equitable prices for all products/services with the objective of maximizing the profits and/or customer uptake of these offerings. Reconcile the pricing mechanism in order to achieve equilibrium pricing. Adjust the prices for all of the organization's offerings, using the insights gleaned from examining how much profit or customer uptake is generated by the present pricing strategy." ;
    rdfs:label "Refine pricing as needed" ;
    skos:definition "An Act of Formulation that adjusts the pricing mechanism toward equilibrium and produces a revised pricing strategy." ;
    rdfs:comment "Directive output (a revised pricing strategy) agrees with the planning genus. Pricing performance evaluation is a typical input recorded here." ;
    skos:example "A team reconciles prices toward equilibrium based on observed profit and uptake." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingStrategy ] .

ex:P11495 a owl:Class ;
    ex:pcfID "11495" ; ex:hierarchyID "3.3.3.7" ;
    ex:apqcSourceText "Managing schemes that offer lower pricing for a limited time as a promotional and sales incentive when launching a new product or a service." ;
    rdfs:label "Implement promotional pricing programs" ;
    skos:definition "A Planned Act that runs time-limited promotional pricing schemes and produces a price list of the discounted prices." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): it executes a held promotional-pricing scheme. Directive output (a discounted price list)." ;
    skos:example "A launch promotion applies introductory prices to a new product for a fixed window." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PriceList ] .

ex:P11496 a owl:Class ;
    ex:pcfID "11496" ; ex:hierarchyID "3.3.3.8" ;
    ex:apqcSourceText "Determining the optimum consumer pricing for each product or service at the point of sale, based on production and distribution costs and estimated sales volume." ;
    rdfs:label "Implement other retail pricing programs" ;
    skos:definition "An Act of Formulation that composes a retail pricing plan setting optimum consumer point-of-sale prices from costs and estimated sales volume." ;
    rdfs:comment "Genus is formulation, not bare execution, because the verb 'Determining the optimum consumer pricing' composes a Directive pricing plan." ;
    skos:example "A retail team sets shelf prices per SKU from cost and volume estimates." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingPlan ] .

ex:P11497 a owl:Class ;
    ex:pcfID "11497" ; ex:hierarchyID "3.3.3.9" ;
    ex:apqcSourceText "Assigning new prices or pricing adjustments to products or services to replace the original base prices. Update the prices in product catalogs and databases, and disseminate the information through all involved distribution and marketing channels." ;
    rdfs:label "Communicate and implement price changes" ;
    skos:definition "A Planned Act that assigns new prices, updates catalogs and databases, and disseminates the updated price list through distribution and marketing channels." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): it applies and propagates already-decided price changes. Directive output (an updated price list)." ;
    skos:example "An operations team pushes revised prices to the catalog and all channels." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PriceList ] .

ex:P17684 a owl:Class ;
    ex:pcfID "17684" ; ex:hierarchyID "3.3.3.10" ;
    ex:apqcSourceText "Obtaining internal price approvals and governmental approvals that are required for licensed products and for products that can be reimbursed by the government." ;
    rdfs:label "Achieve regulatory approval for pricing" ;
    skos:definition "An Act of Acquisition that obtains the internal and governmental pricing approvals required for licensed or reimbursable products." ;
    rdfs:comment "Reuses ex:ActOfAcquisition (inlined): an approval not previously held is obtained from an authority. Directive output (a pricing approval)." ;
    skos:example "A regulatory team secures government price approval for a reimbursable drug." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingApproval ] .

ex:P10167 a owl:Class ;
    ex:pcfID "10167" ; ex:hierarchyID "3.3.4.1" ;
    ex:apqcSourceText "Outlining a conceptual framework for all promotional activity in order to create an overarching aspiration and ensure consistency. Create a plan for running promotional programs and designing the associated activities in order to increase visibility or sales. Determine how the organization quantifies what it wishes to achieve from these activities, what sort of messages the organization comfortable publicizing, what channels the organization wishes to employ, etc." ;
    rdfs:label "Define promotional concepts and objectives" ;
    skos:definition "An Act of Formulation that composes a promotional plan setting the conceptual framework and objectives for all promotional activity." ;
    rdfs:comment "Directive output (a promotional plan) agrees with the planning genus." ;
    skos:example "A team defines the promotional concept, target outcomes, and approved channels for the year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PromotionalPlan ] .

ex:P10159 a owl:Class ;
    ex:pcfID "10159" ; ex:hierarchyID "3.3.4.2" ;
    ex:apqcSourceText "Developing the central messages for a segment of its customers. Craft concise statements that position the value proposition of individual products/services around the pressing concerns in the market, thereby showing how the organization's offerings are the right fit for the customers." ;
    rdfs:label "Develop marketing messages" ;
    skos:definition "An Act of Formulation that composes the central marketing messages positioning an offering's value proposition for a customer segment." ;
    rdfs:comment "Directive output (a marketing message) agrees with the planning genus." ;
    skos:example "A copy team crafts the headline messages that position a product's value to a target segment." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketingMessage ] .

ex:P10160 a owl:Class ;
    ex:pcfID "10160" ; ex:hierarchyID "3.3.4.3" ;
    ex:apqcSourceText "Determining the appropriate audience to direct marketing efforts at. Identify the particular group of customers to target. Discover the appropriate customer groups at a micro-level. Use techniques such as segmentation analysis, whereby the entire population is sliced according to certain demographic or behavioral attributes." ;
    rdfs:label "Define target audience" ;
    skos:definition "An Act of Selection that chooses the target customer segment from candidate segments and produces a target segment definition." ;
    rdfs:comment "Reuses ex:ActOfSelection (inlined): a target is chosen from candidate segments. Directive output (a target-segment definition) agrees with the selection genus." ;
    skos:example "A marketer selects the micro-segment to target after segmentation analysis." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TargetSegmentDefinition ] .

ex:P10168 a owl:Class ;
    ex:pcfID "10168" ; ex:hierarchyID "3.3.4.4" ;
    ex:apqcSourceText "Developing a scheme for executing the promotional programs and campaigns, and testing these on sample audiences. Create a program plan, and carry out trials for promotional activities. Develop a scheme for how, when, where, and by whom the promotional schemes and campaigns will be deployed. Design incentives that convince or tempt the consumer to take up the organization's offerings. Conduct focus groups and pilot programs that reach out to a smaller number of people from among the target audiences to validate effectiveness." ;
    rdfs:label "Plan and test promotional activities" ;
    skos:definition "An Act of Formulation that develops and trials a promotional program plan specifying how, when, where, and by whom campaigns will be deployed." ;
    rdfs:comment "Directive output (a promotional plan) agrees with the planning genus. Pilot/focus-group results are typical and recorded here, not an existential restriction." ;
    skos:example "A team drafts a campaign deployment plan and validates it with focus groups." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PromotionalPlan ] .

ex:P10169 a owl:Class ;
    ex:pcfID "10169" ; ex:hierarchyID "3.3.4.5" ;
    ex:apqcSourceText "Executing promotional programs in the market for reaching out to the desired customer segments. Implement the promotional schemes and campaigns. Create collaterals for the dissemination of information about the product, product line, brand, or company to the target audiences in an effective manner. Leverage relationships with distributors, vendors, and retailers. Consider enlisting professional services such as design, PR, and advertising firms." ;
    rdfs:label "Execute promotional activities" ;
    skos:definition "A Planned Act that executes promotional campaigns in the market and produces branding collateral disseminated to target audiences." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): it carries out a held promotional plan. Directive output (branding collateral); promotional plan is a typical input recorded here." ;
    skos:example "An agency deploys a campaign and ships the collateral to the target segments." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BrandingCollateral ] .

ex:P10170 a owl:Class ;
    ex:pcfID "10170" ; ex:hierarchyID "3.3.4.6" ;
    ex:apqcSourceText "Evaluating the success of promotional programs through metrics that track the impact of these activities. Examine the performance of promotional activities. Measure the success of these programs through metrics representative of customer uptake, market penetration, sustenance of impact created, revenue growth through offerings marketed, etc. Measure through primary data collection. Analyze through various statistical techniques to generate insights." ;
    rdfs:label "Evaluate promotional performance metrics" ;
    skos:definition "An Act of Appraisal that measures the success of promotional programs against metrics and produces a promotional performance evaluation." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal). Descriptive output (a performance evaluation) agrees with the appraisal genus." ;
    skos:example "An analyst measures uptake and revenue growth to evaluate a campaign's performance." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PromotionalPerformanceEvaluation ] .

ex:P10171 a owl:Class ;
    ex:pcfID "10171" ; ex:hierarchyID "3.3.4.7" ;
    ex:apqcSourceText "Fine-tuning promotional activities by employing the insights gleaned from the quantitative, as well as any qualitative, performance evaluations. Change certain attributes of the schemes, campaigns, and programs deployed in order to increase the impact generated, in terms of measures already agreed upon such as customer uptake, market penetration, sustenance of impact created, and revenue growth through offerings marketed." ;
    rdfs:label "Refine promotional performance metrics" ;
    skos:definition "An Act of Formulation that adjusts promotional activities from evaluation insights and produces an improvement plan." ;
    rdfs:comment "Directive output (an improvement plan) agrees with the planning genus. Promotional performance evaluation is a typical input recorded here." ;
    skos:example "A team revises campaign attributes to raise uptake based on measured results." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementPlan ] .

ex:P10172 a owl:Class ;
    ex:pcfID "10172" ; ex:hierarchyID "3.3.4.8" ;
    ex:apqcSourceText "Incorporating the understanding developed by studying promotional activities as well as refining them. Include the best practices and value-enhancing attributes identified in Refine promotional activities [10171] into similarly planned schemes, programs, and campaigns. Adjust promotional activities to further increase the effectiveness of the overall promotional efforts." ;
    rdfs:label "Incorporate learning into future/planned consumer promotions" ;
    skos:definition "An Act of Formulation that incorporates lessons and best practices from prior promotions into an improvement plan for future campaigns." ;
    rdfs:comment "Directive output (an improvement plan) agrees with the planning genus." ;
    skos:example "Best practices from a campaign are written into the plan for next quarter's promotions." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementPlan ] .

ex:P10153 a owl:Class ;
    ex:pcfID "10153" ; ex:hierarchyID "3.3.5" ;
    ex:apqcSourceText "Collating all customer-centered metrics. The objective is to create a big-picture view of the customers' mindset and their behavior pertaining to the organization's offerings." ;
    rdfs:label "Track customer management measures" ;
    skos:definition "An Act of Monitoring that collates customer-centered metrics over time to produce a customer metric analysis giving a big-picture view of customer behavior." ;
    rdfs:comment "Uses ex:ActOfMonitoring (PROPOSE-EXT): ongoing tracking of customer measures. Descriptive output agrees with the information-processing genus. Its five APQC children are process parts." ;
    skos:example "A CRM team continuously collates loyalty, retention, and value metrics into a customer dashboard." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMetricAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10173 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10174 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10175 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10176 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10177 ] .

ex:P10173 a owl:Class ;
    ex:pcfID "10173" ; ex:hierarchyID "3.3.5.1" ;
    ex:apqcSourceText "Estimating customer loyalty and the average contribution made by them to revenues, over their lifespan. Use metrics to quantify the commitment of customers to the offerings of the organization, such as measures of tendency to switch brands/providers, number/proportion of return customers, and the number of customers using multiple substitutable offerings." ;
    rdfs:label "Determine customer lifetime value" ;
    skos:definition "An Act of Forecasting that estimates the uncertain future revenue contribution of customers over their lifespan and produces a customer lifetime value estimate." ;
    rdfs:comment "Predictive output (a lifetime-value estimate) agrees with the forecasting genus per the GOLDEN PRINCIPLE." ;
    skos:example "An analyst forecasts each segment's lifetime value from loyalty and retention measures." ;
    rdfs:subClassOf ex:ActOfForecasting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerLifetimeValue ] .

ex:P10174 a owl:Class ;
    ex:pcfID "10174" ; ex:hierarchyID "3.3.5.2" ;
    ex:apqcSourceText "Analyzing the revenue stream generated by the sale of the organization's products/services in order to identify trends therein. Examine data relating to the inflow of revenue from individual/groups of customers in order to identify patterns in the generation and sustenance of receivables. Conduct statistical analysis over the stream of revenue collected and the point of origin associated with each unit of sale through metrics such as the accounting rate of return, the GAAP revenue over a given period, and customer lifetime revenue." ;
    rdfs:label "Analyze customer revenue trend" ;
    skos:definition "An Act of Analysis that examines customer revenue data to identify trends and produces a customer metric analysis." ;
    rdfs:comment "Descriptive output agrees with the information-processing genus. Customer data is a typical input recorded here." ;
    skos:example "An analyst finds growth patterns in revenue by customer group." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMetricAnalysis ] .

ex:P10175 a owl:Class ;
    ex:pcfID "10175" ; ex:hierarchyID "3.3.5.3" ;
    ex:apqcSourceText "Calculating measures that capture the proportion of customers the organization is able to retain to those it is losing. Compute metrics such as the tendency to switch brands/providers and the proportion of return customers to comprehend the trends within the customer attrition and retention rates." ;
    rdfs:label "Analyze customer attrition and retention rates" ;
    skos:definition "An Act of Analysis that computes customer attrition and retention measures and produces a customer metric analysis." ;
    rdfs:comment "Descriptive output agrees with the information-processing genus." ;
    skos:example "A team calculates churn and return-customer proportions to understand retention trends." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMetricAnalysis ] .

ex:P10176 a owl:Class ;
    ex:pcfID "10176" ; ex:hierarchyID "3.3.5.4" ;
    ex:apqcSourceText "Studying all measures of the customer's behavior and conduct toward the organization's offerings in order to glean insight and identify patterns into their decision making. Closely examine all categories of data sets over a customer base. Analyze data points related to customer loyalty, retention, value, conversion, level of satisfaction, attrition, etc. Flesh out measures for an all-encompassing analysis that provides a macro-level picture of the customer's behavior and mindset related to the organization's products/services." ;
    rdfs:label "Analyze customer metrics" ;
    skos:definition "An Act of Analysis that has as input customer data and produces a customer metric analysis and customer insight giving a macro-level picture of customer behavior." ;
    rdfs:comment "Descriptive outputs agree with the information-processing genus." ;
    skos:example "An analyst studies loyalty, conversion, and satisfaction data to surface behavioral insight." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMetricAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerInsight ] .

ex:P10177 a owl:Class ;
    ex:pcfID "10177" ; ex:hierarchyID "3.3.5.5" ;
    ex:apqcSourceText "Reviewing and reappraising the strategies, objectives, and plans for all customer-centered processes. Revisit all customer-focused processes and activities--which relate to their acquisition, conversion, and retention--with the objective of revising them in light of customer analysis. Revise accordingly." ;
    rdfs:label "Revise customer strategies, objectives, and plans based on metrics" ;
    skos:definition "An Act of Formulation that revises customer strategies, objectives, and plans in light of customer analysis and produces a revised customer management measure." ;
    rdfs:comment "Directive output (a revised customer-management measure) agrees with the planning genus. Customer metric analysis is a typical input recorded here." ;
    skos:example "A team rewrites the customer-retention objectives after reviewing the metrics." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerManagementMeasure ] .

ex:P16613 a owl:Class ;
    ex:pcfID "16613" ; ex:hierarchyID "3.3.6" ;
    ex:apqcSourceText "Reviewing and responding to customer feedback. Create tickets to initiate bug fixes or to propose feature updates. Monitor and track progress." ;
    rdfs:label "Analyze and respond to customer insight" ;
    skos:definition "An Act of Analysis that has as input customer feedback and produces customer insight used to drive responses." ;
    rdfs:comment "Descriptive output (customer insight) agrees with the information-processing genus. Its five APQC children are process parts." ;
    skos:example "A team reviews customer feedback, derives insight, and raises tickets in response." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerInsight ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16627 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16614 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16615 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16616 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16617 ] .

ex:P16627 a owl:Class ;
    ex:pcfID "16627" ; ex:hierarchyID "3.3.6.1" ;
    ex:apqcSourceText "Following postings on social media to promote offerings, raise brand awareness, interact with customers, increase customer engagement and brand loyalty, respond to queries, gauge sentiment regarding company's products or services, and to derive customer insight." ;
    rdfs:label "Monitor and respond to social media activity" ;
    skos:definition "An Act of Monitoring that has as input customer feedback from social media, tracks sentiment, and produces customer insight." ;
    rdfs:comment "Uses ex:ActOfMonitoring (PROPOSE-EXT): ongoing following of social-media postings. Descriptive output (customer insight) agrees with the information-processing genus." ;
    skos:example "A social team tracks brand mentions, replies to queries, and derives sentiment insight." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerInsight ] .

ex:P16614 a owl:Class ;
    ex:pcfID "16614" ; ex:hierarchyID "3.3.6.2" ;
    ex:apqcSourceText "Examining user activity on company, vendor or reseller websites to improve traffic on and to the website, improve user experience on the website to simplify purchasing process and encourage repeat purchases, and to increase the site's visibility in search engine results. Various metrics can be used to measure user activity, such as number of users who are new, returning or unique, time spent on page, session duration, bounce rate, click through rate, conversion rate, and others." ;
    rdfs:label "Analyze customer website activity" ;
    skos:definition "An Act of Analysis that has as input customer data on website activity and produces a customer metric analysis." ;
    rdfs:comment "Descriptive output agrees with the information-processing genus." ;
    skos:example "A web analyst examines bounce and conversion rates to characterize site usage." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMetricAnalysis ] .

ex:P16615 a owl:Class ;
    ex:pcfID "16615" ; ex:hierarchyID "3.3.6.3" ;
    ex:apqcSourceText "Conducting analyses to uncover customer purchasing habits. Detect patterns and categorize users based on similar characteristics and behaviors, demographic information, geographic location, search history, etc." ;
    rdfs:label "Analyze customer purchase patterns" ;
    skos:definition "An Act of Analysis that has as input customer data and produces a customer behavior model describing purchasing patterns." ;
    rdfs:comment "Descriptive output (a behavior model, about Customer) agrees with the information-processing genus." ;
    skos:example "An analyst clusters customers by purchasing behavior into a behavior model." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerBehaviorModel ] .

ex:P16616 a owl:Class ;
    ex:pcfID "16616" ; ex:hierarchyID "3.3.6.4" ;
    ex:apqcSourceText "Creating formulas for personalized offers, purchasing recommendations and targeted advertisements for customers on the basis of previously detected purchase patterns [16615]." ;
    rdfs:label "Develop business rules to provide personalized offers" ;
    skos:definition "An Act of Formulation that composes business rules prescribing personalized offers and recommendations from detected purchase patterns." ;
    rdfs:comment "Directive output (a business rule) agrees with the planning genus. Customer behavior model is a typical input recorded here." ;
    skos:example "A team writes rules that trigger personalized offers from a customer's purchase history." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessRule ] .

ex:P16617 a owl:Class ;
    ex:pcfID "16617" ; ex:hierarchyID "3.3.6.5" ;
    ex:apqcSourceText "Analyzing how well the targeted offers perform to see whether they result in an increased conversion rate. Reanalyze the purchase patterns or modify those business rules that are produce effective recommendations." ;
    rdfs:label "Monitor effectiveness of personalized offers and adjust offers accordingly" ;
    skos:definition "An Act of Monitoring that tracks the conversion effectiveness of personalized offers and produces a promotional performance evaluation driving rule adjustments." ;
    rdfs:comment "Uses ex:ActOfMonitoring (PROPOSE-EXT): ongoing tracking of offer effectiveness. Descriptive output (a performance evaluation) agrees with the information-processing genus." ;
    skos:example "A team watches conversion lift from personalized offers and flags rules to revise." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PromotionalPerformanceEvaluation ] .

ex:P10178 a owl:Class ;
    ex:pcfID "10178" ; ex:hierarchyID "3.3.7.1" ;
    ex:apqcSourceText "Creating a strategic road map for how to package products/services into desirable solutions while increasing profitability. Create a scheme for how the organization will bundle and wrap its products/services into a presentable and sellable offering. Consider what aspects or components of an offering the organization can extract the maximum revenue from, and reduce the less profitable constituents while maintaining a high perceptible value for the customers. Balance maximizing profit with benefits to the customer." ;
    rdfs:label "Plan packaging strategy" ;
    skos:definition "An Act of Formulation that composes a packaging strategy road map for bundling and wrapping offerings into sellable solutions." ;
    rdfs:comment "Directive output (a packaging strategy) agrees with the planning genus." ;
    skos:example "A team drafts the road map for how products will be bundled and packaged." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PackagingStrategy ] .

ex:P10179 a owl:Class ;
    ex:pcfID "10179" ; ex:hierarchyID "3.3.7.2" ;
    ex:apqcSourceText "Piloting the packaged products/services in the market with a test audience. Create trial runs using techniques such as focus groups of the final product, wrapped and bundled." ;
    rdfs:label "Test packaging options" ;
    skos:definition "A Planned Act that pilots packaged offerings with a test audience to validate packaging options." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): it executes trials of a held packaging strategy. The packaging strategy is a typical input and the gathered test feedback a typical output, recorded here rather than as existential restrictions." ;
    skos:example "A team runs focus groups on wrapped, bundled product samples." ;
    rdfs:subClassOf cco:ont00000228 .

ex:P10180 a owl:Class ;
    ex:pcfID "10180" ; ex:hierarchyID "3.3.7.3" ;
    ex:apqcSourceText "Implementing the final packaging. Put into action the packaging strategy in light of the insights accumulated from testing various options." ;
    rdfs:label "Execute packaging strategy" ;
    skos:definition "A Planned Act that implements the final packaging in line with the packaging strategy and testing insights." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): it executes a held packaging strategy. The packaging strategy is a typical input recorded here." ;
    skos:example "Production rolls out the chosen packaging across the product line." ;
    rdfs:subClassOf cco:ont00000228 .

ex:P10181 a owl:Class ;
    ex:pcfID "10181" ; ex:hierarchyID "3.3.7.4" ;
    ex:apqcSourceText "Fine-tuning the packaging that has been developed and tested using insights gleaned from feedback." ;
    rdfs:label "Refine packaging" ;
    skos:definition "An Act of Formulation that fine-tunes packaging from feedback and produces a revised packaging strategy." ;
    rdfs:comment "Directive output (a revised packaging strategy) agrees with the planning genus. Customer feedback is a typical input recorded here." ;
    skos:example "A team adjusts the packaging design after reviewing test feedback." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PackagingStrategy ] .

ex:P21425 a owl:Class ;
    ex:pcfID "21425" ; ex:hierarchyID "3.3.8" ;
    ex:apqcSourceText "Creation of a plan detailing how a company plans to execute a successful product release and promotion, and ultimately its sale to customers." ;
    rdfs:label "Develop go-to-market strategy" ;
    skos:definition "An Act of Formulation that composes a go-to-market strategy detailing how an offering will be released, promoted, and sold to customers." ;
    rdfs:comment "Directive output (a go-to-market strategy) agrees with the planning genus." ;
    skos:example "A product team writes the go-to-market plan for a new product launch." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GoToMarketStrategy ] .

ex:P16630 a owl:Class ;
    ex:pcfID "16630" ; ex:hierarchyID "3.3.9.1" ;
    ex:apqcSourceText "Producing or overseeing the creation or acquisition of photos, images and graphics for a product description, advertisement or a website. Like the copy [18131], product images are chosen and edited to enhance the product description and to convince consumers to purchase the product." ;
    rdfs:label "Manage product images" ;
    skos:definition "An Act of Communication that produces the photos, images, and graphics of product marketing content about an offering." ;
    rdfs:comment "RE-ANCHORED (Gate-F): the output ex:ProductMarketingContent is a DESCRIPTIVE ICE, but the prior genus ex:ActOfFormulation is defined (inlined) as an Act of Planning whose output is a DIRECTIVE ICE -- a GOLDEN PRINCIPLE violation (the 'composes an artifact' reading is a false friend for Formulation's planning sense). Re-anchored to cco:ont00000402 (Act of Communication; product images are communication content transferred to the audience) plus cco:ont00000228 (Planned Act), the descriptive-content-authoring genus chosen for this row and its sibling P18130. Output ex:ProductMarketingContent (Descriptive) retained." ;
    skos:example "A designer creates and edits the product hero image for a listing." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductMarketingContent ] .

ex:P18130 a owl:Class ;
    ex:pcfID "18130" ; ex:hierarchyID "3.3.9.2" ;
    ex:apqcSourceText "Authoring or overseeing the creation of the textual portion of a product description, advertisement, or web page, including the headline, body, product attributes, and brand or advertiser information. A copy is designed to provide information about the product and to catch and hold the interest of prospective buyers long enough to persuade them to make a purchase. The copy of a website is called its content." ;
    rdfs:label "Manage product copy" ;
    skos:definition "An Act of Communication that authors the textual product marketing content about an offering, including headline, body, and attributes." ;
    rdfs:comment "RE-ANCHORED (Gate-F): the output ex:ProductMarketingContent is an explicitly DESCRIPTIVE ICE ('persuasive intent does not make it directive -- it states facts/claims about the offering'), but the prior genus ex:ActOfFormulation entails a DIRECTIVE output by its apqc-ext.ttl definition -- a GOLDEN PRINCIPLE violation (the 'composes an artifact' false-friend reading of Formulation). Re-anchored to cco:ont00000402 (Act of Communication) plus cco:ont00000228 (Planned Act), consistent with its sibling P16630. Output ex:ProductMarketingContent (Descriptive) retained." ;
    skos:example "A copywriter drafts the headline and body text for a product page." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProductMarketingContent ] .

####################################################################
# 6. PROCESS CLASSES  --  GROUP 3.4  Develop sales strategy
#    (PCF 10103). Partonomy via cco:ont00001777.
####################################################################

ex:P10103 a owl:Class ;
    ex:pcfID "10103" ; ex:hierarchyID "3.4" ;
    ex:apqcSourceText "Developing concrete plans for guiding and providing support to the sales function. Chart a road map for the sales function, including an analysis of historical sales data to create forecasts for anticipated sales, forming sales targets, forging partnerships with other economic agents to boost sales, devising a budget for this function, and determining metrics to measure customer management activities as well as progress in achieving sales targets." ;
    rdfs:label "Develop sales strategy" ;
    skos:definition "An Act of Formulation that charts a road map for the sales function and produces a sales strategy, comprising the development of a sales forecast, the cultivation of partner and alliance relationships, the establishment of sales budgets, and the establishment of sales goals and customer-management measures." ;
    rdfs:comment "Models APQC group 3.4 as an occurrent. Anchored at ex:ActOfFormulation (under Act of Planning): the node composes a directive road map. Its APQC children are process parts (has process part), not subclasses (D1)." ;
    skos:example "A sales leadership team runs its annual sales-strategy cycle, producing the forecast, partner plan, budget, and target/metric set for the year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10129 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10130 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10131 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10132 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10133 ] .

ex:P10129 a owl:Class ;
    ex:pcfID "10129" ; ex:hierarchyID "3.4.1" ;
    ex:apqcSourceText "Developing a sales forecast for the organization's portfolio of offerings, bearing in mind the effect of promotional events, and fine-tuning these in the context of the new forecast. Estimate the future demand for the organization's products/services by analyzing historical information and any promotional activity." ;
    rdfs:label "Develop sales forecast" ;
    skos:definition "An Act of Forecasting that estimates the future demand for an organization's portfolio of offerings from historical and promotional information and produces a sales forecast." ;
    rdfs:comment "Genus ex:ActOfForecasting (under cco:ont00000371 Act of Prediction): the definitional output is a Predictive ICE (ex:SalesForecast). Children are process parts." ;
    skos:example "A demand-planning team analyzes order history and promotions and issues next year's sales forecast." ;
    rdfs:subClassOf ex:ActOfForecasting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesOrderData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10134 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10135 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10136 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10137 ] .

ex:P10134 a owl:Class ;
    ex:pcfID "10134" ; ex:hierarchyID "3.4.1.1" ;
    ex:apqcSourceText "Gathering all information about sales orders into an index. Create a directory of all sales orders, whether open or those which have been fulfilled. Track what product/service was ordered, the quantity ordered, who ordered it, the delivery date, the shipping method, the unit price and line total, payment terms, and any discount applied." ;
    rdfs:label "Gather current and historic order information" ;
    skos:definition "An Act of Information Processing that gathers and stores information about current and historical sales orders into an index and produces a sales-order data record." ;
    rdfs:comment "Anchored directly at cco:ont00000366 (Act of Information Processing): gathering orders into an index is the 'received ... and stored' sense of information processing, not an analysis or appraisal. The directory it builds is the descriptive ex:SalesOrderData." ;
    skos:example "A sales-ops analyst compiles open and fulfilled orders into a single order directory." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesOrderData ] .

ex:P10135 a owl:Class ;
    ex:pcfID "10135" ; ex:hierarchyID "3.4.1.2" ;
    ex:apqcSourceText "Analyzing sales order data to identify patterns in order to capitalize on emerging trends in the industry or the economy. Closely examine the directory of sales orders. Discern any patterns from this index, which is representative of the demand for the organization's offerings. Identify trends among the various segments of the organization's customer base to create forecasts. Glean patterns from this analysis, including the triangulation of segments that are showing the most growth in demand or those that represent the highest decline revenue, industry-wide trends such as decline/boost in overall demand, and any unusual trends that lie outside of the organization's expectations." ;
    rdfs:label "Analyze sales trends and patterns" ;
    skos:definition "An Act of Analysis that examines sales-order data to discern demand patterns and produces a sales-trend analysis." ;
    rdfs:comment "Genus ex:ActOfAnalysis (under cco:ont00000366): descriptive examination of the order directory yielding ex:SalesTrendAnalysis (GOLDEN PRINCIPLE: Analysis -> Descriptive ICE)." ;
    skos:example "An analyst discerns which customer segments are growing fastest from the order index." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesOrderData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesTrendAnalysis ] .

ex:P10136 a owl:Class ;
    ex:pcfID "10136" ; ex:hierarchyID "3.4.1.3" ;
    ex:apqcSourceText "Calculating the future demand for the organization's products/services. Use the trends and patterns identified in the sales data to estimate future demand. Use forecast to prepare for future customer demand and to recalibrate the strategic course of functions and business units." ;
    rdfs:label "Generate sales forecast" ;
    skos:definition "An Act of Forecasting that extrapolates from identified sales trends to estimate future demand and produces a sales forecast." ;
    rdfs:comment "Genus ex:ActOfForecasting: the definitional output is the Predictive ICE ex:SalesForecast (GOLDEN PRINCIPLE: forecast -> Predictive). The sales-trend analysis (ex:SalesTrendAnalysis) from 3.4.1.2 is the typical informational input." ;
    skos:example "A planner converts the trend analysis into a unit-demand forecast for the next four quarters." ;
    rdfs:subClassOf ex:ActOfForecasting ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesTrendAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesForecast ] .

ex:P10137 a owl:Class ;
    ex:pcfID "10137" ; ex:hierarchyID "3.4.1.4" ;
    ex:apqcSourceText "Reviewing promotional activities' effect on the sales orders. Analyze all promotional events and campaigns that the organization has already employed or is planning to deploy." ;
    rdfs:label "Analyze historical and planned promotions and events" ;
    skos:definition "An Act of Analysis that reviews the effect of historical and planned promotional events on sales orders and produces a sales-trend analysis of promotional impact." ;
    rdfs:comment "Genus ex:ActOfAnalysis: descriptive review of promotional effect, output ex:SalesTrendAnalysis. Refines the forecast (3.4.1.3) but is a parallel analytic facet, so no precedence is asserted." ;
    skos:example "An analyst quantifies how past campaigns lifted order volume to adjust the forecast." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesOrderData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesTrendAnalysis ] .

ex:P10130 a owl:Class ;
    ex:pcfID "10130" ; ex:hierarchyID "3.4.2" ;
    ex:apqcSourceText "Cultivating an alliance of partners by identifying, analyzing, negotiating, and managing partnerships with other economic agents." ;
    rdfs:label "Develop sales partner/alliance relationships" ;
    skos:definition "An Act of Formulation that cultivates an organization's set of sales partner and alliance relationships and produces a partner and alliance strategy." ;
    rdfs:comment "Genus ex:ActOfFormulation: the node develops the relationship set and yields the directive ex:AllianceStrategy. The standing 'manage' function is modeled separately as ex:PartnerManagementCapability (R6), not by this bounded development node. Children are process parts." ;
    skos:example "A partnerships team builds out the year's alliance program, from opportunity scan to signed agreements and management goals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AllianceStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10138 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10139 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10140 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11465 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11521 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11466 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10141 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10142 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18629 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11522 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11523 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11468 ] .

ex:P10138 a owl:Class ;
    ex:pcfID "10138" ; ex:hierarchyID "3.4.2.1" ;
    ex:apqcSourceText "Identifying collaboration opportunities for selling, marketing, and distributing the organization's products/services. Determine any scope for partnering with other economic agents, with synergies for the marketing, sales, and/or distribution of the organization's products/services. Identify alliance opportunities that target customer segments who would be interested." ;
    rdfs:label "Identify alliance opportunities" ;
    skos:definition "An Act of Identification that discerns collaboration opportunities for selling, marketing, and distributing an organization's offerings and produces a market-opportunity statement for partnering." ;
    rdfs:comment "Genus ex:ActOfIdentification (discernment sense, under cco:ont00000366): output is the descriptive ex:MarketOpportunity. Not cco:ont00001261 (a communication act)." ;
    skos:example "A partnerships lead identifies distributors whose reach complements the firm's target segments." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketOpportunity ] .

ex:P10139 a owl:Class ;
    ex:pcfID "10139" ; ex:hierarchyID "3.4.2.2" ;
    ex:apqcSourceText "Creating the frameworks needed to select alliance partners, and maintaining relationships with them. Create a framework for structured programs that can receive and support multiple alliances. Clearly outline the responsibilities and benefits of the alliance partners. Create frameworks for selecting the right alliance partners, and maintain a relationship with them. Create or repurpose teams of relationship managers and outline a methodology for selecting alliance partners." ;
    rdfs:label "Design alliance programs and methods for selecting and managing relationships" ;
    skos:definition "An Act of Formulation that composes the programs, selection methods, and relationship-management frameworks for alliance partnerships and produces a partner and alliance strategy." ;
    rdfs:comment "Genus ex:ActOfFormulation: the frameworks/methodology are a directive specification (ex:AllianceStrategy). Referenced as the basis of selection in 3.4.2.3 [10140] and management in 3.4.2.7 [10141]." ;
    skos:example "A team drafts the alliance-program template and the partner-selection scorecard methodology." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AllianceStrategy ] .

ex:P10140 a owl:Class ;
    ex:pcfID "10140" ; ex:hierarchyID "3.4.2.3" ;
    ex:apqcSourceText "Choosing alliance partners using the selected programs and methodology. Select the most feasible and profitable alliance partners, based on Design alliance programs and methods for selecting and managing relationships [10139] and through a careful scrutiny of the potential alliance." ;
    rdfs:label "Select alliances" ;
    skos:definition "An Act of Selection that chooses the most feasible and profitable alliance partners from a candidate set using the designed selection methodology and produces an alliance selection." ;
    rdfs:comment "Genus ex:ActOfSelection (under cco:ont00000366): a candidate set is narrowed to chosen partners, yielding the directive ex:AllianceSelection (a decision). Definitional input is the selection methodology authored in 3.4.2.2 [10139] (ex:AllianceStrategy)." ;
    skos:example "A committee scores prospective partners against the methodology and selects two alliances." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:AllianceStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AllianceSelection ] .

ex:P11465 a owl:Class ;
    ex:pcfID "11465" ; ex:hierarchyID "3.4.2.4" ;
    ex:apqcSourceText "Implementing category management strategies for customers through the use of consumer insights and understanding of customer specifics. Develop consumer and channel insights. Establish long term strategies, objectives and targets across the brand." ;
    rdfs:label "Develop customer trade strategy and customer objectives/targets" ;
    skos:definition "An Act of Formulation that composes a customer trade and category-management strategy with long-term objectives and targets and produces a customer trade strategy." ;
    rdfs:comment "Genus ex:ActOfFormulation: directive trade strategy (ex:CustomerTradeStrategy). Customer and channel insights (ex:CustomerInsight) are typical informational input. The brand-level objectives/targets co-emit a sales goal (ex:SalesGoal)." ;
    skos:example "A trade-marketing team sets the brand's annual customer category strategy and targets." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerTradeStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesGoal ] .

ex:P11521 a owl:Class ;
    ex:pcfID "11521" ; ex:hierarchyID "3.4.2.5" ;
    ex:apqcSourceText "Establishing business-to-business marketing campaigns and financial incentives for wholesalers, dealers, distributors and other intermediaries that the company uses to distribute its products or services." ;
    rdfs:label "Define trade programs and funding options" ;
    skos:definition "An Act of Formulation that defines business-to-business trade programs and financial incentives for distribution intermediaries and produces an incentive scheme." ;
    rdfs:comment "Genus ex:ActOfFormulation: the trade funding/incentives are a directive ex:IncentiveScheme (per the section vocab mapping of 3.4.2.5 trade funding)." ;
    skos:example "A channel team defines the dealer rebate and co-op funding program for the year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IncentiveScheme ] .

ex:P11466 a owl:Class ;
    ex:pcfID "11466" ; ex:hierarchyID "3.4.2.6" ;
    ex:apqcSourceText "Arranging meetings with trade partners to coordinate logistics, manage critical resources, resolve bottlenecks, and schedule urgent or time-sensitive matters." ;
    rdfs:label "Conduct planning activities for major trade customers" ;
    skos:definition "An Act of Planning that arranges coordination of logistics, resources, and scheduling with major trade customers and produces an execution roadmap." ;
    rdfs:comment "Anchored at cco:ont00000511 (Act of Planning): the act makes a plan/schedule to achieve coordination objectives, output the directive ex:ExecutionRoadmap (prescribes actions, ordering, and timing). Distinguished from ex:ActOfFormulation by its operational scheduling focus rather than authoring a strategy." ;
    skos:example "Account managers convene trade partners and lay out the quarter's logistics and resolution schedule." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExecutionRoadmap ] .

ex:P10141 a owl:Class ;
    ex:pcfID "10141" ; ex:hierarchyID "3.4.2.7" ;
    ex:apqcSourceText "Designing strategies for effectively managing, identifying, and countering any possible issues from the alliance partnerships formed. Create a strategic road map for managing the partnerships forged through Design alliance programs and methods for selecting and managing relationships [10139]. Determine where the alliance partnerships are headed, possible problems or pushback from the partners, how these issues might be countered, how these alliance partnerships would evolve in the future, any other business cases where these partnerships might be deployed, etc." ;
    rdfs:label "Develop partner and alliance management strategies" ;
    skos:definition "An Act of Formulation that designs strategies for managing, anticipating issues in, and evolving alliance partnerships and produces a partner and alliance strategy." ;
    rdfs:comment "Genus ex:ActOfFormulation: a strategic road map for managing partnerships is the directive ex:AllianceStrategy. Builds on the frameworks of 3.4.2.2 [10139]." ;
    skos:example "A partnerships lead drafts the management road map anticipating partner pushback and exit scenarios." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AllianceStrategy ] .

ex:P10142 a owl:Class ;
    ex:pcfID "10142" ; ex:hierarchyID "3.4.2.8" ;
    ex:apqcSourceText "Setting targets for organizational achievement. This includes what the organization aims to achieve from and how it wishes to manage both the individual partners and the alliance as a whole. Set immediate through long-term goals including revenue targets, market penetration, footfall numbers, and geographical coverage." ;
    rdfs:label "Establish partner and alliance management goals" ;
    skos:definition "An Act of Formulation that sets immediate through long-term goals and targets for managing individual partners and the alliance as a whole and produces a sales goal and target." ;
    rdfs:comment "Genus ex:ActOfFormulation: revenue/penetration/coverage targets are a directive ex:SalesGoal." ;
    skos:example "Management sets the alliance's revenue and geographical-coverage targets for the next three years." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesGoal ] .

ex:P18629 a owl:Class ;
    ex:pcfID "18629" ; ex:hierarchyID "3.4.2.9" ;
    ex:apqcSourceText "Setting up strategic alliances with key trade partners and ratifying partnership agreements." ;
    rdfs:label "Establish partner and alliance agreements" ;
    skos:definition "A Planned Act that sets up strategic alliances with key trade partners by ratifying partnership agreements and produces an alliance agreement." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): ratifying an already-negotiated single agreement is not a candidate-set choice, so it is NOT ex:ActOfSelection; the output is the directive ex:AllianceAgreement." ;
    skos:example "Executives sign the alliance agreement ratifying terms with a key distributor." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AllianceAgreement ] .

ex:P11522 a owl:Class ;
    ex:pcfID "11522" ; ex:hierarchyID "3.4.2.10" ;
    ex:apqcSourceText "Combining scheduled promotional, category management and trade marketing events into unified timetables. Update the calendars. Register new events." ;
    rdfs:label "Develop promotional and category management calendars (trade marketing calendars)" ;
    skos:definition "An Act of Formulation that combines scheduled promotional, category-management, and trade-marketing events into a unified timetable and produces a trade marketing calendar." ;
    rdfs:comment "Genus ex:ActOfFormulation (Directive output) is correct. OUTPUT ICE CORRECTED (Gate-F): formerly ex:CommunicationCalendar, whose definition denotes marketing-MESSAGE-delivery scheduling; the source combines promotional/category-management/trade-marketing EVENTS into timetables, so the dedicated ex:TradeMarketingCalendar is now used (D5 reuse-before-mint: the reused ICE denoted a different artifact)." ;
    skos:example "A trade-marketing planner merges promo and category events into one master trade calendar." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TradeMarketingCalendar ] .

ex:P11523 a owl:Class ;
    ex:pcfID "11523" ; ex:hierarchyID "3.4.2.11" ;
    ex:apqcSourceText "Establishing long term customer sales plans to assess current sales and to determine future sales objectives, strategies for achieving the goals, and available resources." ;
    rdfs:label "Create strategic and tactical sales plans by customer" ;
    skos:definition "An Act of Formulation that establishes long-term strategic and tactical sales plans for individual customers and produces a sales plan." ;
    rdfs:comment "Genus ex:ActOfFormulation: the per-customer sales plan is the directive ex:SalesPlan (per the section vocab mapping of 11523)." ;
    skos:example "An account team builds the multi-year sales plan for a strategic account, with objectives and resources." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesPlan ] .

ex:P11468 a owl:Class ;
    ex:pcfID "11468" ; ex:hierarchyID "3.4.2.12" ;
    ex:apqcSourceText "Sending invitations and distributing information about upcoming events to customer teams and other involved entities." ;
    rdfs:label "Communicate planning information to customer teams" ;
    skos:definition "An Act of Communication that transfers planning information about upcoming events from the organization to customer teams and other involved parties." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): an ICE is transferred from one agent to another. INPUT ICE CORRECTED (Gate-F): the communicated content is the trade-event timetable from 3.4.2.10, now the dedicated ex:TradeMarketingCalendar (formerly the mismatched ex:CommunicationCalendar); it is the act's definitional informational input rather than a newly authored output." ;
    skos:example "A coordinator emails the trade-event calendar and invitations to the customer account teams." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TradeMarketingCalendar ] .

ex:P10131 a owl:Class ;
    ex:pcfID "10131" ; ex:hierarchyID "3.4.3" ;
    ex:apqcSourceText "Setting up a financial plan for the sales function. Calculate the estimated sales revenue and costs, which helps in calculating the overall net profit. Create a sound plan for resource outlay by comparing the forecast with historical data." ;
    rdfs:label "Establish overall sales budgets" ;
    skos:definition "An Act of Formulation that sets up the financial plan for the sales function from estimated revenue, costs, and net profit and produces a sales budget." ;
    rdfs:comment "Genus ex:ActOfFormulation: a budget prescribes resource allocation, so the output is the directive ex:SalesBudget. The cost/revenue/profit calculations are its analytic process parts. The sales forecast (ex:SalesForecast) is the typical input compared against history." ;
    skos:example "Finance and sales jointly set the sales function's annual budget after costing the forecast." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesBudget ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17682 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10143 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10144 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10145 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10146 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10147 ] .

ex:P17682 a owl:Class ;
    ex:pcfID "17682" ; ex:hierarchyID "3.4.3.1" ;
    ex:apqcSourceText "Determining the percentage of total sales volume in the market for a particular product." ;
    rdfs:label "Calculate product market share" ;
    skos:definition "An Act of Analysis that calculates the percentage of total market sales volume held by a particular product and produces a market-share analysis." ;
    rdfs:comment "Genus ex:ActOfAnalysis: a quantitative calculation yielding the descriptive ex:MarketShareAnalysis (per the section vocab mapping of 3.4.3.1)." ;
    skos:example "An analyst computes that a SKU holds 12 percent of its category's unit volume." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MarketShareAnalysis ] .

ex:P10143 a owl:Class ;
    ex:pcfID "10143" ; ex:hierarchyID "3.4.3.2" ;
    ex:apqcSourceText "Estimating revenue from the sale of products/services. Approximate the anticipated sale of products/services and multiply it by the selling price of the respective offering. (This represents the total amount of money that the organization receives from the sale of its portfolio of offerings.)" ;
    rdfs:label "Calculate product revenue" ;
    skos:definition "An Act of Analysis that estimates the revenue from the sale of products and services by multiplying anticipated sales by selling price and produces a revenue estimate." ;
    rdfs:comment "Genus ex:ActOfAnalysis: a descriptive quantitative estimate. Output is ex:RevenueEstimate (minted in shared vocab): revenue is not a cost, so ex:CostAnalysis would be a wrong genus-differentia fit; the sales forecast is the definitional input." ;
    skos:example "Finance multiplies forecast units by list price to estimate next year's product revenue." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesForecast ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RevenueEstimate ] .

ex:P10144 a owl:Class ;
    ex:pcfID "10144" ; ex:hierarchyID "3.4.3.3" ;
    ex:apqcSourceText "Calculating the variable costs of production. Approximate those costs that depend on the volume of products/services produced by the organization." ;
    rdfs:label "Determine variable costs" ;
    skos:definition "An Act of Analysis that calculates the variable production costs that depend on output volume and produces a cost analysis." ;
    rdfs:comment "Genus ex:ActOfAnalysis: descriptive cost calculation yielding ex:CostAnalysis (per the section vocab mapping of 3.4.3.2-.5 cost calculations)." ;
    skos:example "An analyst computes per-unit material and labor cost across the forecast volume." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CostAnalysis ] .

ex:P10145 a owl:Class ;
    ex:pcfID "10145" ; ex:hierarchyID "3.4.3.4" ;
    ex:apqcSourceText "Calculating the overhead costs associated with selling the organization's products/services. Determine fixed costs that are not directly related to the volume of products/services processed or the sale of these offerings (e.g., expense over machinery and equipment)." ;
    rdfs:label "Determine overhead and fixed costs" ;
    skos:definition "An Act of Analysis that calculates the overhead and fixed costs not directly related to output volume and produces a cost analysis." ;
    rdfs:comment "Genus ex:ActOfAnalysis: descriptive fixed-cost calculation yielding ex:CostAnalysis." ;
    skos:example "An analyst totals equipment depreciation and facility overhead allocable to sales." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CostAnalysis ] .

ex:P10146 a owl:Class ;
    ex:pcfID "10146" ; ex:hierarchyID "3.4.3.5" ;
    ex:apqcSourceText "Calculating the net income. Calculate the organization's profitability by accounting for Determine overhead and fixed costs [10145] and Determine variable costs [10144]." ;
    rdfs:label "Calculate net profit" ;
    skos:definition "An Act of Analysis that calculates net income by netting estimated revenue against variable, overhead, and fixed costs and produces a profitability analysis." ;
    rdfs:comment "Genus ex:ActOfAnalysis: descriptive profitability calculation yielding ex:ProfitabilityAnalysis (per the section vocab mapping of 3.4.3.5 net-profit calculation). Definitional inputs are the cost analyses from 3.4.3.3 [10144] and 3.4.3.4 [10145]." ;
    skos:example "Finance derives projected net profit by subtracting all costed items from estimated revenue." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProfitabilityAnalysis ] .

ex:P10147 a owl:Class ;
    ex:pcfID "10147" ; ex:hierarchyID "3.4.3.6" ;
    ex:apqcSourceText "Creating a plan in measurable terms for the financial outlay that best captures resource allocation for the sales forecast. Consider the outlay of capital, HR, raw materials, and provisions needed to reach sales targets." ;
    rdfs:label "Create budget" ;
    skos:definition "An Act of Formulation that creates a measurable financial-outlay plan allocating resources to meet the sales forecast and produces a sales budget." ;
    rdfs:comment "Genus ex:ActOfFormulation: a budget prescribes resource allocation, so the output is the directive ex:SalesBudget (per the section vocab mapping of 3.4.3.6). The profitability analysis (ex:ProfitabilityAnalysis) is the typical input." ;
    skos:example "A manager allocates capital, headcount, and materials into the sales budget to hit targets." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesBudget ] .

ex:P10132 a owl:Class ;
    ex:pcfID "10132" ; ex:hierarchyID "3.4.4" ;
    ex:apqcSourceText "Establishing specific quantitative and qualitative measures of realizing sales targets. Create sales targets by analyzing historical sales data and comparing the forecasts to results, in light of customer and market intelligence. Examine the performance of sales personnel in light of market opportunities. Based on this review, establish sales targets along with metrics to quantify these goals, corresponding with the overall business strategy." ;
    rdfs:label "Establish sales goals and measures" ;
    skos:definition "An Act of Formulation that establishes sales targets and the quantitative and qualitative metrics used to track their realization and produces a sales goal and a performance-measure specification." ;
    rdfs:comment "Genus ex:ActOfFormulation: establishing targets and metrics is a directive output (ex:SalesGoal and ex:PerformanceMeasure; per the section vocab mapping of 3.4.4). 'Establish' here is a bounded act with a clear deliverable, not a standing function. The sales forecast and market intelligence are typical inputs." ;
    skos:example "Sales leadership sets the quarter's revenue targets and the KPI set that quantifies them." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesGoal ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceMeasure ] .

ex:P10133 a owl:Class ;
    ex:pcfID "10133" ; ex:hierarchyID "3.4.5" ;
    ex:apqcSourceText "Identifying the appropriate measures that can represent key attributes of the customer management function. Select measures to track customer activity, feedback, satisfaction, organizational responsiveness to customer needs, and general data on how the organization is managing customer accounts, leads, and contacts. Build on customer and market intelligence to identify metrics gauging aspects related to customer management. Select measures based on the nature of the business, the type and size of customer base, strategic goals, and the model used to structure sales and customer relationships." ;
    rdfs:label "Establish customer management measures" ;
    skos:definition "An Act of Formulation that selects the measures representing key attributes of the customer-management function and produces a customer-management measure specification." ;
    rdfs:comment "Genus ex:ActOfFormulation: selecting/establishing measures prescribes what to track, so the output is the directive ex:CustomerManagementMeasure (per the section vocab mapping of 3.4.5). Customer and market intelligence are typical inputs. Bounded act with a clear deliverable, not a standing function." ;
    skos:example "A CRM lead selects the satisfaction, responsiveness, and account-health metrics to govern customer management." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerManagementMeasure ] .

####################################################################
# 7. PROCESS CLASSES  --  GROUP 3.5  Develop and manage sales plans
#    (PCF 10105). Partonomy via cco:ont00001777. Supporting vocab
#    (ICEs/agents/roles/capabilities) is reused from the shared
#    section-3.0 vocabulary above; only process classes appear here.
#    PCF 11174 'Manage customer relationships' is the standing
#    ex:SalesManagementCapability (R6), not a process.
####################################################################

ex:P10105 a owl:Class ;
    ex:pcfID "10105" ;
    ex:hierarchyID "3.5" ;
    ex:apqcSourceText "Selling products/services. Set appropriate customer expectations. Work with customers using the same schedule that product/service development, production, and customer service functions follow. Manage sales personnel and sales partnerships/alliances." ;
    rdfs:label "Develop and manage sales plans" ;
    skos:definition "A Planned Act in which an organization plans and carries out the selling of its products and services, encompassing lead management, customer and account management, proposal development, sales-order management, and partner and alliance management." ;
    rdfs:comment "Process-group container for PCF 3.5. Its APQC children are process parts (cco:ont00001777), not subclasses. Anchored at cco:ont00000228 (Planned Act) as a heterogeneous aggregate of selling, planning, information-processing, and communication acts." ;
    skos:example "An organization's end-to-end sales operation across a fiscal year." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10182 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10183 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11779 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10185 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10187 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21427 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21428 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21429 ] .

####################################################################
# 6. PROCESS 3.5.1  Manage leads/opportunities  (PCF 10182)
####################################################################

ex:P10182 a owl:Class ;
    ex:pcfID "10182" ; ex:hierarchyID "3.5.1" ;
    ex:apqcSourceText "Generating leads of prospective customers to grow the organization's business. Identify viable customers based on customer and market research. Discover leads through IT applications, cold calling, reference/network development, or other sales and business development techniques. Employ a scoring model qualify the prospective customers into leads, and prioritize them." ;
    rdfs:label "Manage leads/opportunities" ;
    skos:definition "An Act of Selling that generates and qualifies leads of prospective customers and has as output sales leads." ;
    rdfs:comment "Process container. 'Manage' here names the bounded lead-generation-and-qualification cycle (begin: prospecting; end: a prioritized lead set), not a standing function, so it is minted as a process whose APQC children are process parts." ;
    skos:example "A business-development team prospects, scores, and prioritizes a quarter's sales leads." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesLead ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10188 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10189 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18115 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11773 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18116 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20011 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10209 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10184 ] .

ex:P10188 a owl:Class ;
    ex:pcfID "10188" ; ex:hierarchyID "3.5.1.1" ;
    ex:apqcSourceText "Identifying people who can be converted into customers. Leverage personal and professional networks, business research over databases and directories, and secondary research." ;
    rdfs:label "Identify potential customers" ;
    skos:definition "An Act of Identification that has as input customer data and market data and has as output a sales lead about a prospective customer." ;
    skos:example "A rep mines directories and networks to compile a list of viable prospects." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesLead ] .

ex:P10189 a owl:Class ;
    ex:pcfID "10189" ; ex:hierarchyID "3.5.1.2" ;
    ex:apqcSourceText "Qualifying the prospective customers into credible leads by gauging their behavior against the organization's offering. Triangulate leads to increase the efficiency of sales and marketing efforts. Build a detailed profile of the prospects. Determine what products/services they already use, if they have decision-making authority, their views on the products/services they already use, how prone they are to switch, if the organization's solution better in some attributes than those prospects currently use, etc." ;
    rdfs:label "Identify/receive leads/opportunities" ;
    skos:definition "An Act of Analysis that has as input customer data and has as output a sales lead profiling a credible prospect against the organization's offering." ;
    rdfs:comment "Analysis (not selection): the act profiles and qualifies prospects into credible leads, producing a descriptive lead profile rather than committing to a choice." ;
    skos:example "An analyst triangulates prospect behavior and builds a detailed qualified-lead profile." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesLead ] .

ex:P18115 a owl:Class ;
    ex:pcfID "18115" ; ex:hierarchyID "3.5.1.3" ;
    ex:apqcSourceText "Reviewing the set of potential customers and sales opportunities. Approve the leads that meet company requirements on new businesses." ;
    rdfs:label "Validate and qualify leads/opportunities" ;
    skos:definition "An Act of Appraisal that has as input sales leads and has as output an opportunity validation result indicating which leads meet company requirements." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): the act reviews and judges leads against requirements. Output is Descriptive (a validation judgement)." ;
    skos:example "A sales manager reviews the lead set and approves those meeting new-business criteria." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesLead ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OpportunityValidation ] .

ex:P11773 a owl:Class ;
    ex:pcfID "11773" ; ex:hierarchyID "3.5.1.4" ;
    ex:apqcSourceText "Aligning sales leads with business objectives." ;
    rdfs:label "Match opportunities to business strategy" ;
    skos:definition "An Act of Appraisal that has as input sales leads and judges their alignment with an organization's business objectives." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal). Output is a descriptive strategic-fit judgement; modeled in this comment rather than as a someValuesFrom restriction because the source does not make a single named artifact definitional for every instance (Phase-3 necessity rule)." ;
    skos:example "A sales lead is assessed for fit against the firm's strategic objectives before pursuit." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesLead ] .

ex:P18116 a owl:Class ;
    ex:pcfID "18116" ; ex:hierarchyID "3.5.1.5" ;
    ex:apqcSourceText "Creating plans about how to close leads and win sales opportunities." ;
    rdfs:label "Develop opportunity win plans" ;
    skos:definition "An Act of Formulation that has as input sales leads and has as output an opportunity win plan prescribing how to close them." ;
    rdfs:comment "Anchored at ex:ActOfFormulation (Act of Planning): the act composes a Directive ICE (the win plan). GOLDEN PRINCIPLE: planning genus agrees with directive output." ;
    skos:example "A rep drafts a win plan detailing the steps to close a high-value opportunity." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesLead ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OpportunityWinPlan ] .

ex:P20011 a owl:Class ;
    ex:pcfID "20011" ; ex:hierarchyID "3.5.1.6" ;
    ex:apqcSourceText "Overseeing and planning the acquisition of new customers." ;
    rdfs:label "Manage opportunity pipeline" ;
    skos:definition "An Act of Monitoring that has as input sales leads and observes the state of the new-customer-acquisition pipeline against expected progress." ;
    rdfs:comment "Anchored at ex:ActOfMonitoring: the act is a bounded, repeatable observe-and-track of pipeline status. The standing oversight function is realized by ex:SalesManagementCapability; this node models the recurring tracking act itself." ;
    skos:example "A weekly pipeline review tracks each opportunity's stage and forecast." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesLead ] .

ex:P10209 a owl:Class ;
    ex:pcfID "10209" ; ex:hierarchyID "3.5.1.7" ;
    ex:apqcSourceText "Planning the distribution of personnel across various sales functions. Match the capabilities of individual employees with the skill sets needed for specific roles. Seek assistance from HR." ;
    rdfs:label "Determine sales resource allocation" ;
    skos:definition "An Act of Planning that determines and prescribes the distribution of sales personnel across an organization's sales functions." ;
    rdfs:comment "Anchored at cco:ont00000511 (Act of Planning): output is a Directive resource-allocation plan. Modeled in this comment rather than as a restriction because no single named artifact is definitional for every instance (Phase-3 necessity rule)." ;
    skos:example "A sales director plans the assignment of reps to territories and accounts for the year." ;
    rdfs:subClassOf cco:ont00000511 .

####################################################################
# 6a. PROCESS 3.5.1.8  Manage customer sales calls  (PCF 10184)
####################################################################

ex:P10184 a owl:Class ;
    ex:pcfID "10184" ; ex:hierarchyID "3.5.1.8" ;
    ex:apqcSourceText "Managing the entire sales process, from using leads to open sales to closing sales and creating records. Govern all sales activities. Make sales calls based on leads and preparatory work (drafting terms of the sale, creating proposals, suggesting prices, etc.). Close the sale, along with any administrative activities related to data entry and the processing of the sale." ;
    rdfs:label "Manage customer sales calls" ;
    skos:definition "An Act of Selling that has as input sales leads and carries the sales process from opening through closing and recording, and has as output a sales agreement." ;
    rdfs:comment "Process container for the end-to-end sales-call cycle; its APQC tasks are process parts." ;
    skos:example "A rep works a lead through calls, pre-sales, close, and record-keeping." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesLead ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesAgreement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10190 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10191 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20012 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10192 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10193 ] .

ex:P10190 a owl:Class ;
    ex:pcfID "10190" ; ex:hierarchyID "3.5.1.8.1" ;
    ex:apqcSourceText "Communicating with customers and prospects with the intent of creating sales opportunities. Reach out to existing and prospective customers through alternate media and networking channels, apart from cold calling/emailing." ;
    rdfs:label "Perform sales calls" ;
    skos:definition "An Act of Selling in which sales personnel communicate with customers and prospects with the intent of creating sales opportunities." ;
    skos:example "A rep cold-calls and emails prospects to open new opportunities." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SalesPersonnel ] .

ex:P10191 a owl:Class ;
    ex:pcfID "10191" ; ex:hierarchyID "3.5.1.8.2" ;
    ex:apqcSourceText "Capitalizing on sales calls by pitching on bids and closing deals. Outline the nature and scope of the work, draft agreement terms, prepare proposals and agreements, and propose timelines and prices." ;
    rdfs:label "Perform pre-sales activities" ;
    skos:definition "An Act of Formulation that prepares the terms, scope, and pricing of a deal and has as output a sales proposal." ;
    rdfs:comment "RE-ANCHORED (Gate-F): the output ex:SalesProposal is a DIRECTIVE ICE (cco:ont00000965), but the prior genus ex:ActOfSelling is a transactional Planned Act (transfer of a good/service for a Financial Instrument) that carries no directive-output requirement -- a GOLDEN PRINCIPLE / false-friend violation ('sales' context misread as a sale transaction). Drafting scope/terms/pricing and assembling a proposal is authoring a Directive ICE, i.e. an Act of Formulation. Re-anchored to ex:ActOfFormulation, matching the sibling proposal-authoring rows P20015 (develop solution/delivery approach) and P20018 (revise bid/proposal). The directive output drives the Formulation genus (GOLDEN PRINCIPLE)." ;
    skos:example "A rep drafts scope, timeline, and price and assembles a proposal for a prospect." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesProposal ] .

ex:P20012 a owl:Class ;
    ex:pcfID "20012" ; ex:hierarchyID "3.5.1.8.3" ;
    ex:apqcSourceText "Arranging and leading meetings, seminars, workshops and training events with customers to educate them about current offerings, best practices and technological advances to provide more value to customers and to increase their attrition and loyalty." ;
    rdfs:label "Manage customer meetings/workshops" ;
    skos:definition "An Act of Communication in which sales personnel arrange and lead meetings, seminars, or workshops to educate customers about an organization's offerings." ;
    rdfs:comment "RE-ANCHORED (Gate-F): the prior genus ex:ActOfSelling (transfer of a good/service for a Financial Instrument) is a false friend -- the source describes arranging/leading meetings, seminars, workshops to EDUCATE customers, an educational/information-transfer act, not a sale transaction. Re-anchored to cco:ont00000402 (Act of Communication) plus cco:ont00000228 (Planned Act), mirroring the parallel partner-education rows P10211 and P20019 (sibling consistency between customer-education and partner-education acts). Retains the ex:SalesPersonnel participant." ;
    skos:example "A team runs a customer workshop showcasing new product capabilities." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SalesPersonnel ] .

ex:P10192 a owl:Class ;
    ex:pcfID "10192" ; ex:hierarchyID "3.5.1.8.4" ;
    ex:apqcSourceText "Formalizing a sale by reaching an agreement on terms of the deal. Negotiate on the price, and reach a consensus on the terms and conditions." ;
    rdfs:label "Close the sale" ;
    skos:definition "An Act of Selling that formalizes a sale by negotiating and reaching a sales agreement on the terms of the deal." ;
    skos:example "A rep negotiates final price and terms and the customer signs the agreement." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesAgreement ] .

ex:P10193 a owl:Class ;
    ex:pcfID "10193" ; ex:hierarchyID "3.5.1.8.5" ;
    ex:apqcSourceText "Completing all the paper-work associated with the sale of its products/services. Exchange any pertinent legal/financial information required for completing the sale, signing of a contract/work-order, and issuing copies of bills/invoices." ;
    rdfs:label "Record outcome of sales process" ;
    skos:definition "An Act of Information Processing that records the completed sale by capturing its legal and financial documentation and has as output a sales order." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): the act stores and registers sale documentation (contracts, invoices)." ;
    skos:example "After close, the back office files the contract and issues the invoice and order record." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesOrder ] .

####################################################################
# 7. PROCESS 3.5.2  Manage customers and accounts  (PCF 10183)
####################################################################

ex:P10183 a owl:Class ;
    ex:pcfID "10183" ; ex:hierarchyID "3.5.2" ;
    ex:apqcSourceText "Managing the customer's expectations, with the intent of responsibly increasing the sale of the organization's products/services. Create a systematic method for governing sales, using sales forecasts and customer management measures. Develop a blueprint to manage relationships with customers and the data it holds on them, as well as the sale of its products/services to these customers. Devise a recipe for handling the organization's key customers in order to manage their expectations with tact and responsibility while maximizing revenue." ;
    rdfs:label "Manage customers and accounts" ;
    skos:definition "An Act of Selling that governs an organization's selling to its customers and the management of their accounts, encompassing key-account selection, account planning, and master-data management." ;
    rdfs:comment "Process container for the customer-and-account-management cycle; its APQC children are process parts. The purely standing relationship-management function (3.5.2.4) is split out as an Organization Capability (R6), not a process part." ;
    skos:example "An account team's quarterly cycle of selecting, planning, and servicing key accounts." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20013 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11173 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20014 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14208 ] .

ex:P20013 a owl:Class ;
    ex:pcfID "20013" ; ex:hierarchyID "3.5.2.1" ;
    ex:apqcSourceText "Choosing principal clients that are vital for the company." ;
    rdfs:label "Select key customers/accounts" ;
    skos:definition "An Act of Selection that has as input customer data and chooses, from among an organization's customers, the principal accounts to prioritize." ;
    rdfs:comment "Anchored at ex:ActOfSelection: chooses from a candidate set and yields a directive designation. The chosen-account designation is a Directive ICE; modeled in this comment because no single named artifact is definitional for every instance (Phase-3)." ;
    skos:example "A sales VP designates the top twenty accounts as key for the year." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] .

ex:P11173 a owl:Class ;
    ex:pcfID "11173" ; ex:hierarchyID "3.5.2.2" ;
    ex:apqcSourceText "Creating a plan for managing the accounts of key customers in order to better maintain relationships with them. Chart a scheme for managing sales. Create a plan for administering accounts of the significant and most important customers of the organization. Coordinate the accounts of principal clients." ;
    rdfs:label "Develop sales/key account plan" ;
    skos:definition "An Act of Formulation that has as input customer data and has as output a sales plan for managing the accounts of key customers." ;
    rdfs:comment "Anchored at ex:ActOfFormulation: composes a Directive ICE (the account plan). GOLDEN PRINCIPLE: planning genus agrees with directive output." ;
    skos:example "An account manager drafts the annual key-account plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesPlan ] .

ex:P20014 a owl:Class ;
    ex:pcfID "20014" ; ex:hierarchyID "3.5.2.3" ;
    ex:apqcSourceText "Handling the accounts of important clients." ;
    rdfs:label "Manage sales/key account plan" ;
    skos:definition "An Act of Monitoring that executes and tracks a key-account plan against its expected outcomes." ;
    rdfs:comment "Anchored at ex:ActOfMonitoring: a bounded, repeatable act of carrying out and tracking the account plan (begin: plan in force; end: review-period close). The standing account-governance function is realized by ex:SalesManagementCapability." ;
    skos:example "An account manager runs the quarter's key-account plan and tracks progress." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesPlan ] .

ex:P14208 a owl:Class ;
    ex:pcfID "14208" ; ex:hierarchyID "3.5.2.5" ;
    ex:apqcSourceText "Managing the corpus of data relating all customers acquired over time. Manage the storage, maintenance, access, revision, and usage of all data on customers. Ensure its security, and determine legitimate use cases that are beneficial to the organization." ;
    rdfs:label "Manage customer master data" ;
    skos:definition "An Act of Information Processing that maintains an organization's corpus of customer data and has as output customer master data." ;
    rdfs:comment "Process container. Though phrased 'Manage', APQC decomposes it into concrete bounded information-processing tasks (collect/merge, de-duplicate); modeled as a process whose tasks are process parts." ;
    skos:example "A data team consolidates and cleanses the customer master record set." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16598 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16599 ] .

ex:P16598 a owl:Class ;
    ex:pcfID "16598" ; ex:hierarchyID "3.5.2.5.1" ;
    ex:apqcSourceText "Gathering the data about customers. Combine the information available locally with the data obtained from external sources." ;
    rdfs:label "Collect and merge internal and third-party customer information" ;
    skos:definition "An Act of Information Processing that has as input customer data and has as output customer master data combining internal and third-party sources." ;
    skos:example "A pipeline merges CRM records with purchased third-party customer data." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] .

ex:P16599 a owl:Class ;
    ex:pcfID "16599" ; ex:hierarchyID "3.5.2.5.2" ;
    ex:apqcSourceText "Eliminating redundant information in customer data." ;
    rdfs:label "De-duplicate customer data" ;
    skos:definition "An Act of Information Processing that has as input customer data and has as output customer master data with redundant records eliminated." ;
    skos:example "A matching job collapses duplicate customer records into golden records." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] .

# --- 3.5.2.4 (PCF 11174) Manage customer relationships : CAPABILITY (R6) ---
# Standing function, no natural end; modeled as Organization Capability,
# realized in the customer-relationship-management acts. See
# ex:SalesManagementCapability above. No ex:P11174 process is minted.

####################################################################
# 8. PROCESS 3.5.3  Develop and manage sales proposals, bids, quotes
#    (PCF 11779)
####################################################################

ex:P11779 a owl:Class ;
    ex:pcfID "11779" ; ex:hierarchyID "3.5.3" ;
    ex:apqcSourceText "Understanding and refining the customer requirements as provided in a RFP (Request for Proposal) or RFI (Request for Information).  When compiling the response, they must take into consideration whether the requirements are a match with the strategic or tactical plans of the organization and whether they are able to submit a bid/proposal that is competitive based on an understanding of the offerings of other competing organizations. The next step will be to define the pricing and scheduling of the proposed solution and determine whether the proposal will be profitable for the company if accepted. The bid is then submitted and a notification of whether or not it was successful is received." ;
    rdfs:label "Develop and manage sales proposals, bids, and quotes" ;
    skos:definition "An Act of Selling that has as input a request for proposal and produces and submits a sales proposal in response, encompassing requirement refinement, competitive and profitability analysis, pricing, and bid submission." ;
    rdfs:comment "Process container for the RFP-to-notification proposal lifecycle; its APQC children are process parts." ;
    skos:example "A bid team responds to an RFP from requirement refinement through submission and outcome." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RequestForProposal ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesProposal ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11781 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11780 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11782 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11783 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11784 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11785 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20015 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11787 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11788 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11789 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20016 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20017 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11790 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20018 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11793 ] .

ex:P11781 a owl:Class ;
    ex:pcfID "11781" ; ex:hierarchyID "3.5.3.1" ;
    ex:apqcSourceText "Accepting procurement proposals." ;
    rdfs:label "Receive Request For Proposal (RFP)/Request For Quote (RFQ)" ;
    skos:definition "An Act of Communication in which an organization receives a request for proposal transferred from a prospective customer." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): an ICE (the RFP) is transferred from one agent to another." ;
    skos:example "A bid desk logs an incoming RFP from a prospective client." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RequestForProposal ] .

ex:P11780 a owl:Class ;
    ex:pcfID "11780" ; ex:hierarchyID "3.5.3.2" ;
    ex:apqcSourceText "Clarifying the details about procurement requests, such as the scope, timeline, data sources, type and characteristics and evaluation criteria for the goods or services to be delivered, and any additional terms, conditions or special requirements." ;
    rdfs:label "Refine customer requirements" ;
    skos:definition "An Act of Information Processing that has as input a request for proposal and clarifies and elaborates the customer's stated requirements." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): the act manipulates the requirement ICE into a clarified form. The refined-requirements artifact is typical but not definitional for every instance (Phase-3), so it is left to this comment." ;
    skos:example "A solution architect clarifies scope, timeline, and evaluation criteria with the customer." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RequestForProposal ] .

ex:P11782 a owl:Class ;
    ex:pcfID "11782" ; ex:hierarchyID "3.5.3.3" ;
    ex:apqcSourceText "Evaluating individual price and delivery solicitations for their strengths and weaknesses. Analyze how closely the submitted bids respond to the requirements outlined in the RFPs." ;
    rdfs:label "Review RFP/RFQ request" ;
    skos:definition "An Act of Appraisal that has as input a request for proposal and judges the strengths and weaknesses of price and delivery solicitations against its requirements." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): the act evaluates and judges solicitations." ;
    skos:example "An analyst scores how well candidate solutions answer the RFP requirements." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RequestForProposal ] .

ex:P11783 a owl:Class ;
    ex:pcfID "11783" ; ex:hierarchyID "3.5.3.4" ;
    ex:apqcSourceText "Comparing the proposals submitted by different bidders in terms of cost, efficiency and value." ;
    rdfs:label "Perform competitive analysis" ;
    skos:definition "An Act of Analysis that has as input market data and has as output a competitive analysis comparing competing bids on cost, efficiency, and value." ;
    rdfs:comment "Reuses ex:CompetitiveAnalysis (Descriptive ICE, is about CompetingOrganization). GOLDEN PRINCIPLE: analysis genus agrees with descriptive output." ;
    skos:example "A bid team benchmarks rival proposals on price and value." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetitiveAnalysis ] .

ex:P11784 a owl:Class ;
    ex:pcfID "11784" ; ex:hierarchyID "3.5.3.5" ;
    ex:apqcSourceText "Assessing the business strategy, forecasted performance, financing and cash flow of the proposals." ;
    rdfs:label "Validate with strategy/business plans" ;
    skos:definition "An Act of Appraisal that judges a proposal's fit with an organization's business strategy, forecasted performance, financing, and cash flow." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal). Output is a descriptive strategic-fit judgement; left to comment per Phase-3 necessity." ;
    skos:example "A finance lead checks a bid against the firm's strategy and cash-flow plan." ;
    rdfs:subClassOf cco:ont00000636 .

ex:P11785 a owl:Class ;
    ex:pcfID "11785" ; ex:hierarchyID "3.5.3.6" ;
    ex:apqcSourceText "Deepening knowledge about the customer's field of operation and business needs." ;
    rdfs:label "Understand customer business and requirements" ;
    skos:definition "An Act of Analysis that has as input customer data and has as output a customer insight describing the customer's field of operation and business needs." ;
    rdfs:comment "GOLDEN PRINCIPLE: analysis genus agrees with descriptive output (ex:CustomerInsight, is about Customer)." ;
    skos:example "A pre-sales consultant researches the customer's industry and pain points." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerInsight ] .

ex:P20015 a owl:Class ;
    ex:pcfID "20015" ; ex:hierarchyID "3.5.3.7" ;
    ex:apqcSourceText "Creating a plan with detailed steps about how produce and deliver the goods or services." ;
    rdfs:label "Develop solution and delivery approach" ;
    skos:definition "An Act of Formulation that has as output an execution roadmap prescribing the detailed steps to produce and deliver a proposed solution." ;
    rdfs:comment "Anchored at ex:ActOfFormulation: composes a Directive ICE (the delivery roadmap). GOLDEN PRINCIPLE satisfied." ;
    skos:example "A delivery lead drafts the implementation roadmap for the proposed solution." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExecutionRoadmap ] .

ex:P11787 a owl:Class ;
    ex:pcfID "11787" ; ex:hierarchyID "3.5.3.8" ;
    ex:apqcSourceText "Determining the needs for internal resources and vacancies." ;
    rdfs:label "Identify staffing requirements" ;
    skos:definition "An Act of Identification that discerns and registers the internal resource and staffing needs for delivering a proposed solution." ;
    rdfs:comment "Anchored at ex:ActOfIdentification (discernment sense). The staffing-requirements register is typical but not definitional for every instance (Phase-3), so it is left to this comment." ;
    skos:example "A resourcing manager lists the roles and headcount a bid would require." ;
    rdfs:subClassOf ex:ActOfIdentification .

ex:P11788 a owl:Class ;
    ex:pcfID "11788" ; ex:hierarchyID "3.5.3.9" ;
    ex:apqcSourceText "Establishing predicted delivery costs, fees and timelines." ;
    rdfs:label "Develop pricing and scheduling estimates" ;
    skos:definition "An Act of Appraisal that has as input cost data and has as output a pricing analysis estimating delivery costs, fees, and timelines." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): estimating value/cost is appraisal. GOLDEN PRINCIPLE: appraisal genus agrees with descriptive output (ex:PricingAnalysis). Rejected ex:ActOfForecasting because the act values a proposed solution rather than projecting a future market state." ;
    skos:example "A cost engineer estimates the price and schedule for the proposed scope." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PricingAnalysis ] .

ex:P11789 a owl:Class ;
    ex:pcfID "11789" ; ex:hierarchyID "3.5.3.10" ;
    ex:apqcSourceText "Reviewing profitability data. Analyze systematically all relevant metrics and parameters. Report findings and make recommendations for changes to operational strategies." ;
    rdfs:label "Conduct profitability analysis" ;
    skos:definition "An Act of Analysis that has as input cost data and has as output a profitability analysis of a proposed engagement." ;
    rdfs:comment "GOLDEN PRINCIPLE: analysis genus agrees with descriptive output (ex:ProfitabilityAnalysis)." ;
    skos:example "A pricing analyst reports the projected margin on a bid." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CostData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProfitabilityAnalysis ] .

ex:P20016 a owl:Class ;
    ex:pcfID "20016" ; ex:hierarchyID "3.5.3.11" ;
    ex:apqcSourceText "Overseeing the internal review process." ;
    rdfs:label "Manage internal reviews" ;
    skos:definition "An Act of Monitoring that observes and tracks the internal review of a proposal against its expected completion." ;
    rdfs:comment "Anchored at ex:ActOfMonitoring: a bounded act of tracking the review process (begin: review initiated; end: review concluded)." ;
    skos:example "A bid manager tracks each reviewer's sign-off on the draft proposal." ;
    rdfs:subClassOf ex:ActOfMonitoring .

ex:P20017 a owl:Class ;
    ex:pcfID "20017" ; ex:hierarchyID "3.5.3.12" ;
    ex:apqcSourceText "Obtaining required company-internal authorizations." ;
    rdfs:label "Manage internal approvals" ;
    skos:definition "An Act of Acquisition in which an organization obtains the internal authorizations required to submit a proposal." ;
    rdfs:comment "Anchored at ex:ActOfAcquisition (Planned Act): the act obtains an authorization the team did not previously hold. The approval ICE is obtained rather than authored here, so it is not modeled as a has-output restriction." ;
    skos:example "A bid lead secures pricing and legal sign-off before submission." ;
    rdfs:subClassOf ex:ActOfAcquisition .

ex:P11790 a owl:Class ;
    ex:pcfID "11790" ; ex:hierarchyID "3.5.3.13" ;
    ex:apqcSourceText "Delivering the proposal to the potential client." ;
    rdfs:label "Submit/present bid/proposal/quote to customer" ;
    skos:definition "An Act of Communication in which an organization transfers a sales proposal to a prospective customer." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): the proposal ICE is transferred to the customer." ;
    skos:example "A rep presents the finished bid to the client." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesProposal ] .

ex:P20018 a owl:Class ;
    ex:pcfID "20018" ; ex:hierarchyID "3.5.3.14" ;
    ex:apqcSourceText "Amending bids, proposals or quotes with more accurate time, cost or delivery estimates." ;
    rdfs:label "Revise bid/proposal/quote" ;
    skos:definition "An Act of Formulation that has as input a sales proposal and has as output a revised sales proposal with more accurate time, cost, or delivery estimates." ;
    rdfs:comment "Anchored at ex:ActOfFormulation: re-composes the Directive proposal ICE. GOLDEN PRINCIPLE satisfied." ;
    skos:example "A bid team reissues the proposal with corrected pricing." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesProposal ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesProposal ] .

ex:P11793 a owl:Class ;
    ex:pcfID "11793" ; ex:hierarchyID "3.5.3.15" ;
    ex:apqcSourceText "Handling proposals depending on whether they were accepted or rejected." ;
    rdfs:label "Manage notification outcome" ;
    skos:definition "An Act of Information Processing that receives the acceptance or rejection notification for a submitted proposal and registers and routes the proposal for the corresponding handling." ;
    rdfs:comment "RE-ANCHORED (Gate-F): the prior genus ex:ActOfMonitoring requires repeated/continuous observation of a process state over time, but the source ('Handling proposals depending on whether they were accepted or rejected') is a one-shot receive-a-notification-and-route event -- a discrete information-processing / decision-routing act, not ongoing tracking. Re-anchored to cco:ont00000366 (Act of Information Processing), which receives the outcome notification and registers/routes the proposal. Retains the ex:SalesProposal input." ;
    skos:example "A bid desk records an award notification and opens the contracting step." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesProposal ] .

####################################################################
# 9. PROCESS 3.5.4  Manage sales orders  (PCF 10185)
####################################################################

ex:P10185 a owl:Class ;
    ex:pcfID "10185" ; ex:hierarchyID "3.5.4" ;
    ex:apqcSourceText "Taking, receiving, processing, and acknowledging new customer orders or amendments to outstanding customer orders. Monitoring status from order receipt to customer delivery/customer invoicing." ;
    rdfs:label "Manage sales orders" ;
    skos:definition "An Act of Selling that has as input sales order data and processes customer orders from receipt through fulfillment and invoicing, and has as output sales orders." ;
    rdfs:comment "Process container for the order-management cycle; its APQC children are process parts." ;
    skos:example "An order desk takes, validates, and tracks a customer order to delivery." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesOrderData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesOrder ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10194 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10195 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10196 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10197 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10199 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10200 ] .

ex:P10194 a owl:Class ;
    ex:pcfID "10194" ; ex:hierarchyID "3.5.4.1" ;
    ex:apqcSourceText "Receiving and confirming orders from customers. Verify that no extra expenses have to be disbursed on part of the organization for labor or inventory when processing the order." ;
    rdfs:label "Accept and validate sales orders" ;
    skos:definition "An Act of Information Processing that has as input sales order data and has as output a confirmed sales order." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): the act receives and validates the order data, yielding a confirmed Directive sales order." ;
    skos:example "An order clerk confirms a customer order after checking it for hidden costs." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesOrderData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesOrder ] .

ex:P10195 a owl:Class ;
    ex:pcfID "10195" ; ex:hierarchyID "3.5.4.2" ;
    ex:apqcSourceText "Collecting and maintaining all account information. Collect information about the purchase, servicing, return, and/or commitment of any products/services on part of the organization to its customers. Bring together information from various organizational divisions, and update periodically." ;
    rdfs:label "Collect and maintain account information" ;
    skos:definition "An Act of Information Processing that collects and maintains customer account information and has as output customer master data." ;
    rdfs:comment "Process container for the account-information tasks; its APQC tasks are process parts." ;
    skos:example "An order team consolidates purchase, service, and return history per account." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10201 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10202 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10203 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10204 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10205 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10206 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10207 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10208 ] .

ex:P10201 a owl:Class ;
    ex:pcfID "10201" ; ex:hierarchyID "3.5.4.2.1" ;
    ex:apqcSourceText "Managing essential information of customer accounts." ;
    rdfs:label "Administer key account details" ;
    skos:definition "An Act of Information Processing that maintains the essential information of customer accounts and has as output customer master data." ;
    skos:example "An admin updates the master record for a key account." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] .

ex:P10202 a owl:Class ;
    ex:pcfID "10202" ; ex:hierarchyID "3.5.4.2.2" ;
    ex:apqcSourceText "Obtaining detailed information about customers." ;
    rdfs:label "Retrieve full customer details" ;
    skos:definition "An Act of Information Processing that has as input customer master data and retrieves the detailed information held about a customer." ;
    skos:example "An agent pulls a customer's full account profile for servicing." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerMasterData ] .

ex:P10203 a owl:Class ;
    ex:pcfID "10203" ; ex:hierarchyID "3.5.4.2.3" ;
    ex:apqcSourceText "Altering information about involved parties." ;
    rdfs:label "Modify involved party details" ;
    skos:definition "An Act of Information Processing that revises the recorded information about parties involved in a customer account." ;
    skos:example "An agent updates a contact's role on an account." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] .

ex:P10204 a owl:Class ;
    ex:pcfID "10204" ; ex:hierarchyID "3.5.4.2.4" ;
    ex:apqcSourceText "Documenting address information." ;
    rdfs:label "Record address details" ;
    skos:definition "An Act of Information Processing that records the address information of a customer or involved party." ;
    skos:example "An agent records a new shipping address on the account." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] .

ex:P10205 a owl:Class ;
    ex:pcfID "10205" ; ex:hierarchyID "3.5.4.2.5" ;
    ex:apqcSourceText "Documenting contact information." ;
    rdfs:label "Record contact details" ;
    skos:definition "An Act of Information Processing that records the contact information of a customer or involved party." ;
    skos:example "An agent records a contact's phone and email on the account." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] .

ex:P10206 a owl:Class ;
    ex:pcfID "10206" ; ex:hierarchyID "3.5.4.2.6" ;
    ex:apqcSourceText "Providing information about important business rules regarding communicating with customers." ;
    rdfs:label "Record key customer communication profile details" ;
    skos:definition "An Act of Information Processing that records the communication-profile information and preferences governing contact with a customer." ;
    skos:example "An agent records a customer's opt-out and preferred-channel rules." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] .

ex:P10207 a owl:Class ;
    ex:pcfID "10207" ; ex:hierarchyID "3.5.4.2.7" ;
    ex:apqcSourceText "Revising information about involved parties." ;
    rdfs:label "Review involved party information" ;
    skos:definition "An Act of Information Processing that has as input customer master data and reviews the recorded information about involved parties." ;
    skos:example "An agent reviews the parties listed on an account for accuracy." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerMasterData ] .

ex:P10208 a owl:Class ;
    ex:pcfID "10208" ; ex:hierarchyID "3.5.4.2.8" ;
    ex:apqcSourceText "Dismissing information about involved parties." ;
    rdfs:label "Terminate involved party information" ;
    skos:definition "An Act of Information Processing that deactivates or removes the recorded information about an involved party from a customer account." ;
    skos:example "An agent retires a departed contact from the account record." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerMasterData ] .

ex:P10196 a owl:Class ;
    ex:pcfID "10196" ; ex:hierarchyID "3.5.4.3" ;
    ex:apqcSourceText "Ascertaining the volume or scale of products/services to provide to customers to fulfill sales orders. Check the finished products stored in warehouses, the production capacity, and (in the case of services) the processing speed, as well as work force availability." ;
    rdfs:label "Determine availability" ;
    skos:definition "An Act of Appraisal that has as input sales order data and judges the availability of products, services, capacity, and workforce to fulfill an order." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal): the act assesses available supply against order demand. The availability judgement is descriptive; left to comment per Phase-3 necessity." ;
    skos:example "An order planner checks stock and capacity before confirming a delivery date." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesOrderData ] .

ex:P10197 a owl:Class ;
    ex:pcfID "10197" ; ex:hierarchyID "3.5.4.4" ;
    ex:apqcSourceText "Devising a blueprint for order fulfillment. Create a schematic flow encompassing all activities to deliver orders to the customers. Outline a procedure for satisfying these orders by answering questions about what needs to happen in sequence to realize an order." ;
    rdfs:label "Determine fulfillment process" ;
    skos:definition "An Act of Formulation that has as output an order fulfillment plan prescribing the sequence of activities to deliver a customer's order." ;
    rdfs:comment "Anchored at ex:ActOfFormulation: composes a Directive ICE (the fulfillment plan). GOLDEN PRINCIPLE satisfied." ;
    skos:example "An operations planner drafts the fulfillment workflow for an order type." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FulfillmentPlan ] .

ex:P10199 a owl:Class ;
    ex:pcfID "10199" ; ex:hierarchyID "3.5.4.5" ;
    ex:apqcSourceText "Processing any unfulfilled orders, and updating the status of any orders that have been accepted and are being attended to. Deliver on any purchase orders that remain unserviced due to temporary unavailability of the product/service. Manage any updates to the sales orders. Revise their status in the order system." ;
    rdfs:label "Process back orders and updates" ;
    skos:definition "An Act of Information Processing that has as input sales order data and updates the status of back-ordered and in-progress sales orders." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): the act revises order-status data in the order system." ;
    skos:example "A clerk re-queues a back-ordered line and updates its status." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesOrderData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesOrder ] .

ex:P10200 a owl:Class ;
    ex:pcfID "10200" ; ex:hierarchyID "3.5.4.6" ;
    ex:apqcSourceText "Attending to any queries received from the customers, even after a sales order has been serviced. Deploy ad hoc personnel for managing these enquiries." ;
    rdfs:label "Handle sales order inquiries including post-order fulfillment transactions" ;
    skos:definition "An Act of Communication in which personnel respond to customer inquiries about a sales order, including after fulfillment." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): the act transfers information between the customer and the organization in response to a query." ;
    skos:example "Support answers a customer's question about a delivered order." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SalesOrderData ] .

####################################################################
# 10. PROCESS 3.5.5  Manage sales partners and alliances  (PCF 10187)
####################################################################

ex:P10187 a owl:Class ;
    ex:pcfID "10187" ; ex:hierarchyID "3.5.5" ;
    ex:apqcSourceText "Managing the organization's partners and alliances, with the objective of maximizing revenue. Train partners regarding the organization's portfolio of products/services. Craft sales forecasts. Examine their performance. Manage all data held by the organization on these partners." ;
    rdfs:label "Manage sales partners and alliances" ;
    skos:definition "An Act of Selling that develops and governs an organization's sales partners and alliances, encompassing partner training, performance evaluation, and partner master-data management." ;
    rdfs:comment "Process container for the partner-management cycle; its APQC children are process parts." ;
    skos:example "A channel team trains, equips, evaluates, and records its sales partners over a period." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10211 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18641 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10214 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14209 ] .

ex:P10211 a owl:Class ;
    ex:pcfID "10211" ; ex:hierarchyID "3.5.5.1" ;
    ex:apqcSourceText "Imparting guidance and instruction to sales partners/alliances concerning products/services. Distribute literature about the organization's products/services. Conduct workshops. Disseminate useful media content to engage and enlighten partners. Create communities through group engagements." ;
    rdfs:label "Provide sales and product/service training to sales partners/alliances" ;
    skos:definition "An Act of Communication that transfers sales training material about an organization's products and services to its sales partners and alliances." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): training material (an ICE) is transferred to partners. Process container; its APQC tasks are process parts." ;
    skos:example "A partner-enablement team runs product workshops for resellers." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesTrainingMaterial ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SalesPartner ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20019 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20020 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20021 ] .

ex:P20019 a owl:Class ;
    ex:pcfID "20019" ; ex:hierarchyID "3.5.5.1.1" ;
    ex:apqcSourceText "Provide training and certification to develop strategies for marketing-driven sales." ;
    rdfs:label "Provide certification enablement training" ;
    skos:definition "An Act of Communication that delivers certification-enablement training to sales partners and has as output sales training material." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): instructional content is transferred to partners." ;
    skos:example "A vendor certifies partner reps on a product line." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesTrainingMaterial ] .

ex:P20020 a owl:Class ;
    ex:pcfID "20020" ; ex:hierarchyID "3.5.5.1.2" ;
    ex:apqcSourceText "Reviewing, processing and issuing certifications and accrediting skills and competencies." ;
    rdfs:label "Manage certifications and skills" ;
    skos:definition "An Act of Information Processing that reviews, processes, and issues partner certifications and accredits skills and competencies." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): the act records and issues certification information." ;
    skos:example "A program office issues a renewed certification to a partner engineer." ;
    rdfs:subClassOf cco:ont00000366 .

ex:P20021 a owl:Class ;
    ex:pcfID "20021" ; ex:hierarchyID "3.5.5.1.3" ;
    ex:apqcSourceText "Backing sales partners and strategic alliances." ;
    rdfs:label "Provide support to partners/alliances" ;
    skos:definition "An Act of Communication in which an organization provides support to its sales partners and strategic alliances." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): the act transfers assistance and information to partners." ;
    skos:example "A partner desk resolves a reseller's deal-registration issue." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SalesPartner ] .

ex:P18641 a owl:Class ;
    ex:pcfID "18641" ; ex:hierarchyID "3.5.5.2" ;
    ex:apqcSourceText "Distributing marketing materials and sales brochures to entities that the company partners with." ;
    rdfs:label "Provide marketing materials to sales partners/alliances" ;
    skos:definition "An Act of Communication that distributes marketing materials and sales brochures to an organization's sales partners and alliances." ;
    rdfs:comment "Anchored at cco:ont00000402 (Act of Communication): marketing-material ICEs are transferred to partners. The distributed-collateral artifact is typical but not definitional for every instance (Phase-3)." ;
    skos:example "A channel team ships co-branded brochures to a reseller." ;
    rdfs:subClassOf cco:ont00000402 , cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SalesPartner ] .

ex:P10214 a owl:Class ;
    ex:pcfID "10214" ; ex:hierarchyID "3.5.5.3" ;
    ex:apqcSourceText "Examining the performance of its partners/alliances in selling its products/services. Use metrics such as growth in revenue generated, conversion rate, and total outreach to customers for assessing the performance results." ;
    rdfs:label "Evaluate partner/alliance results" ;
    skos:definition "An Act of Appraisal that judges the selling performance of an organization's sales partners and has as output a partner/alliance evaluation." ;
    rdfs:comment "Anchored at cco:ont00000636 (Act of Appraisal). GOLDEN PRINCIPLE: appraisal genus agrees with descriptive output (ex:PartnerEvaluation, is about SalesPartner)." ;
    skos:example "A channel manager scores each reseller on revenue growth and conversion." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PartnerEvaluation ] .

ex:P14209 a owl:Class ;
    ex:pcfID "14209" ; ex:hierarchyID "3.5.5.4" ;
    ex:apqcSourceText "Managing the repository of data relating to the organization's partners/alliances over time. Store, maintain, access, revise, and use all data on partners/alliances. Manage data. Ensure its security. Determine legitimate use cases that are beneficial to the organization." ;
    rdfs:label "Manage sales partner/alliance master data" ;
    skos:definition "An Act of Information Processing that maintains an organization's repository of sales partner and alliance data and has as output partner/alliance master data." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): the act stores, maintains, and revises partner data. Modeled as a process (not a capability) because it names a bounded, repeatable data-maintenance act." ;
    skos:example "A data steward updates and secures the partner master records." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PartnerMasterData ] .

####################################################################
# 11. PROCESSES 3.5.6 - 3.5.8  Sales execution channels
####################################################################

ex:P21427 a owl:Class ;
    ex:pcfID "21427" ; ex:hierarchyID "3.5.6" ;
    ex:apqcSourceText "Execution of sales at physical / brick and mortar locations." ;
    rdfs:label "Perform sales at physical outlets" ;
    skos:definition "An Act of Selling that executes sales of an organization's products or services at physical, brick-and-mortar locations." ;
    skos:example "A retail associate completes a sale at a store checkout." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesOrder ] .

ex:P21428 a owl:Class ;
    ex:pcfID "21428" ; ex:hierarchyID "3.5.7" ;
    ex:apqcSourceText "Execution of sales within field/remote locations.  This could be any location that is not part of a headquarters location." ;
    rdfs:label "Perform field sales" ;
    skos:definition "An Act of Selling that executes sales of an organization's products or services at field or remote locations away from a headquarters." ;
    skos:example "A field rep closes a sale at a customer's site." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesOrder ] .

ex:P21429 a owl:Class ;
    ex:pcfID "21429" ; ex:hierarchyID "3.5.8" ;
    ex:apqcSourceText "Execution of sales in an online environment." ;
    rdfs:label "Perform digital sales" ;
    skos:definition "An Act of Selling that executes sales of an organization's products or services in an online environment." ;
    skos:example "A customer completes a purchase through the organization's e-commerce site." ;
    rdfs:subClassOf ex:ActOfSelling ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SalesOrder ] .

