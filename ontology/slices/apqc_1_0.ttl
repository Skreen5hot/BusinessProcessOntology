@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC SECTION 1.0 -> BFO 2020 / CCO  REALITY-LAYER MODULE
# Category 1.0 "Develop Vision and Strategy" (groups 1.1 - 1.4)
#
# Assembled from the four process-group slices (1.1, 1.2, 1.3, 1.4)
# into ONE coherent module. House style mirrors the GOLD reference
# module ontology/slices/apqc_1_1_1.ttl. Every cco:ont... IRI below
# was verified (label + definition + parent) against
# vendor/cco/CommonCoreOntologiesMerged.ttl (CCO v2.0, 2024-11-06).
#
# IRI scheme (D7): reality-layer process class = ex:P<pcfID>;
# catalog node = ex:PCF_<pcfID>; supporting classes = readable ex:
# CamelCase with NO pcf ids.
#
# RECONCILIATION (collisions across the four group slices):
#  * One prefix block, one owl:Ontology header, one set of annotation
#    properties.
#  * Act genera (ex:ActOfAnalysis / Identification / Formulation /
#    Selection / Acquisition) are INLINED below as the canonical
#    definitions from the apqc-ext.ttl registry, so this module is
#    self-contained (validates against CCO with no extension merge).
#    ex:ActOfSelection is anchored under cco:ont00000366 (Act of
#    Information Processing). Communication acts in this section reuse the
#    verified cco:ont00000402 directly (no local communication genus).
#  * Group-1.1 support ICEs/agents/roles (ex:CompetitorData, ...,
#    ex:MarketData) are carried over from the GOLD module so every
#    filler is declared here, since this module is self-contained apart
#    from the pinned CCO/BFO closure.
#  * Duplicate group-1.3 ICEs (PrioritizedInitiativeList,
#    BusinessValueDriver, BusinessValueDriverBaseline) merged to one.
####################################################################

<http://example.org/apqc/slice/1.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 1.0: Develop Vision and Strategy" ;
    dct:source "APQC Process Classification Framework (Cross-Industry)" ;
    owl:versionInfo "0.1.0" ;
    rdfs:comment "Reality-layer module for APQC Category 1.0 (groups 1.1-1.4). CCO pin v2.0 (2024-11-06). Follows ADR-001 two-layer policy: this is the reality layer only; the curatorial catalog (skos) lives in apqc-catalog.ttl. Self-contained: the shared act genera it uses are inlined from the apqc-ext.ttl registry, so it validates standalone against the pinned CCO/BFO closure with no extension merge." .

####################################################################
# ACT GENERA -- SELF-CONTAINED (canonical defs mirrored from
# apqc-ext.ttl, the D9 shared registry). Inlined so this module
# validates standalone against CCO without merging the extension.
####################################################################

ex:ActOfAcquisition a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Acquisition" ;
    skos:definition "A Planned Act in which an Agent obtains from some authority or supplier an entity (such as an authorization, license, or resource) that the Agent did not previously hold." ;
    rdfs:comment "Local extension (D9). Rejected cco:ont00000950 'Act of Maintenance' (modifying Material Artifacts) and cco:ont00000402 'Act of Communication' (mere ICE transfer). Securing/obtaining a held entity anchors at the generic Planned Act. Expected to recur in procurement/asset-acquisition categories (4.0, 10.0)." .

ex:ActOfAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Analysis" ;
    skos:definition "An Act of Information Processing in which an Agent examines one or more input Information Content Entities and produces an Information Content Entity that represents an understanding of their subject matter." ;
    rdfs:comment "Local extension (D9). CCO 2.0 has no generic analysis class; analysis is information processing, so it is anchored under cco:ont00000366." .

ex:ActOfFormulation a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Formulation" ;
    skos:definition "An Act of Planning in which an Agent composes and articulates a Directive Information Content Entity - such as a mission, strategy, objective, design, roadmap, or business model - that prescribes an organization's intended course of action." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000511 (Act of Planning) because formulating a strategy/mission/design is making a plan to achieve an objective; its output is a Directive ICE. Recurs across develop/define/compose-a-directive processes corpus-wide." .

ex:ActOfIdentification a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Identification (discernment sense)" ;
    skos:definition "An Act of Information Processing in which an Agent discerns and enumerates entities of a given kind and produces an Information Content Entity that registers them." ;
    rdfs:comment "Local extension (D9). NOT cco:ont00001261 'Act of Identifying' (a communication act). APQC 'Identify ...' denotes discernment, i.e. information processing." .

ex:ActOfSelection a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Selection" ;
    skos:definition "An Act of Information Processing in which an Agent chooses one or more options from a set of candidates and produces a Directive Information Content Entity that prescribes the chosen option(s)." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000366 (Act of Information Processing): receives candidate-option ICEs and yields a decision ICE. Distinct from Act of Appraisal (judges without committing) and Act of Planning. NOTE: ratifying a single already-settled option is NOT selection (no candidate set) -- anchor such acts at cco:ont00000228 (Planned Act)." .

####################################################################
# 0. PROVENANCE ANNOTATION PROPERTIES
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "ADR-001 R4 bridge: catalog node -> reality-layer process universal or capability. Populated during reality-layer modeling, NOT by the catalog generator." .

####################################################################
# 1. PROPOSED-EXT ACT GENERA
#    ex:ActOfAnalysis / ex:ActOfIdentification are imported from
#    apqc-ext.ttl and are NOT re-minted here.
####################################################################

# Act genera ex:ActOfFormulation, ex:ActOfSelection, ex:ActOfAcquisition were
# promoted to apqc-ext.ttl (D9, v0.2.0) and are imported from there. Communication
# acts use the verified CCO class cco:ont00000402 directly.

####################################################################
# 2. SHARED SUPPORTING VOCABULARY (section-wide)
#
# Scope: input/output ICEs (Descriptive ont00000853 / Directive
# ont00000965), agents & organizations (ont00001017 / ont00001180),
# roles (BFO_0000023), and capabilities (Agent ont00001379 /
# Organization ont00000568) reused by ALL four process-group agents.
# Act genera live in apqc-ext.ttl (imported) + the PROPOSE-EXT block.
####################################################################

####################################################################
# 2A. ROLES  (BFO_0000023; borne by Agents / Organizations only -- D4)
####################################################################

ex:CustomerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Customer Role" ;
    skos:definition "A Role that is borne by an Agent or Organization in virtue of acquiring, or being a target acquirer of, the products or services of a focal organization." ;
    rdfs:comment "Minted because CCO 2.0 has no Customer class/role. Borne by an independent continuant (the buying Agent/Organization), never by the customer-profile ICE that is about it." .

ex:StakeholderRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Stakeholder Role" ;
    skos:definition "A Role that is borne by an Agent or Organization in virtue of having an interest in, or being affected by, the operations and strategy of a focal organization." ;
    rdfs:comment "Minted because CCO 2.0 has no Stakeholder class/role. Superset of customer, partner, and regulator relations relative to a focal organization." .

ex:SeniorManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Senior Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of exercising senior managerial or executive authority over the strategy and direction of an Organization." ;
    rdfs:comment "Narrower than the 1.1.1 reference module's ex:ManagerRole; used where APQC text specifies senior executives / senior strategy personnel. MERGE DECISION: this Senior pair (ex:SeniorManagerRole / ex:SeniorManagement) deliberately supersedes the reference's generic ex:ManagerRole / ex:ManagementPersonnel for the 1.1.1.8 (P10024) participant, which APQC scopes to 'mid- to senior-level management'. The generic role/agent pair is intentionally not carried over: no process in this merged module requires a non-senior management universal, so re-adding it would leave orphaned classes. Re-mint ex:ManagerRole (and ex:ManagementPersonnel bearing it) as the rdfs:subClassOf parent of this pair only if a future merged process needs the generic universal." .

ex:StrategyPersonnelRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Strategy Personnel Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with formulating, evaluating, or coordinating an Organization's strategy." ;
    rdfs:comment "Covers APQC 'strategy personnel', 'strategy executives', and 'business-unit strategy personnel'." .

ex:ProfessionalServicesProviderRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Professional Services Provider Role" ;
    skos:definition "A Role that is borne by an Agent or Organization in virtue of being engaged externally to supply legal, accounting, consulting, or advisory services to a focal organization." ;
    rdfs:comment "Covers APQC 'specialist professional services providers' engaged for due-diligence and deal evaluation (1.1.5)." .

ex:BusinessUnitRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Business Unit Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of being a constituent operating unit within a larger parent organization." ;
    rdfs:comment "Borne by the sub-organization (the unit), not by the business-unit-strategy ICE about it." .

ex:PartnerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Partner Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of entering a partnership or alliance with a focal organization to deliver products or services." .

####################################################################
# 2B. AGENTS & ORGANIZATIONS  (ont00001017 / ont00001180)
####################################################################

ex:SeniorManagement a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:SeniorManagerRole ] ;
    rdfs:label "Senior Management" ;
    skos:definition "An Agent that bears a senior manager role." ;
    rdfs:comment "Section-wide participant: APQC repeatedly assigns strategy formulation/selection to 'senior management executives'." .

ex:StrategyPersonnel a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:StrategyPersonnelRole ] ;
    rdfs:label "Strategy Personnel" ;
    skos:definition "An Agent that bears a strategy personnel role." .

ex:ProfessionalServicesProvider a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ProfessionalServicesProviderRole ] ;
    rdfs:label "Professional Services Provider" ;
    skos:definition "An Agent that bears a professional services provider role." ;
    rdfs:comment "Modeled as Agent (not strictly Organization) so it covers both individual consultants and consulting firms." .

ex:Customer a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:CustomerRole ] ;
    rdfs:label "Customer" ;
    skos:definition "An Agent that bears a customer role." ;
    rdfs:comment "Modeled as Agent so it covers both individual persons and organizational buyers; use ex:CustomerRole on an Organization for B2B customers." .

ex:Stakeholder a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:StakeholderRole ] ;
    rdfs:label "Stakeholder" ;
    skos:definition "An Agent that bears a stakeholder role." .

ex:BusinessUnit a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:BusinessUnitRole ] ;
    rdfs:label "Business Unit" ;
    skos:definition "An Organization that bears a business unit role within a larger parent organization." .

ex:PartnerOrganization a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:PartnerRole ] ;
    rdfs:label "Partner Organization" ;
    skos:definition "An Organization that bears a partner role in relation to a focal organization." .

####################################################################
# 2C. CAPABILITIES  (R6; bearer = Organization ont00000568)
####################################################################

ex:StrategicPlanningCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Strategic Planning Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to formulate vision, mission, and strategy through intentional acts of strategy formulation and selection." ;
    rdfs:comment "Use as the realizable behind standing 'develop/define strategy' functions. Subclass of ont00000568 because the bearer is the Organization as a whole." .

ex:BusinessModelGovernanceCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Business Model Governance Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to maintain and govern its business models through intentional acts of review, update, and control." ;
    rdfs:comment "Realizable behind the standing functions 1.4.2 'Maintain business models' / 1.4.3 'Establish business model governance' when R5 demotes them from process to capability." .

ex:CustomerExperienceManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;   # Organization Capability
    rdfs:label "Customer Experience Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to register, design, and improve the experience of its customers through intentional acts of assessment and design." ;
    rdfs:comment "Supports the standing-function reading of 1.2.8 'Develop customer experience strategy' and its design sub-nodes." .

####################################################################
# 2D. DESCRIPTIVE-ICE INPUTS  (ont00000853)
####################################################################

ex:MarketData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Market Data" ;
    skos:definition "A Descriptive Information Content Entity that describes features of a market." ;
    rdfs:comment "Carried over from the 1.1.1 reference module (same IRI, same definition) so this self-contained module has every filler declared." .

ex:CustomerData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Data" ;
    skos:definition "A Descriptive Information Content Entity that describes customers, their characteristics, and their needs and wants." .

ex:InternalCapabilityData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Internal Capability Data" ;
    skos:definition "A Descriptive Information Content Entity that describes an organization's in-house skills, resources, operations, and capacities." .

ex:FinancialStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Financial Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes the financial state of an organization, including its balance sheet, income, cash flows, equity, and liquidity." .

ex:PerformanceRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Record" ;
    skos:definition "A Descriptive Information Content Entity that describes recorded performance levels of an organization's processes, functions, or units over a period." .

ex:CustomerFeedback a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Feedback" ;
    skos:definition "A Descriptive Information Content Entity that describes responses, reactions, sentiments, and insights expressed by customers about products, services, or experiences." .

ex:BusinessModelInformation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Business Model Information" ;
    skos:definition "A Descriptive Information Content Entity that describes the materials, goals, and process facts gathered as the basis for developing or revising a business model." .

# --- GOLD group-1.1 input ICEs (carried over so every filler is declared) ---

ex:CompetitorData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Competitor Data" ;
    skos:definition "A Descriptive Information Content Entity that describes competitors and their products or services." .

ex:MacroeconomicData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Macroeconomic Data" ;
    skos:definition "A Descriptive Information Content Entity that describes macroeconomic indicators such as interest rates, taxation, commodity prices, and unemployment." .

ex:RegulatoryData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Data" ;
    skos:definition "A Descriptive Information Content Entity that describes public-policy and regulatory measures issued by sovereign or multinational authorities." .

ex:EcologicalData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Ecological Data" ;
    skos:definition "A Descriptive Information Content Entity that describes ecological factors and shifts relevant to an organization." .

ex:SocioculturalData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sociocultural Data" ;
    skos:definition "A Descriptive Information Content Entity that describes societal composition, distribution, and value systems." .

ex:TechnologyData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Technology Data" ;
    skos:definition "A Descriptive Information Content Entity that describes deployed, emerging, and disruptive technologies." .

ex:DemographicData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Demographic Data" ;
    skos:definition "A Descriptive Information Content Entity that describes the size, distribution, and composition of populations." .

ex:ResearchPublication a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Research Publication" ;
    skos:definition "A Descriptive Information Content Entity published as a report, brief, or article and used as analytic input." .

####################################################################
# 2E. DESCRIPTIVE-ICE OUTPUTS  (ont00000853)
####################################################################

ex:CustomerNeedsAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Needs Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the products and services that are needed or wanted by customers in a relevant market." .

ex:CustomerProfile a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Customer ] ;
    rdfs:label "Customer Profile" ;
    skos:definition "A Descriptive Information Content Entity that describes a group of customers with respect to their characteristics, needs, and behavioral patterns." ;
    rdfs:comment "Covers APQC customer profiles, personas, and the 'single view of the customer'." .

ex:InternalEnvironmentAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Internal Environment Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a big-picture understanding of an organization's internal skills, resources, and capacities." ;
    rdfs:comment "Internal counterpart of ex:ExternalEnvironmentAssessment from the 1.1.1 reference module." .

ex:ExternalEnvironmentAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "External Environment Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a big-picture understanding of an organization's external environment." ;
    rdfs:comment "Carried over from the 1.1.1 reference module so this module is self-contained." ;
    skos:example "A strategy team's annual environmental scan report." .

ex:OrganizationalCharacteristicsAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Organizational Characteristics Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the key attributes differentiating an organization in its market and underpinning its operations." .

ex:InternalOperationsAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Internal Operations Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the key elements and measured effectiveness of an organization's internal operations." .

ex:ProcessBaseline a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Process Baseline" ;
    skos:definition "A Descriptive Information Content Entity that describes a standard reference level of process performance against which current performance is benchmarked." .

ex:SystemsAndTechnologyAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Systems and Technology Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the capabilities of technology and process-automation systems deployed within an organization." .

ex:FinancialHealthAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Financial Health Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes an appraisal of an organization's financial state and capacities." .

ex:CoreCompetencyAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Core Competency Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the strategically significant competences and capacities that differentiate an organization in its market." .

ex:StrategicOptionAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Strategic Option Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the assessed impact and consequences of one or more candidate strategic options." ;
    rdfs:comment "Covers the impact/option assessments produced across 1.2.2 (B2B, B2C, partner, IP, innovation, sustainability, support, shared-services, lean options)." .

ex:OrganizationalStructureAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Organizational Structure Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the evaluated breadth, depth, and implications of an organization's structural makeup." .

ex:RoleActivityDiagram a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Role Activity Diagram" ;
    skos:definition "A Descriptive Information Content Entity that describes the constituent activities of a work-related role and the hand-offs among them." .

ex:CustomerJourneyMap a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Journey Map" ;
    skos:definition "A Descriptive Information Content Entity that describes the sequence of a customer's interactions with an organization from initial contact through long-term relationship." .

ex:CustomerExperienceAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Experience Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes measured customer experience, satisfaction, and feedback across touchpoints." .

ex:RootCauseAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Root Cause Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the underlying causes of a problematic outcome, such as a negative customer experience." .

ex:RestructuringOpportunityAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Restructuring Opportunity Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes identified opportunities for restructuring an organization in light of internal viability and external contingency." .

ex:DueDiligenceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Due-Diligence Report" ;
    skos:definition "A Descriptive Information Content Entity that describes verified tangible and substantial facts about an entity being considered for a restructuring transaction." .

ex:DealOptionAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Deal Option Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes an appraisal of acquisition, merger, de-merger, or divestment options for an organization." .

ex:BusinessValueAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Business Value Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the assessed business or customer value of a strategic priority or initiative." .

ex:StrategicInitiativeEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Strategic Initiative Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes the applicability and feasibility of a strategic initiative relative to an organization's vision and constraints." .

ex:PerformanceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes monitored performance of functions, processes, or initiatives against established baselines or objectives." .

ex:StrategyReviewReport a owl:Class ;
    rdfs:subClassOf ex:PerformanceReport ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:BusinessStrategy ] ;
    rdfs:label "Strategy Review Report" ;
    skos:definition "A Performance Report that describes an evaluation of an organization's business objectives and strategies and is about the business strategy reviewed." ;
    rdfs:comment "Minted (Gate-F) for P19977 'Review with stakeholders'. A specialization of ex:PerformanceReport carrying an is-about (cco:ont00001808) to ex:BusinessStrategy, so the reviewed strategy is captured as the report's subject matter rather than as a (mis-typed) has-input to a communication act." .

# --- GOLD group-1.1 output ICEs (carried over) ---

ex:CompetitorAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:Competitor ] ;
    rdfs:label "Competitor Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes one or more competitors with respect to their strengths and weaknesses relative to a focal organization." ;
    rdfs:comment "Carried over from the 1.1.1 reference module. Descriptive (not Directive) because it represents competitors rather than prescribing a course of action." ;
    skos:example "A report comparing two competitors' pricing, product capabilities, and market position." .

ex:CompetitiveForcesAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Competitive Forces Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the competitive forces in a marketplace." .

ex:CompetitiveBenchmark a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Competitive Benchmark" ;
    skos:definition "A Descriptive Information Content Entity that describes a juxtaposition of processes and performance metrics against competitors." .

ex:SubstitutionBusinessCase a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Substitution Business Case" ;
    skos:definition "A Descriptive Information Content Entity that describes an argument for or against a course of action in light of substitute products or services." .

ex:MacroeconomicTrendAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Macroeconomic Trend Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes medium- to long-term macroeconomic shifts relevant to an organization." .

ex:RegulatoryConcernRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Regulatory Concern Register" ;
    skos:definition "A Descriptive Information Content Entity that describes identified public-policy and regulatory concerns." .

ex:EcologicalConcernRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Ecological Concern Register" ;
    skos:definition "A Descriptive Information Content Entity that describes identified ecological concerns." .

ex:SocioculturalShiftAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sociocultural Shift Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes shifts in societal makeup and cultural composition." .

ex:TechnologyAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Technology Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of current, emerging, and disruptive technologies." .

ex:DemographicAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Demographic Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the size, distribution, and composition of relevant populations." .

ex:BusinessValueDriver a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Business Value Driver" ;
    skos:definition "A Descriptive Information Content Entity that describes a key operational, financial, or sustainability indicator responsible for driving business value." ;
    rdfs:comment "Minted for PCF 19982/19983: distinct from ex:PerformanceMetric (a target measure) -- a driver is the underlying value-causing factor." .

ex:BusinessValueDriverBaseline a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Business Value Driver Baseline" ;
    skos:definition "A Descriptive Information Content Entity that records a baseline standard measure for a business value driver against which later performance is assessed." ;
    rdfs:comment "Minted for PCF 19983/19984: distinct from ex:ProcessBaseline (process-scoped) -- this baselines a value driver. Distinct from ex:PerformanceRecord (actuals)." .

ex:ModelIntegrationPointRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Model Integration Point Register" ;
    skos:definition "A Descriptive Information Content Entity that describes the points at which a new business model must integrate with pre-existing models to remain coherent with them." ;
    rdfs:comment "Minted for 1.4.1.3 output. Descriptive (it represents integration points) rather than Directive." .

ex:FeedbackPrioritization a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Feedback Prioritization" ;
    skos:definition "A Descriptive Information Content Entity that describes the relative importance of items of incoming feedback, identifying which are critical to act upon." ;
    rdfs:comment "Minted for 1.4.2.3 output. Descriptive (it represents a judgement of importance)." .

# --- Gate-F minted Descriptive output ICEs (review fixes) ---

ex:CurrentBusinessAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Current Business Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the de-facto core of what a business does and the capacities that underpin it, as understood at the present time." ;
    rdfs:comment "Minted (Gate-F) for P10044 'Define current business'. Descriptive (it represents an understanding of the status quo), so it agrees with the ex:ActOfAnalysis genus; ex:BusinessConcept (Directive) is reserved for the formulation acts P10045/P17040." .

ex:CustomerValueAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Value Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the assessed value a customer derives from a product or service relative to what the customer gives up to obtain it." ;
    rdfs:comment "Minted (Gate-F) for P19979 'Determine the customer value'. Descriptive judgement of value, parallel to ex:BusinessValueAssessment (the sibling P19978 output)." .

ex:CustomerTouchpointInventory a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Customer Touchpoint Inventory" ;
    skos:definition "A Descriptive Information Content Entity that registers the touchpoints through which customers interact with an organization, such as billboards, web sites, direct mail, and service calls." ;
    rdfs:comment "Minted (Gate-F) for P19961 'Identify and review customer touchpoints'. A register of discerned touchpoints, agreeing with the ex:ActOfIdentification genus; replaces the mis-typed ex:CustomerExperienceAssessment output." .

ex:RequiredCapabilityList a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Required Capability List" ;
    skos:definition "A Descriptive Information Content Entity that registers the skills and competencies required to operate a function or support structure." ;
    rdfs:comment "Minted (Gate-F) for P19972 'Identify required capabilities'. A register of discerned required skills, agreeing with the ex:ActOfIdentification genus; replaces the mis-scoped ex:CoreCompetencyAnalysis output." .

ex:BusinessModelSourceMaterial a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Business Model Source Material" ;
    skos:definition "A Descriptive Information Content Entity comprising the relevant materials, documents, and process facts gathered as the raw input from which a business model is developed." ;
    rdfs:comment "Minted (Gate-F) for P20946 'Assemble business model information' as the definitional input its Act-of-Information-Processing genus receives. Distinct from ex:BusinessModelInformation (the assembled output)." .

####################################################################
# 2F. DIRECTIVE-ICE OUTPUTS  (ont00000965; Plan ont00000974 /
#     Objective ont00000476 used where the CCO definition fits, per D5)
####################################################################

ex:MissionStatement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Mission Statement" ;
    skos:definition "A Directive Information Content Entity that prescribes the overarching purpose and practicable targets an organization aims to pursue." ;
    rdfs:comment "Directive: a mission prescribes intended direction rather than describing a state of affairs." .

ex:StrategicVision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Strategic Vision" ;
    skos:definition "A Directive Information Content Entity that prescribes an organization's intended long-term direction and aspirational future state." ;
    rdfs:comment "Directive output of 1.1.4 'Establish strategic vision' and 1.2.8 customer-experience vision." .

ex:BusinessConcept a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Business Concept" ;
    skos:definition "A Directive Information Content Entity that prescribes the conceptual framework of an organization's business activity with long-term applicability." ;
    rdfs:comment "Output of process group 1.1 'Define the business concept and long-term vision'." .

ex:BusinessStrategy a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE (asserted: Plan subClassOf Directive ICE in CCO; stated locally so standalone Gate C/S3 resolves)
        cco:ont00000974 ;   # Plan (Directive ICE)
    rdfs:label "Business Strategy" ;
    skos:definition "A Plan that prescribes the set of intended intentional acts through which an organization expects to achieve its long-term business objectives." ;
    rdfs:comment "Reuses CCO Plan (ont00000974) rather than minting under ont00000965, because the CCO Plan definition ('prescribes some set of intended Intentional Acts through which some Agent expects to achieve some Objective') fits a strategy exactly. Base genus for the strategy outputs of 1.2.3, 1.2.7, and 1.2.8." .

ex:OrganizationalObjective a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE (asserted: Objective subClassOf Directive ICE in CCO; stated locally so standalone Gate C/S3 resolves)
        cco:ont00000476 ;   # Objective (Directive ICE)
    rdfs:label "Organizational Objective" ;
    skos:definition "An Objective that prescribes a projected state an organization intends to achieve in pursuit of its mission." ;
    rdfs:comment "Reuses CCO Objective (ont00000476). Output of 1.2.6 'Develop and set organizational objectives' and the priority statements of 1.3.1." .

ex:StrategicPriority a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE (asserted: Objective subClassOf Directive ICE in CCO; stated locally so standalone Gate C/S3 resolves)
        cco:ont00000476 ;   # Objective (Directive ICE)
    rdfs:label "Strategic Priority" ;
    skos:definition "An Objective that prescribes a ranked organizational direction used to guide resource-allocation decisions." ;
    rdfs:comment "Reuses CCO Objective. Output of 1.3.1.1 'Identify strategic priorities'; priorities are objectives ordered by importance." .

ex:StrategicOption a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Strategic Option" ;
    skos:definition "A Directive Information Content Entity that prescribes one candidate course of strategic action available to an organization." ;
    rdfs:comment "Directive (a candidate prescription) and distinct from ex:StrategicOptionAnalysis, which describes the assessed impact of options." .

ex:PerformanceMetric a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Performance Metric" ;
    skos:definition "A Directive Information Content Entity that prescribes a standard measure and target against which the performance of a function, process, or initiative is assessed." ;
    rdfs:comment "Covers APQC baseline metrics, KPIs, business-value drivers, and high-level measures (1.2.6, 1.3.4). Directive because a metric/target prescribes the standard to be met." .

ex:OrganizationalDesign a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Organizational Design" ;
    skos:definition "A Directive Information Content Entity that prescribes the intended structure and relationships among an organization's units and roles." ;
    rdfs:comment "Output of 1.2.5 'Create organizational design'. Directive: a design prescribes (serves as a model for) the structure to be realized." .

ex:CommunicationStrategy a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE (asserted: Plan subClassOf Directive ICE in CCO; stated locally so standalone Gate C/S3 resolves)
        cco:ont00000974 ;   # Plan (Directive ICE)
    rdfs:label "Communication Strategy" ;
    skos:definition "A Plan that prescribes the intended channels and acts for conveying a mission, vision, or strategy to stakeholders." ;
    rdfs:comment "Reuses CCO Plan. Output of the 'communicate' nodes (1.1.4.3, 1.2.1.3, 1.2.9, 1.3.3.2, 1.2.8.2.7 content strategy)." .

ex:StakeholderAlignmentPlan a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE (asserted: Plan subClassOf Directive ICE in CCO; stated locally so standalone Gate C/S3 resolves)
        cco:ont00000974 ;   # Plan (Directive ICE)
    rdfs:label "Stakeholder Alignment Plan" ;
    skos:definition "A Plan that prescribes how stakeholders are to be oriented and positioned in support of an organization's strategic vision." ;
    rdfs:comment "Output of 1.1.4.2 'Align stakeholders around strategic vision'." .

ex:StrategicInitiativeSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Strategic Initiative Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes a discretionary, time-bound strategic project lying beyond an organization's routine operations." ;
    rdfs:comment "Output of 1.3.1 'Develop strategic initiatives'; consumed (as input) by 1.3.2/1.3.3 evaluation and selection." .

ex:InitiativeSelectionDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Initiative Selection Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes which strategic initiatives an organization will pursue." ;
    rdfs:comment "Directive (a decision prescribes a course of action), parallel to ex:GoNoGoDecision in the 1.1.1 reference module. Output of 1.3.3 'Select strategic initiatives'." .

ex:BusinessModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Business Model" ;
    skos:definition "A Directive Information Content Entity that prescribes how an organization creates, delivers, and captures value, including its products, target market, and core economics." ;
    rdfs:comment "Output of group 1.4 'Develop and maintain business models'. Directive: an adopted business model serves as the guiding model for day-to-day operations." .

ex:BusinessModelGovernancePolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Business Model Governance Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the responsibilities, control mechanisms, and review parameters for managing an organization's business models." ;
    rdfs:comment "Output of 1.4.3 'Establish business model governance' and the maintenance-parameter nodes of 1.4.2." .

ex:CustomerExperienceRoadmap a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE (asserted: Plan subClassOf Directive ICE in CCO; stated locally so standalone Gate C/S3 resolves)
        cco:ont00000974 ;   # Plan (Directive ICE)
    rdfs:label "Customer Experience Roadmap" ;
    skos:definition "A Plan that prescribes the intended capabilities, behaviors, and timeline for delivering a defined customer experience." ;
    rdfs:comment "Output of 1.2.8.3/1.2.8.4 customer-experience support structure and roadmap." .

ex:PrioritizedInitiativeList a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Prioritized Initiative List" ;
    skos:definition "A Directive Information Content Entity that ranks strategic initiatives from most to least important to guide which are pursued first." ;
    rdfs:comment "Minted for PCF 19980: no shared-vocab ICE captures a ranked order of initiatives. Directive (prescribes order of pursuit)." .

ex:BusinessModelAdoptionDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Business Model Adoption Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes that a particular business model is to serve as the accepted basis of an organization's operations." ;
    rdfs:comment "Minted for 1.4.1.4 output. Directive (a decision prescribes) rather than Descriptive." .

ex:BusinessModelMaintenancePlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Business Model Maintenance Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the timeline, procedures, and responsibilities for reviewing and updating a business model." ;
    rdfs:comment "Minted for 1.4.2.1 output. Directive (it prescribes the maintenance procedure)." .

ex:FeedbackCriteriaSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Feedback Criteria Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes which types of feedback are to be taken into consideration during business-model maintenance." ;
    rdfs:comment "Minted for 1.4.2.2 output. Directive (it prescribes admissible feedback)." .

ex:BusinessAuthorization a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE (asserted: Action Permission subClassOf Directive ICE in CCO; stated locally so standalone Gate C/S3 resolves)
        cco:ont00000751 ;   # Action Permission (Authorization/License) -> Directive ICE
    rdfs:label "Business Authorization" ;
    skos:definition "An Action Permission that authorizes the conduct of a particular business or business activity." ;
    rdfs:comment "Minted for 1.4.1.2 output. Subclass of cco:ont00000751 (Action Permission, altLabel Authorization/License), itself a Directive ICE." .

# --- GOLD group-1.1 directive ICEs (carried over) ---

ex:GoNoGoDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Go/No-Go Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes whether to proceed or not proceed with a course of action." ;
    rdfs:comment "Carried over from the 1.1.1 reference module. Directive (not Descriptive) because a decision prescribes rather than describes." .

ex:IPThreatMeasureSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "IP Threat Measure Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes measures and procedures for identifying intellectual-property threats." ;
    rdfs:comment "Carried over from the 1.1.1 reference module." ;
    skos:example "A documented procedure listing IP-threat indicators and the steps to screen for them." .

# --- Gate-F minted Directive output ICEs (review fixes) ---

ex:OrganizationalStructureAdoptionDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Organizational Structure Adoption Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes that a particular organizational structure is to serve as the accepted basis of an organization's operations." ;
    rdfs:comment "Minted (Gate-F) for P10056 'Migrate to new organization', parallel to ex:BusinessModelAdoptionDecision. Subject-matched (an organizational structure, not a strategic initiative), replacing the mis-subjected ex:InitiativeSelectionDecision." .

ex:PartnershipSelectionDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Partnership Selection Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes which partnerships, alliances, and make-versus-buy relationships an organization will pursue to support its extended enterprise." ;
    rdfs:comment "Minted (Gate-F) for P18083 'Select partnerships and relationships' as the Directive chosen-option output required by the ex:ActOfSelection genus (the Descriptive ex:StrategicOptionAnalysis alone did not satisfy it)." .

ex:StrategyAlignmentPlan a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ,   # Directive ICE (asserted: Plan subClassOf Directive ICE in CCO; stated locally so standalone Gate C/S3 resolves)
        cco:ont00000974 ;   # Plan (Directive ICE)
    rdfs:label "Strategy Alignment Plan" ;
    skos:definition "A Plan that prescribes how the plans and methods of an organization's individual units, departments, and processes are to be calibrated to the adopted enterprise strategy." ;
    rdfs:comment "Minted (Gate-F) for P10040 'Coordinate and align cross-functional and process strategies'. Units/processes-oriented, replacing the stakeholder-oriented ex:StakeholderAlignmentPlan, which concerns orienting stakeholders rather than calibrating unit plans." .

ex:PerformanceMonitoringMethodSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Performance Monitoring Method Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the methodology and frequency by which the performance of functions, processes, and activities is to be measured and monitored against set goals." ;
    rdfs:comment "Minted (Gate-F) for P19955 'Monitor performance against objective', whose lead verb is 'defining methodology and frequency' (a formulation act producing a Directive monitoring-method spec), not the appraisal that produces a ex:PerformanceReport." .

####################################################################
# 2G. GOLD group-1.1 AGENTS / ROLES / CAPABILITY (carried over so
#     every filler used by the 1.1 process classes is declared here).
####################################################################

ex:CompetitiveIntelligenceAnalystRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Competitive Intelligence Analyst Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with analyzing competitors on behalf of an Organization." .

ex:CompetitorRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Competitor Role" ;
    skos:definition "A Role that is borne by an Organization in virtue of competing with a focal organization in a market." ;
    rdfs:comment "Borne by an independent continuant (the rival Organization), never by the analysis ICE that is about it." .

ex:CompetitiveAnalysisCapability a owl:Class ;
    rdfs:subClassOf cco:ont00001379 ,   # Agent Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P19945 ] ;
    rdfs:label "Competitive Analysis Capability" ;
    skos:definition "An Agent Capability that is realized in Acts of Analyzing Competitors." ;
    rdfs:comment "Carried over from the 1.1.1 reference module; the realized-in filler is re-pointed to ex:P19945 (this module's IRI for 'Identify competitors / Analyze competitors')." .

ex:CompetitiveIntelligenceAnalyst a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty cco:ont00001954 ; owl:someValuesFrom ex:CompetitiveAnalysisCapability ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:CompetitiveIntelligenceAnalystRole ] ;
    rdfs:label "Competitive Intelligence Analyst" ;
    skos:definition "An Agent that has a competitive analysis capability and bears a competitive-intelligence analyst role." ;
    rdfs:comment "Narrower than BFO material entity: cco:Agent excludes tools, animals, and arbitrary material objects from being analysts." .

ex:Competitor a owl:Class ;
    rdfs:subClassOf cco:ont00001180 ,   # Organization
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:CompetitorRole ] ;
    rdfs:label "Competitor" ;
    skos:definition "An Organization that bears a competitor role in relation to some focal organization or market." ;
    rdfs:comment "Modeled as Organization per APQC 'competing firms'. Use cco:Agent for individual (non-organizational) competitors." .

####################################################################
# 3. PROCESS CLASSES
####################################################################

####################################################################
# 3.1  PROCESS GROUP 1.1  "Define the business concept and long-term vision"
####################################################################

# --- 1.1 (PCF 17040) : formulation of a business concept/vision -> Act of Planning
ex:P17040 a owl:Class ;
    ex:pcfID "17040" ; ex:hierarchyID "1.1" ;
    ex:apqcSourceText "Creating a conceptual framework of the organization's business activity and strategic vision with long-term applicability. Scout the organization's internal capabilities, as well as the customer's needs and desires, to identify a fit that can be used to advance a conceptual structure of the organization's business activity. Conduct analysis in light of relevant externalities and large-scale shifts in the market landscape." ;
    rdfs:label "Define the business concept and long-term vision" ;
    skos:definition "An Act of Planning that synthesizes internal capability, customer, and external-environment findings into a business concept and long-term strategic vision for an organization." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): it produces a directive conceptual framework (the business concept) to be achieved. The ex:StrategicVision output is demoted (Gate-F) from an existential has-output to this comment/CQ note: the long-term vision is supplied by the has-process-part child P10020 'Establish strategic vision', so asserting it as a direct output of P17040 double-counts it. The definitional direct output of P17040 is ex:BusinessConcept. CQ: 'which acts in 1.1 produce a strategic vision?' is answered by P10020 (and its child P19949), not by P17040 directly. Its APQC children 1.1.1-1.1.5 are process parts, not subclasses." ;
    skos:example "An executive team integrates market and capability analyses into a ten-year business concept and vision." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessConcept ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10017 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10018 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10019 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10020 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16792 ] .

ex:P10017 a owl:Class ;
    ex:pcfID "10017" ; ex:hierarchyID "1.1.1" ;
    ex:apqcSourceText "Assessing all forces, entities, and systems that are external to an organization but can affect its operation. Analyze far-reaching currents in the macroeconomic situation, assess the competition, evaluate technological changes, and identify societal as well as ecological issues of concern. Create a big-picture understanding of externalities, with sufficient depth across individual aspects." ;
    rdfs:label "Assess the external environment" ;
    skos:definition "An Act of Analysis that examines the external forces, entities, and systems bearing on an organization and produces a big-picture external-environment assessment." ;
    rdfs:comment "Anchored (Gate-F) to ex:ActOfAnalysis, kept consistent with its sibling P10019 'Assess the internal environment': both differentiate on building a 'big-picture understanding' and emit a Descriptive assessment, so both are Analysis. Rejected cco:ont00000636 (Act of Appraisal): the dominant gerund is creating a synthetic understanding of externalities, not rendering a value-judgement. Was ex:AnalyzeExternalBusinessEnvironment in the GOLD module. Its APQC children are process parts, not subclasses." ;
    skos:example "An organization's yearly strategic environmental scan culminating in an external-environment assessment." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ExternalEnvironmentAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19945 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10021 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21421 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10022 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10023 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10027 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10026 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10024 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10025 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16790 ] .

ex:P19945 a owl:Class ;
    ex:pcfID "19945" ; ex:hierarchyID "1.1.1.1" ;
    ex:apqcSourceText "Identifying your competitors, their service and/or product. Evaluating competitors strategies to determine their strengths and weaknesses relative to those of your own product or service." ;
    rdfs:label "Analyze competitors" ;
    skos:definition "An Act of Analysis that has as input competitor data and has as output a competitor analysis about one or more competitors." ;
    rdfs:comment "Carried over from GOLD module (ex:AnalyzeCompetitors). Represents APQC 1.1.1.1 as an occurrent, not as the analysis artifact (that is ex:CompetitorAnalysis) nor an organizational function." ;
    skos:example "A competitive-intelligence team reviews market reports and produces a competitor analysis." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CompetitorData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetitorAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:CompetitiveIntelligenceAnalyst ] .

ex:P10021 a owl:Class ;
    ex:pcfID "10021" ; ex:hierarchyID "1.1.1.2" ;
    ex:apqcSourceText "Assessing the competitive forces in the marketplace that could potentially affect the organization. Analyze various aspects of business competition including competing firms. Aggregate competitive intelligence, create benchmarks to juxtapose processes and performance metrics, and inject crucial information about the competition into management models to synthesize insights." ;
    rdfs:label "Analyze and evaluate competition" ;
    skos:definition "An Act of Appraisal that has as input competitor data and market data and has as output a competitive-forces assessment and competitive benchmarks." ;
    rdfs:comment "Carried over from GOLD module (ex:AssessMarketplaceCompetitiveForces). Anchored to cco:ont00000636 (Act of Appraisal)." ;
    skos:example "An analyst benchmarks rivals and issues an assessment of the competitive forces in the sector." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CompetitorData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetitiveForcesAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetitiveBenchmark ] .

ex:P21421 a owl:Class ;
    ex:pcfID "21421" ; ex:hierarchyID "1.1.1.3" ;
    ex:apqcSourceText "Examining if there are other existing products or services in the marketplace, and building the business case to make a go/no go decision based upon substitutions." ;
    rdfs:label "Identify potential product or service alternatives" ;
    skos:definition "An Act of Selection that examines substitute products or services on the market and produces a go/no-go decision on the alternative." ;
    rdfs:comment "Re-anchored (Gate-F) from cco:ont00000636 (Act of Appraisal) to ex:ActOfSelection: the source builds a business case in order to 'make a go/no go decision', and the definitional output is the Directive ex:GoNoGoDecision (a chosen-option commitment), which the Golden Principle ties to a Selection act, not an Appraisal. This supersedes the 1.1.1 reference module's Act-of-Appraisal + dual-output model (the Selection genus is the cleaner anchor for an act culminating in a decision). The source explicitly says the act is 'building the business case to make a go/no go decision', so ex:SubstitutionBusinessCase is restored as a SECOND (Descriptive) has-output produced by this act en route to the decision -- a Selection act may carry a secondary descriptive output -- rather than demoted to prose; this answers the CQ 'what document supports the substitution go/no-go?'. Was ex:EvaluateSubstituteProducts in the GOLD module." ;
    skos:example "A product team weighs a substitute on the market and commits to a no-go decision." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SubstitutionBusinessCase ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GoNoGoDecision ] .

ex:P10022 a owl:Class ;
    ex:pcfID "10022" ; ex:hierarchyID "1.1.1.4" ;
    ex:apqcSourceText "Determining large-scale macroeconomic shifts and trends, with medium to long-term relevance for the organization. Vet the immediate and the larger economic ecosystem to identify broad-based movements that affect the organization. In the immediate vicinity, for example, examine the stock price of key vendors/suppliers in the organizational value-chain. In the larger economic ecosystem, analyze according to geographical distribution where factors such as interest rates, taxation structures, oil prices, and unemployment rates are explored." ;
    rdfs:label "Identify economic trends" ;
    skos:definition "An Act of Analysis that has as input macroeconomic data and has as output a macroeconomic trend analysis." ;
    rdfs:comment "Carried over from GOLD module (ex:DetermineMacroeconomicTrends)." ;
    skos:example "An economist reviews indicators and reports the trends likely to affect the firm over five years." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MacroeconomicData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MacroeconomicTrendAnalysis ] .

ex:P10023 a owl:Class ;
    ex:pcfID "10023" ; ex:hierarchyID "1.1.1.5" ;
    ex:apqcSourceText "Identifying areas of concern pertaining to public policy and regulation, established by sovereign or multinational authorities. Examine various regions and geopolitical formations to identify those political and regulatory issues-present or developing-that can potentially affect the organization. Plan for an iterative process, partitioned across regional and geopolitical entities that have a direct bearing on the organization's activities. Assess changes in environmental compliance, product standards, trade barriers, etc." ;
    rdfs:label "Identify political and regulatory factors" ;
    skos:definition "An Act of Identification that has as input regulatory data and has as output a regulatory concern register." ;
    rdfs:comment "Carried over from GOLD module (ex:IdentifyRegulatoryConcerns)." ;
    skos:example "A compliance team screens jurisdictions and registers the regulatory changes that bear on the firm." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RegulatoryData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RegulatoryConcernRegister ] .

ex:P10027 a owl:Class ;
    ex:pcfID "10027" ; ex:hierarchyID "1.1.1.6" ;
    ex:apqcSourceText "Identifying changes in ecological ecosystems that can be directly or indirectly detrimental to the organization. Analyze ecological factors within the immediate ecosystem for near to middle-term impact. Analyze the ecology, at large, to get a sense of long-term shifts and concerns. Gather analyses from research publications. Speak to subject matter experts. Engage with advocacy groups, lawyers, journalists, and the active populations." ;
    rdfs:label "Identify environmental factors" ;
    skos:definition "An Act of Identification that has as input ecological data and research publications and has as output an ecological concern register." ;
    rdfs:comment "Carried over from GOLD module (ex:IdentifyEcologicalConcerns)." ;
    skos:example "An ESG analyst registers ecological risks drawn from scientific publications and expert input." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EcologicalData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ResearchPublication ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EcologicalConcernRegister ] .

ex:P10026 a owl:Class ;
    ex:pcfID "10026" ; ex:hierarchyID "1.1.1.7" ;
    ex:apqcSourceText "Distinguishing changes in societal makeup, as well as the cultural composite. Isolate shifts in the societal composition and distribution, as well as the value systems and attributes that bind the organization together. Analyze well-regarded publications--and gather the perspective of public intellectuals and opinion leaders--on relevant issues." ;
    rdfs:label "Identify social and cultural changes" ;
    skos:definition "An Act of Identification that has as input sociocultural data and has as output a sociocultural shift analysis." ;
    rdfs:comment "Carried over from GOLD module (ex:DistinguishSocioculturalShifts)." ;
    skos:example "A market researcher distinguishes generational value shifts relevant to the brand." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SocioculturalData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SocioculturalShiftAnalysis ] .

ex:P10024 a owl:Class ;
    ex:pcfID "10024" ; ex:hierarchyID "1.1.1.8" ;
    ex:apqcSourceText "Assessing developments in technologies presently being used by the business, new technologies that have a potential for the business, and any disruptive innovations. Conduct a survey of advancement in technologies that are already deployed with inputs from the personnel closely working with them, tracking utility and feasibility for deployment. Arrange for mid- to senior-level management personnel who explore contingent uses to assess new and disruptive technologies. Follow up with desk research, involving physical scoping and viability assessment." ;
    rdfs:label "Assess new technologies" ;
    skos:definition "An Act of Appraisal that has as input technology data, has as output a technology assessment, and has senior management as participant." ;
    rdfs:comment "Carried over from GOLD module (ex:AssessTechnologyDevelopments). Participant re-bound to shared ex:SeniorManagement per the manifest agent vocabulary." ;
    skos:example "Senior managers appraise an emerging technology and issue a technology assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:TechnologyData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TechnologyAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SeniorManagement ] .

ex:P10025 a owl:Class ;
    ex:pcfID "10025" ; ex:hierarchyID "1.1.1.9" ;
    ex:apqcSourceText "Analyzing statistical data relating to the size, distribution, and composition of relevant populations, as well as their characteristics. Perform quantitative analysis over raw data-sets gathered from well-founded sources such as government census or large, private databases. Consider employing primary research in collecting required statistics. Use comprehensive studies (reports, briefs, and articles) to assist with the analysis, in place of raw data." ;
    rdfs:label "Analyze demographics" ;
    skos:definition "An Act of Analysis that has as input demographic data and has as output a demographic analysis." ;
    rdfs:comment "Carried over from GOLD module (ex:AnalyzeDemographics)." ;
    skos:example "A team analyzes census data and produces a demographic profile of a target market." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DemographicData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DemographicAnalysis ] .

ex:P16790 a owl:Class ;
    ex:pcfID "16790" ; ex:hierarchyID "1.1.1.10" ;
    ex:apqcSourceText "Establishing measures and procedures for identifying various intellectual property threats and concerns." ;
    rdfs:label "Evaluate intellectual property" ;
    skos:definition "An Act of Planning that has as output an IP threat measure specification prescribing procedures for identifying intellectual-property threats." ;
    rdfs:comment "Carried over from GOLD module (ex:EstablishIPThreatMeasures). Anchored to cco:ont00000511 (Act of Planning)." ;
    skos:example "Legal counsel establishes a procedure for screening incoming filings for IP-infringement risk." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:IPThreatMeasureSpecification ] .

ex:P10018 a owl:Class ;
    ex:pcfID "10018" ; ex:hierarchyID "1.1.2" ;
    ex:apqcSourceText "Examining the market to identify customer required solutions. Assess the relevant market(s) to determine the products/services that are needed or wanted by customers. Carry out quantitative and qualitative analyses to capture and investigate products/services. Employ creative techniques that allow for a closer appreciation of the customer, and design relevant solutions." ;
    rdfs:label "Survey market and determine customer needs and wants" ;
    skos:definition "An Act of Analysis that examines market and customer data to determine the products and services customers need or want and produces a customer needs assessment." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (information processing): it examines market/customer data into a needs assessment. Its APQC children are process parts." ;
    skos:example "A market-research team surveys a segment and reports the customer needs the firm should address." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerNeedsAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10028 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19946 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19947 ] .

ex:P10028 a owl:Class ;
    ex:pcfID "10028" ; ex:hierarchyID "1.1.2.1" ;
    ex:apqcSourceText "Investigating key market features and customer characteristics, using qualitative and quantitative measures to capture relevant aspects. Distill key ingredients that allow the organization to Capture customer needs and wants [19946], and Assess customer needs and wants [19947]. Conduct standardized appraisals by defining selection parameters and setting quotas." ;
    rdfs:label "Conduct qualitative/quantitative research and assessments" ;
    skos:definition "An Act of Analysis that has as input market data and customer data and has as output a customer needs assessment derived from qualitative and quantitative research." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis. Research/investigation of market features is information processing." ;
    skos:example "Researchers run a survey and focus groups and distill the findings into a needs assessment." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerNeedsAssessment ] .

ex:P19946 a owl:Class ;
    ex:pcfID "19946" ; ex:hierarchyID "1.1.2.2" ;
    ex:apqcSourceText "Identifying and collecting customers' wants and needs of a product and/or services from a marketing perspective. Identify which consumer needs are important and whether needs are being met by current products/services." ;
    rdfs:label "Capture customer needs and wants" ;
    skos:definition "An Act of Identification that has as input customer feedback and has as output a customer needs assessment registering customers' wants and needs." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment sense): it discerns and registers which consumer needs are important." ;
    skos:example "A marketing analyst collects survey responses and registers the unmet needs of a customer segment." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerNeedsAssessment ] .

ex:P19947 a owl:Class ;
    ex:pcfID "19947" ; ex:hierarchyID "1.1.2.3" ;
    ex:apqcSourceText "Creating customer profiles to get a picture of customers and their needs. Identify particular groups of people/organizations that benefit from your product/services and then selling to them." ;
    rdfs:label "Assess customer needs and wants" ;
    skos:definition "An Act of Identification that discerns and characterizes groups of customers who benefit from an organization's products or services and produces a customer profile of those groups and their needs." ;
    rdfs:comment "Re-anchored (Gate-F) from cco:ont00000636 (Act of Appraisal) to ex:ActOfIdentification: the source is 'creating customer profiles ... identify particular groups of people/organizations' -- profiling/segmentation is discernment, and its Descriptive output ex:CustomerProfile agrees with the Information-Processing genus. Rejected Act of Appraisal: there is no evaluative value-judgement here, only characterization of segments." ;
    skos:example "An analyst segments the market and builds customer profiles for the strategy team." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerNeedsAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerProfile ] .

ex:P10019 a owl:Class ;
    ex:pcfID "10019" ; ex:hierarchyID "1.1.3" ;
    ex:apqcSourceText "Undertaking a review of the organization's in-house skills and resources in order to create a big-picture understanding of internal capacities. Assess the organization's capabilities in order to advance the advantageous and weed out the detrimental aspects. Identify synergic associations within the backdrop of the forces and players active in the market, and take into account all externalities." ;
    rdfs:label "Assess the internal environment" ;
    skos:definition "An Act of Analysis that reviews an organization's in-house skills, resources, and capabilities and produces a big-picture internal-environment assessment." ;
    rdfs:comment "Re-anchored (Gate-F) from cco:ont00000636 (Act of Appraisal) to ex:ActOfAnalysis for sibling consistency with P10017 'Assess the external environment': the source's differentia is 'create a big-picture understanding of internal capacities', and the Descriptive ex:InternalEnvironmentAssessment output agrees with the Information-Processing genus. Rejected Act of Appraisal: building a synthetic understanding is analysis, not a value-judgement. Its APQC children are process parts." ;
    skos:example "A strategy team reviews the firm's capabilities and produces an internal-environment assessment." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InternalCapabilityData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InternalEnvironmentAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10030 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19948 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10031 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10032 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10033 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10034 ] .

ex:P10030 a owl:Class ;
    ex:pcfID "10030" ; ex:hierarchyID "1.1.3.1" ;
    ex:apqcSourceText "Identifying and examining key attributes that differentiate the organization in the market and those that underscore the core of its operations. Consider how the organization functions. Reflect over tangible and intangible aspects in order to spot critical correlations and the interplay between these attributes. Have senior executives conduct the analysis, with input from management and operational personnel." ;
    rdfs:label "Analyze organizational characteristics" ;
    skos:definition "An Act of Analysis that has as input internal-capability data and has as output an organizational-characteristics analysis, with senior management as participant." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis. Senior management modeled as definitional participant per the source ('Have senior executives conduct the analysis')." ;
    skos:example "Senior executives examine the firm's differentiating attributes and document an organizational-characteristics analysis." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InternalCapabilityData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalCharacteristicsAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SeniorManagement ] .

ex:P19948 a owl:Class ;
    ex:pcfID "19948" ; ex:hierarchyID "1.1.3.2" ;
    ex:apqcSourceText "Identify key elements of operations and measure effectiveness of these elements within internal operations." ;
    rdfs:label "Analyze internal operations" ;
    skos:definition "An Act of Analysis that has as input internal-capability data and has as output an internal-operations analysis measuring the effectiveness of operational elements." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis: it examines and measures operational elements." ;
    skos:example "An operations team measures the effectiveness of key processes and reports an internal-operations analysis." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InternalCapabilityData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InternalOperationsAnalysis ] .

ex:P10031 a owl:Class ;
    ex:pcfID "10031" ; ex:hierarchyID "1.1.3.3" ;
    ex:apqcSourceText "Establishing baselines that provide standards for assessing performance levels and allow for a relational benchmarking of current processes. Undertake a survey of archival performance records, conducted in conjunction by the management and the operations personnel. Take into account the organization's internal objectives, particularly for process improvement and enhancement. Understand industry best practices." ;
    rdfs:label "Create baselines for current processes" ;
    skos:definition "An Act of Analysis that has as input performance records and has as output a process baseline derived from them as a reference measure for benchmarking current processes." ;
    rdfs:comment "Re-anchored (Gate-F) from cco:ont00000511 (Act of Planning) to ex:ActOfAnalysis, kept consistent with its sibling P19983 'Establish baselines for business value drivers': a baseline is a Descriptive reference measure DERIVED from archival performance records (the output ex:ProcessBaseline is Descriptive), so the act is information processing. Rejected Act of Planning (would require a Directive output, but a baseline describes a reference level rather than prescribing action) and rejected cco:ont00000345 Act of Measuring (measuring determines a value AGAINST an existing standard, whereas this act DERIVES the standard from records)." ;
    skos:example "Management surveys archival performance records and derives process baselines for benchmarking." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessBaseline ] .

ex:P10032 a owl:Class ;
    ex:pcfID "10032" ; ex:hierarchyID "1.1.3.4" ;
    ex:apqcSourceText "Analyzing the capabilities of technology and process automation systems deployed within the organization in order to direct future associated processes. Conduct a broad-based survey to examine various aspects associated with such systems and technologies, with the objective of identifying key facets that are of interest. Investigate the intended purpose, purpose served, utility, longevity, remaining service-life, repair or service requirements, etc." ;
    rdfs:label "Analyze systems and technology" ;
    skos:definition "An Act of Analysis that has as input internal-capability data and has as output a systems-and-technology analysis of deployed technology and automation systems." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis: it examines deployed systems and reports their capabilities." ;
    skos:example "An IT team surveys deployed automation systems and documents a systems-and-technology analysis." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InternalCapabilityData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SystemsAndTechnologyAnalysis ] .

ex:P10033 a owl:Class ;
    ex:pcfID "10033" ; ex:hierarchyID "1.1.3.5" ;
    ex:apqcSourceText "Appraising the financial state of the organization so that management can create resource allocation strategies. Scrutinize the organization's financials--including balance sheets, statements of income, cash-flows, equity holdings, and liquidity--with the objective of understanding the organization's financial health and capacities. (This analysis directly feeds into Conduct organizational restructuring opportunities [16792] and Define a business concept and long-term vision [17040].)" ;
    rdfs:label "Analyze financial health" ;
    skos:definition "An Act of Appraisal that has as input financial statements and has as output a financial-health analysis of the organization's financial state." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it appraises the financial state. Source notes its output feeds 1.1.5 and 1.1." ;
    skos:example "A finance team scrutinizes the balance sheet and cash-flow statements and reports the firm's financial health." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:FinancialStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FinancialHealthAnalysis ] .

ex:P10034 a owl:Class ;
    ex:pcfID "10034" ; ex:hierarchyID "1.1.3.6" ;
    ex:apqcSourceText "Determining a strategically significant aggregate of competence and capacities that differentiates the organization in the market. Identify distinguishing attributes including unique skills and resources and its brand and services in the marketplace. Have senior executives and management personnel assess competencies in order to further develop these capabilities into distinct commercial value propositions." ;
    rdfs:label "Identify core competencies" ;
    skos:definition "An Act of Identification that has as input internal-capability data and has as output a core-competency analysis registering the organization's distinguishing competencies." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment sense): it discerns and registers strategically significant competencies." ;
    skos:example "Senior executives determine and document the firm's core competencies for its value proposition." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InternalCapabilityData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CoreCompetencyAnalysis ] .

ex:P10020 a owl:Class ;
    ex:pcfID "10020" ; ex:hierarchyID "1.1.4" ;
    ex:apqcSourceText "Establishing the organization's long-term vision as a strategic positioning and engagement of stakeholders. Institute the vision by creating strategic orientations of all stakeholders. Understand the strategy development frameworks in this context." ;
    rdfs:label "Establish strategic vision" ;
    skos:definition "An Act of Planning that formulates an organization's long-term strategic vision and orients stakeholders around it, producing a strategic vision." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): it produces a directive vision. Its APQC children are process parts." ;
    skos:example "An executive team establishes a ten-year vision and aligns stakeholders behind it." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicVision ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19949 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10035 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10036 ] .

ex:P19949 a owl:Class ;
    ex:pcfID "19949" ; ex:hierarchyID "1.1.4.1" ;
    ex:apqcSourceText "Developing goals to define organizations vision. Define and document ideas, direction, and activities which enable the organization to reach these goals." ;
    rdfs:label "Define the strategic vision" ;
    skos:definition "An Act of Planning that has as output a strategic vision documenting the goals, direction, and activities that define an organization's vision." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): it formulates and documents a directive vision and its goals." ;
    skos:example "A strategy team drafts and documents the firm's strategic vision statement." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicVision ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalObjective ] .

ex:P10035 a owl:Class ;
    ex:pcfID "10035" ; ex:hierarchyID "1.1.4.2" ;
    ex:apqcSourceText "Orienting those entities, associated with the organization that have a direct bearing on its operations and output, in a way that advances its strategic vision. Map all stakeholders in strategic configurations, within the architectural layout of the marketplace, and position the organization relative to them. (This exercise is undertaken by senior strategy personnel, drawing upon the process Define a business concept and long-term vision [17040].)" ;
    rdfs:label "Align stakeholders around strategic vision" ;
    skos:definition "An Act of Planning that has as input a strategic vision and has as output a stakeholder alignment plan mapping stakeholders in strategic configurations, with strategy personnel as participant." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): it produces a directive alignment plan. Strategy personnel modeled as definitional participant per the source." ;
    skos:example "Senior strategy personnel map stakeholders and produce a plan to align them with the vision." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicVision ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StakeholderAlignmentPlan ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:StrategyPersonnel ] .

ex:P10036 a owl:Class ;
    ex:pcfID "10036" ; ex:hierarchyID "1.1.4.3" ;
    ex:apqcSourceText "Developing and executing communication strategies to convey an alignment plan of all organizational stakeholders, which helps the organization realize its vision. Create custom communication strategies and delivery channels with the objective of orienting stakeholders according to the configuration maps created in the process Align stakeholders around a strategic vision [10035]. Have senior strategy personnel closely collaborate with the communications/marketing team." ;
    rdfs:label "Communicate strategic vision to stakeholders" ;
    skos:definition "An Act of Communication that has as input a stakeholder alignment plan and a strategic vision and conveys the vision to stakeholders by means of a communication strategy." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication, verified v2.0): an ICE (the vision/alignment plan) is transferred from the organization to its stakeholders." ;
    skos:example "Strategy personnel and marketing convey the vision to stakeholders through tailored channels." ;
    rdfs:subClassOf cco:ont00000228 ,   # Planned Act (asserted: Act of Communication subClassOf Planned Act in CCO; stated locally so standalone Gate C/S2 resolves)
        cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StakeholderAlignmentPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicVision ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CommunicationStrategy ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:StrategyPersonnel ] .

ex:P16792 a owl:Class ;
    ex:pcfID "16792" ; ex:hierarchyID "1.1.5" ;
    ex:apqcSourceText "Examining the scope and contingencies for restructuring based on market situation and internal realities. Map the market forces over which any and all probabilities can be probed for utility and viability. Once the restructuring options have been analyzed and the due-diligence performed, execute the deal. Consider seeking professional services for assistance in formalizing these opportunities." ;
    rdfs:label "Conduct organization restructuring opportunities" ;
    skos:definition "An Act of Appraisal that examines the scope and contingencies for restructuring an organization in light of market and internal realities and produces a restructuring opportunity analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the dominant gerund is examining/probing restructuring options for viability. Its APQC children are process parts; deal execution is a downstream consequence noted in the source." ;
    skos:example "A corporate-development team probes merger and divestment options and documents a restructuring opportunity analysis." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RestructuringOpportunityAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16793 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16794 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16795 ] .

ex:P16793 a owl:Class ;
    ex:pcfID "16793" ; ex:hierarchyID "1.1.5.1" ;
    ex:apqcSourceText "Identifying opportunities for restructuring the organization, through an analysis of internal viability and external contingency. Conduct a broad-based survey of the market landscape, taking the large-scale trends and movements into account, to determine the necessity and possibility of restructuring the organization. Review the organization's internal capacities, the readiness of its process frameworks, the robustness of its financials, the capableness of its systems, the resourcefulness of its personnel, etc. for assimilating an extensive overhaul." ;
    rdfs:label "Identify restructuring opportunities" ;
    skos:definition "An Act of Identification that has as input internal-capability data and market data and has as output a restructuring opportunity analysis registering candidate restructuring opportunities." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment sense): it discerns and registers restructuring opportunities from internal and market review." ;
    skos:example "A strategy team surveys the market and internal readiness and lists viable restructuring opportunities." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InternalCapabilityData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MarketData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RestructuringOpportunityAnalysis ] .

ex:P16794 a owl:Class ;
    ex:pcfID "16794" ; ex:hierarchyID "1.1.5.2" ;
    ex:apqcSourceText "Auditing the status quo of the probabilities, before formalizing any restructuring of the organization with another entity. Systematically investigate all entities discerned to be of interest in Identify restructuring opportunities [16793], to verify all tangible and substantial facts. Consider engaging specialist professional services including legal, accounting, and consulting help." ;
    rdfs:label "Perform due-diligence" ;
    skos:definition "An Act of Appraisal that has as input a restructuring opportunity analysis and has as output a due-diligence report verifying the tangible and substantial facts about candidate entities." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): an audit verifying facts is an evaluation/judgement. Professional-services providers noted as typical (non-definitional) participant in source." ;
    skos:example "Advisors audit a target company's financials and legal status and issue a due-diligence report." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RestructuringOpportunityAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DueDiligenceReport ] .

ex:P16795 a owl:Class ;
    ex:pcfID "16795" ; ex:hierarchyID "1.1.5.3" ;
    ex:apqcSourceText "Examining various options shortlisted for assimilating new entities into the organization or dissociating from it. Undertake a piecemeal and comprehensive consideration of each option identified for acquisition, merger, de-merger, and divestment. Consider intangible and non-material aspects of the entities involved and synergic aspects. Consider the assistance of specialist professional services." ;
    rdfs:label "Analyze deal options" ;
    skos:definition "An Act of Analysis that has as input a due-diligence report and has as output a deal-option analysis comparing acquisition, merger, de-merger, and divestment options." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis: it examines and compares shortlisted deal options. Its APQC tasks are process parts." ;
    skos:example "A corporate-development team compares acquisition and divestment options and documents a deal-option analysis." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DueDiligenceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DealOptionAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16796 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16797 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16798 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16799 ] .

ex:P16796 a owl:Class ;
    ex:pcfID "16796" ; ex:hierarchyID "1.1.5.3.1" ;
    ex:apqcSourceText "Appraising entities identified as being suitable for acquisition, taking into account the restructuring opportunities in the internal and external context. Verify the appropriateness and viability of the short-listed options. Ensure these entities pertain to the state-of-affairs in the market, as well as fit with the resources and capabilities of the organization." ;
    rdfs:label "Evaluate acquisition options" ;
    skos:definition "An Act of Appraisal that has as input a deal-option analysis and has as output a business value assessment of the suitability and viability of entities shortlisted for acquisition." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it appraises acquisition candidates for fit and viability." ;
    skos:example "An M&A team appraises an acquisition target's fit and reports its business value." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DealOptionAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessValueAssessment ] .

ex:P16797 a owl:Class ;
    ex:pcfID "16797" ; ex:hierarchyID "1.1.5.3.2" ;
    ex:apqcSourceText "Appraising entities identified as being suitable for a merger, taking stock of the restructuring opportunities within the firm and the market. Verify the appropriateness and viability of such options. Assess these entities to ensure their pertinence to the contextual state-of-affairs in the market, as well as a fit with the resources and capabilities of the organization itself. (This process can be carried out, in its entirety, by qualified in-house personnel or may be designated to specialist professional services providers.)" ;
    rdfs:label "Evaluate merger options" ;
    skos:definition "An Act of Appraisal that has as input a deal-option analysis and has as output a business value assessment of the suitability and viability of entities shortlisted for a merger." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal). In-house personnel or professional-services providers are typical (non-definitional) participants per source." ;
    skos:example "A strategy team appraises a merger candidate's fit and reports its business value." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DealOptionAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessValueAssessment ] .

ex:P16798 a owl:Class ;
    ex:pcfID "16798" ; ex:hierarchyID "1.1.5.3.3" ;
    ex:apqcSourceText "Evaluating departments and subsidiaries within the organization, and/or previously merged entities, to assess the appropriateness of a de-merger, taking account of the fit between these entities as well as any relevant externalities. Examine the pertinence and soundness of a formalized dissociation." ;
    rdfs:label "Evaluate de-merger options" ;
    skos:definition "An Act of Appraisal that has as input a deal-option analysis and has as output a business value assessment of the appropriateness of de-merging departments, subsidiaries, or previously merged entities." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges the soundness of a de-merger." ;
    skos:example "A corporate-development team evaluates spinning off a subsidiary and reports its business value." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DealOptionAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessValueAssessment ] .

ex:P16799 a owl:Class ;
    ex:pcfID "16799" ; ex:hierarchyID "1.1.5.3.4" ;
    ex:apqcSourceText "Evaluating departments and/or subsidiaries within the organization to assess the appropriateness of a divestment, taking account of all market externalities. Examine any internal entities that have been identified to be suitable for dismemberment from the organization. Ensure the pertinence and soundness of such a move." ;
    rdfs:label "Evaluate divesture options" ;
    skos:definition "An Act of Appraisal that has as input a deal-option analysis and has as output a business value assessment of the appropriateness of divesting departments or subsidiaries." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges the soundness of a divestment." ;
    skos:example "A strategy team evaluates divesting a business unit and reports its business value." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DealOptionAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessValueAssessment ] .

####################################################################
# 3.2  PROCESS GROUP 1.2  "Develop business strategy" (PCF 10015)
####################################################################

ex:P10015 a owl:Class ;
    ex:pcfID "10015" ; ex:hierarchyID "1.2" ;
    ex:apqcSourceText "Developing an organization's mission statement, strategy, and business design. Create a concise statement that clearly articulates the mission of the organization, outlining practicable targets to Establish a strategic vision [10020]. Delineate strategic options by matching these alternatives with the organization's internal capabilities. Create an organizational design, and identify goals by developing strategies at the functional and process levels." ;
    rdfs:label "Develop business strategy" ;
    skos:definition "An Act of Planning that develops an organization's mission statement, strategy, and business design and produces a business strategy together with an organizational design." ;
    rdfs:comment "Models APQC process group 1.2 as an occurrent. Its APQC dotted children are process parts (cco:ont00001777), not subclasses." ;
    skos:example "An organization's annual strategic-planning programme that produces a refreshed mission, long-term strategy, and organizational design." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10037 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10038 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10039 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10040 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10041 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10042 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10043 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19959 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18916 ] .

ex:P10037 a owl:Class ;
    ex:pcfID "10037" ; ex:hierarchyID "1.2.1" ;
    ex:apqcSourceText "Establishing an overarching, compact statement that concisely underscores the mission of the organization. Define and communicate a clear and succinct mission statement, which encapsulates how the organization aims to proceed in order to Establish a strategic vision [10020]. Solicit critical inputs from senior management and strategy executives, and collaborate with marketing or personnel from allied functions." ;
    rdfs:label "Develop overall mission statement" ;
    skos:definition "An Act of Formulation that defines and communicates an organization's mission and produces a mission statement." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (subClassOf Act of Planning). Senior management/strategy personnel are typical (non-definitional) participants per the source." ;
    skos:example "An executive team drafts, ratifies, and circulates a one-paragraph corporate mission statement." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MissionStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10044 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10045 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10046 ] .

ex:P10044 a owl:Class ;
    ex:pcfID "10044" ; ex:hierarchyID "1.2.1.1" ;
    ex:apqcSourceText "Defining the status quo relating to the de facto core of what the business is. Reflect over the fundamental essence of what the business accomplishes and the manner in which it operates. Look beyond the obvious solution capabilities to delineate capacities that form the basis of the business engine. Involve senior executives and management personnel and possibly professional services providers." ;
    rdfs:label "Define current business" ;
    skos:definition "An Act of Analysis that examines what the business does and the capacities that underpin it and produces a current-business analysis describing the status quo." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis: 'reflect over' and 'delineate capacities' is examination of the status quo. Output changed (Gate-F) from the Directive ex:BusinessConcept to the Descriptive ex:CurrentBusinessAnalysis so the output's descriptive kind agrees with the Analysis genus (Golden Principle). ex:BusinessConcept (Directive) is reserved for the formulation acts P10045 'Formulate mission' and P17040 'Define the business concept and long-term vision'." ;
    skos:example "A strategy team documents the firm's de-facto business and core capacities before redrafting the mission." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InternalCapabilityData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CurrentBusinessAnalysis ] .

ex:P10045 a owl:Class ;
    ex:pcfID "10045" ; ex:hierarchyID "1.2.1.2" ;
    ex:apqcSourceText "Outlining actionable objectives that effectively set a course to fulfill the organization's vision. In this fundamental activity, articulate certain goals or targets in broad but practicable terms to reach long-term objectives." ;
    rdfs:label "Formulate mission" ;
    skos:definition "An Act of Formulation that articulates the organization's mission as actionable objectives and produces a mission statement." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: 'outline actionable objectives' composes the mission (a Directive ICE)." ;
    skos:example "Executives translate the long-term vision into a concise, actionable mission statement." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MissionStatement ] .

ex:P10046 a owl:Class ;
    ex:pcfID "10046" ; ex:hierarchyID "1.2.1.3" ;
    ex:apqcSourceText "Developing and executing a communication strategy to convey the mission statement. Create a universal communication strategy and appropriate delivery channels, with the objective of leveraging the latter to execute the former. Convey the inherent message of the mission to all stakeholders, including employees, customers, and the public. Ensure collaboration between senior strategy personnel and the communications/marketing team." ;
    rdfs:label "Communicate mission" ;
    skos:definition "An Act of Communication that conveys an organization's mission statement to its stakeholders." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): an existing mission statement ICE is transferred from the organization to its stakeholders. The mission statement is the definitional input being conveyed; the Stakeholder participants are the recipients. The ex:CommunicationStrategy output is demoted (Gate-F, Phase-3): a communication strategy is only a TYPICAL vehicle (not every instance produces a fresh strategy), so it is recorded here rather than as an existential has-output." ;
    skos:example "Leadership rolls out the new mission to employees, customers, and the public across email, town halls, and the website." ;
    rdfs:subClassOf cco:ont00000228 ,   # Planned Act (asserted: Act of Communication subClassOf Planned Act in CCO; stated locally so standalone Gate C/S2 resolves)
        cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MissionStatement ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

ex:P10038 a owl:Class ;
    ex:pcfID "10038" ; ex:hierarchyID "1.2.2" ;
    ex:apqcSourceText "Assessing sets of strategic decisions designed to drive the organization's long-term objectives. Identify various strategies concerning core functional areas. Appraise strategic options in light of auxiliary decision frameworks that ensure smooth functioning, the advancement of functional efficiencies, and vitality. Involve senior management executives, especially strategy and/or business unit personnel, with need-based consultative assistance from professional services providers." ;
    rdfs:label "Define and evaluate strategic options to achieve the mission" ;
    skos:definition "An Act of Appraisal that defines candidate strategic options and evaluates them against the organization's objectives, producing a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the group's defining act is appraising sets of strategic decisions." ;
    skos:example "Strategy leadership enumerates and weighs make-vs-buy, B2B, B2C, partnership, and improvement options before committing to a direction." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10047 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10048 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21606 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21607 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21608 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21609 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21610 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21611 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21612 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21613 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21614 ] .

ex:P10047 a owl:Class ;
    ex:pcfID "10047" ; ex:hierarchyID "1.2.2.1" ;
    ex:apqcSourceText "Defining the various options available to achieve the goals highlighted in the mission statement. Delineate (in accordance with a predefined criteria) the various permutations of strategic decisions that would help the organization achieve the objectives outlined in Develop overall mission statement [10037]. Involve senior management and key strategy personnel, with timely help from professional services providers." ;
    rdfs:label "Define strategic options" ;
    skos:definition "An Act of Formulation that delineates the candidate strategic options available to achieve the organization's mission and produces a set of strategic options." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: defining/delineating options composes prescriptive option specifications. The mission statement is a definitional input." ;
    skos:example "A strategy team enumerates make-vs-buy and market-entry permutations consistent with the mission." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MissionStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOption ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P18083 ] .

ex:P18083 a owl:Class ;
    ex:pcfID "18083" ; ex:hierarchyID "1.2.2.1.1" ;
    ex:apqcSourceText "Supporting the design, manufacture and distribution of product and services through the extended enterprise model.  This is concerned with the strategic decisions on make vs buy, in house or out sourced.  Senior Executives map out how they want to run their business.  Make strategic choices as to whether to buy in components / sub-assemblies, run their own distribution fleet or contract out, own their dealerships or franchise out, etc.  Strategize with partnerships. Collaborate design consideration at strategy level for automotive and procurement act within the Target Operating Model set at strategy level." ;
    rdfs:label "Select partnerships and relationships to support the extended enterprise" ;
    skos:definition "An Act of Selection that chooses among make-versus-buy and partnership options for the extended enterprise and produces a partnership selection decision prescribing the chosen relationships." ;
    rdfs:comment "Anchored to ex:ActOfSelection: 'make strategic choices' commits to make-vs-buy and partnership options. Added (Gate-F) the Directive chosen-option output ex:PartnershipSelectionDecision required by the Selection genus (the Golden Principle ties a Selection act to a Directive decision output); previously only the Descriptive ex:StrategicOptionAnalysis was asserted, which the genus alone did not satisfy. The analysis is retained as the supporting evidence the decision rests on." ;
    skos:example "Executives decide to outsource distribution and franchise dealerships rather than run them in-house." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicOption ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PartnershipSelectionDecision ] .

ex:P10048 a owl:Class ;
    ex:pcfID "10048" ; ex:hierarchyID "1.2.2.2" ;
    ex:apqcSourceText "Scoping and probing to study the impact of strategic options for fulfilling the organization's objectives. Estimate a measure of the impact effectuated by each set of strategic decisions, which comprise Define strategic options [10047]. Closely examine the consequences of each option." ;
    rdfs:label "Assess and analyze impact of each option" ;
    skos:definition "An Act of Appraisal that estimates and examines the impact of each strategic option and produces a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): 'estimate a measure of the impact' is an evaluation." ;
    skos:example "Analysts model the projected impact of each candidate strategy on revenue and operations." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicOption ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P13289 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P13290 ] .

ex:P13289 a owl:Class ;
    ex:pcfID "13289" ; ex:hierarchyID "1.2.2.2.1" ;
    ex:apqcSourceText "Determine impacts of elements such as staffing, skills, training, new markets, technology, or policies within operating model which needs change." ;
    rdfs:label "Identify implications for key operating model business elements that require change" ;
    skos:definition "An Act of Identification that discerns which operating-model elements require change under a strategic option and produces a strategic-option analysis of those implications." ;
    rdfs:comment "Anchored to ex:ActOfIdentification: 'determine impacts ... which need change' discerns and registers affected elements." ;
    skos:example "An analyst lists the staffing and policy changes a candidate strategy would force on the operating model." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicOption ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P13290 a owl:Class ;
    ex:pcfID "13290" ; ex:hierarchyID "1.2.2.2.2" ;
    ex:apqcSourceText "Determining key factors for technology ROI, benefits, architecture, etc." ;
    rdfs:label "Identify implications for key technology aspects" ;
    skos:definition "An Act of Identification that discerns the key technology factors implicated by a strategic option and produces a strategic-option analysis of technology implications." ;
    rdfs:comment "Anchored to ex:ActOfIdentification: 'determining key factors for technology ROI, benefits, architecture' discerns and registers the technology implications of an option." ;
    skos:example "An architect identifies the ROI and architecture impacts of a proposed strategy." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicOption ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P21606 a owl:Class ;
    ex:pcfID "21606" ; ex:hierarchyID "1.2.2.3" ;
    ex:apqcSourceText "Evaluating future business to business opportunities against past and current approaches and performance. Gather insights into what competitors and other similar organizations are doing and the needs, goals, and expectations of stakeholders and partners to understand potential future impact." ;
    rdfs:label "Evaluate B2B options" ;
    skos:definition "An Act of Appraisal that evaluates future business-to-business opportunities against current performance and produces a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal). Performance records are the definitional comparison baseline; stakeholder/partner expectations are typical inputs recorded informally." ;
    skos:example "Strategists weigh new B2B channels against the firm's historical B2B performance." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P21607 a owl:Class ;
    ex:pcfID "21607" ; ex:hierarchyID "1.2.2.4" ;
    ex:apqcSourceText "Evaluating future business to customer opportunities against past and current approaches and performance. Gather insights into what competitors and other similar organizations are doing and the needs, goals, and expectations of customers and partners to understand potential future impact." ;
    rdfs:label "Evaluate B2C options" ;
    skos:definition "An Act of Appraisal that evaluates future business-to-customer opportunities against current performance and produces a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal). Performance records are the definitional baseline; customer needs/partner expectations are typical inputs recorded informally." ;
    skos:example "Strategists assess new direct-to-consumer offerings against historical B2C results." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P21608 a owl:Class ;
    ex:pcfID "21608" ; ex:hierarchyID "1.2.2.5" ;
    ex:apqcSourceText "Evaluating partnership and alliance opportunities to deliver products/services. Understand existing product and market models in use across the markets you serve, evolving trends, and the cost/benefit of potential new/updated partnership/alliance options." ;
    rdfs:label "Evaluate partner/alliance options" ;
    skos:definition "An Act of Appraisal that evaluates the cost and benefit of partnership and alliance opportunities and produces a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): cost/benefit evaluation of partnership options." ;
    skos:example "An alliance team weighs the cost and benefit of candidate distribution partners." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P21609 a owl:Class ;
    ex:pcfID "21609" ; ex:hierarchyID "1.2.2.6" ;
    ex:apqcSourceText "Evaluating intellectual property acquisition options available to scale, modernize, and/or extend product/service reach. Understand the cost, risk, timing and lifecycle value of candidate acquisitions." ;
    rdfs:label "Evaluate IP acquisition options" ;
    skos:definition "An Act of Appraisal that evaluates the cost, risk, and lifecycle value of intellectual-property acquisition options and produces a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): evaluation of cost/risk/value of candidate IP acquisitions." ;
    skos:example "A team appraises licensing versus acquiring a patent portfolio." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P21610 a owl:Class ;
    ex:pcfID "21610" ; ex:hierarchyID "1.2.2.7" ;
    ex:apqcSourceText "Evaluating innovation options to advance technology, products/services, and/or operational performance." ;
    rdfs:label "Evaluate innovation options" ;
    skos:definition "An Act of Appraisal that evaluates innovation options for advancing technology, products, services, or operational performance and produces a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): evaluation of candidate innovation options." ;
    skos:example "An innovation board weighs candidate R&D bets for the coming cycle." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P21611 a owl:Class ;
    ex:pcfID "21611" ; ex:hierarchyID "1.2.2.8" ;
    ex:apqcSourceText "Evaluating sustainability requirements, stakeholder expectations, and value proposition for options. Understand the potential activities and changes across environmental, social, and governance, the effort required, cost to implement, and benefits gained. The analysis should consider sustainable product/service lifecycles, operations, infrastructure, performance, and workforce." ;
    rdfs:label "Evaluate sustainability options" ;
    skos:definition "An Act of Appraisal that evaluates sustainability requirements and stakeholder expectations across environmental, social, and governance dimensions and produces a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): cost/benefit/effort evaluation of ESG options." ;
    skos:example "A sustainability office appraises the cost and benefit of carbon-reduction initiatives." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P21612 a owl:Class ;
    ex:pcfID "21612" ; ex:hierarchyID "1.2.2.9" ;
    ex:apqcSourceText "Evaluating options for global support services and functions. This should include structure, scale, adaptability to change, and alternative delivery models to balance cost, performance, and customer value." ;
    rdfs:label "Evaluate global support options" ;
    skos:definition "An Act of Appraisal that evaluates options for global support services and delivery models and produces a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): evaluation balancing cost, performance, and customer value of global-support options." ;
    skos:example "A shared-services team appraises centralized versus regional global support models." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P21613 a owl:Class ;
    ex:pcfID "21613" ; ex:hierarchyID "1.2.2.10" ;
    ex:apqcSourceText "Evaluating options for shared services and support functions. This should include structure, scale, adaptability to change, and alternative delivery models to balance cost, performance, and operational efficiencies." ;
    rdfs:label "Evaluate shared services options" ;
    skos:definition "An Act of Appraisal that evaluates options for shared services and delivery models and produces a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): evaluation balancing cost, performance, and operational efficiency of shared-services options." ;
    skos:example "A team appraises consolidating finance and HR into a shared-services center." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P21614 a owl:Class ;
    ex:pcfID "21614" ; ex:hierarchyID "1.2.2.11" ;
    ex:apqcSourceText "Evaluating options to enhance and optimize processes and functional areas. Understand alternatives to strengthen business capabilities, enhance process efficiencies, and advance performance standards." ;
    rdfs:label "Evaluate lean/continuous improvement options" ;
    skos:definition "An Act of Appraisal that evaluates options to optimize processes and functional areas and produces a strategic-option analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): evaluation of process-improvement alternatives." ;
    skos:example "A continuous-improvement office appraises lean initiatives for the operations division." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicOptionAnalysis ] .

ex:P10039 a owl:Class ;
    ex:pcfID "10039" ; ex:hierarchyID "1.2.3" ;
    ex:apqcSourceText "Developing a strategy for the achievement of business goals over the distant future. Adopt one of the strategic options for realizing its mission over the long term. Enlist senior management executives, comprising strategy and/or business unit personnel." ;
    rdfs:label "Set/Develop long-term enterprise strategy" ;
    skos:definition "An Act of Formulation that adopts a strategic option and develops it into a long-term enterprise strategy, producing a business strategy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): develops the long-term strategy. The chosen strategic option is the definitional input." ;
    skos:example "The executive committee commits to and elaborates a ten-year enterprise strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicOption ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16803 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14189 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16805 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19952 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19950 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19951 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P14197 ] .

ex:P16803 a owl:Class ;
    ex:pcfID "16803" ; ex:hierarchyID "1.2.3.1" ;
    ex:apqcSourceText "Defining direction and plan objectives for partnering with other companies to deliver product/services. Focus on creating a vision and strategic objectives and culminate in creating measures for the strategic alliance or partnership." ;
    rdfs:label "Develop partner/alliance strategy" ;
    skos:definition "An Act of Formulation that defines the direction, objectives, and measures for partnering with other companies and produces a business strategy for alliances." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: creating a vision, objectives, and measures composes a partnership strategy." ;
    skos:example "An alliance office drafts the multi-year partnership strategy and its success measures." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] .

ex:P14189 a owl:Class ;
    ex:pcfID "14189" ; ex:hierarchyID "1.2.3.2" ;
    ex:apqcSourceText "Formulating strategic options that create opportunities for the sustenance and prosperity of the business in the long run. Go beyond business longevity to consider alternate strategies that allow the organizations preservation of vitality over time. Earmark resources and target processes, the former of which are dedicated to the absorption of sustainable practices in the latter." ;
    rdfs:label "Develop sustainability strategy" ;
    skos:definition "An Act of Formulation that composes strategies for the long-run sustenance and vitality of the business and produces a business strategy for sustainability." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: composes a sustainability strategy." ;
    skos:example "A sustainability office formulates the firm's long-term ESG strategy and resource commitments." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] .

ex:P16805 a owl:Class ;
    ex:pcfID "16805" ; ex:hierarchyID "1.2.3.3" ;
    ex:apqcSourceText "Defining a strategy for corporate development. Include providing a framework for evaluating merger and acquisition candidates; and planning for a value creation through merging/demerging with a company, acquiring a company, or exiting from an already merged/acquired company." ;
    rdfs:label "Develop merger/demerger/acquisition/exit strategy" ;
    skos:definition "An Act of Formulation that defines a corporate-development strategy for mergers, demergers, acquisitions, and exits and produces a business strategy together with a framework for evaluating candidates." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: composes a strategy and an evaluation framework. The candidate-evaluation framework is recorded informally as a secondary output." ;
    skos:example "Corporate development drafts the M&A strategy and the screening criteria for targets." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] .

ex:P19952 a owl:Class ;
    ex:pcfID "19952" ; ex:hierarchyID "1.2.3.4" ;
    ex:apqcSourceText "Developing a plan and vision to encourage advancements in technology or product/services. Create a roadmap for changing or innovating the business model to make business operations more competitive. Set up new R&D services for changing or bringing new value propositions, services, production processes, and invention of technology not previously used by competitors etc." ;
    rdfs:label "Develop innovation strategy" ;
    skos:definition "An Act of Formulation that composes a plan and roadmap to advance technology and products and produces a business strategy for innovation." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: composes an innovation strategy/roadmap." ;
    skos:example "An R&D leadership team formulates the three-year innovation roadmap." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] .

ex:P19950 a owl:Class ;
    ex:pcfID "19950" ; ex:hierarchyID "1.2.3.5" ;
    ex:apqcSourceText "Developing a plan to deploy support services and support functions throughout the organization globally. Arrange the organizations functional support areas to create efficiencies of scale in the delivery of support services, globally." ;
    rdfs:label "Develop global support strategy" ;
    skos:definition "An Act of Formulation that composes a plan to deploy support services globally and produces a business strategy for global support." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: composes a global-support strategy." ;
    skos:example "A shared-services office formulates the plan to deliver global support at scale." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] .

ex:P19951 a owl:Class ;
    ex:pcfID "19951" ; ex:hierarchyID "1.2.3.6" ;
    ex:apqcSourceText "Charting a plan to leverage internal services and support functions throughout the organization. Delineate a framework of parameters and criteria to selectively filter service areas for inclusion among the organizations common resources. Arrange the organizations functional areas to create efficiencies of scale in the delivery of internal services." ;
    rdfs:label "Develop shared services strategy" ;
    skos:definition "An Act of Formulation that charts a plan to leverage internal shared services and produces a business strategy for shared services." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: composes a shared-services strategy." ;
    skos:example "A transformation office formulates the strategy to consolidate functions into shared services." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] .

ex:P14197 a owl:Class ;
    ex:pcfID "14197" ; ex:hierarchyID "1.2.3.7" ;
    ex:apqcSourceText "Developing strategies for the optimization of processes and the improvement of functional areas in order to improve the bottom line. Create a road map of decision choices that would allow the organization to continuously enhance process efficiencies and advance performance standards." ;
    rdfs:label "Develop lean/continuous improvement strategy" ;
    skos:definition "An Act of Formulation that composes a roadmap for continuous optimization of processes and functional areas and produces a business strategy for continuous improvement." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: composes a continuous-improvement strategy." ;
    skos:example "A lean office formulates the multi-year continuous-improvement roadmap." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] .

ex:P10040 a owl:Class ;
    ex:pcfID "10040" ; ex:hierarchyID "1.2.4" ;
    ex:apqcSourceText "Aligning the approach and method of individual units, departments, systems, and operations within the organization, in accordance with the larger strategic course adopted. Employ the organization's strategic path to guide the functions, divisions, and operations. Calibrate the plan and method of each functional area, as well as the processes therein, to Select the long-term business strategy [10039]." ;
    rdfs:label "Coordinate and align cross-functional and process strategies" ;
    skos:definition "An Act of Formulation that calibrates the plans of individual units and processes to the adopted enterprise strategy and produces a strategy alignment plan." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): aligning unit plans to the enterprise strategy composes a coordinated plan. Output replaced (Gate-F) from the stakeholder-oriented ex:StakeholderAlignmentPlan (which concerns orienting stakeholders around the vision, the subject of 1.1.4.2) with the units/processes-oriented ex:StrategyAlignmentPlan, which matches the source ('aligning the approach and method of individual units, departments, systems, and operations'). The business strategy is the definitional input. Leaf process." ;
    skos:example "A PMO calibrates each division's annual plan to the enterprise strategy and publishes the alignment plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategyAlignmentPlan ] .

ex:P10041 a owl:Class ;
    ex:pcfID "10041" ; ex:hierarchyID "1.2.5" ;
    ex:apqcSourceText "Formulating a design for the organization's resources that allow it to meet its objectives. Develop a new framework for molding the organization's various processes into a coherent and seamless whole." ;
    rdfs:label "Create organizational design" ;
    skos:definition "An Act of Formulation that designs a framework for the organization's resources and processes and produces an organizational design." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): composes an organizational design." ;
    skos:example "An org-design team produces a new operating-structure framework aligned to strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalDesign ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10049 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10050 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10051 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10052 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10053 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10054 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10055 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10056 ] .

ex:P10049 a owl:Class ;
    ex:pcfID "10049" ; ex:hierarchyID "1.2.5.1" ;
    ex:apqcSourceText "Evaluating the structural makeup of the organization, including pertinent features of and associated synergies among constituent elements. Examine the organization's architectural framework, paying close attention to the individual elements, the relations among them, and the conjoint and co-acting forces therein. Analyze functions and processes, as well as work-related positions. Scrutinize various relevant characteristics associated with each of them, depending upon the scale, scope, and type of organization." ;
    rdfs:label "Evaluate breadth and depth of organizational structure" ;
    skos:definition "An Act of Appraisal that evaluates the structural makeup and synergies of the organization and produces an organizational structure assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): evaluation/judgement of structure." ;
    skos:example "An org-design analyst assesses the firm's span-of-control and reporting layers." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalStructureAssessment ] .

ex:P10050 a owl:Class ;
    ex:pcfID "10050" ; ex:hierarchyID "1.2.5.2" ;
    ex:apqcSourceText "Appraising job-specific roles within the organizational chart and their hierarchical architecture. Analyze a map of work-related roles within the organizational structure. Examine the value added by the positions associated with jobs to be performed and how they stack up within the organization's operations." ;
    rdfs:label "Perform job-specific roles mapping and value-added analyses" ;
    skos:definition "An Act of Analysis that maps job-specific roles within the organizational chart and examines the value added by each position, producing an organizational structure assessment." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis: 'analyze a map of work-related roles ... examine the value added' is examination producing an understanding." ;
    skos:example "An analyst maps every role to its value contribution across operations." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalStructureAssessment ] .

ex:P10051 a owl:Class ;
    ex:pcfID "10051" ; ex:hierarchyID "1.2.5.3" ;
    ex:apqcSourceText "Examining the constituent exercises and undertakings within a work-related position for the purpose of effective delegation. Deconstruct job-specific roles into activities and visualize the relations among them, with the objective of assigning responsibilities to the appropriate personnel." ;
    rdfs:label "Develop role activity diagrams to assess hand-off activity" ;
    skos:definition "An Act of Analysis that deconstructs job-specific roles into their constituent activities and produces a role activity diagram." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis: deconstruct roles into activities and visualize their relations." ;
    skos:example "An analyst breaks a manager role into tasks and charts the hand-offs between them." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RoleActivityDiagram ] .

ex:P10052 a owl:Class ;
    ex:pcfID "10052" ; ex:hierarchyID "1.2.5.4" ;
    ex:apqcSourceText "Organizing workshop sessions to adopt organizational redesign. Communicate the organizational structure and mapping of responsibilities against job roles in order to facilitate an effective understanding among personnel. Use a collaborative process that may include participative workshop sessions." ;
    rdfs:label "Perform organization redesign workshops" ;
    skos:definition "An Act of Communication that conveys the proposed organizational design to personnel through participative workshop sessions to build shared understanding." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): the workshop transfers the organizational design ICE to personnel. The organizational design is the definitional input; personnel are participants. CHOSEN READING (Gate-F): Communication, because the source's purpose is to 'COMMUNICATE the organizational structure ... to facilitate an effective UNDERSTANDING among personnel' -- conveyance of an existing ICE. Rejected ex:ActOfFormulation (the design already exists; the workshop disseminates rather than composes it) and cco:ont00000234 Act of Training (no skills/values are imparted, only the structure is explained)." ;
    skos:example "Facilitators run redesign workshops to walk staff through the new structure and role map." ;
    rdfs:subClassOf cco:ont00000228 ,   # Planned Act (asserted: Act of Communication subClassOf Planned Act in CCO; stated locally so standalone Gate C/S2 resolves)
        cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:OrganizationalDesign ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:StrategyPersonnel ] .

ex:P10053 a owl:Class ;
    ex:pcfID "10053" ; ex:hierarchyID "1.2.5.5" ;
    ex:apqcSourceText "Fleshing out the connections and dependencies among the various units of the organization. Delineate the relationship among business units or process frameworks within the organization, in terms of activities, synergies, and shared resources and responsibilities. Formalize relationships among business units so that any mutual coherence is clearly understood and can be attended to." ;
    rdfs:label "Design the relationships between organizational units" ;
    skos:definition "An Act of Formulation that delineates and formalizes the relationships and dependencies among the organization's units and produces an organizational design of inter-unit relationships." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): formalizes relationships as part of the organizational design." ;
    skos:example "Designers formalize the dependencies and shared resources between two divisions." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalDesign ] .

ex:P10054 a owl:Class ;
    ex:pcfID "10054" ; ex:hierarchyID "1.2.5.6" ;
    ex:apqcSourceText "Creating an understanding of the fit between job roles and organizational processes in order to properly place personnel. Deconstruct key processes into constituent activities, and examine job-related roles. Take cues from Develop role activity diagrams to assess hand-off activity [10051]. Map appropriate positions against these important processes, which in turn expedite the deployment of staff members." ;
    rdfs:label "Develop role analysis and activity diagrams for key processes" ;
    skos:definition "An Act of Analysis that deconstructs key processes into activities and examines the fit between job roles and those processes, producing a role activity diagram." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis: deconstruct key processes and examine roles. Takes cues from 1.2.5.3 (PCF 10051) per the source." ;
    skos:example "An analyst maps roles to each step of the order-to-cash process." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RoleActivityDiagram ] .

ex:P10055 a owl:Class ;
    ex:pcfID "10055" ; ex:hierarchyID "1.2.5.7" ;
    ex:apqcSourceText "Probing the repercussions of all practicable organizational design options. Analyze the significance and impact of workable organizational structure options. Closely examine the long-term impact of these frameworks over the functioning of the organization." ;
    rdfs:label "Assess organizational implication of feasible alternatives" ;
    skos:definition "An Act of Appraisal that evaluates the long-term repercussions of each feasible organizational design option and produces an organizational structure assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): evaluation of options. The organizational design options are the definitional input." ;
    skos:example "An analyst weighs the multi-year impact of three candidate structures." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:OrganizationalDesign ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalStructureAssessment ] .

ex:P10056 a owl:Class ;
    ex:pcfID "10056" ; ex:hierarchyID "1.2.5.8" ;
    ex:apqcSourceText "Embracing and ratifying a new organizational structure. (Assume the new framework to be the best fit through Assess the organizational implications of feasible alternatives [10055].)" ;
    rdfs:label "Migrate to new organization" ;
    skos:definition "A Planned Act that ratifies the best-fit organizational design already determined among the assessed alternatives and produces an organizational-structure adoption decision adopting the new structure." ;
    rdfs:comment "Output replaced (Gate-F) from the subject-mismatched ex:InitiativeSelectionDecision (which prescribes which strategic INITIATIVES to pursue) with the subject-matched Directive ex:OrganizationalStructureAdoptionDecision, parallel to ex:BusinessModelAdoptionDecision. CHOSEN READING (reconciled with sibling-in-kind P20949 'Adopt the business model'): anchored to cco:ont00000228 (Planned Act). Both leaves RATIFY a single best-fit option already settled by a prior assessment (here P10055), which is a commitment/ratification, not a choice among a candidate set -- so ex:ActOfSelection (definitionally 'chooses from a SET of candidates') does not fit. No narrower CCO act denotes ratification, so it anchors at the generic Planned Act. The organizational design is the definitional input; the ratification decision is the output." ;
    skos:example "Leadership formally ratifies the new operating structure and authorizes the move to it." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:OrganizationalDesign ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalStructureAdoptionDecision ] .

ex:P10042 a owl:Class ;
    ex:pcfID "10042" ; ex:hierarchyID "1.2.6" ;
    ex:apqcSourceText "Developing overall goals for the organization that help in accomplishing its mission. Formulate organization-wide targets in the near to middle term, which will accumulate and propel the organization to realize its long-term objectives, as outlined in Develop an overall mission statement [10037]. Enlist business unit heads or equivalent personnel, in close collaboration with senior management executives." ;
    rdfs:label "Develop and set organizational objectives" ;
    skos:definition "An Act of Formulation that develops organization-wide near- to middle-term goals supporting the mission and produces organizational objectives." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): composes objectives. The mission statement is the definitional input the objectives must support." ;
    skos:example "Leadership sets the firm's annual organization-wide objectives in support of the mission." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:MissionStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalObjective ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19953 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19954 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19955 ] .

ex:P19953 a owl:Class ;
    ex:pcfID "19953" ; ex:hierarchyID "1.2.6.1" ;
    ex:apqcSourceText "Creating and developing strategic objectives that establishes a process to outline expected outcomes and guide employees' efforts." ;
    rdfs:label "Identify organizational objectives" ;
    skos:definition "An Act of Formulation that creates strategic objectives outlining expected outcomes for the organization and produces organizational objectives." ;
    rdfs:comment "Anchored to ex:ActOfFormulation rather than ex:ActOfIdentification: the source says 'creating and developing strategic objectives', i.e. composing new prescriptive goals, not discerning pre-existing entities." ;
    skos:example "Strategy leadership drafts the outcome-oriented objectives that will guide employee effort." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalObjective ] .

ex:P19954 a owl:Class ;
    ex:pcfID "19954" ; ex:hierarchyID "1.2.6.2" ;
    ex:apqcSourceText "Establishing baselines that provide standards for assessing performance. Create metrics and KPI's for various functions/processes/activities based on organizational goals." ;
    rdfs:label "Establish baseline metrics" ;
    skos:definition "An Act of Formulation that establishes baseline metrics and KPIs as standards for assessing performance and produces a set of performance metrics." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): composes prescriptive standards. Organizational objectives are the definitional input the metrics are derived from." ;
    skos:example "A performance office defines the KPI baselines for each function from the organizational goals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:OrganizationalObjective ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceMetric ] .

ex:P19955 a owl:Class ;
    ex:pcfID "19955" ; ex:hierarchyID "1.2.6.3" ;
    ex:apqcSourceText "Defining methodology and frequency of assessment for measuring and monitoring performance of various functions/processes/activities against standard set goals." ;
    rdfs:label "Monitor performance against objective" ;
    skos:definition "An Act of Formulation that defines the methodology and frequency for measuring and monitoring the performance of functions, processes, and activities against set goals, and produces a performance-monitoring method specification." ;
    rdfs:comment "Re-anchored (Gate-F) from cco:ont00000636 (Act of Appraisal) to ex:ActOfFormulation: the source's lead verb is 'DEFINING methodology and frequency of assessment', i.e. composing a Directive monitoring-method spec, not actually rendering the value-judgement. The existential ex:PerformanceReport output is removed (it is produced by the downstream monitoring runs, not by this defining act); the new Directive output ex:PerformanceMonitoringMethodSpecification agrees with the Formulation genus. Performance metrics are the definitional standard the method monitors against." ;
    skos:example "A performance office defines the quarterly methodology and cadence for monitoring each function's KPIs." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceMetric ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceMonitoringMethodSpecification ] .

ex:P10043 a owl:Class ;
    ex:pcfID "10043" ; ex:hierarchyID "1.2.7" ;
    ex:apqcSourceText "Charting a strategic course for business units in order to leverage opportunities, sidestep hurdles, and create synergies among each other. Create strategic road maps for the organization's units--in light of their individual resources and requirements, as well as their relationships with other business units--to achieve organizational goals." ;
    rdfs:label "Formulate business unit strategies" ;
    skos:definition "An Act of Formulation that charts strategic roadmaps for the organization's business units and produces a business strategy for each unit." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): composes unit-level strategies." ;
    skos:example "Each division head drafts a unit strategy aligned to enterprise goals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19956 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19957 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19958 ] .

ex:P19956 a owl:Class ;
    ex:pcfID "19956" ; ex:hierarchyID "1.2.7.1" ;
    ex:apqcSourceText "Assessing the performance of a business unit against set organizational goals which are based on pre-defined metrics collected through various business unit operations." ;
    rdfs:label "Analyze business unit strategies" ;
    skos:definition "An Act of Appraisal that assesses a business unit's performance against organizational goals using predefined metrics and produces a performance report." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): assessing performance against goals. Performance metrics are the definitional standard input." ;
    skos:example "An analyst assesses a division's results against its KPI targets." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceMetric ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceReport ] .

ex:P19957 a owl:Class ;
    ex:pcfID "19957" ; ex:hierarchyID "1.2.7.2" ;
    ex:apqcSourceText "Determining the resources and skills of each business unit based on knowledge and technical capacity. Enable business units to meet customer needs and grow in a competitive marketplace." ;
    rdfs:label "Identify core competency for each business unit" ;
    skos:definition "An Act of Identification that discerns the resources and skills constituting each business unit's core competency and produces a core competency analysis." ;
    rdfs:comment "Anchored to ex:ActOfIdentification: 'determining the resources and skills of each business unit' discerns and registers existing capacities." ;
    skos:example "An analyst catalogs each unit's distinctive technical capabilities." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InternalCapabilityData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CoreCompetencyAnalysis ] .

ex:P19958 a owl:Class ;
    ex:pcfID "19958" ; ex:hierarchyID "1.2.7.3" ;
    ex:apqcSourceText "Evaluating existing business unit strategy based on the company's strategy and eliminate unwanted/unnecessary resources/elements and re-consider necessary resources to meet the overall company's strategy." ;
    rdfs:label "Refine business unit strategies in support of organizational strategy" ;
    skos:definition "An Act of Formulation that reformulates an existing business-unit strategy in light of the enterprise strategy, pruning and re-considering its resources and elements, and produces a refined business strategy." ;
    rdfs:comment "Re-anchored (Gate-F) from ex:ActOfSelection to ex:ActOfFormulation: the act takes an existing ex:BusinessStrategy and emits a revised ex:BusinessStrategy (a Directive plan in, a Directive plan out) -- this is reformulation of a plan, not the selection of one option from a set of candidates. Rejected Act of Selection: there is no slate of discrete candidate strategies being chosen among; the single existing strategy is being re-worked. The enterprise business strategy is the definitional input." ;
    skos:example "A division reworks its strategy to drop initiatives that conflict with the enterprise strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] .

ex:P19959 a owl:Class ;
    ex:pcfID "19959" ; ex:hierarchyID "1.2.8" ;
    ex:apqcSourceText "Defining a roadmap to meet customer expectations while considering how it will affect the business." ;
    rdfs:label "Develop customer experience strategy" ;
    skos:definition "An Act of Formulation that defines a roadmap to meet customer expectations and produces a customer experience roadmap." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): composes a customer-experience strategy." ;
    skos:example "A CX office drafts the multi-year roadmap for improving customer experience." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerExperienceRoadmap ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19960 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19964 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19971 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19974 ] .

ex:P19960 a owl:Class ;
    ex:pcfID "19960" ; ex:hierarchyID "1.2.8.1" ;
    ex:apqcSourceText "Measuring customer feedback in regard to product and services effectiveness based on overall satisfaction. The data to be analyzed is collected through surveys, customer responses, and feedbacks based on the delivered products/services." ;
    rdfs:label "Assess customer experience" ;
    skos:definition "An Act of Appraisal that measures customer feedback on product and service effectiveness and produces a customer experience assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): measuring customer feedback based on satisfaction. Customer feedback is the definitional input." ;
    skos:example "A CX team scores satisfaction from survey responses on delivered services." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerExperienceAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19961 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19962 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19963 ] .

ex:P19961 a owl:Class ;
    ex:pcfID "19961" ; ex:hierarchyID "1.2.8.1.1" ;
    ex:apqcSourceText "Creating methods to gauge customer experiences, expectations, and suggestions. Review both liked and disliked areas of product/services to be delivered. Evaluate touchpoints based on the nature of product/service in the market e.g., billboards, web sites, direct mail, service calls, etc." ;
    rdfs:label "Identify and review customer touchpoints" ;
    skos:definition "An Act of Identification that discerns and reviews the customer touchpoints relevant to a product or service and produces a customer touchpoint inventory." ;
    rdfs:comment "Anchored to ex:ActOfIdentification: 'review ... evaluate touchpoints ... e.g. billboards, web sites' discerns and registers the relevant touchpoints. Output replaced (Gate-F) from the off-target ex:CustomerExperienceAssessment (a satisfaction/feedback measure, the output of the appraisal sibling P19962) with the discernment-matched ex:CustomerTouchpointInventory (a register of touchpoints). Customer feedback is the definitional input." ;
    skos:example "A CX analyst enumerates and reviews every channel through which customers reach the brand." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerTouchpointInventory ] .

ex:P19962 a owl:Class ;
    ex:pcfID "19962" ; ex:hierarchyID "1.2.8.1.2" ;
    ex:apqcSourceText "Evaluating customer experiences, expectations, and suggestions in both liked and disliked areas of the product or services. Analyze all modes of communication, human and physical interactions, or customers experience during the relationship lifecycle with your organization. Evaluate the gaps/further development/alterations to the existing product/service to attain better customer response." ;
    rdfs:label "Assess customer experience across touchpoints" ;
    skos:definition "An Act of Appraisal that evaluates customer experiences and gaps across all touchpoints in the relationship lifecycle and produces a customer experience assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): 'evaluating customer experiences ... evaluate the gaps'. Customer feedback is the definitional input." ;
    skos:example "A CX team scores experience quality at each interaction across the customer lifecycle." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerExperienceAssessment ] .

ex:P19963 a owl:Class ;
    ex:pcfID "19963" ; ex:hierarchyID "1.2.8.1.3" ;
    ex:apqcSourceText "Analyzing the core reason for the customer experience/feedback/response about the product/service to take considerable action for better customer experience." ;
    rdfs:label "Perform root cause analysis of problematic customer experiences" ;
    skos:definition "An Act of Analysis that examines the core reasons behind problematic customer experiences and produces a root cause analysis." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis: 'analyzing the core reason for the customer experience'. Customer feedback is the definitional input." ;
    skos:example "An analyst traces recurring complaints to a flawed onboarding step." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RootCauseAnalysis ] .

ex:P19964 a owl:Class ;
    ex:pcfID "19964" ; ex:hierarchyID "1.2.8.2" ;
    ex:apqcSourceText "Creating a design of how customers interact with the business by analyzing data captured through various customer interaction and customer involvement. These will be captured through various channels such as customer satisfaction surveys, feedback forms, product reviews, targeted studies, observational studies, or voice of customer research." ;
    rdfs:label "Design customer experience" ;
    skos:definition "An Act of Formulation that designs how customers interact with the business from captured customer data and produces a customer experience roadmap." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): composes a prescriptive design. Customer data is the definitional input it is built from." ;
    skos:example "A CX team designs the target interaction model from voice-of-customer research." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerExperienceRoadmap ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16612 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19965 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19966 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19967 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19968 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19969 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19970 ] .

ex:P16612 a owl:Class ;
    ex:pcfID "16612" ; ex:hierarchyID "1.2.8.2.1" ;
    ex:apqcSourceText "Identifying a set of characteristics that define the demographic and behavioral patterns of the customer. Further, use persona scoring to design your marketing strategies around personas, and measure and optimize your interactions with the contacts classified by a certain persona." ;
    rdfs:label "Define and manage personas" ;
    skos:definition "An Act of Identification that discerns the demographic and behavioral characteristics defining customer personas and produces a customer profile." ;
    rdfs:comment "Anchored to ex:ActOfIdentification: 'identifying a set of characteristics that define ... patterns of the customer'. Modeled as a bounded act despite 'manage' in the label, because the source describes a definable identification activity producing a customer profile. Gate-F split: the source's standing 'manage and optimize your interactions with the contacts classified by a persona' aspect is NOT part of this bounded act -- it is a continuant standing function carried by the already-minted ex:CustomerExperienceManagementCapability (Organization Capability), realized in repeated CX-management acts. This leaf captures only the bounded persona-definition occurrent (R5 bounded-occurrent test)." ;
    skos:example "A marketer defines three buyer personas from demographic and behavioral data." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerProfile ] .

ex:P19965 a owl:Class ;
    ex:pcfID "19965" ; ex:hierarchyID "1.2.8.2.2" ;
    ex:apqcSourceText "Creating a story of the customer's experience: from initial contact, through the process of engagement and into a long-term relationship. The goal is to teach organization about the customer." ;
    rdfs:label "Create customer journey maps" ;
    skos:definition "An Act of Analysis that traces the customer's experience from initial contact through long-term relationship and produces a customer journey map." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis: 'creating a story of the customer's experience ... to teach the organization about the customer' produces an analytic representation." ;
    skos:example "A CX designer charts the end-to-end journey from awareness to renewal." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerJourneyMap ] .

ex:P19966 a owl:Class ;
    ex:pcfID "19966" ; ex:hierarchyID "1.2.8.2.3" ;
    ex:apqcSourceText "Defining parameters to show aggregated, consistent, and holistic representation of known data about customers. Define key parameters which enable the tracking of customers and communications across every channel." ;
    rdfs:label "Define single view of the customer for the organization" ;
    skos:definition "An Act of Formulation that defines the parameters for an aggregated, holistic representation of customer data and produces a customer profile specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): 'defining parameters ... which enable the tracking of customers' composes a prescriptive specification." ;
    skos:example "A data team defines the unified customer-record parameters spanning all channels." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerProfile ] .

ex:P19967 a owl:Class ;
    ex:pcfID "19967" ; ex:hierarchyID "1.2.8.2.4" ;
    ex:apqcSourceText "Establishing a direction and vision on how the organization behaves towards customers in a consistent, effective way. The key attributes for customer experience vision consists of emotional connection, commitments and expectations, compelling value proposition, and ease of understanding the organization's behavior." ;
    rdfs:label "Define a vision for the customer experience" ;
    skos:definition "An Act of Formulation that establishes a direction and vision for how the organization behaves toward customers and produces a strategic vision for the customer experience." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): 'establishing a direction and vision' composes a prescriptive vision; reuses ex:StrategicVision." ;
    skos:example "Leadership articulates the guiding vision for every customer interaction." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicVision ] .

ex:P19968 a owl:Class ;
    ex:pcfID "19968" ; ex:hierarchyID "1.2.8.2.5" ;
    ex:apqcSourceText "Creating a process to validate the sales process and the assumptions that underpin the business model. Understand if the products/services have a repeatable, scalable business model around that product." ;
    rdfs:label "Validate with customers" ;
    skos:definition "An Act of Appraisal that tests the assumptions underpinning the business model against customer reality and produces a customer experience assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): 'validate ... understand if the products/services have a repeatable, scalable business model' evaluates assumptions against evidence. Customer feedback is the definitional input." ;
    skos:example "A product team validates the pricing assumptions through customer interviews." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerExperienceAssessment ] .

ex:P19969 a owl:Class ;
    ex:pcfID "19969" ; ex:hierarchyID "1.2.8.2.6" ;
    ex:apqcSourceText "Aligning and defining a relevant, differentiated, and credible value proposition for the brand. Align experience to ensure that the product and service quality is consistent with brand promise and business strategies." ;
    rdfs:label "Align experience with brand values and business strategies" ;
    skos:definition "An Act of Formulation that aligns the customer experience with the brand's value proposition and business strategies and produces a customer experience roadmap." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): aligns experience to brand/strategy. The business strategy is the definitional input." ;
    skos:example "A brand team aligns the service experience to the brand promise and strategy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerExperienceRoadmap ] .

ex:P19970 a owl:Class ;
    ex:pcfID "19970" ; ex:hierarchyID "1.2.8.2.7" ;
    ex:apqcSourceText "Planning, development, and management of content-written or in other media. Getting the right content to the right user at the right time through strategic planning of content creation, delivery, and governance." ;
    rdfs:label "Develop content strategy" ;
    skos:definition "An Act of Formulation that plans the creation, delivery, and governance of content and produces a business strategy for content." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): 'strategic planning of content creation, delivery, and governance' composes a content strategy." ;
    skos:example "A content team formulates the editorial and distribution strategy for the year." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessStrategy ] .

ex:P19971 a owl:Class ;
    ex:pcfID "19971" ; ex:hierarchyID "1.2.8.3" ;
    ex:apqcSourceText "Creating a roadmap for customer experience support with an overall approach, process flow, and impact timeframe." ;
    rdfs:label "Design customer experience support structure" ;
    skos:definition "An Act of Formulation that designs the support structure for customer experience with an approach, process flow, and timeframe and produces a customer experience roadmap." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): composes a prescriptive support structure." ;
    skos:example "A CX office designs the support model and rollout timeframe for the new experience." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerExperienceRoadmap ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19972 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19973 ] .

ex:P19972 a owl:Class ;
    ex:pcfID "19972" ; ex:hierarchyID "1.2.8.3.1" ;
    ex:apqcSourceText "Determining the necessary skills and competencies required to efficiently collect customer experiences through the support structure." ;
    rdfs:label "Identify required capabilities" ;
    skos:definition "An Act of Identification that discerns the skills and competencies required to operate the customer-experience support structure and produces a required capability list." ;
    rdfs:comment "Anchored to ex:ActOfIdentification: 'determining the necessary skills and competencies required' discerns and registers needed capabilities. Output replaced (Gate-F) from the off-target ex:CoreCompetencyAnalysis (which describes an organization's strategically DIFFERENTIATING competencies) with the required-skills ex:RequiredCapabilityList, matching the source's 'necessary skills and competencies required to operate the support structure'." ;
    skos:example "A CX lead lists the analytics and service skills the support team must have." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RequiredCapabilityList ] .

ex:P19973 a owl:Class ;
    ex:pcfID "19973" ; ex:hierarchyID "1.2.8.3.2" ;
    ex:apqcSourceText "Identifying the affect of customer experience through customer experience support structure on other functions of customer services related to customer." ;
    rdfs:label "Identify impact on functional processes" ;
    skos:definition "An Act of Identification that discerns the impact of the customer-experience support structure on other customer-service functions and produces a customer experience assessment of those impacts." ;
    rdfs:comment "Anchored to ex:ActOfIdentification: 'identifying the affect ... on other functions' discerns and registers cross-functional impacts." ;
    skos:example "An analyst identifies how the new CX support model changes the call-center workflow." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerExperienceAssessment ] .

ex:P19974 a owl:Class ;
    ex:pcfID "19974" ; ex:hierarchyID "1.2.8.4" ;
    ex:apqcSourceText "Defining a standard guideline to create and execute the capacities of registering customer experiences in a timely manner. Create a common understanding of what behaviors are required to implement the strategy. Define what talent/skills your organization needs to reach customer experience goals." ;
    rdfs:label "Develop customer experience roadmap to develop and implement defined capabilities" ;
    skos:definition "An Act of Formulation that defines the guideline, behaviors, and talent needed to implement the customer-experience capabilities and produces a customer experience roadmap." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (Act of Planning): 'defining a standard guideline to create and execute the capacities' composes an implementation roadmap." ;
    skos:example "A CX office publishes the roadmap and talent plan to stand up the new capabilities." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerExperienceRoadmap ] .

ex:P18916 a owl:Class ;
    ex:pcfID "18916" ; ex:hierarchyID "1.2.9" ;
    ex:apqcSourceText "Conveying planned procedures and methods to both internal departments and external stakeholders like customers, suppliers, etc., in an effective manner based on organizational objective." ;
    rdfs:label "Communicate strategies internally and externally" ;
    skos:definition "An Act of Communication that conveys the organization's business strategy to internal departments and external stakeholders." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): an existing business strategy ICE is transferred from the organization to internal and external stakeholders. The business strategy is the definitional input; stakeholders are participants. Leaf process." ;
    skos:example "Leadership rolls out the new strategy to staff, customers, and suppliers via briefings and publications." ;
    rdfs:subClassOf cco:ont00000228 ,   # Planned Act (asserted: Act of Communication subClassOf Planned Act in CCO; stated locally so standalone Gate C/S2 resolves)
        cco:ont00000402 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessStrategy ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

####################################################################
# 3.3  PROCESS GROUP 1.3  "Develop and measure strategic initiatives" (PCF 10016)
####################################################################

ex:P10016 a owl:Class ;
    ex:pcfID "10016" ; ex:hierarchyID "1.3" ;
    ex:apqcSourceText "Managing strategic initiatives, from development through selection, execution, and evaluation. Conduct and oversee strategic projects supporting long-term objectives. Administer programs of strategic significance by developing such initiatives, select the most appropriate projects, and formulate measures to assess their impact." ;
    rdfs:label "Develop and measure strategic initiatives" ;
    skos:definition "An Act of Planning that develops, selects, executes, and evaluates programs of strategic significance and formulates the measures used to assess their impact." ;
    rdfs:comment "Models APQC process group 1.3 as a bounded occurrent (an end-to-end initiative cycle), not a standing function. Its APQC children are process parts, not subclasses (D1)." ;
    skos:example "An organization's annual strategic-initiative cycle, from drafting candidate initiatives to evaluating the executed ones." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10057 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10058 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10059 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10060 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19507 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21422 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21423 ] .

ex:P10057 a owl:Class ;
    ex:pcfID "10057" ; ex:hierarchyID "1.3.1" ;
    ex:apqcSourceText "Developing strategic projects that help fulfill long-term goals. Develop time-bound projects that are discretionary in nature and lie beyond the scope of the organization's routine operations." ;
    rdfs:label "Develop strategic initiatives" ;
    skos:definition "An Act of Formulation that composes discretionary, time-bound strategic projects supporting long-term goals and produces a strategic-initiative specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (under cco:ont00000511 Act of Planning): developing initiatives produces a Directive ICE (the specification). Children are process parts." ;
    skos:example "A strategy team drafts a slate of discretionary projects to advance the firm's ten-year goals." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicInitiativeSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19975 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19976 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19977 ] .

ex:P19975 a owl:Class ;
    ex:pcfID "19975" ; ex:hierarchyID "1.3.1.1" ;
    ex:apqcSourceText "Creating a statement of the organization's direction to guide decision making around the allocation of resources. Provide a focus on the organization's overarching goals to ensure coherent and considered action. Strategic objectives are ranked by their importance in achieving the strategic goals. All subsequent operational or tactical planning and resource allocation is based on strategic priorities" ;
    rdfs:label "Identify strategic priorities" ;
    skos:definition "An Act of Appraisal that ranks the organization's strategic objectives by their importance in achieving the strategic goals and produces a statement of strategic priorities guiding resource allocation." ;
    rdfs:comment "Re-anchored (Gate-F) from ex:ActOfIdentification to cco:ont00000636 (Act of Appraisal), matching its sibling P19980 'Prioritize strategic initiatives': the source's core operation is that 'strategic objectives are ranked by their importance', and ranking-by-importance is an evaluative judgement, not mere discernment. Rejected ex:ActOfIdentification: the objectives already exist (taken as input); the act adds a value-ordering over them. Output remains the Directive ex:StrategicPriority (the ranked priorities prescribe subsequent allocation) -- consistent with an Appraisal that issues a prescriptive ranking, as P19980 does with ex:PrioritizedInitiativeList." ;
    skos:example "Leadership ranks its objectives and issues the priorities that govern the year's budgeting." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:OrganizationalObjective ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicPriority ] .

ex:P19976 a owl:Class ;
    ex:pcfID "19976" ; ex:hierarchyID "1.3.1.2" ;
    ex:apqcSourceText "Creating a statement of the organization's direction based on what is considered \"value\" to the customer or business." ;
    rdfs:label "Develop strategic initiatives based on business/customer value" ;
    skos:definition "An Act of Formulation that composes strategic initiatives grounded in what is considered value to the customer or the business and produces a strategic-initiative specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation. The ex:BusinessValueAssessment input is demoted (Gate-F, Phase-3) from an existential has-input to this comment: the source ('based on what is considered value to the customer or business') treats value as the framing notion guiding formulation, not a formal assessment ICE that every instance must consume. Output ex:StrategicInitiativeSpecification retained." ;
    skos:example "A team frames its candidate initiatives explicitly around customer value drivers." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicInitiativeSpecification ] .

ex:P19977 a owl:Class ;
    ex:pcfID "19977" ; ex:hierarchyID "1.3.1.3" ;
    ex:apqcSourceText "Developing a process for stakeholder dialog that is integrated into the assessment of business strategies. Report on the evaluation of the business objectives, strategies, subject, or past events." ;
    rdfs:label "Review with stakeholders" ;
    skos:definition "An Act of Appraisal that evaluates an organization's business objectives and strategies and reports the resulting strategy review to stakeholders through structured dialogue." ;
    rdfs:comment "Re-anchored (Gate-F) from cco:ont00000402 (Act of Communication) to cco:ont00000636 (Act of Appraisal): the source's substance is 'report on the EVALUATION of the business objectives, strategies, ... or past events' -- the defining act is the evaluation/review, not the mere transfer of an ICE (the stakeholder dialogue is the channel through which the review is conducted and reported). The reviewed ex:BusinessStrategy is demoted from a has-input to an is-about (cco:ont00001808) on the output ICE: the new ex:StrategyReviewReport (a ex:PerformanceReport specialization) is about the business strategy. The PerformanceReport genus output is definitional (the review produces a report). Stakeholder participant retained." ;
    skos:example "Strategists hold a review session reporting strategy evaluation results to the board and partners." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategyReviewReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

ex:P10058 a owl:Class ;
    ex:pcfID "10058" ; ex:hierarchyID "1.3.2" ;
    ex:apqcSourceText "Examining projects of strategic significance that lie outside the purview of the organization's routine operations. Closely analyze strategic initiatives for their applicability and feasibility, given the organization's vision." ;
    rdfs:label "Evaluate strategic initiatives" ;
    skos:definition "An Act of Appraisal that examines strategic initiatives for applicability and feasibility against the organization's vision and produces a strategic-initiative evaluation." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): the act judges applicability and feasibility. Children are process parts." ;
    skos:example "A review board appraises each candidate initiative for fit with the firm's vision and constraints." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicInitiativeSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicInitiativeEvaluation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19978 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19979 ] .

ex:P19978 a owl:Class ;
    ex:pcfID "19978" ; ex:hierarchyID "1.3.2.1" ;
    ex:apqcSourceText "Establishing a standard measure of value to determine the business worth for each of the Identify strategic priorities [19975]. List the effectiveness and utility for every important strategic element based on the benefit it adds to the business." ;
    rdfs:label "Determine business value for each strategic priority" ;
    skos:definition "An Act of Appraisal that judges the business worth of each strategic priority against a standard measure of value and produces a business-value assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): determining worth is judging value. Input is the strategic priorities (cross-reference to PCF 19975)." ;
    skos:example "Analysts score each priority by the benefit it adds to the business." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicPriority ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessValueAssessment ] .

ex:P19979 a owl:Class ;
    ex:pcfID "19979" ; ex:hierarchyID "1.3.2.2" ;
    ex:apqcSourceText "Analyzing the value preposition; the value the customer gets from a product/services for each of your Identify strategic priorities [19975]. Customer value is the satisfaction a consumer feels after making a purchase for goods or services relative to what he/she must give up to receive them." ;
    rdfs:label "Determine the customer value for each strategic priority" ;
    skos:definition "An Act of Appraisal that judges the value a customer derives from the offerings tied to each strategic priority and produces a customer value assessment." ;
    rdfs:comment "Re-anchored (Gate-F) from ex:ActOfAnalysis to cco:ont00000636 (Act of Appraisal), matching its sibling P19978 'Determine business value for each strategic priority': 'determining customer value' (the satisfaction a consumer feels relative to what is given up) is a value-judgement, the same evaluative operation P19978 applies to business value. Output replaced from the off-target ex:CustomerNeedsAssessment (which describes needs, not value) with the Descriptive ex:CustomerValueAssessment, parallel to ex:BusinessValueAssessment. Inputs are the strategic priorities (cross-ref PCF 19975) and customer feedback." ;
    skos:example "A team appraises what customers gain from offerings tied to each strategic priority." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicPriority ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CustomerValueAssessment ] .

ex:P10059 a owl:Class ;
    ex:pcfID "10059" ; ex:hierarchyID "1.3.3" ;
    ex:apqcSourceText "Selecting relevant projects of strategic significance that create opportunities for the organization to realize its long-term objectives, on the basis of their suitability to the organization's constraints and reality. Select from the process Evaluate strategic initiatives [10058], based on their applicability and feasibility for the organization. Enlist senior management, especially strategy personnel." ;
    rdfs:label "Select strategic initiatives" ;
    skos:definition "An Act of Selection that chooses strategic initiatives from the evaluated set on the basis of suitability to the organization's constraints and produces an initiative selection decision." ;
    rdfs:comment "Anchored to ex:ActOfSelection (under cco:ont00000366 Act of Information Processing). Senior management participant is definitional (the source enlists them). Children are process parts." ;
    skos:example "Senior managers and strategists pick the initiatives the firm will fund this cycle." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicInitiativeEvaluation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:InitiativeSelectionDecision ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:SeniorManagement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19980 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19981 ] .

ex:P19980 a owl:Class ;
    ex:pcfID "19980" ; ex:hierarchyID "1.3.3.1" ;
    ex:apqcSourceText "Listing the most effective procedures in the order of most important to the least. Create measures or filter for determining which of many \"strategic initiatives\" is most important to the least important." ;
    rdfs:label "Prioritize strategic initiatives" ;
    skos:definition "An Act of Appraisal that judges strategic initiatives by importance and produces a prioritized initiative list ordering them from most to least important." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): ranking by importance is judging importance. Output is Directive (the ranking prescribes order of pursuit)." ;
    skos:example "A filter scores initiatives so the team can list them most- to least-important." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicInitiativeEvaluation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PrioritizedInitiativeList ] .

ex:P19981 a owl:Class ;
    ex:pcfID "19981" ; ex:hierarchyID "1.3.3.2" ;
    ex:apqcSourceText "Establishing procedures for communications within the organization which creates the road map for successful understanding of strategic initiatives for both business units and stakeholders (internal and external)." ;
    rdfs:label "Communicate strategic initiatives to business units and stakeholders" ;
    skos:definition "An Act of Formulation that establishes the procedures and roadmap for communicating the selected strategic initiatives to business units and stakeholders and produces a communication strategy." ;
    rdfs:comment "CHOSEN READING (Gate-F): re-anchored from cco:ont00000402 (Act of Communication) to ex:ActOfFormulation. The source is 'ESTABLISHING procedures for communications ... which creates the ROADMAP for successful understanding' -- the leaf composes a Directive ex:CommunicationStrategy (a plan), it does not itself perform the conveyance. Under this reading the business-unit and stakeholder recipients are NOT definitional participants of the formulation act (they are the audience the planned strategy will later address), so the bfo:has participant restrictions are dropped. Rejected the Act-of-Communication reading (the actual rollout) because the source's verb is 'establishing/creating' the communication scheme, not transferring an ICE. The selected initiatives (ex:InitiativeSelectionDecision) are the definitional input the strategy is built around." ;
    skos:example "Leadership drafts the communication plan and roadmap so every business unit will understand the chosen initiatives." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:InitiativeSelectionDecision ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CommunicationStrategy ] .

ex:P10060 a owl:Class ;
    ex:pcfID "10060" ; ex:hierarchyID "1.3.4" ;
    ex:apqcSourceText "Devising measures to examine strategic projects. Formulate evaluation criteria to assess the strategic initiatives for the level of impact." ;
    rdfs:label "Establish high-level measures" ;
    skos:definition "An Act of Formulation that devises evaluation criteria for assessing the impact of strategic initiatives and produces a set of performance metrics." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (under cco:ont00000511): devising measures produces a Directive ICE (the metrics). Children are process parts." ;
    skos:example "A team defines the high-level KPIs by which the initiatives' impact will be judged." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceMetric ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19982 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19983 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P19984 ] .

ex:P19982 a owl:Class ;
    ex:pcfID "19982" ; ex:hierarchyID "1.3.4.1" ;
    ex:apqcSourceText "Determining key indicators or factors responsible for driving business value. Key business value drivers comprise of operational, financial, and sustainability drivers." ;
    rdfs:label "Identify business value drivers" ;
    skos:definition "An Act of Identification that discerns the key operational, financial, and sustainability indicators responsible for driving business value and produces a register of business value drivers." ;
    rdfs:comment "Discernment sense -> ex:ActOfIdentification (shared). Output is a Descriptive ICE describing each driver." ;
    skos:example "Analysts enumerate the operational and financial factors that move enterprise value." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessValueDriver ] .

ex:P19983 a owl:Class ;
    ex:pcfID "19983" ; ex:hierarchyID "1.3.4.2" ;
    ex:apqcSourceText "Establishing baseline measures that provide standards for assessing performance of Identify business value drivers [19982]." ;
    rdfs:label "Establish baselines for business value drivers" ;
    skos:definition "An Act of Analysis that has as input the business value drivers and has as output business-value-driver baselines derived as reference standards for assessing later performance." ;
    rdfs:comment "Re-anchored (Gate-F) from cco:ont00000345 (Act of Measuring) to ex:ActOfAnalysis, kept consistent with its sibling P10031 'Create baselines for current processes': a baseline is a Descriptive reference measure DERIVED from the value drivers (the output ex:BusinessValueDriverBaseline is Descriptive). Rejected cco:ont00000345 Act of Measuring (measuring determines a value AGAINST an existing standard; here the standard is being established, not applied) and rejected Act of Planning (the output describes a reference level, it does not prescribe action). Input is the value drivers (cross-ref PCF 19982)." ;
    skos:example "The team derives the starting-period value of each driver as its assessment benchmark." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessValueDriver ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessValueDriverBaseline ] .

ex:P19984 a owl:Class ;
    ex:pcfID "19984" ; ex:hierarchyID "1.3.4.3" ;
    ex:apqcSourceText "Overseeing the progress of activities to ensure they are on-course and on-schedule in meeting the objectives and performance targets against Establish baselines for business value drivers [19983]." ;
    rdfs:label "Monitor performance against baselines" ;
    skos:definition "An Act of Measuring that determines actual performance of activities against the established business-value-driver baselines and produces a performance record." ;
    rdfs:comment "Anchored to cco:ont00000345 (Act of Measuring): monitoring measures performance relative to the baseline standard (cross-ref PCF 19983)." ;
    skos:example "A PMO tracks each driver's running value against its baseline to flag off-course initiatives." ;
    rdfs:subClassOf cco:ont00000228 ,   # Planned Act (asserted: Act of Measuring subClassOf Planned Act in CCO; stated locally so standalone Gate C/S2 resolves)
        cco:ont00000345 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessValueDriverBaseline ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceRecord ] .

ex:P19507 a owl:Class ;
    ex:pcfID "19507" ; ex:hierarchyID "1.3.5" ;
    ex:apqcSourceText "Successfully implement strategic initiatives. Execution of strategy is also defined as the process of implementing logical set of connected activities by an organization to make a strategy work." ;
    rdfs:label "Execute strategic initiatives" ;
    skos:definition "A Planned Act that implements the connected activities prescribed by a strategic-initiative specification in order to make the strategy work." ;
    rdfs:comment "Anchored directly to cco:ont00000228 (Planned Act): no narrower CCO act denotes execution/implementation, and execution is prescribed by the initiative specification (the Directive ICE). DELIBERATE non-mint: not Act of Planning/Appraisal/Measuring -- it carries out rather than plans or judges." ;
    skos:example "Project teams carry out the funded initiatives across the organization." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StrategicInitiativeSpecification ] .

ex:P21422 a owl:Class ;
    ex:pcfID "21422" ; ex:hierarchyID "1.3.6" ;
    ex:apqcSourceText "Periodic review of initiatives based performance, conditions, and marketplace response." ;
    rdfs:label "Review execution of strategic initiatives" ;
    skos:definition "An Act of Appraisal that periodically judges the execution of strategic initiatives against performance, conditions, and marketplace response and produces a performance report." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): a periodic review judges execution. Repeatable occurrence with identifiable begin/end each cycle." ;
    skos:example "A quarterly steering review assesses how the executed initiatives are performing." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceReport ] .

ex:P21423 a owl:Class ;
    ex:pcfID "21423" ; ex:hierarchyID "1.3.7" ;
    ex:apqcSourceText "Performing required updates to strategic initiatives based upon changes in the marketplace or performance." ;
    rdfs:label "Refine strategic initiatives and project plans as needed" ;
    skos:definition "An Act of Formulation that revises strategic initiatives and project plans in response to marketplace or performance changes and produces an updated strategic-initiative specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (under cco:ont00000511): re-formulating a plan is planning. Input is the performance report that triggers the revision." ;
    skos:example "After a downturn, the team rewrites two initiatives' project plans to fit the new market." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StrategicInitiativeSpecification ] .

####################################################################
# 3.4  PROCESS GROUP 1.4  "Develop and maintain business models" (PCF 20944)
####################################################################

ex:P20944 a owl:Class ;
    ex:pcfID "20944" ; ex:hierarchyID "1.4" ;
    ex:apqcSourceText "Establishing how an organization creates, delivers and captures value or makes profit. Identify the products or services that a business will sell, its target market, anticipated expenses, and other core aspects of its modus operandi. Revise the plan as required to reflect changing circumstances." ;
    rdfs:label "Develop and maintain business models" ;
    skos:definition "An Act of Planning that establishes how an organization creates, delivers, and captures value, and revises that arrangement as circumstances change, comprising the development, maintenance, and governance of its business models." ;
    rdfs:comment "Models APQC process group 1.4 as a bounded occurrent. Its APQC dotted children are process parts (cco:ont00001777), not subclasses (D1). This is a Process Group, not the Category 1.0, so a has-process-part restriction is licensed." ;
    skos:example "An organization's program to design its business model, keep it current against market feedback, and govern its evolution over a planning horizon." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessModel ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20945 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20950 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20955 ] .

ex:P20945 a owl:Class ;
    ex:pcfID "20945" ; ex:hierarchyID "1.4.1" ;
    ex:apqcSourceText "Creating an economic model that describes the goals of an organization and the business processes needed to achieve those goals. This involves information gathering, securing necessary approvals and authorizations, integrating with preexisting models, including the general business concept [10002] and business strategy [10015], and formally accepting the model as the basis for organization's day-to-day operations." ;
    rdfs:label "Develop business models" ;
    skos:definition "An Act of Planning that examines a business concept and business strategy and produces a business model describing an organization's goals and the processes needed to achieve them." ;
    rdfs:comment "Inputs ex:BusinessConcept and ex:BusinessStrategy are definitional (the source states the model must integrate the general business concept [10002] and business strategy [10015]), so they are promoted to restrictions (Phase-3 necessity)." ;
    skos:example "A strategy team integrates the firm's business concept and strategy into a formally adopted business model." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessConcept ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessModel ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20946 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20947 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20948 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20949 ] .

ex:P20946 a owl:Class ;
    ex:pcfID "20946" ; ex:hierarchyID "1.4.1.1" ;
    ex:apqcSourceText "Collecting all relevant materials needed to develop the business model, so that it can adequately model its processes." ;
    rdfs:label "Assemble business model information" ;
    skos:definition "An Act of Information Processing that collects business-model source material and produces a body of assembled business-model information." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): assembling is the receiving and storing of input ICEs, not the analysis (ex:ActOfAnalysis) of their subject matter. Added (Gate-F) the definitional has-input ex:BusinessModelSourceMaterial that the Information-Processing genus (whose definition is 'one or more input ICEs are received, manipulated, transferred, or stored') requires; without an input ICE the genus' differentia was unsatisfied." ;
    skos:example "An analyst gathers cost, market, and process documents into a single business-model information pack." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessModelSourceMaterial ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessModelInformation ] .

ex:P20947 a owl:Class ;
    ex:pcfID "20947" ; ex:hierarchyID "1.4.1.2" ;
    ex:apqcSourceText "Obtaining required permissions, licenses and authorizations that legitimize the business, help to mitigate associated risks and safeguard the operations." ;
    rdfs:label "Secure appropriate approvals" ;
    skos:definition "An Act of Acquisition that obtains the permissions, licenses, and authorizations required to legitimize a business and produces a business authorization." ;
    rdfs:comment "Output ex:BusinessAuthorization is a Directive ICE (Action Permission). Genus is the local ex:ActOfAcquisition because no CCO Act covers obtaining a held authorization (see that genus' rdfs:comment). Rejected (Gate-F, per §6) cco:ont00000366 (Act of Information Processing): securing approvals is coming to HOLD an authorization the agent did not previously have, not receiving/manipulating/transferring/storing the CONTENT of an input ICE -- the authorization is acquired as a held entity, not processed for its information. Also rejected cco:ont00000402 (Act of Communication): the transfer of the permission to the agent is incidental to the agent's coming to hold it." ;
    skos:example "A compliance officer secures the licenses needed to operate the proposed line of business." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessAuthorization ] .

ex:P20948 a owl:Class ;
    ex:pcfID "20948" ; ex:hierarchyID "1.4.1.3" ;
    ex:apqcSourceText "Ensuring coherence with pre-exsiting models to avoid contradictions between models. Make sure that all models represent the same long-term vision." ;
    rdfs:label "Identify integration points with existing models" ;
    skos:definition "An Act of Identification that has as input business-model information and pre-existing business models and has as output a register of the points at which the new model must integrate with them." ;
    rdfs:comment "Genus ex:ActOfIdentification (discernment sense, from apqc-ext.ttl): the act discerns and enumerates integration points. Input ex:BusinessModel ranges over pre-existing models. CHOSEN READING (Gate-F): Identification, because the leaf 'ensures coherence' by discerning and registering the points of contact (output ex:ModelIntegrationPointRegister, Descriptive). Rejected ex:ActOfAnalysis: the act enumerates discrete integration points rather than examining subject matter to synthesize an understanding -- discernment, not analysis." ;
    skos:example "A modeller maps where the new business model touches the existing operating model to prevent contradictions." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessModelInformation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessModel ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ModelIntegrationPointRegister ] .

ex:P20949 a owl:Class ;
    ex:pcfID "20949" ; ex:hierarchyID "1.4.1.4" ;
    ex:apqcSourceText "Consenting to a particular business model and formally accepting it to serve as the set of guiding principles in operating the company." ;
    rdfs:label "Adopt the business model" ;
    skos:definition "A Planned Act that consents to and formally ratifies a single business model, producing an adoption decision accepting it as the basis of operations." ;
    rdfs:comment "Re-anchored (Gate-F) from ex:ActOfSelection to cco:ont00000228 (Planned Act): the source is 'consenting to a PARTICULAR business model and formally accepting it' -- a commitment/ratification act over a single model, not a choice among a set of candidates (ex:ActOfSelection definitionally chooses from a set). Rejected ex:ActOfSelection: there is no candidate set here; the model has already been settled, and this leaf is the ratification. No narrower CCO act denotes ratification/acceptance, so it anchors at the generic Planned Act, parallel to ex:P19507 'Execute strategic initiatives'. Output ex:BusinessModelAdoptionDecision (Directive) is kept: a ratification still prescribes that the model govern operations. Anchored as Planned Act consistently with the parallel ratification leaf ex:P10056 'Migrate to new organization'." ;
    skos:example "An executive board formally adopts the proposed business model as the company's operating basis." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BusinessModel ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessModelAdoptionDecision ] .

ex:P20950 a owl:Class ;
    ex:pcfID "20950" ; ex:hierarchyID "1.4.2" ;
    ex:apqcSourceText "Revising and updating business models to reflect the changes in the marketed services, product inventory, market behavior, available resources or accrued expenses. Determine how and when to modify the accepted business model in response to incoming feedback." ;
    rdfs:label "Maintain business models" ;
    skos:definition "An Act of Planning that revises and updates an organization's business models in response to feedback and changing circumstances and produces an updated business model." ;
    rdfs:comment "R5 bounded-occurrent test: this is a bounded revision PROCESS, not the standing function. Begin/end criterion (Gate-F): an instance BEGINS when a triggering condition (incoming feedback or a scheduled review) opens a revision episode and ENDS when the reissued business model is published; it has a determinate temporal extent and modeled child steps. By contrast, the standing upkeep/oversight FUNCTION (which has no per-episode begin/end and persists between revisions) is the continuant ex:BusinessModelGovernanceCapability set up by 1.4.3, not this process. The ex:CustomerFeedback input is demoted (Gate-F, Phase-3) from an existential has-input to this comment: the source's wider scope ('changes in marketed services, product inventory, market behavior, available resources or accrued expenses') shows feedback is only one of several alternative triggers, so it is not necessary for every instance." ;
    skos:example "A product team runs its periodic review and reissues the business model to reflect new market behavior." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessModel ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20951 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20952 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20953 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20954 ] .

ex:P20951 a owl:Class ;
    ex:pcfID "20951" ; ex:hierarchyID "1.4.2.1" ;
    ex:apqcSourceText "Determining the timeline, procedures and responsibilities for reviewing the business model and for updating it to best serve the organization." ;
    rdfs:label "Establish business model maintenance parameters" ;
    skos:definition "An Act of Planning that determines the timeline, procedures, and responsibilities for reviewing and updating a business model and produces a business-model maintenance plan." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): it makes a procedure (a Directive ICE) prescribing how and when maintenance occurs." ;
    skos:example "A governance lead sets a quarterly review cadence and assigns owners for business-model updates." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessModelMaintenancePlan ] .

ex:P20952 a owl:Class ;
    ex:pcfID "20952" ; ex:hierarchyID "1.4.2.2" ;
    ex:apqcSourceText "Deciding the type of responses, reactions, sentiments and insights that are crucial to be taken into consideration with business model maintenance." ;
    rdfs:label "Accept business model feedback parameters" ;
    skos:definition "An Act of Selection that determines which types of feedback are to be taken into consideration during business-model maintenance and produces a feedback-criteria specification." ;
    rdfs:comment "Genus ex:ActOfSelection: the act picks, among candidate feedback types, those that count. Output ex:FeedbackCriteriaSpecification is a Directive ICE prescribing which feedback is admissible. CHOSEN READING (Gate-F): Selection, because the source verb is 'DECIDING the type of responses ... crucial to be taken into consideration' -- choosing admissible types from a candidate set, with a Directive chosen-option output (Golden Principle agreement). Rejected ex:ActOfFormulation: the act selects among pre-existing feedback kinds rather than composing a novel specification from scratch." ;
    skos:example "A team decides that only structured customer-survey and churn signals will drive model changes." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FeedbackCriteriaSpecification ] .

ex:P20953 a owl:Class ;
    ex:pcfID "20953" ; ex:hierarchyID "1.4.2.3" ;
    ex:apqcSourceText "Evaluating the feedback regarding products, services, processes or resources. Determine which judgments are critical and mandate changes to the current business model to better deliver the desired value" ;
    rdfs:label "Prioritize and manage incoming feedback" ;
    skos:definition "An Act of Appraisal that evaluates incoming feedback to judge which items are critical and produces a prioritization of that feedback." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it evaluates and judges the importance of feedback. Input ex:CustomerFeedback is definitional (the act is about the feedback)." ;
    skos:example "A product council ranks incoming feedback and flags the items that mandate model changes." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CustomerFeedback ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FeedbackPrioritization ] .

ex:P20954 a owl:Class ;
    ex:pcfID "20954" ; ex:hierarchyID "1.4.2.4" ;
    ex:apqcSourceText "Modifying the business models that are presently in use in response to incoming feedback or changing markets to achieve the enterprise business goals." ;
    rdfs:label "Update existing models" ;
    skos:definition "An Act of Planning that modifies the business models presently in use in response to feedback or changing markets and produces an updated business model." ;
    rdfs:comment "Anchored to cco:ont00000511 (Act of Planning): revising the operative plan (the business model, a Directive ICE). The ex:CustomerFeedback input is demoted (Gate-F, Phase-3) from an existential has-input to this comment: the source says the update is triggered by 'incoming feedback OR changing markets', so feedback is only ONE of two alternative triggers and is not necessary for every instance. Output ex:BusinessModel retained." ;
    skos:example "A team revises the in-force business model to reflect prioritized feedback and new market conditions." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessModel ] .

ex:P20955 a owl:Class ;
    ex:pcfID "20955" ; ex:hierarchyID "1.4.3" ;
    ex:apqcSourceText "Creating and implementing a strategy, responsibilities and control mechanisms for managing business models that are timely, efficient and cost-effective." ;
    rdfs:label "Establish business model governance" ;
    skos:definition "An Act of Planning that creates and implements the strategy, responsibilities, and control mechanisms for governing an organization's business models and produces a business-model governance policy." ;
    rdfs:comment "R5/R6: the bounded establishing act passes R5 and is modeled here as a process; the standing governance function it stands up is the pre-existing shared ex:BusinessModelGovernanceCapability (Organization Capability), reused (not re-minted) and linked via obo:BFO_0000054 (realized in)." ;
    skos:example "An organization stands up a model-governance board with a charter, owners, and review controls." ;
    rdfs:subClassOf cco:ont00000511 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessModelGovernancePolicy ] .

# R6 cross-reference (capability reused from the shared vocabulary, not redefined):
# the standing function set up by ex:P20955 is realized in such acts.
ex:BusinessModelGovernanceCapability
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty obo:BFO_0000054 ;   # realized in
        owl:someValuesFrom ex:P20955 ] .

####################################################################
# 4. CATALOG -> REALITY BRIDGES (ADR-001 R4)
#    Each catalog node (ex:PCF_<id>, defined in apqc-catalog.ttl)
#    designates the reality-layer process universal modeled above.
####################################################################

