@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix obo:   <http://purl.obolibrary.org/obo/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC PCF -> BFO 2020 / CCO 2.0  REALITY-LAYER MODULE
# Slice 13.0 "Develop and Manage Business Capabilities"
#
# Assembled from the process-group transforms for ALL nine groups of
# section 13.0: 13.1 manage business processes, 13.2 manage portfolio/
# program/project, 13.3 manage enterprise quality, 13.4 manage change,
# 13.5 develop/manage KM capability, 13.6 measure and benchmark,
# 13.7 develop/manage/deliver analytics, 13.8 manage EHS, and
# 13.9 manage sustainability -- over a single shared supporting-
# vocabulary layer. (Groups 13.2/13.7/13.8/13.9 were added in the
# Gate-F review pass that also re-anchored the per-class findings.)
#
# CCO pin: v2.0 (2024-11-06). Every cco:ont... IRI below was verified
# against vendor/cco/CommonCoreOntologiesMerged.ttl (label +
# definition + parent read, not just the label). Two-layer model and
# the R5 bounded-occurrent test per ADR-001.
#
# RECONCILIATION NOTE: the per-group transforms each emitted a local
# copy of the recurring act genera, occasionally under divergent
# parents. They are reconciled here to ONE coherent definition each,
# matching the section CONTEXT PROPOSE-EXT block (the binding spec):
#   ex:ActOfMonitoring     -> cco:ont00000366 (Act of Information Processing)
#   ex:ActOfImplementation -> cco:ont00000228 (Planned Act)
#   ex:ActOfImprovement    -> cco:ont00000228 (Planned Act)
# (The 13.3 transform's variant anchoring ex:ActOfMonitoring under
#  cco:ont00000636 Act of Appraisal is superseded by the section
#  CONTEXT spec, which anchors it under cco:ont00000366.)
# Duplicate supporting ICEs/agents/capabilities are likewise collapsed
# to one definition each.
####################################################################

<http://example.org/apqc/slice/13.0> a owl:Ontology ;
    dct:title "APQC reality-layer slice 13.0: Develop and Manage Business Capabilities" ;
    dct:source "APQC Process Classification Framework (Cross-Industry)" ;
    owl:versionInfo "0.3.0" ;
    rdfs:comment "Reality-layer module for APQC section 13.0. CCO pin v2.0 (2024-11-06) per ADR-001 (two-layer model, R5 bounded-occurrent test, GOLDEN PRINCIPLE). New recurring genera (ex:ActOfMonitoring, ex:ActOfImplementation, ex:ActOfImprovement) are emitted below as PROPOSE-EXT for human promotion. Self-contained: the shared act genera it uses are inlined from the apqc-ext.ttl registry, so it validates standalone against the pinned CCO/BFO closure with no extension merge." .

####################################################################
# ACT GENERA -- SELF-CONTAINED (canonical defs mirrored from
# apqc-ext.ttl, the D9 shared registry). Inlined so this module
# validates standalone against CCO without merging the extension.
####################################################################

ex:ActOfAcquisition a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Acquisition" ;
    skos:definition "A Planned Act in which an Agent obtains from some authority or supplier an entity (such as an authorization, license, or resource) that the Agent did not previously hold." ;
    rdfs:comment "Local extension (D9). Rejected cco:ont00000950 'Act of Maintenance' (modifying Material Artifacts) and cco:ont00000402 'Act of Communication' (mere ICE transfer). Securing/obtaining a held entity anchors at the generic Planned Act. Expected to recur in procurement/asset-acquisition categories (4.0, 10.0)." .

ex:ActOfAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Analysis" ;
    skos:definition "An Act of Information Processing in which an Agent examines one or more input Information Content Entities and produces an Information Content Entity that represents an understanding of their subject matter." ;
    rdfs:comment "Local extension (D9). CCO 2.0 has no generic analysis class; analysis is information processing, so it is anchored under cco:ont00000366." .

ex:ActOfFormulation a owl:Class ;
    rdfs:subClassOf cco:ont00000511 ;   # Act of Planning
    rdfs:label "Act of Formulation" ;
    skos:definition "An Act of Planning in which an Agent composes and articulates a Directive Information Content Entity - such as a mission, strategy, objective, design, roadmap, or business model - that prescribes an organization's intended course of action." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000511 (Act of Planning) because formulating a strategy/mission/design is making a plan to achieve an objective; its output is a Directive ICE. Recurs across develop/define/compose-a-directive processes corpus-wide." .

ex:ActOfIdentification a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Identification (discernment sense)" ;
    skos:definition "An Act of Information Processing in which an Agent discerns and enumerates entities of a given kind and produces an Information Content Entity that registers them." ;
    rdfs:comment "Local extension (D9). NOT cco:ont00001261 'Act of Identifying' (a communication act). APQC 'Identify ...' denotes discernment, i.e. information processing." .

ex:ActOfImplementation a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Implementation" ;
    skos:definition "A Planned Act in which an Agent executes, deploys, or puts into operation a previously specified plan, program, methodology, or system so as to bring about the state of affairs it prescribes." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000228 (Planned Act): carrying out a Directive ICE is realizing a plan, and its effect is a change in the world rather than a new ICE. Distinct from ex:ActOfFormulation (which composes the plan) and ex:ActOfDeployment (the narrower IT install/configure case). Rejected cco:ont00000950 'Act of Maintenance' (restricted to modifying Material Artifacts). Recurs in execute/deploy/implement processes (13.0)." .

ex:ActOfImprovement a owl:Class ;
    rdfs:subClassOf cco:ont00000228 ;   # Planned Act
    rdfs:label "Act of Improvement" ;
    skos:definition "A Planned Act in which an Agent modifies an existing process, system, or capability with the intent of raising its performance, quality, or fitness against stated objectives." ;
    rdfs:comment "PROPOSE-EXT (D9). Anchored under cco:ont00000228 (Planned Act): it alters an existing occurrent-type or system rather than merely processing information or composing a new plan. Distinct from ex:ActOfImplementation (enacts a fixed directive). Rejected cco:ont00000950 'Act of Maintenance' (restores/preserves a Material Artifact's designed Qualities/Functions, whereas improvement raises performance of a process/system). Recurs in improve/reengineer/enhance/sustain processes (13.0)." .

ex:ActOfMonitoring a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Monitoring" ;
    skos:definition "An Act of Information Processing in which an Agent repeatedly or continuously observes the state, progress, or performance of some process, system, or quantity over time and produces a Descriptive Information Content Entity that represents its tracked status against expected conditions, targets, or requirements." ;
    rdfs:comment "PROPOSE-EXT (D9). CCO 2.0 has no generic monitoring/tracking class. Anchored under cco:ont00000366 (Act of Information Processing) because monitoring ingests repeated observations (including electronic records, not only senses) and yields a descriptive status/deviation ICE -- the GOLDEN PRINCIPLE (descriptive output => information-processing genus) holds. Rejected cco:ont00000037 (Act of Observation: a single sense-based acquisition, too narrow -- monitoring also processes ICEs and is sustained); cco:ont00000636 (Act of Appraisal: renders a single bounded value/quality judgement rather than tracking status over time); and cco:ont00000345 (Act of Measuring: a single quantification against a standard at one time -- at most a method sub-step of the monitoring cycle; a node that is purely one quantification, e.g. Calculate performance measures, anchors to cco:ont00000345 directly, not here). Distinct from ex:ActOfAnalysis (one-shot examination of a fixed input set) by its continuous, longitudinal character. A standing 'Manage/Monitor X' function with no natural end is an Organization Capability (cco:ont00000568) realized in such acts, not itself a process. Recurs corpus-wide (slices 3.0/4.0/5.0/6.0/8.0/9.0/10.0/11.0/12.0/13.0). Reconciled from 10 divergent slice restatements to one definition." .

ex:ActOfSelection a owl:Class ;
    rdfs:subClassOf cco:ont00000366 ;   # Act of Information Processing
    rdfs:label "Act of Selection" ;
    skos:definition "An Act of Information Processing in which an Agent chooses one or more options from a set of candidates and produces a Directive Information Content Entity that prescribes the chosen option(s)." ;
    rdfs:comment "Local extension (D9). Anchored under cco:ont00000366 (Act of Information Processing): receives candidate-option ICEs and yields a decision ICE. Distinct from Act of Appraisal (judges without committing) and Act of Planning. NOTE: ratifying a single already-settled option is NOT selection (no candidate set) -- anchor such acts at cco:ont00000228 (Planned Act)." .

####################################################################
# 0. PROVENANCE ANNOTATION PROPERTIES
####################################################################

ex:pcfID a owl:AnnotationProperty ;
    rdfs:label "APQC PCF ID" ;
    rdfs:comment "Stable APQC identifier. Anchor IRIs to this; it persists across PCF versions." .

ex:hierarchyID a owl:AnnotationProperty ;
    rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions. Reference only; never for IRI minting or subsumption." .

ex:apqcSourceText a owl:AnnotationProperty ;
    rdfs:label "APQC source description" ;
    rdfs:comment "Verbatim APQC Element Description retained for provenance." .

ex:designatesProcessType a owl:AnnotationProperty ;
    rdfs:label "designates process type" ;
    rdfs:comment "Bridges a catalog node (ex:PCF_<pcfID>) to its reality-layer class (ex:P<pcfID> or a supporting capability)." .

####################################################################
# 1. NEW ACT-GENUS PROPOSALS  (PROPOSE-EXT: promote to apqc-ext.ttl)
#    Reused without re-minting (from apqc-ext.ttl): ex:ActOfAnalysis,
#    ex:ActOfIdentification, ex:ActOfFormulation, ex:ActOfSelection,
#    ex:ActOfAcquisition. Reused CCO acts directly: Act of Appraisal
#    (cco:ont00000636), Act of Measuring (cco:ont00000345), Act of
#    Training (cco:ont00000234), Act of Communication (cco:ont00000402),
#    Act of Information Processing (cco:ont00000366), Planned Act
#    (cco:ont00000228).
#
# ----- §6 VERIFIED CORE TERMS (CCO v2.0, 2024-11-06) -----------------
# D6 verify-before-assert: every opaque cco:ont... IRI written below was
# read (label + definition + parent chain) from
# vendor/cco/CommonCoreOntologiesMerged.ttl, not matched on label alone.
# This is the authoritative verification record for the IRIs used.
#   cco:ont00000228  Planned Act
#       def "An Act that realizes a Plan whose Objective is part of that Plan."
#       parent: Act (cco:ont00000545) -> ... -> bfo:process. ROOT ACT ANCHOR.
#   cco:ont00000366  Act of Information Processing
#       def "A Planned Act ... manipulates Information Content Entities."
#       parent: cco:ont00000228 Planned Act. (analysis/identification/monitoring genus)
#   cco:ont00000636  Act of Appraisal
#       def "A Planned Act ... assessing the value/condition of some Entity."
#       parent: cco:ont00000228 Planned Act. (assessment/evaluation/benchmark genus)
#   cco:ont00000511  Act of Planning
#       def "A Planned Act ... producing a Plan ... to achieve an Objective."
#       parent: cco:ont00000228 Planned Act. (formulation genus)
#   cco:ont00000345  Act of Measuring
#       def "A Planned Act that involves determining the extent, dimensions,
#            quanity, or quality of an Entity relative to some standard."
#       parent: cco:ont00000228 Planned Act. VERIFIED for 13.6.3.4 / 13.3.2.1.1 / 13.9.2.3.1.
#   cco:ont00000234  Act of Training
#       def "A Planned Act in which knowledge, skills or values are imparted
#            from one or more Agents to at least one other Agent."
#       parent: cco:ont00000228 Planned Act. VERIFIED: definition (imparting skills
#            to Agents) matches the intended use for 13.1.4.1, 13.3.4.6.3, 13.8.3.5, 13.9.2.1.
#   cco:ont00000402  Act of Communication
#       def "A Planned Act in which some Information Content Entity is transferred
#            from some Agent to Another."
#       parent: cco:ont00000228 Planned Act. VERIFIED: descends from Planned Act 228;
#            the ICE-transfer definition matches publish/disseminate use (13.1.3.5, 13.5.4.2).
# REJECTED (verified, deliberately NOT used): cco:ont00001261 'Act of Identifying'
#   = an Act of Representative Communication (asserting who/what a thing is),
#   a communication act -- NOT discernment. APQC 'Identify ...' (discernment)
#   anchors at ex:ActOfIdentification (subClassOf cco:ont00000366) instead.
# Because 345/234/402 all descend from Planned Act 228, each process using them
# also asserts an explicit cco:ont00000228 co-parent so Gate C (S2) sees the Act
# anchor without the CCO closure merged.
####################################################################

####################################################################
# 2. REALIZABLE ROLES (obo:BFO_0000023; borne by Agents/Orgs only -- D4)
####################################################################

ex:ProcessOwnerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Process Owner Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being assigned accountability for identifying, analyzing, and improving a given business process within an Organization." ;
    rdfs:comment "Minted for recurring APQC 13.1 participant 'process owner'. Borne by an independent continuant (the assigned Agent), never by a process or ICE." .

ex:BPMGovernanceLeaderRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "BPM Governance Leader Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being designated to set standards and priorities for business-process-management efforts within an Organization." ;
    rdfs:comment "Minted for APQC 13.1.1.1 'Identify BPM governance leaders'." .

ex:PortfolioManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Portfolio Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being responsible for governing and monitoring an Organization's business portfolio of investments, holdings, products, businesses, and brands." ;
    rdfs:comment "Minted for recurring APQC 13.2.1 participant." .

ex:ProgramManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Program Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being responsible for establishing, executing, and reporting on a business program comprising related projects." ;
    rdfs:comment "Minted for recurring APQC 13.2.2 participant; also referenced in 13.2.3.4.5 project reviews with program managers." .

ex:ProjectManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Project Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being responsible for scoping, planning, executing, reporting on, and closing a business project." ;
    rdfs:comment "Minted for recurring APQC 13.2.3 participant." .

ex:QualityManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Quality Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being responsible for establishing, evaluating, and maintaining enterprise quality requirements and the quality management system." ;
    rdfs:comment "Minted for recurring APQC 13.3 participant ('quality management team')." .

ex:ChangeChampionRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Change Champion Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being designated to promote, communicate, and drive the adoption of a change initiative within a division or team of an Organization." ;
    rdfs:comment "Minted for APQC 13.4.1.3 'Identify change champion(s)' and 13.4.2.5 'Assign change champion(s)'." .

ex:ChangeManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Change Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being held accountable for ensuring that an Organization's change is planned, designed, implemented, and sustained systematically." ;
    rdfs:comment "Minted for APQC 13.4.1.12 'Establish accountability for change management'." .

ex:KnowledgeManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Knowledge Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being responsible for governing, capturing, maintaining, and providing access to an Organization's collective knowledge base." ;
    rdfs:comment "Minted for recurring APQC 13.5 participant ('KM core group' / specialized KM roles)." .

ex:DataAnalystRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Data Analyst Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being tasked with collecting, preparing, analyzing, and modeling data to produce analytical findings for an Organization." ;
    rdfs:comment "Minted for recurring APQC 13.7 participant ('knowledge engineers, data scientists, and other relevant personnel')." .

ex:EHSManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "EHS Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being responsible for developing, monitoring, and managing an Organization's environmental, health, and safety program." ;
    rdfs:comment "Minted for recurring APQC 13.8 participant." .

ex:SustainabilityManagerRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Sustainability Manager Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being responsible for developing and managing an Organization's sustainability (ESG) capability, policies, and reporting." ;
    rdfs:comment "Minted for recurring APQC 13.9 participant." .

ex:StakeholderRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Stakeholder Role" ;
    skos:definition "A Role that is borne by an Agent or Organization in virtue of having an interest in, or being affected by, an Organization's process, program, project, change initiative, or analytics effort." ;
    rdfs:comment "Minted for the cross-cutting 'stakeholder' participant referenced across 13.2, 13.4, 13.7, 13.8, 13.9." .

ex:TraineeRole a owl:Class ;
    rdfs:subClassOf obo:BFO_0000023 ;
    rdfs:label "Trainee Role" ;
    skos:definition "A Role that is borne by an Agent in virtue of being a recipient of training -- the Agent to whom knowledge, skills, or values are imparted by an Act of Training." ;
    rdfs:comment "Minted for the training-recipient participant of EHS training (13.8.3.5). Distinct from ex:StakeholderRole (an interested/affected party): a trainee is the recipient of the imparted competence." .

####################################################################
# 3. ORGANIZATION CAPABILITIES (cco:ont00000568)
#    Group-level 'Manage X' standing-function nodes (fail R5) are
#    modeled as capabilities realized in their constituent acts.
####################################################################

# Reconciled: ex:BusinessProcessManagementCapability carries the 13.1
# realized-in restrictions (group 13.1 'Manage business processes',
# PCF 16378). The plain shared-vocab stub is superseded by this richer
# definition. No ex:P16378 process is minted (R5/R6 standing function).
ex:BusinessProcessManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16379 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16384 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16387 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16392 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21453 ] ;
    rdfs:label "Business Process Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to govern, define, administer, and improve its business processes, realized in the acts of establishing process governance, defining process frameworks, defining processes, managing process performance, and improving processes." ;
    rdfs:comment "Models APQC group 13.1 'Manage business processes' (PCF 16378). Per R5/R6 the verb 'Manage' denotes a standing organizational function with no natural end, so it is an Organization Capability realized in the child acts -- NOT a process class. No ex:P16378 is minted." .

# 13.2 group node (PCF 16400) modeled as an aggregate Organization Capability
# sitting above the three sub-capacities (portfolio/program/project mgmt).
ex:PortfolioProgramProjectManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Portfolio, Program, and Project Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to manage its portfolio of investments and brands, its programs of related projects, and its individual projects." ;
    rdfs:comment "Aggregate standing-function reading of APQC group 13.2 'Manage portfolio, program, and project' (PCF 16400). Sits above the three sub-capacities ex:PortfolioManagementCapability / ex:ProgramManagementCapability / ex:ProjectManagementCapability. The catalog node ex:PCF_16400 designates this aggregate. Per D8 the ProcessGroup level gets an aggregate capability node (not a process) consistent with the standing-function reading of its 'Manage X' children. No ex:P16400 process is minted." .

ex:PortfolioManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16402 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16403 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16404 ] ;
    rdfs:label "Portfolio Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to establish strategy for, govern, and monitor its business portfolio of investments, holdings, products, businesses, and brands, realized in its constituent acts." ;
    rdfs:comment "Standing-function reading of APQC 13.2.1 'Manage portfolio' (PCF 16401). No ex:P16401 process is minted; the catalog node ex:PCF_16401 designates this capability. Wired with obo:BFO_0000054 (realized in) to its constituent acts ex:P16402/ex:P16403/ex:P16404, mirroring the 13.1/13.5 capability pattern." .

ex:ProgramManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16406 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16407 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16408 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16409 ] ;
    rdfs:label "Program Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to establish, execute, and report on business programs comprising related projects, realized in its constituent acts." ;
    rdfs:comment "Standing-function reading of APQC 13.2.2 'Manage programs' (PCF 16405). No ex:P16405 process is minted; the catalog node ex:PCF_16405 designates this capability. Wired with obo:BFO_0000054 (realized in) to ex:P16406..ex:P16409, mirroring the 13.1/13.5 capability pattern." .

ex:ProjectManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16411 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11119 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16413 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16414 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16417 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P16418 ] ;
    rdfs:label "Project Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to scope, plan, execute, review, and close business projects, realized in its constituent acts." ;
    rdfs:comment "Standing-function reading of APQC 13.2.3 'Manage projects' (PCF 16410). No ex:P16410 process is minted; the catalog node ex:PCF_16410 designates this capability. Wired with obo:BFO_0000054 (realized in) to its constituent Activity acts ex:P16411/ex:P11119/ex:P16413/ex:P16414/ex:P16417/ex:P16418, mirroring the 13.1/13.5 capability pattern." .

ex:EnterpriseQualityManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Enterprise Quality Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to establish quality requirements, evaluate performance against them, manage non-conformance, and operate an enterprise quality management system." ;
    rdfs:comment "Shared target for the standing-function reading of APQC 13.3 'Manage enterprise quality'. The 13.3 group node ex:P17471 carries the same intent with explicit realized-in restrictions to its child acts." .

ex:ChangeManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ;
    rdfs:label "Change Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to plan, design, implement, and sustain organizational change." ;
    rdfs:comment "Shared target for the standing-function reading of APQC 13.4 'Manage change'. The 13.4 group node ex:P11074 models a single bounded change-management cycle as a Planned Act; this capability is the standing-function reading." .

ex:KnowledgeManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11095 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11096 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20965 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20969 ] ;
    rdfs:label "Knowledge Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to develop strategy for, assess, design, implement, and sustain the management of its collective knowledge, realized in the acts of developing KM strategy, assessing KM capabilities, designing and implementing KM capabilities, and evolving and sustaining them." ;
    rdfs:comment "Models APQC group 13.5 'Develop and manage enterprise-wide knowledge management capability' (PCF 11073). Per R5/R6 a standing function -> Organization Capability realized in its child acts; the catalog node ex:PCF_11073 designates this capability. No ex:P11073 process is minted." .

ex:BenchmarkingCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21584 ] ;
    rdfs:label "Benchmarking Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to measure and benchmark the performance of its internal processes and of the organization as a whole against internal or external reference points, realized in its bounded measure-and-benchmark cycles." ;
    rdfs:comment "Standing-function reading of APQC 13.6 'Measure and benchmark'. Improved by the bounded act ex:P11084 'Develop benchmarking capabilities'. Carries a realized-in restriction to the bounded enterprise measure-and-benchmark cycle ex:P21584 so the dual model (standing capability + bounded cycle) is coherent." .

ex:AnalyticsCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21459 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21460 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20960 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20961 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21461 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20962 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21462 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21463 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21464 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20963 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P20964 ] ;
    rdfs:label "Analytics Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to develop, manage, and deliver analytics across its data-management pipeline, realized in its bounded analytics acts." ;
    rdfs:comment "Standing-function reading of APQC 13.7 'Develop, manage, and deliver analytics' (PCF 20959). Per R5 the 'Develop/manage/deliver' group node is a standing function -> Organization Capability; the catalog node ex:PCF_20959 designates this capability. Its 11 bounded leaf acts (ex:P21459..ex:P20964) are wired as obo:BFO_0000054 (realized in) fillers, mirroring the 13.1/13.5 capability pattern; they are NOT has-process-part of a capability." .

ex:EHSManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11180 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P11181 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21587 ] ;
    rdfs:label "EHS Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to determine, develop, monitor, and manage its environmental, health, and safety program, realized in its bounded EHS acts." ;
    rdfs:comment "Standing-function reading of APQC 13.8 'Manage environmental health and safety' (PCF 11179). Per R5 the 'Manage' group node is a standing function -> Organization Capability; the catalog node ex:PCF_11179 designates this capability. Its three bounded group children (ex:P11180 determine impacts, ex:P11181 develop program, ex:P21587 monitor and manage) are wired as obo:BFO_0000054 (realized in) fillers, mirroring the 13.1/13.5 capability pattern. No ex:P11179 process is minted." .

ex:SustainabilityManagementCapability a owl:Class ;
    rdfs:subClassOf cco:ont00000568 ,   # Organization Capability
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21589 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P21598 ] ;
    rdfs:label "Sustainability Management Capability" ;
    skos:definition "An Organization Capability that inheres in an Organization in virtue of its capacity to develop and manage its sustainability (ESG) practices, policies, requirements, and reporting, realized in its bounded sustainability acts." ;
    rdfs:comment "Standing-function reading of APQC 13.9 'Manage sustainability' (PCF 21588). Per R5 the 'Manage' group node is a standing function -> Organization Capability; the catalog node ex:PCF_21588 designates this capability. Its two bounded process children (ex:P21589 Develop sustainability capability, ex:P21598 Manage sustainability capability) are wired as obo:BFO_0000054 (realized in) fillers, mirroring the 13.1/13.5 capability pattern (previously a hollow stub with no realized-in restrictions). No ex:P21588 process is minted." .

####################################################################
# 4. AGENTS / ORGANIZATIONS (cco:ont00001017 / cco:ont00001180)
#    Recurring named participants. Bearer-of restrictions attach
#    realizables to independent continuants (D4).
####################################################################

ex:ProcessOwner a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ProcessOwnerRole ] ;
    rdfs:label "Process Owner" ;
    skos:definition "An Agent that bears a process-owner role." .

ex:BPMGovernanceLeader a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:BPMGovernanceLeaderRole ] ;
    rdfs:label "BPM Governance Leader" ;
    skos:definition "An Agent that bears the BPM Governance Leader Role within an organization's business-process-management governance." ;
    rdfs:comment "Minted as the named participant of ex:P16380 (Define and manage governance approach). Bears the shared ex:BPMGovernanceLeaderRole (D4: realizables on Agents only)." .

ex:ProjectManager a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ProjectManagerRole ] ;
    rdfs:label "Project Manager" ;
    skos:definition "An Agent that bears a project-manager role." .

ex:ProgramManager a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ProgramManagerRole ] ;
    rdfs:label "Program Manager" ;
    skos:definition "An Agent that bears a program-manager role." .

ex:ChangeChampion a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ChangeChampionRole ] ;
    rdfs:label "Change Champion" ;
    skos:definition "An Agent that bears a change-champion role." .

ex:ChangeManager a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:ChangeManagerRole ] ;
    rdfs:label "Change Manager" ;
    skos:definition "An Agent that bears a change-manager role, held accountable for ensuring an Organization's change is managed systematically." .

ex:DataAnalyst a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:DataAnalystRole ] ;
    rdfs:label "Data Analyst" ;
    skos:definition "An Agent that bears a data-analyst role." .

ex:Stakeholder a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:StakeholderRole ] ;
    rdfs:label "Stakeholder" ;
    skos:definition "An Agent that bears a stakeholder role with respect to an Organization's initiative." ;
    rdfs:comment "Where the stakeholder is itself an Organization (e.g. a partner firm), use cco:ont00001180 as the genus instead." .

ex:FunctionalEmployee a owl:Class ;
    rdfs:subClassOf cco:ont00001017 ,   # Agent
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000196 ; owl:someValuesFrom ex:TraineeRole ] ;
    rdfs:label "Functional Employee" ;
    skos:definition "An Agent that bears a trainee role as a functional employee receiving an organization's training -- e.g. environmental, health, and safety training." ;
    rdfs:comment "Minted as the definitional training-recipient participant of ex:P11182 'Train and educate functional employees' (13.8.3.5), mirroring the ex:ProcessOwner pattern used by the sibling-analog ex:P16393 'Provide process training'. NOT ex:Stakeholder (an interested/affected party): the source names functional employees as the recipients." .

####################################################################
# 5. SHARED INPUT/OUTPUT INFORMATION CONTENT ENTITIES
#    Genus per GOLDEN PRINCIPLE: Descriptive (cco:ont00000853) for
#    representations/judgements/reports/records; Directive (cco:ont00000965)
#    for plans/strategies/policies/specifications/decisions.
####################################################################

# ---- 13.1 Manage business processes ----------------------------------

ex:ProcessGovernanceFramework a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Process Governance Framework" ;
    skos:definition "A Directive Information Content Entity that prescribes an Organization's approach, standards, and priorities for governing business process management." .

ex:ProcessFramework a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Process Framework" ;
    skos:definition "A Directive Information Content Entity that prescribes the required business processes of an Organization, their key elements, and how they should interact." .

ex:ProcessScopeStatement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Process Scope Statement" ;
    skos:definition "A Directive Information Content Entity that prescribes the extent and limits of a business process in terms of the activities and tasks it comprises." .

ex:ProcessAnalysis a owl:Class ;
    rdfs:subClassOf cco:ont00000853 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001808 ; owl:someValuesFrom ex:ProcessOwner ] ;
    rdfs:label "Process Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes how a business process works and how participants from different groups work together to achieve a business goal." ;
    rdfs:comment "is-about filler is illustrative of the subject business process; group agent may narrow it." .

ex:BestPracticesRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Best Practices Register" ;
    skos:definition "A Descriptive Information Content Entity that describes the practices and procedures identified as most effective for the success of a business." .

ex:ProcessControlPointSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Process Control Point Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes checkpoints in a business process that prevent its continuation unless stated requirements are satisfied." .

ex:ProcessModel a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Process Model" ;
    skos:definition "A Descriptive Information Content Entity that describes what a business entity does, who is responsible, the standard to which a business process should be completed, and how its success is determined." ;
    rdfs:comment "Documentation/representation of an as-is or to-be process (descriptive). Distinct from ex:ProcessFramework, which prescribes the required process set." .

ex:ProcessPerformanceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Process Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the measured performance of business processes against defined performance indicators." .

ex:PerformanceIndicatorSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Performance Indicator Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the indicators and measures used to evaluate the performance of a process, project, program, or organization." ;
    rdfs:comment "Shared across 13.1.4.3, 13.2.3.1.5, 13.6.3.1, 13.8.3.2 -- one definition of 'measures/indicators' as a prescriptive artifact." .

ex:ImprovementOpportunityAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Improvement Opportunity Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes identified opportunities to improve an existing business process to meet new goals and objectives." .

ex:ProcessImprovementMethodologySelection a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Process Improvement Methodology Selection" ;
    skos:definition "A Directive Information Content Entity that prescribes the process-improvement methodology (e.g. Lean, Six Sigma) chosen for an improvement effort." ;
    rdfs:comment "Directive: the output of a selection act, prescribing the chosen methodology. Reused as input to 13.4.3.2 reengineering." .

ex:BPMToolTemplate a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "BPM Tool Template" ;
    skos:definition "A Directive Information Content Entity that prescribes a reusable configuration of a business-process-management tool (process engine, analytics, content management, or collaboration tool) ready for implementation." ;
    rdfs:comment "Directive: a template prescribes how a tool is set up. Minted because no shared-vocab ICE covers BPM tool/template artifacts (output of ex:P16381)." ;
    skos:example "A pre-built process-engine workflow template instantiated for new processes." .

ex:CrossFunctionalProcessRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Cross-Functional Process Register" ;
    skos:definition "A Descriptive Information Content Entity that describes the business processes spanning two or more functional areas of an organization." ;
    rdfs:comment "Descriptive: represents which processes are cross-functional. Minted because no shared-vocab ICE covers this register (output of ex:P16386)." ;
    skos:example "A list of order-to-cash processes flagged as cross-functional." .

ex:MetricGapAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Metric Gap Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes whether additional performance indicators are needed to achieve a business goal and which measurement gaps exist." ;
    rdfs:comment "Descriptive (a gap-finding/discernment), not Directive: it represents the NEED for further metrics, not the composition of any new indicator. Output of ex:P20141 'Identify additional metrics as required'. Distinct from ex:PerformanceIndicatorSpecification (the Directive artifact a later formulation act would compose)." ;
    skos:example "A note finding that the new on-time-delivery goal is not yet covered by any existing KPI." .

# ---- 13.2 Manage portfolio, program, and project ---------------------

ex:PortfolioStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Portfolio Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an Organization's plan for managing its portfolio of investments, holdings, products, businesses, and brands." .

ex:PortfolioGovernanceFramework a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Portfolio Governance Framework" ;
    skos:definition "A Directive Information Content Entity that prescribes the rules, metrics, and procedures for identifying, selecting, prioritizing, and monitoring portfolio components." .

ex:PortfolioStatusReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Portfolio Status Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the health and progress of an Organization's business portfolio as observed through monitoring." .

ex:ProgramStructureSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Program Structure Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the framework and approach for managing a business program, including governance, alignment, assurance, and management." .

ex:ProgramPerformanceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Program Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the evaluated performance of a business program against its goals, completion dates, defects, and cost-effectiveness." .

ex:ProjectScopeStatement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Project Scope Statement" ;
    skos:definition "A Directive Information Content Entity that prescribes the goals, deliverables, tasks, costs, deadlines, and boundaries of a business project." .

ex:ProjectRequirementsStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Project Requirements Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes the discerned capabilities, features, and attributes a project's deliverables are required to have, as recognized and registered by a requirements-discernment act." ;
    rdfs:comment "Descriptive (a registration of stated/discerned requirements), parallel to the sibling outputs ex:ProjectResourceRequirementsStatement (853, P16412) and ex:ITRequirementsStatement (853, P11124). Output of ex:P11117 'Identify project requirements and objectives'. Any directive force (deliverables MUST satisfy X) would be a separate downstream Directive ICE composed by a Formulation act -- mirroring how ex:BusinessCase (P11120) stays descriptive and leaves the go/no-go as a separate Directive -- and is not modeled by this discernment act." .

ex:ProjectReadinessAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Project Readiness Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the culture and readiness of an organizational environment for adopting a project-management approach." .

ex:BusinessCase a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Business Case" ;
    skos:definition "A Descriptive Information Content Entity that describes a current situation, proposed solution, financial analysis, and conclusion in order to justify a course of action to a decision maker." ;
    rdfs:comment "Descriptive (an argument/justification representing a situation), not Directive; the go/no-go decision it supports is a separate Directive ICE." .

ex:ProjectManagementMethodologySelection a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Project Management Methodology Selection" ;
    skos:definition "A Directive Information Content Entity that prescribes the project-management methodology chosen for designing, planning, implementing, and achieving project objectives." .

ex:ProjectPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Project Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the resources, roles, IT requirements, training, communication, reward approaches, and launch for executing a business project." .

ex:TrainingPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Training Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the actions for equipping personnel with the skills and abilities to fulfill their roles." ;
    rdfs:comment "Shared across 13.2.3.3.4, 13.4.2.3, 13.5.1.7." .

ex:CommunicationPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Communication Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the goals, audiences, and tools for imparting or exchanging information relevant to a project, change, or initiative." ;
    rdfs:comment "Shared across 13.2.3.3.4, 13.4.2.4, 13.5.1.7." .

ex:RecognitionAndRewardPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Recognition and Reward Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes incentives, bonuses, and recognition for extraordinary performance within a project or change initiative." ;
    rdfs:comment "Shared across 13.2.3.3.5 and 13.4.2.6." .

ex:ProjectLaunchPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Project Launch Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes when to initiate a project and how to introduce it to its target audience, including team, objectives, timelines, and milestones." .

ex:ProjectStatusReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Project Status Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the current status of a project, including completed, incomplete, and planned tasks and problems faced." .

ex:ProjectPerformanceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Project Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes a project's performance against scope, schedule, quality, cost, and risk criteria, including deviations from plan." .

ex:ProjectReviewRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Project Review Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the findings and lessons learned from a post-project or after-action review." .

ex:ProjectResourceRequirementsStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Project Resource Requirements Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes the people, skills, capital, facilities, equipment, material, and information a project requires." ;
    rdfs:comment "Descriptive (an enumeration of identified prerequisites). Output of ex:P16412 'Identify project resource requirements'." .

ex:ITRequirementsStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Requirements Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes the information-technology requirements -- computers and telecommunications equipment to store, retrieve, transmit, and manipulate data -- of a specific project." ;
    rdfs:comment "Descriptive (an enumeration of discerned IT requirements). Output of ex:P11124 'Identify specific IT requirements'." .

ex:ProjectPortfolioSelection a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Project Portfolio Selection" ;
    skos:definition "A Directive Information Content Entity that prescribes which projects are selected and prioritized for the portfolio based on preestablished criteria." ;
    rdfs:comment "Directive (a selection/prioritization decision). Output of ex:P21454 'Prioritize and select projects for the portfolio'." .

ex:ProjectManagementImpactAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Project Management Impact Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the assessed impact of project-management strategy and projects on the organization's measures and outcomes." ;
    rdfs:comment "Descriptive (an assessment/judgement of impact). Output of ex:P11131 'Evaluate impact of project management on measures and outcomes'." .

# ---- 13.3 Manage enterprise quality ----------------------------------

ex:CriticalToQualityCharacteristicSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Critical-to-Quality Characteristic Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the key measurable performance characteristics that products and processes must satisfy to meet customer needs." .

ex:QualityControlSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality Control Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the process steps, methods, and competencies for controlling enterprise quality." .

ex:SamplingPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sampling Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes which parameters to measure, sample sizes, the sampling scheme, and the roles for taking samples." .

ex:QualityPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes how critical-to-quality characteristics will be achieved, controlled, ensured, and managed throughout a product or service lifecycle." .

ex:QualityTestDataRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Quality Test Data Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the data and results collected from testing organizational outputs against the quality plan." .

ex:QualityTestResultDisposition a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality Test Result Disposition" ;
    skos:definition "A Directive Information Content Entity that prescribes the action to take on a quality test result, such as quarantine, scrap, or rework." ;
    rdfs:comment "Directive: a disposition decision prescribes a course of action on the tested item." .

ex:SampleSignificanceAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sample Significance Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes whether a test sample is representative of the larger output and meets acceptance requirements." .

ex:QualityTestSummary a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Quality Test Summary" ;
    skos:definition "A Descriptive Information Content Entity that describes the major facts, figures, and conclusions of quality test results." .

ex:QualityImprovementRecommendation a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality Improvement Recommendation" ;
    skos:definition "A Directive Information Content Entity that prescribes recommended measures for improving the quality plan based on test results." ;
    rdfs:comment "Directive: a recommendation that prescribes actions for management to consider." .

ex:QualityImprovementActionDecision a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality Improvement Action Decision" ;
    skos:definition "A Directive Information Content Entity that prescribes which of the recommended quality-improvement actions the organization has decided to adopt." ;
    rdfs:comment "Directive: a decision selecting and committing to a subset of recommended actions. Minted so that 17490 (produces the recommendation) -> 17491 (decides which recommended actions to adopt, producing this decision) form a non-degenerate input->output chain, rather than 17491 emitting its own input." ;
    skos:example "Management's documented decision to adopt two of the four recommended control-limit changes next quarter." .

ex:NonconformanceImpactAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Nonconformance Impact Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the potential impact of a non-conformance event and the need for corrective or preventive action." .

ex:RootCauseAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Root Cause Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the underlying causes that triggered a non-conformance event or activity." ;
    rdfs:comment "Shared with 13.3.3.3; also relevant to risk/root-cause work in 13.4." .

ex:CorrectiveAndPreventiveActionSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Corrective and Preventive Action Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the corrective and preventive actions to eliminate the cause of a detected non-conformity and prevent its recurrence." .

ex:NonconformanceRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Nonconformance Record" ;
    skos:definition "A Descriptive Information Content Entity that describes a closed non-conformance, including its documented root causes and the corrective and preventive actions taken." .

ex:CorrectiveActionCompletionRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Corrective Action Completion Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the corrective and preventive actions carried out against a non-conformity and the resulting state after implementation and monitoring." ;
    rdfs:comment "Descriptive (a completion/effect record), not Directive: it represents what was done and the brought-about state, in contrast to the governing ex:CorrectiveAndPreventiveActionSpecification (the input directive). Output of ex:P17496 'Take corrective or preventative action'." ;
    skos:example "A closed CAPA log entry recording the tooling change implemented and the post-change defect rate observed." .

ex:QualityStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an Organization's techniques, standards, responsibilities, and procedures for managing enterprise quality." .

ex:EQMSPerformanceAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "EQMS Performance Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the benchmarked performance of an enterprise quality management system and the gaps relative to industry peers." .

ex:PreventiveQualityActivitySpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Preventive Quality Activity Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes preventive quality activities and the standard methodology for designing or conducting them in order to mitigate the risk of not meeting critical-to-quality characteristics." ;
    rdfs:comment "Minted: distinct from event-triggered Corrective and Preventive Action Specification; this is requirement-gap-driven prevention (output of ex:P17474)." .

ex:MeasurementMethodSelection a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Measurement Method Selection" ;
    skos:definition "A Directive Information Content Entity that prescribes the tools and methods chosen to measure quality levels." ;
    rdfs:comment "Minted: Directive output of choosing measurement methods from candidate tools (output of ex:P17478)." .

ex:CompetencyRequirementSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Competency Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the competencies required to perform a defined set of quality-control activities." ;
    rdfs:comment "Minted: no competency-requirement directive in the shared vocabulary (output of ex:P17479)." .

ex:ComplianceCapabilityDemonstration a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Compliance Capability Demonstration" ;
    skos:definition "A Descriptive Information Content Entity that describes evidence demonstrating an organization's ability to confirm and fulfil its quality requirements before stakeholders." ;
    rdfs:comment "Minted: descriptive evidentiary artifact (SPC, process-capability analysis) of conformance ability (output of ex:P17480)." .

ex:EQMSScopeAndGoalSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "EQMS Scope and Goal Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the scope, targets, and goals of an enterprise quality management system." ;
    rdfs:comment "Minted: distinct from the broader Quality Strategy; fixes the deployable EQMS scope/targets/goals (output of ex:P17498/ex:P17500)." .

ex:QualityPartnershipAgreement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Quality Partnership Agreement" ;
    skos:definition "A Directive Information Content Entity that prescribes the terms of a partnership with a third party formed to advance quality excellence." ;
    rdfs:comment "Minted: directive artifact governing an established quality partnership (output of ex:P17506)." .

# ---- 13.4 Manage change ----------------------------------------------

ex:StakeholderAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Stakeholder Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the internal and external stakeholders affected by a change and the degree of influence the change has on them." .

ex:ChangeReadinessAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Change Readiness Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the preparedness of the conditions, attitudes, and resources at all levels of an Organization for a change to succeed." .

ex:CurrentStateAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Current State Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the existing processes, structures, and culture of an Organization prior to a change." .

ex:FutureStateSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Future State Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the target state an Organization intends to reach after implementing a change, including resource requirements." .

ex:OrganizationalRiskAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Organizational Risk Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the impact and probability of threats to an Organization's critical assets." .

ex:CulturalContextAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Cultural Context Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes an Organization's culture and the aspirations for it along multiple dimensions." .

ex:ChangeImpactAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Change Impact Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes which groups and assets are impacted by a change and the degree of that impact." .

ex:ChangeBarrierAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Change Barrier Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the obstacles, resistors, and enablers bearing on an Organization's change." .

ex:ChangeManagementPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Change Management Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the reasons, type, scope, team, and communications for managing an Organization's change." .

ex:RewardsAndIncentivesPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Rewards and Incentives Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the rewards and incentives for employees who exhibit the behavior desired by a change." .

ex:ChangeAdoptionMeasureSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Change Adoption Measure Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the measures and standards for assessing the adoption of a change." .

ex:RoleDefinitionSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Role Definition Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the new roles and responsibilities to be assigned to personnel." ;
    rdfs:comment "Shared across 13.4.2.8 'Establish/Clarify new roles' and 13.2.3.3.1 'Define roles and resources'." .

ex:ChangeReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Change Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the outcome of a change and the impact it had on critical assets." .

ex:LessonsLearnedRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Lessons Learned Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the insights and knowledge captured from a completed change or project for reuse." ;
    rdfs:comment "Shared across 13.4.4.2 and 13.2.3.4.5 project reviews." .

# ---- 13.5 Knowledge management ---------------------------------------

ex:KMStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "KM Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an Organization's plan for capturing, maintaining, accessing, and exploiting its knowledge base." .

ex:KMGovernanceModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "KM Governance Model" ;
    skos:definition "A Directive Information Content Entity that prescribes the structure, roles, and accountability for governing an Organization's collective knowledge." .

ex:KMFundingModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "KM Funding Model" ;
    skos:definition "A Directive Information Content Entity that prescribes the funding approach selected for an Organization's knowledge management program." .

ex:KMMethodologySpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "KM Methodology Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the core procedures and methodologies for developing, planning, executing, and improving knowledge management." ;
    rdfs:comment "Covers 'KM approaches' (policies, procedures, guidelines) developed and implemented in 13.5.3/13.5.4." .

ex:KMCapabilityMaturityAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "KM Capability Maturity Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the maturity level of existing knowledge-management initiatives." .

ex:KMApproachEvaluation a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "KM Approach Evaluation" ;
    skos:definition "A Descriptive Information Content Entity that describes an evaluation of existing knowledge-management procedures, policies, and guidelines against industry best practices." .

ex:GapAndNeedsAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Gap and Needs Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the gaps and needs identified by comparing actual performance or capability against a desired or standard reference." ;
    rdfs:comment "Shared across 13.5.2.3 and the gap-analysis work in 13.6.2.4." .

ex:KMInitiativeLinkageAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "KM Initiative Linkage Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the correlations and dependencies between an organization's knowledge-management strategy and its other functional areas or initiatives." ;
    rdfs:comment "Minted locally: not present in the shared vocabulary list. Descriptive (represents discovered correlations) per the GOLDEN PRINCIPLE; it is the definitional output of ex:P11104." .

ex:ITNeedsAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "IT Needs Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the information-technology requirements for building and implementing a knowledge-management strategy." ;
    rdfs:comment "Minted locally: not present in the shared vocabulary list. Descriptive (judges/represents requirements) per the GOLDEN PRINCIPLE; it is the definitional output of ex:P11106." .

ex:KMResourceModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "KM Resource Model" ;
    skos:definition "A Directive Information Content Entity that prescribes the resources, standards, and guidelines an organization's knowledge-management approaches are to follow." ;
    rdfs:comment "Minted locally: not present in the shared vocabulary list. Directive (prescribes resources/standards/guidelines) per the GOLDEN PRINCIPLE; it is the definitional output of ex:P20966." .

ex:KMAwarenessCommunication a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "KM Awareness Communication" ;
    skos:definition "A Descriptive Information Content Entity that describes the awareness-and-engagement messaging promoting use of an Organization's available knowledge bases." ;
    rdfs:comment "Descriptive: the communicated content disseminated to raise awareness and drive use of knowledge bases. Output of ex:P20970 'Sustain awareness and engagement' (a communication/promotion act)." ;
    skos:example "An internal campaign message encouraging staff to contribute to and consult the knowledge base." .

# ---- 13.6 Measure and benchmark --------------------------------------

ex:OrganizationalPerformanceStrategy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Organizational Performance Strategy" ;
    skos:definition "A Directive Information Content Entity that prescribes an Organization's approach for measuring, tracking, streamlining, and improving internal performance." .

ex:EnterpriseMeasurementModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Enterprise Measurement Model" ;
    skos:definition "A Directive Information Content Entity that prescribes which processes to measure, which measures to use, how often to measure, and the measurement targets across an enterprise." .

ex:PerformanceData a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Data" ;
    skos:definition "A Descriptive Information Content Entity that describes consolidated metrics and trends collected on the performance of a process, function, or organization." .

ex:PerformanceMeasurement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Measurement" ;
    skos:definition "A Descriptive Information Content Entity that describes the quantified performance of a process or organization relative to defined indicators." ;
    rdfs:comment "Genus is generic Descriptive ICE rather than CCO Measurement ICE leaf, per GOLD house style of anchoring at the descriptive parent." .

ex:PerformanceAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes a judgement of the performance of people, processes, or other areas the Organization wants to benchmark or track." .

ex:BenchmarkAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Benchmark Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes a comparison of an Organization's performance internally or against external organizations." .

ex:PerformanceTrendAnalysis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Trend Analysis" ;
    skos:definition "A Descriptive Information Content Entity that describes the trends discerned in performance results over time." .

ex:PerformanceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes performance, including performance gaps, trends, and analysis, for the appropriate authority." .

ex:PerformanceImprovementPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Performance Improvement Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the actions for bridging identified performance gaps." .

ex:ChangeNeedStatement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Change Need Statement" ;
    skos:definition "A Directive Information Content Entity that prescribes the need and rationale for changing an Organization's performance, derived from gap-analysis results." ;
    rdfs:comment "Used by 13.6.2.5 'Establish need for change'; can feed 13.4 change planning." .

ex:MonitoringFrequencySpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Monitoring Frequency Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes how often performance is to be supervised, measured, and assessed." ;
    rdfs:comment "Minted for APQC 13.6.3.2 'Establish monitoring frequency'. Directive (not Descriptive) because it prescribes a monitoring cadence rather than describing reality. Distinct from ex:PerformanceIndicatorSpecification (which prescribes what is measured, not how often)." .

# ---- 13.7 Develop, manage, and deliver analytics ---------------------

ex:StakeholderNeedsStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Stakeholder Needs Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes the needs and requirements gathered from stakeholders prior to conducting analytics." .

ex:AnalyticsProjectScopeStatement a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Analytics Project Scope Statement" ;
    skos:definition "A Directive Information Content Entity that prescribes the size and scale of an analytics project based on collected information." .

ex:Hypothesis a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Hypothesis" ;
    skos:definition "A Descriptive Information Content Entity that describes a proposed explanation of empirical data, used to guide feature selection during data collection." ;
    rdfs:comment "Descriptive: a hypothesis asserts a candidate account of how reality is, not a prescription." .

ex:AnalyticsDataset a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Analytics Dataset" ;
    skos:definition "A Descriptive Information Content Entity consisting of structured and unstructured data gathered, cleaned, and converted to a uniform format for analysis." .

ex:PreparedDataset a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Prepared Dataset" ;
    skos:definition "A Descriptive Information Content Entity consisting of a validated dataset created and verified to be fit for the initiation of analysis." ;
    rdfs:comment "Descriptive: the validated, analysis-ready dataset. Minted distinct from ex:AnalyticsDataset (the collected/cleaned dataset of 13.7.4) so the parallel pipeline steps 20961 'Collect data' and 21461 'Prepare data' have distinct outputs. Output of ex:P21461." .

ex:DataAnalysisResult a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Data Analysis Result" ;
    skos:definition "A Descriptive Information Content Entity that describes the patterns, trends, error rates, and outliers revealed by statistical analysis of data." .

ex:DataModel a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Data Model" ;
    skos:definition "A Directive Information Content Entity that prescribes the conceptual and physical structure and storage of data." ;
    rdfs:comment "Directive: a data model prescribes how data is to be structured and stored (a model/blueprint), per CCO's notion of prescription for Continuants." .

ex:DataModelReviewRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Data Model Review Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the outcome of reviewing data models with stakeholders against the original research question and hypothesis." .

ex:AnalysisReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Analysis Report" ;
    skos:definition "A Descriptive Information Content Entity that summarizes and documents the results of data analysis, including graphs and visualizations of numerical findings." .

ex:RemedialActionSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Remedial Action Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the steps to be taken to correct identified shortcomings." ;
    rdfs:comment "Shared between 13.7.11 'Identify remedial actions' and corrective-action work in 13.4.4.3." .

# ---- 13.8 Manage environmental health and safety ---------------------

ex:EnvironmentalImpactAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Environmental Impact Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the environmental impact of an Organization's products, services, and operations over their lifecycle." .

ex:EHSAuditReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "EHS Audit Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the findings of an inspection verifying compliance with environmental, health, and safety standards." .

ex:EHSRequirementSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "EHS Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the regulatory and stakeholder protocols and standards an Organization must comply with for environment, health, and safety." ;
    rdfs:comment "Directive ICE authored externally by regulators/stakeholders, NOT by the discernment act ex:P11188. P11188 consumes it as a has-input and produces the Descriptive ex:EHSRequirementRegister; it does not compose this directive." .

ex:EHSRequirementRegister a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "EHS Requirement Register" ;
    skos:definition "A Descriptive Information Content Entity that registers the regulatory and stakeholder protocols and standards an Organization has discerned it must comply with for environment, health, and safety." ;
    rdfs:comment "Descriptive (a register/record of discerned, externally-set requirements). Output of ex:P11188 'Identify regulatory and stakeholder requirements', restoring Info-Processing -> Descriptive agreement (GOLDEN PRINCIPLE). The externally-authored Directive ex:EHSRequirementSpecification is the has-input it captures." .

ex:EHSRiskAndOpportunityAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "EHS Risk and Opportunity Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the future risks and opportunities affecting the environmental, health, and safety of products and services." .

ex:EHSPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "EHS Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the minimum requirements, procedures, and tools by which an Organization will manage its environmental, health, and safety impact." .

ex:EHSEventRecord a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "EHS Event Record" ;
    skos:definition "A Descriptive Information Content Entity that describes the events and activities associated with complying with environmental, health, and safety standards." .

ex:EHSPerformanceReport a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "EHS Performance Report" ;
    skos:definition "A Descriptive Information Content Entity that describes the measured performance of an environmental, health, and safety program against its indicators." .

ex:EHSCostBenefitAssessment a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "EHS Cost-Benefit Assessment" ;
    skos:definition "A Descriptive Information Content Entity that describes the evaluated costs and benefits of an environmental, health, and safety program and whether its benefits outweigh its costs." ;
    rdfs:comment "Descriptive (a judgement of cost vs benefit). Output of ex:P11193 'Manage EHS costs and benefits'." .

ex:EmergencyResponseProgram a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Emergency Response Program" ;
    skos:definition "A Directive Information Content Entity that prescribes how available resources are organized, coordinated, and directed to respond to emergency scenarios." .

ex:PollutionPreventionProgram a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Pollution Prevention Program" ;
    skos:definition "A Directive Information Content Entity that prescribes how an Organization reduces or eliminates the creation of pollutants through increased efficiency in resource use." .

# ---- 13.9 Manage sustainability --------------------------------------

ex:SustainabilityRequirementSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sustainability Requirement Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes the disclosure, governance, functional, and performance requirements an Organization must satisfy for sustainability (ESG)." .

ex:SustainabilityGoalSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sustainability Goal Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes an Organization's measurable sustainability goals and qualitative and quantitative targets." .

ex:SustainabilityPolicy a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sustainability Policy" ;
    skos:definition "A Directive Information Content Entity that prescribes the written procedures and supporting tools by which an Organization will meet its sustainability requirements." .

ex:SustainabilityMeasureSpecification a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sustainability Measure Specification" ;
    skos:definition "A Directive Information Content Entity that prescribes organization-wide sustainability measures, including data-collection strategies, calculations, analytics, and reporting formats." .

ex:SustainabilityPlan a owl:Class ; rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Sustainability Plan" ;
    skos:definition "A Directive Information Content Entity that prescribes the sustainability actions for an Organization, its functional units, and support services, aligned to requirements, goals, and governance." .

ex:SustainabilityPerformanceMeasurement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sustainability Performance Measurement" ;
    skos:definition "A Descriptive Information Content Entity that describes collected and validated sustainability performance data appraised against requirements and targets, including audit findings and identified gaps and variances." ;
    rdfs:comment "Descriptive appraisal record. Output of ex:P21602 'Measure sustainability performance' (an Act of Appraisal) and has-input of ex:P21603." .

ex:SustainabilityStatement a owl:Class ; rdfs:subClassOf cco:ont00000853 ;
    rdfs:label "Sustainability Statement" ;
    skos:definition "A Descriptive Information Content Entity that describes an Organization's sustainability performance prepared for reporting to its audiences." .

####################################################################
# 6. PROCESS CLASSES + group capabilities
# ===== group 13.1 Manage business processes (PCF 16378) ===========
# Group node modeled as ex:BusinessProcessManagementCapability (above).
####################################################################

# --- 13.1.1 (PCF 16379) : establish governance -> Formulation
ex:P16379 a owl:Class ;
    ex:pcfID "16379" ; ex:hierarchyID "13.1.1" ;
    ex:apqcSourceText "Defining and managing the organization's approach to governing business process management. Establish and manage tools to support the governance process. Assign ownership for all business processes. Perform activities to administer the governing process." ;
    rdfs:label "Establish and maintain process management governance" ;
    skos:definition "An Act of Formulation that composes and maintains an organization's approach to governing business process management and produces a process governance framework." ;
    rdfs:comment "Reality-layer occurrent for APQC 13.1.1. Anchored to ex:ActOfFormulation because its definitional output is a Directive ICE (the governance framework). Its APQC children are process parts, not subclasses." ;
    skos:example "A BPM office stands up and maintains the charter, tooling, and ownership model that govern process management." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessGovernanceFramework ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16380 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16381 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16382 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16383 ] .

# --- 13.1.1.1 (PCF 16380) : define governance approach -> Formulation
ex:P16380 a owl:Class ;
    ex:pcfID "16380" ; ex:hierarchyID "13.1.1.1" ;
    ex:apqcSourceText "Outlining and managing the methodology for administering business process management (BPM). Define the method for setting standards and priorities for BPM efforts. Identify BPM governance leaders. Define BPM project participants' roles." ;
    rdfs:label "Define and manage governance approach" ;
    skos:definition "An Act of Formulation that articulates the methodology for administering business process management and produces a process governance framework specifying standards, priorities, and participant roles." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the output (the governance approach/methodology) is a Directive ICE." ;
    skos:example "A BPM lead documents how BPM standards are set and names the governance leaders and their roles." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessGovernanceFramework ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:BPMGovernanceLeader ] .

# --- 13.1.1.2 (PCF 16381) : tools and templates -> Formulation
ex:P16381 a owl:Class ;
    ex:pcfID "16381" ; ex:hierarchyID "13.1.1.2" ;
    ex:apqcSourceText "Instituting, organizing, and maintaining the upkeep of the techniques used for business process management (BPM). Create and maintain templates of BPM tools that can be readily implemented, including process engine, business analytics, content management, and collaboration tools." ;
    rdfs:label "Establish and maintain process tools and templates" ;
    skos:definition "An Act of Formulation that institutes and maintains the techniques of business process management and produces reusable BPM tool templates." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output (a BPM tool template) is a Directive ICE prescribing a ready-to-implement tool configuration." ;
    skos:example "A team builds and curates reusable process-engine and analytics templates for the BPM toolkit." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BPMToolTemplate ] .

# --- 13.1.1.3 (PCF 16382) : assign ownership -> Planned Act (confers a role)
ex:P16382 a owl:Class ;
    ex:pcfID "16382" ; ex:hierarchyID "13.1.1.3" ;
    ex:apqcSourceText "Assigning resources (employees) ownership of tasks. These include the responsibility of identifying, analyzing, and improving business processes in order to meet the goals and objectives such as increasing profits and performance, reducing costs, and accelerating schedules." ;
    rdfs:label "Assign and support process ownership" ;
    skos:definition "A Planned Act that allocates responsibility for business processes to employees, conferring the process owner role and producing a role-definition specification." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): assigning ownership confers a Role on an Agent; it is neither analysis nor the formulation of a standalone strategy. The conferred role is ex:ProcessOwnerRole, borne by ex:ProcessOwner." ;
    skos:example "A BPM governance board names accountable owners for each end-to-end process." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RoleDefinitionSpecification ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProcessOwner ] .

# --- 13.1.1.4 (PCF 16383) : perform governance activities -> Implementation
ex:P16383 a owl:Class ;
    ex:pcfID "16383" ; ex:hierarchyID "13.1.1.4" ;
    ex:apqcSourceText "Implementing and executing activities for governing business processes. Execute activities that encourage participation, accountability, transparency, responsiveness, equity and inclusiveness, etc. within the business processes." ;
    rdfs:label "Perform process governance activities" ;
    skos:definition "An Act of Implementation that carries out the activities prescribed by an organization's process governance framework." ;
    rdfs:comment "Anchored to ex:ActOfImplementation: the act enacts the governance framework (a Directive ICE input) rather than producing a new ICE; the framework is a definitional input." ;
    skos:example "Governance staff run the recurring review and accountability rituals defined in the BPM charter." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProcessGovernanceFramework ] .

# --- 13.1.2 (PCF 16384) : define process frameworks -> Formulation
ex:P16384 a owl:Class ;
    ex:pcfID "16384" ; ex:hierarchyID "13.1.2" ;
    ex:apqcSourceText "Determining and organizing the structural composition of business processes. Design, establish, and administer the framework. Identify any cross-functional processes that are mandatory for achieving business excellence." ;
    rdfs:label "Define and manage process frameworks" ;
    skos:definition "An Act of Formulation that designs and organizes the structural composition of an organization's business processes and produces a process framework." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output (the process framework) is a Directive ICE. Its APQC children are process parts." ;
    skos:example "An enterprise-architecture team designs the process framework spanning strategy, operations, and enterprise management." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessFramework ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16385 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16386 ] .

# --- 13.1.2.1 (PCF 16385) : establish framework -> Formulation
ex:P16385 a owl:Class ;
    ex:pcfID "16385" ; ex:hierarchyID "13.1.2.1" ;
    ex:apqcSourceText "Defining and managing the framework that outlines the required business processes of the organization, key elements, and how they should interact. Institute strategy infrastructure and product, operations, and enterprise management." ;
    rdfs:label "Establish and maintain process framework" ;
    skos:definition "An Act of Formulation that composes and maintains the framework outlining an organization's required business processes, their key elements, and their interactions, and produces a process framework." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: its definitional output (the process framework) is a Directive ICE." ;
    skos:example "Architects publish the canonical process framework that all functions must align to." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessFramework ] .

# --- 13.1.2.2 (PCF 16386) : identify cross-functional processes -> Identification
ex:P16386 a owl:Class ;
    ex:pcfID "16386" ; ex:hierarchyID "13.1.2.2" ;
    ex:apqcSourceText "Recognizing the different functional areas working on the same project or goal." ;
    rdfs:label "Identify cross-functional processes" ;
    skos:definition "An Act of Identification that discerns the business processes spanning multiple functional areas and produces a cross-functional process register." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment sense): the act enumerates cross-functional processes; its definitional output is a Descriptive ICE." ;
    skos:example "An analyst flags which processes require coordination across sales, finance, and operations." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CrossFunctionalProcessRegister ] .

# --- 13.1.3 (PCF 16387) : define processes -> Formulation
ex:P16387 a owl:Class ;
    ex:pcfID "16387" ; ex:hierarchyID "13.1.3" ;
    ex:apqcSourceText "Outlining and establishing the business processes of the organization. Scope, analyze, map, and publish processes for the employees who may require it." ;
    rdfs:label "Define processes" ;
    skos:definition "An Act of Formulation that outlines and establishes an organization's business processes by scoping, analyzing, mapping, and publishing them." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: defining processes establishes prescriptive process definitions (Directive ICEs). Its APQC children are process parts." ;
    skos:example "A process team scopes, analyzes, models, and publishes the procurement process set." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16388 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16389 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21452 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16390 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16391 ] .

# --- 13.1.3.1 (PCF 16388) : scope processes -> Formulation
ex:P16388 a owl:Class ;
    ex:pcfID "16388" ; ex:hierarchyID "13.1.3.1" ;
    ex:apqcSourceText "Defining the extent and limits of business processes. Define the range and diversity of all the set of activities and tasks that, once completed, will accomplish an organizational goal." ;
    rdfs:label "Scope processes" ;
    skos:definition "An Act of Formulation that defines the extent and limits of a business process and produces a process scope statement." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: a scope statement is a Directive ICE that bounds the process." ;
    skos:example "A BPM analyst writes the scope statement bounding the order-to-cash process." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessScopeStatement ] .

# --- 13.1.3.2 (PCF 16389) : analyze processes -> Analysis
ex:P16389 a owl:Class ;
    ex:pcfID "16389" ; ex:hierarchyID "13.1.3.2" ;
    ex:apqcSourceText "Assessing and examining the set of activities and tasks that, once completed, will accomplish an organizational goal. Create a business process model that captures how a business process works and how individuals from different groups work together to achieve a business goal." ;
    rdfs:label "Analyze processes" ;
    skos:definition "An Act of Analysis that examines the activities and tasks of a business process and produces a process analysis and a process model representing how the process works." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis: it manipulates input information into a descriptive understanding (process analysis / process model). Its child Identify published best practices is a process part." ;
    skos:example "An analyst examines the as-is hiring process and produces a process model and analysis." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessModel ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20140 ] .

# --- 13.1.3.2.1 (PCF 20140) : identify best practices -> Identification
ex:P20140 a owl:Class ;
    ex:pcfID "20140" ; ex:hierarchyID "13.1.3.2.1" ;
    ex:apqcSourceText "Realizing those practices and procedures that are the most effective to the success of the business and making that information available." ;
    rdfs:label "Identify published best practices" ;
    skos:definition "An Act of Identification that discerns the practices and procedures most effective for business success and produces a best-practices register." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment sense): the act enumerates effective practices; its definitional output is a Descriptive ICE." ;
    skos:example "A center of excellence catalogs proven process practices for reuse." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BestPracticesRegister ] .

# --- 13.1.3.3 (PCF 21452) : process control points -> Formulation
ex:P21452 a owl:Class ;
    ex:pcfID "21452" ; ex:hierarchyID "13.1.3.3" ;
    ex:apqcSourceText "Establishment of a \"checkpoint\" in a process that prevent the process from continuing unless all requirements are satisfied." ;
    rdfs:label "Identify and denote process control points" ;
    skos:definition "An Act of Formulation that establishes checkpoints within a process and produces a process control point specification gating continuation on satisfied requirements." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: a control-point specification is a Directive ICE that prescribes a gating rule." ;
    skos:example "A team designates an approval gate that halts the process until compliance checks pass." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessControlPointSpecification ] .

# --- 13.1.3.4 (PCF 16390) : model and document -> Analysis (descriptive model)
ex:P16390 a owl:Class ;
    ex:pcfID "16390" ; ex:hierarchyID "13.1.3.4" ;
    ex:apqcSourceText "Defining what a business entity does, who is responsible, to what standard a business process should be completed, and how the success of a business process can be determined. Identify processes, gather information gathering, interview participants, map processes, and perform analysis." ;
    rdfs:label "Model and document processes" ;
    skos:definition "An Act of Analysis that gathers information about a business process and produces a process model documenting what is done, who is responsible, and to what standard." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (information processing): mapping and documenting yields a Descriptive ICE (the process model). Interviewing/mapping are method sub-steps, not separate processes." ;
    skos:example "An analyst interviews participants and maps the procure-to-pay process into a documented model." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessModel ] .

# --- 13.1.3.5 (PCF 16391) : publish processes -> Communication
ex:P16391 a owl:Class ;
    ex:pcfID "16391" ; ex:hierarchyID "13.1.3.5" ;
    ex:apqcSourceText "Disclosing the information available on business processes. Ensure the availability of the information regarding the business processes to all process team members, business stakeholders, and process owners. Use BPM software, as well as business process diagrams and documents that help depict the required information." ;
    rdfs:label "Publish processes" ;
    skos:definition "An Act of Communication that transfers documented business-process information to process team members, stakeholders, and owners." ;
    rdfs:comment "Anchored to cco:ont00000402 (Act of Communication): publishing transfers an ICE (the process model) from authors to recipients. The process model is a definitional input that is disseminated. cco:ont00000402 is VERIFIED in the §6 verified-core-terms table above (label 'Act of Communication'; def 'A Planned Act in which some Information Content Entity is transferred from some Agent to Another'; parent cco:ont00000228 Planned Act); the explicit cco:ont00000228 co-parent gives Gate C the Act anchor without the CCO closure." ;
    skos:example "A BPM team posts the approved process models to the intranet for all stakeholders." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication (a CCO Planned Act)
        cco:ont00000228 ,   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProcessModel ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.1.4 (PCF 16392) : manage process performance -> Planned Act (parent)
ex:P16392 a owl:Class ;
    ex:pcfID "16392" ; ex:hierarchyID "13.1.4" ;
    ex:apqcSourceText "Evaluating and handling the performance of business processes. Provide training to process owners. Support the execution of business processes. Measure and report the performance of the business processes." ;
    rdfs:label "Manage process performance" ;
    skos:definition "A Planned Act that administers the ongoing performance of business processes by training owners, supporting execution, and measuring and reporting performance." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): this bounded administration cycle aggregates heterogeneous children (training, support, measurement) with no single definitional ICE output, so no has-output restriction is asserted; the children are process parts. DELIBERATE R5 DIVERGENCE FROM SIBLINGS (auditable): the parallel 'Manage X' GROUP nodes -- 16378 'Manage business processes', 17471 'Manage enterprise quality', 11073 'Manage KM', and the 13.2 Manage portfolio/program/project nodes -- are modeled as standing Organization Capabilities (cco:ont00000568) because each is an open-ended enterprise FUNCTION with no natural terminus. P16392 'Manage process performance' is NOT a group node but a 13.1.4 sub-process that, on each performance period (e.g. quarter), runs a bounded train->support->measure-and-report administration cycle with an identifiable begin (period open) and end (period KPI report issued); it passes R5 as a repeatable bounded occurrent and is a proper part of the standing ex:BusinessProcessManagementCapability, which is realized in it. Thus the divergence is intentional: the standing FUNCTION is the capability; the repeatable bounded CYCLE that realizes it is this Planned Act." ;
    skos:example "Each quarter the BPM office trains owners, supports execution, and reports process KPIs." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16393 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16394 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16395 ] .

# --- 13.1.4.1 (PCF 16393) : provide training -> Act of Training (CCO)
ex:P16393 a owl:Class ;
    ex:pcfID "16393" ; ex:hierarchyID "13.1.4.1" ;
    ex:apqcSourceText "Providing training for the employees and process owners that administer the business processes. Design internal training programs or source third party agencies to provide the skills and training necessary." ;
    rdfs:label "Provide process training" ;
    skos:definition "An Act of Training in which process-management knowledge and skills are imparted to the employees and process owners who administer business processes." ;
    rdfs:comment "Anchored to cco:ont00000234 (Act of Training): the act imparts skills to Agents. Process owners are definitional participants/recipients. cco:ont00000234 is VERIFIED in the §6 verified-core-terms table above (label 'Act of Training'; def 'A Planned Act in which knowledge, skills or values are imparted from one or more Agents to at least one other Agent'; parent cco:ont00000228 Planned Act) -- its definition (imparting skills to Agents) matches this use." ;
    skos:example "The BPM office runs a workshop teaching new owners how to monitor their processes." ;
    rdfs:subClassOf cco:ont00000234 ,   # Act of Training (a CCO Planned Act)
        cco:ont00000228 ,   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProcessOwner ] .

# --- 13.1.4.2 (PCF 16394) : support execution -> Implementation
ex:P16394 a owl:Class ;
    ex:pcfID "16394" ; ex:hierarchyID "13.1.4.2" ;
    ex:apqcSourceText "Assisting and executing the business processes. Use business process execution language (BEPL), which is a standard, executable language for specifying actions within the business processes with the use of web services." ;
    rdfs:label "Support process execution" ;
    skos:definition "An Act of Implementation that assists and carries out the running of an organization's business processes." ;
    rdfs:comment "Anchored to ex:ActOfImplementation: supporting execution enacts the defined processes rather than producing an ICE. BPEL is a method detail, not a definitional I/O." ;
    skos:example "A BPM support team keeps the automated approval workflows running and unblocks exceptions." ;
    rdfs:subClassOf ex:ActOfImplementation .

# --- 13.1.4.3 (PCF 16395) : measure and report -> Monitoring
ex:P16395 a owl:Class ;
    ex:pcfID "16395" ; ex:hierarchyID "13.1.4.3" ;
    ex:apqcSourceText "Defining and using performance indicators to consider the financial perspective, customer perspective, internal process perspective, and learning perspective of the organization." ;
    rdfs:label "Measure and report process performance" ;
    skos:definition "An Act of Monitoring that uses defined performance indicators to measure business-process performance and produces a process performance report." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring: it tracks performance and yields a Descriptive ICE (the performance report). Performance indicator specifications are a definitional input. Its child Identify additional metrics is a process part." ;
    skos:example "An analyst publishes a balanced-scorecard report of the hiring process each month." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceIndicatorSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessPerformanceReport ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20141 ] .

# --- 13.1.4.3.1 (PCF 20141) : identify additional metrics -> Formulation
ex:P20141 a owl:Class ;
    ex:pcfID "20141" ; ex:hierarchyID "13.1.4.3.1" ;
    ex:apqcSourceText "Determining the need for additional performance indicators that would be necessary to successfully achieve the business goal." ;
    rdfs:label "Identify additional metrics as required" ;
    skos:definition "An Act of Identification that determines whether additional performance indicators are needed to achieve a business goal and produces a metric gap assessment registering that need." ;
    rdfs:comment "RE-ANCHORED from ex:ActOfFormulation to ex:ActOfIdentification. Source text is 'Determining the NEED for additional performance indicators that would be necessary' -- a discernment/appraisal that yields a descriptive gap-finding (whether more metrics are required), NOT the composition of the KPI specification itself. Rejected candidate ex:ActOfFormulation (Planning -> Directive output): it over-commits, modeling the authoring of the indicator spec rather than the determination of the gap, and would violate the GOLDEN PRINCIPLE (a descriptive determination paired with a Directive output). This re-anchoring aligns the row with its sibling 'Identify' rows 16386 and 20140, which are ex:ActOfIdentification (information-processing, Descriptive). The actual composition of any new indicator spec is a downstream formulation act (cf. ex:P10270 / ex:P11109)." ;
    skos:example "When a new goal is set, an analyst determines that no current KPI tracks it and records the metric gap." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MetricGapAssessment ] .

# --- 13.1.5 (PCF 21453) : improve processes -> Improvement (parent)
ex:P21453 a owl:Class ;
    ex:pcfID "21453" ; ex:hierarchyID "13.1.5" ;
    ex:apqcSourceText "Identifying, selecting, and managing improvements. Based on the type and scope of the improvement, determination of the appropriate improvement methodology (e.g., Lean, Six Sigma, etc.) should guide the effort. This includes continuous improvement, process redesign, process reengineering, and application of the organizations approaches for Manage projects." ;
    rdfs:label "Improve processes" ;
    skos:definition "An Act of Improvement that identifies, selects, and manages modifications to an organization's business processes so as to raise their efficiency and effectiveness." ;
    rdfs:comment "Anchored to ex:ActOfImprovement: the act changes existing processes to optimize them. Its APQC children are process parts." ;
    skos:example "A continuous-improvement program runs Lean and Six Sigma initiatives across the process portfolio." ;
    rdfs:subClassOf ex:ActOfImprovement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16397 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11138 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16398 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16399 ] .

# --- 13.1.5.1 (PCF 16397) : identify/select opportunities -> Identification (descriptive)
ex:P16397 a owl:Class ;
    ex:pcfID "16397" ; ex:hierarchyID "13.1.5.1" ;
    ex:apqcSourceText "Helping a process owner to identify, analyze, and improve existing business processes within an organization to meet new goals and objectives." ;
    rdfs:label "Identify and select improvement opportunities" ;
    skos:definition "An Act of Identification that discerns and appraises candidate improvements to existing business processes and produces an improvement opportunity assessment." ;
    rdfs:comment "Anchored to ex:ActOfIdentification: per the GOLDEN PRINCIPLE the definitional output is a Descriptive ICE (the improvement opportunity assessment), so the genus is information-processing rather than Selection. Process owners are definitional participants." ;
    skos:example "A facilitator and the process owner surface and rank improvement opportunities for the billing process." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ImprovementOpportunityAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProcessOwner ] .

# --- 13.1.5.2 (PCF 11138) : select methodology -> Selection (directive)
ex:P11138 a owl:Class ;
    ex:pcfID "11138" ; ex:hierarchyID "13.1.5.2" ;
    ex:apqcSourceText "Assessing and choosing methodologies to identify, analyze, and improve existing processes within an organization to meet new goals and objective. Assess the various methodologies available such as process mapping, statistical process control, and simulation. Choose the most appropriate and effective methodology." ;
    rdfs:label "Select process improvement methodology" ;
    skos:definition "An Act of Selection that chooses the most appropriate process-improvement methodology from available candidates and produces a process improvement methodology selection." ;
    rdfs:comment "Anchored to ex:ActOfSelection: it chooses one option from a candidate set (Lean, Six Sigma, SPC, simulation) and yields a Directive ICE recording the choice." ;
    skos:example "A black belt selects Six Sigma over process mapping for a defect-reduction effort." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessImprovementMethodologySelection ] .

# --- 13.1.5.3 (PCF 16398) : manage improvement projects -> Implementation
ex:P16398 a owl:Class ;
    ex:pcfID "16398" ; ex:hierarchyID "13.1.5.3" ;
    ex:apqcSourceText "Developing and implementing a systematic approach to help the organization optimize its underlying processes in order to achieve more efficient results. Systematically gather information to clarify issues or problems. Intervene for improvements. Restructure training programs as appropriate to increase effectiveness." ;
    rdfs:label "Manage improvement projects" ;
    skos:definition "An Act of Implementation that develops and puts into effect a systematic approach for optimizing an organization's underlying processes." ;
    rdfs:comment "Anchored to ex:ActOfImplementation: managing an improvement project enacts a systematic optimization approach. Modeled as a single bounded improvement-project act; APQC defers detailed project mechanics to category Manage projects." ;
    skos:example "A PMO runs a chartered improvement project to streamline the returns process." ;
    rdfs:subClassOf ex:ActOfImplementation .

# --- 13.1.5.4 (PCF 16399) : continuous improvement -> Improvement
ex:P16399 a owl:Class ;
    ex:pcfID "16399" ; ex:hierarchyID "13.1.5.4" ;
    ex:apqcSourceText "Persistently implementing activities for improving business processes." ;
    rdfs:label "Perform continuous improvement activities" ;
    skos:definition "An Act of Improvement that persistently enacts incremental modifications to business processes to raise their performance." ;
    rdfs:comment "Anchored to ex:ActOfImprovement: each cycle is a repeatable bounded change to a process. The 'persistent/ongoing' framing is realized as many repeatable instances, not a standing function." ;
    skos:example "A team runs weekly kaizen cycles trimming waste from the fulfillment process." ;
    rdfs:subClassOf ex:ActOfImprovement .

# ===== group 13.3 Manage enterprise quality (PCF 17471) ===========
# Group node modeled as capability ex:P17471 (standing 'Manage' function).

# 13.3 (PCF 17471) : R5 = capability; Organization Capability realized in
# its constituent acts. Same intent as ex:EnterpriseQualityManagementCapability.
ex:P17471 a owl:Class ;
    ex:pcfID "17471" ; ex:hierarchyID "13.3" ;
    ex:apqcSourceText "Managing organizational attributes that are closely associated with the quality of output. Determine the quality requirements. Evaluate the correspondence between the quality performance and requirements. Manage non-conformance activities. Ensure implementation and maintenance of the enterprise quality management system." ;
    rdfs:label "Manage enterprise quality" ;
    skos:definition "An Organization Capability that inheres in an Organization to the extent of its capacity to establish quality requirements, evaluate quality performance against those requirements, handle nonconformances, and operate an enterprise quality management system." ;
    rdfs:comment "Modeled as Organization Capability (R5/R6): 'Manage enterprise quality' is a standing function with no natural end, realized in its constituent acts rather than being a single bounded occurrent. Same capability as the shared ex:EnterpriseQualityManagementCapability. DELIBERATE R5 DIVERGENCE FROM SIBLING 13.4 (auditable, uniform criterion): unlike 'Manage change' (P11074), which is a discrete transformation INITIATIVE with a natural terminus and is therefore minted as a bounded Planned Act, quality management is a PERMANENT enterprise function with no natural end and so is capability-only (no ex:P process). The same capability-only treatment applies to 13.1 (16378), 13.5 (11073), and the 13.2 portfolio/program/project management functions. See the cross-reference on ex:P11074." ;
    skos:example "A manufacturer's standing quality-management function spanning requirements, testing, nonconformance handling, and its EQMS." ;
    rdfs:subClassOf cco:ont00000568 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P17472 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P17482 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P17492 ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom ex:P17498 ] .

# --- 13.3.1 (PCF 17472) : establish quality requirements -> Formulation
ex:P17472 a owl:Class ;
    ex:pcfID "17472" ; ex:hierarchyID "13.3.1" ;
    ex:apqcSourceText "Determining essential activities, processes, and attributes for securing enterprise quality. Outline critical characteristics for quality. Outline activities encouraging the preservation of quality. Create quality controls. Confirm capabilities in accordance with quality requirements. Finalize the plan for quality maintenance." ;
    rdfs:label "Establish quality requirements" ;
    skos:definition "An Act of Formulation that determines the critical characteristics, preventive activities, and controls securing enterprise quality and produces a quality plan." ;
    rdfs:comment "Aggregating planning process; its APQC children are process parts (cco:ont00001777), not subclasses." ;
    skos:example "A quality team translates customer needs into critical-to-quality characteristics, controls, and a finalized quality plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17473 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17474 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17475 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17480 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17481 ] .

# --- 13.3.1.1 (PCF 17473) : Formulation -> Directive CtQ spec
ex:P17473 a owl:Class ;
    ex:pcfID "17473" ; ex:hierarchyID "13.3.1.1" ;
    ex:apqcSourceText "Outlining characteristics crucial for managing enterprise quality. Translate broad customer needs into specific, actionable, measurable performance requirements. Define the key measurable characteristics of key products and processes." ;
    rdfs:label "Define critical-to-quality characteristics" ;
    skos:definition "An Act of Formulation that translates customer needs into a critical-to-quality characteristic specification of measurable product and process requirements." ;
    skos:example "An engineer converts a customer expectation into a measurable tolerance on a key product dimension." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CriticalToQualityCharacteristicSpecification ] .

# --- 13.3.1.2 (PCF 17474) : Formulation -> Directive preventive-activity spec
ex:P17474 a owl:Class ;
    ex:pcfID "17474" ; ex:hierarchyID "13.3.1.2" ;
    ex:apqcSourceText "Identifying gaps in customer requirements and determining whether the gap will be mitigated through preventive Quality activities or deemed as acceptable risk. The goal of any preventive quality activities is to create provisions to prevent, control, or reduce the risk of not meeting the CtQCs. In addition, any standard methodology that will be used to design or conduct preventive Quality activities are defined and documented." ;
    rdfs:label "Define preventive quality activities" ;
    skos:definition "An Act of Formulation that specifies the preventive quality activities and methodology for reducing the risk of not meeting critical-to-quality characteristics." ;
    rdfs:comment "Critical-to-quality characteristic specification is a typical input (the gap is judged against it) rather than definitional, so it is noted here, not asserted as a restriction." ;
    skos:example "A quality engineer documents a preventive inspection regime to close a requirement gap." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PreventiveQualityActivitySpecification ] .

# --- 13.3.1.3 (PCF 17475) : Formulation -> Directive quality-control spec
ex:P17475 a owl:Class ;
    ex:pcfID "17475" ; ex:hierarchyID "13.3.1.3" ;
    ex:apqcSourceText "Developing controls for managing the quality of enterprise. Define the process steps for quality controls and the sampling plan. Identify the tools and methods to measure quality. Define the competencies required." ;
    rdfs:label "Develop quality controls" ;
    skos:definition "An Act of Formulation that develops a quality control specification comprising the control steps, sampling plan, measurement methods, and required competencies." ;
    rdfs:comment "Aggregating planning process; its APQC children are process parts." ;
    skos:example "A quality team defines control steps, a sampling plan, measurement tools, and operator competencies for a production line." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityControlSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17476 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17477 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17478 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17479 ] .

# --- 13.3.1.3.1 (PCF 17476) : Formulation -> Directive control-point spec
ex:P17476 a owl:Class ;
    ex:pcfID "17476" ; ex:hierarchyID "13.3.1.3.1" ;
    ex:apqcSourceText "Establishing the steps for developing quality controls. Conduct Alpha testing. Have the product team conduct rework. Send the product/service for Beta testing, and carry on rework as needed." ;
    rdfs:label "Define process steps for controls (or integration points)" ;
    skos:definition "An Act of Formulation that establishes the process steps and integration points of a quality control as a process control point specification." ;
    skos:example "A quality lead specifies alpha-test, rework, and beta-test gates as control points." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessControlPointSpecification ] .

# --- 13.3.1.3.2 (PCF 17477) : Formulation -> Directive sampling plan
ex:P17477 a owl:Class ;
    ex:pcfID "17477" ; ex:hierarchyID "13.3.1.3.2" ;
    ex:apqcSourceText "Establishing a detailed summary including measures, on which material, in what manner, and by whom. Identify the parameters to be measured, the range of possible values, and the required resolution. Provide a sampling scheme that details how and when samples will be taken. Select sample sizes. Assign roles and responsibilities." ;
    rdfs:label "Define sampling plan" ;
    skos:definition "An Act of Formulation that produces a sampling plan specifying the parameters, sample sizes, scheme, and responsibilities for taking quality samples." ;
    skos:example "A quality engineer authors a sampling plan fixing sample sizes and inspection timing." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SamplingPlan ] .

# --- 13.3.1.3.3 (PCF 17478) : Selection -> Directive measurement-method selection
ex:P17478 a owl:Class ;
    ex:pcfID "17478" ; ex:hierarchyID "13.3.1.3.3" ;
    ex:apqcSourceText "Using tools to measure quality. Use tools such as quality improvement oversight system tool, performance measurement tools, consumer information models/guides, and validation tools to effectively determine the quality levels." ;
    rdfs:label "Identify measurement methods" ;
    skos:definition "An Act of Selection that chooses the tools and methods for measuring quality and produces a measurement method selection." ;
    rdfs:comment "Anchored under ex:ActOfSelection (reused from apqc-ext.ttl): choosing among candidate tools yields a Directive decision ICE." ;
    skos:example "A quality team selects SPC software and gage-calibration tooling for line measurement." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MeasurementMethodSelection ] .

# --- 13.3.1.3.4 (PCF 17479) : Formulation -> Directive competency spec
ex:P17479 a owl:Class ;
    ex:pcfID "17479" ; ex:hierarchyID "13.3.1.3.4" ;
    ex:apqcSourceText "Defining the competencies required for developing quality controls. Define the required competencies including compliance management, audit management, and document control and document management." ;
    rdfs:label "Define required competencies" ;
    skos:definition "An Act of Formulation that specifies the competencies required to perform quality-control activities as a competency requirement specification." ;
    skos:example "A quality manager documents that control operators must hold audit-management and document-control competencies." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CompetencyRequirementSpecification ] .

# --- 13.3.1.4 (PCF 17480) : Appraisal -> Descriptive capability demonstration
ex:P17480 a owl:Class ;
    ex:pcfID "17480" ; ex:hierarchyID "13.3.1.4" ;
    ex:apqcSourceText "Demonstrating the ability and capability to confirm and fulfill the quality requirements in front of customers, managers, employees, board members, associations, regulatory bodies, and creditors. Leverage tools and techniques such as process behavior or control charts, statistical process control, measurement system analysis, gage calibration management, and process capability analysis." ;
    rdfs:label "Prove capability to assess compliance with requirements" ;
    skos:definition "An Act of Appraisal that evaluates and demonstrates an organization's ability to fulfil its quality requirements and produces a compliance capability demonstration." ;
    rdfs:comment "Anchored under cco:ont00000636 (Act of Appraisal); statistical-process-control and process-capability techniques judge conformance ability, yielding a descriptive evidentiary artifact." ;
    skos:example "A quality team runs a process-capability study and presents the results to a regulator." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ComplianceCapabilityDemonstration ] .

# --- 13.3.1.5 (PCF 17481) : Formulation -> Directive quality plan
ex:P17481 a owl:Class ;
    ex:pcfID "17481" ; ex:hierarchyID "13.3.1.5" ;
    ex:apqcSourceText "Establishing how the critical-to-quality characteristics will be achieved, controlled, ensured, and managed throughout the lifecycle of a product/service. Address quality requirements and critical-to-quality characteristics. Conduct a preventive quality assessment. Describe how to verify the product/service, verification criteria, and response to nonconformance. Keep records to demonstrate conformity." ;
    rdfs:label "Finalize quality plan" ;
    skos:definition "An Act of Formulation that consolidates the quality requirements, controls, and verification approach into a finalized quality plan governing a product or service lifecycle." ;
    skos:example "A quality manager issues the approved quality plan covering verification criteria and nonconformance response." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityPlan ] .

# --- 13.3.2 (PCF 17482) : evaluate performance to requirements -> Appraisal
ex:P17482 a owl:Class ;
    ex:pcfID "17482" ; ex:hierarchyID "13.3.2" ;
    ex:apqcSourceText "Analyzing if the performance of the quality plan has achieved the estimated and desired requirements. Conduct tests against the quality plan. Assess the results of these tests." ;
    rdfs:label "Evaluate performance to requirements" ;
    skos:definition "An Act of Appraisal that analyzes whether quality performance has met the requirements set in the quality plan and produces a quality test summary." ;
    rdfs:comment "Aggregating appraisal process; its APQC children (testing and assessment) are process parts." ;
    skos:example "A quality function tests output against the plan and judges whether requirements were met." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestSummary ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17483 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17487 ] .

# --- 13.3.2.1 (PCF 17483) : Info-processing -> Descriptive test data
ex:P17483 a owl:Class ;
    ex:pcfID "17483" ; ex:hierarchyID "13.3.2.1" ;
    ex:apqcSourceText "Examining the quality of organizational processes. Conduct tests. Collect information and data. Record the results of these tests. Determine the dispositions of the test results." ;
    rdfs:label "Test against quality plan" ;
    skos:definition "An Act of Information Processing that conducts quality tests against the quality plan, records the resulting test data, and determines their disposition." ;
    rdfs:comment "Aggregating process anchored at cco:ont00000366 (Act of Information Processing); its APQC children are process parts." ;
    skos:example "An inspector runs tests, logs the data, and assigns a disposition to each result." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestDataRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17484 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17485 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17486 ] .

# --- 13.3.2.1.1 (PCF 17484) : Measuring -> Descriptive test data
ex:P17484 a owl:Class ;
    ex:pcfID "17484" ; ex:hierarchyID "13.3.2.1.1" ;
    ex:apqcSourceText "Evaluating quality performance through periodic or episodic testing against the established standards for quality characteristics. For periodic testing, design a schedule with sufficient time to make any required adjustments to the process or system to maintain the desired level of quality. For episodic testing, conduct a test whenever a known non-conformance or fault occurs, which results in outputs or outcomes known to be unsatisfactory to performance requirements." ;
    rdfs:label "Conduct test and collect data" ;
    skos:definition "An Act of Measuring that tests quality characteristics against established standards and collects the resulting quality test data record." ;
    rdfs:comment "Anchored at cco:ont00000345 (Act of Measuring): determines quality of an entity relative to a standard." ;
    skos:example "A technician runs a scheduled gauge test and logs the measured values." ;
    rdfs:subClassOf cco:ont00000345 ,   # Act of Measuring (a CCO Planned Act)
        cco:ont00000228 ,   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestDataRecord ] .

# --- 13.3.2.1.2 (PCF 17485) : Info-processing -> Descriptive record
ex:P17485 a owl:Class ;
    ex:pcfID "17485" ; ex:hierarchyID "13.3.2.1.2" ;
    ex:apqcSourceText "Maintaining and recording the results of Test against the quality plan [17483] electronically and in standard formats. Assign ownership to a designated function or role." ;
    rdfs:label "Record result(s)" ;
    skos:definition "An Act of Information Processing that records and stores quality test results in standard formats as a quality test data record." ;
    skos:example "A quality clerk enters test outcomes into the QMS in the standard template." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestDataRecord ] .

# --- 13.3.2.1.3 (PCF 17486) : Selection -> Directive disposition
ex:P17486 a owl:Class ;
    ex:pcfID "17486" ; ex:hierarchyID "13.3.2.1.3" ;
    ex:apqcSourceText "Deciding whether to take any additional actions based on the results of quality tests. Initiate a quarantine disposition and relocated inventory, scrap workflow item and scrap transaction, rework operation, net-able and nonnet-able items, and the activity list." ;
    rdfs:label "Determine disposition of result(s)" ;
    skos:definition "An Act of Selection that decides the disposition action for quality test results and produces a quality test result disposition." ;
    rdfs:comment "Anchored under ex:ActOfSelection (reused): chooses a disposition (quarantine, scrap, rework) from candidates, yielding a Directive ICE." ;
    skos:example "A quality engineer selects a quarantine-and-rework disposition for a failing lot." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityTestDataRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestResultDisposition ] .

# --- 13.3.2.2 (PCF 17487) : Appraisal -> Descriptive summary
ex:P17487 a owl:Class ;
    ex:pcfID "17487" ; ex:hierarchyID "13.3.2.2" ;
    ex:apqcSourceText "Assessing the significance of the sample. Summarize the results of the test. Recommend improvement actions. Decide what steps to take next." ;
    rdfs:label "Assess results of tests" ;
    skos:definition "An Act of Appraisal that judges the significance of quality test results, summarizes them, and recommends improvement actions." ;
    rdfs:comment "Aggregating appraisal process; its APQC children are process parts." ;
    skos:example "A quality analyst summarizes test outcomes and recommends corrective measures to management." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityTestDataRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestSummary ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17488 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17489 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17490 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17491 ] .

# --- 13.3.2.2.1 (PCF 17488) : Appraisal -> Descriptive sample-significance assessment
ex:P17488 a owl:Class ;
    ex:pcfID "17488" ; ex:hierarchyID "13.3.2.2.1" ;
    ex:apqcSourceText "Assessing the significance of the sample chosen for the test in order to determine whether or not the sample is representative of the larger output or outcome. Determine if the sample meets or does not meet the requirements. Identify the conditions for acceptance, rejection, remediation, and prevention." ;
    rdfs:label "Assess sample significance" ;
    skos:definition "An Act of Appraisal that judges whether a test sample is representative of the larger output and produces a sample significance assessment." ;
    skos:example "A statistician evaluates whether an inspection sample is representative of a production run." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityTestDataRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SampleSignificanceAssessment ] .

# --- 13.3.2.2.2 (PCF 17489) : Info-processing -> Descriptive summary
ex:P17489 a owl:Class ;
    ex:pcfID "17489" ; ex:hierarchyID "13.3.2.2.2" ;
    ex:apqcSourceText "Outlining the major facts and figures of the quality test results in order to provide insights and information. Use charts, tables, statistical test results, and written findings and conclusions in a summary of results." ;
    rdfs:label "Summarize result(s)" ;
    skos:definition "An Act of Information Processing that condenses quality test results into a quality test summary of findings and conclusions." ;
    skos:example "An analyst compiles charts and conclusions into a quality test summary report." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityTestDataRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityTestSummary ] .

# --- 13.3.2.2.3 (PCF 17490) : Formulation -> Directive improvement recommendation
ex:P17490 a owl:Class ;
    ex:pcfID "17490" ; ex:hierarchyID "13.3.2.2.3" ;
    ex:apqcSourceText "Recommending measures for improvement. Assess the summarized results to identify areas which can be improved. Suggest actions to management for improving the quality plan basis on the results of the tests." ;
    rdfs:label "Recommend actions" ;
    skos:definition "An Act of Formulation that composes recommended improvement measures for the quality plan as a quality improvement recommendation." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (reused): a recommendation prescribes a course of action, hence a Directive ICE." ;
    skos:example "A quality lead recommends tightening a control limit based on summarized results." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityTestSummary ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityImprovementRecommendation ] .

# --- 13.3.2.2.4 (PCF 17491) : Selection -> Directive decision
ex:P17491 a owl:Class ;
    ex:pcfID "17491" ; ex:hierarchyID "13.3.2.2.4" ;
    ex:apqcSourceText "Selecting the subsequent actions that the organization can adopt for improving the enterprise quality. Select measures and recommended actions for managing the enterprise quality." ;
    rdfs:label "Decide next steps" ;
    skos:definition "An Act of Selection that chooses, from the recommended quality-improvement actions, those the organization will adopt and produces a quality improvement action decision prescribing them." ;
    rdfs:comment "Anchored under ex:ActOfSelection (reused): selects from candidate recommended actions, yielding a Directive ICE. FIXED degenerate I/O: the has-output now points at the distinct ex:QualityImprovementActionDecision (the committed decision), while ex:QualityImprovementRecommendation -- the output of sibling 17490 -- is retained as has-input only. Previously this act asserted the SAME ICE as both input and output (a vacuous self-emission) and collided with 17490's output." ;
    skos:example "Management selects which recommended quality measures to implement next quarter and records the decision." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:QualityImprovementRecommendation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityImprovementActionDecision ] .

# --- 13.3.3 (PCF 17492) : manage non-conformance -> Planned Act (bounded)
ex:P17492 a owl:Class ;
    ex:pcfID "17492" ; ex:hierarchyID "13.3.3" ;
    ex:apqcSourceText "Handling any nonconformance activities or events. Assess the potential impact of the nonconformity. Decide the immediate actions to take. Identify the root causes. Take corrective or preventive action. Ensure future conformance." ;
    rdfs:label "Manage non-conformance" ;
    skos:definition "A Planned Act that handles a nonconformance event from impact assessment through corrective or preventive action to closure of the nonconformance record." ;
    rdfs:comment "Modeled as a bounded process (Planned Act), not an Organization Capability: a nonconformance handling instance has an identifiable beginning (the event) and end (closure). Its APQC children are process parts." ;
    skos:example "A quality team works a single nonconformance from detection through CAPA to documented closure." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:NonconformanceRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17493 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17494 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17495 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17496 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17497 ] .

# --- 13.3.3.1 (PCF 17493) : Appraisal -> Descriptive impact assessment
ex:P17493 a owl:Class ;
    ex:pcfID "17493" ; ex:hierarchyID "13.3.3.1" ;
    ex:apqcSourceText "Analyzing any nonconformance events. Determine the need for corrective and/or preventative action(s). Leverage root-cause analysis, risk exposure, and other evaluations to properly review and approve/reject subsequent actions." ;
    rdfs:label "Assess potential impact" ;
    skos:definition "An Act of Appraisal that evaluates a nonconformance event and produces a nonconformance impact assessment determining the need for corrective or preventive action." ;
    skos:example "An analyst rates the risk exposure of a nonconformity to decide whether CAPA is warranted." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:NonconformanceRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:NonconformanceImpactAssessment ] .

# --- 13.3.3.2 (PCF 17494) : Selection -> Directive immediate action
ex:P17494 a owl:Class ;
    ex:pcfID "17494" ; ex:hierarchyID "13.3.3.2" ;
    ex:apqcSourceText "Initiating immediate corrective, preventative, or no action based upon the impact and likelihood of reoccurrence. Consider cost/benefit, risk exposure, timing, the assignment of responsibility, and other pertinent factors." ;
    rdfs:label "Determine immediate action(s)" ;
    skos:definition "An Act of Selection that chooses the immediate corrective, preventive, or no-action response to a nonconformance and produces a corrective and preventive action specification." ;
    rdfs:comment "Anchored under ex:ActOfSelection (reused): selects among action options based on impact, yielding a Directive ICE." ;
    skos:example "A quality manager selects an immediate containment action for a high-impact nonconformity." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:NonconformanceImpactAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CorrectiveAndPreventiveActionSpecification ] .

# --- 13.3.3.3 (PCF 17495) : Analysis -> Descriptive RCA
ex:P17495 a owl:Class ;
    ex:pcfID "17495" ; ex:hierarchyID "13.3.3.3" ;
    ex:apqcSourceText "Recognizing the reasons that have triggered the nonconformance events or activities. Perform a root-cause analysis through documentary evidence and interviews. Involve the appropriate individuals. Leverage cause analysis and risk assessment." ;
    rdfs:label "Identify root cause(s)" ;
    skos:definition "An Act of Analysis that examines a nonconformance event and produces a root cause analysis of the reasons that triggered it." ;
    rdfs:comment "Anchored under ex:ActOfAnalysis (reused): information processing yielding an explanatory descriptive ICE." ;
    skos:example "Investigators trace a defect to a miscalibrated tool via documentary evidence and interviews." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:NonconformanceRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RootCauseAnalysis ] .

# --- 13.3.3.4 (PCF 17496) : Implementation -> CAPA enacted
ex:P17496 a owl:Class ;
    ex:pcfID "17496" ; ex:hierarchyID "13.3.3.4" ;
    ex:apqcSourceText "Pursuing corrective and preventative activities to eliminate the cause of a detected nonconformity. Define the nonconformity. Communicate and assign responsibility. Identify the appropriate corrective and preventive action. Implement and monitor for reoccurrence." ;
    rdfs:label "Take corrective or preventative action" ;
    skos:definition "An Act of Implementation that carries a corrective and preventive action specification into effect to eliminate the cause of a detected nonconformity and produces a corrective action completion record." ;
    rdfs:comment "Anchored under ex:ActOfImplementation (PROPOSE-EXT): enacts the prescribed CAPA in the organization. GOLDEN-PRINCIPLE FIX: an implementation/enactment act's definitional product is a brought-about state / descriptive completion record, NOT a fresh Directive specification. The Directive ex:CorrectiveAndPreventiveActionSpecification is therefore the governing has-INPUT here (the spec authored by 13.3.3.2 'Determine immediate action'); the has-output is now the Descriptive ex:CorrectiveActionCompletionRecord. The 'identify the appropriate CAPA' authoring facet is modeled separately as the Selection act 13.3.3.2 (ex:P17494), not overloaded onto this implementation class. Root-cause analysis is a typical (non-definitional) supporting input, dropped to comment." ;
    skos:example "A team implements a tooling change and monitors the line for recurrence of the defect, then records completion." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CorrectiveAndPreventiveActionSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CorrectiveActionCompletionRecord ] .

# --- 13.3.3.5 (PCF 17497) : Info-processing -> Descriptive nonconformance record
ex:P17497 a owl:Class ;
    ex:pcfID "17497" ; ex:hierarchyID "13.3.3.5" ;
    ex:apqcSourceText "Closing nonconformance. Perform all the final processes related to the nonconformance, including documenting root causes. Document corrective and preventive actions." ;
    rdfs:label "Close non-conformance" ;
    skos:definition "An Act of Information Processing that documents the root causes and corrective and preventive actions and closes the nonconformance record." ;
    skos:example "A quality clerk finalizes and closes the nonconformance record after CAPA verification." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:CorrectiveAndPreventiveActionSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:NonconformanceRecord ] .

# --- 13.3.4 (PCF 17498) : implement and maintain the EQMS -> Implementation
ex:P17498 a owl:Class ;
    ex:pcfID "17498" ; ex:hierarchyID "13.3.4" ;
    ex:apqcSourceText "Establishing and administering the software that manages content and business processes for quality and compliance across the value chain. Define the quality strategy. Plan and deploy the EQMS scope, targets, and goals. Identify core process controls and metric. Develop EQMS governance. Assess the performance of EQMS. Encourage improvements in EQMS." ;
    rdfs:label "Implement and maintain the enterprise quality management system (EQMS)" ;
    skos:definition "An Act of Implementation that establishes and deploys the enterprise quality management system by defining its strategy, scope, controls, and policies and assessing and improving its performance." ;
    rdfs:comment "Modeled as a bounded process (Act of Implementation, PROPOSE-EXT): the establish-and-deploy effort has identifiable phases and bounded children. Its APQC children are process parts." ;
    skos:example "A quality program stands up an EQMS platform, configures controls, and runs the first performance assessment." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EQMSScopeAndGoalSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17499 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17500 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17501 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17502 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17503 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17504 ] .

# --- 13.3.4.1 (PCF 17499) : Formulation -> Directive quality strategy
ex:P17499 a owl:Class ;
    ex:pcfID "17499" ; ex:hierarchyID "13.3.4.1" ;
    ex:apqcSourceText "Outlining the strategy for managing enterprise quality. Define and formalize quality techniques and standards. Assign responsibilities for achieving the required quality levels. Standardize the quality maintenance procedure, tools and techniques, recording and reporting, the timing of quality maintenance activities, and the roles and responsibilities for the quality management team." ;
    rdfs:label "Define the quality strategy" ;
    skos:definition "An Act of Formulation that formalizes the techniques, standards, and responsibilities for managing enterprise quality as a quality strategy." ;
    skos:example "A quality director issues the enterprise quality strategy standardizing tools, reporting, and roles." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityStrategy ] .

# --- 13.3.4.2 (PCF 17500) : Implementation -> scope/goal spec deployed
ex:P17500 a owl:Class ;
    ex:pcfID "17500" ; ex:hierarchyID "13.3.4.2" ;
    ex:apqcSourceText "Establishing and effectively deploying the scope, targets, and goals of EQMS. Define the role of EQMS through nonconformance/corrective and preventive action, compliance/audit management, risk management, failure mode and effects analysis, and statistical process control. Implement EQMS into operational activities. Define the goals and objectives that are to be achieved by the EQMS." ;
    rdfs:label "Plan and deploy the EQMS scope, targets, and goals" ;
    skos:definition "An Act of Implementation that establishes and deploys the EQMS scope, targets, and goals into operational activities, governed by an EQMS scope and goal specification." ;
    rdfs:comment "Anchored under ex:ActOfImplementation (PROPOSE-EXT): the planning of scope produces the directive, and deployment enacts it operationally." ;
    skos:example "A program rolls out the EQMS across audit, risk, and SPC modules per the defined scope." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EQMSScopeAndGoalSpecification ] .

# --- 13.3.4.3 (PCF 17501) : Formulation -> Directive control point + indicator spec
ex:P17501 a owl:Class ;
    ex:pcfID "17501" ; ex:hierarchyID "13.3.4.3" ;
    ex:apqcSourceText "Recognizing and implementing the processes, controls, and metrics for maintenance of EQMS. Define the role of EQMS in failure mode and effects analysis, complaint handling, and advanced product quality planning. Establish the role of EQMS in evaluating metrics such as cost of quality, overall equipment effectiveness, on-time and complete shipments, percentage of products in compliance, and new product introductions." ;
    rdfs:label "Identify core EQMS processes, controls, and metrics" ;
    skos:definition "An Act of Formulation that specifies the core EQMS processes, controls, and metrics as a process control point specification." ;
    rdfs:comment "Anchored under ex:ActOfFormulation (reused): recognizing-and-specifying the control/metric set composes a Directive ICE." ;
    skos:example "A quality architect defines the EQMS controls and the cost-of-quality and OEE metrics to track." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessControlPointSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceIndicatorSpecification ] .

# --- 13.3.4.4 (PCF 17502) : Formulation -> Directive EQMS governance docs
ex:P17502 a owl:Class ;
    ex:pcfID "17502" ; ex:hierarchyID "13.3.4.4" ;
    ex:apqcSourceText "Setting the process limits. Gather required information. Align with other documents and processes. Define the document structure." ;
    rdfs:label "Develop and document EQMS policies, procedures, standards, and measures" ;
    skos:definition "An Act of Formulation that composes and documents the EQMS policies, procedures, standards, and measures as a process governance framework." ;
    skos:example "A quality team authors the EQMS procedure manual and document hierarchy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessGovernanceFramework ] .

# --- 13.3.4.5 (PCF 17503) : Appraisal -> Descriptive EQMS performance assessment
ex:P17503 a owl:Class ;
    ex:pcfID "17503" ; ex:hierarchyID "13.3.4.5" ;
    ex:apqcSourceText "Benchmarking current performance in quality metrics that span across the value chain. Identify gaps in performance as compared to industry peers. Identify and implement complementary EQMS capabilities. Enable a continuous improvement environment." ;
    rdfs:label "Assess the EQMS performance" ;
    skos:definition "An Act of Appraisal that benchmarks EQMS quality metrics against industry peers and produces an EQMS performance assessment identifying performance gaps." ;
    skos:example "A quality lead benchmarks the EQMS against peers and reports the capability gaps." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EQMSPerformanceAssessment ] .

# --- 13.3.4.6 (PCF 17504) : Improvement -> aggregating improvement process
ex:P17504 a owl:Class ;
    ex:pcfID "17504" ; ex:hierarchyID "13.3.4.6" ;
    ex:apqcSourceText "Rewarding excellence in quality. Create and maintain quality partnerships. Maintain talent capabilities and competencies. Incorporate EQMS messaging into communication channels. Transfer proven EQMS methods. Consider factors such as EQMS reviews and gap assessments and the alignment and compatibility of business processes and quality. Adopt Lean principles." ;
    rdfs:label "Create environment and capability for EQMS improvement(s)" ;
    skos:definition "An Act of Improvement that enacts the rewards, partnerships, talent, communications, and method-transfer changes that build an environment and capability for ongoing EQMS improvement." ;
    rdfs:comment "Anchored under ex:ActOfImprovement (PROPOSE-EXT). Its APQC children are process parts." ;
    skos:example "A quality program launches recognition awards, supplier partnerships, and training to drive EQMS maturity." ;
    rdfs:subClassOf ex:ActOfImprovement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17505 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17506 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17507 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17508 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17509 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P17510 ] .

# --- 13.3.4.6.1 (PCF 17505) : Implementation -> reward granting
ex:P17505 a owl:Class ;
    ex:pcfID "17505" ; ex:hierarchyID "13.3.4.6.1" ;
    ex:apqcSourceText "Provisioning rewards for achieving quality excellence. Provide monetary and nonmonetary rewards such as compensation, vacations, gift cards, and reimbursements to employees in in recognition of their services, efforts, and achievements in quality excellence." ;
    rdfs:label "Reward quality excellence" ;
    skos:definition "An Act of Implementation that grants monetary and nonmonetary rewards to personnel in recognition of quality excellence, governed by a recognition and reward plan." ;
    rdfs:comment "Anchored under ex:ActOfImplementation (PROPOSE-EXT): enacts the recognition-and-reward plan. The plan is a typical governing input rather than a definitional one, noted here." ;
    skos:example "A manager awards gift cards to a team that eliminated a recurring defect." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.3.4.6.2 (PCF 17506) : Implementation -> partnership formation
ex:P17506 a owl:Class ;
    ex:pcfID "17506" ; ex:hierarchyID "13.3.4.6.2" ;
    ex:apqcSourceText "Establishing and maintaining partnerships with third-party sources to achieve quality excellence. Source and evaluate third-party sources both public and private to ensure that the most effective and efficient partnerships are formed." ;
    rdfs:label "Create and maintain quality partnerships" ;
    skos:definition "An Act of Implementation that forms and maintains partnerships with third-party sources to advance quality excellence and produces a quality partnership agreement." ;
    skos:example "A quality director establishes a supplier-quality partnership with shared audit rights." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:QualityPartnershipAgreement ] .

# --- 13.3.4.6.3 (PCF 17507) : Implementation -> talent training
ex:P17507 a owl:Class ;
    ex:pcfID "17507" ; ex:hierarchyID "13.3.4.6.3" ;
    ex:apqcSourceText "Maintaining a common denominator for the competency level within the organization's talent circle. Conduct training sessions, skill development activities, and quality excellence activities to ensure that the resources of the organization are competent enough and have the capabilities to achieve the required level of quality." ;
    rdfs:label "Maintain talent capabilities and competencies" ;
    skos:definition "An Act of Training that conducts training sessions and skill-development activities to maintain personnel competencies at the level required for quality, governed by a training plan." ;
    rdfs:comment "RE-ANCHORED from ex:ActOfImplementation to cco:ont00000234 (Act of Training, VERIFIED §6: imparts knowledge/skills/values to Agents; parent cco:ont00000228 Planned Act). Source text -- 'Conduct training sessions, skill development activities ... to ensure that the resources of the organization are competent' -- is paradigmatically training, not the enactment of a directive plan. Rejected candidate ex:ActOfImplementation: filing a training act under a generic local Implementation genus is a false genus and a D5 reuse miss (the module header provisions Act of Training). Explicit cco:ont00000228 co-parent added so Gate C (S2) sees the Act anchor without the CCO closure (same pattern as 17484). Training plan is a typical governing input, noted here." ;
    skos:example "A quality team runs SPC training to keep operators qualified." ;
    rdfs:subClassOf cco:ont00000234 ,   # Act of Training (a CCO Planned Act)
        cco:ont00000228 ,   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.3.4.6.4 (PCF 17508) : Implementation -> EQMS communications
ex:P17508 a owl:Class ;
    ex:pcfID "17508" ; ex:hierarchyID "13.3.4.6.4" ;
    ex:apqcSourceText "Assimilating all the communication related to the EQMS into the organization's already established communication channels." ;
    rdfs:label "Incorporate EQMS messaging into communication channels" ;
    skos:definition "An Act of Communication that disseminates EQMS-related messaging through the organization's established communication channels, governed by a communication plan." ;
    rdfs:comment "RE-ANCHORED from ex:ActOfImplementation to cco:ont00000402 (Act of Communication, VERIFIED §6: transfers an ICE from one Agent to another; parent cco:ont00000228 Planned Act). Source text -- 'Assimilating all the communication related to the EQMS into the organization's already established communication channels' -- is fundamentally a communication act, not the enactment of a directive plan. Rejected candidate ex:ActOfImplementation: a false-friend genus and D5 reuse miss. Explicit cco:ont00000228 co-parent added so Gate C (S2) sees the Act anchor without the CCO closure. Communication plan is a typical governing input, noted here." ;
    skos:example "A quality communications lead adds EQMS updates to the intranet and newsletter." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication (a CCO Planned Act)
        cco:ont00000228 .   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure

# --- 13.3.4.6.5 (PCF 17509) : Implementation -> authorized access established
ex:P17509 a owl:Class ;
    ex:pcfID "17509" ; ex:hierarchyID "13.3.4.6.5" ;
    ex:apqcSourceText "Ensuring EQMS access to the person in charge of the quality management process. Establish who has the authority to manage the EQMS. Ensure access of EQMS to only the person(s) in authority." ;
    rdfs:label "Assure independent EQMS management access to appropriate authority in the organization" ;
    skos:definition "An Act of Implementation that establishes and secures EQMS management access for the authorized quality role, governed by a role definition specification." ;
    rdfs:comment "Anchored under ex:ActOfImplementation (PROPOSE-EXT): enacts an access/role arrangement defined by a role definition specification." ;
    skos:example "An administrator grants EQMS administrative rights only to the designated quality manager." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:RoleDefinitionSpecification ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.3.4.6.6 (PCF 17510) : Info-processing -> Descriptive best-practices register
ex:P17510 a owl:Class ;
    ex:pcfID "17510" ; ex:hierarchyID "13.3.4.6.6" ;
    ex:apqcSourceText "Recording and transferring the best practices and proven methods associated with enterprise quality management systems (EQMS) that can be leveraged in improving the organization's framework. Record proven methodologies and approaches with the objective of communicating them for upgrading, refining, and enhancing the organization's systems." ;
    rdfs:label "Transfer proven EQMS methods" ;
    skos:definition "An Act of Information Processing that records and disseminates proven EQMS methods and best practices as a best practices register." ;
    rdfs:comment "Anchored at cco:ont00000366 (Act of Information Processing): captures and transfers proven methods as a descriptive ICE." ;
    skos:example "A knowledge lead documents a proven CAPA workflow and shares it across sites." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BestPracticesRegister ] .

# ===== group 13.4 Manage change (PCF 11074) =======================
# Modeled as a bounded change-management cycle (Planned Act), with the
# standing-function reading carried by ex:ChangeManagementCapability.

ex:P11074 a owl:Class ;
    ex:pcfID "11074" ; ex:hierarchyID "13.4" ;
    ex:apqcSourceText "Planning, designing, and implementing the change. Ensure improvement in the change process." ;
    rdfs:label "Manage change" ;
    skos:definition "A Planned Act in which an Agent plans, designs, implements, and sustains a deliberate organizational change, comprising the planning, design, implementation, and improvement-sustainment of that change." ;
    rdfs:comment "Models APQC process group 13.4 as a bounded change-management cycle (an occurrent), not the standing 'change management' function. Its APQC children are process parts, not subclasses. DELIBERATE R5 DIVERGENCE FROM SIBLING GROUP NODES (auditable, uniform criterion): a 'Manage X' group node is minted as a bounded Planned Act ONLY when X denotes a discrete initiative with a natural terminus, and as an Organization Capability (cco:ont00000568, no ex:P) when X denotes an open-ended enterprise function with no natural end. A change/transformation INITIATIVE has a natural end (the target future state is reached and adoption sustained), so 13.4 is a bounded Planned Act AND additionally carries the standing-function reading ex:ChangeManagementCapability for orgs that run change as a permanent function. By contrast 13.3 'Manage enterprise quality' (P17471), 13.1 'Manage business processes' (16378), 13.5 'Manage KM' (11073), and 13.2 portfolio/program/project management are permanent functions with no natural end, so they are capability-only. See the cross-reference on ex:P17471." ;
    skos:example "An organization's end-to-end transformation initiative from concept through sustained adoption." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21457 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11135 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11136 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11137 ] .

# --- 13.4.1 (PCF 21457) : plan for change -> Formulation
ex:P21457 a owl:Class ;
    ex:pcfID "21457" ; ex:hierarchyID "13.4.1" ;
    ex:apqcSourceText "Evaluating impact and planning change activities. Spanning the lifecycle of change from initial concept, to designing, implementing, and sustaining the change, change planning identifies the activities to enage and enable the stakeholders and all impacted by the change. Change plans should address the interplay between people, process, technology, and knowledge to guide the transition, or tranformation, from current state to the future state." ;
    rdfs:label "Plan for change" ;
    skos:definition "An Act of Formulation that evaluates the impact of an intended change and composes a change management plan identifying the activities needed to engage stakeholders and guide the transition from current to future state." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (under cco:ont00000511 Act of Planning) because its definitional output is a Directive ICE (the change plan). APQC children are process parts." ;
    skos:example "A program team scopes a transformation, assesses readiness, and produces the change management plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeManagementPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11140 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11139 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11141 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11142 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11143 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11144 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11145 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11146 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11147 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20143 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20144 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11148 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11149 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11150 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11151 ] .

# --- 13.4.1.1 (PCF 11140) : Identification -> descriptive
ex:P11140 a owl:Class ;
    ex:pcfID "11140" ; ex:hierarchyID "13.4.1.1" ;
    ex:apqcSourceText "Identifying and communicating with shareholders affected by the change. Consider internal and external stakeholders that will be affected by the change. Determine the amount of influence the change will have on them. Ensure the involvement of these stakeholders in the change process by effectively communicating with them." ;
    rdfs:label "Determine stakeholders" ;
    skos:definition "An Act of Identification that discerns the internal and external stakeholders affected by a change and produces a stakeholder assessment registering them and their influence." ;
    skos:example "A change team enumerates affected departments and external parties and rates their influence." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StakeholderAssessment ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.4.1.2 (PCF 11139) : Appraisal -> descriptive
ex:P11139 a owl:Class ;
    ex:pcfID "11139" ; ex:hierarchyID "13.4.1.2" ;
    ex:apqcSourceText "Determining the level of preparedness of the conditions, attitudes, and resources at all levels in the organization needed for change to happen successfully. Define scope of the proposed change. Select the tools for a change readiness assessment." ;
    rdfs:label "Assess readiness for change" ;
    skos:definition "An Act of Appraisal that evaluates the preparedness of an organization's conditions, attitudes, and resources for a change and produces a change readiness assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges the level of preparedness; output is a Descriptive ICE." ;
    skos:example "A readiness survey across business units yields a change readiness assessment." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeReadinessAssessment ] .

# --- 13.4.1.3 (PCF 11141) : Identification (agents; no definitional ICE)
ex:P11141 a owl:Class ;
    ex:pcfID "11141" ; ex:hierarchyID "13.4.1.3" ;
    ex:apqcSourceText "Identifying people exhibit an extraordinary interest in the adoption, implementation, and success of the change. Engage champions in each division or team. Define the roles and responsibilities for the change champions. Determine criteria for selecting change champions. Provide training sessions to champions. Reward and recognize champions." ;
    rdfs:label "Identify change champion(s)" ;
    skos:definition "An Act of Identification that discerns the individuals who exhibit exceptional commitment to the success of a change and are to act as its champions." ;
    rdfs:comment "Output is a set of identified Agents (the champions), not an Information Content Entity, so no has-output restriction is asserted (Phase-3). Champion-role definition occurs in 13.4.2.8 / 13.4.2.5." ;
    skos:example "Each division nominates an enthusiastic advocate to serve as its change champion." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ChangeChampion ] .

# --- 13.4.1.4 (PCF 11142) : Planned Act (team assembly)
ex:P11142 a owl:Class ;
    ex:pcfID "11142" ; ex:hierarchyID "13.4.1.4" ;
    ex:apqcSourceText "Preparing a design team for implementing change throughout the organization." ;
    rdfs:label "Form design team" ;
    skos:definition "A Planned Act in which an Agent assembles a team tasked with designing and implementing a change throughout the organization." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): forming a team is an organizational act that produces neither an analysis (Descriptive ICE) nor a plan (Directive ICE); no shared act genus fits, so the generic Planned Act is used." ;
    skos:example "A sponsor convenes a cross-functional design team for the transformation." ;
    rdfs:subClassOf cco:ont00000228 .

# --- 13.4.1.5 (PCF 11143) : Formulation -> directive
ex:P11143 a owl:Class ;
    ex:pcfID "11143" ; ex:hierarchyID "13.4.1.5" ;
    ex:apqcSourceText "Defining the extent of the area or subject matter that the change process deals with or to which it is relevant. Establish a set of tools, processes, skills, and principles for managing the people side of change to achieve the required outcomes of the change process." ;
    rdfs:label "Define scope" ;
    skos:definition "An Act of Formulation that delimits and prescribes the extent of the area and subject matter that a change process addresses, producing a process scope statement." ;
    rdfs:comment "Reuses ex:ProcessScopeStatement (Directive ICE) as the scope-defining output of the change effort." ;
    skos:example "The team documents which functions, locations, and systems fall inside the change." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessScopeStatement ] .

# --- 13.4.1.6 (PCF 11144) : Analysis -> descriptive
ex:P11144 a owl:Class ;
    ex:pcfID "11144" ; ex:hierarchyID "13.4.1.6" ;
    ex:apqcSourceText "Using graphical and statistical tools such as pareto diagrams, process flow diagrams, cause-and-effect diagrams, check sheets, histograms, run charts, and scatter diagrams." ;
    rdfs:label "Understand current state" ;
    skos:definition "An Act of Analysis that examines the organization's as-is processes and conditions using graphical and statistical tools and produces a current state assessment." ;
    skos:example "Analysts chart current process flows and defect Pareto diagrams to characterize the baseline." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CurrentStateAssessment ] .

# --- 13.4.1.7 (PCF 11145) : Formulation -> directive
ex:P11145 a owl:Class ;
    ex:pcfID "11145" ; ex:hierarchyID "13.4.1.7" ;
    ex:apqcSourceText "Determining the state or position that the organization wants to be in after the implementation of the change. Gather necessary information about the processes, structures, and cultures. Define resource requirements." ;
    rdfs:label "Define future state" ;
    skos:definition "An Act of Formulation that prescribes the target state the organization intends to reach after a change, producing a future state specification." ;
    rdfs:comment "Reuses ex:FutureStateSpecification (Directive ICE): the future state is a prescribed target, not a description of present reality." ;
    skos:example "Leadership specifies the desired post-change operating model and its resource requirements." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:FutureStateSpecification ] .

# --- 13.4.1.8 (PCF 11146) : Analysis -> descriptive
ex:P11146 a owl:Class ;
    ex:pcfID "11146" ; ex:hierarchyID "13.4.1.8" ;
    ex:apqcSourceText "Looking beyond the immediate consequences of the threat to a critical asset and placing it in the context of what is important to the organization. Identify the impact of threats to critical assets. Create risk evaluation criteria. Evaluate the impact of threats to critical assets. Incorporate probability into the risk analysis." ;
    rdfs:label "Conduct organizational risk analysis" ;
    skos:definition "An Act of Analysis that examines threats to the organization's critical assets in light of their probability and consequence and produces an organizational risk analysis." ;
    skos:example "A risk team scores asset threats by likelihood and impact for the change." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalRiskAnalysis ] .

# --- 13.4.1.9 (PCF 11147) : Appraisal -> descriptive
ex:P11147 a owl:Class ;
    ex:pcfID "11147" ; ex:hierarchyID "13.4.1.9" ;
    ex:apqcSourceText "Evaluating the culture within the organization. Adopt a quantitative, multidimensional measurement approach of an organization's culture and the aspirations for it. Diagnose cultural activities, enhance leadership sections. Integrate cultures." ;
    rdfs:label "Assess cultural context" ;
    skos:definition "An Act of Appraisal that evaluates the organization's culture along multiple dimensions and produces a cultural context assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges the state of organizational culture; output is a Descriptive ICE." ;
    skos:example "A culture survey produces a multidimensional assessment of organizational values." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CulturalContextAssessment ] .

# --- 13.4.1.10 (PCF 20143) : Identification -> descriptive
ex:P20143 a owl:Class ;
    ex:pcfID "20143" ; ex:hierarchyID "13.4.1.10" ;
    ex:apqcSourceText "Recognizing the impact of threats to critical assets. Determine what groups are impacted by this impact." ;
    rdfs:label "Identify impacted groups" ;
    skos:definition "An Act of Identification that discerns which organizational groups are impacted by a change and registers them in a change impact assessment." ;
    rdfs:comment "Reuses ex:ChangeImpactAssessment (Descriptive ICE) as the register of impacted groups; the companion act 13.4.1.11 quantifies the extent." ;
    skos:example "The team lists the teams and functions touched by the proposed change." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeImpactAssessment ] .

# --- 13.4.1.11 (PCF 20144) : Appraisal -> descriptive
ex:P20144 a owl:Class ;
    ex:pcfID "20144" ; ex:hierarchyID "13.4.1.11" ;
    ex:apqcSourceText "Evaluating the impact of threats to critical assets. Determine what assets will be impacted by the change." ;
    rdfs:label "Determine degree/extent of impact" ;
    skos:definition "An Act of Appraisal that evaluates the degree and extent to which the change impacts the organization's assets and records its judgement in a change impact assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges the magnitude of impact, refining the descriptive ex:ChangeImpactAssessment." ;
    skos:example "Analysts rate how severely each affected asset is impacted by the change." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeImpactAssessment ] .

# --- 13.4.1.12 (PCF 11148) : Formulation -> directive (role assignment)
ex:P11148 a owl:Class ;
    ex:pcfID "11148" ; ex:hierarchyID "13.4.1.12" ;
    ex:apqcSourceText "Identifying and assigning the people accountable for effective change management. Hold managers accountable for ensuring change happens systematically and rigorously. Ensure that certain behaviors are rewarded or reprimanded accordingly." ;
    rdfs:label "Establish accountability for change management" ;
    skos:definition "A Planned Act that identifies and assigns accountability for managing a change to specific persons, holding them responsible for ensuring the change happens systematically." ;
    rdfs:comment "RE-ANCHORED from ex:ActOfFormulation to cco:ont00000228 (Planned Act). Source text -- 'Identifying and ASSIGNING the people accountable ... Hold managers accountable ... behaviors are rewarded or reprimanded' -- is a deontic role-assignment / organizational act of assigning accountability to specific persons, NOT the composition of a generic directive plan (Formulation). It parallels the other organizational-assignment Planned Acts P11142 'Form design team' and P20145 'Assign change champions'. DROPPED the has-output ex:RoleDefinitionSpecification restriction: that role spec is properly the output of P11158 'Establish/Clarify new roles', and reusing it here both over-committed to Formulation and double-claimed P11158's output. The assigned ex:ChangeManager is the salient participant." ;
    skos:example "Each manager is formally made accountable for delivering the change in their unit." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ChangeManager ] .

# --- 13.4.1.13 (PCF 11149) : Identification -> descriptive
ex:P11149 a owl:Class ;
    ex:pcfID "11149" ; ex:hierarchyID "13.4.1.13" ;
    ex:apqcSourceText "Recognizing the circumstances or obstacles that keep the organization from progressing. Identify who and what are the resources resisting change. Identify integration failures, threats by competitive forces, and complexity failures." ;
    rdfs:label "Identify barriers to change" ;
    skos:definition "An Act of Identification that discerns the obstacles and sources of resistance impeding a change and registers them in a change barrier analysis." ;
    skos:example "The team catalogs integration, resistance, and complexity obstacles to the change." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeBarrierAnalysis ] .

# --- 13.4.1.14 (PCF 11150) : Identification (entities; no definitional ICE)
ex:P11150 a owl:Class ;
    ex:pcfID "11150" ; ex:hierarchyID "13.4.1.14" ;
    ex:apqcSourceText "Identifying the person(s) or thing(s)responsible for making the change possible. Consider factors such as interdependence of efforts, reward to the integrators, sharing of power and responsibility, and employee understanding of why change is essential." ;
    rdfs:label "Determine change enablers" ;
    skos:definition "An Act of Identification that discerns the persons and factors that make a change possible." ;
    rdfs:comment "Output is the set of identified enabling entities/factors, not a single shared Information Content Entity, so no has-output restriction is asserted (Phase-3); the enabler register is typical, not definitional." ;
    skos:example "The team names the integrators and conditions that will enable the change to succeed." ;
    rdfs:subClassOf ex:ActOfIdentification .

# --- 13.4.1.15 (PCF 11151) : Formulation -> directive
ex:P11151 a owl:Class ;
    ex:pcfID "11151" ; ex:hierarchyID "13.4.1.15" ;
    ex:apqcSourceText "Recognizing the resource requirements, and developing measures for change. Identify the financial, material, human, and informational resources needed to successfully implement the change. Develop programs, campaigns, etc. for establishing the change within the organization." ;
    rdfs:label "Identify resources and develop measures" ;
    skos:definition "An Act of Formulation that, having identified the resources a change requires, develops the measures and programs prescribed to establish the change, producing a change adoption measure specification." ;
    rdfs:comment "Reuses ex:ChangeAdoptionMeasureSpecification (Directive ICE) for the developed measures/programs; resource identification is a typical sub-step recorded here in comment, not a separate output restriction." ;
    skos:example "The team budgets the resources and designs adoption campaigns for the change." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeAdoptionMeasureSpecification ] .

# --- 13.4.2 (PCF 11135) : design the change -> Formulation
ex:P11135 a owl:Class ;
    ex:pcfID "11135" ; ex:hierarchyID "13.4.2" ;
    ex:apqcSourceText "Developing plans for change management, training, communication, and rewards/incentives. Establish metrics for measuring the change adoption. Clarify new roles for employees. Identify budgets." ;
    rdfs:label "Design the change" ;
    skos:definition "An Act of Formulation that develops the change management, training, communication, and rewards plans, the adoption metrics, and the new-role definitions that together design how a change will be enacted." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (under cco:ont00000511 Act of Planning): its definitional outputs are Directive ICEs (plans/specs). APQC children are process parts." ;
    skos:example "The team produces the suite of plans and metrics that constitute the change design." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11152 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11153 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11154 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11155 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20145 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11156 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11157 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11158 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11159 ] .

# --- 13.4.2.1 (PCF 11152) : Analysis -> descriptive (no definitional ICE)
ex:P11152 a owl:Class ;
    ex:pcfID "11152" ; ex:hierarchyID "13.4.2.1" ;
    ex:apqcSourceText "Correlating the change initiative with the other initiatives. Create an alignment between the goals and objectives of the change process and that of the other initiatives." ;
    rdfs:label "Assess connection to other initiatives" ;
    skos:definition "An Act of Analysis that examines how a change initiative correlates with the organization's other initiatives and characterizes their alignment." ;
    rdfs:comment "No shared output ICE for the alignment finding; the alignment representation is typical rather than definitional, so no has-output restriction is asserted (Phase-3)." ;
    skos:example "The team maps the change's goals against concurrent programs to find overlaps and conflicts." ;
    rdfs:subClassOf ex:ActOfAnalysis .

# --- 13.4.2.2 (PCF 11153) : Formulation -> directive
ex:P11153 a owl:Class ;
    ex:pcfID "11153" ; ex:hierarchyID "13.4.2.2" ;
    ex:apqcSourceText "Creating a detailed structure summary for the purposes of managing the change. Demonstrate the reasons for the change. Define the type and scope of change. Form a change management team. Create a communication plan." ;
    rdfs:label "Develop change management plans" ;
    skos:definition "An Act of Formulation that composes a detailed change management plan structuring how a change will be managed." ;
    skos:example "The team drafts the master change management plan covering rationale, type, and scope." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeManagementPlan ] .

# --- 13.4.2.3 (PCF 11154) : Formulation -> directive
ex:P11154 a owl:Class ;
    ex:pcfID "11154" ; ex:hierarchyID "13.4.2.3" ;
    ex:apqcSourceText "Creating a detailed summary of all the actions relevant to teaching a person a particular skill or type of behavior. Determine who will deliver the training. Determine when and where the apprentice or trainee needs to go to receive the structured component of the training." ;
    rdfs:label "Develop training plan" ;
    skos:definition "An Act of Formulation that composes a training plan prescribing the actions, delivery, timing, and location for teaching the skills a change requires." ;
    skos:example "The team specifies the courses, trainers, and schedule to equip staff for the change." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TrainingPlan ] .

# --- 13.4.2.4 (PCF 11155) : Formulation -> directive
ex:P11155 a owl:Class ;
    ex:pcfID "11155" ; ex:hierarchyID "13.4.2.4" ;
    ex:apqcSourceText "Developing a plan for imparting or exchanging information relevant the to change. Define goals, objectives, and audience. Gather tools for all communications." ;
    rdfs:label "Develop communication plan" ;
    skos:definition "An Act of Formulation that composes a communication plan prescribing the goals, audiences, and channels for imparting information about a change." ;
    skos:example "The team plans the announcements, channels, and cadence for the change rollout." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CommunicationPlan ] .

# --- 13.4.2.5 (PCF 20145) : Planned Act (champion deployment)
ex:P20145 a owl:Class ;
    ex:pcfID "20145" ; ex:hierarchyID "13.4.2.5" ;
    ex:apqcSourceText "Utilizing champions that have been trained to carry out needed changes. Engage champions to communicate roles and responsibilities for the change." ;
    rdfs:label "Assign change champion(s)" ;
    skos:definition "A Planned Act in which trained change champions are deployed and engaged to carry out and communicate the change in their respective areas." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): deploying/engaging champions is an organizational act, not the production of an analysis or plan; the champion participants are the salient continuants." ;
    skos:example "Each trained champion is formally tasked with driving the change in their division." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ChangeChampion ] .

# --- 13.4.2.6 (PCF 11156) : Formulation -> directive
ex:P11156 a owl:Class ;
    ex:pcfID "11156" ; ex:hierarchyID "13.4.2.6" ;
    ex:apqcSourceText "Creating and designing the plan for rewarding the employees exhibiting the desired behavior. Specify rewards in recognition of service, effort, or achievement regarding the change, including bonuses, compensation, stock options, profit sharing, vacations, and flexible time." ;
    rdfs:label "Develop rewards/incentives plan" ;
    skos:definition "An Act of Formulation that composes a rewards and incentives plan prescribing how employees who exhibit the desired change behaviors are to be rewarded." ;
    skos:example "The team designs a bonus-and-recognition scheme for early adopters of the change." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RewardsAndIncentivesPlan ] .

# --- 13.4.2.7 (PCF 11157) : Formulation -> directive
ex:P11157 a owl:Class ;
    ex:pcfID "11157" ; ex:hierarchyID "13.4.2.7" ;
    ex:apqcSourceText "Establishing a system or standard of measurement for measuring the adoption of the change. Consider activities such as the number of people who have adopted the change, how quickly have they adopted, number of unique adopters, and adopters by teams/divisions." ;
    rdfs:label "Establish change adoption measures" ;
    skos:definition "An Act of Formulation that establishes the standards of measurement for tracking change adoption, producing a change adoption measure specification." ;
    skos:example "The team defines adoption-rate and unique-adopter metrics for the change." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeAdoptionMeasureSpecification ] .

# --- 13.4.2.8 (PCF 11158) : Formulation -> directive
ex:P11158 a owl:Class ;
    ex:pcfID "11158" ; ex:hierarchyID "13.4.2.8" ;
    ex:apqcSourceText "Establishing and explaining the new roles to employees. Assign roles and responsibilities to resources." ;
    rdfs:label "Establish/Clarify new roles" ;
    skos:definition "An Act of Formulation that defines and assigns the new roles and responsibilities a change introduces, producing a role definition specification." ;
    skos:example "The team documents and explains each employee's role under the new operating model." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RoleDefinitionSpecification ] .

# --- 13.4.2.9 (PCF 11159) : Formulation -> directive (budget; no shared ICE)
ex:P11159 a owl:Class ;
    ex:pcfID "11159" ; ex:hierarchyID "13.4.2.9" ;
    ex:apqcSourceText "Creating a plan of financial outlay for the newly defined roles. Determine the amount of capital the organization is willing to invest in effectuating these new roles, how would the roles be financed, and what would comprise the ROI from these flows. Coordinate personnel responsible for change management and the finance division." ;
    rdfs:label "Identify budget/roles" ;
    skos:definition "An Act of Formulation that composes a plan of financial outlay funding the newly defined roles required by a change." ;
    rdfs:comment "Output is a budget/financing plan (a Directive ICE). No shared budget ICE exists in the section vocabulary, so the output is recorded in comment rather than promoted to a has-output restriction (Phase-3)." ;
    skos:example "Finance and change leads set the capital and ROI assumptions for the new roles." ;
    rdfs:subClassOf ex:ActOfFormulation .

# --- 13.4.3 (PCF 11136) : implement change -> Implementation
ex:P11136 a owl:Class ;
    ex:pcfID "11136" ; ex:hierarchyID "13.4.3" ;
    ex:apqcSourceText "Effectuating the change within the desired impact areas of the organization. Ensure adequate commitment from all corners of the organization for the desired change. Create support structures. Refashion all processes deemed necessary. Observe the progress." ;
    rdfs:label "Implement change" ;
    skos:definition "An Act of Implementation that effectuates a designed change within the targeted areas of the organization by building commitment, reengineering processes, supporting transitions, and observing progress." ;
    rdfs:comment "Anchored to ex:ActOfImplementation (under cco:ont00000228 Planned Act): it executes the change design rather than producing a plan. APQC children are process parts." ;
    skos:example "The organization rolls out the redesigned processes and support structures for the change." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11160 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11161 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11162 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11163 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20146 ] .

# --- 13.4.3.1 (PCF 11160) : Planned Act (mobilization)
ex:P11160 a owl:Class ;
    ex:pcfID "11160" ; ex:hierarchyID "13.4.3.1" ;
    ex:apqcSourceText "Kindling an organization wide commitment for effectuating the change. Effectively communicate the advantages of the desired change. Personalize the pitch for change." ;
    rdfs:label "Create commitment for improvement/change" ;
    skos:definition "A Planned Act in which an Agent mobilizes organization-wide commitment to a change by communicating and personalizing its advantages." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): building commitment is a mobilization/communication act with no single definitional Information Content Entity output." ;
    skos:example "Leaders run a campaign making the case for the change to every team." ;
    rdfs:subClassOf cco:ont00000228 .

# --- 13.4.3.2 (PCF 11161) : Implementation (process reengineering)
ex:P11161 a owl:Class ;
    ex:pcfID "11161" ; ex:hierarchyID "13.4.3.2" ;
    ex:apqcSourceText "Restructuring, redesigning, repurposing, and/or retrofitting existing business processes, activities, and frameworks in order to effectuate the desired change. Review pertinent processes from the ground up by starting with the desired result. (Build on Select a process improvement methodology [11138] to create business processes that perfectly fit with the road map for change.)" ;
    rdfs:label "Reengineer business processes and systems" ;
    skos:definition "An Act of Implementation that restructures and redesigns existing business processes and systems in order to effectuate the desired change." ;
    rdfs:comment "Builds on the methodology selected in 13.1.5.2 (PCF 11138). Reengineering existing processes to bring about the change is implementation; no single definitional ICE output." ;
    skos:example "The team rebuilds the order-to-cash process from the desired outcome backward." ;
    rdfs:subClassOf ex:ActOfImplementation .

# --- 13.4.3.3 (PCF 11162) : Implementation (transition support)
ex:P11162 a owl:Class ;
    ex:pcfID "11162" ; ex:hierarchyID "13.4.3.3" ;
    ex:apqcSourceText "Supporting the transition of personnel to new roles and the dismissal of any existing employees, necessitated for the desired change. Create an on-boarding process for seamlessly transitioning personnel to new roles. Offer orientation and training. Address any concerns. Create a structured procedure for the discharge of incumbents from their positions." ;
    rdfs:label "Support transition to new roles or exit strategies for incumbents" ;
    skos:definition "An Act of Implementation that supports personnel through their transition to new roles and, where necessary, through structured exit from current positions during a change." ;
    rdfs:comment "Implementation support act; onboarding and discharge procedures are operational sub-steps, not a single definitional Information Content Entity output." ;
    skos:example "HR onboards staff into new roles and manages structured exits for redundant positions." ;
    rdfs:subClassOf ex:ActOfImplementation .

# --- 13.4.3.4 (PCF 11163) : Monitoring
ex:P11163 a owl:Class ;
    ex:pcfID "11163" ; ex:hierarchyID "13.4.3.4" ;
    ex:apqcSourceText "Monitoring activities in the change process in order to assess the performance of individual agents and the process as a whole. Oversee the implementation of activities needed for effectuating the change. Track the pace, impact, enthusiasm, reaction, and feedback over the change process." ;
    rdfs:label "Monitor change" ;
    skos:definition "An Act of Monitoring that observes and tracks the activities, pace, and reception of a change in progress in order to register the performance of the agents and of the change process as a whole." ;
    rdfs:comment "Reuses ex:ActOfMonitoring. The tracked observations are recorded across heterogeneous channels (pace, impact, feedback); no single shared output ICE is definitional, so none is asserted (Phase-3)." ;
    skos:example "A change office tracks adoption pace and sentiment week by week during rollout." ;
    rdfs:subClassOf ex:ActOfMonitoring .

# --- 13.4.3.5 (PCF 20146) : Information Processing -> descriptive
ex:P20146 a owl:Class ;
    ex:pcfID "20146" ; ex:hierarchyID "13.4.3.5" ;
    ex:apqcSourceText "Reporting on the outcome of the change. Document changes and the impact those changes had on critical assets. Share findings with those within the target audience: those impacted by the change, change champions, stakeholders, etc." ;
    rdfs:label "Report on change" ;
    skos:definition "An Act of Information Processing that documents the outcome and impact of a change and produces a change report shared with its affected audience." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): reporting compiles observations into a Descriptive ICE (the change report)." ;
    skos:example "The change office issues a closeout report to stakeholders and champions." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeReport ] .

# --- 13.4.4 (PCF 11137) : sustain improvement -> Improvement
ex:P11137 a owl:Class ;
    ex:pcfID "11137" ; ex:hierarchyID "13.4.4" ;
    ex:apqcSourceText "Sustaining the impact of the change process in order to enact continual process improvement. Monitor the performance of re-engineered business processes. Identify best practices and potential issues. Effectuate remedial steps." ;
    rdfs:label "Sustain improvement" ;
    skos:definition "An Act of Improvement that sustains the impact of a change by monitoring re-engineered process performance, capturing lessons, and effecting remedial steps for continual improvement." ;
    rdfs:comment "Anchored to ex:ActOfImprovement (under cco:ont00000228 Planned Act): it adjusts and reinforces the changed processes toward continually better performance. APQC children are process parts." ;
    skos:example "After go-live the team tracks the new process, captures lessons, and applies fixes." ;
    rdfs:subClassOf ex:ActOfImprovement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11164 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11165 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11166 ] .

# --- 13.4.4.1 (PCF 11164) : Monitoring -> descriptive
ex:P11164 a owl:Class ;
    ex:pcfID "11164" ; ex:hierarchyID "13.4.4.1" ;
    ex:apqcSourceText "Monitoring the performance of improved business processes. Track the key performance indicators of the upgraded processes in order to gauge its contribution to the desired change. Expedite through the use of business process management software." ;
    rdfs:label "Monitor improved process performance" ;
    skos:definition "An Act of Monitoring that tracks the key performance indicators of improved business processes and produces a process performance report gauging their contribution to the change." ;
    rdfs:comment "Reuses ex:ActOfMonitoring and ex:ProcessPerformanceReport (Descriptive ICE)." ;
    skos:example "BPM dashboards track the upgraded process KPIs against targets." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProcessPerformanceReport ] .

# --- 13.4.4.2 (PCF 11165) : Analysis -> descriptive
ex:P11165 a owl:Class ;
    ex:pcfID "11165" ; ex:hierarchyID "13.4.4.2" ;
    ex:apqcSourceText "Documenting and standardizing insights gleaned and the knowledge acquired from studying the change process already implemented. Create case studies/best practices guides from the process of implementing change. Include experienced personnel." ;
    rdfs:label "Capture and reuse lessons learned from change process" ;
    skos:definition "An Act of Analysis that examines an implemented change process and documents the insights and knowledge gained as a lessons-learned record." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (under cco:ont00000366 Act of Information Processing): it studies the completed change and produces a Descriptive ICE (the lessons-learned record / best-practices guide)." ;
    skos:example "The team writes a best-practices guide capturing what worked in the rollout." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:LessonsLearnedRecord ] .

# --- 13.4.4.3 (PCF 11166) : Improvement
ex:P11166 a owl:Class ;
    ex:pcfID "11166" ; ex:hierarchyID "13.4.4.3" ;
    ex:apqcSourceText "Implement corrective action to adjust the re-engineered processes for maximizing the desired impact. Adjust business processes and systems to implement the desired change." ;
    rdfs:label "Take corrective action as necessary" ;
    skos:definition "An Act of Improvement that adjusts the re-engineered business processes and systems through corrective action so as to maximize the intended impact of the change." ;
    rdfs:comment "Reuses ex:ActOfImprovement: corrective action modifies the changed processes toward better performance. May consume a remedial-action specification (ex:RemedialActionSpecification) as input; that input is typical rather than definitional, so no restriction is asserted (Phase-3)." ;
    skos:example "Post-launch, the team retunes the new workflow to remove a bottleneck." ;
    rdfs:subClassOf ex:ActOfImprovement .

# ===== group 13.5 Develop and manage KM capability (PCF 11073) =====
# Group node modeled as ex:KnowledgeManagementCapability (above);
# catalog node ex:PCF_11073 designates that capability. No ex:P11073.

# --- 13.5.1 (PCF 11095) : develop KM strategy -> Formulation
ex:P11095 a owl:Class ;
    ex:pcfID "11095" ; ex:hierarchyID "13.5.1" ;
    ex:apqcSourceText "Creating a plan for managing the organization's knowledge base. Determine what kind of specialized knowledge the organization possesses, which elements of this collective knowledge can prove beneficial, how to capture and maintain this knowledge, how to grant access to this library of information, and how the organization should proceed." ;
    rdfs:label "Develop KM strategy" ;
    skos:definition "An Act of Formulation that composes and articulates a KM strategy prescribing how an organization will capture, maintain, access, and exploit its collective knowledge." ;
    rdfs:comment "Models APQC 13.5.1 as an occurrent. Its APQC children are process parts, not subclasses. Output is a Directive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "A KM team drafts the enterprise knowledge-management strategy for the coming planning cycle." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11100 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11102 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11103 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11104 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11105 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11106 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11107 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11108 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11109 ] .

# --- 13.5.1.1 (PCF 11100) : Formulation -> Directive governance model
ex:P11100 a owl:Class ;
    ex:pcfID "11100" ; ex:hierarchyID "13.5.1.1" ;
    ex:apqcSourceText "Developing a structure for the governance of the organization's collective knowledge. Gather, maintain, and make accessible the collective knowledge base. Develop a standard procedure for the conservation and perpetuation of the organization's knowledge. Create policies for the usage and maintenance of this knowledge. Establish specialized roles." ;
    rdfs:label "Develop governance model with roles and accountability" ;
    skos:definition "An Act of Formulation that composes a KM governance model prescribing the structure, standard procedures, policies, and specialized roles for governing an organization's collective knowledge." ;
    rdfs:comment "Output is a Directive ICE (governance model) per the GOLDEN PRINCIPLE." ;
    skos:example "A KM lead defines a governance model assigning knowledge-stewardship roles and usage policies." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMGovernanceModel ] .

# --- 13.5.1.2 (PCF 11102) : Formulation -> Directive role definitions
ex:P11102 a owl:Class ;
    ex:pcfID "11102" ; ex:hierarchyID "13.5.1.2" ;
    ex:apqcSourceText "Clearly determining the roles and responsibilities of all personnel involved in the management of the organization's corpus of knowledge. Flesh out the roles and responsibilities of the KM core group, as well as the operational staff involved in the upkeep of the knowledge management program." ;
    rdfs:label "Define roles and accountability of core group versus operating units" ;
    skos:definition "An Act of Formulation that composes a role-definition specification prescribing the responsibilities of the KM core group versus the operating-unit staff who maintain the knowledge-management program." ;
    rdfs:comment "Output is a Directive ICE (role-definition specification) per the GOLDEN PRINCIPLE." ;
    skos:example "A KM governance team documents the split of accountabilities between the central KM office and business-unit knowledge owners." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RoleDefinitionSpecification ] .

# --- 13.5.1.3 (PCF 11103) : Selection -> Directive funding model
ex:P11103 a owl:Class ;
    ex:pcfID "11103" ; ex:hierarchyID "13.5.1.3" ;
    ex:apqcSourceText "Analyze the organization's current approach to funding. Learn from the funding approaches of peer organizations. Evaluate the revenue potential and costs of those short-list funding models. Select funding models to implement." ;
    rdfs:label "Develop funding models" ;
    skos:definition "An Act of Selection that, having evaluated candidate funding approaches against revenue potential and cost, chooses and prescribes the KM funding model(s) to implement." ;
    rdfs:comment "Anchored to ex:ActOfSelection (not Formulation) because the differentiating step is choosing among short-listed candidate funding models; its output is a Directive ICE (the selected funding model)." ;
    skos:example "A KM steering group short-lists three funding approaches and selects a chargeback model to adopt." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMFundingModel ] .

# --- 13.5.1.4 (PCF 11104) : Identification -> Descriptive linkage analysis
ex:P11104 a owl:Class ;
    ex:pcfID "11104" ; ex:hierarchyID "13.5.1.4" ;
    ex:apqcSourceText "Identifying any links that exist between the strategy for knowledge management and any other functional areas. Determine any correlations that exist between the strategic road map for the knowledge management and any other functional areas. Study each function's/unit's attributes." ;
    rdfs:label "Identify links to key initiatives" ;
    skos:definition "An Act of Identification that discerns the correlations between the KM strategy and other functional areas and produces a KM initiative linkage analysis registering them." ;
    rdfs:comment "Output is a Descriptive ICE (a linkage analysis representing discovered correlations) per the GOLDEN PRINCIPLE (information processing / discernment)." ;
    skos:example "An analyst maps how the KM roadmap intersects with the data-governance and HR-learning programs." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMInitiativeLinkageAnalysis ] .

# --- 13.5.1.5 (PCF 11105) : Formulation -> Directive methodology
ex:P11105 a owl:Class ;
    ex:pcfID "11105" ; ex:hierarchyID "13.5.1.5" ;
    ex:apqcSourceText "Creating core knowledge management procedures and methodologies. Initiate developing a strategy, planning, execution, and improvement." ;
    rdfs:label "Develop core KM methodologies" ;
    skos:definition "An Act of Formulation that composes a KM methodology specification prescribing the core procedures for strategizing, planning, executing, and improving knowledge management." ;
    rdfs:comment "Output is a Directive ICE (methodology specification) per the GOLDEN PRINCIPLE." ;
    skos:example "A KM center of excellence documents the standard lifecycle methodology for knowledge projects." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMMethodologySpecification ] .

# --- 13.5.1.6 (PCF 11106) : Appraisal -> Descriptive IT needs assessment
ex:P11106 a owl:Class ;
    ex:pcfID "11106" ; ex:hierarchyID "13.5.1.6" ;
    ex:apqcSourceText "Determining the IT needs for developing the knowledge management strategy, and collaborating with the IT function to implement the strategy. Assess requirements for technologies such as computer hardware, software, electronics, semiconductors, internet, and telecommunications equipment in order to effectively build and implement the strategy for knowledge management." ;
    rdfs:label "Assess IT needs and engage IT function" ;
    skos:definition "An Act of Appraisal that evaluates the information-technology requirements for building and implementing the KM strategy and produces an IT needs assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal) because the differentiating step evaluates/judges technology requirements; output is a Descriptive ICE per the GOLDEN PRINCIPLE. Engaging the IT function is a typical (non-definitional) collaboration, recorded in this comment rather than as a restriction." ;
    skos:example "A KM architect assesses the hardware and platform requirements and briefs the IT function." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITNeedsAssessment ] .

# --- 13.5.1.7 (PCF 11107) : Formulation -> Directive training + communication plans
ex:P11107 a owl:Class ;
    ex:pcfID "11107" ; ex:hierarchyID "13.5.1.7" ;
    ex:apqcSourceText "Creating plans for KM training plans and conveying the knowledge management strategy within the organization. Create training programs, sessions, and activities in order to familiarize employees and management with the concept of knowledge management." ;
    rdfs:label "Develop training and communication plans" ;
    skos:definition "An Act of Formulation that composes a training plan and a communication plan prescribing how the KM strategy will be taught and conveyed across the organization." ;
    rdfs:comment "Dual Directive ICE output (training plan and communication plan) per the GOLDEN PRINCIPLE." ;
    skos:example "A KM team drafts a rollout training curriculum and a stakeholder communication plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TrainingPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CommunicationPlan ] .

# --- 13.5.1.8 (PCF 11108) : Formulation -> Directive change management plan
ex:P11108 a owl:Class ;
    ex:pcfID "11108" ; ex:hierarchyID "13.5.1.8" ;
    ex:apqcSourceText "Creating approaches for effectively administering the changes in knowledge management. Design an approach that transforms individuals, teams, and the organization to a desired future state represented by the change." ;
    rdfs:label "Develop change management approaches" ;
    skos:definition "An Act of Formulation that composes a change management plan prescribing how individuals, teams, and the organization will be transitioned to the desired KM future state." ;
    rdfs:comment "Output is a Directive ICE (change management plan) per the GOLDEN PRINCIPLE." ;
    skos:example "A change lead designs the adoption approach for a new knowledge-sharing platform." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeManagementPlan ] .

# --- 13.5.1.9 (PCF 11109) : Formulation -> Directive performance-indicator spec
ex:P11109 a owl:Class ;
    ex:pcfID "11109" ; ex:hierarchyID "13.5.1.9" ;
    ex:apqcSourceText "Establishing measures and indicators for evaluating the performance of the knowledge management function. Define key performance indicators such as the amount of knowledge assets created and number of knowledge projects undertaken." ;
    rdfs:label "Develop strategic measures and indicators" ;
    skos:definition "An Act of Formulation that establishes and prescribes a performance-indicator specification of the key indicators used to evaluate the performance of the KM function." ;
    rdfs:comment "Establishing measures/indicators yields a Directive ICE (a specification of indicators) per the GOLDEN PRINCIPLE; aligns with ex:EstablishIPThreatMeasures in the GOLD slice (an Act of Planning producing a Directive ICE)." ;
    skos:example "A KM analyst defines KPIs such as knowledge assets created per quarter." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceIndicatorSpecification ] .

# --- 13.5.2 (PCF 11096) : assess KM capabilities -> Appraisal
ex:P11096 a owl:Class ;
    ex:pcfID "11096" ; ex:hierarchyID "13.5.2" ;
    ex:apqcSourceText "Assessing the maturity of the existing initiatives in knowledge management, and evaluating existing KM approaches. Identify the gaps and needs in order to enhance the existing KM approaches. Develop and implement new KM approaches." ;
    rdfs:label "Assess KM capabilities" ;
    skos:definition "An Act of Appraisal that evaluates the maturity and effectiveness of an organization's existing knowledge-management capabilities and produces a KM capability maturity assessment." ;
    rdfs:comment "Models APQC 13.5.2 as an occurrent. Its APQC children are process parts, not subclasses. Output is a Descriptive ICE per the GOLDEN PRINCIPLE (appraisal)." ;
    skos:example "A KM review board appraises current KM maturity ahead of the next planning cycle." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMCapabilityMaturityAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11110 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11111 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11112 ] .

# --- 13.5.2.1 (PCF 11110) : Appraisal -> Descriptive maturity assessment
ex:P11110 a owl:Class ;
    ex:pcfID "11110" ; ex:hierarchyID "13.5.2.1" ;
    ex:apqcSourceText "Evaluating if initiatives are effective or should be discarded. Design a framework for assessing maturity, typically from Level 1 (undefined), Level 2 (repeatable), Level 3 (defined), and Level 4 (managed) through Level 5 (optimized)." ;
    rdfs:label "Assess maturity of existing KM initiatives" ;
    skos:definition "An Act of Appraisal that judges the maturity of existing KM initiatives against a defined maturity scale and produces a KM capability maturity assessment." ;
    rdfs:comment "Output is a Descriptive ICE per the GOLDEN PRINCIPLE (appraisal)." ;
    skos:example "An assessor rates each KM initiative from Level 1 to Level 5 on the maturity model." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMCapabilityMaturityAssessment ] .

# --- 13.5.2.2 (PCF 11111) : Appraisal -> Descriptive approach evaluation
ex:P11111 a owl:Class ;
    ex:pcfID "11111" ; ex:hierarchyID "13.5.2.2" ;
    ex:apqcSourceText "Evaluating existing procedures, policies, and guidelines for knowledge management. Study and examine the organization's approach against industry best practices by benchmarking, competitive analysis, etc." ;
    rdfs:label "Evaluate existing KM approaches" ;
    skos:definition "An Act of Appraisal that evaluates the organization's existing KM procedures, policies, and guidelines against industry best practice and produces a KM approach evaluation." ;
    rdfs:comment "Output is a Descriptive ICE per the GOLDEN PRINCIPLE (appraisal). Benchmarking/competitive analysis are typical methods, noted here rather than as restrictions." ;
    skos:example "A KM lead benchmarks current knowledge policies against sector best practice." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMApproachEvaluation ] .

# --- 13.5.2.3 (PCF 11112) : Identification -> Descriptive gap-and-needs analysis
ex:P11112 a owl:Class ;
    ex:pcfID "11112" ; ex:hierarchyID "13.5.2.3" ;
    ex:apqcSourceText "Assessing the KM approach evaluations in order to identify any gaps or needs. Compare the performance of the KM approach against the desired or expected performance, as well as against the standard knowledge management industry approach." ;
    rdfs:label "Identify gaps and needs" ;
    skos:definition "An Act of Identification that, from the KM approach evaluations, discerns the gaps between actual and desired KM performance and produces a gap-and-needs analysis registering them." ;
    rdfs:comment "Has as input the KM approach evaluation produced by 13.5.2.2; that input is definitional for this gap analysis, so promoted to a restriction (Phase 3). Output is a Descriptive ICE per the GOLDEN PRINCIPLE." ;
    skos:example "An analyst compares current KM performance against the target state and lists capability gaps." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:KMApproachEvaluation ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GapAndNeedsAnalysis ] .

# --- 13.5.3 (PCF 20965) : design and implement KM capabilities -> Planned Act
ex:P20965 a owl:Class ;
    ex:pcfID "20965" ; ex:hierarchyID "13.5.3" ;
    ex:apqcSourceText "Creating knowledge bases and other repositories to preserve and develop company expertise, and to train new employees." ;
    rdfs:label "Design and implement KM capabilities" ;
    skos:definition "A Planned Act that designs and then puts into operation the knowledge bases, approaches, and supporting technology that preserve and develop an organization's expertise." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): an aggregate build-and-deploy effort spanning formulation, implementation, and improvement sub-acts; no single act genus dominates, and its APQC children are process parts, not subclasses." ;
    skos:example "A KM program builds a new expertise repository and rolls it out to a business unit." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11114 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20966 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11115 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20967 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20968 ] .

# --- 13.5.3.1 (PCF 11114) : Formulation -> Directive methodology spec
ex:P11114 a owl:Class ;
    ex:pcfID "11114" ; ex:hierarchyID "13.5.3.1" ;
    ex:apqcSourceText "Designing new policies, procedures, and guidelines to support knowledge management." ;
    rdfs:label "Develop new KM approaches" ;
    skos:definition "An Act of Formulation that composes new KM policies, procedures, and guidelines, prescribed as a KM methodology specification, to support knowledge management." ;
    rdfs:comment "Output is a Directive ICE (methodology specification) per the GOLDEN PRINCIPLE." ;
    skos:example "A KM designer drafts a new set of knowledge-capture guidelines." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMMethodologySpecification ] .

# --- 13.5.3.2 (PCF 20966) : Formulation -> Directive resource model
ex:P20966 a owl:Class ;
    ex:pcfID "20966" ; ex:hierarchyID "13.5.3.2" ;
    ex:apqcSourceText "Creating a model to describe resources and approaches to organization's knowledge management. Establish standards and guidelines to be followed." ;
    rdfs:label "Design resource model for KM approaches" ;
    skos:definition "An Act of Formulation that composes a KM resource model prescribing the resources, standards, and guidelines that the organization's KM approaches will follow." ;
    rdfs:comment "Output is a Directive ICE (resource model with standards/guidelines) per the GOLDEN PRINCIPLE." ;
    skos:example "A KM architect models the staffing, tooling, and content resources required for each KM approach." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMResourceModel ] .

# --- 13.5.3.3 (PCF 11115) : Implementation (PROPOSE-EXT genus)
ex:P11115 a owl:Class ;
    ex:pcfID "11115" ; ex:hierarchyID "13.5.3.3" ;
    ex:apqcSourceText "Implementing new policies, procedures, and guidelines to support knowledge management." ;
    rdfs:label "Implement new KM approaches" ;
    skos:definition "An Act of Implementation that puts into effect the new KM policies, procedures, and guidelines prescribed by the KM methodology specification." ;
    rdfs:comment "Has as input the directive KM methodology specification it operationalizes; that input is definitional, so promoted to a restriction (Phase 3). An implementation act realizes a directive rather than producing a new ICE, so no has-output restriction is asserted." ;
    skos:example "A KM team rolls out the newly approved knowledge-capture procedures across the operating units." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:KMMethodologySpecification ] .

# --- 13.5.3.4 (PCF 20967) : Improvement (PROPOSE-EXT genus)
ex:P20967 a owl:Class ;
    ex:pcfID "20967" ; ex:hierarchyID "13.5.3.4" ;
    ex:apqcSourceText "Using existing technologies to improve organization's knowledge management processes. Research available third-party offerings. Develop proprietary solutions. Employ knowledge engineers, data scientists and other relevant personnel." ;
    rdfs:label "Leverage and enhance IT for KM approaches" ;
    skos:definition "An Act of Improvement that uses and enhances existing information technology in order to raise the performance of an organization's knowledge-management processes." ;
    rdfs:comment "Anchored to ex:ActOfImprovement (PROPOSE-EXT): the act augments existing IT for a better-than-prior KM process state. Researching third-party offerings and employing specialists are typical methods, noted here rather than as restrictions." ;
    skos:example "A KM engineering team integrates a third-party search platform to speed knowledge retrieval." ;
    rdfs:subClassOf ex:ActOfImprovement .

# --- 13.5.3.5 (PCF 20968) : Formulation -> Directive performance-indicator spec
ex:P20968 a owl:Class ;
    ex:pcfID "20968" ; ex:hierarchyID "13.5.3.5" ;
    ex:apqcSourceText "Creating metrics that can be used to systematically describe KM approaches and capabilities. Choose applicable scales, benchmarks and units of measure. Determine required precision and error rates." ;
    rdfs:label "Develop measures" ;
    skos:definition "An Act of Formulation that establishes and prescribes a performance-indicator specification of the metrics, scales, benchmarks, and units used to describe KM approaches and capabilities." ;
    rdfs:comment "Establishing metrics yields a Directive ICE (a specification of indicators) per the GOLDEN PRINCIPLE; parallels ex:P11109." ;
    skos:example "A KM analyst defines the measurement scales and precision targets for KM capability metrics." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceIndicatorSpecification ] .

# --- 13.5.4 (PCF 20969) : evolve and sustain KM capabilities -> Planned Act
ex:P20969 a owl:Class ;
    ex:pcfID "20969" ; ex:hierarchyID "13.5.4" ;
    ex:apqcSourceText "Developing resources for improved knowledge management and knowledge engineering." ;
    rdfs:label "Evolve and sustain KM capabilities" ;
    skos:definition "A Planned Act that develops and augments resources in order to improve and sustain an organization's knowledge-management and knowledge-engineering capabilities over time." ;
    rdfs:comment "Anchored at cco:ont00000228 (Planned Act): an aggregate of enhancement, sustainment, and expansion sub-acts; no single act genus dominates, and its APQC children are process parts, not subclasses." ;
    skos:example "A KM program runs a continuous-improvement cycle that upgrades repositories and grows usage." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11113 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20970 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20971 ] .

# --- 13.5.4.1 (PCF 11113) : Improvement (PROPOSE-EXT genus)
ex:P11113 a owl:Class ;
    ex:pcfID "11113" ; ex:hierarchyID "13.5.4.1" ;
    ex:apqcSourceText "Leveraging KM evaluations and identified gap to enhance existing approaches." ;
    rdfs:label "Enhance/Modify existing KM approaches" ;
    skos:definition "An Act of Improvement that, leveraging KM approach evaluations and identified gaps, enhances or modifies existing KM approaches to raise their performance." ;
    rdfs:comment "Anchored to ex:ActOfImprovement (PROPOSE-EXT). Has as input the gap-and-needs analysis from 13.5.2.3; that input is definitional (the enhancement is driven by the identified gaps), so promoted to a restriction (Phase 3)." ;
    skos:example "A KM team revises the knowledge-capture workflow to close gaps found in the last capability review." ;
    rdfs:subClassOf ex:ActOfImprovement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GapAndNeedsAnalysis ] .

# --- 13.5.4.2 (PCF 20970) : Implementation (PROPOSE-EXT genus)
ex:P20970 a owl:Class ;
    ex:pcfID "20970" ; ex:hierarchyID "13.5.4.2" ;
    ex:apqcSourceText "Developing awareness about available knowledge bases and promoting their use to maximize their impact." ;
    rdfs:label "Sustain awareness and engagement" ;
    skos:definition "An Act of Communication that develops awareness of available knowledge bases and promotes their use across the organization, producing awareness messaging directed at the organization's members in order to maximize the knowledge bases' impact." ;
    rdfs:comment "RE-ANCHORED from ex:ActOfImplementation to cco:ont00000402 (Act of Communication, VERIFIED §6: transfers an ICE from one Agent to another; parent cco:ont00000228 Planned Act). Source text -- 'Developing awareness about available knowledge bases and promoting their use to maximize their impact' -- describes a PROMOTION / awareness-raising act whose essence is communication, not the neutral execution of a directive. Rejected candidate ex:ActOfImplementation: a false-friend genus (the prior 'operationalizing the communication plan' framing buried the communicative act-kind) and a D5 reuse miss. Added a has-output (ex:KMAwarenessCommunication) and an audience participant so the communicative content and recipients are visible. R5: read as repeatable bounded promotion campaigns (each campaign has a begin/end) realizing the standing engagement function, not as a single open-ended occurrent. Explicit cco:ont00000228 co-parent gives Gate C the Act anchor without the CCO closure." ;
    skos:example "A KM team runs an internal campaign encouraging staff to contribute to and consult the knowledge base." ;
    rdfs:subClassOf cco:ont00000402 ,   # Act of Communication (a CCO Planned Act)
        cco:ont00000228 ,   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:KMAwarenessCommunication ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.5.4.3 (PCF 20971) : Improvement (PROPOSE-EXT genus)
ex:P20971 a owl:Class ;
    ex:pcfID "20971" ; ex:hierarchyID "13.5.4.3" ;
    ex:apqcSourceText "Augmenting available resources to better leverage the offerings of the organization to serve existing clients and to expand the client base." ;
    rdfs:label "Expand KM infrastructure to meet demand" ;
    skos:definition "An Act of Improvement that augments the available knowledge-management infrastructure and resources in order to increase capacity to serve existing and new clients." ;
    rdfs:comment "Anchored to ex:ActOfImprovement (PROPOSE-EXT): augmenting resources to a greater-than-prior capacity. Target may be material (servers, storage) or informational; modeled generically as improvement." ;
    skos:example "A KM operations team adds storage and indexing capacity ahead of a surge in knowledge-base usage." ;
    rdfs:subClassOf ex:ActOfImprovement .

# ===== group 13.6 Measure and benchmark (PCF 21584) ===============
# Modeled as a bounded Act of Measuring; standing-function reading is
# ex:BenchmarkingCapability.

ex:P21584 a owl:Class ;
    ex:pcfID "21584" ; ex:hierarchyID "13.6" ;
    ex:apqcSourceText "Defining and managing measurement and benchmarking. Measure and benchmark the performance of internal processes, as well as the organization as a whole." ;
    rdfs:label "Measure and benchmark" ;
    skos:definition "A Planned Act that constitutes an organization's bounded enterprise cycle of defining performance strategy, measuring, and benchmarking the performance of its internal processes and of the organization as a whole against standards and other organizations." ;
    rdfs:comment "Models APQC process group 13.6 as a bounded enterprise measure-and-benchmark cycle. RE-ANCHORED from cco:ont00000345 (Act of Measuring) to cco:ont00000228 (Planned Act): Act of Measuring is too narrow a genus for a group aggregate whose children also include strategy formulation (13.6.1 ex:P21585) and appraisal (13.6.2 ex:P11072), not just measurement; the broad Planned Act covers the heterogeneous cycle. R5 / SIBLING-CONSISTENCY note: 'Defining and MANAGING measurement and benchmarking' carries a standing-function signal like the 13.1 (16378) and 13.5 (11073) group nodes that are capability-only; 13.6 is modeled with the 13.4 (P11074) DUAL precedent instead -- the standing capacity is ex:BenchmarkingCapability (an Organization Capability, which the catalog could alternatively bridge), and this Planned Act is the bounded annual cycle that realizes it. ex:BenchmarkingCapability carries an explicit obo:BFO_0000054 (realized in) link to this act so the dual model is coherent. Its APQC children are process parts, not subclasses." ;
    skos:example "An enterprise's annual performance measurement and benchmarking cycle covering process and organization-level metrics." ;
    rdfs:subClassOf cco:ont00000228 ,   # Planned Act (broad genus for the heterogeneous cycle)
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21585 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11072 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20147 ] .

# --- 13.6.1 (PCF 21585) : define/manage organizational performance strategy -> Formulation
ex:P21585 a owl:Class ;
    ex:pcfID "21585" ; ex:hierarchyID "13.6.1" ;
    ex:apqcSourceText "Creating and implementing a strategy for managing organizational performance. The strategy should include approaches for measuring, tracking, streamlining, and improving internal performance. It encompasses a blueprint for the tactical measurement of internal processes and work force improvement, in alignment with Employee Metrics Developed and Managed [10526]." ;
    rdfs:label "Define and manage organizational performance strategy" ;
    skos:definition "An Act of Formulation that composes an organizational performance strategy prescribing how an organization measures, tracks, streamlines, and improves its internal performance." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (inlined) because its definitional output is a Directive ICE (strategy). The 'and manage'/implementation facet is carried by its child processes; the parent itself produces the strategy." ;
    skos:example "A performance management office drafts and ratifies the firm's organizational performance strategy for the planning cycle." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:OrganizationalPerformanceStrategy ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11075 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21586 ] .

# --- 13.6.1.1 (PCF 11075) : Formulation -> Directive ICE
ex:P11075 a owl:Class ;
    ex:pcfID "11075" ; ex:hierarchyID "13.6.1.1" ;
    ex:apqcSourceText "Developing a model for organization's management systems. Develop a high-level measurement system to track performance across the enterprise or in specific functions or business units. Determine which processes to measure, which measures to use, how often to measure, and measurement targets. Review strategic decisions about how to best measure an organization." ;
    rdfs:label "Define enterprise measurement models" ;
    skos:definition "An Act of Formulation that composes an enterprise measurement model prescribing which processes to measure, which measures to use, how often to measure, and the measurement targets across an enterprise or business unit." ;
    rdfs:comment "Directive output (a measurement model/system is prescriptive), so anchored under ex:ActOfFormulation per the GOLDEN PRINCIPLE." ;
    skos:example "A measurement office defines a balanced-scorecard-style enterprise measurement model for a business unit." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnterpriseMeasurementModel ] .

# --- 13.6.1.2 (PCF 21586) : Improvement of an existing artifact
ex:P21586 a owl:Class ;
    ex:pcfID "21586" ; ex:hierarchyID "13.6.1.2" ;
    ex:apqcSourceText "Reviewing, evaluating, and updating enterprise measurement models. Align measurement models to current and future goals and performance targets, and make adjustments to support visibility and reporting needs across the organization." ;
    rdfs:label "Maintain enterprise measurement models" ;
    skos:definition "An Act of Formulation that reviews, evaluates, and recomposes an existing enterprise measurement model to align it with current and future goals, performance targets, and reporting needs." ;
    rdfs:comment "RE-ANCHORED from ex:ActOfImprovement to ex:ActOfFormulation. ex:ActOfImprovement's differentia is modifying an existing PROCESS, SYSTEM, or CAPABILITY to raise its performance; but the object here is an Enterprise Measurement MODEL -- an Information Content Entity (Directive ICE), not a process/system/capability. The source verb 'Reviewing, evaluating, and updating' an ICE is the revision/recomposition of a directive artifact, i.e. formulation/information-processing, not improvement-of-a-system. Contrast sibling P11084, which correctly uses ex:ActOfImprovement on a CAPABILITY. The existing measurement model is the definitional has-input; the revised model is the has-output (both Directive)." ;
    skos:example "An annual review updates the enterprise measurement model to reflect new strategic targets." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EnterpriseMeasurementModel ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnterpriseMeasurementModel ] .

# --- 13.6.2 (PCF 11072) : benchmark performance -> Appraisal
ex:P11072 a owl:Class ;
    ex:pcfID "11072" ; ex:hierarchyID "13.6.2" ;
    ex:apqcSourceText "Comparing organizational performance internally or externally with other organizations." ;
    rdfs:label "Benchmark performance" ;
    skos:definition "An Act of Appraisal that compares an organization's performance internally or externally against other organizations and produces a benchmark analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal) because benchmarking evaluates and judges performance relative to comparators. Children are process parts." ;
    skos:example "A benchmarking team compares the firm's order-cycle time against industry peers." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BenchmarkAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11083 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11084 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11085 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11087 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11088 ] .

# --- 13.6.2.1 (PCF 11083) : Appraisal -> Descriptive ICE
ex:P11083 a owl:Class ;
    ex:pcfID "11083" ; ex:hierarchyID "13.6.2.1" ;
    ex:apqcSourceText "Measuring, researching, and recording the performance of people, processes, mechanisms, or other areas of the business that the organization wants to benchmark or track." ;
    rdfs:label "Conduct performance assessments" ;
    skos:definition "An Act of Appraisal that measures, researches, and records the performance of people, processes, or other areas of a business and produces a performance assessment." ;
    rdfs:comment "Descriptive output (a recorded assessment), consistent with cco:ont00000636 (Act of Appraisal, a kind of Act of Measuring)." ;
    skos:example "An analyst measures and records contact-center handle times to support a benchmarking study." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceAssessment ] .

# --- 13.6.2.2 (PCF 11084) : Improvement of a standing capability
ex:P11084 a owl:Class ;
    ex:pcfID "11084" ; ex:hierarchyID "13.6.2.2" ;
    ex:apqcSourceText "Improving an organization's ability to compare its performance internally or externally, and maintaining benchmarking relationships with other organizations. Train staff in benchmarking. Develop technological solutions or other materials to aid benchmarking efforts. Consult with external entities to gain knowledge or tools to help benchmark." ;
    rdfs:label "Develop benchmarking capabilities" ;
    skos:definition "An Act of Improvement that enhances an organization's benchmarking capability by training staff, developing tools, and maintaining benchmarking relationships with other organizations." ;
    rdfs:comment "Modeled as a bounded improvement act (ex:ActOfImprovement), not as the capability itself: the standing capacity is the shared ex:BenchmarkingCapability (an Organization Capability), which this act brings about / enhances. REMOVED the prior obo:BFO_0000055 (realizes) some ex:BenchmarkingCapability restriction: 'realizes' means the act IS an exercise of that capability (capability realized IN the act), which would wrongly type this act as an instance of benchmarking. Developing/improving the benchmarking capability does NOT exercise benchmarking -- it produces/enhances the capability. The capability's own obo:BFO_0000054 (realized in) restrictions reference the genuine benchmarking acts (P21584, and the benchmarking appraisals P11083/P11085); this developing act is related to the capability descriptively here, not by a realizes axiom (a capability is not an ICE, so it is not asserted as a has-output either)." ;
    skos:example "A center of excellence trains analysts and procures a benchmarking platform, strengthening the firm's benchmarking capability." ;
    rdfs:subClassOf ex:ActOfImprovement .

# --- 13.6.2.3 (PCF 11085) : Appraisal -> Descriptive ICE
ex:P11085 a owl:Class ;
    ex:pcfID "11085" ; ex:hierarchyID "13.6.2.3" ;
    ex:apqcSourceText "Benchmarking internal processes and against external competitors." ;
    rdfs:label "Conduct internal and external benchmarking" ;
    skos:definition "An Act of Appraisal that compares internal processes against one another and against external competitors and produces a benchmark analysis." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal); the comparison yields a Descriptive ICE (benchmark analysis)." ;
    skos:example "A team benchmarks the firm's procurement cycle both across plants and against a rival." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BenchmarkAnalysis ] .

# --- 13.6.2.4 (PCF 11087) : Analysis -> Descriptive ICE
ex:P11087 a owl:Class ;
    ex:pcfID "11087" ; ex:hierarchyID "13.6.2.4" ;
    ex:apqcSourceText "Examining performance against benchmarked organizations or entities. Determine how much performance needs to change to meet expectations. Reach strategic goals." ;
    rdfs:label "Conduct gap analysis" ;
    skos:definition "An Act of Analysis that examines performance against benchmarked organizations and produces a gap and needs analysis quantifying how much performance must change to meet expectations." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (inlined): it processes benchmark inputs into a representation of the performance gap (Descriptive ICE)." ;
    skos:example "An analyst computes the percentage improvement in cycle time needed to match the benchmark leader." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:BenchmarkAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:GapAndNeedsAnalysis ] .

# --- 13.6.2.5 (PCF 11088) : Formulation -> Directive ICE
ex:P11088 a owl:Class ;
    ex:pcfID "11088" ; ex:hierarchyID "13.6.2.5" ;
    ex:apqcSourceText "Establishing a need for changing the performance of the organization. Make use of the gap analysis results in order to define the need for change." ;
    rdfs:label "Establish need for change" ;
    skos:definition "An Act of Formulation that uses gap analysis results to compose a change need statement defining the required change in organizational performance." ;
    rdfs:comment "Directive output (a change-need statement prescribing what must change), so anchored under ex:ActOfFormulation per the GOLDEN PRINCIPLE. Input is the gap and needs analysis." ;
    skos:example "Following a gap analysis, leadership issues a statement establishing the need to reduce defect rates by 30%." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:GapAndNeedsAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ChangeNeedStatement ] .

# --- 13.6.3 (PCF 20147) : evaluate performance -> Appraisal
ex:P20147 a owl:Class ;
    ex:pcfID "20147" ; ex:hierarchyID "13.6.3" ;
    ex:apqcSourceText "Assessing process data, measures, and trends in an effort to evaluate process performance and identify possible improvements." ;
    rdfs:label "Evaluate performance" ;
    skos:definition "An Act of Appraisal that assesses process data, measures, and trends to evaluate process performance and identify possible improvements, producing a performance assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal) because it evaluates and judges performance. Children are process parts." ;
    skos:example "A quarterly performance review evaluates KPI results and flags improvement opportunities." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10270 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10271 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20148 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10272 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10273 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10274 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10275 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P10276 ] .

# --- 13.6.3.1 (PCF 10270) : Formulation -> Directive ICE
ex:P10270 a owl:Class ;
    ex:pcfID "10270" ; ex:hierarchyID "13.6.3.1" ;
    ex:apqcSourceText "Designing key measures that analyze and interpret how effectively the business is achieving its objectives." ;
    rdfs:label "Establish performance indicators (measures)" ;
    skos:definition "An Act of Formulation that designs key performance measures and composes a performance indicator specification prescribing how effectively the business is achieving its objectives." ;
    rdfs:comment "Directive output (a specification of indicators), so anchored under ex:ActOfFormulation per the GOLDEN PRINCIPLE." ;
    skos:example "A team defines a set of KPIs and their formulas for the order-fulfillment process." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceIndicatorSpecification ] .

# --- 13.6.3.2 (PCF 10271) : Formulation -> Directive ICE
ex:P10271 a owl:Class ;
    ex:pcfID "10271" ; ex:hierarchyID "13.6.3.2" ;
    ex:apqcSourceText "Deciding on the appropriate amount of supervisions that are needed to effectively assess the performance of business plans." ;
    rdfs:label "Establish monitoring frequency" ;
    skos:definition "An Act of Formulation that decides and composes a monitoring frequency specification prescribing how often performance is to be supervised and assessed." ;
    rdfs:comment "Directive output (a prescription of monitoring cadence), so anchored under ex:ActOfFormulation per the GOLDEN PRINCIPLE. Output ICE ex:MonitoringFrequencySpecification is minted here (not in the shared list)." ;
    skos:example "Governance decides KPIs will be reviewed monthly and the dashboard refreshed weekly." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:MonitoringFrequencySpecification ] .

# --- 13.6.3.3 (PCF 20148) : Information Processing -> Descriptive ICE
ex:P20148 a owl:Class ;
    ex:pcfID "20148" ; ex:hierarchyID "13.6.3.3" ;
    ex:apqcSourceText "Consolidating acquired metrics and trends. Provide data that can be benchmarked against historical data." ;
    rdfs:label "Collect performance data" ;
    skos:definition "An Act of Information Processing that consolidates acquired metrics and trends into performance data suitable for benchmarking against historical data." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): input metric ICEs are received and consolidated into an output Descriptive ICE (performance data)." ;
    skos:example "A reporting tool consolidates monthly KPI feeds into a single performance dataset." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceData ] .

# --- 13.6.3.4 (PCF 10272) : Measuring -> Descriptive ICE
ex:P10272 a owl:Class ;
    ex:pcfID "10272" ; ex:hierarchyID "13.6.3.4" ;
    ex:apqcSourceText "Measuring the performance of process planning. Quantify the performance, record results of the performance tests, and report them to the appropriate authority." ;
    rdfs:label "Calculate performance measures" ;
    skos:definition "An Act of Measuring that quantifies process performance against defined indicators and records the results as a performance measurement." ;
    rdfs:comment "Anchored directly to cco:ont00000345 (Act of Measuring): it determines the quantity/extent of performance relative to a standard. Input is performance data; output is a Descriptive ICE (performance measurement)." ;
    skos:example "A scorecard calculates the period's KPI values from the collected data." ;
    rdfs:subClassOf cco:ont00000345 ,   # Act of Measuring (a CCO Planned Act)
        cco:ont00000228 ,   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceData ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceMeasurement ] .

# --- 13.6.3.5 (PCF 10273) : Analysis -> Descriptive ICE
ex:P10273 a owl:Class ;
    ex:pcfID "10273" ; ex:hierarchyID "13.6.3.5" ;
    ex:apqcSourceText "Recognizing the trends in performance. Carefully and strategically assess the results in order to effectively spot the trends." ;
    rdfs:label "Identify performance trends" ;
    skos:definition "An Act of Analysis that examines performance measurements over time and produces a performance trend analysis representing the recognized trends." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (inlined): it processes measurement ICEs into a representation of trends (Descriptive ICE). Not ex:ActOfIdentification because the emphasis is analytic trend-detection rather than enumeration." ;
    skos:example "An analyst plots twelve months of KPI data and identifies a declining-quality trend." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceMeasurement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceTrendAnalysis ] .

# --- 13.6.3.6 (PCF 10274) : Analysis -> Descriptive ICE
ex:P10274 a owl:Class ;
    ex:pcfID "10274" ; ex:hierarchyID "13.6.3.6" ;
    ex:apqcSourceText "Evaluating the gaps between achieved and benchmarked performance. Analyze how performance differs from the optimal or expected performance." ;
    rdfs:label "Analyze performance" ;
    skos:definition "An Act of Appraisal that evaluates the gaps between achieved and benchmarked or expected performance and produces a performance assessment of how performance differs from the optimum." ;
    rdfs:comment "RE-ANCHORED from ex:ActOfAnalysis to cco:ont00000636 (Act of Appraisal). The source verb is 'EVALUATING the gaps ... Analyze how performance differs', and its asserted output ex:PerformanceAssessment is defined as 'describes a JUDGEMENT of performance' -- the product of appraisal, not generic information-processing analysis. This makes the genus agree with the judgement-bearing output (GOLDEN PRINCIPLE) and makes the row consistent with its siblings P11083 and P20147, which also produce ex:PerformanceAssessment under cco:ont00000636. (If a purely analytic gap-quantification reading were wanted, a distinct descriptive ex:PerformanceGapAnalysis ICE would be used under ex:ActOfAnalysis; here the appraisal/judgement reading is adopted for sibling consistency.)" ;
    skos:example "An analyst explains why the period's throughput fell short of the benchmark target." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceMeasurement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceAssessment ] .

# --- 13.6.3.7 (PCF 10275) : Information Processing -> Descriptive ICE
ex:P10275 a owl:Class ;
    ex:pcfID "10275" ; ex:hierarchyID "13.6.3.7" ;
    ex:apqcSourceText "Creating reports that systematically record and represent the performance planning. Construct a detailed report specifying the performance, and include indicators such as the performance gaps, performance trends, and analysis." ;
    rdfs:label "Prepare performance reports" ;
    skos:definition "An Act of Information Processing that assembles performance measurements, trends, and analyses into a performance report that systematically records and represents performance." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): input ICEs (measurements, trends, analyses) are manipulated and assembled into an output Descriptive ICE (performance report)." ;
    skos:example "A reporting analyst compiles the quarterly performance report including gaps, trends, and commentary." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceTrendAnalysis ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceReport ] .

# --- 13.6.3.8 (PCF 10276) : Formulation -> Directive ICE
ex:P10276 a owl:Class ;
    ex:pcfID "10276" ; ex:hierarchyID "13.6.3.8" ;
    ex:apqcSourceText "Using performance indicators to report, analyze, and create a detailed performance improvement plan to bridge the performance gaps." ;
    rdfs:label "Develop performance improvement plan" ;
    skos:definition "An Act of Formulation that uses performance indicators and assessments to compose a performance improvement plan prescribing actions to bridge identified performance gaps." ;
    rdfs:comment "Directive output (a plan), so anchored under ex:ActOfFormulation per the GOLDEN PRINCIPLE. Input is the performance assessment." ;
    skos:example "After analyzing gaps, a team drafts a performance improvement plan with owners and milestones." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceAssessment ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceImprovementPlan ] .

# ===== group 13.2 Manage portfolio, program, and project (PCF 16400) =====
# Group node 16400 -> ex:PortfolioProgramProjectManagementCapability (aggregate).
# The three 'Manage X' nodes 16401/16405/16410 are standing functions ->
# capabilities (no ex:P); their Activity children are wired to those
# capabilities as realized-in fillers. The deeper Activity>Task partonomies
# (16411>tasks, 16413>tasks, 16414>tasks) are genuine process partonomies.

# --- 13.2.1.1 (PCF 16402) : establish portfolio strategy -> Formulation
ex:P16402 a owl:Class ;
    ex:pcfID "16402" ; ex:hierarchyID "13.2.1.1" ;
    ex:apqcSourceText "Instituting the strategy for managing business portfolio. Create a systematic plan that defines the strategy for managing investments, holdings, products, businesses, and brands." ;
    rdfs:label "Establish portfolio strategy" ;
    skos:definition "An Act of Formulation that composes a portfolio strategy prescribing how an organization manages its portfolio of investments, holdings, products, businesses, and brands." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output (portfolio strategy) is a Directive ICE." ;
    skos:example "A portfolio office drafts the strategy governing the firm's brand and investment portfolio." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PortfolioStrategy ] .

# --- 13.2.1.2 (PCF 16403) : define portfolio governance -> Formulation
ex:P16403 a owl:Class ;
    ex:pcfID "16403" ; ex:hierarchyID "13.2.1.2" ;
    ex:apqcSourceText "Outlining the administration of business portfolio of the organization. Create and manage the rules and regulations regarding the business processes in order to identify, select, prioritize, and monitor portfolio components. Include a set of metrics to indicate the health and progress of the portfolio in the most vital area." ;
    rdfs:label "Define portfolio governance" ;
    skos:definition "An Act of Formulation that composes a portfolio governance framework prescribing the rules, metrics, and procedures for identifying, selecting, prioritizing, and monitoring portfolio components." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output (portfolio governance framework) is a Directive ICE." ;
    skos:example "A portfolio board defines the governance rules and health metrics for portfolio components." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PortfolioGovernanceFramework ] .

# --- 13.2.1.3 (PCF 16404) : monitor and control portfolio -> Monitoring
ex:P16404 a owl:Class ;
    ex:pcfID "16404" ; ex:hierarchyID "13.2.1.3" ;
    ex:apqcSourceText "Overseeing and administering the business portfolio of the organization. Monitor all activities related to investments, holdings, products, businesses, and brands by effectively monitoring and supervising these activities." ;
    rdfs:label "Monitor and control portfolio" ;
    skos:definition "An Act of Monitoring that oversees and supervises the activities of an organization's business portfolio and produces a portfolio status report." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring: it tracks portfolio activities over time and yields a Descriptive ICE (the status report)." ;
    skos:example "A portfolio manager tracks investment and brand performance and issues a portfolio status report." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PortfolioStatusReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.2.2.1 (PCF 16406) : establish program structure -> Formulation
ex:P16406 a owl:Class ;
    ex:pcfID "16406" ; ex:hierarchyID "13.2.2.1" ;
    ex:apqcSourceText "Constructing and instituting the framework and approach to manage business programs. Monitor key factors such as governance, alignment with the overall business vision, assurance, and management." ;
    rdfs:label "Establish program structure and approach" ;
    skos:definition "An Act of Formulation that composes a program structure specification prescribing the framework and approach -- governance, alignment, assurance, and management -- for managing a business program." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output (program structure specification) is a Directive ICE." ;
    skos:example "A program office defines the governance and assurance framework for a transformation program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProgramStructureSpecification ] .

# --- 13.2.2.2 (PCF 16407) : manage program stakeholders and partners -> Planned Act
ex:P16407 a owl:Class ;
    ex:pcfID "16407" ; ex:hierarchyID "13.2.2.2" ;
    ex:apqcSourceText "Managing relationships with stakeholders and partners of the business programs." ;
    rdfs:label "Manage program stakeholders and partners" ;
    skos:definition "A Planned Act that manages the relationships with the stakeholders and partners of a business program." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): relationship management is an organizational act with no single definitional ICE output; the stakeholders/partners are the salient participants." ;
    skos:example "A program manager runs the stakeholder and partner engagement cadence for a program." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.2.2.3 (PCF 16408) : manage program execution -> Implementation
ex:P16408 a owl:Class ;
    ex:pcfID "16408" ; ex:hierarchyID "13.2.2.3" ;
    ex:apqcSourceText "Administering and implementing business programs. Implement and execute programs with the intention of improving an organization's performance. Execute all the individual projects of the program to ensure the desired success." ;
    rdfs:label "Manage program execution" ;
    skos:definition "An Act of Implementation that administers and executes a business program by carrying out its constituent projects." ;
    rdfs:comment "Anchored to ex:ActOfImplementation (under cco:ont00000228): executing the program enacts the program structure rather than producing an ICE." ;
    skos:example "A program manager runs the program's constituent projects to completion." ;
    rdfs:subClassOf ex:ActOfImplementation .

# --- 13.2.2.4 (PCF 16409) : review and report program performance -> Monitoring
ex:P16409 a owl:Class ;
    ex:pcfID "16409" ; ex:hierarchyID "13.2.2.4" ;
    ex:apqcSourceText "Evaluating and documenting the performance of business programs. Evaluate the performance of the programs. Create reports on the basis of the analysis. Use performance indicators and metrics such as desired/achieved goals, completion dates, issues and defects, and cost effectiveness." ;
    rdfs:label "Review and report program performance" ;
    skos:definition "An Act of Monitoring that evaluates and documents the performance of a business program against its indicators and produces a program performance report." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring: it tracks program performance and yields a Descriptive ICE (the program performance report)." ;
    skos:example "A program office issues the quarterly program performance report against goals and cost-effectiveness." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProgramPerformanceReport ] .

# --- 13.2.3.1 (PCF 16411) : establish project scope -> Formulation (parent)
ex:P16411 a owl:Class ;
    ex:pcfID "16411" ; ex:hierarchyID "13.2.3.1" ;
    ex:apqcSourceText "Establishing the horizons of business projects. Identify the objectives of the program, along with the resource requirements. Assess the readiness for the project management approach. Identify methodologies for project management. Obtain funding. Develop performance measures and indicators." ;
    rdfs:label "Establish project scope" ;
    skos:definition "An Act of Formulation that establishes the scope of a business project -- its objectives, resource requirements, and measures -- producing a project scope statement." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output (project scope statement) is a Directive ICE. Its APQC children are process parts." ;
    skos:example "A project manager fixes the project's objectives, resourcing, and KPIs in a scope statement." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectScopeStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11117 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16412 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11118 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11120 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11121 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21454 ] .

# --- 13.2.3.1.1 (PCF 11117) : identify project requirements -> Identification
ex:P11117 a owl:Class ;
    ex:pcfID "11117" ; ex:hierarchyID "13.2.3.1.1" ;
    ex:apqcSourceText "Recognizing and defining what the project is ultimately supposed to do. Specify the capabilities, features, or attributes of the project's deliverables, as well as any kind of formal documentation." ;
    rdfs:label "Identify project requirements and objectives" ;
    skos:definition "An Act of Identification that discerns and defines what a project is to accomplish -- the capabilities, features, and attributes of its deliverables -- registering them in a project requirements statement." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment, under cco:ont00000366), NOT the false-friend cco:ont00001261 'Act of Identifying' (a communication act) per §6. Per the GOLDEN PRINCIPLE (Analysis/Info-Processing -> Descriptive), the output ex:ProjectRequirementsStatement is Descriptive: this act registers the discerned required capabilities/features, parallel to its siblings ex:P16412 (-> ex:ProjectResourceRequirementsStatement, 853) and ex:P11124 (-> ex:ITRequirementsStatement, 853). Any directive force (deliverables MUST satisfy X) would be a separate downstream Directive ICE composed by a Formulation act, not authored here." ;
    skos:example "A business analyst defines the required features of the project's deliverables." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectRequirementsStatement ] .

# --- 13.2.3.1.2 (PCF 16412) : identify project resource requirements -> Identification
ex:P16412 a owl:Class ;
    ex:pcfID "16412" ; ex:hierarchyID "13.2.3.1.2" ;
    ex:apqcSourceText "Identifying the prerequisites of business projects. Identify the people with appropriate and applicable skills and competencies. Locate resources such as capital, facilities, equipment, material, and information required to accomplish the objectives of a specific project." ;
    rdfs:label "Identify project resource requirements" ;
    skos:definition "An Act of Identification that discerns the people, skills, and resources a project requires and registers them in a project resource requirements statement." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment), NOT cco:ont00001261. Output is the Descriptive ex:ProjectResourceRequirementsStatement (a discernment of prerequisites), agreeing with the information-processing genus per the GOLDEN PRINCIPLE." ;
    skos:example "A project manager lists the skilled staff, capital, and equipment the project needs." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectResourceRequirementsStatement ] .

# --- 13.2.3.1.3 (PCF 11118) : assess culture and readiness -> Appraisal
ex:P11118 a owl:Class ;
    ex:pcfID "11118" ; ex:hierarchyID "13.2.3.1.3" ;
    ex:apqcSourceText "Evaluating the culture and readiness of the organizational environment is order to implement the project management approach." ;
    rdfs:label "Assess culture and readiness for project management approach" ;
    skos:definition "An Act of Appraisal that evaluates the culture and readiness of an organizational environment for adopting a project-management approach and produces a project readiness assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges readiness; output is the Descriptive ex:ProjectReadinessAssessment." ;
    skos:example "A PMO surveys readiness for agile adoption before launching a project." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectReadinessAssessment ] .

# --- 13.2.3.1.4 (PCF 11120) : create business case -> Analysis (descriptive)
ex:P11120 a owl:Class ;
    ex:pcfID "11120" ; ex:hierarchyID "13.2.3.1.4" ;
    ex:apqcSourceText "Creating a document that includes the current situation, proposed solution, financial analysis, conclusion, etc. Convince a decision maker and investors to approve the project. Obtain funding." ;
    rdfs:label "Create business case" ;
    skos:definition "An Act of Analysis that examines the current situation, proposed solution, and financial analysis and produces a business case justifying the project to decision makers." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (under cco:ont00000366): it assembles a reasoned justification (a Descriptive ICE) rather than prescribing a course of action. Output ex:BusinessCase is correctly Descriptive (an argument/justification representing a situation); the go/no-go approval it supports is a separate Directive decision, not modeled here." ;
    skos:example "A sponsor writes the business case making the financial argument to fund the project." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:BusinessCase ] .

# --- 13.2.3.1.5 (PCF 11121) : develop project measures and indicators -> Formulation
ex:P11121 a owl:Class ;
    ex:pcfID "11121" ; ex:hierarchyID "13.2.3.1.5" ;
    ex:apqcSourceText "Developing procedures and indictors to assess performance of business projects. Design and develop metrics and indicators--such as cost, schedule, resources, risk, and quality--that exhibit the performance of the business projects." ;
    rdfs:label "Develop project measures and indicators" ;
    skos:definition "An Act of Formulation that designs and prescribes the metrics and indicators -- cost, schedule, resources, risk, and quality -- used to assess project performance, producing a performance indicator specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: designing measures yields a Directive ICE (the shared ex:PerformanceIndicatorSpecification, whose comment lists 13.2.3.1.5 as a consumer)." ;
    skos:example "A project manager defines the cost, schedule, and quality KPIs for the project." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PerformanceIndicatorSpecification ] .

# --- 13.2.3.1.6 (PCF 21454) : prioritize and select projects -> Selection
ex:P21454 a owl:Class ;
    ex:pcfID "21454" ; ex:hierarchyID "13.2.3.1.6" ;
    ex:apqcSourceText "Stack ranking of projects in the portfolio based upon preestablished criteria." ;
    rdfs:label "Prioritize and select projects for the portfolio" ;
    skos:definition "An Act of Selection that stack-ranks and chooses the projects for the portfolio against preestablished criteria and produces a project portfolio selection." ;
    rdfs:comment "Anchored to ex:ActOfSelection (reused): chooses/prioritizes from candidate projects, yielding a Directive decision ICE (the selection/prioritization)." ;
    skos:example "A portfolio board ranks and selects which projects to fund this cycle." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectPortfolioSelection ] .

# --- 13.2.3.2 (PCF 11119) : identify PM methodologies -> Selection
ex:P11119 a owl:Class ;
    ex:pcfID "11119" ; ex:hierarchyID "13.2.3.2" ;
    ex:apqcSourceText "Identifying and implementing the techniques and procedures for managing business projects. Identify the most appropriate models, which are to be employed by the project managers for the purpose of designing, planning, implementing, and achieving project objectives. Examine and assess various project management methodologies such as adaptive project framework, agile development, crystal methods, and feature-driven development." ;
    rdfs:label "Identify appropriate project management methodologies" ;
    skos:definition "An Act of Selection that examines and chooses the most appropriate project-management methodology from candidate models and produces a project management methodology selection." ;
    rdfs:comment "Anchored to ex:ActOfSelection (reused): the differentiating step ('Identify the most appropriate models ... Examine and assess various ... methodologies') chooses one option from a candidate set, yielding a Directive ICE. Output ex:ProjectManagementMethodologySelection is Directive (the producing act being a selection whose output prescribes the chosen methodology)." ;
    skos:example "A PMO assesses agile vs feature-driven development and selects the methodology for the project." ;
    rdfs:subClassOf ex:ActOfSelection ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectManagementMethodologySelection ] .

# --- 13.2.3.3 (PCF 16413) : develop project plans -> Formulation (parent)
ex:P16413 a owl:Class ;
    ex:pcfID "16413" ; ex:hierarchyID "13.2.3.3" ;
    ex:apqcSourceText "Defining the resources and their roles. Identify IT requirements. Create plans for effective training and communication. Design reward approaches. Plan the launch of project. Deploy the project." ;
    rdfs:label "Develop project plans" ;
    skos:definition "An Act of Formulation that composes a project plan prescribing the resources, roles, IT requirements, training, communication, reward approaches, and launch for executing a business project." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output (project plan) is a Directive ICE. Its APQC children are process parts." ;
    skos:example "A project manager assembles the resourcing, training, and launch plans into the project plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11123 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P20142 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11124 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11125 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11127 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11128 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11129 ] .

# --- 13.2.3.3.1 (PCF 11123) : define roles and resources -> Formulation
ex:P11123 a owl:Class ;
    ex:pcfID "11123" ; ex:hierarchyID "13.2.3.3.1" ;
    ex:apqcSourceText "Outlining the resources and their roles in the business projects." ;
    rdfs:label "Define roles and resources" ;
    skos:definition "An Act of Formulation that defines and assigns the roles and resources of a business project, producing a role definition specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: outlining roles/resources yields a Directive ICE (the shared ex:RoleDefinitionSpecification)." ;
    skos:example "A project manager documents who fills each project role and the resources assigned." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RoleDefinitionSpecification ] .

# --- 13.2.3.3.2 (PCF 20142) : acquire/secure project resources -> Acquisition
ex:P20142 a owl:Class ;
    ex:pcfID "20142" ; ex:hierarchyID "13.2.3.3.2" ;
    ex:apqcSourceText "Procuring the necessary resources outlined in Define roles and resources [11123]" ;
    rdfs:label "Acquire/secure project resources" ;
    skos:definition "An Act of Acquisition that procures and secures the resources outlined for a business project that the organization did not previously hold." ;
    rdfs:comment "Anchored to ex:ActOfAcquisition (reused from apqc-ext, under cco:ont00000228 Planned Act): obtaining/securing resources the organization did not previously hold. The role-definition specification from 11123 is a typical governing input, noted here; the resources acquired are material/independent continuants, not a definitional ICE output." ;
    skos:example "A project manager procures the contractors and equipment the project plan requires." ;
    rdfs:subClassOf ex:ActOfAcquisition .

# --- 13.2.3.3.3 (PCF 11124) : identify specific IT requirements -> Identification
ex:P11124 a owl:Class ;
    ex:pcfID "11124" ; ex:hierarchyID "13.2.3.3.3" ;
    ex:apqcSourceText "Determining the IT requirements for specific business projects. Identify the requirements of computers and telecommunications equipment to store, retrieve, transmit, and manipulate data related to the project. Consider factors such as functional requirements, design requirements, project phases, and project schedule." ;
    rdfs:label "Identify specific IT requirements" ;
    skos:definition "An Act of Identification that discerns the information-technology requirements of a specific business project and registers them in an IT requirements statement." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment), NOT cco:ont00001261. Output is the Descriptive ex:ITRequirementsStatement (an enumeration of discerned requirements), agreeing with the information-processing genus per the GOLDEN PRINCIPLE." ;
    skos:example "A project's IT lead lists the hardware and telecom requirements for the project." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ITRequirementsStatement ] .

# --- 13.2.3.3.4 (PCF 11125) : create training and communication plans -> Formulation
ex:P11125 a owl:Class ;
    ex:pcfID "11125" ; ex:hierarchyID "13.2.3.3.4" ;
    ex:apqcSourceText "Designing a plan for equipping the project team with the necessary skills and abilities to fulfill their roles and responsibilities in the project effectively and efficiently. Offer formal training, mentoring, or coaching. Initiate informal conversations. Communicate messages during the project." ;
    rdfs:label "Create training and communication plans" ;
    skos:definition "An Act of Formulation that composes a training plan and a communication plan for equipping the project team with the necessary skills and for communicating during the project." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: dual Directive ICE output (training plan and communication plan)." ;
    skos:example "A project manager drafts the team training curriculum and the project communication plan." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:TrainingPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:CommunicationPlan ] .

# --- 13.2.3.3.5 (PCF 11127) : design recognition and reward approaches -> Formulation
ex:P11127 a owl:Class ;
    ex:pcfID "11127" ; ex:hierarchyID "13.2.3.3.5" ;
    ex:apqcSourceText "Creating a plan for recognizing and rewarding extraordinary performances within the business projects. Use incentives, bonuses, and certificates for recognition and rewarding purposes." ;
    rdfs:label "Design recognition and reward approaches" ;
    skos:definition "An Act of Formulation that composes a recognition and reward plan prescribing the incentives, bonuses, and recognition for extraordinary performance within a project." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output (the shared ex:RecognitionAndRewardPlan) is a Directive ICE." ;
    skos:example "A project manager designs a bonus-and-certificate scheme for outstanding project work." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RecognitionAndRewardPlan ] .

# --- 13.2.3.3.6 (PCF 11128) : design and plan launch of project -> Formulation
ex:P11128 a owl:Class ;
    ex:pcfID "11128" ; ex:hierarchyID "13.2.3.3.6" ;
    ex:apqcSourceText "Creating a plan specifying when to initiate the project, and introducing it to the target audience. Clearly define the project team, objectives, timelines, and milestone." ;
    rdfs:label "Design and plan launch of project" ;
    skos:definition "An Act of Formulation that composes a project launch plan prescribing when to initiate the project and how to introduce it to its target audience, including team, objectives, timelines, and milestones." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output (project launch plan) is a Directive ICE." ;
    skos:example "A project manager plans the kickoff timing, audience, and milestones for the launch." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectLaunchPlan ] .

# --- 13.2.3.3.7 (PCF 11129) : deploy the project -> Implementation
ex:P11129 a owl:Class ;
    ex:pcfID "11129" ; ex:hierarchyID "13.2.3.3.7" ;
    ex:apqcSourceText "Putting the project into position by effectively bringing it into action." ;
    rdfs:label "Deploy the project" ;
    skos:definition "An Act of Implementation that puts a business project into position and brings it into action per its project plan." ;
    rdfs:comment "Anchored to ex:ActOfImplementation (under cco:ont00000228): deployment enacts the project plan rather than producing an ICE." ;
    skos:example "A project manager mobilizes the team and kicks off project execution." ;
    rdfs:subClassOf ex:ActOfImplementation .

# --- 13.2.3.4 (PCF 16414) : execute projects -> Implementation (parent)
ex:P16414 a owl:Class ;
    ex:pcfID "16414" ; ex:hierarchyID "13.2.3.4" ;
    ex:apqcSourceText "Implementing the business projects of the organization. Evaluate the impact of project management. Record and report the status of the project. Manage the project scope. Promote and sustain activities and involvement. Realign and revamp the project management strategy and approach." ;
    rdfs:label "Execute projects" ;
    skos:definition "An Act of Implementation that carries out a business project by evaluating impact, reporting status, managing scope, sustaining involvement, and realigning approach." ;
    rdfs:comment "Anchored to ex:ActOfImplementation (under cco:ont00000228): executing the project enacts the project plan. Its APQC children are process parts." ;
    skos:example "A project team runs the project to plan, tracking status and adjusting scope as needed." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11131 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16415 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P16416 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11132 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21455 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11133 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21456 ] .

# --- 13.2.3.4.1 (PCF 11131) : evaluate impact of project management -> Appraisal
ex:P11131 a owl:Class ;
    ex:pcfID "11131" ; ex:hierarchyID "13.2.3.4.1" ;
    ex:apqcSourceText "Assessing the impact of business project management on the measures and outcomes of the projects. Gauge non-financial measures, frequency of measurement, action plan, etc." ;
    rdfs:label "Evaluate impact of project management (strategy and projects) on measures and outcomes" ;
    skos:definition "An Act of Appraisal that evaluates the impact of project-management strategy and projects on the organization's measures and outcomes and produces a project management impact assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): it judges impact; output is the Descriptive ex:ProjectManagementImpactAssessment." ;
    skos:example "A PMO assesses how the chosen PM approach affected delivery outcomes." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectManagementImpactAssessment ] .

# --- 13.2.3.4.2 (PCF 16415) : report the status of project -> Information Processing
ex:P16415 a owl:Class ;
    ex:pcfID "16415" ; ex:hierarchyID "13.2.3.4.2" ;
    ex:apqcSourceText "Recording and documenting the current status and position of the project. Record and report items such as completed tasks, incomplete tasks, planned tasks, and problems faced." ;
    rdfs:label "Report the status of project" ;
    skos:definition "An Act of Information Processing that records and documents the current status of a project -- completed, incomplete, and planned tasks and problems -- and produces a project status report." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): recording/documenting status assembles a Descriptive ICE (the project status report)." ;
    skos:example "A project manager issues the weekly status report of tasks done, pending, and blocked." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectStatusReport ] .

# --- 13.2.3.4.3 (PCF 16416) : manage project scope -> Formulation
ex:P16416 a owl:Class ;
    ex:pcfID "16416" ; ex:hierarchyID "13.2.3.4.3" ;
    ex:apqcSourceText "Determining and documenting a list of specific project goals, deliverables, tasks, costs, and deadlines. Use the scope statement to explain the boundaries of the project. Assign responsibilities for team members. Set up procedures for verifying and approving the completed tasks." ;
    rdfs:label "Manage project scope" ;
    skos:definition "An Act of Formulation that determines and documents the project's goals, deliverables, tasks, costs, and deadlines, maintaining the project scope statement that bounds the project." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: determining-and-documenting the scope composes/maintains a Directive ICE (the shared ex:ProjectScopeStatement)." ;
    skos:example "A project manager keeps the scope statement current as goals and deliverables are confirmed." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectScopeStatement ] .

# --- 13.2.3.4.4 (PCF 11132) : promote and sustain activity and involvement -> Implementation
ex:P11132 a owl:Class ;
    ex:pcfID "11132" ; ex:hierarchyID "13.2.3.4.4" ;
    ex:apqcSourceText "Encouraging and sustaining the activities and involvement while executing projects. Promote the execution activities of the projects. Encourage employee involvement in project implementation." ;
    rdfs:label "Promote and sustain activity and involvement" ;
    skos:definition "An Act of Implementation that encourages and sustains the execution activities and employee involvement during project implementation." ;
    rdfs:comment "Anchored to ex:ActOfImplementation (under cco:ont00000228): enacting the engagement/promotion activities that keep the project moving; no single definitional ICE output." ;
    skos:example "A project lead runs engagement activities to keep the team involved through delivery." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.2.3.4.5 (PCF 21455) : conduct project reviews -> Appraisal
ex:P21455 a owl:Class ;
    ex:pcfID "21455" ; ex:hierarchyID "13.2.3.4.5" ;
    ex:apqcSourceText "Hold post project reviews, lessons learned, or After Action Reviews (AARs) at the end of each project to understand what could be improved during future projects." ;
    rdfs:label "Conduct Project Reviews with Program Managers and other stakeholders" ;
    skos:definition "An Act of Appraisal that conducts a post-project or after-action review with program managers and stakeholders and produces a project review record of lessons learned." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): a review judges what worked and what could improve; output is the Descriptive ex:ProjectReviewRecord. Program managers and stakeholders are definitional participants." ;
    skos:example "A team holds an after-action review and records lessons for future projects." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectReviewRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:ProgramManager ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.2.3.4.6 (PCF 11133) : realign and refresh PM strategy -> Improvement
ex:P11133 a owl:Class ;
    ex:pcfID "11133" ; ex:hierarchyID "13.2.3.4.6" ;
    ex:apqcSourceText "Reorganizing and stimulating the approach and strategy for managing business projects. Make improvements based on the project scope and on findings from Evaluate the impact of project management (strategy and projects) on measures and outcomes [11131]." ;
    rdfs:label "Realign and refresh project management strategy and approaches" ;
    skos:definition "An Act of Improvement that reorganizes and refreshes an organization's project-management strategy and approaches based on impact findings to raise their effectiveness." ;
    rdfs:comment "Anchored to ex:ActOfImprovement (under cco:ont00000228): it modifies the existing PM approach/strategy toward better performance. The project management impact assessment from 11131 is a typical driving input, noted here." ;
    skos:example "A PMO revises its delivery methodology based on the impact assessment findings." ;
    rdfs:subClassOf ex:ActOfImprovement .

# --- 13.2.3.4.7 (PCF 21456) : adjust project plan as needed -> Improvement
ex:P21456 a owl:Class ;
    ex:pcfID "21456" ; ex:hierarchyID "13.2.3.4.7" ;
    ex:apqcSourceText "Changes to project plans based upon internal and or external influences on the project.  This would include the update to the project plan file, as well as the communication to the team." ;
    rdfs:label "Adjust project plan as needed" ;
    skos:definition "An Act of Improvement that makes required changes to an existing project plan in response to internal and external influences and produces the updated project plan." ;
    rdfs:comment "Anchored to ex:ActOfImprovement (under cco:ont00000228): it modifies an existing project plan rather than composing one de novo. Input and revised output are both ex:ProjectPlan; communication to the team is a typical sub-step." ;
    skos:example "A project manager updates the plan and notifies the team after a scope change." ;
    rdfs:subClassOf ex:ActOfImprovement ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:ProjectPlan ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectPlan ] .

# --- 13.2.3.5 (PCF 16417) : review and report project performance -> Monitoring
ex:P16417 a owl:Class ;
    ex:pcfID "16417" ; ex:hierarchyID "13.2.3.5" ;
    ex:apqcSourceText "Measuring the performance of a business project against key performance indicators including the project scope, schedule, quality, cost, and risk criteria. Identify any deviations from the plan. Assess the impact of these deviations on the project, as well as on the overall program. Report results to key stakeholders." ;
    rdfs:label "Review and report project performance" ;
    skos:definition "An Act of Monitoring that measures a project's performance against its key performance indicators, identifies deviations from plan, and produces a project performance report for stakeholders." ;
    rdfs:comment "Anchored to ex:ActOfMonitoring: it tracks project performance against indicators and yields a Descriptive ICE (the project performance report). Performance indicators are a typical input; stakeholders are the reporting audience." ;
    skos:example "A project manager reports schedule and cost variances against the baseline to stakeholders." ;
    rdfs:subClassOf ex:ActOfMonitoring ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:ProjectPerformanceReport ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.2.3.6 (PCF 16418) : close projects -> Planned Act
ex:P16418 a owl:Class ;
    ex:pcfID "16418" ; ex:hierarchyID "13.2.3.6" ;
    ex:apqcSourceText "Settling each contract. Close each contract applicable to the project or project phase. Finalize all activities across all of the process groups in order to formally close the project or a project phase." ;
    rdfs:label "Close projects" ;
    skos:definition "A Planned Act that settles the project's contracts and finalizes all activities to formally close a business project or project phase." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): a bounded closing/finalization act (settling contracts, finalizing activities) with an identifiable end and no single definitional ICE output." ;
    skos:example "A project manager closes out all contracts and formally ends the project." ;
    rdfs:subClassOf cco:ont00000228 .

# ===== group 13.7 Develop, manage, and deliver analytics (PCF 20959) =====
# Group node modeled as ex:AnalyticsCapability (standing 'Develop/manage/
# deliver' function). Its bounded leaf acts are wired to the capability as
# realized-in fillers (see ex:AnalyticsCapability above). The supporting
# 13.7 ICEs (StakeholderNeedsStatement ... RemedialActionSpecification) are
# now consumed as has input/has output of these acts.

# --- 13.7.1 (PCF 21459) : identify needs from stakeholders -> Identification
ex:P21459 a owl:Class ;
    ex:pcfID "21459" ; ex:hierarchyID "13.7.1" ;
    ex:apqcSourceText "Gathering information from stakeholders prior to conducting analytics." ;
    rdfs:label "Identify needs from stakeholders" ;
    skos:definition "An Act of Identification that gathers and discerns the needs of stakeholders prior to conducting analytics and produces a stakeholder needs statement." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment, under cco:ont00000366). REJECTED cco:ont00001261 'Act of Identifying' (a communication act of asserting who/what a thing is) per §6: 'Identify' here means discerning needs, i.e. information processing. Output is a Descriptive ICE." ;
    skos:example "An analytics team interviews business stakeholders and records their information needs." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:StakeholderNeedsStatement ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.7.2 (PCF 21460) : scope analytics project -> Formulation
ex:P21460 a owl:Class ;
    ex:pcfID "21460" ; ex:hierarchyID "13.7.2" ;
    ex:apqcSourceText "Determining the size and scale of the project based upon the collected information and analytics." ;
    rdfs:label "Scope analytics project" ;
    skos:definition "An Act of Formulation that determines the size and scale of an analytics project from collected information and produces an analytics project scope statement." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the definitional output (the scope statement) is a Directive ICE prescribing size/scale, so the formulation genus agrees with the directive output (GOLDEN PRINCIPLE). Input is the stakeholder needs statement." ;
    skos:example "A lead analyst sets the boundaries and resourcing of a churn-analysis project." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:StakeholderNeedsStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AnalyticsProjectScopeStatement ] .

# --- 13.7.3 (PCF 20960) : develop and manage hypotheses -> Analysis (descriptive)
ex:P20960 a owl:Class ;
    ex:pcfID "20960" ; ex:hierarchyID "13.7.3" ;
    ex:apqcSourceText "Creating theories that explain empirical data. Use the hypotheses to guide feature selection in the process of data collection." ;
    rdfs:label "Develop and manage hypotheses" ;
    skos:definition "An Act of Information Processing that composes and frames the hypotheses explaining empirical data, producing a hypothesis used to guide feature selection during data collection." ;
    rdfs:comment "R5 de-conflation: the bounded 'develop hypotheses' act is modeled here; the 'manage' aspect is the standing analytics function carried by ex:AnalyticsCapability (this act is one of its realized-in fillers), not a separate conflated occurrent. Anchored to ex:ActOfAnalysis (under cco:ont00000366 Act of Information Processing): a hypothesis-forming act composes a descriptive account of empirical data, not a directive plan. Per the GOLDEN PRINCIPLE the Info-Processing genus agrees with the Descriptive output ex:Hypothesis (a candidate account of how reality is). REJECTED ex:ActOfFormulation (cco:ont00000511 Act of Planning): a Planning/Directive genus would contradict the descriptive output." ;
    skos:example "A data scientist frames a testable hypothesis about which features drive customer churn." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:Hypothesis ] .

# --- 13.7.4 (PCF 20961) : collect data -> Acquisition
ex:P20961 a owl:Class ;
    ex:pcfID "20961" ; ex:hierarchyID "13.7.4" ;
    ex:apqcSourceText "Gathering and harvesting structured and unstructured data from disparate sources. Clean and pre-process data. Remove duplicates. Convert to a uniform format to make records comparable." ;
    rdfs:label "Collect data" ;
    skos:definition "An Act of Acquisition that gathers and harvests structured and unstructured data from disparate sources and cleans, deduplicates, and normalizes it into an analytics dataset." ;
    rdfs:comment "Anchored to ex:ActOfAcquisition (reused from apqc-ext, under cco:ont00000228 Planned Act): the differentiating step is obtaining data the organization did not previously hold from disparate sources. DISPOSITIONED Act of Information Processing (cco:ont00000366): the clean/dedup/normalize sub-steps are information processing, but the dominant act-kind is acquisition (gather/harvest from sources); the consolidation is a method sub-step. Output is the descriptive ex:AnalyticsDataset." ;
    skos:example "An ETL pipeline pulls and normalizes transaction logs from three source systems." ;
    rdfs:subClassOf ex:ActOfAcquisition ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AnalyticsDataset ] .

# --- 13.7.5 (PCF 21461) : prepare data -> Information Processing
ex:P21461 a owl:Class ;
    ex:pcfID "21461" ; ex:hierarchyID "13.7.5" ;
    ex:apqcSourceText "Creation and validation of data in order to initiate the process of analysis." ;
    rdfs:label "Prepare data" ;
    skos:definition "An Act of Information Processing that creates and validates an analytics dataset so as to produce a prepared dataset fit to initiate analysis." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): validation/preparation manipulates the collected dataset into an analysis-ready form. Genus is deliberately DISTINCT from sibling 20961 'Collect data' (ex:ActOfAcquisition): collection obtains the data; preparation validates/transforms data already held. Input is ex:AnalyticsDataset; output is the distinct ex:PreparedDataset." ;
    skos:example "A data engineer validates and feature-engineers the collected dataset before modeling." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:AnalyticsDataset ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:PreparedDataset ] .

# --- 13.7.6 (PCF 20962) : analyze data -> Analysis
ex:P20962 a owl:Class ;
    ex:pcfID "20962" ; ex:hierarchyID "13.7.6" ;
    ex:apqcSourceText "Conducting data analysis. Choose statistical algorithms that best reveal patterns and trends in the data. Compare with hypotheses and time series forecasts. Determine error rates and significant outliers." ;
    rdfs:label "Analyze data" ;
    skos:definition "An Act of Analysis that applies statistical algorithms to a prepared dataset to reveal patterns, trends, error rates, and outliers and produces a data analysis result." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (under cco:ont00000366): the canonical analysis act of the group. Input is the prepared dataset (definitional); output is the descriptive ex:DataAnalysisResult. Mirrors the Appendix-A AnalyzeCompetitors pattern." ;
    skos:example "A data scientist runs regression and clustering over the prepared data to surface churn drivers." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PreparedDataset ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DataAnalysisResult ] .

# --- 13.7.7 (PCF 21462) : create data models -> Formulation
ex:P21462 a owl:Class ;
    ex:pcfID "21462" ; ex:hierarchyID "13.7.7" ;
    ex:apqcSourceText "Creation of conceptual and physical data models as an outline for data structure and storage." ;
    rdfs:label "Create data models" ;
    skos:definition "An Act of Formulation that composes conceptual and physical data models prescribing how data is to be structured and stored, producing a data model." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the output ex:DataModel is Directive (it prescribes required data structure/storage), so the formulation genus agrees with the directive output (GOLDEN PRINCIPLE). (If on review ex:DataModel were read as a descriptive representation, it would be re-anchored to cco:ont00000853 and this genus switched to analysis to preserve agreement.)" ;
    skos:example "A data architect produces the conceptual and physical schema for the analytics store." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DataModel ] .

# --- 13.7.8 (PCF 21463) : review data models with stakeholders -> Appraisal
ex:P21463 a owl:Class ;
    ex:pcfID "21463" ; ex:hierarchyID "13.7.8" ;
    ex:apqcSourceText "Confirm data models represent the hypothesis supporting the original research question" ;
    rdfs:label "Review data models with stakeholders" ;
    skos:definition "An Act of Appraisal that reviews data models with stakeholders against the original research question and hypothesis and produces a data model review record." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): 'review/confirm against the hypothesis' judges the models, distinct from the formulation genus of its create/refine siblings 21462/21464. Input is the data model; output is the descriptive ex:DataModelReviewRecord." ;
    skos:example "The team confirms with stakeholders that the model captures the hypothesized relationships." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DataModel ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DataModelReviewRecord ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.7.9 (PCF 21464) : refine data models -> Formulation
ex:P21464 a owl:Class ;
    ex:pcfID "21464" ; ex:hierarchyID "13.7.9" ;
    ex:apqcSourceText "Make required changes to data model based upon review with stakeholders." ;
    rdfs:label "Refine data models" ;
    skos:definition "An Act of Formulation that makes the required changes to a data model based on the stakeholder review and produces the revised data model." ;
    rdfs:comment "Anchored to ex:ActOfFormulation, aligned with sibling 21462 'Create data models' per sibling consistency (the create->review->refine triad: 21462 formulation, 21463 appraisal, 21464 formulation). Input is the data model review record; output is the revised Directive ex:DataModel." ;
    skos:example "The architect updates the schema to address the review findings." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DataModelReviewRecord ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:DataModel ] .

# --- 13.7.10 (PCF 20963) : report on analysis -> Information Processing
ex:P20963 a owl:Class ;
    ex:pcfID "20963" ; ex:hierarchyID "13.7.10" ;
    ex:apqcSourceText "Summarizing and documenting the results of data analysis. Create graphs and visualizations to illustrate numerical findings to make them more accessible to readers." ;
    rdfs:label "Report on analysis" ;
    skos:definition "An Act of Information Processing that summarizes and documents the results of data analysis, including graphs and visualizations, and produces an analysis report." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): assembling and documenting analysis results into a Descriptive ICE. DISPOSITIONED cco:ont00000402 'Act of Communication': the dominant act here is composing/documenting the report (information processing); dissemination to readers is a downstream/typical facet. Input is the data analysis result; output is the descriptive ex:AnalysisReport." ;
    skos:example "An analyst compiles the findings into a visual report for the business sponsor." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:DataAnalysisResult ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:AnalysisReport ] .

# --- 13.7.11 (PCF 20964) : identify remedial actions -> Formulation (directive)
ex:P20964 a owl:Class ;
    ex:pcfID "20964" ; ex:hierarchyID "13.7.11" ;
    ex:apqcSourceText "Determining the steps that need to be taken to correct the shortcomings." ;
    rdfs:label "Identify remedial actions" ;
    skos:definition "An Act of Formulation that determines the steps required to correct identified shortcomings and produces a remedial action specification prescribing them." ;
    rdfs:comment "Anchored to ex:ActOfFormulation, NOT ex:ActOfIdentification, despite the 'Identify' label: the source 'Determining the STEPS that need to be taken to correct the shortcomings' composes a prescription of corrective steps, and its output ex:RemedialActionSpecification is Directive. Anchoring under the descriptive ex:ActOfIdentification would pair a descriptive genus with a Directive output and violate the GOLDEN PRINCIPLE; the formulation genus agrees with the directive output." ;
    skos:example "A team specifies the corrective steps to address the data-quality gaps the analysis revealed." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:RemedialActionSpecification ] .

# ===== group 13.8 Manage environmental health and safety (PCF 11179) =====
# Group node modeled as ex:EHSManagementCapability (standing 'Manage'
# function); its three bounded group children (P11180/P11181/P21587) are
# wired to the capability as realized-in fillers.

# --- 13.8.1 (PCF 11180) : determine EHS impacts -> Analysis (parent)
ex:P11180 a owl:Class ;
    ex:pcfID "11180" ; ex:hierarchyID "13.8.1" ;
    ex:apqcSourceText "Determining the impact of EHS offering--and the procedures it employs to process them--on the environment at large, as well as the health and safety of employees. Evaluate the environmental impact of the organization's products, services, and operations. Conduct health, safety, and environmental audits." ;
    rdfs:label "Determine environmental health and safety impacts" ;
    skos:definition "An Act of Analysis that examines audit and lifecycle data to determine the environmental, health, and safety impacts of an organization's offerings and operations." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (under cco:ont00000366 Act of Information Processing): 'Determine' here is discernment from audit/lifecycle data, NOT the false-friend cco:ont00001261 'Act of Identifying' (a communication act). Aggregating process; its APQC children are process parts." ;
    skos:example "An EHS team determines the lifecycle environmental and safety impacts of a product line from audit findings." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11186 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11187 ] .

# --- 13.8.1.1 (PCF 11186) : evaluate environmental impact -> Analysis
ex:P11186 a owl:Class ;
    ex:pcfID "11186" ; ex:hierarchyID "13.8.1.1" ;
    ex:apqcSourceText "Evaluating the impact of offerings and the auxiliary operations required to process them on the immediate ecosystem and the environment at large. Study the lifecycle of the products/services offered by the organization. Estimate any affect on the environment through metrics such as a calculation of carbon footprint." ;
    rdfs:label "Evaluate environmental impact of products, services, and operations" ;
    skos:definition "An Act of Analysis that studies the lifecycle of an organization's products, services, and operations and produces an environmental impact assessment." ;
    rdfs:comment "Anchored to ex:ActOfAnalysis (under cco:ont00000366): lifecycle study and footprint estimation manipulate input data into a descriptive understanding. Output is the descriptive ex:EnvironmentalImpactAssessment (a descriptive output implies analysis/appraisal, not planning, per the GOLDEN PRINCIPLE)." ;
    skos:example "An analyst computes the carbon footprint across a product's lifecycle." ;
    rdfs:subClassOf ex:ActOfAnalysis ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EnvironmentalImpactAssessment ] .

# --- 13.8.1.2 (PCF 11187) : conduct EHS audits -> Appraisal
ex:P11187 a owl:Class ;
    ex:pcfID "11187" ; ex:hierarchyID "13.8.1.2" ;
    ex:apqcSourceText "Conducting an inspection to verify that the organization adequately complies with the environmental, health, and safety standards. Audit procedures and records regarding responsibility for the environment, health, and safety." ;
    rdfs:label "Conduct health and safety and environmental audits" ;
    skos:definition "An Act of Appraisal that inspects and verifies an organization's compliance with environmental, health, and safety standards and produces an EHS audit report." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): an audit is an appraisal/verification act judging conformance, producing a descriptive report. NOT Act of Planning (no plan composed) and NOT Act of Communication (no ICE-transfer is the essence)." ;
    skos:example "An EHS auditor inspects a facility and issues a compliance audit report." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EHSAuditReport ] .

# --- 13.8.2 (PCF 11181) : develop EHS program -> Formulation (parent)
ex:P11181 a owl:Class ;
    ex:pcfID "11181" ; ex:hierarchyID "13.8.2" ;
    ex:apqcSourceText "Identify the requirements for regulation and shareholders. Assess future risks and opportunities. Develop a policy for the EHS program. Record and manage EHS program events." ;
    rdfs:label "Develop EHS program" ;
    skos:definition "An Act of Formulation that composes an organization's environmental, health, and safety program by establishing its requirements, risk assessment, and policy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (under cco:ont00000511 Act of Planning): 'Develop ... program' is a bounded composing act that passes R5 (it has a natural end), so -- unlike the standing group node 11179 -- it is a process class, not a capability. Its APQC children are process parts." ;
    skos:example "An EHS team develops the program: requirements, risk assessment, and a published EHS policy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11188 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11189 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11190 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11191 ] .

# --- 13.8.2.1 (PCF 11188) : identify regulatory/stakeholder requirements -> Identification
ex:P11188 a owl:Class ;
    ex:pcfID "11188" ; ex:hierarchyID "13.8.2.1" ;
    ex:apqcSourceText "Determining any protocols or standards to comply with, set by regulatory agencies or the organization's stakeholders. Closely examine all standards and matters of compliance relating to the environment, health, and safety." ;
    rdfs:label "Identify regulatory and stakeholder requirements" ;
    skos:definition "An Act of Identification that discerns the regulatory and stakeholder protocols and standards an organization must comply with for environment, health, and safety and registers them in an EHS requirement register." ;
    rdfs:comment "Anchored to ex:ActOfIdentification (discernment, under cco:ont00000366). REJECTED cco:ont00001261 'Act of Identifying' (the communication sense of asserting who/what a thing is) per §6: the act discerns externally-set requirements. Per the GOLDEN PRINCIPLE (Info-Processing -> Descriptive), the definitional has-output is the Descriptive ex:EHSRequirementRegister (a register of the discerned requirements). The externally-authored Directive ex:EHSRequirementSpecification is a has-INPUT this act captures, NOT something it composes -- composing it would be a Formulation act, contradicting the discernment genus. This restores genus<->output agreement." ;
    skos:example "A compliance officer compiles the EHS regulations and stakeholder standards the firm must meet." ;
    rdfs:subClassOf ex:ActOfIdentification ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EHSRequirementSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EHSRequirementRegister ] .

# --- 13.8.2.2 (PCF 11189) : assess future risks and opportunities -> Appraisal
ex:P11189 a owl:Class ;
    ex:pcfID "11189" ; ex:hierarchyID "13.8.2.2" ;
    ex:apqcSourceText "Evaluating any risks and opportunities that might affect the environmental, health, and safety of products/services. Leverage techniques such as cost-benefit analysis, trend extrapolation, systems analysis, social surveys, historical surveys, historical analogy, Delphi, conferences, workshops, briefings, hearings, advisory committees, moot courts, artistic judgment, on-site field investigation, scaling techniques, and scenario creation." ;
    rdfs:label "Assess future risks and opportunities" ;
    skos:definition "An Act of Appraisal that evaluates the future risks and opportunities affecting the environmental, health, and safety of products and services and produces an EHS risk and opportunity assessment." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): 'Assess' yields a descriptive judgement; output is the descriptive ex:EHSRiskAndOpportunityAssessment, agreeing with the appraisal genus (GOLDEN PRINCIPLE)." ;
    skos:example "An EHS planner runs scenario and cost-benefit analysis to assess emerging safety risks." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EHSRiskAndOpportunityAssessment ] .

# --- 13.8.2.3 (PCF 11190) : create EHS policy -> Formulation
ex:P11190 a owl:Class ;
    ex:pcfID "11190" ; ex:hierarchyID "13.8.2.3" ;
    ex:apqcSourceText "Creating a plan for managing the environmental, health, and safety impact of products/services. Establish minimum requirements for the organization regarding the environment at large and the health and safety of employees. Develop policies, written procedures, and supporting tools to dictate how the organization will meet policy requirements." ;
    rdfs:label "Create EHS policy" ;
    skos:definition "An Act of Formulation that composes an EHS policy prescribing the minimum requirements, procedures, and tools by which an organization will manage its environmental, health, and safety impact." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (under cco:ont00000511): a directive output (the policy) requires a planning/formulation genus, NOT analysis or appraisal (GOLDEN PRINCIPLE). Output is the Directive ex:EHSPolicy." ;
    skos:example "An EHS team issues the corporate environmental, health, and safety policy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EHSPolicy ] .

# --- 13.8.2.4 (PCF 11191) : record and manage EHS events -> Information Processing
ex:P11191 a owl:Class ;
    ex:pcfID "11191" ; ex:hierarchyID "13.8.2.4" ;
    ex:apqcSourceText "Recording and managing all events and activities associated with complying with environmental, health and safety standards. Create event calendars. Assign funds. Educate employees. Conduct events." ;
    rdfs:label "Record and manage EHS events" ;
    skos:definition "An Act of Information Processing that records the events and activities associated with environmental, health, and safety compliance and produces an EHS event record." ;
    rdfs:comment "Compound-verb de-conflation (Phase 1): the bounded 'Record' act (information processing producing the descriptive ex:EHSEventRecord) is modeled here; the 'manage' standing-function aspect is carried by ex:EHSManagementCapability, not by this occurrent. Anchored to cco:ont00000366 (Act of Information Processing); the descriptive output implies a recording act, not planning." ;
    skos:example "An EHS coordinator logs compliance events and activities into the EHS register." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EHSEventRecord ] .

# --- 13.8.3 (PCF 21587) : monitor and manage EHS program -> Planned Act (parent)
ex:P21587 a owl:Class ;
    ex:pcfID "21587" ; ex:hierarchyID "13.8.3" ;
    ex:apqcSourceText "Managing the performance, costs and benefits of EHS. Measure and report the performance of EHS. Implement plans for emergency response and pollution prevention. Train and educate employees. Provide EHS support." ;
    rdfs:label "Monitor and manage EHS program" ;
    skos:definition "A Planned Act that constitutes an organization's bounded EHS management and oversight cycle -- measuring and reporting EHS performance, appraising costs and benefits, implementing emergency-response and pollution-prevention programs, training employees, and providing support." ;
    rdfs:comment "RE-ANCHORED from ex:ActOfMonitoring to cco:ont00000228 (Planned Act): Act of Monitoring is too narrow a genus for this heterogeneous group aggregate, whose children are mostly NOT monitoring -- appraisal (13.8.3.1 ex:P11193 cost-benefit), implementation (ex:P11196/ex:P11197 enacting directive programs), training (ex:P11182), and generic support (ex:P11195); only ex:P11194 'Measure and report' is genuinely monitoring/measuring. Per the documented 13.6 precedent (ex:P21584: 'Act of Measuring is too narrow a genus for a group aggregate whose children also include ... appraisal ... the broad Planned Act covers the heterogeneous cycle'), the 13.8.3 aggregate is anchored at the broad Planned Act. R5 DECISION retained: this is the repeatable bounded oversight CYCLE that realizes the standing ex:EHSManagementCapability (which carries an explicit obo:BFO_0000054 realized-in link to this act), not the capability itself. Any monitoring facet lives only on the genuinely-monitoring child ex:P11194. Its APQC children are process parts." ;
    skos:example "An EHS office runs the quarterly cycle of measuring, reporting, training, and supporting the EHS program." ;
    rdfs:subClassOf cco:ont00000228 ,   # Planned Act (broad genus for the heterogeneous cycle)
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11193 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11194 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11196 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11197 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11182 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P11195 ] .

# --- 13.8.3.1 (PCF 11193) : manage EHS costs and benefits -> Appraisal
ex:P11193 a owl:Class ;
    ex:pcfID "11193" ; ex:hierarchyID "13.8.3.1" ;
    ex:apqcSourceText "Administering the costs and benefits of EHS management program. Evaluate program costs to ensure that the benefits of the program always outweigh its costs." ;
    rdfs:label "Manage EHS costs and benefits" ;
    skos:definition "An Act of Appraisal that evaluates the costs and benefits of an EHS program and produces an EHS cost-benefit assessment of whether benefits outweigh costs." ;
    rdfs:comment "Anchored to cco:ont00000636 (Act of Appraisal): cost-benefit evaluation is an appraisal yielding a descriptive judgement. Output is the descriptive ex:EHSCostBenefitAssessment." ;
    skos:example "A finance-EHS review judges whether the safety program's benefits exceed its costs." ;
    rdfs:subClassOf cco:ont00000636 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EHSCostBenefitAssessment ] .

# --- 13.8.3.2 (PCF 11194) : measure and report EHS performance -> Measuring
ex:P11194 a owl:Class ;
    ex:pcfID "11194" ; ex:hierarchyID "13.8.3.2" ;
    ex:apqcSourceText "Using performance techniques and indicators. Utilize number of audits or inspections performed, safety committee meetings, the number and types of findings and observations, timely preventive maintenance tasks performed, etc." ;
    rdfs:label "Measure and report EHS performance" ;
    skos:definition "An Act of Measuring that uses defined performance indicators to measure environmental, health, and safety performance and produces an EHS performance report." ;
    rdfs:comment "Anchored to cco:ont00000345 (Act of Measuring, VERIFIED §6; parent cco:ont00000228) with explicit cco:ont00000228 co-parent so Gate C sees the Act anchor; 'Measure and report' against indicators determines performance relative to a standard. Input is the shared ex:PerformanceIndicatorSpecification (whose comment lists 13.8.3.2 as a consumer); output is the descriptive ex:EHSPerformanceReport. NOT planning." ;
    skos:example "An EHS analyst computes audit and incident metrics and issues the EHS performance report." ;
    rdfs:subClassOf cco:ont00000345 ,   # Act of Measuring (a CCO Planned Act)
        cco:ont00000228 ,   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PerformanceIndicatorSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:EHSPerformanceReport ] .

# --- 13.8.3.3 (PCF 11196) : implement emergency response program -> Implementation
ex:P11196 a owl:Class ;
    ex:pcfID "11196" ; ex:hierarchyID "13.8.3.3" ;
    ex:apqcSourceText "Implementing a program for organizing, coordinating, and directing available resources to respond to the event. Conduct a risk assessment to identify potential emergency scenarios in order to create a program that ensures that resources are on hand--or quickly available--in case of emergencies." ;
    rdfs:label "Implement emergency response program" ;
    skos:definition "An Act of Implementation that puts an emergency response program into operation so that resources are organized, coordinated, and available to respond to emergency events." ;
    rdfs:comment "Anchored to ex:ActOfImplementation (under cco:ont00000228 Planned Act): 'Implement a program' enacts a Directive ICE. The directive ex:EmergencyResponseProgram is the definitional has-input it operationalizes; no new ICE is produced." ;
    skos:example "An EHS team stands up and exercises the emergency response program across sites." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:EmergencyResponseProgram ] .

# --- 13.8.3.4 (PCF 11197) : implement pollution prevention program -> Implementation
ex:P11197 a owl:Class ;
    ex:pcfID "11197" ; ex:hierarchyID "13.8.3.4" ;
    ex:apqcSourceText "Implementing a program that reduces or eliminates the creation of pollutants through increased efficiency in the use of raw materials, energy, water, or other resources. Implement a program to inspect facilities that store, manufacture, or use hazardous, toxic, or polluting materials." ;
    rdfs:label "Implement pollution prevention program" ;
    skos:definition "An Act of Implementation that puts a pollution prevention program into operation to reduce or eliminate the creation of pollutants through increased resource efficiency." ;
    rdfs:comment "Anchored to ex:ActOfImplementation (under cco:ont00000228), mirroring sibling ex:P11196: both enact a Directive program. The directive ex:PollutionPreventionProgram is the definitional has-input." ;
    skos:example "An EHS team rolls out the pollution prevention program and facility inspection regime." ;
    rdfs:subClassOf ex:ActOfImplementation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:PollutionPreventionProgram ] .

# --- 13.8.3.5 (PCF 11182) : train and educate functional employees -> Training
ex:P11182 a owl:Class ;
    ex:pcfID "11182" ; ex:hierarchyID "13.8.3.5" ;
    ex:apqcSourceText "Conducting programs such as on-the-job training sessions, group training workshops, and online training." ;
    rdfs:label "Train and educate functional employees" ;
    skos:definition "An Act of Training in which environmental, health, and safety knowledge and skills are imparted to the organization's functional employees through on-the-job, workshop, and online training programs." ;
    rdfs:comment "Anchored to cco:ont00000234 (Act of Training, VERIFIED §6; parent cco:ont00000228) with explicit cco:ont00000228 co-parent so Gate C sees the Act anchor. NOT Act of Communication or Act of Planning (false-friend caution): the act imparts competence. The same training genus is used corpus-wide for training rows (13.1.4.1, 13.3.4.6.3, 13.9.2.1). The definitional participant is ex:FunctionalEmployee (the training RECIPIENT, bearer of ex:TraineeRole), mirroring the ex:ProcessOwner pattern used by sibling-analog ex:P16393 'Provide process training'. REJECTED ex:Stakeholder here: that is an interested/affected PARTY, not a training recipient, so it mis-typed the definitional participant." ;
    skos:example "An EHS trainer runs safety workshops for plant operators." ;
    rdfs:subClassOf cco:ont00000234 ,   # Act of Training (a CCO Planned Act)
        cco:ont00000228 ,   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:FunctionalEmployee ] .

# --- 13.8.3.6 (PCF 11195) : provide EHS support -> Planned Act
ex:P11195 a owl:Class ;
    ex:pcfID "11195" ; ex:hierarchyID "13.8.3.6" ;
    ex:apqcSourceText "Supporting employees in light of the organization's environmental, health, and safety policies and standards. Provide medical insurance, maternity leave, environmental education, training over safety, etc." ;
    rdfs:label "Provide EHS support" ;
    skos:definition "A Planned Act that provides employees with support services -- such as medical insurance, leave, environmental education, and safety training -- in light of an organization's environmental, health, and safety policies and standards." ;
    rdfs:comment "Anchored to cco:ont00000228 (Planned Act): a service/provision act bundling heterogeneous deliverables (insurance, leave, education, training). Phase-1 de-conflation: the bundled deliverables are method content, not separate process classes or a single definitional ICE output; no shared service genus fits, so the generic Planned Act is used." ;
    skos:example "An EHS-HR function provides safety training, insurance, and leave benefits to staff." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# ===== group 13.9 Manage sustainability (PCF 21588) ==============
# Group node modeled as ex:SustainabilityManagementCapability (standing
# 'Manage' function); its two bounded process children (P21589 Develop
# sustainability capability, P21598 Manage sustainability capability) are
# wired to the capability as realized-in fillers. The 7 Sustainability
# ICEs are consumed here as has input/has output.

# --- 13.9.1 (PCF 21589) : develop sustainability capability -> Formulation (parent)
ex:P21589 a owl:Class ;
    ex:pcfID "21589" ; ex:hierarchyID "13.9.1" ;
    ex:apqcSourceText "Developing sustainability (ESG) capabilities for the organization. Understand and communicate legal, regulatory, and social/environmental requirements. Establish policies, objectives, guidelines and approaches for ESG efforts and reporting." ;
    rdfs:label "Develop sustainability capability" ;
    skos:definition "An Act of Formulation that develops an organization's sustainability (ESG) capability by establishing its requirements, goals, policies, measures, and plans." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (under cco:ont00000511 Act of Planning): its definitional children produce Directive ICEs (requirement spec, goal spec, policy, measure spec, plan), so this aggregating planning parent is a bounded Formulation act, not a standing capability. (R5: 'Develop ... capability' here is the bounded composing effort; the standing capacity is ex:SustainabilityManagementCapability, which is realized in this act.) Its APQC children are process parts." ;
    skos:example "An ESG office stands up the sustainability program: requirements, goals, policies, measures, and plans." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21590 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21594 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21595 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21596 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21597 ] .

# --- 13.9.1.1 (PCF 21590) : identify sustainability requirements -> Formulation (parent)
ex:P21590 a owl:Class ;
    ex:pcfID "21590" ; ex:hierarchyID "13.9.1.1" ;
    ex:apqcSourceText "Identifying, documenting, and communicating sustainability requirements. Closely examine all standards and matters of compliance relating to ESG. Determine protocols or standards to comply with, set by regulatory agencies or the organizations stakeholders." ;
    rdfs:label "Identify sustainability requirements" ;
    skos:definition "An Act of Formulation that identifies, documents, and composes the disclosure, governance, functional, and performance requirements for sustainability, producing a sustainability requirement specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation, NOT ex:ActOfIdentification despite the 'Identify' label: the output ex:SustainabilityRequirementSpecification is a DIRECTIVE ICE, and per the GOLDEN PRINCIPLE the directive output forces a formulation genus, not identification. The 'document and communicate' clauses confirm composition of a prescriptive artifact. Its APQC children (the three Define-requirement tasks) are process parts." ;
    skos:example "An ESG analyst documents the disclosure, governance, and performance requirements the firm must satisfy." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityRequirementSpecification ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21591 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21592 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21593 ] .

# --- 13.9.1.1.1 (PCF 21591) : define disclosure requirements -> Formulation
ex:P21591 a owl:Class ;
    ex:pcfID "21591" ; ex:hierarchyID "13.9.1.1.1" ;
    ex:apqcSourceText "Defining and communicating sustainability disclosure requirements. Clarify and align disclosure requirements to other organizational reporting requirements and needs. Integrate preparation and reporting activities." ;
    rdfs:label "Define sustainability disclosure requirements" ;
    skos:definition "An Act of Formulation that defines and aligns the sustainability disclosure requirements an organization must satisfy, producing a sustainability requirement specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: the output is a Directive ICE (the disclosure-requirement facet of the sustainability requirement specification)." ;
    skos:example "An ESG team specifies the firm's sustainability disclosure obligations and aligns them to financial reporting." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityRequirementSpecification ] .

# --- 13.9.1.1.2 (PCF 21592) : define governance requirements -> Formulation
ex:P21592 a owl:Class ;
    ex:pcfID "21592" ; ex:hierarchyID "13.9.1.1.2" ;
    ex:apqcSourceText "Defining governance requirements for sustainability. Include structure, roles, alignment to organization models, processes and standards to be applied." ;
    rdfs:label "Define sustainability governance requirements" ;
    skos:definition "An Act of Formulation that defines the governance requirements for sustainability -- structure, roles, and standards -- producing a sustainability requirement specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: Directive output (the governance-requirement facet of the sustainability requirement specification)." ;
    skos:example "An ESG lead specifies the governance structure and roles for the sustainability program." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityRequirementSpecification ] .

# --- 13.9.1.1.3 (PCF 21593) : define functional/performance requirements -> Formulation
ex:P21593 a owl:Class ;
    ex:pcfID "21593" ; ex:hierarchyID "13.9.1.1.3" ;
    ex:apqcSourceText "Defining functional and performance requirements for sustainability. Align with ESG strategies, goals, and the implementation of sustainability efforts across the organization, provide a roadmap and visibility to shared and collective requirements." ;
    rdfs:label "Define sustainability functional and performance requirements" ;
    skos:definition "An Act of Formulation that defines the functional and performance requirements for sustainability, aligned to ESG strategies and goals, producing a sustainability requirement specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: Directive output (the functional/performance-requirement facet of the sustainability requirement specification)." ;
    skos:example "An ESG analyst specifies the functional and performance requirements and roadmap for sustainability efforts." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityRequirementSpecification ] .

# --- 13.9.1.2 (PCF 21594) : establish goals/objectives -> Formulation
ex:P21594 a owl:Class ;
    ex:pcfID "21594" ; ex:hierarchyID "13.9.1.2" ;
    ex:apqcSourceText "Establishing organizational sustainability goals/objectives. Gather, align, and promote organization-wide sustainability goals that collectively address the overall sustainability requirements. Ensure the goals are measurable and have qualitative and quantitative targets." ;
    rdfs:label "Establish sustainability goals/objectives" ;
    skos:definition "An Act of Formulation that composes the organization's measurable sustainability goals and targets, producing a sustainability goal specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: 'Establish ... goals' composes a Directive artifact. Output is the Directive ex:SustainabilityGoalSpecification." ;
    skos:example "An ESG committee sets organization-wide, measurable sustainability targets." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityGoalSpecification ] .

# --- 13.9.1.3 (PCF 21595) : create policies -> Formulation
ex:P21595 a owl:Class ;
    ex:pcfID "21595" ; ex:hierarchyID "13.9.1.3" ;
    ex:apqcSourceText "Establishing, documenting, and communicating sustainability policies. Develop policies, written procedures, and supporting tools to dictate how the organization will meet policy requirements." ;
    rdfs:label "Create sustainability policies" ;
    skos:definition "An Act of Formulation that composes the written sustainability policies and procedures dictating how an organization will meet its sustainability requirements, producing a sustainability policy." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: creating policies/written procedures composes a Directive artifact. Output is the Directive ex:SustainabilityPolicy." ;
    skos:example "An ESG office issues the corporate sustainability policy and supporting procedures." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityPolicy ] .

# --- 13.9.1.4 (PCF 21596) : define measures -> Formulation
ex:P21596 a owl:Class ;
    ex:pcfID "21596" ; ex:hierarchyID "13.9.1.4" ;
    ex:apqcSourceText "Defining sustainability measures. Provide organization-wide measures, to include data collection strategies, calculations, analytics, and reporting formats." ;
    rdfs:label "Define sustainability measures" ;
    skos:definition "An Act of Formulation that composes organization-wide sustainability measures -- including data-collection strategies, calculations, and reporting formats -- producing a sustainability measure specification." ;
    rdfs:comment "Anchored to ex:ActOfFormulation: this is the act of SPECIFYING measures (a Directive measure spec), NOT the act of measuring. FALSE-FRIEND caution observed: 'measures' could lure cco:ont00000345 'Act of Measuring', which would be wrong here (the act produces a measure SPEC, not measurement data). Act of Measuring is reserved for 21602, which actually collects data. Output is the Directive ex:SustainabilityMeasureSpecification." ;
    skos:example "An ESG analyst defines the organization-wide sustainability metrics and their data-collection and reporting formats." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityMeasureSpecification ] .

# --- 13.9.1.5 (PCF 21597) : create plan(s) -> Formulation
ex:P21597 a owl:Class ;
    ex:pcfID "21597" ; ex:hierarchyID "13.9.1.5" ;
    ex:apqcSourceText "Creating sustainability plans. Develop and socialize sustainability plans for the organization, functional units, and support services. Ensure alignment to sustainability requirements, goals, and governance." ;
    rdfs:label "Create sustainability plan(s)" ;
    skos:definition "An Act of Formulation that composes sustainability plans for the organization, its functional units, and support services, aligned to sustainability requirements, goals, and governance, producing a sustainability plan." ;
    rdfs:comment "Anchored to ex:ActOfFormulation (under cco:ont00000511 Act of Planning): plan composition is planning/formulation. Output is the Directive ex:SustainabilityPlan." ;
    skos:example "An ESG team develops the enterprise and functional-unit sustainability plans." ;
    rdfs:subClassOf ex:ActOfFormulation ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityPlan ] .

# --- 13.9.2 (PCF 21598) : manage sustainability capability -> Planned Act (parent)
ex:P21598 a owl:Class ;
    ex:pcfID "21598" ; ex:hierarchyID "13.9.2" ;
    ex:apqcSourceText "Managing sustainability across the organization. Provide training, support, reporting, and oversight to the distributed sustainability efforts across functional units and support services." ;
    rdfs:label "Manage sustainability capability" ;
    skos:definition "A Planned Act that administers distributed sustainability efforts across an organization by providing training, support, and reporting and oversight to functional units and support services." ;
    rdfs:comment "R5 DECISION (explicit, sibling-consistent): modeled as a bounded Planned Act mirroring 13.1.4 ex:P16392 'Manage process performance' -- a bounded administration cycle aggregating training/support/reporting children with no single definitional ICE output. Although 'Manage' carries a standing-function signal, the standing capacity is ex:SustainabilityManagementCapability (which is realized in this act); this Planned Act is its repeatable bounded realization. Its APQC children are process parts." ;
    skos:example "Each period an ESG office trains, supports, and reports on the distributed sustainability efforts." ;
    rdfs:subClassOf cco:ont00000228 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21599 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21600 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21601 ] .

# --- 13.9.2.1 (PCF 21599) : provide sustainability training -> Training
ex:P21599 a owl:Class ;
    ex:pcfID "21599" ; ex:hierarchyID "13.9.2.1" ;
    ex:apqcSourceText "Providing sustainability training and awareness. Plan, prepare, and oversee delivery of sustainability education and enablement activities." ;
    rdfs:label "Provide sustainability training" ;
    skos:definition "An Act of Training in which sustainability education and enablement are imparted to an organization's personnel." ;
    rdfs:comment "Anchored to cco:ont00000234 (Act of Training, VERIFIED §6; parent cco:ont00000228) with explicit cco:ont00000228 co-parent so Gate C sees the Act anchor -- matching the sibling-analog ex:P16393 'Provide process training'. Sustainability trainees/manager are definitional participants." ;
    skos:example "An ESG trainer runs sustainability enablement workshops for functional teams." ;
    rdfs:subClassOf cco:ont00000234 ,   # Act of Training (a CCO Planned Act)
        cco:ont00000228 ,   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000057 ; owl:someValuesFrom ex:Stakeholder ] .

# --- 13.9.2.2 (PCF 21600) : provide sustainability support -> Implementation
ex:P21600 a owl:Class ;
    ex:pcfID "21600" ; ex:hierarchyID "13.9.2.2" ;
    ex:apqcSourceText "Providing support for sustainability activities. Augment functional units and support teams with coaching, mentoring, and SME capacity to perform sustainability projects and activities." ;
    rdfs:label "Provide sustainability support" ;
    skos:definition "An Act of Implementation that augments functional units and support teams with coaching, mentoring, and subject-matter-expert capacity to carry out sustainability projects and activities." ;
    rdfs:comment "Anchored to ex:ActOfImplementation (under cco:ont00000228), mirroring the sibling-analog ex:P16394 'Support process execution': coaching/SME support enacts rather than producing an ICE; no definitional has-output." ;
    skos:example "An ESG center of excellence embeds SMEs to help business units run sustainability initiatives." ;
    rdfs:subClassOf ex:ActOfImplementation .

# --- 13.9.2.3 (PCF 21601) : perform sustainability reporting -> Information Processing (parent)
ex:P21601 a owl:Class ;
    ex:pcfID "21601" ; ex:hierarchyID "13.9.2.3" ;
    ex:apqcSourceText "Conducting and supporting sustainability reporting. Collect, analyze, and report sustainability performance to requirements. Align reporting across functional units and support teams." ;
    rdfs:label "Perform sustainability reporting" ;
    skos:definition "An Act of Information Processing that collects, analyzes, and reports sustainability performance against requirements and produces a sustainability statement." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing): an aggregating reporting parent over measuring (21602) and statement preparation (21603). Output is the descriptive ex:SustainabilityStatement. Its APQC children are process parts." ;
    skos:example "An ESG reporting team consolidates measured sustainability data into the annual statement." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityStatement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21602 ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001777 ; owl:someValuesFrom ex:P21603 ] .

# --- 13.9.2.3.1 (PCF 21602) : measure sustainability performance -> Appraisal
ex:P21602 a owl:Class ;
    ex:pcfID "21602" ; ex:hierarchyID "13.9.2.3.1" ;
    ex:apqcSourceText "Measuring sustainability performance. Setup, collect, and validate sustainability data. Conduct audits and inspections. Evaluate results to requirements and targets. Identify and track resolution of gaps and variances." ;
    rdfs:label "Measure sustainability performance" ;
    skos:definition "An Act of Appraisal that collects and validates sustainability data, conducts audits and inspections, and evaluates sustainability performance against requirements and targets -- tracking gaps and variances -- producing a sustainability performance assessment." ;
    rdfs:comment "RE-ANCHORED from cco:ont00000345 (Act of Measuring) to cco:ont00000636 (Act of Appraisal, VERIFIED in vendored CCO: 'An Act of Measuring that involves evaluating, assessing, ... or judging the ... condition, or quality of something'; rdfs:subClassOf cco:ont00000345 -> ... -> cco:ont00000228 Planned Act). The source is broader than pure quantification: 'Conduct audits and inspections. Evaluate results to requirements and targets. Identify and track resolution of gaps and variances' are canonical appraisal signals (assessment of condition/value against a standard) and form the bulk of the description, not an aside. Both Measuring and Appraisal yield Descriptive ICE outputs, so the GOLDEN PRINCIPLE does not disambiguate; the appraisal genus is chosen on the de-conflated verb. REJECTED the narrower cco:ont00000345 reading and the cited analog ex:P10272 'Calculate performance measures' (pure quantification: 'Quantify ... record results'), which lacks the audit/evaluate-against-target language and so is not a clean precedent. The explicit cco:ont00000228 co-parent (now redundant via the appraisal->measuring->planned-act chain) is retained so Gate C sees the Act anchor without the CCO closure. Output is the descriptive ex:SustainabilityPerformanceMeasurement (an appraisal record)." ;
    skos:example "An ESG auditor inspects emissions data, evaluates results against targets, and logs gaps for resolution." ;
    rdfs:subClassOf cco:ont00000636 ,   # Act of Appraisal (a CCO Act of Measuring / Planned Act)
        cco:ont00000228 ,   # Planned Act -- explicit so Gate C sees the Act anchor without the CCO closure
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityPerformanceMeasurement ] .

# --- 13.9.2.3.2 (PCF 21603) : prepare sustainability statements -> Information Processing
ex:P21603 a owl:Class ;
    ex:pcfID "21603" ; ex:hierarchyID "13.9.2.3.2" ;
    ex:apqcSourceText "Preparing sustainability statements. Given the multitude of potential audiences for reporting, alignment and consistency of sustainability statements provides clarity and reusability for those audiences." ;
    rdfs:label "Prepare sustainability statements" ;
    skos:definition "An Act of Information Processing that assembles measured sustainability performance into aligned, consistent sustainability statements for an organization's reporting audiences." ;
    rdfs:comment "Anchored to cco:ont00000366 (Act of Information Processing), mirroring the sibling-analog ex:P10275 'Prepare performance reports': input ICEs are assembled into an output Descriptive ICE. Input is ex:SustainabilityPerformanceMeasurement; output is ex:SustainabilityStatement." ;
    skos:example "An ESG reporting analyst compiles the validated metrics into the published sustainability statement." ;
    rdfs:subClassOf cco:ont00000366 ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001921 ; owl:someValuesFrom ex:SustainabilityPerformanceMeasurement ] ,
        [ a owl:Restriction ; owl:onProperty cco:ont00001986 ; owl:someValuesFrom ex:SustainabilityStatement ] .

