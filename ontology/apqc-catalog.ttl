    skos:broader ex:PCF_20959 .

ex:PCF_21460 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Scope analytics project""" ;
    ex:pcfID "21460" ;
    ex:hierarchyID "13.7.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Determining the size and scale of the project based upon the collected information and analytics. """ ;
    skos:broader ex:PCF_20959 .

ex:PCF_20960 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
