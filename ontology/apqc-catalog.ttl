    ex:pcfID "17056" ;
    ex:hierarchyID "7.7" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Managing the employee reporting processes, employee inquiry process, employee information and data, and the HR information systems. Create and administer the employee metrics. Develop and handle the time and attendance systems. Refurbish the indicators for employee retention and motivation.""" ;
    skos:broader ex:PCF_10007 .

ex:PCF_10522 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage reporting processes""" ;
    ex:pcfID "10522" ;
    ex:hierarchyID "7.7.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Providing information and reports regarding employees to management.""" ;
    skos:broader ex:PCF_17056 .

ex:PCF_10523 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage employee inquiry process""" ;
    ex:pcfID "10523" ;
    ex:hierarchyID "7.7.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Handling instances where an employee believes that he/she has been inappropriately treated or he/she desires clarification. Encourage employees to inquire when needed. Record and clarify the issues for which the enquiry has been made.""" ;
    skos:broader ex:PCF_17056 .

ex:PCF_10524 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage and maintain employee data""" ;
    ex:pcfID "10524" ;
    ex:hierarchyID "7.7.3" ;
