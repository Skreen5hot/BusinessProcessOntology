    skos:broader ex:PCF_11216 .

ex:PCF_16471 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Share knowledge of specific risks across other parts of the organization""" ;
    ex:pcfID "16471" ;
    ex:hierarchyID "11.4.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Sharing information about risks and resilience strategies of business operations across the organization so that prospective risks can be avoided. """ ;
    skos:broader ex:PCF_11216 .

ex:PCF_10012 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage External Relationships""" ;
    ex:pcfID "10012" ;
    ex:hierarchyID "12.0" ;
    rdfs:comment "APQC level: Category" ;
    ex:apqcSourceText """Fostering external relationships with stakeholders of the entity, including investors, government and industry, the board of directors, and the general public. This is not related to customer management.""" .

ex:PCF_11010 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Build investor relationships""" ;
    ex:pcfID "11010" ;
    ex:hierarchyID "12.1" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Creating a strategic management responsibility for integrating finance, communication, marketing, and securities law compliance. Allow the most effective two-way communication among the organization, the financial community, and other constituencies. Enlist the investor relations function to provide market intelligence to corporate management.""" ;
    skos:broader ex:PCF_10012 .

ex:PCF_11035 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan, build, and manage lender relations""" ;
    ex:pcfID "11035" ;
    ex:hierarchyID "12.1.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Building and managing relations with bankers or lenders through strong products/services strategies that bankers would want to invest in. Foster a receptive environment for low rates of interest, easy access to loans, etc.""" ;
    skos:broader ex:PCF_11010 .

ex:PCF_11036 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan, build, and manage analyst relations""" ;
    ex:pcfID "11036" ;
    ex:hierarchyID "12.1.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating and maintaining long-term relations with analysts. Involve analysts in strategy and product decisions in order to elicit valuable information.""" ;
    skos:broader ex:PCF_11010 .

ex:PCF_11037 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Communicate with shareholders""" ;
    ex:pcfID "11037" ;
    ex:hierarchyID "12.1.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Practicing regular, transparent communication with shareholders through annual shareholders' meetings, quarterly earnings calls, shareholders letters, one-on-one emails or calls, etc.""" ;
    skos:broader ex:PCF_11010 .

ex:PCF_11011 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage government and industry relationships""" ;
    ex:pcfID "11011" ;
    ex:hierarchyID "12.2" ;
