    skos:inScheme apqc:PCF ;
    skos:prefLabel """Execute IT continuity and recovery action""" ;
    ex:pcfID "20928" ;
    ex:hierarchyID "8.7.8.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Successfully implement preventive measures to manage IT risk of exposure to internal and external threats. Integrating the disciplines of Emergency Response, Crisis Management, Disaster Recovery (technology continuity) and Business Continuity for IT.""" ;
    skos:broader ex:PCF_20921 .

ex:PCF_17058 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage Financial Resources""" ;
    ex:pcfID "17058" ;
    ex:hierarchyID "9.0" ;
    rdfs:comment "APQC level: Category" ;
    ex:apqcSourceText """Overseeing key back-office processes for organizations. This category includes process groups related to planning and management accounting, revenue accounting, general accounting and reporting, fixed-asset project accounting, payroll, accounts payable and expense reimbursements, treasury operations, internal controls, tax management, international funds/consolidation, and global trade services.""" .

ex:PCF_10728 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform planning and management accounting""" ;
    ex:pcfID "10728" ;
    ex:hierarchyID "9.1" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Determining different stages of the planning process and accounting. Classify, determine, analyze, interpret, and communicate information to make up-to-date business decisions for better management and control functions.""" ;
    skos:broader ex:PCF_17058 .

ex:PCF_10738 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform planning/budgeting/forecasting""" ;
    ex:pcfID "10738" ;
    ex:hierarchyID "9.1.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Allocating funds to meet future and current financial goals. Led by the chief financial officer, have the finance function plan, budget, and forecast in order to determine and describe long and short-term financial goals.""" ;
    skos:broader ex:PCF_10728 .

ex:PCF_10771 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and maintain budget policies and procedures""" ;
    ex:pcfID "10771" ;
    ex:hierarchyID "9.1.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Formulating financial budgetary guidelines and strategies. Develop a framework for rules and regulations regarding budgets. Create a step-by-step process to achieve financial goals. """ ;
    skos:broader ex:PCF_10738 .

ex:PCF_10772 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prepare periodic budgets and plans""" ;
    ex:pcfID "10772" ;
    ex:hierarchyID "9.1.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating reports on a quarterly or annual basis for fund allocation. Create a financial statement that estimates revenues and expenses over a specific period of time. (Leverage budget methods such as cost-based and zero-based budgeting techniques, in light of the periodic targets outlined during Develop and maintain budget policies and procedures [10771].)""" ;
    skos:broader ex:PCF_10738 .

ex:PCF_20135 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Operationalize and implement plans to achieve budget""" ;
    ex:pcfID "20135" ;
    ex:hierarchyID "9.1.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Putting budgeting plans into practical use keeping within designated forecasting parameters.""" ;
    skos:broader ex:PCF_10738 .

ex:PCF_10773 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prepare periodic financial forecasts""" ;
    ex:pcfID "10773" ;
    ex:hierarchyID "9.1.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating estimates of the projected income and expenses required over a predetermined time frame. Develop the projections of profit and loss statements, balance sheets, and the cash flow forecast.""" ;
    skos:broader ex:PCF_10738 .

ex:PCF_20136 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform variance analysis against forecasts and budgets""" ;
    ex:pcfID "20136" ;
    ex:hierarchyID "9.1.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conducting a quantitative analysis between what was forecasted and budgeted and actual financial behavior. """ ;
    skos:broader ex:PCF_10738 .

ex:PCF_10739 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform cost accounting and control""" ;
    ex:pcfID "10739" ;
    ex:hierarchyID "9.1.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Defining costs to be incurred and methods for optimum utilization. Determine the costs of products, processes, projects, etc. to compile in the financial statements, as well as to assist management in making decisions regarding planning and control. Control costs by managing and reducing business expenses.""" ;
    skos:broader ex:PCF_10728 .

ex:PCF_10774 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform inventory accounting""" ;
    ex:pcfID "10774" ;
    ex:hierarchyID "9.1.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conducting accounting for assets, and finding reasons for changes (depreciation, obsolescence, deterioration, change in customer taste, increased demand, decreased market supply, etc.).""" ;
    skos:broader ex:PCF_10739 .

ex:PCF_14057 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform profit center accounting""" ;
    ex:pcfID "14057" ;
    ex:hierarchyID "9.1.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the revenue, profits, and losses incurred by each unit within the organization that produces profit. """ ;
    skos:broader ex:PCF_10739 .

ex:PCF_10775 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform cost of sales analysis""" ;
    ex:pcfID "10775" ;
    ex:hierarchyID "9.1.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Studying expenses directly associated with product. Analyze the cost of sales, which is the cost of manufacturing products.""" ;
    skos:broader ex:PCF_10739 .

ex:PCF_10776 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform product costing""" ;
    ex:pcfID "10776" ;
    ex:hierarchyID "9.1.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Studying and finding out the relevant cost center for a product by studying every resource used in its making.""" ;
    skos:broader ex:PCF_10739 .

ex:PCF_10777 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform variance analysis""" ;
    ex:pcfID "10777" ;
    ex:hierarchyID "9.1.2.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Discovering the changes between forecasted and actual costing. Analyze actual and planned behavior by reviewing the amount of a variance on a trend line in order to maintain control over a business.""" ;
    skos:broader ex:PCF_10739 .

ex:PCF_11175 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Report on profitability""" ;
    ex:pcfID "11175" ;
    ex:hierarchyID "9.1.2.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Making a report about revenues generated by the organization or business unit concerned. This process requires the organization to create a report which shows how business is generating profits. Profits are the part which is left after paying all expenses directly related to the generation of the revenue, such as producing a product, and other expenses related to conducting business activities.""" ;
    skos:broader ex:PCF_10739 .

ex:PCF_10740 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform cost management""" ;
    ex:pcfID "10740" ;
    ex:hierarchyID "9.1.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Deciding which expenses can be avoided to reduce some costs and increase revenues. Plan and control the organization's budget to forecast future expenditures. """ ;
    skos:broader ex:PCF_10728 .

ex:PCF_10778 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine key cost drivers""" ;
    ex:pcfID "10778" ;
    ex:hierarchyID "9.1.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining cost drivers for a particular activity. """ ;
    skos:broader ex:PCF_10740 .

ex:PCF_10779 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Measure cost drivers""" ;
    ex:pcfID "10779" ;
    ex:hierarchyID "9.1.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Calculating cost drivers. """ ;
    skos:broader ex:PCF_10740 .

ex:PCF_10780 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine critical activities""" ;
    ex:pcfID "10780" ;
    ex:hierarchyID "9.1.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determine the activities that hinder the progress of finance activities. This requires the organization to determine those business activities carried out by the financial function of the organization and which are indispensable. This undertaking helps the organization triangulate those activities which are essential and where costs cannot be slashed.""" ;
    skos:broader ex:PCF_10740 .

ex:PCF_10781 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage asset resource deployment and utilization""" ;
    ex:pcfID "10781" ;
    ex:hierarchyID "9.1.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Distributing or allocating asset resources in different processes for optimal utilization.""" ;
    skos:broader ex:PCF_10740 .

ex:PCF_10741 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate and manage financial performance""" ;
    ex:pcfID "10741" ;
    ex:hierarchyID "9.1.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Checking and achieving predetermined financial targets and timelines. Assess and manage the profitability, feasibility, and consistency of a business or project. Study the revenues generated.""" ;
    skos:broader ex:PCF_10728 .

ex:PCF_10782 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess customer and product profitability""" ;
    ex:pcfID "10782" ;
    ex:hierarchyID "9.1.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Studying product demand and targeted customer preferences. Study customers' demands or preferences after deducting the cost of delivering the final product.""" ;
    skos:broader ex:PCF_10741 .

ex:PCF_10783 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate new products""" ;
    ex:pcfID "10783" ;
    ex:hierarchyID "9.1.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Checking demand about a specific product by a customer segment. Conduct a detailed study--or research a customer behavior or preference for a product--in order to determine its production and profitability in a specific market. """ ;
    skos:broader ex:PCF_10741 .

ex:PCF_10784 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform life cycle costing""" ;
    ex:pcfID "10784" ;
    ex:hierarchyID "9.1.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the cost of delivering an end product at different stages of production. Study the total life cycle of a product/process to determine how much revenue and production cost will be incurred at every stage in order to make strategic decisions. """ ;
    skos:broader ex:PCF_10741 .

ex:PCF_10785 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Optimize customer and product mix""" ;
    ex:pcfID "10785" ;
    ex:hierarchyID "9.1.4.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating the best fit between a product and the end user. Maximize the customer base by providing different products in the market. """ ;
    skos:broader ex:PCF_10741 .

ex:PCF_10786 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Track performance of new-customer and product strategies""" ;
    ex:pcfID "10786" ;
    ex:hierarchyID "9.1.4.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Observing the behavior of a new set of customers for different products. Prepare strategies to improve sales and profits.""" ;
    skos:broader ex:PCF_10741 .

ex:PCF_10787 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prepare activity-based performance measures""" ;
    ex:pcfID "10787" ;
    ex:hierarchyID "9.1.4.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating performance based on different sets of activities created by management to measure performance.""" ;
    skos:broader ex:PCF_10741 .

ex:PCF_10788 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage continuous cost improvement""" ;
    ex:pcfID "10788" ;
    ex:hierarchyID "9.1.4.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conducting activities to improve cost distribution regularly. Follow or adopt different ways of reducing costs.""" ;
    skos:broader ex:PCF_10741 .

ex:PCF_10729 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform revenue accounting""" ;
    ex:pcfID "10729" ;
    ex:hierarchyID "9.2" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Comparing revenue targets to reality. Review all transactions and entries passed in final accounts in a year in order to examine profits.""" ;
    skos:broader ex:PCF_17058 .

ex:PCF_10742 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Process customer credit""" ;
    ex:pcfID "10742" ;
    ex:hierarchyID "9.2.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Evaluating and processing requests for advances. Evaluate credit requests by customers requiring loans to buy products/services. """ ;
    skos:broader ex:PCF_10729 .

ex:PCF_10789 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish credit policies""" ;
    ex:pcfID "10789" ;
    ex:hierarchyID "9.2.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating guidelines for providing advances. Set up credit standards, credit terms, and collection policies.""" ;
    skos:broader ex:PCF_10742 .

ex:PCF_10790 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze/Approve new account applications""" ;
    ex:pcfID "10790" ;
    ex:hierarchyID "9.2.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Checking and accepting new requests based on eligibility criteria. Analyze the status of applicants and requirements to be met for a new account.""" ;
    skos:broader ex:PCF_10742 .

ex:PCF_14187 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze credit scoring history""" ;
    ex:pcfID "14187" ;
    ex:hierarchyID "9.2.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Reviewing past credit scores to determine the if a line of credit will be extended to potential customers. This could also include extending additional credit to existing accounts.""" ;
    skos:broader ex:PCF_10742 .

ex:PCF_14188 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Forecast credit scoring requirement""" ;
    ex:pcfID "14188" ;
    ex:hierarchyID "9.2.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Planning credit score requirements based on established credit policies. """ ;
    skos:broader ex:PCF_10742 .

ex:PCF_10791 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review existing accounts""" ;
    ex:pcfID "10791" ;
    ex:hierarchyID "9.2.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating existing account holders and their past performance. Regularly review existing accounts to get the required information about the status at present.""" ;
    skos:broader ex:PCF_10742 .

ex:PCF_10792 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Produce credit/collection reports""" ;
    ex:pcfID "10792" ;
    ex:hierarchyID "9.2.1.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Preparing account payable reports about payments to be made according to accounting rules and principles, and providing the reports to management.""" ;
    skos:broader ex:PCF_10742 .

ex:PCF_10793 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Reinstate or suspend accounts based on credit policies""" ;
    ex:pcfID "10793" ;
    ex:hierarchyID "9.2.1.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Closing or restarting accounts according to changes made in credit policies. """ ;
    skos:broader ex:PCF_10742 .

ex:PCF_10743 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Invoice customer""" ;
    ex:pcfID "10743" ;
    ex:hierarchyID "9.2.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Preparing detailed reports of customer purchases. Prepare a commercial document between the seller and customer with details about transaction. Detail the quantity purchased, price of products/services, date, parties involved, unique invoice number, and tax information.""" ;
    skos:broader ex:PCF_10729 .

ex:PCF_10794 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Maintain customer/product master files""" ;
    ex:pcfID "10794" ;
    ex:hierarchyID "9.2.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating and updating a record of customers and the products being purchased by them in a database. This process element requires the organization to maintain a database of customers and their purchases. Such a master-file can be used to ensure customer touch point, enhance customer satisfaction, explore cross selling opportunities, and identify future trends. This database will include several particulars about the personal details of the organization's customers and a tracking of the products being sold.""" ;
    skos:broader ex:PCF_10743 .

ex:PCF_10795 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Generate customer billing data""" ;
    ex:pcfID "10795" ;
    ex:hierarchyID "9.2.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Preparing detailed reports about products purchased by customers. Record and generate a detail account of transactions made by customers fat a particular time and location. Include all details about products such as price, quantity, and name.""" ;
    skos:broader ex:PCF_10743 .

ex:PCF_10796 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Transmit billing data to customers""" ;
    ex:pcfID "10796" ;
    ex:hierarchyID "9.2.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Providing information to customers about purchases made by them. Communicate the details of purchases. Provide customers with a copy of details for their reference.""" ;
    skos:broader ex:PCF_10743 .

ex:PCF_10797 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Post receivable entries""" ;
    ex:pcfID "10797" ;
    ex:hierarchyID "9.2.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Registering transactions and their scheduled payments. """ ;
    skos:broader ex:PCF_10743 .

ex:PCF_10798 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Resolve customer billing inquiries""" ;
    ex:pcfID "10798" ;
    ex:hierarchyID "9.2.2.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Checking and solving billing queries raised by customers. """ ;
    skos:broader ex:PCF_10743 .

ex:PCF_10744 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Process accounts receivable (AR)""" ;
    ex:pcfID "10744" ;
    ex:hierarchyID "9.2.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Processing payments due from customers. This includes all processing of funds received, whether by check or electronically. This does not include the generation of invoices.""" ;
    skos:broader ex:PCF_10729 .

ex:PCF_10799 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish AR policies""" ;
    ex:pcfID "10799" ;
    ex:hierarchyID "9.2.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating rules and regulations to be followed in case of credit sales to customers. Create rules and procedures to follow at the time of sale (e.g., the allowable number of installments).""" ;
    skos:broader ex:PCF_10744 .

ex:PCF_10800 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Receive/Deposit customer payments""" ;
    ex:pcfID "10800" ;
    ex:hierarchyID "9.2.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Collecting cash from customers. Deposit it into bank account. Make entries into the books of accounts.""" ;
    skos:broader ex:PCF_10744 .

ex:PCF_10801 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Apply cash remittances""" ;
    ex:pcfID "10801" ;
    ex:hierarchyID "9.2.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Checking and moving funds between countries for business activities, typically through authorized remittance agents.""" ;
    skos:broader ex:PCF_10744 .

ex:PCF_10802 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prepare AR reports""" ;
    ex:pcfID "10802" ;
    ex:hierarchyID "9.2.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Preparing reports that detail balances due or what to collect from customers at a certain point in time. """ ;
    skos:broader ex:PCF_10744 .

ex:PCF_10803 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Post AR activity to the general ledger""" ;
    ex:pcfID "10803" ;
    ex:hierarchyID "9.2.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Preparing the general ledger for account receivables from journals. Place all journal entries related to accounts receivables in the general ledger accounts of a business. """ ;
