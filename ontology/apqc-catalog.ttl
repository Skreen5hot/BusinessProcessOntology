    ex:hierarchyID "8.1.4.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Providing a plan of action to provide solution to IT customers. The solution design should be based on the collection and analysis of IT customer requirements.""" ;
    skos:broader ex:PCF_20623 .

ex:PCF_20628 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prioritize IT outcomes""" ;
    ex:pcfID "20628" ;
    ex:hierarchyID "8.1.4.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Prioritizing IT outcomes based on need, effectiveness, and efficiency.""" ;
    skos:broader ex:PCF_20623 .

ex:PCF_20629 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop business cases""" ;
    ex:pcfID "20629" ;
    ex:hierarchyID "8.1.4.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Create a business case with value proposition indicating current situation, proposed solution, financial analysis, and measurable benefits to the IT customers.""" ;
    skos:broader ex:PCF_20623 .

ex:PCF_20630 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
