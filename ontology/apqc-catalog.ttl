ex:PCF_10530 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage/Collect employee suggestions and perform employee research""" ;
    ex:pcfID "10530" ;
    ex:hierarchyID "7.7.9" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Procuring and handling suggestions from employees, and performing research on employees. Manage and analyze the programs that help the organization to tap into employee ideas for improving the organization's processes and/or products. Use surveys, focus groups, and other data-gathering methods to find out the attitudes, opinions, and feelings of members of an organization.""" ;
    skos:broader ex:PCF_17056 .

ex:PCF_21451 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage employee communication""" ;
    ex:pcfID "21451" ;
    ex:hierarchyID "7.8" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Creating an effective plan that initiates and promotes communication and engagement among the employees and between employees and management.""" ;
    skos:broader ex:PCF_10007 .

ex:PCF_10529 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop employee communication plan""" ;
    ex:pcfID "10529" ;
    ex:hierarchyID "7.8.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating a plan for managing communication among employees. Inform employees of direction. Counter resistance with change management approaches. Seek specific areas of input to the decision-making process. Seek varying degrees of involvement and co-creation.""" ;
    skos:broader ex:PCF_21451 .

ex:PCF_16944 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct employee engagement surveys""" ;
    ex:pcfID "16944" ;
    ex:hierarchyID "7.8.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Questioning employees to ascertain overall workplace satisfaction. """ ;
    skos:broader ex:PCF_21451 .

ex:PCF_10532 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Deliver employee communications""" ;
    ex:pcfID "10532" ;
    ex:hierarchyID "7.8.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Implementing the communication plan for employees. Initiate dialogues and engagement by monitoring the exchange of ideas and opinions, the development of personal relationships, etc.""" ;
    skos:broader ex:PCF_21451 .

ex:PCF_20607 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage Information Technology (IT)""" ;
    ex:pcfID "20607" ;
    ex:hierarchyID "8.0" ;
    rdfs:comment "APQC level: Category" ;
    ex:apqcSourceText """Managing process groups relevant to the business of information technology within an organization. The process groups include \"Develop and manage IT customer relationships\", \"Develop and manage IT business strategy\", \" Develop and manage IT resilience and risk\", \" Manage information\", \" Develop and manage services/solutions\", \"Deploy services/solutions\", and \" Create and manage support services/solutions\".""" .

ex:PCF_20608 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage IT customer relationships""" ;
    ex:pcfID "20608" ;
    ex:hierarchyID "8.1" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Creating and administering relationships with IT customers. Understanding customer needs including high-level business requirements for IT transformation. Plan for and communicate IT services along with establishing IT service levels, providing transformation guidance, and performance analysis that foster IT customer relationships.""" ;
    skos:broader ex:PCF_20607 .

ex:PCF_20609 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Understand IT customer needs""" ;
    ex:pcfID "20609" ;
    ex:hierarchyID "8.1.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Assessing the customer communities along with current IT operational capabilities and usage. """ ;
    skos:broader ex:PCF_20608 .

ex:PCF_20610 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Understand IT customer communities""" ;
    ex:pcfID "20610" ;
    ex:hierarchyID "8.1.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Interacting with IT customers to understand the IT needs through a collaborative community through involvement, connection, and informed communication.""" ;
    skos:broader ex:PCF_20609 .

ex:PCF_20611 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess IT customer operational capabilities""" ;
    ex:pcfID "20611" ;
    ex:hierarchyID "8.1.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluate the ability of the group of staff dependent on information technology, to align resources and critical processes according to organizational vision being able to deliver effectively and efficiently.""" ;
    skos:broader ex:PCF_20609 .

ex:PCF_20612 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify IT customer transformation needs""" ;
    ex:pcfID "20612" ;
    ex:hierarchyID "8.1.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Identifying changing needs of staff dependent on information technology based on continuous improvement to deliver results according to organizational goals.""" ;
    skos:broader ex:PCF_20608 .

ex:PCF_20613 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Understand business requirements for IT capabilities""" ;
    ex:pcfID "20613" ;
    ex:hierarchyID "8.1.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Understanding business requirements for the existing IT environment as well as future IT needs.""" ;
    skos:broader ex:PCF_20612 .

ex:PCF_20614 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Understand IT landscape""" ;
    ex:pcfID "20614" ;
    ex:hierarchyID "8.1.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Understanding the complete logical structure and working of the organization's IT landscape. Assess the configuration of hardware and software (IT Assets) across the organization that supports overall business operations.""" ;
    skos:broader ex:PCF_20612 .

ex:PCF_20615 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop IT visioning""" ;
    ex:pcfID "20615" ;
    ex:hierarchyID "8.1.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing goals to define IT vision. Define and document ideas, direction, and activities which enable information technology to reach these goals.""" ;
    skos:broader ex:PCF_20612 .

ex:PCF_20616 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Outline IT service expectations""" ;
    ex:pcfID "20616" ;
    ex:hierarchyID "8.1.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining a roadmap to meet organizational expectations from information technology services while considering how it will affect the business.""" ;
    skos:broader ex:PCF_20612 .

ex:PCF_20617 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan and communicate IT services""" ;
    ex:pcfID "20617" ;
    ex:hierarchyID "8.1.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Create and design an organized and curated collection of all IT-related services that can be performed by, for, or within the organization. Maintain and convey information about deliverables, prices, contact points, and processes for requesting an information technology service.""" ;
    skos:broader ex:PCF_20608 .

ex:PCF_20618 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage IT customer expectations""" ;
    ex:pcfID "20618" ;
    ex:hierarchyID "8.1.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing customer expectations of the existing IT environment while considering how it will affect the business.""" ;
    skos:broader ex:PCF_20617 .

ex:PCF_20619 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define future IT services""" ;
    ex:pcfID "20619" ;
    ex:hierarchyID "8.1.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining the expected demand and usage of information technology services to meet organization's future business goals. Gather necessary information about the processes, resource requirements, and structures pertaining to planned business growth.""" ;
    skos:broader ex:PCF_20617 .

ex:PCF_20620 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine IT performance indicators""" ;
    ex:pcfID "20620" ;
    ex:hierarchyID "8.1.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining IT KPIs crucial to the organization's success. Measure indicators such as IT costs as percentage of revenue, IT maintenance ratio, and system downtime in an effort to evaluate the performance of IT across the organization.""" ;
    skos:broader ex:PCF_20617 .

ex:PCF_20621 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create IT marketing messages""" ;
    ex:pcfID "20621" ;
    ex:hierarchyID "8.1.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing concise statements that position the value proposition around the pressing concerns of the internal IT user base, thereby showing how the IT offerings are the right fit for a segment of IT customers. """ ;
    skos:broader ex:PCF_20617 .

ex:PCF_20622 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create IT service marketing plan""" ;
    ex:pcfID "20622" ;
    ex:hierarchyID "8.1.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a marketing strategy for IT offerings to customers. Plan processes for making budgets; identifying and developing media; and managing marketing content and promotional activities.""" ;
    skos:broader ex:PCF_20617 .

ex:PCF_20623 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Provide IT transformation guidance""" ;
    ex:pcfID "20623" ;
    ex:hierarchyID "8.1.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Understanding the necessity of IT transformation for the business. Collect and analyze customer requirements. Identify opportunities and prioritize outcomes. Develop and support business case for transformation. Develop transformation plan and roadmap. """ ;
    skos:broader ex:PCF_20608 .

ex:PCF_20624 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop IT transformation plans""" ;
    ex:pcfID "20624" ;
    ex:hierarchyID "8.1.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a robust plan to replace or upgrade an organization's information technology systems. Understanding the business need of IT transformation from current to an expected state for the business. Developing a strategic plan for IT operating model, governance, service delivery, and workforce transformation.""" ;
    skos:broader ex:PCF_20623 .

ex:PCF_20625 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Collect IT customer requirements""" ;
    ex:pcfID "20625" ;
    ex:hierarchyID "8.1.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying existing or potential IT gaps between the expected business performance levels and current business outcomes.""" ;
    skos:broader ex:PCF_20623 .

ex:PCF_20937 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze IT customer requirements""" ;
    ex:pcfID "20937" ;
    ex:hierarchyID "8.1.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing identified IT gaps to plan for remediation efforts to allow outcomes to meet established performance levels.""" ;
    skos:broader ex:PCF_20623 .

ex:PCF_20626 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
