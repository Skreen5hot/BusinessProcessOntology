    ex:hierarchyID "11.0" ;
    rdfs:comment "APQC level: Category" ;
    ex:apqcSourceText """Ensuring that an organization effectively manages its risk. Process groups are aligned with traditional risk management activities.""" .

ex:PCF_17060 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
