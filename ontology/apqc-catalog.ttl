    ex:pcfID "10233" ;
    ex:hierarchyID "4.1.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Outlining the manufacturing and processing capacities of the organization. Delineate the capabilities required for optimizing output with available resources. Analyze capabilities possessed by the organization concerning the raw materials required and the process necessitated for producing finished products. """ ;
