    ex:hierarchyID "7.7.8.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Logically and statistically validate collected or purchased data in support of analytics needs""" ;
    skos:broader ex:PCF_21447 .

ex:PCF_21449 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
