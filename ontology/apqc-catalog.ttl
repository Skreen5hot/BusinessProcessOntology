    ex:apqcSourceText """Capturing and updating employee information and data and information on the employees. """ ;
    skos:broader ex:PCF_17056 .

ex:PCF_10525 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage human resource information systems HRIS""" ;
    ex:pcfID "10525" ;
    ex:hierarchyID "7.7.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Administering and maintaining HR information systems that take care of activities related to HR, accounting, management, and payroll.""" ;
    skos:broader ex:PCF_17056 .

ex:PCF_10526 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage employee measures""" ;
    ex:pcfID "10526" ;
    ex:hierarchyID "7.7.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating and maintaining performance metrics for employees. Create and manage a strategic system of data and statistics to accurately gauge each employee's information. Consider productivity metrics, efficiency metrics, training metrics, etc.""" ;
    skos:broader ex:PCF_17056 .

ex:PCF_10527 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage time and attendance systems""" ;
    ex:pcfID "10527" ;
    ex:hierarchyID "7.7.6" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing and maintaining systems for managing the time and attendance of employees. Routinely upgrade the process and systems that track when employees start and stop work, the department where the work is performed, attendance in addition to tracking meals and breaks, the type of work performed, and the number of items produced.""" ;
    skos:broader ex:PCF_17056 .

