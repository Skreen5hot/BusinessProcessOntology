    ex:apqcSourceText """Evaluating and supporting capital investments in projects and fixed assets. Confirm details of capital projects. Secure approvals from managements for large investments.""" ;
    skos:broader ex:PCF_10751 .

ex:PCF_10847 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
