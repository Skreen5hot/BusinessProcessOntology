ex:PCF_20638 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Negotiate and establish service level agreements""" ;
    ex:pcfID "20638" ;
    ex:hierarchyID "8.1.5.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establish a service level agreement, which is a negotiated agreement designed to create a common understanding about services, priorities, and responsibilities.""" ;
    skos:broader ex:PCF_20632 .

ex:PCF_20640 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and maintain improvement processes""" ;
    ex:pcfID "20640" ;
    ex:hierarchyID "8.1.5.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conveying the improvement opportunities for the business and level of IT services. Leverage the results obtained from the performance metrics of the business and IT service levels to identify and recognize any opportunities that would improve or enhance the efficiency of the business and IT service-level structure. Communicate these opportunities to management in order for the improvements to take effect.""" ;
    skos:broader ex:PCF_20632 .

ex:PCF_20641 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage IT customer relationships""" ;
    ex:pcfID "20641" ;
    ex:hierarchyID "8.1.6" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Managing the IT relationship with its customers by systematically coordinating interactions over multiple touch points on a regular basis. Coordinate the IT's efforts to reach out to its customers, which include emails, social-media interactions, newsletters, and direct conversations.""" ;
    skos:broader ex:PCF_20608 .

ex:PCF_20642 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish relationship management mechanisms""" ;
    ex:pcfID "20642" ;
    ex:hierarchyID "8.1.6.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Create mechanisms for effective public relationship in order to preserve the image and goodwill of the organization through the process.""" ;
    skos:broader ex:PCF_20641 .

ex:PCF_20643 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Understand IT customer strategy""" ;
    ex:pcfID "20643" ;
    ex:hierarchyID "8.1.6.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Understanding the strategy for staff dependent on information technology. Create a plan to create services and solutions, conduct daily operations, and train new employees.""" ;
    skos:broader ex:PCF_20641 .

ex:PCF_20644 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Understand IT customer environment""" ;
    ex:pcfID "20644" ;
    ex:hierarchyID "8.1.6.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Understanding the environment of staff dependent on information technology. Assess and evaluate services and solutions used by customers to conduct daily operations, and train new employees.""" ;
    skos:broader ex:PCF_20641 .

ex:PCF_20645 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Communicate IT capabilities""" ;
    ex:pcfID "20645" ;
    ex:hierarchyID "8.1.6.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conveying the goals and objectives of the IT function and how it contributes to the overall business objectives to staff and departments across the organization.""" ;
    skos:broader ex:PCF_20641 .

ex:PCF_20646 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage IT requirements""" ;
    ex:pcfID "20646" ;
    ex:hierarchyID "8.1.6.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing the IT requirements for business objectives. Identify the requirements of hardware and software equipment to store, retrieve, transmit, and manipulate data related to business operations. Consider factors such as functional, design, growth phases, and delivery schedule while managing IT requirements.""" ;
    skos:broader ex:PCF_20641 .

ex:PCF_20648 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
