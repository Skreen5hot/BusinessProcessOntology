    skos:broader ex:PCF_20959 .

ex:PCF_11179 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage environmental health and safety (EHS)""" ;
    ex:pcfID "11179" ;
    ex:hierarchyID "13.8" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Determining the impacts of environmental health and safety. Create and implement the EHS program. Train and educate employees of the EHS function. Oversee and manage the EHS program. """ ;
    skos:broader ex:PCF_10013 .

ex:PCF_11180 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine environmental health and safety impacts""" ;
    ex:pcfID "11180" ;
    ex:hierarchyID "13.8.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Determining the impact of EHS offering--and the procedures it employs to process them--on the environment at large, as well as the health and safety of employees. Evaluate the environmental impact of the organization's products, services, and operations. Conduct health, safety, and environmental audits.""" ;
    skos:broader ex:PCF_11179 .

ex:PCF_11186 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate environmental impact of products, services, and operations""" ;
    ex:pcfID "11186" ;
    ex:hierarchyID "13.8.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating the impact of offerings and the auxiliary operations required to process them on the immediate ecosystem and the environment at large. Study the lifecycle of the products/services offered by the organization. Estimate any affect on the environment through metrics such as a calculation of carbon footprint.""" ;
    skos:broader ex:PCF_11180 .

ex:PCF_11187 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct health and safety and environmental audits""" ;
    ex:pcfID "11187" ;
    ex:hierarchyID "13.8.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conducting an inspection to verify that the organization adequately complies with the environmental, health, and safety standards. Audit procedures and records regarding responsibility for the environment, health, and safety.""" ;
    skos:broader ex:PCF_11180 .

ex:PCF_11181 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop EHS program""" ;
    ex:pcfID "11181" ;
    ex:hierarchyID "13.8.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Identify the requirements for regulation and shareholders. Assess future risks and opportunities. Develop a policy for the EHS program. Record and manage EHS program events.""" ;
    skos:broader ex:PCF_11179 .

ex:PCF_11188 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify regulatory and stakeholder requirements""" ;
    ex:pcfID "11188" ;
    ex:hierarchyID "13.8.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining any protocols or standards to comply with, set by regulatory agencies or the organization's stakeholders. Closely examine all standards and matters of compliance relating to the environment, health, and safety.""" ;
    skos:broader ex:PCF_11181 .

ex:PCF_11189 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess future risks and opportunities""" ;
    ex:pcfID "11189" ;
    ex:hierarchyID "13.8.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating any risks and opportunities that might affect the environmental, health, and safety of products/services. Leverage techniques such as cost-benefit analysis, trend extrapolation, systems analysis, social surveys, historical surveys, historical analogy, Delphi, conferences, workshops, briefings, hearings, advisory committees, moot courts, artistic judgment, on-site field investigation, scaling techniques, and scenario creation.""" ;
    skos:broader ex:PCF_11181 .

ex:PCF_11190 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create EHS policy""" ;
    ex:pcfID "11190" ;
    ex:hierarchyID "13.8.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a plan for managing the environmental, health, and safety impact of products/services. Establish minimum requirements for the organization regarding the environment at large and the health and safety of employees. Develop policies, written procedures, and supporting tools to dictate how the organization will meet policy requirements.""" ;
    skos:broader ex:PCF_11181 .

ex:PCF_11191 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Record and manage EHS events""" ;
    ex:pcfID "11191" ;
    ex:hierarchyID "13.8.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Recording and managing all events and activities associated with complying with environmental, health and safety standards. Create event calendars. Assign funds. Educate employees. Conduct events.""" ;
    skos:broader ex:PCF_11181 .

ex:PCF_21587 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor and manage EHS program""" ;
    ex:pcfID "21587" ;
    ex:hierarchyID "13.8.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Managing the performance, costs and benefits of EHS. Measure and report the performance of EHS. Implement plans for emergency response and pollution prevention. Train and educate employees. Provide EHS support.""" ;
    skos:broader ex:PCF_11179 .

ex:PCF_11193 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage EHS costs and benefits""" ;
    ex:pcfID "11193" ;
    ex:hierarchyID "13.8.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Administering the costs and benefits of EHS management program. Evaluate program costs to ensure that the benefits of the program always outweigh its costs. """ ;
    skos:broader ex:PCF_21587 .

ex:PCF_11194 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Measure and report EHS performance""" ;
    ex:pcfID "11194" ;
    ex:hierarchyID "13.8.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Using performance techniques and indicators. Utilize number of audits or inspections performed, safety committee meetings, the number and types of findings and observations, timely preventive maintenance tasks performed, etc.""" ;
    skos:broader ex:PCF_21587 .

ex:PCF_11196 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Implement emergency response program""" ;
    ex:pcfID "11196" ;
    ex:hierarchyID "13.8.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Implementing a program for organizing, coordinating, and directing available resources to respond to the event. Conduct a risk assessment to identify potential emergency scenarios in order to create a program that ensures that resources are on hand--or quickly available--in case of emergencies.""" ;
    skos:broader ex:PCF_21587 .

ex:PCF_11197 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Implement pollution prevention program""" ;
    ex:pcfID "11197" ;
    ex:hierarchyID "13.8.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Implementing a program that reduces or eliminates the creation of pollutants through increased efficiency in the use of raw materials, energy, water, or other resources. Implement a program to inspect facilities that store, manufacture, or use hazardous, toxic, or polluting materials.""" ;
    skos:broader ex:PCF_21587 .

ex:PCF_11182 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Train and educate functional employees""" ;
    ex:pcfID "11182" ;
    ex:hierarchyID "13.8.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conducting programs such as on-the-job training sessions, group training workshops, and online training.""" ;
    skos:broader ex:PCF_21587 .

ex:PCF_11195 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Provide EHS support""" ;
    ex:pcfID "11195" ;
    ex:hierarchyID "13.8.3.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Supporting employees in light of the organization's environmental, health, and safety policies and standards. Provide medical insurance, maternity leave, environmental education, training over safety, etc.""" ;
    skos:broader ex:PCF_21587 .

ex:PCF_21588 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage sustainability""" ;
    ex:pcfID "21588" ;
    ex:hierarchyID "13.9" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Developing and managing sustainability practices for the organization. Ensure proper understanding and communication of ESG standards, requirements, capabilities, and future trends. Promote awareness, alignment, and continuity.""" ;
    skos:broader ex:PCF_10013 .

ex:PCF_21589 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop sustainability capability""" ;
    ex:pcfID "21589" ;
    ex:hierarchyID "13.9.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing sustainability (ESG) capabilities for the organization. Understand and communicate legal, regulatory, and social/environmental requirements. Establish policies, objectives, guidelines and approaches for ESG efforts and reporting.""" ;
    skos:broader ex:PCF_21588 .

ex:PCF_21590 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify sustainability requirements""" ;
    ex:pcfID "21590" ;
    ex:hierarchyID "13.9.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying, documenting, and communicating sustainability requirements. Closely examine all standards and matters of compliance relating to ESG. Determine protocols or standards to comply with, set by regulatory agencies or the organizations stakeholders.""" ;
    skos:broader ex:PCF_21589 .

ex:PCF_21591 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define sustainability disclosure requirements""" ;
    ex:pcfID "21591" ;
    ex:hierarchyID "13.9.1.1.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Defining and communicating sustainability disclosure requirements. Clarify and align disclosure requirements to other organizational reporting requirements and needs. Integrate preparation and reporting activities.""" ;
    skos:broader ex:PCF_21590 .

ex:PCF_21592 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define sustainability governance requirements""" ;
    ex:pcfID "21592" ;
    ex:hierarchyID "13.9.1.1.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Defining governance requirements for sustainability. Include structure, roles, alignment to organization models, processes and standards to be applied.""" ;
    skos:broader ex:PCF_21590 .

ex:PCF_21593 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define sustainability functional and performance requirements""" ;
    ex:pcfID "21593" ;
    ex:hierarchyID "13.9.1.1.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Defining functional and performance requirements for sustainability. Align with ESG strategies, goals, and the implementation of sustainability efforts across the organization, provide a roadmap and visibility to shared and collective requirements.""" ;
    skos:broader ex:PCF_21590 .

ex:PCF_21594 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish sustainability goals/objectives""" ;
    ex:pcfID "21594" ;
    ex:hierarchyID "13.9.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing organizational sustainability goals/objectives. Gather, align, and promote organization-wide sustainability goals that collectively address the overall sustainability requirements. Ensure the goals are measurable and have qualitative and quantitative targets.""" ;
    skos:broader ex:PCF_21589 .

ex:PCF_21595 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create sustainability policies""" ;
    ex:pcfID "21595" ;
    ex:hierarchyID "13.9.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing, documenting, and communicating sustainability policies. Develop policies, written procedures, and supporting tools to dictate how the organization will meet policy requirements.""" ;
    skos:broader ex:PCF_21589 .

ex:PCF_21596 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define sustainability measures""" ;
    ex:pcfID "21596" ;
    ex:hierarchyID "13.9.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining sustainability measures. Provide organization-wide measures, to include data collection strategies, calculations, analytics, and reporting formats.""" ;
    skos:broader ex:PCF_21589 .

ex:PCF_21597 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create sustainability plan(s)""" ;
    ex:pcfID "21597" ;
    ex:hierarchyID "13.9.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating sustainability plans. Develop and socialize sustainability plans for the organization, functional units, and support services. Ensure alignment to sustainability requirements, goals, and governance.""" ;
    skos:broader ex:PCF_21589 .

ex:PCF_21598 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage sustainability capability""" ;
    ex:pcfID "21598" ;
    ex:hierarchyID "13.9.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Managing sustainability across the organization. Provide training, support, reporting, and oversight to the distributed sustainability efforts across functional units and support services.""" ;
    skos:broader ex:PCF_21588 .

ex:PCF_21599 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Provide sustainability training""" ;
    ex:pcfID "21599" ;
    ex:hierarchyID "13.9.2.1" ;
