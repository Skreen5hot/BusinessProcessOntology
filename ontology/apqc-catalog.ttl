    ex:pcfID "21447" ;
    ex:hierarchyID "7.7.8" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Transform, develop, and communicate workforce data into analytics in support of organizational requirements.  """ ;
    skos:broader ex:PCF_17056 .

ex:PCF_21448 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
