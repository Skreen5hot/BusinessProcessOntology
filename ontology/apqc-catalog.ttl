    ex:hierarchyID "3.5.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Clarifying the details about procurement requests, such as the scope, timeline, data sources, type and characteristics and evaluation criteria for the goods or services to be delivered, and any additional terms, conditions or special requirements.""" ;
    skos:broader ex:PCF_11779 .

