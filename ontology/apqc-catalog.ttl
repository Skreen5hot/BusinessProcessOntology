ex:PCF_21445 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify workforce data sources""" ;
    ex:pcfID "21445" ;
    ex:hierarchyID "7.7.7.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identify appropriate data sources for workforce analytics data while considering organizational standards for data sources.  """ ;
    skos:broader ex:PCF_21441 .

ex:PCF_21446 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
