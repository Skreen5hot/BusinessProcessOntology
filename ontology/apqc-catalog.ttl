ex:PCF_21443 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify research questions""" ;
    ex:pcfID "21443" ;
    ex:hierarchyID "7.7.7.2" ;
