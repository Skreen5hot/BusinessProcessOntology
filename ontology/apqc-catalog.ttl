    skos:broader ex:PCF_11216 .

ex:PCF_11223 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Test continuous business operations""" ;
    ex:pcfID "11223" ;
    ex:hierarchyID "11.4.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Assessing ongoing activities within the organization that are not intended to stop except for in an emergency. """ ;
    skos:broader ex:PCF_11216 .

ex:PCF_11224 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Maintain continuous business operations""" ;
    ex:pcfID "11224" ;
    ex:hierarchyID "11.4.4" ;
