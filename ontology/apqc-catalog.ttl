    ex:apqcSourceText """Gather data from each service target defined in an SLA for a time segment or review period to evaluate an overall performance percentage.""" ;
    skos:broader ex:PCF_20648 .

ex:PCF_20650 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Triage SLA compliance issues""" ;
    ex:pcfID "20650" ;
    ex:hierarchyID "8.1.7.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Prioritizing SLA compliance issues and plan for remediation.""" ;
    skos:broader ex:PCF_20648 .

ex:PCF_20647 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
