    ex:pcfID "10229" ;
    ex:hierarchyID "4.1.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating quantifiable strategic objectives for each manufacturing segment in conjunction with sales projections.""" ;
    skos:broader ex:PCF_10221 .

