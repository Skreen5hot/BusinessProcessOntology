    ex:apqcSourceText """Meeting with government heads and representatives.""" ;
    skos:broader ex:PCF_11038 .

ex:PCF_11039 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage relations with quasi-government bodies""" ;
    ex:pcfID "11039" ;
    ex:hierarchyID "12.2.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Managing relations with quasi-governmental organizations, corporations, businesses, or any other agency that is treated by national laws and principles to be under the supervision of the government but also distinct and self-directed from the government.""" ;
    skos:broader ex:PCF_11011 .

ex:PCF_12875 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish relationships with agencies""" ;
    ex:pcfID "12875" ;
    ex:hierarchyID "12.2.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Engaging government, regulatory, or industry agencies to establish relationships. Analyze steps and requirements necessary for inclusion, if needed. """ ;
    skos:broader ex:PCF_11039 .

ex:PCF_12876 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Respond to audit inquiries""" ;
    ex:pcfID "12876" ;
    ex:hierarchyID "12.2.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Cooperating with auditors regarding potential or ongoing inquiries.""" ;
    skos:broader ex:PCF_11039 .

ex:PCF_12877 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Maintain documentation of contacts""" ;
    ex:pcfID "12877" ;
    ex:hierarchyID "12.2.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Keeping a repository of documents that contain information about the network of partners, prospects and customers. Keep records up-to-date with routine reviews and modify as needed.""" ;
    skos:broader ex:PCF_11039 .

ex:PCF_12878 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan and manage meetings""" ;
    ex:pcfID "12878" ;
    ex:hierarchyID "12.2.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Ensuring regular interaction between business entity and quasi-government bodies in order to maintain established relationships. Collect and record meeting data for further analysis and use.""" ;
    skos:broader ex:PCF_11039 .

ex:PCF_11040 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage relations with trade or industry groups""" ;
    ex:pcfID "11040" ;
    ex:hierarchyID "12.2.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Managing relations with organizations established and financed by businesses that operate in a specific industry. Participate in public relations actions such as lobbying and publishing, advertising, education, and political donations.""" ;
    skos:broader ex:PCF_11011 .

ex:PCF_12879 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate the requirements for strategic relationships""" ;
    ex:pcfID "12879" ;
    ex:hierarchyID "12.2.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the requirements to enter in to an agreement with trade or industry agencies. Discover what activities or processes can be conducted to provide the best mutual outcome.""" ;
    skos:broader ex:PCF_11040 .

ex:PCF_12880 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor the success of the partnerships""" ;
    ex:pcfID "12880" ;
    ex:hierarchyID "12.2.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyzing current relationships with trade and industry groups. Ensure that the partnership in successful and make modifications where needed. """ ;
    skos:broader ex:PCF_11040 .

ex:PCF_12881 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Extend or change the relationships""" ;
    ex:pcfID "12881" ;
    ex:hierarchyID "12.2.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Providing additional information or inclusion for third party trade or industry entities; or changing existing parameters to modify the current relationship. Communicate and execute changes.""" ;
    skos:broader ex:PCF_11040 .

ex:PCF_11041 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage lobby activities""" ;
    ex:pcfID "11041" ;
    ex:hierarchyID "12.2.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Managing lobbying activities to affect government policies. """ ;
    skos:broader ex:PCF_11011 .

ex:PCF_11012 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage relations with board of directors""" ;
    ex:pcfID "11012" ;
    ex:hierarchyID "12.3" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Maintaining relations with representatives of the stockholders. Establish corporate management-related policies and to make decisions on major company issues. Implement practices designed to engender communication, trust, and cooperation.""" ;
    skos:broader ex:PCF_10012 .

ex:PCF_11042 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Report financial results""" ;
    ex:pcfID "11042" ;
    ex:hierarchyID "12.3.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Reporting financial results to management, and releasing results to the public. Report financial statements, including the income statement, balance sheet, and statement of cash flows.""" ;
    skos:broader ex:PCF_11012 .

ex:PCF_11043 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Report audit findings""" ;
    ex:pcfID "11043" ;
    ex:hierarchyID "12.3.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Reporting audit findings to management. Practice an internal audit with criteria for confirming a problem, a description of the situation, and the root cause of the problem. Make recommendations that resolve the issue.""" ;
    skos:broader ex:PCF_11012 .

ex:PCF_11013 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage legal and ethical issues""" ;
    ex:pcfID "11013" ;
    ex:hierarchyID "12.4" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Managing legal practices to abide by the law, as well as ethical practices.""" ;
    skos:broader ex:PCF_10012 .

ex:PCF_11044 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create ethics policies""" ;
    ex:pcfID "11044" ;
    ex:hierarchyID "12.4.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating a code of ethics that communicate the organization's philosophy to employees, vendors, customers, clients, and the public.""" ;
    skos:broader ex:PCF_11013 .

ex:PCF_11045 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage corporate governance policies""" ;
    ex:pcfID "11045" ;
    ex:hierarchyID "12.4.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Administering the system of rules, practices, and processes through which a company is directed and controlled. Balance stakeholder interests including shareholders, management, customers, suppliers, financiers, government, and the community. Outline a strategy for achieving organizational goals, from action plans and internal controls to performance measurement and corporate disclosure.""" ;
    skos:broader ex:PCF_11013 .

ex:PCF_11046 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and perform preventive law programs""" ;
    ex:pcfID "11046" ;
    ex:hierarchyID "12.4.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating and applying programs and activities. Encourage the adherence preventive laws, such as environmental law, sex discrimination, computer law, estate planning, corporate compliance, business planning, and property transactions.""" ;
    skos:broader ex:PCF_11013 .

ex:PCF_11047 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Ensure compliance""" ;
    ex:pcfID "11047" ;
    ex:hierarchyID "12.4.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Ensuring the organization's compliance position. Validate compliance with different statutes, regulatory directions, and legal principles (using Establish compliance framework and policies [17468]). Coordinate with compliance and risk management personnel.""" ;
    skos:broader ex:PCF_11013 .

ex:PCF_11053 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan and initiate compliance program""" ;
    ex:pcfID "11053" ;
    ex:hierarchyID "12.4.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Employing an internal system or process to identify and reduce the risk of breaching the Competition and Consumer Act 2010. Remedy any breach. Create a culture of compliance. Design compliance programs.""" ;
    skos:broader ex:PCF_11047 .

ex:PCF_11054 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Execute compliance program""" ;
    ex:pcfID "11054" ;
    ex:hierarchyID "12.4.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Implementing the established compliance program in order to meet the government laws and regulations. Create a compliance team that scrutinizes the rules set out by government bodies such as the Securities and Exchange Commission.""" ;
    skos:broader ex:PCF_11047 .

ex:PCF_11048 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage outside counsel""" ;
    ex:pcfID "11048" ;
    ex:hierarchyID "12.4.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Managing professionals, sought externally for assistance over legal and ethical concerns. Administer and oversee assistance from subject matter experts and professionals for sourcing expert opinion and counseling over legal and ethical matters.""" ;
    skos:broader ex:PCF_11013 .

ex:PCF_11056 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess problem and determine work requirements""" ;
    ex:pcfID "11056" ;
    ex:hierarchyID "12.4.5.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining the problems and deciding the action requirements for engaging outside counsel. This process element calls upon the organization to internally analyze the issues for which assistance from external counsel is needed. Additionally, the organization needs to break-down the issue, identifying the tasks and exercises where outside counsel can help.""" ;
    skos:broader ex:PCF_11048 .

ex:PCF_11057 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Engage/Retain outside counsel if necessary""" ;
    ex:pcfID "11057" ;
    ex:hierarchyID "12.4.5.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Recruiting the assistance of outside counsel for any legal and/or ethical concerns. Engage and/or retain any external counsel sought from subject matter experts and professionals.""" ;
    skos:broader ex:PCF_11048 .

ex:PCF_11058 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Receive strategy/budget""" ;
    ex:pcfID "11058" ;
    ex:hierarchyID "12.4.5.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Making a financial plan. This strategy sets out, using figures, an organization's expected future results. Enlist the finance function to support work generated by other business functions in order to build and secure their support for the budget.""" ;
    skos:broader ex:PCF_11048 .

ex:PCF_11059 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Receive work product and manage/monitor case and work performed""" ;
    ex:pcfID "11059" ;
    ex:hierarchyID "12.4.5.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Receiving deliverables from outside counsel, and monitoring the efforts committed by them. Track the progress of, collect, and validate the required work product from the subject matter experts and professionals engaged as external counsel. Verify the amount of effort dedicated by these counsels to the issue at hand, in order to confirm their fees.""" ;
    skos:broader ex:PCF_11048 .

ex:PCF_11060 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Process payment for legal services""" ;
    ex:pcfID "11060" ;
    ex:hierarchyID "12.4.5.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Making payments to legal advisers for their services. Payments include addressing issues or suits by customers, suppliers, competitors, bankers, government agencies, etc.""" ;
    skos:broader ex:PCF_11048 .

ex:PCF_11061 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Track legal activity/performance""" ;
    ex:pcfID "11061" ;
    ex:hierarchyID "12.4.5.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Keeping track of the legal activities and performance of the organization. """ ;
    skos:broader ex:PCF_11048 .

ex:PCF_11049 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Protect intellectual property""" ;
    ex:pcfID "11049" ;
    ex:hierarchyID "12.4.6" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Safeguarding the intellectual property of the organization. This process requires the organization to protect a wide variety of intellectual property created by it. It involves creating and managing non-disclosure agreements (NDAs), following up on current developments in the areas where the organization holds patents, tracking the use of the organization's copyrighted material, creating and upholding licensing terms, and administering policies for safeguarding intellectual property.""" ;
    skos:broader ex:PCF_11013 .

ex:PCF_11062 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage copyrights, patents, and trademarks""" ;
    ex:pcfID "11062" ;
    ex:hierarchyID "12.4.6.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing the patents and copyrights already held or sought by the organization. Administer and oversee applying for, securing, and maintaining intellectual property rights in the form of patents and copyrights. Submit applications for such rights. Handle associated legal issues. Draft and communicate proper attributions. Collect royalties. Monitor any misuse of the intellectual property rights.""" ;
    skos:broader ex:PCF_11049 .

ex:PCF_11063 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Maintain intellectual property rights and restrictions""" ;
    ex:pcfID "11063" ;
    ex:hierarchyID "12.4.6.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing the upkeep of intellectual property rights by creating and managing a framework of rules, policies, procedures, and restrictions. Outline a clear policy for any possible scenario of their use by any external agent.""" ;
    skos:broader ex:PCF_11049 .

ex:PCF_11064 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Administer licensing terms""" ;
    ex:pcfID "11064" ;
    ex:hierarchyID "12.4.6.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Administering and overseeing the terms and policies associated with licensing the organization's intellectual property. Create and manage the policies and terms governing the possible granting of a license to any external agent. Demarcate a clear framework that governs the licensing of any patents or copyrights held by the organization.""" ;
    skos:broader ex:PCF_11049 .

ex:PCF_11065 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Administer options""" ;
    ex:pcfID "11065" ;
    ex:hierarchyID "12.4.6.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing options regarding licensing agreements. Follow favorable terms and conditions. """ ;
    skos:broader ex:PCF_11049 .

ex:PCF_11050 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Resolve disputes and litigations""" ;
    ex:pcfID "11050" ;
    ex:hierarchyID "12.4.7" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Resolving disputes or civil lawsuits internally or externally. """ ;
    skos:broader ex:PCF_11013 .

ex:PCF_11051 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Provide legal advice/counseling""" ;
    ex:pcfID "11051" ;
    ex:hierarchyID "12.4.8" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Providing legal advice concerning the substance or procedure of a law in relation to a particular situation.""" ;
    skos:broader ex:PCF_11013 .

ex:PCF_11052 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Negotiate and document agreements/contracts""" ;
    ex:pcfID "11052" ;
    ex:hierarchyID "12.4.9" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Negotiating terms to reach a final draft of a contract that is acceptable to all parties. """ ;
    skos:broader ex:PCF_11013 .

ex:PCF_11014 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage public relations program""" ;
    ex:pcfID "11014" ;
    ex:hierarchyID "12.5" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Managing a public relations programs through business and communications skills. """ ;
    skos:broader ex:PCF_10012 .

ex:PCF_11066 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage community relations""" ;
    ex:pcfID "11066" ;
    ex:hierarchyID "12.5.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing and administering community relations. Establish business connections with the people constituting the environment the organization operates in and draws resources from in order to foster mutual understanding, trust, and support. Create programs that promote the organization's image in a positive and community-oriented way.""" ;
    skos:broader ex:PCF_11014 .

ex:PCF_11067 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage media relations""" ;
    ex:pcfID "11067" ;
    ex:hierarchyID "12.5.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing and managing relations with media. Develop connections with journalists to solicit critical, third-party endorsements for a product, issue, service, or organization.""" ;
    skos:broader ex:PCF_11014 .

ex:PCF_11068 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Promote political stability""" ;
    ex:pcfID "11068" ;
    ex:hierarchyID "12.5.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Promoting political security and stability in the regions where the organization conducts business. Encourage political stability in the regions where the organization operates. Support civic programs, citizen engagement, connection platforms, etc.""" ;
    skos:broader ex:PCF_11014 .

ex:PCF_11069 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create press releases""" ;
    ex:pcfID "11069" ;
    ex:hierarchyID "12.5.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing press releases to communicate developments and generate interest in the organization. """ ;
    skos:broader ex:PCF_11014 .

ex:PCF_11070 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Issue press releases""" ;
    ex:pcfID "11070" ;
    ex:hierarchyID "12.5.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Issuing press releases to carefully selected media in distribution channels such as the web, newspapers, and social media.""" ;
    skos:broader ex:PCF_11014 .

ex:PCF_10013 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and Manage Business Capabilities""" ;
    ex:pcfID "10013" ;
    ex:hierarchyID "13.0" ;
    rdfs:comment "APQC level: Category" ;
    ex:apqcSourceText """Performing activities by an organization that are fundamental to the successful operation of the organization, even across functions in a business. Capabilities defined in the PCF include business process management; portfolio, program, and project management; quality management; change management; benchmarking; environmental health and safety management; and knowledge management.""" .

ex:PCF_16378 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage business processes""" ;
    ex:pcfID "16378" ;
    ex:hierarchyID "13.1" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Establishing and administering governance for management of the processes. Outline and manage the frameworks for management of the processes. Define the business processes. Administer the performance of the processes. Enhance the business processes.""" ;
    skos:broader ex:PCF_10013 .

ex:PCF_16379 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish and maintain process management governance""" ;
    ex:pcfID "16379" ;
    ex:hierarchyID "13.1.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Defining and managing the organization's approach to governing business process management. Establish and manage tools to support the governance process. Assign ownership for all business processes. Perform activities to administer the governing process.""" ;
    skos:broader ex:PCF_16378 .

ex:PCF_16380 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define and manage governance approach""" ;
    ex:pcfID "16380" ;
    ex:hierarchyID "13.1.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Outlining and managing the methodology for administering business process management (BPM). Define the method for setting standards and priorities for BPM efforts. Identify BPM governance leaders. Define BPM project participants' roles.""" ;
    skos:broader ex:PCF_16379 .

ex:PCF_16381 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish and maintain process tools and templates""" ;
    ex:pcfID "16381" ;
    ex:hierarchyID "13.1.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Instituting, organizing, and maintaining the upkeep of the techniques used for business process management (BPM). Create and maintain templates of BPM tools that can be readily implemented, including process engine, business analytics, content management, and collaboration tools.""" ;
    skos:broader ex:PCF_16379 .

ex:PCF_16382 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assign and support process ownership""" ;
    ex:pcfID "16382" ;
    ex:hierarchyID "13.1.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assigning resources (employees) ownership of tasks. These include the responsibility of identifying, analyzing, and improving business processes in order to meet the goals and objectives such as increasing profits and performance, reducing costs, and accelerating schedules.""" ;
    skos:broader ex:PCF_16379 .

ex:PCF_16383 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform process governance activities""" ;
    ex:pcfID "16383" ;
    ex:hierarchyID "13.1.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Implementing and executing activities for governing business processes. Execute activities that encourage participation, accountability, transparency, responsiveness, equity and inclusiveness, etc. within the business processes.""" ;
    skos:broader ex:PCF_16379 .

ex:PCF_16384 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define and manage process frameworks""" ;
    ex:pcfID "16384" ;
    ex:hierarchyID "13.1.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Determining and organizing the structural composition of business processes. Design, establish, and administer the framework. Identify any cross-functional processes that are mandatory for achieving business excellence.""" ;
    skos:broader ex:PCF_16378 .

ex:PCF_16385 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish and maintain process framework""" ;
    ex:pcfID "16385" ;
    ex:hierarchyID "13.1.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining and managing the framework that outlines the required business processes of the organization, key elements, and how they should interact. Institute strategy infrastructure and product, operations, and enterprise management.""" ;
    skos:broader ex:PCF_16384 .

ex:PCF_16386 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify cross-functional processes""" ;
    ex:pcfID "16386" ;
    ex:hierarchyID "13.1.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Recognizing the different functional areas working on the same project or goal. """ ;
    skos:broader ex:PCF_16384 .

ex:PCF_16387 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define processes""" ;
    ex:pcfID "16387" ;
    ex:hierarchyID "13.1.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Outlining and establishing the business processes of the organization. Scope, analyze, map, and publish processes for the employees who may require it.""" ;
    skos:broader ex:PCF_16378 .

ex:PCF_16388 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Scope processes""" ;
    ex:pcfID "16388" ;
    ex:hierarchyID "13.1.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining the extent and limits of business processes. Define the range and diversity of all the set of activities and tasks that, once completed, will accomplish an organizational goal.""" ;
    skos:broader ex:PCF_16387 .

ex:PCF_16389 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze processes""" ;
    ex:pcfID "16389" ;
    ex:hierarchyID "13.1.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing and examining the set of activities and tasks that, once completed, will accomplish an organizational goal. Create a business process model that captures how a business process works and how individuals from different groups work together to achieve a business goal.""" ;
    skos:broader ex:PCF_16387 .

ex:PCF_20140 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify published best practices""" ;
    ex:pcfID "20140" ;
    ex:hierarchyID "13.1.3.2.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Realizing those practices and procedures that are the most effective to the success of the business and making that information available.""" ;
    skos:broader ex:PCF_16389 .

ex:PCF_21452 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify and denote process control points""" ;
    ex:pcfID "21452" ;
    ex:hierarchyID "13.1.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishment of a \"checkpoint\" in a process that prevent the process from continuing unless all requirements are satisfied.  """ ;
    skos:broader ex:PCF_16387 .

ex:PCF_16390 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Model and document processes""" ;
    ex:pcfID "16390" ;
    ex:hierarchyID "13.1.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining what a business entity does, who is responsible, to what standard a business process should be completed, and how the success of a business process can be determined. Identify processes, gather information gathering, interview participants, map processes, and perform analysis.""" ;
    skos:broader ex:PCF_16387 .

ex:PCF_16391 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Publish processes""" ;
    ex:pcfID "16391" ;
    ex:hierarchyID "13.1.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Disclosing the information available on business processes. Ensure the availability of the information regarding the business processes to all process team members, business stakeholders, and process owners. Use BPM software, as well as business process diagrams and documents that help depict the required information.""" ;
    skos:broader ex:PCF_16387 .

ex:PCF_16392 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage process performance""" ;
    ex:pcfID "16392" ;
    ex:hierarchyID "13.1.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Evaluating and handling the performance of business processes. Provide training to process owners. Support the execution of business processes. Measure and report the performance of the business processes.""" ;
    skos:broader ex:PCF_16378 .

ex:PCF_16393 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Provide process training""" ;
    ex:pcfID "16393" ;
    ex:hierarchyID "13.1.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Providing training for the employees and process owners that administer the business processes. Design internal training programs or source third party agencies to provide the skills and training necessary.""" ;
    skos:broader ex:PCF_16392 .

ex:PCF_16394 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Support process execution""" ;
    ex:pcfID "16394" ;
    ex:hierarchyID "13.1.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assisting and executing the business processes. Use business process execution language (BEPL), which is a standard, executable language for specifying actions within the business processes with the use of web services.""" ;
    skos:broader ex:PCF_16392 .

ex:PCF_16395 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Measure and report process performance""" ;
    ex:pcfID "16395" ;
    ex:hierarchyID "13.1.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining and using performance indicators to consider the financial perspective, customer perspective, internal process perspective, and learning perspective of the organization.""" ;
    skos:broader ex:PCF_16392 .

ex:PCF_20141 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify additional metrics as required""" ;
    ex:pcfID "20141" ;
    ex:hierarchyID "13.1.4.3.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining the need for additional performance indicators that would be necessary to successfully achieve the business goal.""" ;
    skos:broader ex:PCF_16395 .

ex:PCF_21453 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Improve processes""" ;
    ex:pcfID "21453" ;
    ex:hierarchyID "13.1.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Identifying, selecting, and managing improvements. Based on the type and scope of the improvement, determination of the appropriate improvement methodology (e.g., Lean, Six Sigma, etc.) should guide the effort. This includes continuous improvement, process redesign, process reengineering, and application of the organizations approaches for Manage projects.""" ;
    skos:broader ex:PCF_16378 .

ex:PCF_16397 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify and select improvement opportunities""" ;
    ex:pcfID "16397" ;
    ex:hierarchyID "13.1.5.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Helping a process owner to identify, analyze, and improve existing business processes within an organization to meet new goals and objectives.""" ;
    skos:broader ex:PCF_21453 .

ex:PCF_11138 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Select process improvement methodology""" ;
    ex:pcfID "11138" ;
    ex:hierarchyID "13.1.5.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing and choosing methodologies to identify, analyze, and improve existing processes within an organization to meet new goals and objective. Assess the various methodologies available such as process mapping, statistical process control, and simulation. Choose the most appropriate and effective methodology.""" ;
    skos:broader ex:PCF_21453 .

ex:PCF_16398 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage improvement projects""" ;
    ex:pcfID "16398" ;
    ex:hierarchyID "13.1.5.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing and implementing a systematic approach to help the organization optimize its underlying processes in order to achieve more efficient results. Systematically gather information to clarify issues or problems. Intervene for improvements. Restructure training programs as appropriate to increase effectiveness. """ ;
    skos:broader ex:PCF_21453 .

ex:PCF_16399 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform continuous improvement activities""" ;
    ex:pcfID "16399" ;
    ex:hierarchyID "13.1.5.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Persistently implementing activities for improving business processes. """ ;
    skos:broader ex:PCF_21453 .

ex:PCF_16400 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage portfolio, program, and project""" ;
    ex:pcfID "16400" ;
    ex:hierarchyID "13.2" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Managing investments, holdings, products, businesses, and brands, along with the related projects that together constitute a program.""" ;
    skos:broader ex:PCF_10013 .

ex:PCF_16401 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage portfolio""" ;
    ex:pcfID "16401" ;
    ex:hierarchyID "13.2.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Managing the business portfolio of the organization, including investments, holdings, products, businesses, and brands. Establish a portfolio strategy. Define portfolio governance. Monitor and control the portfolio.""" ;
    skos:broader ex:PCF_16400 .

ex:PCF_16402 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish portfolio strategy""" ;
    ex:pcfID "16402" ;
    ex:hierarchyID "13.2.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Instituting the strategy for managing business portfolio. Create a systematic plan that defines the strategy for managing investments, holdings, products, businesses, and brands.""" ;
    skos:broader ex:PCF_16401 .

ex:PCF_16403 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define portfolio governance""" ;
    ex:pcfID "16403" ;
    ex:hierarchyID "13.2.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Outlining the administration of business portfolio of the organization. Create and manage the rules and regulations regarding the business processes in order to identify, select, prioritize, and monitor portfolio components. Include a set of metrics to indicate the health and progress of the portfolio in the most vital area.""" ;
    skos:broader ex:PCF_16401 .

ex:PCF_16404 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor and control portfolio""" ;
    ex:pcfID "16404" ;
    ex:hierarchyID "13.2.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Overseeing and administering the business portfolio of the organization. Monitor all activities related to investments, holdings, products, businesses, and brands by effectively monitoring and supervising these activities.""" ;
    skos:broader ex:PCF_16401 .

ex:PCF_16405 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage programs""" ;
    ex:pcfID "16405" ;
    ex:hierarchyID "13.2.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Establishing, implementing, and managing business programs. Successfully handle related projects that together constitute a program. Establish the program structure and approach. Coordinate with stakeholders and partners. Execute the program. Assess and report the performance of the program. Coordinate and prioritize resources across projects. Manage links between the projects and the overall costs and risks of the program.""" ;
    skos:broader ex:PCF_16400 .

ex:PCF_16406 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish program structure and approach""" ;
    ex:pcfID "16406" ;
    ex:hierarchyID "13.2.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Constructing and instituting the framework and approach to manage business programs. Monitor key factors such as governance, alignment with the overall business vision, assurance, and management.""" ;
    skos:broader ex:PCF_16405 .

ex:PCF_16407 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage program stakeholders and partners""" ;
    ex:pcfID "16407" ;
    ex:hierarchyID "13.2.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing relationships with stakeholders and partners of the business programs. """ ;
    skos:broader ex:PCF_16405 .

ex:PCF_16408 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage program execution""" ;
    ex:pcfID "16408" ;
    ex:hierarchyID "13.2.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Administering and implementing business programs. Implement and execute programs with the intention of improving an organization's performance. Execute all the individual projects of the program to ensure the desired success.""" ;
    skos:broader ex:PCF_16405 .

ex:PCF_16409 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review and report program performance""" ;
    ex:pcfID "16409" ;
    ex:hierarchyID "13.2.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating and documenting the performance of business programs. Evaluate the performance of the programs. Create reports on the basis of the analysis. Use performance indicators and metrics such as desired/achieved goals, completion dates, issues and defects, and cost effectiveness.""" ;
    skos:broader ex:PCF_16405 .

ex:PCF_16410 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage projects""" ;
    ex:pcfID "16410" ;
    ex:hierarchyID "13.2.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Establishing the scope of the projects. Create plans for implementing the projects. Initiate projects. Review and report project performance to management. Close projects.""" ;
    skos:broader ex:PCF_16400 .

ex:PCF_16411 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish project scope""" ;
    ex:pcfID "16411" ;
    ex:hierarchyID "13.2.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing the horizons of business projects. Identify the objectives of the program, along with the resource requirements. Assess the readiness for the project management approach. Identify methodologies for project management. Obtain funding. Develop performance measures and indicators.""" ;
    skos:broader ex:PCF_16410 .

ex:PCF_11117 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify project requirements and objectives""" ;
    ex:pcfID "11117" ;
    ex:hierarchyID "13.2.3.1.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Recognizing and defining what the project is ultimately supposed to do. Specify the capabilities, features, or attributes of the project's deliverables, as well as any kind of formal documentation.""" ;
    skos:broader ex:PCF_16411 .

ex:PCF_16412 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify project resource requirements""" ;
    ex:pcfID "16412" ;
    ex:hierarchyID "13.2.3.1.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Identifying the prerequisites of business projects. Identify the people with appropriate and applicable skills and competencies. Locate resources such as capital, facilities, equipment, material, and information required to accomplish the objectives of a specific project.""" ;
    skos:broader ex:PCF_16411 .

ex:PCF_11118 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess culture and readiness for project management approach""" ;
    ex:pcfID "11118" ;
    ex:hierarchyID "13.2.3.1.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Evaluating the culture and readiness of the organizational environment is order to implement the project management approach. """ ;
    skos:broader ex:PCF_16411 .

ex:PCF_11120 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create business case""" ;
    ex:pcfID "11120" ;
    ex:hierarchyID "13.2.3.1.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Creating a document that includes the current situation, proposed solution, financial analysis, conclusion, etc. Convince a decision maker and investors to approve the project. Obtain funding.""" ;
    skos:broader ex:PCF_16411 .

ex:PCF_11121 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop project measures and indicators""" ;
    ex:pcfID "11121" ;
    ex:hierarchyID "13.2.3.1.5" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Developing procedures and indictors to assess performance of business projects. Design and develop metrics and indicators--such as cost, schedule, resources, risk, and quality--that exhibit the performance of the business projects.""" ;
    skos:broader ex:PCF_16411 .

ex:PCF_21454 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prioritize and select projects for the portfolio""" ;
    ex:pcfID "21454" ;
    ex:hierarchyID "13.2.3.1.6" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Stack ranking of projects in the portfolio based upon preestablished criteria. """ ;
    skos:broader ex:PCF_16411 .

ex:PCF_11119 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify appropriate project management methodologies""" ;
    ex:pcfID "11119" ;
    ex:hierarchyID "13.2.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying and implementing the techniques and procedures for managing business projects. Identify the most appropriate models, which are to be employed by the project managers for the purpose of designing, planning, implementing, and achieving project objectives. Examine and assess various project management methodologies such as adaptive project framework, agile development, crystal methods, and feature-driven development.""" ;
    skos:broader ex:PCF_16410 .

ex:PCF_16413 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop project plans""" ;
    ex:pcfID "16413" ;
    ex:hierarchyID "13.2.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining the resources and their roles. Identify IT requirements. Create plans for effective training and communication. Design reward approaches. Plan the launch of project. Deploy the project.""" ;
    skos:broader ex:PCF_16410 .

ex:PCF_11123 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define roles and resources""" ;
    ex:pcfID "11123" ;
    ex:hierarchyID "13.2.3.3.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Outlining the resources and their roles in the business projects. """ ;
    skos:broader ex:PCF_16413 .

ex:PCF_20142 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Acquire/secure project resources""" ;
    ex:pcfID "20142" ;
    ex:hierarchyID "13.2.3.3.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Procuring the necessary resources outlined in Define roles and resources [11123]""" ;
    skos:broader ex:PCF_16413 .

ex:PCF_11124 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify specific IT requirements""" ;
    ex:pcfID "11124" ;
    ex:hierarchyID "13.2.3.3.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining the IT requirements for specific business projects. Identify the requirements of computers and telecommunications equipment to store, retrieve, transmit, and manipulate data related to the project. Consider factors such as functional requirements, design requirements, project phases, and project schedule.""" ;
    skos:broader ex:PCF_16413 .

ex:PCF_11125 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create training and communication plans""" ;
    ex:pcfID "11125" ;
    ex:hierarchyID "13.2.3.3.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Designing a plan for equipping the project team with the necessary skills and abilities to fulfill their roles and responsibilities in the project effectively and efficiently. Offer formal training, mentoring, or coaching. Initiate informal conversations. Communicate messages during the project.""" ;
    skos:broader ex:PCF_16413 .

ex:PCF_11127 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design recognition and reward approaches""" ;
    ex:pcfID "11127" ;
    ex:hierarchyID "13.2.3.3.5" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Creating a plan for recognizing and rewarding extraordinary performances within the business projects. Use incentives, bonuses, and certificates for recognition and rewarding purposes.""" ;
    skos:broader ex:PCF_16413 .

ex:PCF_11128 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design and plan launch of project""" ;
    ex:pcfID "11128" ;
    ex:hierarchyID "13.2.3.3.6" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Creating a plan specifying when to initiate the project, and introducing it to the target audience. Clearly define the project team, objectives, timelines, and milestone.""" ;
    skos:broader ex:PCF_16413 .

ex:PCF_11129 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Deploy the project""" ;
    ex:pcfID "11129" ;
    ex:hierarchyID "13.2.3.3.7" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Putting the project into position by effectively bringing it into action. """ ;
    skos:broader ex:PCF_16413 .

ex:PCF_16414 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Execute projects""" ;
    ex:pcfID "16414" ;
    ex:hierarchyID "13.2.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Implementing the business projects of the organization. Evaluate the impact of project management. Record and report the status of the project. Manage the project scope. Promote and sustain activities and involvement. Realign and revamp the project management strategy and approach. """ ;
    skos:broader ex:PCF_16410 .

ex:PCF_11131 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate impact of project management (strategy and projects) on measures and outcomes""" ;
    ex:pcfID "11131" ;
    ex:hierarchyID "13.2.3.4.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Assessing the impact of business project management on the measures and outcomes of the projects. Gauge non-financial measures, frequency of measurement, action plan, etc.""" ;
    skos:broader ex:PCF_16414 .

ex:PCF_16415 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Report the status of project""" ;
    ex:pcfID "16415" ;
    ex:hierarchyID "13.2.3.4.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Recording and documenting the current status and position of the project. Record and report items such as completed tasks, incomplete tasks, planned tasks, and problems faced.""" ;
    skos:broader ex:PCF_16414 .

ex:PCF_16416 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage project scope""" ;
    ex:pcfID "16416" ;
    ex:hierarchyID "13.2.3.4.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining and documenting a list of specific project goals, deliverables, tasks, costs, and deadlines. Use the scope statement to explain the boundaries of the project. Assign responsibilities for team members. Set up procedures for verifying and approving the completed tasks.""" ;
    skos:broader ex:PCF_16414 .

ex:PCF_11132 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Promote and sustain activity and involvement""" ;
    ex:pcfID "11132" ;
    ex:hierarchyID "13.2.3.4.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Encouraging and sustaining the activities and involvement while executing projects. Promote the execution activities of the projects. Encourage employee involvement in project implementation. """ ;
    skos:broader ex:PCF_16414 .

ex:PCF_21455 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct Project Reviews with Program Managers and other stakeholders""" ;
    ex:pcfID "21455" ;
    ex:hierarchyID "13.2.3.4.5" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Hold post project reviews, lessons learned, or After Action Reviews (AARs) at the end of each project to understand what could be improved during future projects. """ ;
    skos:broader ex:PCF_16414 .

ex:PCF_11133 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Realign and refresh project management strategy and approaches""" ;
    ex:pcfID "11133" ;
    ex:hierarchyID "13.2.3.4.6" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Reorganizing and stimulating the approach and strategy for managing business projects. Make improvements based on the project scope and on findings from Evaluate the impact of project management (strategy and projects) on measures and outcomes [11131].""" ;
    skos:broader ex:PCF_16414 .

ex:PCF_21456 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Adjust project plan as needed""" ;
    ex:pcfID "21456" ;
    ex:hierarchyID "13.2.3.4.7" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Changes to project plans based upon internal and or external influences on the project.  This would include the update to the project plan file, as well as the communication to the team.""" ;
    skos:broader ex:PCF_16414 .

ex:PCF_16417 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review and report project performance""" ;
    ex:pcfID "16417" ;
    ex:hierarchyID "13.2.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Measuring the performance of a business project against key performance indicators including the project scope, schedule, quality, cost, and risk criteria. Identify any deviations from the plan. Assess the impact of these deviations on the project, as well as on the overall program. Report results to key stakeholders.""" ;
    skos:broader ex:PCF_16410 .

ex:PCF_16418 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Close projects""" ;
    ex:pcfID "16418" ;
    ex:hierarchyID "13.2.3.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Settling each contract. Close each contract applicable to the project or project phase. Finalize all activities across all of the process groups in order to formally close the project or a project phase.""" ;
    skos:broader ex:PCF_16410 .

ex:PCF_17471 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage enterprise quality""" ;
    ex:pcfID "17471" ;
    ex:hierarchyID "13.3" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Managing organizational attributes that are closely associated with the quality of output. Determine the quality requirements. Evaluate the correspondence between the quality performance and requirements. Manage non-conformance activities. Ensure implementation and maintenance of the enterprise quality management system. """ ;
    skos:broader ex:PCF_10013 .

ex:PCF_17472 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish quality requirements""" ;
    ex:pcfID "17472" ;
    ex:hierarchyID "13.3.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Determining essential activities, processes, and attributes for securing enterprise quality. Outline critical characteristics for quality. Outline activities encouraging the preservation of quality. Create quality controls. Confirm capabilities in accordance with quality requirements. Finalize the plan for quality maintenance.""" ;
    skos:broader ex:PCF_17471 .

ex:PCF_17473 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define critical-to-quality characteristics""" ;
    ex:pcfID "17473" ;
    ex:hierarchyID "13.3.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Outlining characteristics crucial for managing enterprise quality. Translate broad customer needs into specific, actionable, measurable performance requirements. Define the key measurable characteristics of key products and processes.""" ;
    skos:broader ex:PCF_17472 .

ex:PCF_17474 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define preventive quality activities""" ;
    ex:pcfID "17474" ;
    ex:hierarchyID "13.3.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying gaps in customer requirements and determining whether the gap will be mitigated through preventive Quality activities or deemed as acceptable risk. The goal of any preventive quality activities is to create provisions to prevent, control, or reduce the risk of not meeting the CtQCs. In addition, any standard methodology that will be used to design or conduct preventive Quality activities are defined and documented.""" ;
    skos:broader ex:PCF_17472 .

ex:PCF_17475 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop quality controls""" ;
    ex:pcfID "17475" ;
    ex:hierarchyID "13.3.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing controls for managing the quality of enterprise. Define the process steps for quality controls and the sampling plan. Identify the tools and methods to measure quality. Define the competencies required. """ ;
    skos:broader ex:PCF_17472 .

ex:PCF_17476 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define process steps for controls (or integration points)""" ;
    ex:pcfID "17476" ;
    ex:hierarchyID "13.3.1.3.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Establishing the steps for developing quality controls. Conduct Alpha testing. Have the product team conduct rework. Send the product/service for Beta testing, and carry on rework as needed.""" ;
    skos:broader ex:PCF_17475 .

ex:PCF_17477 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define sampling plan""" ;
    ex:pcfID "17477" ;
    ex:hierarchyID "13.3.1.3.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Establishing a detailed summary including measures, on which material, in what manner, and by whom. Identify the parameters to be measured, the range of possible values, and the required resolution. Provide a sampling scheme that details how and when samples will be taken. Select sample sizes. Assign roles and responsibilities.""" ;
    skos:broader ex:PCF_17475 .

ex:PCF_17478 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify measurement methods""" ;
    ex:pcfID "17478" ;
    ex:hierarchyID "13.3.1.3.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Using tools to measure quality. Use tools such as quality improvement oversight system tool, performance measurement tools, consumer information models/guides, and validation tools to effectively determine the quality levels.""" ;
    skos:broader ex:PCF_17475 .

ex:PCF_17479 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define required competencies""" ;
    ex:pcfID "17479" ;
    ex:hierarchyID "13.3.1.3.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Defining the competencies required for developing quality controls. Define the required competencies including compliance management, audit management, and document control and document management.""" ;
    skos:broader ex:PCF_17475 .

ex:PCF_17480 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prove capability to assess compliance with requirements""" ;
    ex:pcfID "17480" ;
    ex:hierarchyID "13.3.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Demonstrating the ability and capability to confirm and fulfill the quality requirements in front of customers, managers, employees, board members, associations, regulatory bodies, and creditors. Leverage tools and techniques such as process behavior or control charts, statistical process control, measurement system analysis, gage calibration management, and process capability analysis.""" ;
    skos:broader ex:PCF_17472 .

ex:PCF_17481 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Finalize quality plan""" ;
    ex:pcfID "17481" ;
    ex:hierarchyID "13.3.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing how the critical-to-quality characteristics will be achieved, controlled, ensured, and managed throughout the lifecycle of a product/service. Address quality requirements and critical-to-quality characteristics. Conduct a preventive quality assessment. Describe how to verify the product/service, verification criteria, and response to nonconformance. Keep records to demonstrate conformity.""" ;
    skos:broader ex:PCF_17472 .

ex:PCF_17482 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate performance to requirements""" ;
    ex:pcfID "17482" ;
    ex:hierarchyID "13.3.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Analyzing if the performance of the quality plan has achieved the estimated and desired requirements. Conduct tests against the quality plan. Assess the results of these tests.""" ;
    skos:broader ex:PCF_17471 .

ex:PCF_17483 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Test against quality plan""" ;
    ex:pcfID "17483" ;
    ex:hierarchyID "13.3.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining the quality of organizational processes. Conduct tests. Collect information and data. Record the results of these tests. Determine the dispositions of the test results.""" ;
    skos:broader ex:PCF_17482 .

ex:PCF_17484 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct test and collect data""" ;
    ex:pcfID "17484" ;
    ex:hierarchyID "13.3.2.1.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Evaluating quality performance through periodic or episodic testing against the established standards for quality characteristics. For periodic testing, design a schedule with sufficient time to make any required adjustments to the process or system to maintain the desired level of quality. For episodic testing, conduct a test whenever a known non-conformance or fault occurs, which results in outputs or outcomes known to be unsatisfactory to performance requirements.""" ;
    skos:broader ex:PCF_17483 .

ex:PCF_17485 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Record result(s)""" ;
    ex:pcfID "17485" ;
    ex:hierarchyID "13.3.2.1.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Maintaining and recording the results of Test against the quality plan [17483] electronically and in standard formats. Assign ownership to a designated function or role. """ ;
    skos:broader ex:PCF_17483 .

ex:PCF_17486 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine disposition of result(s)""" ;
    ex:pcfID "17486" ;
    ex:hierarchyID "13.3.2.1.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Deciding whether to take any additional actions based on the results of quality tests. Initiate a quarantine disposition and relocated inventory, scrap workflow item and scrap transaction, rework operation, net-able and nonnet-able items, and the activity list.""" ;
    skos:broader ex:PCF_17483 .

ex:PCF_17487 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess results of tests""" ;
    ex:pcfID "17487" ;
    ex:hierarchyID "13.3.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing the significance of the sample. Summarize the results of the test. Recommend improvement actions. Decide what steps to take next.""" ;
    skos:broader ex:PCF_17482 .

ex:PCF_17488 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess sample significance""" ;
    ex:pcfID "17488" ;
    ex:hierarchyID "13.3.2.2.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Assessing the significance of the sample chosen for the test in order to determine whether or not the sample is representative of the larger output or outcome. Determine if the sample meets or does not meet the requirements. Identify the conditions for acceptance, rejection, remediation, and prevention.""" ;
    skos:broader ex:PCF_17487 .

ex:PCF_17489 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Summarize result(s)""" ;
    ex:pcfID "17489" ;
    ex:hierarchyID "13.3.2.2.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Outlining the major facts and figures of the quality test results in order to provide insights and information. Use charts, tables, statistical test results, and written findings and conclusions in a summary of results.""" ;
    skos:broader ex:PCF_17487 .

ex:PCF_17490 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Recommend actions""" ;
    ex:pcfID "17490" ;
    ex:hierarchyID "13.3.2.2.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Recommending measures for improvement. Assess the summarized results to identify areas which can be improved. Suggest actions to management for improving the quality plan basis on the results of the tests.""" ;
    skos:broader ex:PCF_17487 .

ex:PCF_17491 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Decide next steps""" ;
    ex:pcfID "17491" ;
    ex:hierarchyID "13.3.2.2.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Selecting the subsequent actions that the organization can adopt for improving the enterprise quality. Select measures and recommended actions for managing the enterprise quality.""" ;
    skos:broader ex:PCF_17487 .

ex:PCF_17492 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage non-conformance""" ;
    ex:pcfID "17492" ;
    ex:hierarchyID "13.3.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Handling any nonconformance activities or events. Assess the potential impact of the nonconformity. Decide the immediate actions to take. Identify the root causes. Take corrective or preventive action. Ensure future conformance.""" ;
    skos:broader ex:PCF_17471 .

ex:PCF_17493 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess potential impact""" ;
    ex:pcfID "17493" ;
    ex:hierarchyID "13.3.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyzing any nonconformance events. Determine the need for corrective and/or preventative action(s). Leverage root-cause analysis, risk exposure, and other evaluations to properly review and approve/reject subsequent actions.""" ;
    skos:broader ex:PCF_17492 .

ex:PCF_17494 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine immediate action(s)""" ;
    ex:pcfID "17494" ;
    ex:hierarchyID "13.3.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Initiating immediate corrective, preventative, or no action based upon the impact and likelihood of reoccurrence. Consider cost/benefit, risk exposure, timing, the assignment of responsibility, and other pertinent factors .""" ;
    skos:broader ex:PCF_17492 .

ex:PCF_17495 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify root cause(s)""" ;
    ex:pcfID "17495" ;
    ex:hierarchyID "13.3.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Recognizing the reasons that have triggered the nonconformance events or activities. Perform a root-cause analysis through documentary evidence and interviews. Involve the appropriate individuals. Leverage cause analysis and risk assessment.""" ;
    skos:broader ex:PCF_17492 .

ex:PCF_17496 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Take corrective or preventative action""" ;
    ex:pcfID "17496" ;
    ex:hierarchyID "13.3.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Pursuing corrective and preventative activities to eliminate the cause of a detected nonconformity. Define the nonconformity. Communicate and assign responsibility. Identify the appropriate corrective and preventive action. Implement and monitor for reoccurrence. """ ;
    skos:broader ex:PCF_17492 .

ex:PCF_17497 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Close non-conformance""" ;
    ex:pcfID "17497" ;
    ex:hierarchyID "13.3.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Closing nonconformance. Perform all the final processes related to the nonconformance, including documenting root causes. Document corrective and preventive actions.""" ;
    skos:broader ex:PCF_17492 .

ex:PCF_17498 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Implement and maintain the enterprise quality management system (EQMS)""" ;
    ex:pcfID "17498" ;
    ex:hierarchyID "13.3.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Establishing and administering the software that manages content and business processes for quality and compliance across the value chain. Define the quality strategy. Plan and deploy the EQMS scope, targets, and goals. Identify core process controls and metric. Develop EQMS governance. Assess the performance of EQMS. Encourage improvements in EQMS.""" ;
    skos:broader ex:PCF_17471 .

ex:PCF_17499 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define the quality strategy""" ;
    ex:pcfID "17499" ;
    ex:hierarchyID "13.3.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Outlining the strategy for managing enterprise quality. Define and formalize quality techniques and standards. Assign responsibilities for achieving the required quality levels. Standardize the quality maintenance procedure, tools and techniques, recording and reporting, the timing of quality maintenance activities, and the roles and responsibilities for the quality management team.""" ;
    skos:broader ex:PCF_17498 .

ex:PCF_17500 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan and deploy the EQMS scope, targets, and goals""" ;
    ex:pcfID "17500" ;
    ex:hierarchyID "13.3.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing and effectively deploying the scope, targets, and goals of EQMS. Define the role of EQMS through nonconformance/corrective and preventive action, compliance/audit management, risk management, failure mode and effects analysis, and statistical process control. Implement EQMS into operational activities. Define the goals and objectives that are to be achieved by the EQMS.""" ;
    skos:broader ex:PCF_17498 .

ex:PCF_17501 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify core EQMS processes, controls, and metrics""" ;
    ex:pcfID "17501" ;
    ex:hierarchyID "13.3.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Recognizing and implementing the processes, controls, and metrics for maintenance of EQMS. Define the role of EQMS in failure mode and effects analysis, complaint handling, and advanced product quality planning. Establish the role of EQMS in evaluating metrics such as cost of quality, overall equipment effectiveness, on-time and complete shipments, percentage of products in compliance, and new product introductions.""" ;
    skos:broader ex:PCF_17498 .

ex:PCF_17502 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and document EQMS policies, procedures, standards, and measures""" ;
    ex:pcfID "17502" ;
    ex:hierarchyID "13.3.4.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Setting the process limits. Gather required information. Align with other documents and processes. Define the document structure.""" ;
    skos:broader ex:PCF_17498 .

ex:PCF_17503 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess the EQMS performance""" ;
    ex:pcfID "17503" ;
    ex:hierarchyID "13.3.4.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Benchmarking current performance in quality metrics that span across the value chain. Identify gaps in performance as compared to industry peers. Identify and implement complementary EQMS capabilities. Enable a continuous improvement environment.""" ;
    skos:broader ex:PCF_17498 .

ex:PCF_17504 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create environment and capability for EQMS improvement(s)""" ;
    ex:pcfID "17504" ;
    ex:hierarchyID "13.3.4.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Rewarding excellence in quality. Create and maintain quality partnerships. Maintain talent capabilities and competencies. Incorporate EQMS messaging into communication channels. Transfer proven EQMS methods. Consider factors such as EQMS reviews and gap assessments and the alignment and compatibility of business processes and quality. Adopt Lean principles. """ ;
    skos:broader ex:PCF_17498 .

ex:PCF_17505 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Reward quality excellence""" ;
    ex:pcfID "17505" ;
    ex:hierarchyID "13.3.4.6.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Provisioning rewards for achieving quality excellence. Provide monetary and nonmonetary rewards such as compensation, vacations, gift cards, and reimbursements to employees in in recognition of their services, efforts, and achievements in quality excellence.""" ;
    skos:broader ex:PCF_17504 .

ex:PCF_17506 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create and maintain quality partnerships""" ;
    ex:pcfID "17506" ;
    ex:hierarchyID "13.3.4.6.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Establishing and maintaining partnerships with third-party sources to achieve quality excellence. Source and evaluate third-party sources both public and private to ensure that the most effective and efficient partnerships are formed.""" ;
    skos:broader ex:PCF_17504 .

ex:PCF_17507 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Maintain talent capabilities and competencies""" ;
    ex:pcfID "17507" ;
    ex:hierarchyID "13.3.4.6.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Maintaining a common denominator for the competency level within the organization's talent circle. Conduct training sessions, skill development activities, and quality excellence activities to ensure that the resources of the organization are competent enough and have the capabilities to achieve the required level of quality.""" ;
    skos:broader ex:PCF_17504 .

ex:PCF_17508 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Incorporate EQMS messaging into communication channels""" ;
    ex:pcfID "17508" ;
    ex:hierarchyID "13.3.4.6.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Assimilating all the communication related to the EQMS into the organization's already established communication channels. """ ;
    skos:broader ex:PCF_17504 .

ex:PCF_17509 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assure independent EQMS management access to appropriate authority in the organization""" ;
    ex:pcfID "17509" ;
    ex:hierarchyID "13.3.4.6.5" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Ensuring EQMS access to the person in charge of the quality management process. Establish who has the authority to manage the EQMS. Ensure access of EQMS to only the person(s) in authority. """ ;
    skos:broader ex:PCF_17504 .

ex:PCF_17510 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Transfer proven EQMS methods""" ;
    ex:pcfID "17510" ;
    ex:hierarchyID "13.3.4.6.6" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Recording and transferring the best practices and proven methods associated with enterprise quality management systems (EQMS) that can be leveraged in improving the organization's framework. Record proven methodologies and approaches with the objective of communicating them for upgrading, refining, and enhancing the organization's systems.""" ;
    skos:broader ex:PCF_17504 .

ex:PCF_11074 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage change""" ;
    ex:pcfID "11074" ;
    ex:hierarchyID "13.4" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Planning, designing, and implementing the change. Ensure improvement in the change process.""" ;
    skos:broader ex:PCF_10013 .

ex:PCF_21457 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan for change""" ;
    ex:pcfID "21457" ;
    ex:hierarchyID "13.4.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Evaluating impact and planning change activities. Spanning the lifecycle of change from initial concept, to designing, implementing, and sustaining the change, change planning identifies the activities to enage and enable the stakeholders and all impacted by the change. Change plans should address the interplay between people, process, technology, and knowledge to guide the transition, or tranformation, from current state to the future state.""" ;
    skos:broader ex:PCF_11074 .

ex:PCF_11140 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine stakeholders""" ;
    ex:pcfID "11140" ;
    ex:hierarchyID "13.4.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying and communicating with shareholders affected by the change. Consider internal and external stakeholders that will be affected by the change. Determine the amount of influence the change will have on them. Ensure the involvement of these stakeholders in the change process by effectively communicating with them. """ ;
    skos:broader ex:PCF_21457 .

ex:PCF_11139 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess readiness for change""" ;
    ex:pcfID "11139" ;
    ex:hierarchyID "13.4.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the level of preparedness of the conditions, attitudes, and resources at all levels in the organization needed for change to happen successfully. Define scope of the proposed change. Select the tools for a change readiness assessment.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11141 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify change champion(s)""" ;
    ex:pcfID "11141" ;
    ex:hierarchyID "13.4.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying people exhibit an extraordinary interest in the adoption, implementation, and success of the change. Engage champions in each division or team. Define the roles and responsibilities for the change champions. Determine criteria for selecting change champions. Provide training sessions to champions. Reward and recognize champions.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11142 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Form design team""" ;
    ex:pcfID "11142" ;
    ex:hierarchyID "13.4.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Preparing a design team for implementing change throughout the organization. """ ;
    skos:broader ex:PCF_21457 .

ex:PCF_11143 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define scope""" ;
    ex:pcfID "11143" ;
    ex:hierarchyID "13.4.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining the extent of the area or subject matter that the change process deals with or to which it is relevant. Establish a set of tools, processes, skills, and principles for managing the people side of change to achieve the required outcomes of the change process.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11144 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Understand current state""" ;
    ex:pcfID "11144" ;
    ex:hierarchyID "13.4.1.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Using graphical and statistical tools such as pareto diagrams, process flow diagrams, cause-and-effect diagrams, check sheets, histograms, run charts, and scatter diagrams.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11145 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define future state""" ;
    ex:pcfID "11145" ;
    ex:hierarchyID "13.4.1.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the state or position that the organization wants to be in after the implementation of the change. Gather necessary information about the processes, structures, and cultures. Define resource requirements.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11146 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct organizational risk analysis""" ;
    ex:pcfID "11146" ;
    ex:hierarchyID "13.4.1.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Looking beyond the immediate consequences of the threat to a critical asset and placing it in the context of what is important to the organization. Identify the impact of threats to critical assets. Create risk evaluation criteria. Evaluate the impact of threats to critical assets. Incorporate probability into the risk analysis.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11147 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess cultural context""" ;
    ex:pcfID "11147" ;
    ex:hierarchyID "13.4.1.9" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating the culture within the organization. Adopt a quantitative, multidimensional measurement approach of an organization's culture and the aspirations for it. Diagnose cultural activities, enhance leadership sections. Integrate cultures.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_20143 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify impacted groups""" ;
    ex:pcfID "20143" ;
    ex:hierarchyID "13.4.1.10" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Recognizing the impact of threats to critical assets. Determine what groups are impacted by this impact. """ ;
    skos:broader ex:PCF_21457 .

ex:PCF_20144 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine degree/extent of impact""" ;
    ex:pcfID "20144" ;
    ex:hierarchyID "13.4.1.11" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating the impact of threats to critical assets. Determine what assets will be impacted by the change.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11148 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish accountability for change management""" ;
    ex:pcfID "11148" ;
    ex:hierarchyID "13.4.1.12" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying and assigning the people accountable for effective change management. Hold managers accountable for ensuring change happens systematically and rigorously. Ensure that certain behaviors are rewarded or reprimanded accordingly.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11149 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify barriers to change""" ;
    ex:pcfID "11149" ;
    ex:hierarchyID "13.4.1.13" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Recognizing the circumstances or obstacles that keep the organization from progressing. Identify who and what are the resources resisting change. Identify integration failures, threats by competitive forces, and complexity failures.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11150 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine change enablers""" ;
    ex:pcfID "11150" ;
    ex:hierarchyID "13.4.1.14" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying the person(s) or thing(s)responsible for making the change possible. Consider factors such as interdependence of efforts, reward to the integrators, sharing of power and responsibility, and employee understanding of why change is essential.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11151 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify resources and develop measures""" ;
    ex:pcfID "11151" ;
    ex:hierarchyID "13.4.1.15" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Recognizing the resource requirements, and developing measures for change. Identify the financial, material, human, and informational resources needed to successfully implement the change. Develop programs, campaigns, etc. for establishing the change within the organization.""" ;
    skos:broader ex:PCF_21457 .

ex:PCF_11135 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design the change""" ;
    ex:pcfID "11135" ;
    ex:hierarchyID "13.4.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing plans for change management, training, communication, and rewards/incentives. Establish metrics for measuring the change adoption. Clarify new roles for employees. Identify budgets.""" ;
    skos:broader ex:PCF_11074 .

ex:PCF_11152 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess connection to other initiatives""" ;
    ex:pcfID "11152" ;
    ex:hierarchyID "13.4.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Correlating the change initiative with the other initiatives. Create an alignment between the goals and objectives of the change process and that of the other initiatives.""" ;
    skos:broader ex:PCF_11135 .

ex:PCF_11153 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop change management plans""" ;
    ex:pcfID "11153" ;
    ex:hierarchyID "13.4.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a detailed structure summary for the purposes of managing the change. Demonstrate the reasons for the change. Define the type and scope of change. Form a change management team. Create a communication plan. """ ;
    skos:broader ex:PCF_11135 .

ex:PCF_11154 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop training plan""" ;
    ex:pcfID "11154" ;
    ex:hierarchyID "13.4.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a detailed summary of all the actions relevant to teaching a person a particular skill or type of behavior. Determine who will deliver the training. Determine when and where the apprentice or trainee needs to go to receive the structured component of the training.""" ;
    skos:broader ex:PCF_11135 .

ex:PCF_11155 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop communication plan""" ;
    ex:pcfID "11155" ;
    ex:hierarchyID "13.4.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a plan for imparting or exchanging information relevant the to change. Define goals, objectives, and audience. Gather tools for all communications.""" ;
    skos:broader ex:PCF_11135 .

ex:PCF_20145 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assign change champion(s)""" ;
    ex:pcfID "20145" ;
    ex:hierarchyID "13.4.2.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Utilizing champions that have been trained to carry out needed changes. Engage champions to communicate roles and responsibilities for the change. """ ;
    skos:broader ex:PCF_11135 .

ex:PCF_11156 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop rewards/incentives plan""" ;
    ex:pcfID "11156" ;
    ex:hierarchyID "13.4.2.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating and designing the plan for rewarding the employees exhibiting the desired behavior. Specify rewards in recognition of service, effort, or achievement regarding the change, including bonuses, compensation, stock options, profit sharing, vacations, and flexible time.""" ;
    skos:broader ex:PCF_11135 .

ex:PCF_11157 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish change adoption measures""" ;
    ex:pcfID "11157" ;
    ex:hierarchyID "13.4.2.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing a system or standard of measurement for measuring the adoption of the change. Consider activities such as the number of people who have adopted the change, how quickly have they adopted, number of unique adopters, and adopters by teams/divisions.""" ;
    skos:broader ex:PCF_11135 .

ex:PCF_11158 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish/Clarify new roles""" ;
    ex:pcfID "11158" ;
    ex:hierarchyID "13.4.2.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing and explaining the new roles to employees. Assign roles and responsibilities to resources.""" ;
    skos:broader ex:PCF_11135 .

ex:PCF_11159 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify budget/roles""" ;
    ex:pcfID "11159" ;
    ex:hierarchyID "13.4.2.9" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a plan of financial outlay for the newly defined roles. Determine the amount of capital the organization is willing to invest in effectuating these new roles, how would the roles be financed, and what would comprise the ROI from these flows. Coordinate personnel responsible for change management and the finance division.""" ;
    skos:broader ex:PCF_11135 .

ex:PCF_11136 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Implement change""" ;
    ex:pcfID "11136" ;
    ex:hierarchyID "13.4.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Effectuating the change within the desired impact areas of the organization. Ensure adequate commitment from all corners of the organization for the desired change. Create support structures. Refashion all processes deemed necessary. Observe the progress.""" ;
    skos:broader ex:PCF_11074 .

ex:PCF_11160 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create commitment for improvement/change""" ;
    ex:pcfID "11160" ;
    ex:hierarchyID "13.4.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Kindling an organization wide commitment for effectuating the change. Effectively communicate the advantages of the desired change. Personalize the pitch for change. """ ;
    skos:broader ex:PCF_11136 .

ex:PCF_11161 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Reengineer business processes and systems""" ;
    ex:pcfID "11161" ;
    ex:hierarchyID "13.4.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Restructuring, redesigning, repurposing, and/or retrofitting existing business processes, activities, and frameworks in order to effectuate the desired change. Review pertinent processes from the ground up by starting with the desired result. (Build on Select a process improvement methodology [11138] to create business processes that perfectly fit with the road map for change.)""" ;
    skos:broader ex:PCF_11136 .

ex:PCF_11162 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Support transition to new roles or exit strategies for incumbents""" ;
    ex:pcfID "11162" ;
    ex:hierarchyID "13.4.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Supporting the transition of personnel to new roles and the dismissal of any existing employees, necessitated for the desired change. Create an on-boarding process for seamlessly transitioning personnel to new roles. Offer orientation and training. Address any concerns. Create a structured procedure for the discharge of incumbents from their positions.""" ;
    skos:broader ex:PCF_11136 .

ex:PCF_11163 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor change""" ;
    ex:pcfID "11163" ;
    ex:hierarchyID "13.4.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Monitoring activities in the change process in order to assess the performance of individual agents and the process as a whole. Oversee the implementation of activities needed for effectuating the change. Track the pace, impact, enthusiasm, reaction, and feedback over the change process.""" ;
    skos:broader ex:PCF_11136 .

ex:PCF_20146 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Report on change""" ;
    ex:pcfID "20146" ;
    ex:hierarchyID "13.4.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Reporting on the outcome of the change. Document changes and the impact those changes had on critical assets. Share findings with those within the target audience: those impacted by the change, change champions, stakeholders, etc.""" ;
    skos:broader ex:PCF_11136 .

ex:PCF_11137 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Sustain improvement""" ;
    ex:pcfID "11137" ;
    ex:hierarchyID "13.4.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Sustaining the impact of the change process in order to enact continual process improvement. Monitor the performance of re-engineered business processes. Identify best practices and potential issues. Effectuate remedial steps.""" ;
    skos:broader ex:PCF_11074 .

ex:PCF_11164 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor improved process performance""" ;
    ex:pcfID "11164" ;
    ex:hierarchyID "13.4.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Monitoring the performance of improved business processes. Track the key performance indicators of the upgraded processes in order to gauge its contribution to the desired change. Expedite through the use of business process management software.""" ;
    skos:broader ex:PCF_11137 .

ex:PCF_11165 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Capture and reuse lessons learned from change process""" ;
    ex:pcfID "11165" ;
    ex:hierarchyID "13.4.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Documenting and standardizing insights gleaned and the knowledge acquired from studying the change process already implemented. Create case studies/best practices guides from the process of implementing change. Include experienced personnel. """ ;
    skos:broader ex:PCF_11137 .

ex:PCF_11166 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Take corrective action as necessary""" ;
    ex:pcfID "11166" ;
    ex:hierarchyID "13.4.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Implement corrective action to adjust the re-engineered processes for maximizing the desired impact. Adjust business processes and systems to implement the desired change.""" ;
    skos:broader ex:PCF_11137 .

ex:PCF_11073 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage enterprise-wide knowledge management (KM) capability""" ;
    ex:pcfID "11073" ;
    ex:hierarchyID "13.5" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Creating and administering the capability of the organization's knowledge management function. Develop a strategy for knowledge management. Assess capabilities of the knowledge management function. """ ;
    skos:broader ex:PCF_10013 .

ex:PCF_11095 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop KM strategy""" ;
    ex:pcfID "11095" ;
    ex:hierarchyID "13.5.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating a plan for managing the organization's knowledge base. Determine what kind of specialized knowledge the organization possesses, which elements of this collective knowledge can prove beneficial, how to capture and maintain this knowledge, how to grant access to this library of information, and how the organization should proceed.""" ;
    skos:broader ex:PCF_11073 .

ex:PCF_11100 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop governance model with roles and accountability""" ;
    ex:pcfID "11100" ;
    ex:hierarchyID "13.5.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a structure for the governance of the organization's collective knowledge. Gather, maintain, and make accessible the collective knowledge base. Develop a standard procedure for the conservation and perpetuation of the organization's knowledge. Create policies for the usage and maintenance of this knowledge. Establish specialized roles.""" ;
    skos:broader ex:PCF_11095 .

ex:PCF_11102 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define roles and accountability of core group versus operating units""" ;
    ex:pcfID "11102" ;
    ex:hierarchyID "13.5.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Clearly determining the roles and responsibilities of all personnel involved in the management of the organization's corpus of knowledge. Flesh out the roles and responsibilities of the KM core group, as well as the operational staff involved in the upkeep of the knowledge management program.""" ;
    skos:broader ex:PCF_11095 .

ex:PCF_11103 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop funding models""" ;
    ex:pcfID "11103" ;
    ex:hierarchyID "13.5.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyze the organization's current approach to funding. Learn from the funding approaches of peer organizations. Evaluate the revenue potential and costs of those short-list funding models. Select funding models to implement.""" ;
    skos:broader ex:PCF_11095 .

ex:PCF_11104 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify links to key initiatives""" ;
    ex:pcfID "11104" ;
    ex:hierarchyID "13.5.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying any links that exist between the strategy for knowledge management and any other functional areas. Determine any correlations that exist between the strategic road map for the knowledge management and any other functional areas. Study each function's/unit's attributes.""" ;
    skos:broader ex:PCF_11095 .

ex:PCF_11105 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop core KM methodologies""" ;
    ex:pcfID "11105" ;
    ex:hierarchyID "13.5.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating core knowledge management procedures and methodologies. Initiate developing a strategy, planning, execution, and improvement.""" ;
    skos:broader ex:PCF_11095 .

ex:PCF_11106 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess IT needs and engage IT function""" ;
    ex:pcfID "11106" ;
    ex:hierarchyID "13.5.1.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the IT needs for developing the knowledge management strategy, and collaborating with the IT function to implement the strategy. Assess requirements for technologies such as computer hardware, software, electronics, semiconductors, internet, and telecommunications equipment in order to effectively build and implement the strategy for knowledge management.""" ;
    skos:broader ex:PCF_11095 .

ex:PCF_11107 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop training and communication plans""" ;
    ex:pcfID "11107" ;
    ex:hierarchyID "13.5.1.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating plans for KM training plans and conveying the knowledge management strategy within the organization. Create training programs, sessions, and activities in order to familiarize employees and management with the concept of knowledge management.""" ;
    skos:broader ex:PCF_11095 .

ex:PCF_11108 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop change management approaches""" ;
    ex:pcfID "11108" ;
    ex:hierarchyID "13.5.1.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating approaches for effectively administering the changes in knowledge management. Design an approach that transforms individuals, teams, and the organization to a desired future state represented by the change.""" ;
    skos:broader ex:PCF_11095 .

ex:PCF_11109 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop strategic measures and indicators""" ;
    ex:pcfID "11109" ;
    ex:hierarchyID "13.5.1.9" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing measures and indicators for evaluating the performance of the knowledge management function. Define key performance indicators such as the amount of knowledge assets created and number of knowledge projects undertaken.""" ;
    skos:broader ex:PCF_11095 .

ex:PCF_11096 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess KM capabilities""" ;
    ex:pcfID "11096" ;
    ex:hierarchyID "13.5.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Assessing the maturity of the existing initiatives in knowledge management, and evaluating existing KM approaches. Identify the gaps and needs in order to enhance the existing KM approaches. Develop and implement new KM approaches.""" ;
    skos:broader ex:PCF_11073 .

ex:PCF_11110 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess maturity of existing KM initiatives""" ;
    ex:pcfID "11110" ;
    ex:hierarchyID "13.5.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating if initiatives are effective or should be discarded. Design a framework for assessing maturity, typically from Level 1 (undefined), Level 2 (repeatable), Level 3 (defined), and Level 4 (managed) through Level 5 (optimized).""" ;
    skos:broader ex:PCF_11096 .

ex:PCF_11111 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate existing KM approaches""" ;
    ex:pcfID "11111" ;
    ex:hierarchyID "13.5.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating existing procedures, policies, and guidelines for knowledge management. Study and examine the organization's approach against industry best practices by benchmarking, competitive analysis, etc.""" ;
    skos:broader ex:PCF_11096 .

ex:PCF_11112 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify gaps and needs""" ;
    ex:pcfID "11112" ;
    ex:hierarchyID "13.5.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing the KM approach evaluations in order to identify any gaps or needs. Compare the performance of the KM approach against the desired or expected performance, as well as against the standard knowledge management industry approach.""" ;
    skos:broader ex:PCF_11096 .

ex:PCF_20965 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design and implement KM capabilities""" ;
    ex:pcfID "20965" ;
    ex:hierarchyID "13.5.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating knowledge bases and other repositories to preserve and develop company expertise, and to train new employees.""" ;
    skos:broader ex:PCF_11073 .

ex:PCF_11114 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop new KM approaches""" ;
    ex:pcfID "11114" ;
    ex:hierarchyID "13.5.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Designing new policies, procedures, and guidelines to support knowledge management.""" ;
    skos:broader ex:PCF_20965 .

ex:PCF_20966 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design resource model for KM approaches""" ;
    ex:pcfID "20966" ;
    ex:hierarchyID "13.5.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a model to describe resources and approaches to organization's knowledge management. Establish standards and guidelines to be followed.""" ;
    skos:broader ex:PCF_20965 .

ex:PCF_11115 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Implement new KM approaches""" ;
    ex:pcfID "11115" ;
    ex:hierarchyID "13.5.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Implementing new policies, procedures, and guidelines to support knowledge management.""" ;
    skos:broader ex:PCF_20965 .

ex:PCF_20967 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Leverage and enhance IT for KM approaches""" ;
    ex:pcfID "20967" ;
    ex:hierarchyID "13.5.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Using existing technologies to improve organization's knowledge management processes. Research available third-party offerings. Develop proprietary solutions. Employ knowledge engineers, data scientists and other relevant personnel.""" ;
    skos:broader ex:PCF_20965 .

ex:PCF_20968 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop measures""" ;
    ex:pcfID "20968" ;
    ex:hierarchyID "13.5.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating metrics that can be used to systematically describe KM approaches and capabilities. Choose applicable scales, benchmarks and units of measure. Determine required precision and error rates.""" ;
    skos:broader ex:PCF_20965 .

ex:PCF_20969 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evolve and sustain KM capabilities""" ;
    ex:pcfID "20969" ;
    ex:hierarchyID "13.5.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing resources for improved knowledge management and knowledge engineering.""" ;
    skos:broader ex:PCF_11073 .

ex:PCF_11113 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Enhance/Modify existing KM approaches""" ;
    ex:pcfID "11113" ;
    ex:hierarchyID "13.5.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Leveraging KM evaluations and identified gap to enhance existing approaches. """ ;
    skos:broader ex:PCF_20969 .

ex:PCF_20970 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """ Sustain awareness and engagement""" ;
    ex:pcfID "20970" ;
    ex:hierarchyID "13.5.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing awareness about available knowledge bases and promoting their use to maximize their impact.""" ;
    skos:broader ex:PCF_20969 .

ex:PCF_20971 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Expand KM infrastructure to meet demand""" ;
    ex:pcfID "20971" ;
    ex:hierarchyID "13.5.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Augmenting available resources to better leverage the offerings of the organization to serve existing clients and to expand the client base.""" ;
    skos:broader ex:PCF_20969 .

ex:PCF_21584 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Measure and benchmark""" ;
    ex:pcfID "21584" ;
    ex:hierarchyID "13.6" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Defining and managing measurement and benchmarking. Measure and benchmark the performance of internal processes, as well as the organization as a whole.""" ;
    skos:broader ex:PCF_10013 .

ex:PCF_21585 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define and manage organizational performance strategy""" ;
    ex:pcfID "21585" ;
    ex:hierarchyID "13.6.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating and implementing a strategy for managing organizational performance. The strategy should include approaches for measuring, tracking, streamlining, and improving internal performance. It encompasses a blueprint for the tactical measurement of internal processes and work force improvement, in alignment with Employee Metrics Developed and Managed [10526].""" ;
    skos:broader ex:PCF_21584 .

ex:PCF_11075 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define enterprise measurement models""" ;
    ex:pcfID "11075" ;
    ex:hierarchyID "13.6.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a model for organization's management systems. Develop a high-level measurement system to track performance across the enterprise or in specific functions or business units. Determine which processes to measure, which measures to use, how often to measure, and measurement targets. Review strategic decisions about how to best measure an organization.""" ;
    skos:broader ex:PCF_21585 .

ex:PCF_21586 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Maintain enterprise measurement models""" ;
    ex:pcfID "21586" ;
    ex:hierarchyID "13.6.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Reviewing, evaluating, and updating enterprise measurement models. Align measurement models to current and future goals and performance targets, and make adjustments to support visibility and reporting needs across the organization.""" ;
    skos:broader ex:PCF_21585 .

ex:PCF_11072 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Benchmark performance""" ;
    ex:pcfID "11072" ;
    ex:hierarchyID "13.6.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Comparing organizational performance internally or externally with other organizations. """ ;
    skos:broader ex:PCF_21584 .

ex:PCF_11083 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct performance assessments""" ;
    ex:pcfID "11083" ;
    ex:hierarchyID "13.6.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Measuring, researching, and recording the performance of people, processes, mechanisms, or other areas of the business that the organization wants to benchmark or track.""" ;
    skos:broader ex:PCF_11072 .

ex:PCF_11084 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop benchmarking capabilities""" ;
    ex:pcfID "11084" ;
    ex:hierarchyID "13.6.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Improving an organization's ability to compare its performance internally or externally, and maintaining benchmarking relationships with other organizations. Train staff in benchmarking. Develop technological solutions or other materials to aid benchmarking efforts. Consult with external entities to gain knowledge or tools to help benchmark.""" ;
    skos:broader ex:PCF_11072 .

ex:PCF_11085 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct internal and external benchmarking""" ;
    ex:pcfID "11085" ;
    ex:hierarchyID "13.6.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Benchmarking internal processes and against external competitors. """ ;
    skos:broader ex:PCF_11072 .

ex:PCF_11087 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct gap analysis""" ;
    ex:pcfID "11087" ;
    ex:hierarchyID "13.6.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining performance against benchmarked organizations or entities. Determine how much performance needs to change to meet expectations. Reach strategic goals.""" ;
    skos:broader ex:PCF_11072 .

ex:PCF_11088 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
