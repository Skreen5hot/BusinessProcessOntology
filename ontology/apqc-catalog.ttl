    ex:apqcSourceText """Creating and maintaining relationships with government and industry representatives. """ ;
    skos:broader ex:PCF_10012 .

ex:PCF_11038 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage government relations""" ;
    ex:pcfID "11038" ;
    ex:hierarchyID "12.2.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Persuading public and government policy at the local, regional, national, and global level (subject to government regulations).""" ;
    skos:broader ex:PCF_11011 .

ex:PCF_12869 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess relationships""" ;
    ex:pcfID "12869" ;
    ex:hierarchyID "12.2.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Ascertaining how the business entity relates to all levels of government. Identify areas that needs further growth and resources to foster those relationships.""" ;
    skos:broader ex:PCF_11038 .

ex:PCF_12870 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Appoint responsible executives""" ;
    ex:pcfID "12870" ;
    ex:hierarchyID "12.2.1.2" ;
