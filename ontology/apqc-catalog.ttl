    ex:pcfID "20648" ;
    ex:hierarchyID "8.1.7" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Proactively manage IT service levels against IT customer requirements.""" ;
    skos:broader ex:PCF_20608 .

ex:PCF_20649 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
