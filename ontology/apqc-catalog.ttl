    ex:hierarchyID "8.1.4.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Supporting business case with supporting research, business analysis, and background information on IT transformation.""" ;
    skos:broader ex:PCF_20623 .

ex:PCF_20631 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
