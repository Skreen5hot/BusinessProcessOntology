    ex:hierarchyID "9.4.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating procedures and policies to follow for investing in capital projects. Create rules and regulations regarding large investment plans, which require in-depth forecasting for expenditure and revenue.""" ;
    skos:broader ex:PCF_10751 .

ex:PCF_10845 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and approve capital expenditure plans and budgets""" ;
    ex:pcfID "10845" ;
    ex:hierarchyID "9.4.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating budgets, and soliciting approvals for capital projects. Prepare budgets for projects that require heavy investments. Secure approvals from management.""" ;
    skos:broader ex:PCF_10751 .

ex:PCF_10846 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
