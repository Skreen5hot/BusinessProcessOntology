    skos:prefLabel """Receive Request For Proposal (RFP)/Request For Quote (RFQ)""" ;
    ex:pcfID "11781" ;
    ex:hierarchyID "3.5.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Accepting procurement proposals. """ ;
    skos:broader ex:PCF_11779 .

