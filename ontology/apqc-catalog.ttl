    ex:hierarchyID "11.3.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Studying the causes of damage, which could be environmental, physical, social, etc. at country level in order to institute better policies and regulations.""" ;
    skos:broader ex:PCF_11185 .

