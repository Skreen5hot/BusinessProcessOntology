@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix cco:   <https://www.commoncoreontologies.org/> .
@prefix ex:    <http://example.org/apqc#> .
@prefix apqc:  <http://example.org/apqc/scheme#> .

####################################################################
# APQC PCF -> CATALOG LAYER  (GENERATED -- do not hand-edit)
#
# ADR-001 R1: every PCF row, all levels, as a catalog node.
#   node a owl:NamedIndividual, cco:ont00000853 (Descriptive ICE), skos:Concept
#   skos:inScheme apqc:PCF ; prefLabel ; ex:pcfID/hierarchyID/apqcSourceText
#   dotted hierarchy -> skos:broader  (CURATORIAL relation, NOT parthood; R7)
#
# Regenerate:  python -m src.apqc_transform.catalog
# CCO pin: 2.0 (2024-11-06)
####################################################################

<http://example.org/apqc/scheme> a owl:Ontology ;
    dct:title "APQC PCF Catalog Layer" ;
    dct:source "APQC Process Classification Framework (Cross-Industry) v7.4" ;
    owl:versionInfo "0.1.0" ;
    rdfs:comment "Generated deterministically from the PCF export. Curatorial taxonomy only; process semantics live in the reality-layer slice modules." .

# Provenance annotation properties (mirror the reference module)
ex:pcfID a owl:AnnotationProperty ; rdfs:label "APQC PCF ID" .
ex:hierarchyID a owl:AnnotationProperty ; rdfs:label "APQC Hierarchy ID" ;
    rdfs:comment "Positional dotted-decimal locator. NON-STABLE across PCF versions." .
ex:apqcSourceText a owl:AnnotationProperty ; rdfs:label "APQC source description" .
ex:designatesProcessType a owl:AnnotationProperty ; rdfs:label "designates process type" ;
    rdfs:comment "ADR-001 R4 bridge: catalog node -> reality-layer process universal or capability. Populated during reality-layer modeling, NOT by the catalog generator." .

apqc:PCF a skos:ConceptScheme ;
    rdfs:label "APQC Process Classification Framework (Cross-Industry)" ;
    skos:prefLabel "APQC PCF Cross-Industry v7.4" .

####################################################################
# CATALOG NODES
####################################################################


ex:PCF_10002 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop Vision and Strategy""" ;
    ex:pcfID "10002" ;
    ex:hierarchyID "1.0" ;
    rdfs:comment "APQC level: Category" ;
    ex:apqcSourceText """Establishing a direction and vision for an organization. This involves defining the business concept and long-term vision, as well as developing the business strategy and managing strategic initiatives. Processes in this category focus on creating a vision, a mission, and strategic objectives, and culminate in creating measures to ensure that the organization is moving in the desired direction.""" .

ex:PCF_17040 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define the business concept and long-term vision""" ;
    ex:pcfID "17040" ;
    ex:hierarchyID "1.1" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Creating a conceptual framework of the organization's business activity and strategic vision with long-term applicability. Scout the organization's internal capabilities, as well as the customer's needs and desires, to identify a fit that can be used to advance a conceptual structure of the organization's business activity. Conduct analysis in light of relevant externalities and large-scale shifts in the market landscape.""" ;
    skos:broader ex:PCF_10002 .

ex:PCF_10017 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess the external environment""" ;
    ex:pcfID "10017" ;
    ex:hierarchyID "1.1.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Assessing all forces, entities, and systems that are external to an organization but can affect its operation. Analyze far-reaching currents in the macroeconomic situation, assess the competition, evaluate technological changes, and identify societal as well as ecological issues of concern. Create a big-picture understanding of externalities, with sufficient depth across individual aspects.""" ;
    skos:broader ex:PCF_17040 .

ex:PCF_19945 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify competitors""" ;
    ex:pcfID "19945" ;
    ex:hierarchyID "1.1.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying your competitors, their service and/or product. Evaluating competitors strategies to determine their strengths and weaknesses relative to those of your own product or service.""" ;
    skos:broader ex:PCF_10017 .

ex:PCF_10021 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze and evaluate competition""" ;
    ex:pcfID "10021" ;
    ex:hierarchyID "1.1.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing the competitive forces in the marketplace that could potentially affect the organization. Analyze various aspects of business competition including competing firms. Aggregate competitive intelligence, create benchmarks to juxtapose processes and performance metrics, and inject crucial information about the competition into management models to synthesize insights.""" ;
    skos:broader ex:PCF_10017 .

ex:PCF_21421 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify potential product or service alternatives""" ;
    ex:pcfID "21421" ;
    ex:hierarchyID "1.1.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining if there are other existing products or services in the marketplace, and building the business case to make a go/no go decision based upon substitutions.  """ ;
    skos:broader ex:PCF_10017 .

ex:PCF_10022 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify economic trends""" ;
    ex:pcfID "10022" ;
    ex:hierarchyID "1.1.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining large-scale macroeconomic shifts and trends, with medium to long-term relevance for the organization. Vet the immediate and the larger economic ecosystem to identify broad-based movements that affect the organization. In the immediate vicinity, for example, examine the stock price of key vendors/suppliers in the organizational value-chain. In the larger economic ecosystem, analyze according to geographical distribution where factors such as interest rates, taxation structures, oil prices, and unemployment rates are explored.""" ;
    skos:broader ex:PCF_10017 .

ex:PCF_10023 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify political and regulatory factors""" ;
    ex:pcfID "10023" ;
    ex:hierarchyID "1.1.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying areas of concern pertaining to public policy and regulation, established by sovereign or multinational authorities. Examine various regions and geopolitical formations to identify those political and regulatory issues-present or developing-that can potentially affect the organization. Plan for an iterative process, partitioned across regional and geopolitical entities that have a direct bearing on the organization's activities. Assess changes in environmental compliance, product standards, trade barriers, etc.""" ;
    skos:broader ex:PCF_10017 .

ex:PCF_10027 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify environmental factors""" ;
    ex:pcfID "10027" ;
    ex:hierarchyID "1.1.1.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying changes in ecological ecosystems that can be directly or indirectly detrimental to the organization. Analyze ecological factors within the immediate ecosystem for near to middle-term impact. Analyze the ecology, at large, to get a sense of long-term shifts and concerns. Gather analyses from research publications. Speak to subject matter experts. Engage with advocacy groups, lawyers, journalists, and the active populations.""" ;
    skos:broader ex:PCF_10017 .

ex:PCF_10026 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify social and cultural changes""" ;
    ex:pcfID "10026" ;
    ex:hierarchyID "1.1.1.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Distinguishing changes in societal makeup, as well as the cultural composite. Isolate shifts in the societal composition and distribution, as well as the value systems and attributes that bind the organization together. Analyze well-regarded publications--and gather the perspective of public intellectuals and opinion leaders--on relevant issues.""" ;
    skos:broader ex:PCF_10017 .

ex:PCF_10024 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess new technologies""" ;
    ex:pcfID "10024" ;
    ex:hierarchyID "1.1.1.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing developments in technologies presently being used by the business, new technologies that have a potential for the business, and any disruptive innovations. Conduct a survey of advancement in technologies that are already deployed with inputs from the personnel closely working with them, tracking utility and feasibility for deployment. Arrange for mid- to senior-level management personnel who explore contingent uses to assess new and disruptive technologies. Follow up with desk research, involving physical scoping and viability assessment.""" ;
    skos:broader ex:PCF_10017 .

ex:PCF_10025 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze demographics""" ;
    ex:pcfID "10025" ;
    ex:hierarchyID "1.1.1.9" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyzing statistical data relating to the size, distribution, and composition of relevant populations, as well as their characteristics. Perform quantitative analysis over raw data-sets gathered from well-founded sources such as government census or large, private databases. Consider employing primary research in collecting required statistics. Use comprehensive studies (reports, briefs, and articles) to assist with the analysis, in place of raw data.""" ;
    skos:broader ex:PCF_10017 .

ex:PCF_16790 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate intellectual property""" ;
    ex:pcfID "16790" ;
    ex:hierarchyID "1.1.1.10" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing measures and procedures for identifying various intellectual property threats and concerns.""" ;
    skos:broader ex:PCF_10017 .

ex:PCF_10018 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Survey market and determine customer needs and wants""" ;
    ex:pcfID "10018" ;
    ex:hierarchyID "1.1.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Examining the market to identify customer required solutions. Assess the relevant market(s) to determine the products/services that are needed or wanted by customers. Carry out quantitative and qualitative analyses to capture and investigate products/services. Employ creative techniques that allow for a closer appreciation of the customer, and design relevant solutions.""" ;
    skos:broader ex:PCF_17040 .

ex:PCF_10028 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct qualitative/quantitative research and assessments""" ;
    ex:pcfID "10028" ;
    ex:hierarchyID "1.1.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Investigating key market features and customer characteristics, using qualitative and quantitative measures to capture relevant aspects. Distill key ingredients that allow the organization to Capture customer needs and wants [19946], and Assess customer needs and wants [19947]. Conduct standardized appraisals by defining selection parameters and setting quotas.""" ;
    skos:broader ex:PCF_10018 .

ex:PCF_19946 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Capture customer needs and wants""" ;
    ex:pcfID "19946" ;
    ex:hierarchyID "1.1.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying and collecting customers' wants and needs of a product and/or services from a marketing perspective. Identify which consumer needs are important and whether needs are being met by current products/services. """ ;
    skos:broader ex:PCF_10018 .

ex:PCF_19947 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess customer needs and wants""" ;
    ex:pcfID "19947" ;
    ex:hierarchyID "1.1.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating customer profiles to get a picture of customers and their needs. Identify particular groups of people/organizations that benefit from your product/services and then selling to them.""" ;
    skos:broader ex:PCF_10018 .

ex:PCF_10019 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess the internal environment""" ;
    ex:pcfID "10019" ;
    ex:hierarchyID "1.1.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Undertaking a review of the organization's in-house skills and resources in order to create a big-picture understanding of internal capacities. Assess the organization's capabilities in order to advance the advantageous and weed out the detrimental aspects. Identify synergic associations within the backdrop of the forces and players active in the market, and take into account all externalities.""" ;
    skos:broader ex:PCF_17040 .

ex:PCF_10030 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze organizational characteristics""" ;
    ex:pcfID "10030" ;
    ex:hierarchyID "1.1.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying and examining key attributes that differentiate the organization in the market and those that underscore the core of its operations. Consider how the organization functions. Reflect over tangible and intangible aspects in order to spot critical correlations and the interplay between these attributes. Have senior executives conduct the analysis, with input from management and operational personnel.""" ;
    skos:broader ex:PCF_10019 .

ex:PCF_19948 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze internal operations""" ;
    ex:pcfID "19948" ;
    ex:hierarchyID "1.1.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identify key elements of operations and measure effectiveness of these elements within internal operations.""" ;
    skos:broader ex:PCF_10019 .

ex:PCF_10031 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create baselines for current processes""" ;
    ex:pcfID "10031" ;
    ex:hierarchyID "1.1.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing baselines that provide standards for assessing performance levels and allow for a relational benchmarking of current processes. Undertake a survey of archival performance records, conducted in conjunction by the management and the operations personnel. Take into account the organization's internal objectives, particularly for process improvement and enhancement. Understand industry best practices.""" ;
    skos:broader ex:PCF_10019 .

ex:PCF_10032 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze systems and technology""" ;
    ex:pcfID "10032" ;
    ex:hierarchyID "1.1.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyzing the capabilities of technology and process automation systems deployed within the organization in order to direct future associated processes. Conduct a broad-based survey to examine various aspects associated with such systems and technologies, with the objective of identifying key facets that are of interest. Investigate the intended purpose, purpose served, utility, longevity, remaining service-life, repair or service requirements, etc.""" ;
    skos:broader ex:PCF_10019 .

ex:PCF_10033 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze financial health""" ;
    ex:pcfID "10033" ;
    ex:hierarchyID "1.1.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Appraising the financial state of the organization so that management can create resource allocation strategies. Scrutinize the organization's financials--including balance sheets, statements of income, cash-flows, equity holdings, and liquidity--with the objective of understanding the organization's financial health and capacities. (This analysis directly feeds into Conduct organizational restructuring opportunities [16792] and Define a business concept and long-term vision [17040].)""" ;
    skos:broader ex:PCF_10019 .

ex:PCF_10034 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify core competencies""" ;
    ex:pcfID "10034" ;
    ex:hierarchyID "1.1.3.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining a strategically significant aggregate of competence and capacities that differentiates the organization in the market. Identify distinguishing attributes including unique skills and resources and its brand and services in the marketplace. Have senior executives and management personnel assess competencies in order to further develop these capabilities into distinct commercial value propositions.""" ;
    skos:broader ex:PCF_10019 .

ex:PCF_10020 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish strategic vision""" ;
    ex:pcfID "10020" ;
    ex:hierarchyID "1.1.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Establishing the organization's long-term vision as a strategic positioning and engagement of stakeholders. Institute the vision by creating strategic orientations of all stakeholders. Understand the strategy development frameworks in this context.""" ;
    skos:broader ex:PCF_17040 .

ex:PCF_19949 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define the strategic vision""" ;
    ex:pcfID "19949" ;
    ex:hierarchyID "1.1.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing goals to define organizations vision. Define and document ideas, direction, and activities which enable the organization to reach these goals.""" ;
    skos:broader ex:PCF_10020 .

ex:PCF_10035 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Align stakeholders around strategic vision""" ;
    ex:pcfID "10035" ;
    ex:hierarchyID "1.1.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Orienting those entities, associated with the organization that have a direct bearing on its operations and output, in a way that advances its strategic vision. Map all stakeholders in strategic configurations, within the architectural layout of the marketplace, and position the organization relative to them. (This exercise is undertaken by senior strategy personnel, drawing upon the process Define a business concept and long-term vision [17040].)""" ;
    skos:broader ex:PCF_10020 .

ex:PCF_10036 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Communicate strategic vision to stakeholders""" ;
    ex:pcfID "10036" ;
    ex:hierarchyID "1.1.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing and executing communication strategies to convey an alignment plan of all organizational stakeholders, which helps the organization realize its vision. Create custom communication strategies and delivery channels with the objective of orienting stakeholders according to the configuration maps created in the process Align stakeholders around a strategic vision [10035]. Have senior strategy personnel closely collaborate with the communications/marketing team.""" ;
    skos:broader ex:PCF_10020 .

ex:PCF_16792 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct organization restructuring opportunities""" ;
    ex:pcfID "16792" ;
    ex:hierarchyID "1.1.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Examining the scope and contingencies for restructuring based on market situation and internal realities. Map the market forces over which any and all probabilities can be probed for utility and viability. Once the restructuring options have been analyzed and the due-diligence performed, execute the deal. Consider seeking professional services for assistance in formalizing these opportunities.""" ;
    skos:broader ex:PCF_17040 .

ex:PCF_16793 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify restructuring opportunities""" ;
    ex:pcfID "16793" ;
    ex:hierarchyID "1.1.5.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying opportunities for restructuring the organization, through an analysis of internal viability and external contingency. Conduct a broad-based survey of the market landscape, taking the large-scale trends and movements into account, to determine the necessity and possibility of restructuring the organization. Review the organization's internal capacities, the readiness of its process frameworks, the robustness of its financials, the capableness of its systems, the resourcefulness of its personnel, etc. for assimilating an extensive overhaul.""" ;
    skos:broader ex:PCF_16792 .

ex:PCF_16794 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform due-diligence""" ;
    ex:pcfID "16794" ;
    ex:hierarchyID "1.1.5.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Auditing the status quo of the probabilities, before formalizing any restructuring of the organization with another entity. Systematically investigate all entities discerned to be of interest in Identify restructuring opportunities [16793], to verify all tangible and substantial facts. Consider engaging specialist professional services including legal, accounting, and consulting help.""" ;
    skos:broader ex:PCF_16792 .

ex:PCF_16795 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze deal options""" ;
    ex:pcfID "16795" ;
    ex:hierarchyID "1.1.5.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining various options shortlisted for assimilating new entities into the organization or dissociating from it. Undertake a piecemeal and comprehensive consideration of each option identified for acquisition, merger, de-merger, and divestment. Consider intangible and non-material aspects of the entities involved and synergic aspects. Consider the assistance of specialist professional services.""" ;
    skos:broader ex:PCF_16792 .

ex:PCF_16796 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate acquisition options""" ;
    ex:pcfID "16796" ;
    ex:hierarchyID "1.1.5.3.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Appraising entities identified as being suitable for acquisition, taking into account the restructuring opportunities in the internal and external context. Verify the appropriateness and viability of the short-listed options. Ensure these entities pertain to the state-of-affairs in the market, as well as fit with the resources and capabilities of the organization.""" ;
    skos:broader ex:PCF_16795 .

ex:PCF_16797 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate merger options""" ;
    ex:pcfID "16797" ;
    ex:hierarchyID "1.1.5.3.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Appraising entities identified as being suitable for a merger, taking stock of the restructuring opportunities within the firm and the market. Verify the appropriateness and viability of such options. Assess these entities to ensure their pertinence to the contextual state-of-affairs in the market, as well as a fit with the resources and capabilities of the organization itself. (This process can be carried out, in its entirety, by qualified in-house personnel or may be designated to specialist professional services providers.)""" ;
    skos:broader ex:PCF_16795 .

ex:PCF_16798 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate de-merger options""" ;
    ex:pcfID "16798" ;
    ex:hierarchyID "1.1.5.3.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Evaluating departments and subsidiaries within the organization, and/or previously merged entities, to assess the appropriateness of a de-merger, taking account of the fit between these entities as well as any relevant externalities. Examine the pertinence and soundness of a formalized dissociation.""" ;
    skos:broader ex:PCF_16795 .

ex:PCF_16799 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate divesture options""" ;
    ex:pcfID "16799" ;
    ex:hierarchyID "1.1.5.3.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Evaluating departments and/or subsidiaries within the organization to assess the appropriateness of a divestment, taking account of all market externalities. Examine any internal entities that have been identified to be suitable for dismemberment from the organization. Ensure the pertinence and soundness of such a move.""" ;
    skos:broader ex:PCF_16795 .

ex:PCF_10015 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop business strategy""" ;
    ex:pcfID "10015" ;
    ex:hierarchyID "1.2" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Developing an organization's mission statement, strategy, and business design. Create a concise statement that clearly articulates the mission of the organization, outlining practicable targets to Establish a strategic vision [10020]. Delineate strategic options by matching these alternatives with the organization's internal capabilities. Create an organizational design, and identify goals by developing strategies at the functional and process levels.""" ;
    skos:broader ex:PCF_10002 .

ex:PCF_10037 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop overall mission statement""" ;
    ex:pcfID "10037" ;
    ex:hierarchyID "1.2.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Establishing an overarching, compact statement that concisely underscores the mission of the organization. Define and communicate a clear and succinct mission statement, which encapsulates how the organization aims to proceed in order to Establish a strategic vision [10020]. Solicit critical inputs from senior management and strategy executives, and collaborate with marketing or personnel from allied functions.""" ;
    skos:broader ex:PCF_10015 .

ex:PCF_10044 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define current business""" ;
    ex:pcfID "10044" ;
    ex:hierarchyID "1.2.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining the status quo relating to the de facto core of what the business is. Reflect over the fundamental essence of what the business accomplishes and the manner in which it operates. Look beyond the obvious solution capabilities to delineate capacities that form the basis of the business engine. Involve senior executives and management personnel and possibly professional services providers.""" ;
    skos:broader ex:PCF_10037 .

ex:PCF_10045 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Formulate mission""" ;
    ex:pcfID "10045" ;
    ex:hierarchyID "1.2.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Outlining actionable objectives that effectively set a course to fulfill the organization's vision. In this fundamental activity, articulate certain goals or targets in broad but practicable terms to reach long-term objectives.""" ;
    skos:broader ex:PCF_10037 .

ex:PCF_10046 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Communicate mission""" ;
    ex:pcfID "10046" ;
    ex:hierarchyID "1.2.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing and executing a communication strategy to convey the mission statement. Create a universal communication strategy and appropriate delivery channels, with the objective of leveraging the latter to execute the former. Convey the inherent message of the mission to all stakeholders, including employees, customers, and the public. Ensure collaboration between senior strategy personnel and the communications/marketing team.""" ;
    skos:broader ex:PCF_10037 .

ex:PCF_10038 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define and evaluate strategic options to achieve the mission""" ;
    ex:pcfID "10038" ;
    ex:hierarchyID "1.2.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Assessing sets of strategic decisions designed to drive the organization's long-term objectives. Identify various strategies concerning core functional areas. Appraise strategic options in light of auxiliary decision frameworks that ensure smooth functioning, the advancement of functional efficiencies, and vitality. Involve senior management executives, especially strategy and/or business unit personnel, with need-based consultative assistance from professional services providers.""" ;
    skos:broader ex:PCF_10015 .

ex:PCF_10047 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define strategic options""" ;
    ex:pcfID "10047" ;
    ex:hierarchyID "1.2.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining the various options available to achieve the goals highlighted in the mission statement. Delineate (in accordance with a predefined criteria) the various permutations of strategic decisions that would help the organization achieve the objectives outlined in Develop overall mission statement [10037]. Involve senior management and key strategy personnel, with timely help from professional services providers.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_18083 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Select partnerships and relationships to support the extended enterprise""" ;
    ex:pcfID "18083" ;
    ex:hierarchyID "1.2.2.1.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Supporting the design, manufacture and distribution of product and services through the extended enterprise model.  This is concerned with the strategic decisions on make vs buy, in house or out sourced.  Senior Executives map out how they want to run their business.  Make strategic choices as to whether to buy in components / sub-assemblies, run their own distribution fleet or contract out, own their dealerships or franchise out, etc.  Strategize with partnerships. Collaborate design consideration at strategy level for automotive and procurement act within the Target Operating Model set at strategy level.""" ;
    skos:broader ex:PCF_10047 .

ex:PCF_10048 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess and analyze impact of each option""" ;
    ex:pcfID "10048" ;
    ex:hierarchyID "1.2.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Scoping and probing to study the impact of strategic options for fulfilling the organization's objectives. Estimate a measure of the impact effectuated by each set of strategic decisions, which comprise Define strategic options [10047]. Closely examine the consequences of each option.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_13289 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify implications for key operating model business elements that require change""" ;
    ex:pcfID "13289" ;
    ex:hierarchyID "1.2.2.2.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determine impacts of elements such as staffing, skills, training, new markets, technology, or policies within operating model which needs change. """ ;
    skos:broader ex:PCF_10048 .

ex:PCF_13290 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify implications for key technology aspects""" ;
    ex:pcfID "13290" ;
    ex:hierarchyID "1.2.2.2.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining key factors for technology ROI, benefits, architecture, etc.""" ;
    skos:broader ex:PCF_10048 .

ex:PCF_21606 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate B2B options""" ;
    ex:pcfID "21606" ;
    ex:hierarchyID "1.2.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating future business to business opportunities against past and current approaches and performance. Gather insights into what competitors and other similar organizations are doing and the needs, goals, and expectations of stakeholders and partners to understand potential future impact.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_21607 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate B2C options""" ;
    ex:pcfID "21607" ;
    ex:hierarchyID "1.2.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating future business to customer opportunities against past and current approaches and performance. Gather insights into what competitors and other similar organizations are doing and the needs, goals, and expectations of customers and partners to understand potential future impact.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_21608 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate partner/alliance options""" ;
    ex:pcfID "21608" ;
    ex:hierarchyID "1.2.2.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating partnership and alliance opportunities to deliver products/services. Understand existing product and market models in use across the markets you serve, evolving trends, and the cost/benefit of potential new/updated partnership/alliance options.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_21609 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate IP acquisition options""" ;
    ex:pcfID "21609" ;
    ex:hierarchyID "1.2.2.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating intellectual property acquisition options available to scale, modernize, and/or extend product/service reach. Understand the cost, risk, timing and lifecycle value of candidate acquisitions.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_21610 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate innovation options""" ;
    ex:pcfID "21610" ;
    ex:hierarchyID "1.2.2.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating innovation options to advance technology, products/services, and/or operational performance.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_21611 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate sustainability options""" ;
    ex:pcfID "21611" ;
    ex:hierarchyID "1.2.2.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating sustainability requirements, stakeholder expectations, and value proposition for options. Understand the potential activities and changes across environmental, social, and governance, the effort required, cost to implement, and benefits gained. The analysis should consider sustainable product/service lifecycles, operations, infrastructure, performance, and workforce.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_21612 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate global support options""" ;
    ex:pcfID "21612" ;
    ex:hierarchyID "1.2.2.9" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating options for global support services and functions. This should include structure, scale, adaptability to change, and alternative delivery models to balance cost, performance, and customer value.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_21613 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate shared services options""" ;
    ex:pcfID "21613" ;
    ex:hierarchyID "1.2.2.10" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating options for shared services and support functions. This should include structure, scale, adaptability to change, and alternative delivery models to balance cost, performance, and operational efficiencies.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_21614 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate lean/continuous improvement options""" ;
    ex:pcfID "21614" ;
    ex:hierarchyID "1.2.2.11" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating options to enhance and optimize processes and functional areas. Understand alternatives to strengthen business capabilities, enhance process efficiencies, and advance performance standards.""" ;
    skos:broader ex:PCF_10038 .

ex:PCF_10039 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Set/Develop long-term enterprise strategy""" ;
    ex:pcfID "10039" ;
    ex:hierarchyID "1.2.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing a strategy for the achievement of business goals over the distant future. Adopt one of the strategic options for realizing its mission over the long term. Enlist senior management executives, comprising strategy and/or business unit personnel.""" ;
    skos:broader ex:PCF_10015 .

ex:PCF_16803 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop partner/alliance strategy""" ;
    ex:pcfID "16803" ;
    ex:hierarchyID "1.2.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining direction and plan objectives for partnering with other companies to deliver product/services. Focus on creating a vision and strategic objectives and culminate in creating measures for the strategic alliance or partnership.""" ;
    skos:broader ex:PCF_10039 .

ex:PCF_14189 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop sustainability strategy""" ;
    ex:pcfID "14189" ;
    ex:hierarchyID "1.2.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Formulating strategic options that create opportunities for the sustenance and prosperity of the business in the long run. Go beyond business longevity to consider alternate strategies that allow the organizations preservation of vitality over time. Earmark resources and target processes, the former of which are dedicated to the absorption of sustainable practices in the latter.""" ;
    skos:broader ex:PCF_10039 .

ex:PCF_16805 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop merger/demerger/acquisition/exit strategy""" ;
    ex:pcfID "16805" ;
    ex:hierarchyID "1.2.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining a strategy for corporate development. Include providing a framework for evaluating merger and acquisition candidates; and planning for a value creation through merging/demerging with a company, acquiring a company, or exiting from an already merged/acquired company.""" ;
    skos:broader ex:PCF_10039 .

ex:PCF_19952 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop innovation strategy""" ;
    ex:pcfID "19952" ;
    ex:hierarchyID "1.2.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a plan and vision to encourage advancements in technology or product/services. Create a roadmap for changing or innovating the business model to make business operations more competitive. Set up new R&D services for changing or bringing new value propositions, services, production processes, and invention of technology not previously used by competitors etc.""" ;
    skos:broader ex:PCF_10039 .

ex:PCF_19950 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop global support strategy""" ;
    ex:pcfID "19950" ;
    ex:hierarchyID "1.2.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a plan to deploy support services and support functions throughout the organization globally. Arrange the organizations functional support areas to create efficiencies of scale in the delivery of support services, globally.""" ;
    skos:broader ex:PCF_10039 .

ex:PCF_19951 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop shared services strategy""" ;
    ex:pcfID "19951" ;
    ex:hierarchyID "1.2.3.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Charting a plan to leverage internal services and support functions throughout the organization. Delineate a framework of parameters and criteria to selectively filter service areas for inclusion among the organizations common resources. Arrange the organizations functional areas to create efficiencies of scale in the delivery of internal services.""" ;
    skos:broader ex:PCF_10039 .

ex:PCF_14197 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop lean/continuous improvement strategy""" ;
    ex:pcfID "14197" ;
    ex:hierarchyID "1.2.3.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing strategies for the optimization of processes and the improvement of functional areas in order to improve the bottom line. Create a road map of decision choices that would allow the organization to continuously enhance process efficiencies and advance performance standards.""" ;
    skos:broader ex:PCF_10039 .

ex:PCF_10040 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Coordinate and align cross-functional and process strategies""" ;
    ex:pcfID "10040" ;
    ex:hierarchyID "1.2.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Aligning the approach and method of individual units, departments, systems, and operations within the organization, in accordance with the larger strategic course adopted. Employ the organization's strategic path to guide the functions, divisions, and operations. Calibrate the plan and method of each functional area, as well as the processes therein, to Select the long-term business strategy [10039].""" ;
    skos:broader ex:PCF_10015 .

ex:PCF_10041 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create organizational design""" ;
    ex:pcfID "10041" ;
    ex:hierarchyID "1.2.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Formulating a design for the organization's resources that allow it to meet its objectives. Develop a new framework for molding the organization's various processes into a coherent and seamless whole.""" ;
    skos:broader ex:PCF_10015 .

ex:PCF_10049 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate breadth and depth of organizational structure""" ;
    ex:pcfID "10049" ;
    ex:hierarchyID "1.2.5.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating the structural makeup of the organization, including pertinent features of and associated synergies among constituent elements. Examine the organization's architectural framework, paying close attention to the individual elements, the relations among them, and the conjoint and co-acting forces therein. Analyze functions and processes, as well as work-related positions. Scrutinize various relevant characteristics associated with each of them, depending upon the scale, scope, and type of organization.""" ;
    skos:broader ex:PCF_10041 .

ex:PCF_10050 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform job-specific roles mapping and value-added analyses""" ;
    ex:pcfID "10050" ;
    ex:hierarchyID "1.2.5.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Appraising job-specific roles within the organizational chart and their hierarchical architecture. Analyze a map of work-related roles within the organizational structure. Examine the value added by the positions associated with jobs to be performed and how they stack up within the organization's operations.""" ;
    skos:broader ex:PCF_10041 .

ex:PCF_10051 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop role activity diagrams to assess hand-off activity""" ;
    ex:pcfID "10051" ;
    ex:hierarchyID "1.2.5.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining the constituent exercises and undertakings within a work-related position for the purpose of effective delegation. Deconstruct job-specific roles into activities and visualize the relations among them, with the objective of assigning responsibilities to the appropriate personnel.""" ;
    skos:broader ex:PCF_10041 .

ex:PCF_10052 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform organization redesign workshops""" ;
    ex:pcfID "10052" ;
    ex:hierarchyID "1.2.5.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Organizing workshop sessions to adopt organizational redesign. Communicate the organizational structure and mapping of responsibilities against job roles in order to facilitate an effective understanding among personnel. Use a collaborative process that may include participative workshop sessions.""" ;
    skos:broader ex:PCF_10041 .

ex:PCF_10053 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design the relationships between organizational units""" ;
    ex:pcfID "10053" ;
    ex:hierarchyID "1.2.5.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Fleshing out the connections and dependencies among the various units of the organization. Delineate the relationship among business units or process frameworks within the organization, in terms of activities, synergies, and shared resources and responsibilities. Formalize relationships among business units so that any mutual coherence is clearly understood and can be attended to.""" ;
    skos:broader ex:PCF_10041 .

ex:PCF_10054 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop role analysis and activity diagrams for key processes""" ;
    ex:pcfID "10054" ;
    ex:hierarchyID "1.2.5.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating an understanding of the fit between job roles and organizational processes in order to properly place personnel. Deconstruct key processes into constituent activities, and examine job-related roles. Take cues from Develop role activity diagrams to assess hand-off activity [10051]. Map appropriate positions against these important processes, which in turn expedite the deployment of staff members.""" ;
    skos:broader ex:PCF_10041 .

ex:PCF_10055 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess organizational implication of feasible alternatives""" ;
    ex:pcfID "10055" ;
    ex:hierarchyID "1.2.5.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Probing the repercussions of all practicable organizational design options. Analyze the significance and impact of workable organizational structure options. Closely examine the long-term impact of these frameworks over the functioning of the organization.""" ;
    skos:broader ex:PCF_10041 .

ex:PCF_10056 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Migrate to new organization""" ;
    ex:pcfID "10056" ;
    ex:hierarchyID "1.2.5.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Embracing and ratifying a new organizational structure. (Assume the new framework to be the best fit through Assess the organizational implications of feasible alternatives [10055].)""" ;
    skos:broader ex:PCF_10041 .

ex:PCF_10042 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and set organizational objectives""" ;
    ex:pcfID "10042" ;
    ex:hierarchyID "1.2.6" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing overall goals for the organization that help in accomplishing its mission. Formulate organization-wide targets in the near to middle term, which will accumulate and propel the organization to realize its long-term objectives, as outlined in Develop an overall mission statement [10037]. Enlist business unit heads or equivalent personnel, in close collaboration with senior management executives.""" ;
    skos:broader ex:PCF_10015 .

ex:PCF_19953 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify organizational objectives""" ;
    ex:pcfID "19953" ;
    ex:hierarchyID "1.2.6.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating and developing strategic objectives that establishes a process to outline expected outcomes and guide employees' efforts.""" ;
    skos:broader ex:PCF_10042 .

ex:PCF_19954 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish baseline metrics""" ;
    ex:pcfID "19954" ;
    ex:hierarchyID "1.2.6.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing baselines that provide standards for assessing performance. Create metrics and KPI's for various functions/processes/activities based on organizational goals.""" ;
    skos:broader ex:PCF_10042 .

ex:PCF_19955 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor performance against objective""" ;
    ex:pcfID "19955" ;
    ex:hierarchyID "1.2.6.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining methodology and frequency of assessment for measuring and monitoring performance of various functions/processes/activities against standard set goals.""" ;
    skos:broader ex:PCF_10042 .

ex:PCF_10043 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Formulate business unit strategies""" ;
    ex:pcfID "10043" ;
    ex:hierarchyID "1.2.7" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Charting a strategic course for business units in order to leverage opportunities, sidestep hurdles, and create synergies among each other. Create strategic road maps for the organization's units--in light of their individual resources and requirements, as well as their relationships with other business units--to achieve organizational goals.""" ;
    skos:broader ex:PCF_10015 .

ex:PCF_19956 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze business unit strategies""" ;
    ex:pcfID "19956" ;
    ex:hierarchyID "1.2.7.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing the performance of a business unit against set organizational goals which are based on pre-defined metrics collected through various business unit operations.""" ;
    skos:broader ex:PCF_10043 .

ex:PCF_19957 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify core competency for each business unit""" ;
    ex:pcfID "19957" ;
    ex:hierarchyID "1.2.7.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the resources and skills of each business unit based on knowledge and technical capacity. Enable business units to meet customer needs and grow in a competitive marketplace.""" ;
    skos:broader ex:PCF_10043 .

ex:PCF_19958 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Refine business unit strategies in support of organizational strategy""" ;
    ex:pcfID "19958" ;
    ex:hierarchyID "1.2.7.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating existing business unit strategy based on the company's strategy and eliminate unwanted/unnecessary resources/elements and re-consider necessary resources to meet the overall company's strategy.""" ;
    skos:broader ex:PCF_10043 .

ex:PCF_19959 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop customer experience strategy""" ;
    ex:pcfID "19959" ;
    ex:hierarchyID "1.2.8" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Defining a roadmap to meet customer expectations while considering how it will affect the business.""" ;
    skos:broader ex:PCF_10015 .

ex:PCF_19960 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess customer experience""" ;
    ex:pcfID "19960" ;
    ex:hierarchyID "1.2.8.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Measuring customer feedback in regard to product and services effectiveness based on overall satisfaction. The data to be analyzed is collected through surveys, customer responses, and feedbacks based on the delivered products/services.""" ;
    skos:broader ex:PCF_19959 .

ex:PCF_19961 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify and review customer touchpoints""" ;
    ex:pcfID "19961" ;
    ex:hierarchyID "1.2.8.1.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Creating methods to gauge customer experiences, expectations, and suggestions. Review both liked and disliked areas of product/services to be delivered. Evaluate touchpoints based on the nature of product/service in the market e.g., billboards, web sites, direct mail, service calls, etc.""" ;
    skos:broader ex:PCF_19960 .

ex:PCF_19962 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess customer experience across touchpoints""" ;
    ex:pcfID "19962" ;
    ex:hierarchyID "1.2.8.1.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Evaluating customer experiences, expectations, and suggestions in both liked and disliked areas of the product or services. Analyze all modes of communication, human and physical interactions, or customers experience during the relationship lifecycle with your organization. Evaluate the gaps/further development/alterations to the existing product/service to attain better customer response.""" ;
    skos:broader ex:PCF_19960 .

ex:PCF_19963 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform root cause analysis of problematic customer experiences""" ;
    ex:pcfID "19963" ;
    ex:hierarchyID "1.2.8.1.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Analyzing the core reason for the customer experience/feedback/response about the product/service to take considerable action for better customer experience.""" ;
    skos:broader ex:PCF_19960 .

ex:PCF_19964 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design customer experience""" ;
    ex:pcfID "19964" ;
    ex:hierarchyID "1.2.8.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a design of how customers interact with the business by analyzing data captured through various customer interaction and customer involvement. These will be captured through various channels such as customer satisfaction surveys, feedback forms, product reviews, targeted studies, observational studies, or voice of customer research.""" ;
    skos:broader ex:PCF_19959 .

ex:PCF_16612 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define and manage personas""" ;
    ex:pcfID "16612" ;
    ex:hierarchyID "1.2.8.2.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Identifying a set of characteristics that define the demographic and behavioral patterns of the customer. Further, use persona scoring to design your marketing strategies around personas, and measure and optimize your interactions with the contacts classified by a certain persona.""" ;
    skos:broader ex:PCF_19964 .

ex:PCF_19965 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create customer journey maps""" ;
    ex:pcfID "19965" ;
    ex:hierarchyID "1.2.8.2.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Creating a story of the customer's experience: from initial contact, through the process of engagement and into a long-term relationship. The goal is to teach organization about the customer.""" ;
    skos:broader ex:PCF_19964 .

ex:PCF_19966 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define single view of the customer for the organization""" ;
    ex:pcfID "19966" ;
    ex:hierarchyID "1.2.8.2.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Defining parameters to show aggregated, consistent, and holistic representation of known data about customers. Define key parameters which enable the tracking of customers and communications across every channel.""" ;
    skos:broader ex:PCF_19964 .

ex:PCF_19967 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define a vision for the customer experience""" ;
    ex:pcfID "19967" ;
    ex:hierarchyID "1.2.8.2.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Establishing a direction and vision on how the organization behaves towards customers in a consistent, effective way. The key attributes for customer experience vision consists of emotional connection, commitments and expectations, compelling value proposition, and ease of understanding the organization's behavior.""" ;
    skos:broader ex:PCF_19964 .

ex:PCF_19968 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Validate with customers""" ;
    ex:pcfID "19968" ;
    ex:hierarchyID "1.2.8.2.5" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Creating a process to validate the sales process and the assumptions that underpin the business model. Understand if the products/services have a repeatable, scalable business model around that product.""" ;
    skos:broader ex:PCF_19964 .

ex:PCF_19969 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Align experience with brand values and business strategies""" ;
    ex:pcfID "19969" ;
    ex:hierarchyID "1.2.8.2.6" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Aligning and defining a relevant, differentiated, and credible value proposition for the brand. Align experience to ensure that the product and service quality is consistent with brand promise and business strategies.""" ;
    skos:broader ex:PCF_19964 .

ex:PCF_19970 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop content strategy""" ;
    ex:pcfID "19970" ;
    ex:hierarchyID "1.2.8.2.7" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Planning, development, and management of content-written or in other media. Getting the right content to the right user at the right time through strategic planning of content creation, delivery, and governance.""" ;
    skos:broader ex:PCF_19964 .

ex:PCF_19971 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design customer experience support structure""" ;
    ex:pcfID "19971" ;
    ex:hierarchyID "1.2.8.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a roadmap for customer experience support with an overall approach, process flow, and impact timeframe. """ ;
    skos:broader ex:PCF_19959 .

ex:PCF_19972 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify required capabilities""" ;
    ex:pcfID "19972" ;
    ex:hierarchyID "1.2.8.3.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining the necessary skills and competencies required to efficiently collect customer experiences through the support structure.""" ;
    skos:broader ex:PCF_19971 .

ex:PCF_19973 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify impact on functional processes""" ;
    ex:pcfID "19973" ;
    ex:hierarchyID "1.2.8.3.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Identifying the affect of customer experience through customer experience support structure on other functions of customer services related to customer.""" ;
    skos:broader ex:PCF_19971 .

ex:PCF_19974 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop customer experience roadmap to develop and implement defined capabilities""" ;
    ex:pcfID "19974" ;
    ex:hierarchyID "1.2.8.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining a standard guideline to create and execute the capacities of registering customer experiences in a timely manner. Create a common understanding of what behaviors are required to implement the strategy. Define what talent/skills your organization needs to reach customer experience goals.""" ;
    skos:broader ex:PCF_19959 .

ex:PCF_18916 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Communicate strategies internally and externally""" ;
    ex:pcfID "18916" ;
    ex:hierarchyID "1.2.9" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Conveying planned procedures and methods to both internal departments and external stakeholders like customers, suppliers, etc., in an effective manner based on organizational objective.""" ;
    skos:broader ex:PCF_10015 .

ex:PCF_10016 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and measure strategic initiatives""" ;
    ex:pcfID "10016" ;
    ex:hierarchyID "1.3" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Managing strategic initiatives, from development through selection, execution, and evaluation. Conduct and oversee strategic projects supporting long-term objectives. Administer programs of strategic significance by developing such initiatives, select the most appropriate projects, and formulate measures to assess their impact.""" ;
    skos:broader ex:PCF_10002 .

ex:PCF_10057 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop strategic initiatives""" ;
    ex:pcfID "10057" ;
    ex:hierarchyID "1.3.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing strategic projects that help fulfill long-term goals. Develop time-bound projects that are discretionary in nature and lie beyond the scope of the organization's routine operations.""" ;
    skos:broader ex:PCF_10016 .

ex:PCF_19975 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify strategic priorities""" ;
    ex:pcfID "19975" ;
    ex:hierarchyID "1.3.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a statement of the organization's direction to guide decision making around the allocation of resources. Provide a focus on the organization's overarching goals to ensure coherent and considered action. Strategic objectives are ranked by their importance in achieving the strategic goals. All subsequent operational or tactical planning and resource allocation is based on strategic priorities""" ;
    skos:broader ex:PCF_10057 .

ex:PCF_19976 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop strategic initiatives based on business/customer value""" ;
    ex:pcfID "19976" ;
    ex:hierarchyID "1.3.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a statement of the organization's direction based on what is considered \"value\" to the customer or business.""" ;
    skos:broader ex:PCF_10057 .

ex:PCF_19977 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review with stakeholders""" ;
    ex:pcfID "19977" ;
    ex:hierarchyID "1.3.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a process for stakeholder dialog that is integrated into the assessment of business strategies. Report on the evaluation of the business objectives, strategies, subject, or past events.""" ;
    skos:broader ex:PCF_10057 .

ex:PCF_10058 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate strategic initiatives""" ;
    ex:pcfID "10058" ;
    ex:hierarchyID "1.3.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Examining projects of strategic significance that lie outside the purview of the organization's routine operations. Closely analyze strategic initiatives for their applicability and feasibility, given the organization's vision.""" ;
    skos:broader ex:PCF_10016 .

ex:PCF_19978 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine business value for each strategic priority""" ;
    ex:pcfID "19978" ;
    ex:hierarchyID "1.3.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing a standard measure of value to determine the business worth for each of the Identify strategic priorities [19975]. List the effectiveness and utility for every important strategic element based on the benefit it adds to the business.""" ;
    skos:broader ex:PCF_10058 .

ex:PCF_19979 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine the customer value for each strategic priority""" ;
    ex:pcfID "19979" ;
    ex:hierarchyID "1.3.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyzing the value preposition; the value the customer gets from a product/services for each of your Identify strategic priorities [19975]. Customer value is the satisfaction a consumer feels after making a purchase for goods or services relative to what he/she must give up to receive them.""" ;
    skos:broader ex:PCF_10058 .

ex:PCF_10059 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Select strategic initiatives""" ;
    ex:pcfID "10059" ;
    ex:hierarchyID "1.3.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Selecting relevant projects of strategic significance that create opportunities for the organization to realize its long-term objectives, on the basis of their suitability to the organization's constraints and reality. Select from the process Evaluate strategic initiatives [10058], based on their applicability and feasibility for the organization. Enlist senior management, especially strategy personnel.""" ;
    skos:broader ex:PCF_10016 .

ex:PCF_19980 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prioritize strategic initiatives""" ;
    ex:pcfID "19980" ;
    ex:hierarchyID "1.3.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Listing the most effective procedures in the order of most important to the least. Create measures or filter for determining which of many \"strategic initiatives\" is most important to the least important.""" ;
    skos:broader ex:PCF_10059 .

ex:PCF_19981 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Communicate strategic initiatives to business units and stakeholders""" ;
    ex:pcfID "19981" ;
    ex:hierarchyID "1.3.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing procedures for communications within the organization which creates the road map for successful understanding of strategic initiatives for both business units and stakeholders (internal and external).""" ;
    skos:broader ex:PCF_10059 .

ex:PCF_10060 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish high-level measures""" ;
    ex:pcfID "10060" ;
    ex:hierarchyID "1.3.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Devising measures to examine strategic projects. Formulate evaluation criteria to assess the strategic initiatives for the level of impact.""" ;
    skos:broader ex:PCF_10016 .

ex:PCF_19982 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify business value drivers""" ;
    ex:pcfID "19982" ;
    ex:hierarchyID "1.3.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining key indicators or factors responsible for driving business value. Key business value drivers comprise of operational, financial, and sustainability drivers. """ ;
    skos:broader ex:PCF_10060 .

ex:PCF_19983 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish baselines for business value drivers""" ;
    ex:pcfID "19983" ;
    ex:hierarchyID "1.3.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing baseline measures that provide standards for assessing performance of Identify business value drivers [19982].""" ;
    skos:broader ex:PCF_10060 .

ex:PCF_19984 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor performance against baselines""" ;
    ex:pcfID "19984" ;
    ex:hierarchyID "1.3.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Overseeing the progress of activities to ensure they are on-course and on-schedule in meeting the objectives and performance targets against Establish baselines for business value drivers [19983].""" ;
    skos:broader ex:PCF_10060 .

ex:PCF_19507 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Execute strategic initiatives""" ;
    ex:pcfID "19507" ;
    ex:hierarchyID "1.3.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Successfully implement strategic initiatives. Execution of strategy is also defined as the process of implementing logical set of connected activities by an organization to make a strategy work.""" ;
    skos:broader ex:PCF_10016 .

ex:PCF_21422 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review execution of strategic initiatives""" ;
    ex:pcfID "21422" ;
    ex:hierarchyID "1.3.6" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Periodic review of initiatives based performance, conditions, and marketplace response.""" ;
    skos:broader ex:PCF_10016 .

ex:PCF_21423 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Refine strategic initiatives and project plans as needed""" ;
    ex:pcfID "21423" ;
    ex:hierarchyID "1.3.7" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Performing required updates to strategic initiatives based upon changes in the marketplace or performance.""" ;
    skos:broader ex:PCF_10016 .

ex:PCF_20944 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and maintain business models""" ;
    ex:pcfID "20944" ;
    ex:hierarchyID "1.4" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Establishing how an organization creates, delivers and captures value or makes profit. Identify the products or services that a business will sell, its target market, anticipated expenses, and other core aspects of its modus operandi. Revise the plan as required to reflect changing circumstances.""" ;
    skos:broader ex:PCF_10002 .

ex:PCF_20945 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop business models""" ;
    ex:pcfID "20945" ;
    ex:hierarchyID "1.4.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating an economic model that describes the goals of an organization and the business processes needed to achieve those goals. This involves information gathering, securing necessary approvals and authorizations, integrating with preexisting models, including the general business concept [10002] and business strategy [10015], and formally accepting the model as the basis for organization's day-to-day operations.""" ;
    skos:broader ex:PCF_20944 .

ex:PCF_20946 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assemble business model information""" ;
    ex:pcfID "20946" ;
    ex:hierarchyID "1.4.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Collecting all relevant materials needed to develop the business model, so that it can adequately model its processes.""" ;
    skos:broader ex:PCF_20945 .

ex:PCF_20947 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Secure appropriate approvals""" ;
    ex:pcfID "20947" ;
    ex:hierarchyID "1.4.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Obtaining required permissions, licenses and authorizations that legitimize the business, help to mitigate associated risks and safeguard the operations.""" ;
    skos:broader ex:PCF_20945 .

ex:PCF_20948 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify integration points with existing models""" ;
    ex:pcfID "20948" ;
    ex:hierarchyID "1.4.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Ensuring coherence with pre-exsiting models to avoid contradictions between models. Make sure that all models represent the same long-term vision.""" ;
    skos:broader ex:PCF_20945 .

ex:PCF_20949 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Adopt the business model""" ;
    ex:pcfID "20949" ;
    ex:hierarchyID "1.4.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Consenting to a particular business model and formally accepting it to serve as the set of guiding principles in operating the company.""" ;
    skos:broader ex:PCF_20945 .

ex:PCF_20950 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Maintain business models""" ;
    ex:pcfID "20950" ;
    ex:hierarchyID "1.4.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Revising and updating business models to reflect the changes in the marketed services, product inventory, market behavior, available resources or accrued expenses. Determine how and when to modify the accepted business model in response to incoming feedback.""" ;
    skos:broader ex:PCF_20944 .

ex:PCF_20951 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish business model maintenance parameters""" ;
    ex:pcfID "20951" ;
    ex:hierarchyID "1.4.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the timeline, procedures and responsibilities for reviewing the business model and for updating it to best serve the organization.""" ;
    skos:broader ex:PCF_20950 .

ex:PCF_20952 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Accept business model feedback parameters""" ;
    ex:pcfID "20952" ;
    ex:hierarchyID "1.4.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Deciding the type of responses, reactions, sentiments and insights that are crucial to be taken into consideration with business model maintenance.""" ;
    skos:broader ex:PCF_20950 .

ex:PCF_20953 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prioritize and manage incoming feedback""" ;
    ex:pcfID "20953" ;
    ex:hierarchyID "1.4.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating the feedback regarding products, services, processes or resources. Determine which judgments are critical and mandate changes to the current business model to better deliver the desired value """ ;
    skos:broader ex:PCF_20950 .

ex:PCF_20954 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Update existing models""" ;
    ex:pcfID "20954" ;
    ex:hierarchyID "1.4.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Modifying the business models that are presently in use in response to incoming feedback or changing markets to achieve the enterprise business goals.""" ;
    skos:broader ex:PCF_20950 .

ex:PCF_20955 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish business model governance""" ;
    ex:pcfID "20955" ;
    ex:hierarchyID "1.4.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating and implementing a strategy, responsibilities and control mechanisms for managing business models that are timely, efficient and cost-effective.""" ;
    skos:broader ex:PCF_20944 .

ex:PCF_10003 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and Manage Products and Services""" ;
    ex:pcfID "10003" ;
    ex:hierarchyID "2.0" ;
    rdfs:comment "APQC level: Category" ;
    ex:apqcSourceText """Detailing practices and procedures related to the concept of developing and managing products and services. These are reflected in the process groups Govern and manage product/service development program [19696], Generate and define new product/service ideas [19698], and Develop products and services [10062].""" .

ex:PCF_19696 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Govern and manage product/service development program""" ;
    ex:pcfID "19696" ;
    ex:hierarchyID "2.1" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Supervising the complete product/service program from innovation until its commercial success. Meeting the customer demand and expectations. Conduct further development and innovation pertaining to business goals.""" ;
    skos:broader ex:PCF_10003 .

ex:PCF_10061 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage product and service portfolio""" ;
    ex:pcfID "10061" ;
    ex:hierarchyID "2.1.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Managing a portfolio of product/service offerings to take advantage of shifts in the market expectations, all the while coordinating with the overall business strategy. Revisit the product/service portfolio in light of market opportunities, and overhaul it to capture value created by these opportunities. Identify gaps between current offerings and the market expectations to direct the organization's R&D activity. Create new solutions, and revise or retire existing ones so that the revamped portfolio aligns with Develop a business strategy [10015].""" ;
    skos:broader ex:PCF_19696 .

ex:PCF_10063 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate performance of existing products/services against market opportunities""" ;
    ex:pcfID "10063" ;
    ex:hierarchyID "2.1.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing the capabilities and performance of existing products/services, in light of market opportunities. Examine performance of the existing line of products/services, including measures of profitability, penetration, and value delivered. Identify gaps between existing solutions' portfolio or their performance levels, on the one hand, and the current market demand, available technologies, and/or customer expectations, on the other. Consider opportunities in the present market environment and any relation with the performance. Consider input from professional services providers.""" ;
    skos:broader ex:PCF_10061 .

ex:PCF_10066 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Confirm alignment of product/service concepts with business strategy""" ;
    ex:pcfID "10066" ;
    ex:hierarchyID "2.1.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Checking the alignment of product/service portfolio, and its individual offerings, with the organization's overall strategy and planning for the development of new or revised solutions. Conduct reality checks on new product/service concepts prior to committing significant investment to ensure that the revamped solutions' portfolio is in line with the overall business strategy, aligns organizational processes for their development, and creates a plan for assimilating these changes in the organization's offerings. Enlist senior management executives.""" ;
    skos:broader ex:PCF_10061 .

ex:PCF_10074 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prioritize and select new product/service concepts""" ;
    ex:pcfID "10074" ;
    ex:hierarchyID "2.1.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Selecting from among the potential new/revised solutions and capitalizing on market opportunities so that they meet the cost and quality prerequisites. Create an index of product/service concepts, and arrange them in order of preference. Base prioritization on adherence to Plan and develop cost and quality targets [10073], and choose options that would comprise the revised solution portfolio.""" ;
    skos:broader ex:PCF_10061 .

ex:PCF_10073 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan and develop cost and quality targets""" ;
    ex:pcfID "10073" ;
    ex:hierarchyID "2.1.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Setting prerequisites for the cost of development and quality standards for the new solutions' portfolio and/or its individual offerings. Set targets for the budget and quality standards for the revamped portfolio of solution offerings. Prepare a plan for the outlay required for revising and adding new product/services. Identify intended levels of quality for these, bearing in mind the existing standards of solutions offered by the organization and its competitors. Enlist senior management executives, particularly those responsible for finance and budgeting, product/service design, manufacturing/processing, delivery, and quality control.""" ;
    skos:broader ex:PCF_10061 .

ex:PCF_10075 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Specify development timing targets""" ;
    ex:pcfID "10075" ;
    ex:hierarchyID "2.1.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the individual and collective timeframe for realizing new/revised solutions. Create a schedule that clearly demarcates the timeframes designated for the development of every new solution and/or revising each of the existing ones. Create a timetable by setting deadlines for each step in overhauling the product/service portfolio.""" ;
    skos:broader ex:PCF_10061 .

ex:PCF_10076 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan for product/service offering modifications""" ;
    ex:pcfID "10076" ;
    ex:hierarchyID "2.1.1.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a programmatic procedure for changing products/services while paying heed to all stakeholders involved and the prerequisites identified. Create a plan for changing the existing portfolio of solution offerings. Develop a systematic program for the design, processing, and delivery of the new product/service concepts. Construct project-flow diagrams. Identify the stakeholders involved and personnel responsible for each stage, as well as the necessary decisions. Earmark the budgetary outlay, and conduct any strategic planning required.""" ;
    skos:broader ex:PCF_10061 .

ex:PCF_10067 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage product and service life cycle""" ;
    ex:pcfID "10067" ;
    ex:hierarchyID "2.1.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Manage the introduction and withdrawal of products/services. Administer associated changes, namely measuring the performance of new solution offerings and the revision of master files in the archives.""" ;
    skos:broader ex:PCF_19696 .

ex:PCF_16824 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop plan for new product/service development and introduction/launch""" ;
    ex:pcfID "16824" ;
    ex:hierarchyID "2.1.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a program and managing a perspective for new product/service introduction and launch.""" ;
    skos:broader ex:PCF_10067 .

ex:PCF_10077 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Introduce new products/services""" ;
    ex:pcfID "10077" ;
    ex:hierarchyID "2.1.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Launching revamped product/service portfolio in to the market. Introduction in to the marketplace is done by deploying effective channels for marketing, sales, delivery, and after-sales servicing. Introduce new/revised solution offerings in a concerted effort. Coordinate a cross-functional effort.""" ;
    skos:broader ex:PCF_10067 .

ex:PCF_10078 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Retire outdated products/services""" ;
    ex:pcfID "10078" ;
    ex:hierarchyID "2.1.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Removing nonconforming products and services. Withdraw those products/services that do not conform to market realities and are not positioned to take advantage of prevailing opportunities. Coordinate with processing/delivery teams within the organization and key stakeholders in the supply chain. Create mechanisms for continued after-sales servicing, as well as deploy effective public relations efforts in order to preserve the image and goodwill of the organization through the process.""" ;
    skos:broader ex:PCF_10067 .

ex:PCF_10079 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify and refine performance indicators""" ;
    ex:pcfID "10079" ;
    ex:hierarchyID "2.1.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Attuning the performance measures of products/services to better reflect the revamped portfolio of solution offerings. Revise the parameters used to measure performance, apropos the organization's product/service offerings. (Modify these standards in consideration of the changes made to the portfolio by Introduce new products/services [10077] and Retire outdated products/services [10078].)""" ;
    skos:broader ex:PCF_10067 .

ex:PCF_11423 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct post launch review""" ;
    ex:pcfID "11423" ;
    ex:hierarchyID "2.1.2.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Learning from either a test or a full production run within the consumer market. Companies use this as an opportunity to both test and react to new products, ideas, or innovations based on the initial reaction of consumers on an individual level. Within this process, analytics are used to determine the relative success of a new product offering. Within this process, companies will launch key analytics to test a products acceptance. They will also review market performance and compare to similar products and against the business case or the financial plan. Companies can also measure the effectiveness of their supply chain network, and can apply what is learned from the post launch review to other new products, processes, and procedures to ensure and enhance the product quality.""" ;
    skos:broader ex:PCF_10067 .

ex:PCF_19646 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Carry out post launch analytics to test the acceptability in the market""" ;
    ex:pcfID "19646" ;
    ex:hierarchyID "2.1.2.5.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Measuring the performance of marketing once the product/services are launched. This broadly covers measuring user engagement and product's/service's performance in the market.""" ;
    skos:broader ex:PCF_11423 .

ex:PCF_11424 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review market performance""" ;
    ex:pcfID "11424" ;
    ex:hierarchyID "2.1.2.5.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Conducting customer and market analysis to review progress and identify opportunities for increasing market position. Track and review product/service response through sales reports, website statistics, direct response from customers, and survey reports.""" ;
    skos:broader ex:PCF_11423 .

ex:PCF_11425 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review effectiveness of supply chain and distribution network""" ;
    ex:pcfID "11425" ;
    ex:hierarchyID "2.1.2.5.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining the performance of supply chain to all departments and logistics from input to shop floor. Seeking performance reviews at each intersection and communication channels. Review effectiveness of supply chain and distribution to check if it is meeting the demands of the various groups and organizations that are concerned with its activities (groups might include customers, partners, suppliers, and vendors).""" ;
    skos:broader ex:PCF_11423 .

ex:PCF_19647 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Apply data and analytics to review supply chain methodologies""" ;
    ex:pcfID "19647" ;
    ex:hierarchyID "2.1.2.5.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Collecting and examining raw data with the purpose of drawing conclusions about that information and correlate gaps and efficiencies to the existing supply chain channels. Apply the information to make better business decisions to the related supply chain methodologies to meet efficiency.""" ;
    skos:broader ex:PCF_11423 .

ex:PCF_11426 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review quality and performance of the product/service""" ;
    ex:pcfID "11426" ;
    ex:hierarchyID "2.1.2.5.5" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Identifying the quality and performance of the product/service delivered to customers. Analyze data from the customer feedback, audits, measures of customer satisfaction (such as product quality complaints and recalls), and organizational policies on delivery.""" ;
    skos:broader ex:PCF_11423 .

ex:PCF_11427 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct financial review""" ;
    ex:pcfID "11427" ;
    ex:hierarchyID "2.1.2.5.6" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Evaluating organization's financial reports and financial reporting processes. Review and document the ROI catered by the product/service delivery to the customer in the market.""" ;
    skos:broader ex:PCF_11423 .

ex:PCF_11428 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct new product development process assessment""" ;
    ex:pcfID "11428" ;
    ex:hierarchyID "2.1.2.5.7" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Analyzing the steps involved in the development of new product, its effect on existing product, resources, and functions related to the development of the new product until its sale in the competitive market place.""" ;
    skos:broader ex:PCF_11423 .

ex:PCF_19985 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage patents, copyrights, and regulatory requirements""" ;
    ex:pcfID "19985" ;
    ex:hierarchyID "2.1.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Determining the attributes necessary to protect and safeguard intellectual assets, maximize the value of IP assets through streamlined process, and collaboration between departments. Focus on needs to safeguard, critical assets, and assets' value.""" ;
    skos:broader ex:PCF_19696 .

ex:PCF_19941 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct mandatory and elective reviews""" ;
    ex:pcfID "19941" ;
    ex:hierarchyID "2.1.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conducting necessary performance reviews on enforcement of processes and steps to ensure protection. Determine policies and reviews for Manage patents, copyrights, and regulatory requirements [19985].""" ;
    skos:broader ex:PCF_19985 .

ex:PCF_16826 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review infringement of patents and copyrights""" ;
    ex:pcfID "16826" ;
    ex:hierarchyID "2.1.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Reviewing activities in regards to patentability and infringement. The usage of Open Source in commercial product development will be reviewed in regard to licensing, community development, etc.""" ;
    skos:broader ex:PCF_19985 .

ex:PCF_16827 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine patent and copyright needs""" ;
    ex:pcfID "16827" ;
    ex:hierarchyID "2.1.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the business need for patents and copyrights. The patents and copyrights are managed by Manage copyrights and patents [11062].""" ;
    skos:broader ex:PCF_19985 .

ex:PCF_19697 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define product technical documentation management requirements""" ;
    ex:pcfID "19697" ;
    ex:hierarchyID "2.1.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining sourcing and procurement requirements for new product technical documentation management. Make sourcing-based decisions that identify the capabilities that will be required in order to launch the new product. This documentation will be used to support the product following entry into service. It is compiled and managed in Manage product and process related data [12082], but the capability to manage and maintain this documentation must be defined and established.""" ;
    skos:broader ex:PCF_19985 .

ex:PCF_12771 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage regulatory requirements""" ;
    ex:pcfID "12771" ;
    ex:hierarchyID "2.1.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Aligning regulatory activities related to managing industry requirements. Train employees on regulatory requirements. Records for the appropriate regulatory agencies must be maintained and the new product process must be approved by the appropriate regulatory body before it is published to the organization. The submission lifecycle - i.e. creation, review, and approval of the submission and its components must be managed in a collaborative fashion.""" ;
    skos:broader ex:PCF_19985 .

ex:PCF_12772 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Train employees on appropriate regulatory requirements""" ;
    ex:pcfID "12772" ;
    ex:hierarchyID "2.1.3.5.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Conducting training and impart learning to existing and new employees. Training will relate to the most recent/enforced regulations of the business to meet Manage regulatory requirements [12771].""" ;
    skos:broader ex:PCF_12771 .

ex:PCF_12773 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Maintain records for regulatory agencies""" ;
    ex:pcfID "12773" ;
    ex:hierarchyID "2.1.3.5.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Identifying steps and procedures to manage and regularly update the records for regulatory agencies. Updates will be made to safety procedures, identity and access management, software tools and applications, internal accessibility policies, internal quality parameters, etc.""" ;
    skos:broader ex:PCF_12771 .

ex:PCF_12776 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage regulatory submission life cycle""" ;
    ex:pcfID "12776" ;
    ex:hierarchyID "2.1.3.5.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determine and follow the timely input and update of regulatory information by assessing reforms, regulatory policies, and guidelines.""" ;
    skos:broader ex:PCF_12771 .

ex:PCF_11740 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage product and service master data""" ;
    ex:pcfID "11740" ;
    ex:hierarchyID "2.1.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Controlling/authorizing to enable services' and products' data and other critical data of these functions through a well secured storage and accessibility processes backed by siloed applications/IT systems.""" ;
    skos:broader ex:PCF_19696 .

ex:PCF_11741 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage materials master lists""" ;
    ex:pcfID "11741" ;
    ex:hierarchyID "2.1.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Controlling the details of materials' storage and utilization, supplier details linked to materials, in a defined sequential manner and ensuring regular updates with permissible accessibility.""" ;
    skos:broader ex:PCF_11740 .

ex:PCF_11742 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage bills of material""" ;
    ex:pcfID "11742" ;
    ex:hierarchyID "2.1.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing the purchase details/bills through regular and error free updates to applications. Create manual entries wherever necessary and ensure timely review of the laid processes and systems.""" ;
    skos:broader ex:PCF_11740 .

ex:PCF_11743 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage routings""" ;
    ex:pcfID "11743" ;
    ex:hierarchyID "2.1.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Controlling and executing the flow of operations from raw form to finished product in a defined format using industry applications/routing sheets for the specific product/service layout.""" ;
    skos:broader ex:PCF_11740 .

ex:PCF_11744 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage specifications""" ;
    ex:pcfID "11744" ;
    ex:hierarchyID "2.1.4.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Direct, supervise, and control the product/service details necessary to execute the process. Adhere to details and descriptions for product/service through identified or guided parameters towards final outcome in the market with due critical analysis formed on organizational objectives.""" ;
    skos:broader ex:PCF_11740 .

ex:PCF_11745 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage drawings""" ;
    ex:pcfID "11745" ;
    ex:hierarchyID "2.1.4.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Administering the specifications of the product/service and ensure accessibility for product alteration/new product development.""" ;
    skos:broader ex:PCF_11740 .

ex:PCF_11746 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage product/material classification""" ;
    ex:pcfID "11746" ;
    ex:hierarchyID "2.1.4.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Controlling the details of the product and the input materials. Manage classification throughout the production process, and for future accessibility to new product development or product enrichment.""" ;
    skos:broader ex:PCF_11740 .

ex:PCF_11747 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and maintain quality/inspection documents""" ;
    ex:pcfID "11747" ;
    ex:hierarchyID "2.1.4.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining procedures required to assess the sustainability of defined criterion for product/service delivery to customers. Retain results for further review as a procedural practice.""" ;
    skos:broader ex:PCF_11740 .

ex:PCF_11748 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Maintain process specification data""" ;
    ex:pcfID "11748" ;
    ex:hierarchyID "2.1.4.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Directing and handling data with respect to the procedures followed across different functions and mission critical applications.""" ;
    skos:broader ex:PCF_11740 .

ex:PCF_11749 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage traceability data""" ;
    ex:pcfID "11749" ;
    ex:hierarchyID "2.1.4.9" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying and handling data accessed by the permitted touch points. Ensure that no data is accessible to any unnecessary recipient. Data flow should be controlled through secured access and free from unauthorized access.""" ;
    skos:broader ex:PCF_11740 .

ex:PCF_11750 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review and approve data access requests""" ;
    ex:pcfID "11750" ;
    ex:hierarchyID "2.1.4.10" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the requests pertaining to data accessibility. Review the requester details based on internal data security policies and permit data access only if internal policies and data access parameters are met.""" ;
    skos:broader ex:PCF_11740 .

ex:PCF_19698 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Generate and define new product/service ideas""" ;
    ex:pcfID "19698" ;
    ex:hierarchyID "2.2" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Identifying and describing new product or service thoughts based on organizational objectives/targets.""" ;
    skos:broader ex:PCF_10003 .

ex:PCF_10065 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform discovery research""" ;
    ex:pcfID "10065" ;
    ex:hierarchyID "2.2.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Coordinating R&D activity to identify new technologies to integrate into the revamped portfolio of products/services. Conduct early-stage R&D activity to close gaps between existing solution offerings and changing market expectations. Triangulate appropriate technologies that can support the development of a revised product/service portfolio.""" ;
    skos:broader ex:PCF_19698 .

ex:PCF_10070 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify new technologies""" ;
    ex:pcfID "10070" ;
    ex:hierarchyID "2.2.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining new technologies to revise the portfolio of solution offerings. Identify recently developed technological advances that can be leveraged in the development or advancement of the organization's product/service portfolio. Enlist senior management in conjunction with personnel responsible for the design, processing, and delivery of products/services. Have the organization's research division(s) carry out the process.""" ;
    skos:broader ex:PCF_10065 .

ex:PCF_10071 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop new technologies""" ;
    ex:pcfID "10071" ;
    ex:hierarchyID "2.2.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing new technologies from scratch to integrate into a revised portfolio of solutions. Develop new technological processes, models, and/or implements in-house, with the objective of improving existing solutions or creating new ones. Consider market realities, as well as the portfolio of products/services. Assess the results in conjunction with senior executives and personnel responsible for the design, processing, and delivery of these solutions. Engage the R&D function, and consider external sources such as offshore providers, specialized research agencies, and crowdsourcing communities.""" ;
    skos:broader ex:PCF_10065 .

ex:PCF_10072 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess feasibility of integrating new leading technologies into product/service concepts""" ;
    ex:pcfID "10072" ;
    ex:hierarchyID "2.2.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Appraising the feasibility of integrating new technologies, whether developed as a custom solution or adopted from an external source, into revised portfolio of solution offerings. Examine recently developed technological advances for suitability to incorporate them into the concept of revised and/or new solution offerings. Enlist senior management, in consultation with in-house personnel responsible for the design, processing, and delivery of these solutions, as well as key supply-chain stakeholders.""" ;
    skos:broader ex:PCF_10065 .

ex:PCF_19669 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Generate new product/service concepts""" ;
    ex:pcfID "19669" ;
    ex:hierarchyID "2.2.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Producing and defining ideologies for new product/service offerings.""" ;
    skos:broader ex:PCF_19698 .

ex:PCF_19986 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Gather new product/service ideas and requirements""" ;
    ex:pcfID "19986" ;
    ex:hierarchyID "2.2.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Collecting necessary items, documents, regulatory requirements, etc., based on Generate and define new product/service ideas [19698]""" ;
    skos:broader ex:PCF_19669 .

ex:PCF_19987 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze new product/service ideas and requirements""" ;
    ex:pcfID "19987" ;
    ex:hierarchyID "2.2.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing and reviewing the concepts and requirements of Generate and define new product/service ideas [19698]""" ;
    skos:broader ex:PCF_19669 .

ex:PCF_19988 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate new product/service inputs and requirements""" ;
    ex:pcfID "19988" ;
    ex:hierarchyID "2.2.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing and reviewing the required inputs and necessary elements such as automation, technology, hardware installation, regulatory requirements, certifications, etc., for new products/services through defined process and analysis.""" ;
    skos:broader ex:PCF_19669 .

ex:PCF_19989 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Formulate new product/service concepts""" ;
    ex:pcfID "19989" ;
    ex:hierarchyID "2.2.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Devising ideas and elements necessary for thoughts on new product/service development.""" ;
    skos:broader ex:PCF_19669 .

ex:PCF_10068 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify potential improvements to existing products and services""" ;
    ex:pcfID "10068" ;
    ex:hierarchyID "2.2.2.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining potential enhancements to current products/services in order to take advantage of a shift in market expectations. Identify how the existing line of products/services may be revised--through enhancements to individual solutions or across-the-board renovations--in order to capitalize on present opportunities in the market.""" ;
    skos:broader ex:PCF_19669 .

ex:PCF_19990 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define product/service development requirements""" ;
    ex:pcfID "19990" ;
    ex:hierarchyID "2.2.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Encompassing the identification and capture of new product/service requirements or potential improvements to current products/services. Collaborating with members of the supply chain to ensure the feasibility of what is being defined in the requirements. For example, a product with manufacturing requirements that supply chain cannot currently fulfill requires a corporate decision to either upgrade manufacturing capabilities or abandon the new product. Enterprise-level effects and needs must be considered. Depending on the nature of the final product or service, these requirements are often defined as a set of abilities, such as availability or reliability, that influence product development decisions.""" ;
    skos:broader ex:PCF_19698 .

ex:PCF_11331 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define product/service requirements""" ;
    ex:pcfID "11331" ;
    ex:hierarchyID "2.2.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining requirements related to the creation of the product/service. Explain potential achievements that could be made.""" ;
    skos:broader ex:PCF_19990 .

ex:PCF_19991 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define basic functional requirements""" ;
    ex:pcfID "19991" ;
    ex:hierarchyID "2.2.3.1.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining the operations of functions related to the product/service in the marketing environment.""" ;
    skos:broader ex:PCF_11331 .

ex:PCF_16808 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Derive interoperability requirements for products and services""" ;
    ex:pcfID "16808" ;
    ex:hierarchyID "2.2.3.1.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining the ability of products and services to work together, exchange and use information in a multi-vendor, multi-network, and multi-service environment.""" ;
    skos:broader ex:PCF_11331 .

ex:PCF_16809 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Derive safety requirements for products and services""" ;
    ex:pcfID "16809" ;
    ex:hierarchyID "2.2.3.1.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Developing safety requirements in line with environmental safety, occupational health and safety, and community health and safety guidelines.""" ;
    skos:broader ex:PCF_11331 .

ex:PCF_16810 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Derive security requirements for products and services""" ;
    ex:pcfID "16810" ;
    ex:hierarchyID "2.2.3.1.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Implementing security requirements through authentication and encryption of CE device data stream.  Utilize security measures such as cryptographic protocols and hardware security (smart cards).""" ;
    skos:broader ex:PCF_11331 .

ex:PCF_16811 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Derive regulatory compliance requirements""" ;
    ex:pcfID "16811" ;
    ex:hierarchyID "2.2.3.1.5" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Meeting regulatory requirements set forth by such directives as RoHS, WEEE, ELV, and REACH. """ ;
    skos:broader ex:PCF_11331 .

ex:PCF_16812 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Derive requirements from industry standards""" ;
    ex:pcfID "16812" ;
    ex:hierarchyID "2.2.3.1.6" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Complying with consumer electronic industry standards developed by the Consumer Technology Association (CTA).""" ;
    skos:broader ex:PCF_11331 .

ex:PCF_19992 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop user experience requirements""" ;
    ex:pcfID "19992" ;
    ex:hierarchyID "2.2.3.1.7" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Identifying and creating steps and tools to develop the user experience. """ ;
    skos:broader ex:PCF_11331 .

ex:PCF_16814 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Derive ‘services-as-a-product’ offering""" ;
    ex:pcfID "16814" ;
    ex:hierarchyID "2.2.3.1.8" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Productizing the service by defining the scope of the service/cost.  Target market for the service and make the service more tangible.""" ;
    skos:broader ex:PCF_11331 .

ex:PCF_16815 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define post launch support model""" ;
    ex:pcfID "16815" ;
    ex:hierarchyID "2.2.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining SLAs (Service Level Agreement) and service level KPIs (Key Performance Indicator). """ ;
    skos:broader ex:PCF_19990 .

ex:PCF_17389 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify product/service bundling opportunities""" ;
    ex:pcfID "17389" ;
    ex:hierarchyID "2.2.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing areas of growth and further development of product/service mix, customization, market based changes, etc., to further demonstrate value to the customer in the competition.""" ;
    skos:broader ex:PCF_19990 .

ex:PCF_10062 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop products and services""" ;
    ex:pcfID "10062" ;
    ex:hierarchyID "2.3" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Developing new products/services from scratch, including all activities associated with the design, prototyping, evaluation, and market testing of these planned offerings.""" ;
    skos:broader ex:PCF_10003 .

ex:PCF_19993 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design and prototype products and services""" ;
    ex:pcfID "19993" ;
    ex:hierarchyID "2.3.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Sketching and standardizing product and service based on the market. Analyze the data market competitiveness and innovation attained for the product and service development.""" ;
    skos:broader ex:PCF_10062 .

ex:PCF_10083 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assign resources to product/service project""" ;
    ex:pcfID "10083" ;
    ex:hierarchyID "2.3.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Allocating resources to the design, development, and evaluation of product/service concepts. Allocate funds, personnel, and time for developing the new and/or revised products/services. Begin to design the potential new product/service concepts that have been prioritized and selected for further development.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_19994 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify requirements for product/service design/development partners""" ;
    ex:pcfID "19994" ;
    ex:hierarchyID "2.3.1.1.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining essential elements for collaborators involved in blueprint/development of product/service.""" ;
    skos:broader ex:PCF_10083 .

ex:PCF_10084 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prepare high-level business case and technical assessment""" ;
    ex:pcfID "10084" ;
    ex:hierarchyID "2.3.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Preparing a business-level business case and a technical feasibility assessment in order to move the product/service projects forward. Weigh the costs and benefits of designing, developing, and evaluating the shortlisted product/service concepts. Prepare a business case to justify the product/service projects. Conduct a technical appraisal to ensure that the organization has the technical know-how and resources to further develop these concepts.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_10085 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop product/service design specifications""" ;
    ex:pcfID "10085" ;
    ex:hierarchyID "2.3.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating design specifications. Create specifications for the design of new or revised product/service concepts as a measure to meet during development. Have the senior functional-level solutioning or design staff create a framework of compliance standards for these products/services.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_16813 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop user experience design specifications""" ;
    ex:pcfID "16813" ;
    ex:hierarchyID "2.3.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the usability and user experience of products and the business impact it creates.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_16817 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Provide warranty-related recommendations""" ;
    ex:pcfID "16817" ;
    ex:hierarchyID "2.3.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Providing warranty plan and pricing specifications for recommendation.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_10086 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Document design specifications""" ;
    ex:pcfID "10086" ;
    ex:hierarchyID "2.3.1.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Documenting requirements to meet in the design of new or revised products/services. Specify technical, quality, and costing requirements, as well as ergonomic, safety, and servicing requirements for such products/services. Ensure the information presented can be understood by the personnel executing the design and includes examples, anecdotal references, and illustrations.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_10087 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct mandatory and elective external reviews""" ;
    ex:pcfID "10087" ;
    ex:hierarchyID "2.3.1.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conducting any mandatory and elective appraisals of the product/service design specifications in order to ensure compliance with external standards. Carry out external reviews of specifications created for the development of new product/service designs. Conduct mandatory appraisals such as legal and regulatory, as well as any optional assessments that, for instance, pitch the specifications against industrial benchmarks.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_19995 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design products/services""" ;
    ex:pcfID "19995" ;
    ex:hierarchyID "2.3.1.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a sketch of the customer focused product/service in Develop and Manage Products and Services [10003].""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_16819 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design for manufacturing""" ;
    ex:pcfID "16819" ;
    ex:hierarchyID "2.3.1.8.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Carrying out the steps necessary to appropriately manufacture correct parts.  This includes designing application, product hardware, mold, casting, mechanical, and electrical aspects of the product.""" ;
    skos:broader ex:PCF_19995 .

ex:PCF_16820 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design for product servicing""" ;
    ex:pcfID "16820" ;
    ex:hierarchyID "2.3.1.8.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Creating product application service view to allow for product servicing and refurbishing.""" ;
    skos:broader ex:PCF_19995 .

ex:PCF_16821 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design for re-manufacturing""" ;
    ex:pcfID "16821" ;
    ex:hierarchyID "2.3.1.8.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Replacing core components and republishing. """ ;
    skos:broader ex:PCF_19995 .

ex:PCF_16822 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review product troubleshooting methodology""" ;
    ex:pcfID "16822" ;
    ex:hierarchyID "2.3.1.8.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Reviewing the design and approach for troubleshooting the product.""" ;
    skos:broader ex:PCF_19995 .

ex:PCF_16818 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design and manage product data, design, and bill of materials""" ;
    ex:pcfID "16818" ;
    ex:hierarchyID "2.3.1.8.5" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Designing the BOM-Bill of material, manufacturing BOM and Service BOMA bill of materials list for all the raw materials and components/parts used in the producing end product.""" ;
    skos:broader ex:PCF_19995 .

ex:PCF_16823 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design for product upgrades""" ;
    ex:pcfID "16823" ;
    ex:hierarchyID "2.3.1.8.6" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Designing hardware and software upgrade techniques.""" ;
    skos:broader ex:PCF_19995 .

ex:PCF_10088 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Build prototypes/proof of concepts""" ;
    ex:pcfID "10088" ;
    ex:hierarchyID "2.3.1.9" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Building prototypes for shortlisted product/service concepts. Develop prototypes for those product/service concepts that have been identified for further development. Provide proof-of-concepts, and test any processes involved. Build prototypes in line with the design specifications already outlined. Enlist the solutioning and/or design staff.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_10098 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and test prototype production and/or service delivery process""" ;
    ex:pcfID "10098" ;
    ex:hierarchyID "2.3.1.10" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating the new manufacturing/delivery processes for the new products/services, and testing them to ensure proper functioning. Create the production/delivery process for the prototypes that have been built for the new products/services. Conduct trial-runs to test these processes and their integration with the organization's other processes.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_10089 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Eliminate quality and reliability problems""" ;
    ex:pcfID "10089" ;
    ex:hierarchyID "2.3.1.11" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Eliminating any problems relating to utility of the product/service over the course of its expected lifetime. Tweak the prototype in order to comply with the required quality and reliability standards. Further refine the prototype, so it may be subjected to testing.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_10090 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct in-house product/service testing and evaluate feasibility""" ;
    ex:pcfID "10090" ;
    ex:hierarchyID "2.3.1.12" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Carrying out an in-house appraisal of the prototypes in order to validate design and feasibility. Test the product/service prototypes to confirm their compliance with design and usability standards. Corroborate the viability of the design, and validate the feasibility of their production. Identify any areas for improvement.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_10091 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify design/development performance indicators""" ;
    ex:pcfID "10091" ;
    ex:hierarchyID "2.3.1.13" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying performance parameters. Determine the parameters to measure performance of the design and development of the product/service concepts into prototypes. """ ;
    skos:broader ex:PCF_19993 .

ex:PCF_10092 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Collaborate on design with suppliers and external partners""" ;
    ex:pcfID "10092" ;
    ex:hierarchyID "2.3.1.14" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Interacting with suppliers and manufactures to determine design decisions. Collaborate with vendors, suppliers, contractors, and subcontractors to verify feasibility of co-producing the prototype's design. Ensure that efforts can be coordinated with other stakeholders in the organization's supply chain ecosystem at the time of manufacturing, producing, or packaging the finished product/service.""" ;
    skos:broader ex:PCF_19993 .

ex:PCF_19996 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Test market for new or revised products and services""" ;
    ex:pcfID "19996" ;
    ex:hierarchyID "2.3.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Expanding on the marketplace analysis that took place earlier in the product development lifecycle by testing the market against offerings. The results from this in-depth analysis will help the organization finalize product/service characteristics and technical requirements and also identify any needed changes in the manufacturing and delivery processes that support market delivery. To prepare a detailed market study that accounts for any changes in the global environment, the organization may want to conduct a series of interviews, workshops, and focus groups with potential and existing customers.""" ;
    skos:broader ex:PCF_10062 .

ex:PCF_10093 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prepare detailed market study""" ;
    ex:pcfID "10093" ;
    ex:hierarchyID "2.3.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Composing a detailed study of the market ecosystem in light of new products/services. Conduct a detailed analysis of the targeted market(s) in order to Introduce new products/services [10077]. Examine the competition, market size and growth rate, market trends, customer segments and their characteristics, market influencers, distribution channels, and profitability. Enlist in-house marketing and/or solutioning teams, or outsource to specialized professional services agencies.""" ;
    skos:broader ex:PCF_19996 .

ex:PCF_10094 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct customer tests and interviews""" ;
    ex:pcfID "10094" ;
    ex:hierarchyID "2.3.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conducting both qualitative and quantitative studies to determine the fit between the newly developed products/services and the customers. Conduct external tests of the new product/service, and then refine them to maximize the customer uptake. Gather feedback from prospective customers and targeted populations by conducting surveys, focus groups, interviews, and detailed studies. Enlist professional services such as public relations or market research organizations.""" ;
    skos:broader ex:PCF_19996 .

ex:PCF_10095 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Finalize product/service characteristics and business cases""" ;
    ex:pcfID "10095" ;
    ex:hierarchyID "2.3.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Finalizing the characteristics of new products/services by appropriately weighing feedback from prospective customers against a cost-benefit analysis in order to produce a profitable business proposition. Refine the attributes of the newly developed products/services, in light of the feedback and insights collected during Conduct customer tests and interviews [10094]. Revisit the high-level business case to justify the resources assigned to the product/service project against the anticipated benefits.""" ;
    skos:broader ex:PCF_19996 .

ex:PCF_10096 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Finalize technical requirements""" ;
    ex:pcfID "10096" ;
    ex:hierarchyID "2.3.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Reassessing the technical requirements in light of the final product/service attributes. Revisit the technical assessment to revalidate the organization's capacity for progressing with new product/service projects, in light of the revised product/service characteristics.""" ;
    skos:broader ex:PCF_19996 .

ex:PCF_19997 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prepare for production/service delivery""" ;
    ex:pcfID "19997" ;
    ex:hierarchyID "2.3.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Devising business plans and procedures for manufacturing/operations/production and delivery of services offered by the organization. Further in general terms the total amount of output that the manufacturing department is responsible to produce for each period.""" ;
    skos:broader ex:PCF_10062 .

ex:PCF_10099 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design and obtain necessary capabilities/materials and equipment""" ;
    ex:pcfID "10099" ;
    ex:hierarchyID "2.3.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing and/or sourcing the essential machinery needed for creating purpose-built processes, as well as the raw materials, to produce the new products/services. Either design the equipment and materials needed internally, or source from external vendors. Obtain the feedstock or raw materials needed to prepare the finished products, as well as the machinery - hardware and software - needed to arrange production lines, factory operations, assemblies, and manufacturing processes. Revisit the technologies that underpin the new or revised products/services in order to source the right equipment and materials.""" ;
    skos:broader ex:PCF_19997 .

ex:PCF_10097 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify requirements for changes to manufacturing/delivery processes""" ;
    ex:pcfID "10097" ;
    ex:hierarchyID "2.3.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying any changes that need to be effectuated in the organization's internal processes for manufacturing, and delivering the newly developed products/services. Determine if any changes need to be made to the production and distribution processes, in light of the new products/services. Begin production process planning. Prepare for factory layout planning. Generate shop-floor instructions and changes to the supply chain.""" ;
    skos:broader ex:PCF_19997 .

ex:PCF_11418 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Request engineering/process change""" ;
    ex:pcfID "11418" ;
    ex:hierarchyID "2.3.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Requesting changes in the production and/or delivery operations for processing the new or revised products/services. Rectify any problems identified in the manufacturing or delivery processes (through Monitor production runs [11417]). Seek changes in components, repair machinery, optimize production lines, and tweak factory assemblies through a formal notice to the concerned division, known as an engineering change order.""" ;
    skos:broader ex:PCF_19997 .

ex:PCF_10100 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Install and validate production/service delivery process""" ;
    ex:pcfID "10100" ;
    ex:hierarchyID "2.3.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Finalizing production process or methodology. Install and initiate the production process to manufacture the new products, using the equipment and machinery already assembled. In the case of new services, implement delivery processes and methodologies. Validate processes for the accuracy of their operation and proper functioning.""" ;
    skos:broader ex:PCF_19997 .

ex:PCF_11417 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor initial production runs""" ;
    ex:pcfID "11417" ;
    ex:hierarchyID "2.3.3.4.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Regularly monitoring production runs of the production and/or delivery operations. """ ;
    skos:broader ex:PCF_10100 .

ex:PCF_19998 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Validate launch procedures""" ;
    ex:pcfID "19998" ;
    ex:hierarchyID "2.3.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Verifying the measures/processes/techniques through systems and tools involved in the introduction of products and services.""" ;
    skos:broader ex:PCF_19997 .

ex:PCF_10004 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Market and Sell Products and Services""" ;
    ex:pcfID "10004" ;
    ex:hierarchyID "3.0" ;
    rdfs:comment "APQC level: Category" ;
    ex:apqcSourceText """Outlining process groups related to understanding markets, customers, and capabilities; developing marketing strategies; executing marketing plans; developing sales strategies; developing and managing marketing plans; and managing sales partners and alliances.""" .

ex:PCF_10101 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Understand markets, customers, and capabilities""" ;
    ex:pcfID "10101" ;
    ex:hierarchyID "3.1" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Making sense of the market and customers to identify the right opportunities to be capitalized, given the organization's competencies. Discern trends and shift in the market and customers. Identify the right market opportunities that fit closely with the organization's capabilities and strategy by gathering intelligence on various attributes of different market/customer segments.""" ;
    skos:broader ex:PCF_10004 .

ex:PCF_10106 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform customer and market intelligence analysis""" ;
    ex:pcfID "10106" ;
    ex:hierarchyID "3.1.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Gathering intelligence on the market and customers. Closely examine the inherent attributes and collective behavior of the various market and customer segments. Track trends in the market. Determine what drives the customers to make purchasing decisions in order to identify opportunities in the market.""" ;
    skos:broader ex:PCF_10101 .

ex:PCF_10108 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct customer and market research""" ;
    ex:pcfID "10108" ;
    ex:hierarchyID "3.1.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Carrying out research studies to understand the behavior of customers and the realities of the market. Undertake research to understand the market conditions as well as the characteristics, drives, and desires of prospective customers. Gather highly contextualized intelligence through primary and secondary research methods, with the objective of gaining insights over how to best seize a market opportunity. Consider assistance from professional research services.""" ;
    skos:broader ex:PCF_10106 .

ex:PCF_10114 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Understand consumer needs and historical behaviors""" ;
    ex:pcfID "10114" ;
    ex:hierarchyID "3.1.1.1.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Identifying the factors that drive the targeted market segment. Model customer purchasing patterns, and forecast their future purchasing behavior. """ ;
    skos:broader ex:PCF_10108 .

ex:PCF_21424 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Predict customer purchasing behavior""" ;
    ex:pcfID "21424" ;
    ex:hierarchyID "3.1.1.1.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Using customer segmentation tools to examine past customer behavior to predict future purchasing patterns.  """ ;
    skos:broader ex:PCF_10108 .

ex:PCF_10109 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify market segments""" ;
    ex:pcfID "10109" ;
    ex:hierarchyID "3.1.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying a section of the customer population to target for marketing products/services. Create segments within the customer population for targeted marketing campaigns, which increase the efficacy of marketing outlay. Determine the right customer segments, craft effective marketing messages, and efficiently communicate them. Determine the optimal pricing mix. Consider assistance from professional services for market segmentation studies, with coordination and oversight from the marketing/sales functions.""" ;
    skos:broader ex:PCF_10106 .

ex:PCF_10115 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine market share gain/loss""" ;
    ex:pcfID "10115" ;
    ex:hierarchyID "3.1.1.2.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining the increase or decrease of the company's sales volume in the targeted markets. Conduct an analysis to determine the factors and underlying causes that affect the changes in the demand for products or services offered. Consider changes in offerings or in the business strategy to regain or increase the market share.""" ;
    skos:broader ex:PCF_10109 .

ex:PCF_10110 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze market and industry trends""" ;
    ex:pcfID "10110" ;
    ex:hierarchyID "3.1.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining large-scale shifts and trends, with relevance to the organization's products/services. Vet the industrial and larger market landscape to identify broad-based movements that could have a direct or tangential impact on the uptake of the organization's products/services. Examine, among other things, the market capitalization of similar products, the profitability of organizations offering competing products/services, the stock price of key vendors/suppliers in the organizational value-chain, the rate and scale of innovation activity in the organization's product/service category, the price and availability of raw materials, and the shelf-life of similar products/services. Conduct primary and secondary research, and consider enlisting professional services.""" ;
    skos:broader ex:PCF_10106 .

ex:PCF_10111 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze competing organizations, competitive/substitute products/services""" ;
    ex:pcfID "10111" ;
    ex:hierarchyID "3.1.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining the strengths and weaknesses of competing organizations. Assess competing organizations for offerings, product strategy, marketing and delivery channels, etc. Analyze the usability experience, durability, USP, and other key attributes of competing and substitute products. Gather competitive intelligence, and consider enlisting professional services.""" ;
    skos:broader ex:PCF_10106 .

ex:PCF_10112 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate existing products/services""" ;
    ex:pcfID "10112" ;
    ex:hierarchyID "3.1.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining the brands owned and products offered in the market. Determine the relative position of the existing products/brands in the marketplace.""" ;
    skos:broader ex:PCF_10106 .

ex:PCF_10113 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Assess internal and external business environment""" ;
    ex:pcfID "10113" ;
    ex:hierarchyID "3.1.1.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Understanding the culture and environment in which you're operating. Analyze how internal decision-making, thought processes, financial circumstances, and more affect the ability to bring new products to market. Survey or analyze the market into which the products would be introduced.""" ;
    skos:broader ex:PCF_10106 .

ex:PCF_10107 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate and prioritize market opportunities""" ;
    ex:pcfID "10107" ;
    ex:hierarchyID "3.1.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Appraising market opportunities by quantifying and subjecting them to prioritization, as well as validation tests. Closely examine the market opportunities that have been identified by Perform customer and market intelligence analysis [10106]. Triangulate those opportunities to capitalize by finding a fit between identified opportunities and the composite of organizational capabilities and business strategy.""" ;
    skos:broader ex:PCF_10101 .

ex:PCF_10116 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Quantify market opportunities""" ;
    ex:pcfID "10116" ;
    ex:hierarchyID "3.1.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Attaching quantifiable indicators to opportunities that have been identified in the market. Compute estimated figures of the approximate value that can be captured with the provision of existing products/services (i.e., the extent of financial benefits that can be reaped in the market).""" ;
    skos:broader ex:PCF_10107 .

ex:PCF_10117 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine target segments""" ;
    ex:pcfID "10117" ;
    ex:hierarchyID "3.1.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying the targeted segment of customers. Deduce those particular customer segments that are to be targeted from among the market segments. """ ;
    skos:broader ex:PCF_10107 .

ex:PCF_18941 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify under-served and saturated market segments""" ;
    ex:pcfID "18941" ;
    ex:hierarchyID "3.1.2.2.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining which groups of potential customers do not yet, or already do have access to the product or a service that the company produces or markets. Use those findings to create specialized product offerings and differentiated marketing campaigns.""" ;
    skos:broader ex:PCF_10117 .

ex:PCF_10118 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prioritize opportunities consistent with capabilities and overall business strategy""" ;
    ex:pcfID "10118" ;
    ex:hierarchyID "3.1.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating an index of market opportunities, and arrange them in order of preference. Prioritize based on the opportunities' adherence to the overall business strategy. Correlate with the competencies and capacities that the organization, as a whole, processes.""" ;
    skos:broader ex:PCF_10107 .

ex:PCF_10119 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Validate opportunities""" ;
    ex:pcfID "10119" ;
    ex:hierarchyID "3.1.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Confirming the practicability and reasonableness of the market opportunities that have been identified. Give substance to the real-time feasibility of the market opportunities.""" ;
    skos:broader ex:PCF_10107 .

ex:PCF_10120 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Test with customers/consumers""" ;
    ex:pcfID "10120" ;
    ex:hierarchyID "3.1.2.4.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Validating identified market opportunities by testing company's offerings on limited-size samples of the consumer population that are hypothesized to be representative of the target market at large and to have similar purchasing behavior. The feedback gained through consumer testing can be used to modify or reject product offerings before their full scale launch, saving the company valuable resources, should the initial offering not be successful.""" ;
    skos:broader ex:PCF_10119 .

ex:PCF_10121 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Confirm internal capabilities""" ;
    ex:pcfID "10121" ;
    ex:hierarchyID "3.1.2.4.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Verifying that the company has sufficient infrastructure and resources to deliver their offerings in a timely and cost-effective manner, and that it is able to scale up from the small-scale market samples, used for consumer testing, to the entire identified market segment.""" ;
    skos:broader ex:PCF_10119 .

ex:PCF_10102 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop marketing strategy""" ;
    ex:pcfID "10102" ;
    ex:hierarchyID "3.2" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Charting a strategic course for marketing products/services. This will include defining the value proposition, creating a mechanism for pricing, and determining the right mix of marketing channels. Create a specific positioning and branding for the organization's offerings. Enlist marketing head to lead, with inputs from the business development and sales functions.""" ;
    skos:broader ex:PCF_10004 .

ex:PCF_11168 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define offering and customer value proposition""" ;
    ex:pcfID "11168" ;
    ex:hierarchyID "3.2.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Refining the attributes of organizational offerings to define their value proposition for the customer. Clearly define the suite of offerings in terms of the value delivered, from the perspective of what the customer desires. Validate the benefits delivered to the customers against target market segments, using techniques such as minimum viable product. Position brands for the respective products/services, in line with their unique value proposition and aligned with customers needs.""" ;
    skos:broader ex:PCF_10102 .

ex:PCF_11169 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define offering and positioning""" ;
    ex:pcfID "11169" ;
    ex:hierarchyID "3.2.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Defining problem(s) that the organization's products/services solve for the customers, thereby determining how they are positioned in the market. Refine the product/service concepts from the perspective of customers. Succinctly outline the problem the organization's offerings solves for the customers, making a case for why the customer should buy a product or use a service. Define the offering's unique value.""" ;
    skos:broader ex:PCF_11168 .

ex:PCF_11170 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop value proposition including brand positioning for target segments""" ;
    ex:pcfID "11170" ;
    ex:hierarchyID "3.2.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Boosting the attractiveness of products/services to the targeted customers, and creating a unique brand projection around these features. Identify and enhance those product/service features that reinforce the attractiveness of these offerings, for these segment of customers. Underscore the perceived value delivered to the customers by clearly specifying the relevance and desirability of these products/services. Once it has been clarified how the organization's offerings meet the customer's expectations or deliver specific benefits, position the brands around these benefits.""" ;
    skos:broader ex:PCF_11168 .

ex:PCF_11171 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Validate value proposition with target segments""" ;
    ex:pcfID "11171" ;
    ex:hierarchyID "3.2.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Validating the desirability of the perceived value delivered by the organization's offerings, to the targeted customer segment. Substantiate the value of the benefits accrued to the customers through the organization's offerings. Justify the value proposition in light of the targeted segments by gathering feedback (using teaser demonstrations, surveys, interviews, primary research studies, and customer case studies). Corroborate the benefits of the organization's offerings.""" ;
    skos:broader ex:PCF_11168 .

ex:PCF_11172 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop new branding""" ;
    ex:pcfID "11172" ;
    ex:hierarchyID "3.2.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating branding collaterals and campaigns that carve a significant and differentiated presence for the organization's offerings. Create new collaterals, which include names, designs, and symbols, for their products/services. Ensure collaterals reflect the unique value proposition of the respective offerings through a consistent theme. Create advertising and promotion campaigns.""" ;
    skos:broader ex:PCF_11168 .

ex:PCF_10123 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define pricing strategy""" ;
    ex:pcfID "10123" ;
    ex:hierarchyID "3.2.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating a pricing strategy and mechanism that aligns with the benefits of the products/services, as perceived by customers. Chart a strategic course and a methodology that can guide the pricing of products/services. Draw heavily from the customer value proposition, and balance the expectations of different divisions inside the organization, while delivering the maximum ROI.""" ;
    skos:broader ex:PCF_10102 .

ex:PCF_13169 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct pricing analysis""" ;
    ex:pcfID "13169" ;
    ex:hierarchyID "3.2.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyzing marketing objectives, consumer demand, product attributes, competitors' pricing, and economic trends to determine optimum prices for the set of products and services that the company offers or intends to offer by delivering maximum ROI.""" ;
    skos:broader ex:PCF_10123 .

ex:PCF_10124 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish guidelines for applying pricing and discounting of products/services""" ;
    ex:pcfID "10124" ;
    ex:hierarchyID "3.2.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a framework that allows for a uniform methodology while determining the price of individual offerings. Devise a blueprint for establishing the pricing of specific products/services. Create guidelines that factor in the cost of production/servicing, price sensitivity, product lifecycle, and the price of competing/substitute products.""" ;
    skos:broader ex:PCF_10123 .

ex:PCF_19999 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish pricing targets""" ;
    ex:pcfID "19999" ;
    ex:hierarchyID "3.2.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining optimum prices for individual products or services on the basis of the cost of producing, distributing and marketing the offerings, pricing analysis and general pricing strategy.""" ;
    skos:broader ex:PCF_10123 .

ex:PCF_10125 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Approve pricing strategies/policies and targets""" ;
    ex:pcfID "10125" ;
    ex:hierarchyID "3.2.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Confirming the strategy and specifications developed for pricing the organization's products/services. Approve pricing guidelines by vetting the soundness of the methodology and the guidelines' alignment with the value proposition.""" ;
    skos:broader ex:PCF_10123 .

ex:PCF_20000 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define and manage channel strategy""" ;
    ex:pcfID "20000" ;
    ex:hierarchyID "3.2.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Establishing all the activities needed to identify the appropriate channels to market to different customer segments as defined in Determine target segments [10117]. This involves finding channel partners, ensuring that the channels align with organizational strategy for each segment, and the final channel selection process.""" ;
    skos:broader ex:PCF_10102 .

ex:PCF_20001 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine channels to be supported""" ;
    ex:pcfID "20001" ;
    ex:hierarchyID "3.2.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Deciding which distributors, wholesalers and retailers the company will use to promote its offerings and to distribute its products and services to the target market. Narrowing down which intermediaries the company will use will affect retail prices of individual products, and should therefore be included in the pricing analysis.""" ;
    skos:broader ex:PCF_20000 .

ex:PCF_20002 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish channel objectives""" ;
    ex:pcfID "20002" ;
    ex:hierarchyID "3.2.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying the role that each chosen marketing channels plays in the larger distribution network with respect to the organizational marketing strategy. Determine intermediary costs for shipping, handling, transporting, warehousing, insurance and marketing that incur and accumulate in the distribution channel.""" ;
    skos:broader ex:PCF_20000 .

ex:PCF_10127 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine channel role and fit with target segments""" ;
    ex:pcfID "10127" ;
    ex:hierarchyID "3.2.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyze the various channels for their relevance to the targeted segments. Identify the channel that can effectively market to the targeted customers in regard to the drives, desires, and characteristics of these populations, their uptake, extent of engagement, frequency of use, and effectiveness in communicating.""" ;
    skos:broader ex:PCF_20000 .

ex:PCF_10128 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Select channels for target segments""" ;
    ex:pcfID "10128" ;
    ex:hierarchyID "3.2.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Choose the most pertinent marketing channel for the targeted segments (based on Determine channel fit with target segments [10127]).""" ;
    skos:broader ex:PCF_20000 .

ex:PCF_20003 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify required channel capabilities""" ;
    ex:pcfID "20003" ;
    ex:hierarchyID "3.2.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the maximum output rate required from a distribution channel to optimally market and deliver the products and services the company offers or would like to offer. Ideally, a channel should be able to adapt to a certain degree of variability in the demand for the offerings, and able scale up if needed.""" ;
    skos:broader ex:PCF_20000 .

ex:PCF_10126 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate channel attributes and potential partners""" ;
    ex:pcfID "10126" ;
    ex:hierarchyID "3.2.3.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assessing the attributes of all marketing channels, and evaluating the key partners in those channels. Closely examine the various characteristics of all available marketing channels such as the cost of using them, durability of impact, applicability to the organization's products/services, turn-around time, involvement of middlemen, and conversion rate. Analyze key partners in the marketing channels including those who have been associated with the organization; evaluate their capabilities, the scale and scope of their operations, quality of support provided, etc.""" ;
    skos:broader ex:PCF_20000 .

ex:PCF_20004 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Orchestrate seamless customer experience across supported channels""" ;
    ex:pcfID "20004" ;
    ex:hierarchyID "3.2.3.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Coordinating marketing and distribution efforts across different channels that integrate well with each other, are in conformance with company values, visual identity and branding, and offer uniform customer service experience that drives customer loyalty and repeat business.""" ;
    skos:broader ex:PCF_20000 .

ex:PCF_16590 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define omni-channel strategy""" ;
    ex:pcfID "16590" ;
    ex:hierarchyID "3.2.3.7.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Devising a strategy to market company's products or services seamlessly through all or most channels that are in widespread use among the target market. This may mean cross-channel access to customer preferences and purchasing history to accept returned merchandise, provide refunds, resolve payment issues or to provide technical support. """ ;
    skos:broader ex:PCF_20004 .

ex:PCF_16591 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define omni-channel requirements""" ;
    ex:pcfID "16591" ;
    ex:hierarchyID "3.2.3.7.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Identifying necessary preconditions that a channel should fulfill in order to be included as one of the adopted channels, such as required throughput capacities, service capabilities, competitive pricing, and alignment with organizational marketing strategies. """ ;
    skos:broader ex:PCF_20004 .

ex:PCF_16592 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop omni-channel policies and procedures""" ;
    ex:pcfID "16592" ;
    ex:hierarchyID "3.2.3.7.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Determining the detailed policies and procedures that each of the channels needs to follow in order to conform to the organizational marketing strategy and to provide seamless customer service experience.""" ;
    skos:broader ex:PCF_20004 .

ex:PCF_20005 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage execution roadmap""" ;
    ex:pcfID "20005" ;
    ex:hierarchyID "3.2.3.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the actions that need to be taken for successful multichannel marketing, the ordering, timing and dependencies of the steps, and the governance mechanism for reviewing and changing the protocol, if needed.""" ;
    skos:broader ex:PCF_20000 .

ex:PCF_20006 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze and manage channel performance""" ;
    ex:pcfID "20006" ;
    ex:hierarchyID "3.2.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Monitoring marketing and distribution efforts of all channels individually and as a network. Re-distribute or add resources to channels that perform better than expected. Purge or consolidate under-performing channels, and find more promising replacements.""" ;
    skos:broader ex:PCF_10102 .

ex:PCF_16573 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish channel-specific measures and targets""" ;
    ex:pcfID "16573" ;
    ex:hierarchyID "3.2.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining measurable parameters to be used for comparing the performance of different marketing channels. Decide on benchmarks and values for optimum or desired performance. """ ;
    skos:broader ex:PCF_20006 .

ex:PCF_16574 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor and report performance""" ;
    ex:pcfID "16574" ;
    ex:hierarchyID "3.2.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Tracking trends and changes in performance inside individual marketing channels and in channels collectively. Summarize and document results. Alert relevant parties about significant or unexpected deviations from expected behaviors.""" ;
    skos:broader ex:PCF_20006 .

ex:PCF_16575 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor and report events influencing factors""" ;
    ex:pcfID "16575" ;
    ex:hierarchyID "3.2.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyzing the factors and circumstances that influence desired outcomes. Communicate core findings to relevant parties.""" ;
    skos:broader ex:PCF_20006 .

ex:PCF_16500 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze channel performance""" ;
    ex:pcfID "16500" ;
    ex:hierarchyID "3.2.4.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conducting an analysis to review channel performance with respect to chosen metrics, benchmarks and performance targets [16573]. Compare to past performance and forecasts for the channel.""" ;
    skos:broader ex:PCF_20006 .

ex:PCF_16501 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop plan for channel improvements""" ;
    ex:pcfID "16501" ;
    ex:hierarchyID "3.2.4.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Devising a course of action to be taken to improve under-performing channels and to promote or expand channels that surpass expectations.""" ;
    skos:broader ex:PCF_20006 .

ex:PCF_16848 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop marketing communication strategy""" ;
    ex:pcfID "16848" ;
    ex:hierarchyID "3.2.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Establishing marketing communications that deliver promotional messages, in a coordinated way, through multiple marketing channels, such as print, radio, television, direct mail, online or mobile advertising, email, social media or personal selling.""" ;
    skos:broader ex:PCF_10102 .

ex:PCF_16849 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop customer communication calendar""" ;
    ex:pcfID "16849" ;
    ex:hierarchyID "3.2.5.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Timing and scheduling the delivery of marketing messages to maximize their impact on customer purchasing behavior. Integrate individual messages to larger marketing campaigns and to seasonal purchasing patterns.""" ;
    skos:broader ex:PCF_16848 .

ex:PCF_16850 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define public relations (PR) strategy""" ;
    ex:pcfID "16850" ;
    ex:hierarchyID "3.2.5.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Deciding how to promote and maintain a favorable public image of the company in the eyes of its employees, customers, investors, suppliers, politicians or the general public. This may involve various means but is frequently conducted through publicity, education, corporate social responsibility, charitable causes or civic engagements.""" ;
    skos:broader ex:PCF_16848 .

ex:PCF_16851 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define direct marketing strategy""" ;
    ex:pcfID "16851" ;
    ex:hierarchyID "3.2.5.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Devising a master plan how to select potential customers or qualified clients for customized offers, and contact them on one-to-one basis through chat, phone, email or regular mail. The strategy would need to take into account that personalizing offers and contacting customers individually is an effective but resource-intensive marketing technique, and that ill-targeted offers risk at angering and alienating the contactees.""" ;
    skos:broader ex:PCF_16848 .

ex:PCF_16852 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define internal marketing communication strategy""" ;
    ex:pcfID "16852" ;
    ex:hierarchyID "3.2.5.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a program to promote the objectives, values, products and services of the company to its employees by treating them as potential customers, in order to extend company client base, increase employee engagement or to foster brand advocacy.""" ;
    skos:broader ex:PCF_16848 .

ex:PCF_16853 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify new media for marketing communication""" ;
    ex:pcfID "16853" ;
    ex:hierarchyID "3.2.5.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Finding emerging media based on digital or other technologies that would enable the company to increase the speed and volume of marketing communications, to make communications more interactive and to customize promotional messages more easily to the target audience, thus rendering them more effective.""" ;
    skos:broader ex:PCF_16848 .

ex:PCF_16854 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define new media communication strategy""" ;
    ex:pcfID "16854" ;
    ex:hierarchyID "3.2.5.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a marketing strategy that is maximally effective in a new or emerging media channel by capitalizing on its novel attributes and capabilities.""" ;
    skos:broader ex:PCF_16848 .

ex:PCF_16855 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define point of sale (POS) communication strategy""" ;
    ex:pcfID "16855" ;
    ex:hierarchyID "3.2.5.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing a framework for coordinated marketing to increase the profitability and increase brand awareness at the point of sale. This may include promotional posters on product shelves or island displays, advertisements in shopping carts, stickers on the floor that lead consumers to the promoted product, multi-buy promotions, coupons on sales receipts, etc. """ ;
    skos:broader ex:PCF_16848 .

ex:PCF_18627 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define communication guidelines and mechanisms""" ;
    ex:pcfID "18627" ;
    ex:hierarchyID "3.2.5.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing standardized procedures for effective communication that maximizes ROI, promotes brand awareness and respects customers. In its simplest form, it includes a message (what is to be said), a target (to whom the message is reaching) and a medium or a channel (where the message is to be said).""" ;
    skos:broader ex:PCF_16848 .

ex:PCF_18924 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design and manage customer loyalty program""" ;
    ex:pcfID "18924" ;
    ex:hierarchyID "3.2.6" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating and managing a customer loyalty program. The loyalty program is a key part of marketing, with an elaborate strategy and process for acquiring, retaining, and engaging with members. Members are engaged and acquainted to the loyalty program, thus growing relationship and adding value through the program. """ ;
    skos:broader ex:PCF_10102 .

ex:PCF_20007 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define customer loyalty program""" ;
    ex:pcfID "20007" ;
    ex:hierarchyID "3.2.6.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Devising procedures and mechanisms to retain existing customers, promote repeat business and increase the likelihood that previous customers to continue to buy products or services from the company. This may be achieved by rewarding customers for repeat business by means of gifts, discounts, redeemable \"points\", or prioritized access to new products, events or services. """ ;
    skos:broader ex:PCF_18924 .

ex:PCF_18925 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Acquire members to customer loyalty program""" ;
    ex:pcfID "18925" ;
    ex:hierarchyID "3.2.6.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Convincing customers to register their personal information with the company and be assigned a unique identifier that they use when making purchases. The identifier makes it easier for the company to track customer purchases. Customers are rewarded by various incentives that encourage repeat business [20007]. """ ;
    skos:broader ex:PCF_18924 .

ex:PCF_18926 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Build engagement and relationship with members""" ;
    ex:pcfID "18926" ;
    ex:hierarchyID "3.2.6.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Building deeper relationships between a customer and a brand in order to promote customer loyalty and derive repeat business. Besides making frequent purchases, highly engaged customers refer family, friends and colleagues to make purchases as well, consume and re-broadcast promotional materials, provide feedback to the purchases they make and do not support competing brands.""" ;
    skos:broader ex:PCF_18924 .

ex:PCF_16633 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor customer loyalty program benefits to the enterprise and the customer""" ;
    ex:pcfID "16633" ;
    ex:hierarchyID "3.2.6.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Surveying and tracking the benefits of customer loyalty programs both for the company and for customers. Compare with comparable loyalty programs instituted in competitor companies. Propose changes as needed to keep up with market trends. """ ;
    skos:broader ex:PCF_18924 .

ex:PCF_18927 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Optimize loyalty program value to both the enterprise and the customer""" ;
    ex:pcfID "18927" ;
    ex:hierarchyID "3.2.6.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Enhancing the customer loyalty program so that it will yield maximum value both for the company and for the patrons enrolled in the program, increasing customer retention and continued engagement.""" ;
    skos:broader ex:PCF_18924 .

ex:PCF_20008 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage marketing plans""" ;
    ex:pcfID "20008" ;
    ex:hierarchyID "3.3" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Creating specific plans to market offerings to customers. This process group includes processes for making budgets, identifying and developing media, pricing products and services, managing packaging, managing marketing content and promotional activities, tracking and responding to customer insight and monitoring measures established within \"develop marketing strategy\". Additionally, in this process group, organizations take action on plans made in earlier processes. Here, marketing and customers are managed and measured along with any supporting materials.""" ;
    skos:broader ex:PCF_10004 .

ex:PCF_10148 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish goals, objectives, and measures for products/services by channel/segment""" ;
    ex:pcfID "10148" ;
    ex:hierarchyID "3.3.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Determining what to achieve by marketing. Create qualitative and quantitative targets. Establish metrics to track performance (for individual Market segments [10109] and Channels for target segments [10129]). Enlist the head of marketing to determine marketing priorities and the related measures. (The decision in establishing these goals, objectives, and metrics is founded in Develop marketing strategy [10102] and takes cues from current priorities and organizational strategy.)""" ;
    skos:broader ex:PCF_20008 .

ex:PCF_10149 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish marketing budgets""" ;
    ex:pcfID "10149" ;
    ex:hierarchyID "3.3.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating a budget for the organization's marketing efforts, in line with the business-wide strategic outlook. Create a plan to distribute resources for achieving the marketing strategy in light of the overall business strategy. Make cost assumptions; calculate the estimated total revenue from the marketing activities against the costs/expenses of these activities. Forecast the return on investment. Attribute costs to the appropriate marketing activities such as promotional campaigns, advertising, marketing communications, PR campaigns, personnel, and office space. Enlist the financial and marketing functions.""" ;
    skos:broader ex:PCF_20008 .

ex:PCF_10155 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Confirm marketing alignment to business strategy""" ;
    ex:pcfID "10155" ;
    ex:hierarchyID "3.3.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Ensuring corroboration of the marketing strategy and the organizational strategy. Ensure the organization's marketing strategy/plan aligns with the overall business strategy. Fine-tune the marketing plan according to the organizational strategy.""" ;
    skos:broader ex:PCF_10149 .

ex:PCF_10156 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine costs of marketing""" ;
    ex:pcfID "10156" ;
    ex:hierarchyID "3.3.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Calculating the total cost of marketing the organization's portfolio of products/services. Calculate the total outlay needed for promoting, selling, and delivering the organization's products/services to customers. Account for all costs to acquire customers and sustain a relationship with them. Include the expenses needed for promotional actives, warehousing, transactional costs, and distribution of the organization's offering.""" ;
    skos:broader ex:PCF_10149 .

ex:PCF_10157 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create marketing budget""" ;
    ex:pcfID "10157" ;
    ex:hierarchyID "3.3.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Estimating the outlay required for promoting, selling, and distributing the products/services of the organization. Add up the expenses of all activities necessitated in marketing, such as promotional campaigns, advertising, marketing communications, PR campaigns, employing skilled personnel, and office space.""" ;
    skos:broader ex:PCF_10149 .

ex:PCF_17683 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine projected ROI for marketing investment""" ;
    ex:pcfID "17683" ;
    ex:hierarchyID "3.3.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Estimating how much profit the company would generate for its expenses on marketing . Forecasted return on investment, used as a metric to gauge the efficiency of marketing, is beneficial in revising marketing budgets and adjusting costs to improve the overall yield. """ ;
    skos:broader ex:PCF_10149 .

ex:PCF_20593 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage pricing""" ;
    ex:pcfID "20593" ;
    ex:hierarchyID "3.3.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Determining and maintaining a pricing mechanism based on forecasted sales and that enables a pricing equilibrium for the lifecycles of products/services. Create a pricing mechanism, factoring in attributes relating to the market, customers, sales, and the cost of production. Implement this pricing mechanism over all products/services. Analyze its performance, and adjust accordingly.""" ;
    skos:broader ex:PCF_20008 .

ex:PCF_20009 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Understand resource requirements for each product/service and delivery channel/method""" ;
    ex:pcfID "20009" ;
    ex:hierarchyID "3.3.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the production and distribution costs for each product or service, and each channel or method as factors in determining overall pricing.""" ;
    skos:broader ex:PCF_20593 .

ex:PCF_18948 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine corporate incentives""" ;
    ex:pcfID "18948" ;
    ex:hierarchyID "3.3.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Introducing financial inducements, such as discounts, to distributors, resellers or vendors as a motivation to prioritize selling company's products or services over those of its competitors.""" ;
    skos:broader ex:PCF_20593 .

ex:PCF_10163 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine pricing based on volume/unit forecast""" ;
    ex:pcfID "10163" ;
    ex:hierarchyID "3.3.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing a dynamic pricing mechanism for the organization's offerings that is supported by the number of units in production. Outline a system for determining the optimum price point for each product/service. Based this model on an estimation of the volume of anticipated sales for each offering and variable costs.""" ;
    skos:broader ex:PCF_20593 .

ex:PCF_10164 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Execute pricing plan""" ;
    ex:pcfID "10164" ;
    ex:hierarchyID "3.3.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Implementing the pricing mechanism to determine prices for all individual offerings in the organizational portfolio. Calculate the prices of all offerings based on the established methodology and/or formulaic structure.""" ;
    skos:broader ex:PCF_20593 .

ex:PCF_10165 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate pricing performance""" ;
    ex:pcfID "10165" ;
    ex:hierarchyID "3.3.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining the efficiency of pricing with the objective of identifying any divergence from the equilibrium prices and avoiding any deadweight loss. Gauge the performance of the pricing plan by tracking growth in the revenue and/or customer uptake, secured as a result of new prices. Measure the performance of pricing by periodically checking the profits generated from the sale of each of the organization's offerings against the backdrop of any events that may have influenced the uptake of a certain good/service by the customer base.""" ;
    skos:broader ex:PCF_20593 .

ex:PCF_10166 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Refine pricing as needed""" ;
    ex:pcfID "10166" ;
    ex:hierarchyID "3.3.3.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Refining the pricing mechanism to create equitable prices for all products/services with the objective of maximizing the profits and/or customer uptake of these offerings. Reconcile the pricing mechanism in order to achieve equilibrium pricing. Adjust the prices for all of the organization's offerings, using the insights gleaned from examining how much profit or customer uptake is generated by the present pricing strategy.""" ;
    skos:broader ex:PCF_20593 .

ex:PCF_11495 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Implement promotional pricing programs""" ;
    ex:pcfID "11495" ;
    ex:hierarchyID "3.3.3.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing schemes that offer lower pricing for a limited time as a promotional and sales incentive when launching a new product or a service. """ ;
    skos:broader ex:PCF_20593 .

ex:PCF_11496 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Implement other retail pricing programs""" ;
    ex:pcfID "11496" ;
    ex:hierarchyID "3.3.3.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the optimum consumer pricing for each product or service at the point of sale, based on production and distribution costs and estimated sales volume.""" ;
    skos:broader ex:PCF_20593 .

ex:PCF_11497 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Communicate and implement price changes""" ;
    ex:pcfID "11497" ;
    ex:hierarchyID "3.3.3.9" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Assigning new prices or pricing adjustments to products or services to replace the original base prices. Update the prices in product catalogs and databases, and disseminate the information through all involved distribution and marketing channels.""" ;
    skos:broader ex:PCF_20593 .

ex:PCF_17684 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Achieve regulatory approval for pricing""" ;
    ex:pcfID "17684" ;
    ex:hierarchyID "3.3.3.10" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Obtaining internal price approvals and governmental approvals that are required for licensed products and for products that can be reimbursed by the government.""" ;
    skos:broader ex:PCF_20593 .

ex:PCF_20010 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage promotional activities""" ;
    ex:pcfID "20010" ;
    ex:hierarchyID "3.3.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Conceptualizing, testing, and executing product/service/brand promotions. Once a promotion has launched, this process continues as the organization tweaks parts of the promotion or chooses to use ideas or lessons learned during the promotion in future activities. The promotion's performance according to organizational measures is also evaluated in this process. Determine early on whether you need third party help with promotion. Purchase lists, consult with social media experts, hire seasonal staff, or pay for additional research.""" ;
    skos:broader ex:PCF_20008 .

ex:PCF_10167 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define promotional concepts and objectives""" ;
    ex:pcfID "10167" ;
    ex:hierarchyID "3.3.4.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Outlining a conceptual framework for all promotional activity in order to create an overarching aspiration and ensure consistency. Create a plan for running promotional programs and designing the associated activities in order to increase visibility or sales. Determine how the organization quantifies what it wishes to achieve from these activities, what sort of messages the organization comfortable publicizing, what channels the organization wishes to employ, etc.""" ;
    skos:broader ex:PCF_20010 .

ex:PCF_10159 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop marketing messages""" ;
    ex:pcfID "10159" ;
    ex:hierarchyID "3.3.4.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing the central messages for a segment of its customers. Craft concise statements that position the value proposition of individual products/services around the pressing concerns in the market, thereby showing how the organization's offerings are the right fit for the customers.""" ;
    skos:broader ex:PCF_20010 .

ex:PCF_10160 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define target audience""" ;
    ex:pcfID "10160" ;
    ex:hierarchyID "3.3.4.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the appropriate audience to direct marketing efforts at. Identify the particular group of customers to target. Discover the appropriate customer groups at a micro-level. Use techniques such as segmentation analysis, whereby the entire population is sliced according to certain demographic or behavioral attributes.""" ;
    skos:broader ex:PCF_20010 .

ex:PCF_10168 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan and test promotional activities""" ;
    ex:pcfID "10168" ;
    ex:hierarchyID "3.3.4.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Developing a scheme for executing the promotional programs and campaigns, and testing these on sample audiences. Create a program plan, and carry out trials for promotional activities. Develop a scheme for how, when, where, and by whom the promotional schemes and campaigns will be deployed. Design incentives that convince or tempt the consumer to take up the organization's offerings. Conduct focus groups and pilot programs that reach out to a smaller number of people from among the target audiences to validate effectiveness.""" ;
    skos:broader ex:PCF_20010 .

ex:PCF_10169 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Execute promotional activities""" ;
    ex:pcfID "10169" ;
    ex:hierarchyID "3.3.4.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Executing promotional programs in the market for reaching out to the desired customer segments. Implement the promotional schemes and campaigns. Create collaterals for the dissemination of information about the product, product line, brand, or company to the target audiences in an effective manner. Leverage relationships with distributors, vendors, and retailers. Consider enlisting professional services such as design, PR, and advertising firms.""" ;
    skos:broader ex:PCF_20010 .

ex:PCF_10170 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Evaluate promotional performance metrics""" ;
    ex:pcfID "10170" ;
    ex:hierarchyID "3.3.4.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Evaluating the success of promotional programs through metrics that track the impact of these activities. Examine the performance of promotional activities. Measure the success of these programs through metrics representative of customer uptake, market penetration, sustenance of impact created, revenue growth through offerings marketed, etc. Measure through primary data collection. Analyze through various statistical techniques to generate insights.""" ;
    skos:broader ex:PCF_20010 .

ex:PCF_10171 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Refine promotional performance metrics""" ;
    ex:pcfID "10171" ;
    ex:hierarchyID "3.3.4.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Fine-tuning promotional activities by employing the insights gleaned from the quantitative, as well as any qualitative, performance evaluations. Change certain attributes of the schemes, campaigns, and programs deployed in order to increase the impact generated, in terms of measures already agreed upon such as customer uptake, market penetration, sustenance of impact created, and revenue growth through offerings marketed.""" ;
    skos:broader ex:PCF_20010 .

ex:PCF_10172 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Incorporate learning into future/planned consumer promotions""" ;
    ex:pcfID "10172" ;
    ex:hierarchyID "3.3.4.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Incorporating the understanding developed by studying promotional activities as well as refining them. Include the best practices and value-enhancing attributes identified in Refine promotional activities [10171] into similarly planned schemes, programs, and campaigns. Adjust promotional activities to further increase the effectiveness of the overall promotional efforts.""" ;
    skos:broader ex:PCF_20010 .

ex:PCF_10153 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Track customer management measures""" ;
    ex:pcfID "10153" ;
    ex:hierarchyID "3.3.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Collating all customer-centered metrics. The objective is to create a big-picture view of the customers' mindset and their behavior pertaining to the organization's offerings.""" ;
    skos:broader ex:PCF_20008 .

ex:PCF_10173 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine customer lifetime value""" ;
    ex:pcfID "10173" ;
    ex:hierarchyID "3.3.5.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Estimating customer loyalty and the average contribution made by them to revenues, over their lifespan. Use metrics to quantify the commitment of customers to the offerings of the organization, such as measures of tendency to switch brands/providers, number/proportion of return customers, and the number of customers using multiple substitutable offerings.""" ;
    skos:broader ex:PCF_10153 .

ex:PCF_10174 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze customer revenue trend""" ;
    ex:pcfID "10174" ;
    ex:hierarchyID "3.3.5.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyzing the revenue stream generated by the sale of the organization's products/services in order to identify trends therein. Examine data relating to the inflow of revenue from individual/groups of customers in order to identify patterns in the generation and sustenance of receivables. Conduct statistical analysis over the stream of revenue collected and the point of origin associated with each unit of sale through metrics such as the accounting rate of return, the GAAP revenue over a given period, and customer lifetime revenue.""" ;
    skos:broader ex:PCF_10153 .

ex:PCF_10175 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze customer attrition and retention rates""" ;
    ex:pcfID "10175" ;
    ex:hierarchyID "3.3.5.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Calculating measures that capture the proportion of customers the organization is able to retain to those it is losing. Compute metrics such as the tendency to switch brands/providers and the proportion of return customers to comprehend the trends within the customer attrition and retention rates.""" ;
    skos:broader ex:PCF_10153 .

ex:PCF_10176 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze customer metrics""" ;
    ex:pcfID "10176" ;
    ex:hierarchyID "3.3.5.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Studying all measures of the customer's behavior and conduct toward the organization's offerings in order to glean insight and identify patterns into their decision making. Closely examine all categories of data sets over a customer base. Analyze data points related to customer loyalty, retention, value, conversion, level of satisfaction, attrition, etc. Flesh out measures for an all-encompassing analysis that provides a macro-level picture of the customer's behavior and mindset related to the organization's products/services.""" ;
    skos:broader ex:PCF_10153 .

ex:PCF_10177 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Revise customer strategies, objectives, and plans based on metrics""" ;
    ex:pcfID "10177" ;
    ex:hierarchyID "3.3.5.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Reviewing and reappraising the strategies, objectives, and plans for all customer-centered processes. Revisit all customer-focused processes and activities--which relate to their acquisition, conversion, and retention--with the objective of revising them in light of customer analysis. Revise accordingly.""" ;
    skos:broader ex:PCF_10153 .

ex:PCF_16613 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze and respond to customer insight""" ;
    ex:pcfID "16613" ;
    ex:hierarchyID "3.3.6" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Reviewing and responding to customer feedback. Create tickets to initiate bug fixes or to propose feature updates. Monitor and track progress.""" ;
    skos:broader ex:PCF_20008 .

ex:PCF_16627 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor and respond to social media activity""" ;
    ex:pcfID "16627" ;
    ex:hierarchyID "3.3.6.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Following postings on social media to promote offerings, raise brand awareness, interact with customers, increase customer engagement and brand loyalty, respond to queries, gauge sentiment regarding company's products or services, and to derive customer insight.""" ;
    skos:broader ex:PCF_16613 .

ex:PCF_16614 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze customer website activity""" ;
    ex:pcfID "16614" ;
    ex:hierarchyID "3.3.6.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Examining user activity on company, vendor or reseller websites to improve traffic on and to the website, improve user experience on the website to simplify purchasing process and encourage repeat purchases, and to increase the site's visibility in search engine results. Various metrics can be used to measure user activity, such as number of users who are new, returning or unique, time spent on page, session duration, bounce rate, click through rate, conversion rate, and others.""" ;
    skos:broader ex:PCF_16613 .

ex:PCF_16615 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze customer purchase patterns""" ;
    ex:pcfID "16615" ;
    ex:hierarchyID "3.3.6.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Conducting analyses to uncover customer purchasing habits. Detect patterns and categorize users based on similar characteristics and behaviors, demographic information, geographic location, search history, etc.""" ;
    skos:broader ex:PCF_16613 .

ex:PCF_16616 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop business rules to provide personalized offers""" ;
    ex:pcfID "16616" ;
    ex:hierarchyID "3.3.6.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating formulas for personalized offers, purchasing recommendations and targeted advertisements for customers on the basis of previously detected purchase patterns [16615].""" ;
    skos:broader ex:PCF_16613 .

ex:PCF_16617 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Monitor effectiveness of personalized offers and adjust offers accordingly""" ;
    ex:pcfID "16617" ;
    ex:hierarchyID "3.3.6.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyzing how well the targeted offers perform to see whether they result in an increased conversion rate. Reanalyze the purchase patterns or modify those business rules that are produce effective recommendations.""" ;
    skos:broader ex:PCF_16613 .

ex:PCF_10154 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage packaging strategy""" ;
    ex:pcfID "10154" ;
    ex:hierarchyID "3.3.7" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating, executing, and administering a strategic road map for packaging products/services. Determine how to package products/services into finished offerings that can be directly marketed to prospective customers. Consider physicality, perishability, and shelf-life. Develop a strategy for packaging products/services. Test alternatives. Collect feedback. Refine the option chosen for execution. Have marketing, product development, and supply chain functions work together to develop sound packaging.""" ;
    skos:broader ex:PCF_20008 .

ex:PCF_10178 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Plan packaging strategy""" ;
    ex:pcfID "10178" ;
    ex:hierarchyID "3.3.7.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a strategic road map for how to package products/services into desirable solutions while increasing profitability. Create a scheme for how the organization will bundle and wrap its products/services into a presentable and sellable offering. Consider what aspects or components of an offering the organization can extract the maximum revenue from, and reduce the less profitable constituents while maintaining a high perceptible value for the customers. Balance maximizing profit with benefits to the customer.""" ;
    skos:broader ex:PCF_10154 .

ex:PCF_10179 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Test packaging options""" ;
    ex:pcfID "10179" ;
    ex:hierarchyID "3.3.7.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Piloting the packaged products/services in the market with a test audience. Create trial runs using techniques such as focus groups of the final product, wrapped and bundled.""" ;
    skos:broader ex:PCF_10154 .

ex:PCF_10180 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Execute packaging strategy""" ;
    ex:pcfID "10180" ;
    ex:hierarchyID "3.3.7.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Implementing the final packaging. Put into action the packaging strategy in light of the insights accumulated from testing various options.""" ;
    skos:broader ex:PCF_10154 .

ex:PCF_10181 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Refine packaging""" ;
    ex:pcfID "10181" ;
    ex:hierarchyID "3.3.7.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Fine-tuning the packaging that has been developed and tested using insights gleaned from feedback. """ ;
    skos:broader ex:PCF_10154 .

ex:PCF_21425 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop go-to-market strategy""" ;
    ex:pcfID "21425" ;
    ex:hierarchyID "3.3.8" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creation of a plan detailing how a company plans to execute a successful product release and promotion, and ultimately its sale to customers.""" ;
    skos:broader ex:PCF_20008 .

ex:PCF_16629 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage product marketing material""" ;
    ex:pcfID "16629" ;
    ex:hierarchyID "3.3.9" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating descriptions of products that are promotional and informative in content in order to initiate and increase sales. Marketing content consists of text, and optionally, images.""" ;
    skos:broader ex:PCF_20008 .

ex:PCF_16630 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage product images""" ;
    ex:pcfID "16630" ;
    ex:hierarchyID "3.3.9.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Producing or overseeing the creation or acquisition of photos, images and graphics for a product description, advertisement or a website. Like the copy [18131], product images are chosen and edited to enhance the product description and to convince consumers to purchase the product.""" ;
    skos:broader ex:PCF_16629 .

ex:PCF_18130 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage product copy""" ;
    ex:pcfID "18130" ;
    ex:hierarchyID "3.3.9.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Authoring or overseeing the creation of the textual portion of a product description, advertisement, or web page, including the headline, body, product attributes, and brand or advertiser information. A copy is designed to provide information about the product and to catch and hold the interest of prospective buyers long enough to persuade them to make a purchase. The copy of a website is called its content. """ ;
    skos:broader ex:PCF_16629 .

ex:PCF_10103 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop sales strategy""" ;
    ex:pcfID "10103" ;
    ex:hierarchyID "3.4" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Developing concrete plans for guiding and providing support to the sales function. Chart a road map for the sales function, including an analysis of historical sales data to create forecasts for anticipated sales, forming sales targets, forging partnerships with other economic agents to boost sales, devising a budget for this function, and determining metrics to measure customer management activities as well as progress in achieving sales targets.""" ;
    skos:broader ex:PCF_10004 .

ex:PCF_10129 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop sales forecast""" ;
    ex:pcfID "10129" ;
    ex:hierarchyID "3.4.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Developing a sales forecast for the organization's portfolio of offerings, bearing in mind the effect of promotional events, and fine-tuning these in the context of the new forecast. Estimate the future demand for the organization's products/services by analyzing historical information and any promotional activity.""" ;
    skos:broader ex:PCF_10103 .

ex:PCF_10134 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Gather current and historic order information""" ;
    ex:pcfID "10134" ;
    ex:hierarchyID "3.4.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Gathering all information about sales orders into an index. Create a directory of all sales orders, whether open or those which have been fulfilled. Track what product/service was ordered, the quantity ordered, who ordered it, the delivery date, the shipping method, the unit price and line total, payment terms, and any discount applied.""" ;
    skos:broader ex:PCF_10129 .

ex:PCF_10135 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze sales trends and patterns""" ;
    ex:pcfID "10135" ;
    ex:hierarchyID "3.4.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Analyzing sales order data to identify patterns in order to capitalize on emerging trends in the industry or the economy. Closely examine the directory of sales orders. Discern any patterns from this index, which is representative of the demand for the organization's offerings. Identify trends among the various segments of the organization's customer base to create forecasts. Glean patterns from this analysis, including the triangulation of segments that are showing the most growth in demand or those that represent the highest decline revenue, industry-wide trends such as decline/boost in overall demand, and any unusual trends that lie outside of the organization's expectations.""" ;
    skos:broader ex:PCF_10129 .

ex:PCF_10136 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Generate sales forecast""" ;
    ex:pcfID "10136" ;
    ex:hierarchyID "3.4.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Calculating the future demand for the organization's products/services. Use the trends and patterns identified in the sales data to estimate future demand. Use forecast to prepare for future customer demand and to recalibrate the strategic course of functions and business units.""" ;
    skos:broader ex:PCF_10129 .

ex:PCF_10137 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze historical and planned promotions and events""" ;
    ex:pcfID "10137" ;
    ex:hierarchyID "3.4.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Reviewing promotional activities' effect on the sales orders. Analyze all promotional events and campaigns that the organization has already employed or is planning to deploy. """ ;
    skos:broader ex:PCF_10129 .

ex:PCF_10130 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop sales partner/alliance relationships""" ;
    ex:pcfID "10130" ;
    ex:hierarchyID "3.4.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Cultivating an alliance of partners by identifying, analyzing, negotiating, and managing partnerships with other economic agents.""" ;
    skos:broader ex:PCF_10103 .

ex:PCF_10138 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify alliance opportunities""" ;
    ex:pcfID "10138" ;
    ex:hierarchyID "3.4.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying collaboration opportunities for selling, marketing, and distributing the organization's products/services. Determine any scope for partnering with other economic agents, with synergies for the marketing, sales, and/or distribution of the organization's products/services. Identify alliance opportunities that target customer segments who would be interested.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_10139 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Design alliance programs and methods for selecting and managing relationships""" ;
    ex:pcfID "10139" ;
    ex:hierarchyID "3.4.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating the frameworks needed to select alliance partners, and maintaining relationships with them. Create a framework for structured programs that can receive and support multiple alliances. Clearly outline the responsibilities and benefits of the alliance partners. Create frameworks for selecting the right alliance partners, and maintain a relationship with them. Create or repurpose teams of relationship managers and outline a methodology for selecting alliance partners.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_10140 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Select alliances""" ;
    ex:pcfID "10140" ;
    ex:hierarchyID "3.4.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Choosing alliance partners using the selected programs and methodology. Select the most feasible and profitable alliance partners, based on Design alliance programs and methods for selecting and managing relationships [10139] and through a careful scrutiny of the potential alliance.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_11465 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop customer trade strategy and customer objectives/targets""" ;
    ex:pcfID "11465" ;
    ex:hierarchyID "3.4.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Implementing category management strategies for customers through the use of consumer insights and understanding of customer specifics. Develop consumer and channel insights. Establish long term strategies, objectives and targets across the brand.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_11521 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Define trade programs and funding options""" ;
    ex:pcfID "11521" ;
    ex:hierarchyID "3.4.2.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing business-to-business marketing campaigns and financial incentives for wholesalers, dealers, distributors and other intermediaries that the company uses to distribute its products or services.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_11466 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Conduct planning activities for major trade customers""" ;
    ex:pcfID "11466" ;
    ex:hierarchyID "3.4.2.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Arranging meetings with trade partners to coordinate logistics, manage critical resources, resolve bottlenecks, and schedule urgent or time-sensitive matters.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_10141 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop partner and alliance management strategies""" ;
    ex:pcfID "10141" ;
    ex:hierarchyID "3.4.2.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Designing strategies for effectively managing, identifying, and countering any possible issues from the alliance partnerships formed. Create a strategic road map for managing the partnerships forged through Design alliance programs and methods for selecting and managing relationships [10139]. Determine where the alliance partnerships are headed, possible problems or pushback from the partners, how these issues might be countered, how these alliance partnerships would evolve in the future, any other business cases where these partnerships might be deployed, etc.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_10142 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish partner and alliance management goals""" ;
    ex:pcfID "10142" ;
    ex:hierarchyID "3.4.2.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Setting targets for organizational achievement. This includes what the organization aims to achieve from and how it wishes to manage both the individual partners and the alliance as a whole. Set immediate through long-term goals including revenue targets, market penetration, footfall numbers, and geographical coverage.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_18629 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish partner and alliance agreements""" ;
    ex:pcfID "18629" ;
    ex:hierarchyID "3.4.2.9" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Setting up strategic alliances with key trade partners and ratifying partnership agreements.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_11522 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop promotional and category management calendars (trade marketing calendars)""" ;
    ex:pcfID "11522" ;
    ex:hierarchyID "3.4.2.10" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Combining scheduled promotional, category management and trade marketing events into unified timetables. Update the calendars. Register new events.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_11523 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create strategic and tactical sales plans by customer""" ;
    ex:pcfID "11523" ;
    ex:hierarchyID "3.4.2.11" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Establishing long term customer sales plans to assess current sales and to determine future sales objectives, strategies for achieving the goals, and available resources.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_11468 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Communicate planning information to customer teams""" ;
    ex:pcfID "11468" ;
    ex:hierarchyID "3.4.2.12" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Sending invitations and distributing information about upcoming events to customer teams and other involved entities.""" ;
    skos:broader ex:PCF_10130 .

ex:PCF_10131 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish overall sales budgets""" ;
    ex:pcfID "10131" ;
    ex:hierarchyID "3.4.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Setting up a financial plan for the sales function. Calculate the estimated sales revenue and costs, which helps in calculating the overall net profit. Create a sound plan for resource outlay by comparing the forecast with historical data.""" ;
    skos:broader ex:PCF_10103 .

ex:PCF_17682 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Calculate product market share""" ;
    ex:pcfID "17682" ;
    ex:hierarchyID "3.4.3.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Determining the percentage of total sales volume in the market for a particular product.""" ;
    skos:broader ex:PCF_10131 .

ex:PCF_10143 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Calculate product revenue""" ;
    ex:pcfID "10143" ;
    ex:hierarchyID "3.4.3.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Estimating revenue from the sale of products/services. Approximate the anticipated sale of products/services and multiply it by the selling price of the respective offering. (This represents the total amount of money that the organization receives from the sale of its portfolio of offerings.)""" ;
    skos:broader ex:PCF_10131 .

ex:PCF_10144 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine variable costs""" ;
    ex:pcfID "10144" ;
    ex:hierarchyID "3.4.3.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Calculating the variable costs of production. Approximate those costs that depend on the volume of products/services produced by the organization.""" ;
    skos:broader ex:PCF_10131 .

ex:PCF_10145 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine overhead and fixed costs""" ;
    ex:pcfID "10145" ;
    ex:hierarchyID "3.4.3.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Calculating the overhead costs associated with selling the organization's products/services. Determine fixed costs that are not directly related to the volume of products/services processed or the sale of these offerings (e.g., expense over machinery and equipment).""" ;
    skos:broader ex:PCF_10131 .

ex:PCF_10146 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Calculate net profit""" ;
    ex:pcfID "10146" ;
    ex:hierarchyID "3.4.3.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Calculating the net income. Calculate the organization's profitability by accounting for Determine overhead and fixed costs [10145] and Determine variable costs [10144].""" ;
    skos:broader ex:PCF_10131 .

ex:PCF_10147 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create budget""" ;
    ex:pcfID "10147" ;
    ex:hierarchyID "3.4.3.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a plan in measurable terms for the financial outlay that best captures resource allocation for the sales forecast. Consider the outlay of capital, HR, raw materials, and provisions needed to reach sales targets.""" ;
    skos:broader ex:PCF_10131 .

ex:PCF_10132 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish sales goals and measures""" ;
    ex:pcfID "10132" ;
    ex:hierarchyID "3.4.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Establishing specific quantitative and qualitative measures of realizing sales targets. Create sales targets by analyzing historical sales data and comparing the forecasts to results, in light of customer and market intelligence. Examine the performance of sales personnel in light of market opportunities. Based on this review, establish sales targets along with metrics to quantify these goals, corresponding with the overall business strategy.""" ;
    skos:broader ex:PCF_10103 .

ex:PCF_10133 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Establish customer management measures""" ;
    ex:pcfID "10133" ;
    ex:hierarchyID "3.4.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Identifying the appropriate measures that can represent key attributes of the customer management function. Select measures to track customer activity, feedback, satisfaction, organizational responsiveness to customer needs, and general data on how the organization is managing customer accounts, leads, and contacts. Build on customer and market intelligence to identify metrics gauging aspects related to customer management. Select measures based on the nature of the business, the type and size of customer base, strategic goals, and the model used to structure sales and customer relationships.""" ;
    skos:broader ex:PCF_10103 .

ex:PCF_10105 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage sales plans""" ;
    ex:pcfID "10105" ;
    ex:hierarchyID "3.5" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Selling products/services. Set appropriate customer expectations. Work with customers using the same schedule that product/service development, production, and customer service functions follow. Manage sales personnel and sales partnerships/alliances.""" ;
    skos:broader ex:PCF_10004 .

ex:PCF_10182 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage leads/opportunities""" ;
    ex:pcfID "10182" ;
    ex:hierarchyID "3.5.1" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Generating leads of prospective customers to grow the organization's business. Identify viable customers based on customer and market research. Discover leads through IT applications, cold calling, reference/network development, or other sales and business development techniques. Employ a scoring model qualify the prospective customers into leads, and prioritize them.""" ;
    skos:broader ex:PCF_10105 .

ex:PCF_10188 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify potential customers""" ;
    ex:pcfID "10188" ;
    ex:hierarchyID "3.5.1.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Identifying people who can be converted into customers. Leverage personal and professional networks, business research over databases and directories, and secondary research.""" ;
    skos:broader ex:PCF_10182 .

ex:PCF_10189 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Identify/receive leads/opportunities""" ;
    ex:pcfID "10189" ;
    ex:hierarchyID "3.5.1.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Qualifying the prospective customers into credible leads by gauging their behavior against the organization's offering. Triangulate leads to increase the efficiency of sales and marketing efforts. Build a detailed profile of the prospects. Determine what products/services they already use, if they have decision-making authority, their views on the products/services they already use, how prone they are to switch, if the organization's solution better in some attributes than those prospects currently use, etc.""" ;
    skos:broader ex:PCF_10182 .

ex:PCF_18115 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Validate and qualify leads/opportunities""" ;
    ex:pcfID "18115" ;
    ex:hierarchyID "3.5.1.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Reviewing the set of potential customers and sales opportunities. Approve the leads that meet company requirements on new businesses.""" ;
    skos:broader ex:PCF_10182 .

ex:PCF_11773 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Match opportunities to business strategy""" ;
    ex:pcfID "11773" ;
    ex:hierarchyID "3.5.1.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Aligning sales leads with business objectives.""" ;
    skos:broader ex:PCF_10182 .

ex:PCF_18116 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop opportunity win plans""" ;
    ex:pcfID "18116" ;
    ex:hierarchyID "3.5.1.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating plans about how to close leads and win sales opportunities. """ ;
    skos:broader ex:PCF_10182 .

ex:PCF_20011 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage opportunity pipeline""" ;
    ex:pcfID "20011" ;
    ex:hierarchyID "3.5.1.6" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Overseeing and planning the acquisition of new customers.""" ;
    skos:broader ex:PCF_10182 .

ex:PCF_10209 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Determine sales resource allocation""" ;
    ex:pcfID "10209" ;
    ex:hierarchyID "3.5.1.7" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Planning the distribution of personnel across various sales functions. Match the capabilities of individual employees with the skill sets needed for specific roles. Seek assistance from HR.""" ;
    skos:broader ex:PCF_10182 .

ex:PCF_10184 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage customer sales calls""" ;
    ex:pcfID "10184" ;
    ex:hierarchyID "3.5.1.8" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing the entire sales process, from using leads to open sales to closing sales and creating records. Govern all sales activities. Make sales calls based on leads and preparatory work (drafting terms of the sale, creating proposals, suggesting prices, etc.). Close the sale, along with any administrative activities related to data entry and the processing of the sale.""" ;
    skos:broader ex:PCF_10182 .

ex:PCF_10190 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform sales calls""" ;
    ex:pcfID "10190" ;
    ex:hierarchyID "3.5.1.8.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Communicating with customers and prospects with the intent of creating sales opportunities. Reach out to existing and prospective customers through alternate media and networking channels, apart from cold calling/emailing.""" ;
    skos:broader ex:PCF_10184 .

ex:PCF_10191 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform pre-sales activities""" ;
    ex:pcfID "10191" ;
    ex:hierarchyID "3.5.1.8.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Capitalizing on sales calls by pitching on bids and closing deals. Outline the nature and scope of the work, draft agreement terms, prepare proposals and agreements, and propose timelines and prices.""" ;
    skos:broader ex:PCF_10184 .

ex:PCF_20012 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage customer meetings/workshops""" ;
    ex:pcfID "20012" ;
    ex:hierarchyID "3.5.1.8.3" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Arranging and leading meetings, seminars, workshops and training events with customers to educate them about current offerings, best practices and technological advances to provide more value to customers and to increase their attrition and loyalty.""" ;
    skos:broader ex:PCF_10184 .

ex:PCF_10192 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Close the sale""" ;
    ex:pcfID "10192" ;
    ex:hierarchyID "3.5.1.8.4" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Formalizing a sale by reaching an agreement on terms of the deal. Negotiate on the price, and reach a consensus on the terms and conditions.""" ;
    skos:broader ex:PCF_10184 .

ex:PCF_10193 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Record outcome of sales process""" ;
    ex:pcfID "10193" ;
    ex:hierarchyID "3.5.1.8.5" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Completing all the paper-work associated with the sale of its products/services. Exchange any pertinent legal/financial information required for completing the sale, signing of a contract/work-order, and issuing copies of bills/invoices.""" ;
    skos:broader ex:PCF_10184 .

ex:PCF_10183 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage customers and accounts""" ;
    ex:pcfID "10183" ;
    ex:hierarchyID "3.5.2" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Managing the customer's expectations, with the intent of responsibly increasing the sale of the organization's products/services. Create a systematic method for governing sales, using sales forecasts and customer management measures. Develop a blueprint to manage relationships with customers and the data it holds on them, as well as the sale of its products/services to these customers. Devise a recipe for handling the organization's key customers in order to manage their expectations with tact and responsibility while maximizing revenue.""" ;
    skos:broader ex:PCF_10105 .

ex:PCF_20013 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Select key customers/accounts""" ;
    ex:pcfID "20013" ;
    ex:hierarchyID "3.5.2.1" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Choosing principal clients that are vital for the company.""" ;
    skos:broader ex:PCF_10183 .

ex:PCF_11173 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop sales/key account plan""" ;
    ex:pcfID "11173" ;
    ex:hierarchyID "3.5.2.2" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Creating a plan for managing the accounts of key customers in order to better maintain relationships with them. Chart a scheme for managing sales. Create a plan for administering accounts of the significant and most important customers of the organization. Coordinate the accounts of principal clients. """ ;
    skos:broader ex:PCF_10183 .

ex:PCF_20014 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage sales/key account plan""" ;
    ex:pcfID "20014" ;
    ex:hierarchyID "3.5.2.3" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Handling the accounts of important clients.""" ;
    skos:broader ex:PCF_10183 .

ex:PCF_11174 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage customer relationships""" ;
    ex:pcfID "11174" ;
    ex:hierarchyID "3.5.2.4" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing the organization's relationship with its customers, by systematically coordinating interactions over multiple touch points, on a regular basis. Coordinate the organization's efforts to reach out to its customers. Create and manage effective touch points for interactions from the customers, which could include emails, social-media interactions, newsletters, and direct conversations.""" ;
    skos:broader ex:PCF_10183 .

ex:PCF_14208 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Manage customer master data""" ;
    ex:pcfID "14208" ;
    ex:hierarchyID "3.5.2.5" ;
    rdfs:comment "APQC level: Activity" ;
    ex:apqcSourceText """Managing the corpus of data relating all customers acquired over time. Manage the storage, maintenance, access, revision, and usage of all data on customers. Ensure its security, and determine legitimate use cases that are beneficial to the organization.""" ;
    skos:broader ex:PCF_10183 .

ex:PCF_16598 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Collect and merge internal and third-party customer information""" ;
    ex:pcfID "16598" ;
    ex:hierarchyID "3.5.2.5.1" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Gathering the data about customers. Combine the information available locally with the data obtained from external sources. """ ;
    skos:broader ex:PCF_14208 .

ex:PCF_16599 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """De-duplicate customer data""" ;
    ex:pcfID "16599" ;
    ex:hierarchyID "3.5.2.5.2" ;
    rdfs:comment "APQC level: Task" ;
    ex:apqcSourceText """Eliminating redundant information in customer data. """ ;
    skos:broader ex:PCF_14208 .

ex:PCF_11779 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Develop and manage sales proposals, bids, and quotes""" ;
    ex:pcfID "11779" ;
    ex:hierarchyID "3.5.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Understanding and refining the customer requirements as provided in a RFP (Request for Proposal) or RFI (Request for Information).  When compiling the response, they must take into consideration whether the requirements are a match with the strategic or tactical plans of the organization and whether they are able to submit a bid/proposal that is competitive based on an understanding of the offerings of other competing organizations. The next step will be to define the pricing and scheduling of the proposed solution and determine whether the proposal will be profitable for the company if accepted. The bid is then submitted and a notification of whether or not it was successful is received.""" ;
    skos:broader ex:PCF_10105 .

ex:PCF_11781 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
