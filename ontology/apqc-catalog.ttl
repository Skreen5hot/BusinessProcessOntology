    ex:apqcSourceText """Creation of conceptual and physical data models as an outline for data structure and storage. """ ;
    skos:broader ex:PCF_20959 .

ex:PCF_21463 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Review data models with stakeholders""" ;
    ex:pcfID "21463" ;
    ex:hierarchyID "13.7.8" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Confirm data models represent the hypothesis supporting the original research question""" ;
    skos:broader ex:PCF_20959 .

ex:PCF_21464 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
