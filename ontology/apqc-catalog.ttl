    ex:pcfID "10731" ;
    ex:hierarchyID "9.4" ;
    rdfs:comment "APQC level: ProcessGroup" ;
    ex:apqcSourceText """Managing accounts for large funds-invested projects. Manage and account for fixed assets projects (capital projects), which required significant capital investments over many years.""" ;
    skos:broader ex:PCF_17058 .

ex:PCF_10751 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Perform capital planning and project approval""" ;
    ex:pcfID "10751" ;
    ex:hierarchyID "9.4.1" ;
