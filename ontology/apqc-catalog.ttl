    ex:pcfID "20960" ;
    ex:hierarchyID "13.7.3" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creating theories that explain empirical data. Use the hypotheses to guide feature selection in the process of data collection.""" ;
    skos:broader ex:PCF_20959 .

ex:PCF_20961 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Collect data""" ;
    ex:pcfID "20961" ;
    ex:hierarchyID "13.7.4" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Gathering and harvesting structured and unstructured data from disparate sources. Clean and pre-process data. Remove duplicates. Convert to a uniform format to make records comparable.""" ;
    skos:broader ex:PCF_20959 .

ex:PCF_21461 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Prepare data""" ;
    ex:pcfID "21461" ;
    ex:hierarchyID "13.7.5" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Creation and validation of data in order to initiate the process of analysis.  """ ;
    skos:broader ex:PCF_20959 .

ex:PCF_20962 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Analyze data""" ;
    ex:pcfID "20962" ;
    ex:hierarchyID "13.7.6" ;
    rdfs:comment "APQC level: Process" ;
    ex:apqcSourceText """Conducting data analysis. Choose statistical algorithms that best reveal patterns and trends in the data. Compare with hypotheses and time series forecasts. Determine error rates and significant outliers. """ ;
    skos:broader ex:PCF_20959 .

ex:PCF_21462 a owl:NamedIndividual, cco:ont00000853, skos:Concept ;
    skos:inScheme apqc:PCF ;
    skos:prefLabel """Create data models""" ;
    ex:pcfID "21462" ;
    ex:hierarchyID "13.7.7" ;
