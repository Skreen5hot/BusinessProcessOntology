# QA (warn): project-minted (ex:) classes that lack an rdfs:label.
# MIT-authored for the Business Process Ontology. Scoped to the ex: namespace.
PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?entity WHERE {
  ?entity a owl:Class .
  FILTER(STRSTARTS(STR(?entity), "http://example.org/apqc#"))
  FILTER NOT EXISTS { ?entity rdfs:label ?label }
}
ORDER BY ?entity
